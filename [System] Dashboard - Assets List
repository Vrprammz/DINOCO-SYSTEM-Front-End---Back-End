                    <?php
                    if ( $days_left < 0 ) {
                        echo '⛔ หมดอายุ ' . esc_html( abs( $days_left ) ) . ' วันที่แล้ว';
                    } elseif ( $days_left <= 30 ) {
                        echo '⏰ เหลือ ' . esc_html( $days_left ) . ' วัน';
