        if (!sn || !policeNo || !station || !date) {
            if (typeof Swal !== 'undefined') {
                Swal.fire('ข้อมูลไม่ครบ', 'กรุณากรอกใบแจ้งความ + สถานีตำรวจ + วันที่เกิดเหตุ', 'warning');
            } else {
                window.alert('กรุณากรอกข้อมูลให้ครบ');
            }
            return false;
        }

        // POST to /dinoco-sn/v1/stolen/report — defensive: 503 if endpoint not synced
        if (typeof toggleLoader === 'function') toggleLoader(true);
        var fd = new FormData();
        fd.append('sn', sn);
        fd.append('product_id', pid);
        fd.append('police_report_no', policeNo);
        fd.append('police_station', station);
        fd.append('incident_date', date);
        fd.append('description', desc);

        var nonceVal = (typeof wpApiSettings !== 'undefined' && wpApiSettings.nonce) ? wpApiSettings.nonce : '';
        var headers = {};
        if (nonceVal) headers['X-WP-Nonce'] = nonceVal;

        fetch('/wp-json/dinoco-sn/v1/stolen/report', { method: 'POST', body: fd, credentials: 'same-origin', headers: headers })
            .then(function(r) {
                return r.json().then(function(d) { return { ok: r.ok, status: r.status, data: d }; });
            })
            .then(function(res) {
                if (typeof toggleLoader === 'function') toggleLoader(false);
                if (res.ok) {
                    dncSnCloseStolenModal();
                    if (typeof Swal !== 'undefined') {
                        Swal.fire('รายงานสำเร็จ', 'แอดมินจะตรวจสอบและติดต่อกลับโดยเร็วที่สุด', 'success').then(function(){ location.reload(); });
                    } else {
                        window.alert('รายงานสำเร็จ');
                        location.reload();
                    }
                } else {
                    var msg = (res.data && res.data.message) || 'ส่งรายงานไม่สำเร็จ — กรุณาติดต่อแอดมินทาง LINE';
                    if (typeof Swal !== 'undefined') {
                        Swal.fire('ไม่สำเร็จ', msg, 'error');
                    } else {
                        window.alert(msg);
                    }
                }
            })
            .catch(function(err) {
                if (typeof toggleLoader === 'function') toggleLoader(false);
                console.error(err);
                // Defensive — endpoint may not be synced yet
                if (typeof Swal !== 'undefined') {
                    Swal.fire('ติดต่อ Admin', 'ไม่สามารถส่งรายงานอัตโนมัติได้ — กรุณาติดต่อแอดมินทาง LINE', 'info');
                } else {
                    window.alert('กรุณาติดต่อแอดมินทาง LINE');
                }
            });
        return false;
    }

    // History timeline toggle (Q28=B default collapsed) + lazy fetch
    function dncSnToggleHistory(btn) {
        var wrap = btn && btn.closest ? btn.closest('.dnc-sn-asset-card-history') : null;
        if (!wrap) return;
        var expanded = wrap.getAttribute('data-expanded') === 'true';
        var newState = !expanded;
        wrap.setAttribute('data-expanded', newState ? 'true' : 'false');
        btn.setAttribute('aria-expanded', newState ? 'true' : 'false');

        if (newState) {
            var list = wrap.querySelector('.dnc-sn-asset-card-history-list');
            if (list && list.getAttribute('data-loaded') !== 'true') {
                dncSnLoadHistory(wrap);
            }
        }
    }

    function dncSnLoadHistory(wrap) {
        var sn = wrap.getAttribute('data-sn');
        var list = wrap.querySelector('.dnc-sn-asset-card-history-list');
        if (!sn || !list) return;
        fetch('/wp-json/dinoco-sn/v1/timeline/' + encodeURIComponent(sn), { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
            .then(function(data) {
                list.innerHTML = '';
                var rows = (data && data.timeline) ? data.timeline : (Array.isArray(data) ? data : []);
                if (!rows.length) {
                    list.innerHTML = '<li class="dnc-sn-asset-card-history-item"><span class="dnc-sn-asset-card-history-icon">📭</span><span class="dnc-sn-asset-card-history-label">ยังไม่มีประวัติ</span></li>';
                } else {
                    rows.forEach(function(row) {
                        var icon  = row.icon  || '•';
                        var label = row.label || row.action || '(ไม่ระบุ)';
                        var date  = row.date  || row.created_at || '';
                        var li = document.createElement('li');
                        li.className = 'dnc-sn-asset-card-history-item';
                        var iconSp = document.createElement('span');
                        iconSp.className = 'dnc-sn-asset-card-history-icon';
                        iconSp.textContent = icon;
                        var labelSp = document.createElement('span');
                        labelSp.className = 'dnc-sn-asset-card-history-label';
                        labelSp.textContent = label;
                        var dateSp = document.createElement('span');
                        dateSp.className = 'dnc-sn-asset-card-history-date';
                        dateSp.textContent = date;
                        li.appendChild(iconSp);
                        li.appendChild(labelSp);
                        li.appendChild(dateSp);
                        list.appendChild(li);
                    });
                }
                list.setAttribute('data-loaded', 'true');
            })
            .catch(function() {
                list.innerHTML = '<li class="dnc-sn-asset-card-history-item"><span class="dnc-sn-asset-card-history-icon">⚠️</span><span class="dnc-sn-asset-card-history-label">โหลดประวัติไม่สำเร็จ</span></li>';
            });
    }

    // Backdrop click → close stolen modal
    document.addEventListener('click', function(e) {
        var modal = document.getElementById('dnc-sn-asset-card-stolen-modal');
        if (!modal) return;
        if (modal.getAttribute('aria-hidden') === 'false' && e.target === modal) {
            dncSnCloseStolenModal();
        }
    });

    // V.31.2 F3 — overflow menu toggle (⋯ เพิ่มเติม) with full keyboard nav.
    // Implements roving tabindex pattern (WAI-ARIA Authoring Practices §menu):
    //   - Only one menu item has tabindex=0 at a time (the "active" one).
    //   - Others have tabindex=-1 so Tab/Shift+Tab skips past them.
    //   - ArrowDown/ArrowUp move focus within open menu (wraps top↔bottom).
    //   - Home/End jump to first/last enabled item.
    //   - Tab + Shift+Tab close the menu and let browser focus move outside
    //     (we don't trap to next page element — closing is the trap exit).
    //   - Esc closes menu + restores focus to the toggle button.
    function _dncSnGetMenuItems(wrap) {
        if (!wrap) return [];
        var menu = wrap.querySelector('.dnc-sn-asset-card-overflow-menu');
        if (!menu) return [];
        return Array.prototype.filter.call(
            menu.querySelectorAll('.dnc-sn-asset-card-overflow-item'),
            function(el) { return !el.disabled && !el.hasAttribute('disabled'); }
        );
    }
    function _dncSnSetActiveMenuItem(wrap, idx) {
        var items = _dncSnGetMenuItems(wrap);
        if (!items.length) return;
        if (idx < 0) idx = items.length - 1;
        if (idx >= items.length) idx = 0;
        items.forEach(function(el, i) {
            el.setAttribute('tabindex', i === idx ? '0' : '-1');
        });
        try { items[idx].focus(); } catch (e) { /* silent */ }
    }
    function _dncSnGetActiveIdx(wrap) {
        var items = _dncSnGetMenuItems(wrap);
        for (var i = 0; i < items.length; i++) {
            if (items[i] === document.activeElement) return i;
        }
        return -1;
    }
    function dncSnToggleOverflow(btn) {
        try {
            var wrap = btn && btn.closest ? btn.closest('.dnc-sn-asset-card-overflow') : null;
            if (!wrap) return;
            var open = wrap.getAttribute('data-open') === 'true';
            // Close all other open menus first (single-open invariant)
            document.querySelectorAll('.dnc-sn-asset-card-overflow[data-open="true"]').forEach(function(el) {
                if (el !== wrap) {
                    el.setAttribute('data-open', 'false');
                    var t = el.querySelector('.dnc-sn-asset-card-overflow-toggle');
                    if (t) t.setAttribute('aria-expanded', 'false');
                    // Reset roving tabindex on closed menu — all items back to -1
                    el.querySelectorAll('.dnc-sn-asset-card-overflow-item').forEach(function(it) {
                        it.setAttribute('tabindex', '-1');
                    });
                }
            });
            wrap.setAttribute('data-open', open ? 'false' : 'true');
            btn.setAttribute('aria-expanded', open ? 'false' : 'true');
            if (!open) {
                // Just opened → focus first enabled item
                _dncSnSetActiveMenuItem(wrap, 0);
            } else {
                // Just closed → reset roving tabindex
                wrap.querySelectorAll('.dnc-sn-asset-card-overflow-item').forEach(function(it) {
                    it.setAttribute('tabindex', '-1');
                });
            }
        } catch (e) { /* silent */ }
    }

    // Keyboard navigation inside open menus (roving tabindex)
    document.addEventListener('keydown', function(e) {
        var wrap = document.activeElement && document.activeElement.closest
            ? document.activeElement.closest('.dnc-sn-asset-card-overflow[data-open="true"]')
            : null;
        if (!wrap) return;
        // Only react if focus is on a menu item (not the toggle)
        var inMenu = document.activeElement && document.activeElement.closest
            && document.activeElement.closest('.dnc-sn-asset-card-overflow-menu');
        if (!inMenu) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            var idx = _dncSnGetActiveIdx(wrap);
            _dncSnSetActiveMenuItem(wrap, idx + 1);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            var idx2 = _dncSnGetActiveIdx(wrap);
            _dncSnSetActiveMenuItem(wrap, idx2 - 1);
        } else if (e.key === 'Home') {
            e.preventDefault();
            _dncSnSetActiveMenuItem(wrap, 0);
        } else if (e.key === 'End') {
            e.preventDefault();
            var lastItems = _dncSnGetMenuItems(wrap);
            _dncSnSetActiveMenuItem(wrap, lastItems.length - 1);
        } else if (e.key === 'Tab') {
            // Close menu + let browser handle Tab natively (focus moves outside).
            // Don't trap inside menu — closing IS the exit pattern for short menus.
            wrap.setAttribute('data-open', 'false');
            var tBtn = wrap.querySelector('.dnc-sn-asset-card-overflow-toggle');
            if (tBtn) tBtn.setAttribute('aria-expanded', 'false');
            wrap.querySelectorAll('.dnc-sn-asset-card-overflow-item').forEach(function(it) {
                it.setAttribute('tabindex', '-1');
            });
            // No preventDefault → browser moves focus to next/prev focusable
        }
    });

    // Outside click → close overflow menus
    document.addEventListener('click', function(e) {
        var t = e.target;
        if (t && t.closest && t.closest('.dnc-sn-asset-card-overflow')) return;
        document.querySelectorAll('.dnc-sn-asset-card-overflow[data-open="true"]').forEach(function(el) {
            el.setAttribute('data-open', 'false');
            var btn = el.querySelector('.dnc-sn-asset-card-overflow-toggle');
            if (btn) btn.setAttribute('aria-expanded', 'false');
            el.querySelectorAll('.dnc-sn-asset-card-overflow-item').forEach(function(it) {
                it.setAttribute('tabindex', '-1');
            });
        });
    });

    // ESC closes any open overflow menu + restores focus to its toggle (F3)
    document.addEventListener('keydown', function(e) {
        if (e.key !== 'Escape') return;
        document.querySelectorAll('.dnc-sn-asset-card-overflow[data-open="true"]').forEach(function(el) {
            el.setAttribute('data-open', 'false');
            var btn = el.querySelector('.dnc-sn-asset-card-overflow-toggle');
            if (btn) {
                btn.setAttribute('aria-expanded', 'false');
                try { btn.focus(); } catch (e2) { /* silent */ }
            }
            el.querySelectorAll('.dnc-sn-asset-card-overflow-item').forEach(function(it) {
                it.setAttribute('tabindex', '-1');
            });
        });
    });

    // Expose for tests / external triggers
    window.dncSnCallDealer       = dncSnCallDealer;
    window.dncSnExtendWarranty   = dncSnExtendWarranty;
    window.dncSnOpenStolenModal  = dncSnOpenStolenModal;
    window.dncSnCloseStolenModal = dncSnCloseStolenModal;
    window.dncSnToggleHistory    = dncSnToggleHistory;
    window.dncSnSubmitStolen     = dncSnSubmitStolen;
    window.dncSnToggleOverflow   = dncSnToggleOverflow;

    </script>
