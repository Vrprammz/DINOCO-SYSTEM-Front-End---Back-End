if ( ! function_exists( 'dinoco_security_log' ) ) {
    function dinoco_security_log( $action, $user_id, $details ) {
        $upload_dir = wp_upload_dir();
        
        // [SECURITY FIX] Use AUTH_SALT (unique per installation) for log filename hash
        $salt = defined( 'AUTH_SALT' ) ? AUTH_SALT : 'dinoco_fallback_salt';
        $secure_hash = hash( 'sha256', $salt . '_dinoco_audit_' . date('Ym') );
        $log_file = $upload_dir['basedir'] . '/.dinoco_audit_' . substr( $secure_hash, 0, 16 ) . '.log';
        
        // [SECURITY FIX] สร้าง .htaccess ดักการเข้าถึงไฟล์ Log (ถ้ายังไม่มี)
        $htaccess_file = $upload_dir['basedir'] . '/.htaccess_dinoco_logs'; 
        
        $timezone = new DateTimeZone('Asia/Bangkok');
        $date = new DateTime('now', $timezone);
        $timestamp = $date->format('Y-m-d H:i:s');
        
        $user_ip = '';
        if ( ! empty( $_SERVER['HTTP_CLIENT_IP'] ) && filter_var( $_SERVER['HTTP_CLIENT_IP'], FILTER_VALIDATE_IP ) ) {
            $user_ip = $_SERVER['HTTP_CLIENT_IP'];
        } elseif ( ! empty( $_SERVER['HTTP_X_FORWARDED_FOR'] ) ) {
            $forwarded_ips = array_map( 'trim', explode( ',', $_SERVER['HTTP_X_FORWARDED_FOR'] ) );
            foreach ( $forwarded_ips as $fip ) {
                if ( filter_var( $fip, FILTER_VALIDATE_IP ) ) {
                    $user_ip = $fip;
                    break;
                }
            }
        }
        if ( empty( $user_ip ) && ! empty( $_SERVER['REMOTE_ADDR'] ) && filter_var( $_SERVER['REMOTE_ADDR'], FILTER_VALIDATE_IP ) ) {
            $user_ip = $_SERVER['REMOTE_ADDR'];
        }
        
        $log_entry = sprintf(
            "[%s] AUTH: User %s | IP: %s | Action: %s | Details: %s" . PHP_EOL,
            $timestamp,
            $user_id,
            $user_ip,
            strtoupper($action),
            $details
        );
        
        @file_put_contents( $log_file, $log_entry, FILE_APPEND | LOCK_EX );
    }
}

