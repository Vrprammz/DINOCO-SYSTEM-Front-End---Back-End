                $dealer_shop_name = $d_post->post_title;
                $phone_field = get_post_meta( $dealer_id, 'phone_number', true );
                if ( empty( $phone_field ) ) {
                    $phone_field = get_post_meta( $dealer_id, 'shop_phone', true );
                }
                $dealer_phone_raw = (string) $phone_field;
                if ( function_exists( 'dinoco_sn_mask_phone_for_call' ) ) {
                    $dealer_phone_masked = dinoco_sn_mask_phone_for_call( $dealer_phone_raw );
                }
            }
        }

        // Disable rules per state
        $is_stolen   = ( $card_state === 'stolen' );
        $is_expired  = ( $card_state === 'expired' );
        $is_claimed  = ( $card_state === 'claimed' );

