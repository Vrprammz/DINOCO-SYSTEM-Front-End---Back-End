if ( ! function_exists( 'dinoco_sn_compute_card_state' ) ) {
    /**
     * V.31.0 — Phase 2 W7.4 asset card state classifier.
     *
     * Pure-logic classifier for the asset card visual state. Reads only
     * fields that exist on a sn_pool row (status / registered_at / stolen_at)
     * — does NOT touch DB. Mirror lives in tests/helpers/SnAssetCardStateTest.php.
     *
     * Priority order:
     *   1. null/missing plate         → 'pending_verification'
     *   2. stolen_at set              → 'stolen'           (highest mutable priority)
     *   3. status=voided/recalled     → 'pending_verification'
     *   4. status=claimed             → 'claimed'
     *   5. status!=registered         → 'pending_verification'
     *   6. days_left < 0              → 'expired'
     *   7. days_left ≤ 30 (inclusive) → 'near_expiry'
     *   8. otherwise                  → 'active'
     *
     * @param object|null $plate    sn_pool row (must expose: status, registered_at, stolen_at)
     * @param int|null    $now_ts   Override for tests (default = time())
     * @return string state slug for data-state attribute on the card
     */
    function dinoco_sn_compute_card_state( $plate, $now_ts = null ) {
        if ( ! is_object( $plate ) ) return 'pending_verification';

        $stolen_at = isset( $plate->stolen_at ) ? $plate->stolen_at : '';
        if ( ! empty( $stolen_at ) && $stolen_at !== '0000-00-00 00:00:00' ) {
            return 'stolen';
        }

        $status = isset( $plate->status ) ? (string) $plate->status : '';
        if ( $status === 'voided' || $status === 'recalled' ) return 'pending_verification';
        if ( $status === 'claimed' )                          return 'claimed';
        if ( $status !== 'registered' )                       return 'pending_verification';

        $registered_at = isset( $plate->registered_at ) ? $plate->registered_at : '';
        if ( empty( $registered_at ) ) return 'pending_verification';

        $reg_ts = strtotime( $registered_at );
        if ( $reg_ts === false ) return 'pending_verification';

        $now       = is_int( $now_ts ) ? $now_ts : time();
        $end_ts    = $reg_ts + ( 365 * 86400 );          // 1y default warranty
        $days_left = (int) floor( ( $end_ts - $now ) / 86400 );

        if ( $days_left < 0 )   return 'expired';
        if ( $days_left <= 30 ) return 'near_expiry';
        return 'active';
    }
}

if ( ! function_exists( 'dinoco_sn_mask_phone_for_call' ) ) {
    /**
     * V.31.0 — Phase 2 W7.4 F#6 Click-to-Call display masking.
     *
     * Returns a masked rendering of the phone number for visible UI,
     * keeping only first 3 + last 4 digits (e.g. 0812345678 → "08x-xxx-5678").
     * Full number stays in data-attribute for the tap-to-call action.
     *
     * @param string $phone_raw raw 10-digit phone (numbers only or with hyphens)
     * @return string masked rendering, or empty when phone invalid
     */
    function dinoco_sn_mask_phone_for_call( $phone_raw ) {
        $digits = preg_replace( '/[^0-9]/', '', (string) $phone_raw );
        if ( strlen( $digits ) < 9 ) return '';
        $head = substr( $digits, 0, 3 );
        $tail = substr( $digits, -4 );
        return $head . '-xxx-' . $tail;
    }
}

if ( ! function_exists( 'dinoco_sn_render_asset_card_extension' ) ) {
