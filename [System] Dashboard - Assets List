        // Defensive defaults
        $sn = (string) $sn;
        $pid = (int) $pid;
        $card_state = (string) $card_state;

        // Cold meta lookup (purchase_dealer_id, purchase_date, etc.)
        $plate_meta = ( ! empty( $sn ) && function_exists( 'dinoco_sn_get_plate_meta' ) )
            ? dinoco_sn_get_plate_meta( $sn ) : null;

        $dealer_id    = $plate_meta && isset( $plate_meta->purchase_dealer_id ) ? (int) $plate_meta->purchase_dealer_id : 0;
        $purchase_date = $plate_meta && isset( $plate_meta->purchase_date ) ? (string) $plate_meta->purchase_date : '';

        // Derive days_left for progress bar (registered + 1y default)
        $days_left = null;
        $days_pct = 0;
        if ( $card_state !== 'pending_verification' && ! empty( $plate->registered_at ) ) {
            $reg_ts = strtotime( $plate->registered_at );
            if ( $reg_ts !== false ) {
                $end_ts    = $reg_ts + ( 365 * 86400 );
                $now       = time();
                $secs_left = $end_ts - $now;
                $days_left = (int) floor( $secs_left / 86400 );
                $days_pct = max( 0, min( 100, (int) round( ( $secs_left / ( 365 * 86400 ) ) * 100 ) ) );
            }
