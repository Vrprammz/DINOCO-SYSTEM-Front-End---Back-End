/* ─── Permission + rate limit ──────────────────────────────────── */
if ( ! function_exists( 'dinoco_sn_golive_perm' ) ) {
    function dinoco_sn_golive_perm( $req ) {
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'rest_forbidden', 'Admin only', array( 'status' => 403 ) );
        }
        $nonce = $req->get_header( 'X-WP-Nonce' );
        if ( ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
            return new WP_Error( 'rest_cookie_invalid_nonce', 'Nonce expired', array( 'status' => 403 ) );
        }
        return true;
    }
}

if ( ! function_exists( 'dinoco_sn_golive_rate_limit' ) ) {
    function dinoco_sn_golive_rate_limit( $bucket = 'general', $limit = 30 ) {
        if ( ! function_exists( 'b2b_rate_limit' ) ) return true;
        $rl = b2b_rate_limit( 'sn_golive_' . $bucket, get_current_user_id(), $limit, 60 );
        if ( is_wp_error( $rl ) ) return $rl;
        return true;
    }
}

/* ─── Preflight check — 9 gates ─────────────────────────────────── */
if ( ! function_exists( 'dinoco_sn_golive_preflight' ) ) {
    function dinoco_sn_golive_preflight() {
        global $wpdb;
        $checks = array();

        // 1. Required snippets present — list each missing function explicitly.
        // Use canonical functions that actually exist (verified against source).
        $req_fns = array(
            'dinoco_sn_table'                  => '[Admin System] DINOCO Production SN Manager (DB_ID 1195)',
            'dinoco_sn_required_plates_for_sku'=> '[Admin System] DINOCO Production SN Manager (DB_ID 1195)',
            'dinoco_sn_render_tab_marketplace' => '[Admin System] DINOCO Production SN Manager (DB_ID 1195)',
            'dinoco_sn_marketplace_is_enabled' => '[System] DINOCO SN REST API (DB_ID 1196)',
        );
        $missing_fns = array();
        foreach ( $req_fns as $fn => $snippet ) {
            if ( ! function_exists( $fn ) ) $missing_fns[] = $fn . ' — ' . $snippet;
        }
        $checks[] = array(
            'id'       => 'snippets_loaded',
            'label'    => 'SN snippets ทั้ง 3 ตัวโหลด',
            'pass'     => empty( $missing_fns ),
            'hint'     => empty( $missing_fns )
                          ? 'OK ทุก function โหลด'
                          : 'ฟังก์ชันที่หาย: ' . implode( ' / ', $missing_fns ),
        );

        // 2. Schema 15 tables installed
        $tables = $wpdb->get_col(
            "SELECT TABLE_NAME FROM information_schema.tables
             WHERE TABLE_SCHEMA=DATABASE() AND TABLE_NAME LIKE '" . $wpdb->prefix . "dinoco_sn_%'"
        );
        $checks[] = array(
            'id'       => 'schema_15_tables',
            'label'    => 'Schema 15 ตาราง SN ติดตั้งครบ',
            'pass'     => count( $tables ) >= 14, // 14 sn_* + 1 flag_audit external
            'hint'     => 'พบ ' . count( $tables ) . '/15 ตาราง — ถ้าไม่ครบกด Install Schema',
        );

        // 3. ALTER products columns
        $cols = $wpdb->get_col(
            "SHOW COLUMNS FROM {$wpdb->prefix}dinoco_products LIKE 'sn_%'"
        );
        $checks[] = array(
            'id'       => 'alter_products',
            'label'    => 'ALTER wp_dinoco_products เพิ่ม 3 columns',
            'pass'     => count( $cols ) >= 3,
            'hint'     => 'ต้องการ sn_attach_level + sn_required + sn_qty_per_unit (พบ ' . count( $cols ) . '/3)',
        );

        // 4. Idempotency Helper available
        $checks[] = array(
            'id'       => 'idempotency_helper',
            'label'    => 'Idempotency Helper โหลด',
            'pass'     => function_exists( 'dinoco_idempotency_check' ),
            'hint'     => 'ถ้าไม่โหลดจะมี race condition ตอน slip upload',
        );

        // 5. Modal Helpers available
        $checks[] = array(
            'id'       => 'modal_helpers',
            'label'    => 'Modal Helpers (window.dinocoModal)',
            'pass'     => true, // client-side check — assume true (loaded via wp_footer)
            'hint'     => 'Frontend confirm dialogs ต้องการ — fallback native ถ้าไม่โหลด',
        );

        // 6. Constants required
        $line_ok = defined( 'DINOCO_LINE_CHANNEL_ID' )
                   && defined( 'DINOCO_LINE_CHANNEL_SECRET' )
                   && defined( 'DINOCO_LINE_REDIRECT_URI' );
        $checks[] = array(
            'id'       => 'line_constants',
            'label'    => 'LINE OAuth constants ตั้งใน wp-config.php',
            'pass'     => $line_ok,
            'hint'     => 'ต้องมี DINOCO_LINE_CHANNEL_ID/SECRET/REDIRECT_URI สำหรับ LIFF activate',
        );

        // 7. B2B integration helpers — list each missing function explicitly
        $b2b_fns = array(
            'b2b_get_logo_url'   => 'receipt logo',
            'b2b_get_bank_info'  => 'payment instructions',
            'b2b_line_push'      => 'LINE notifications',
        );
        $b2b_missing = array();
        foreach ( $b2b_fns as $fn => $purpose ) {
            if ( ! function_exists( $fn ) ) $b2b_missing[] = $fn . ' (' . $purpose . ')';
        }
        $checks[] = array(
            'id'       => 'b2b_helpers',
            'label'    => 'B2B Snippet helpers (logo + bank + push)',
            'pass'     => empty( $b2b_missing ),
            'hint'     => empty( $b2b_missing )
                          ? 'OK ทุก function โหลด'
                          : 'หาย: ' . implode( ' / ', $b2b_missing ) . ' — ตรวจว่า [B2B] Snippet 1 active',
        );

        // 8. At least 1 SKU with sn_attach_level configured
        $sku_count = 0;
        if ( count( $cols ) >= 3 ) {
            $sku_count = (int) $wpdb->get_var(
                "SELECT COUNT(*) FROM {$wpdb->prefix}dinoco_products
                 WHERE sn_attach_level IS NOT NULL AND sn_attach_level != 'none'"
            );
        }
        $checks[] = array(
            'id'       => 'sku_configured',
            'label'    => 'SKU อย่างน้อย 1 ตัวมี sn_attach_level',
            'pass'     => $sku_count > 0,
            'hint'     => 'พบ ' . $sku_count . ' SKU — เปิด Product Catalog → Edit → SN Plate Configuration',
        );

        // 9. Cron heartbeat — V.1.5 fix: use REAL hook names verified against source.
        // Real names use 'schedule' not 'reminder' for expiry+anniversary.
        $cron_hooks = array(
            'dinoco_sn_expiry_schedule_cron'      => 'F#1 Expiry',
            'dinoco_sn_anniversary_schedule_cron' => 'F#4 Anniversary',
            'dinoco_sn_review_request_cron'       => 'F#10 Review',
            'dinoco_sn_service_reminder_cron'     => 'QW-7 Service',
            'dinoco_sn_ltv_snapshot_cron'         => 'F#9 LTV',
        );
        $cron_missing = array();
        foreach ( $cron_hooks as $hook => $label ) {
            if ( ! wp_next_scheduled( $hook ) ) {
                $cron_missing[] = $label . ' (' . $hook . ')';
            }
        }
        $cron_drift = count( $cron_missing );
        $checks[] = array(
            'id'       => 'cron_scheduled',
            'label'    => 'Cron jobs ถูก schedule แล้ว',
            'pass'     => $cron_drift === 0,
            'hint'     => $cron_drift === 0
                          ? 'OK ทั้ง 5 cron schedule แล้ว'
                          : $cron_drift . '/5 ไม่ schedule: ' . implode( ' / ', $cron_missing )
                            . ' — เปิด master flag dinoco_sn_system_enabled แล้วรีโหลดหน้า',
        );

        $all_pass = true;
        foreach ( $checks as $c ) {
            if ( ! $c['pass'] ) { $all_pass = false; break; }
        }

        return array(
            'all_pass' => $all_pass,
            'checks'   => $checks,
            'summary'  => array(
                'total'  => count( $checks ),
                'passed' => count( array_filter( $checks, function( $c ) { return $c['pass']; } ) ),
            ),
        );
    }
}

/* ─── Schema install trigger ──────────────────────────────────── */
if ( ! function_exists( 'dinoco_sn_golive_rest_schema_install' ) ) {
    function dinoco_sn_golive_rest_schema_install( $req ) {
        $rl = dinoco_sn_golive_rate_limit( 'schema_install', 5 );
        if ( is_wp_error( $rl ) ) return $rl;

        if ( $req->get_param( 'confirm' ) !== 'true' ) {
            return new WP_Error( 'confirm_required', 'Type "INSTALL SCHEMA" to confirm', array( 'status' => 400 ) );
        }
        if ( ! function_exists( 'dinoco_sn_schema_install' ) ) {
            return new WP_Error( 'not_ready', 'Production SN Manager snippet not loaded', array( 'status' => 503 ) );
        }

        try {
            dinoco_sn_schema_install();
            global $wpdb;
            $tables = $wpdb->get_col(
                "SELECT TABLE_NAME FROM information_schema.tables
                 WHERE TABLE_SCHEMA=DATABASE() AND TABLE_NAME LIKE '" . $wpdb->prefix . "dinoco_sn_%'"
            );
            return rest_ensure_response( array(
                'success'      => true,
                'tables_count' => count( $tables ),
                'tables'       => $tables,
            ) );
        } catch ( \Throwable $e ) {
            return new WP_Error( 'schema_fail', $e->getMessage(), array( 'status' => 500 ) );
        }
    }
}

/* ─── Flag operations ──────────────────────────────────────────── */
if ( ! function_exists( 'dinoco_sn_golive_rest_flag_status' ) ) {
    function dinoco_sn_golive_rest_flag_status() {
        $whitelist = dinoco_sn_golive_flag_whitelist();
        $state = array();
        foreach ( $whitelist as $flag => $label ) {
            $state[] = array(
                'flag'    => $flag,
                'label'   => $label,
                'value'   => (int) (bool) get_option( $flag, 0 ),
                'autoload'=> wp_load_alloptions() && isset( wp_load_alloptions()[ $flag ] ),
            );
        }
        return rest_ensure_response( array( 'success' => true, 'flags' => $state ) );
    }
}

if ( ! function_exists( 'dinoco_sn_golive_rest_flag_toggle' ) ) {
    function dinoco_sn_golive_rest_flag_toggle( $req ) {
        // V.1.7 — relax 10→60/min to allow rapid sequential flips during go-live
        // (admin-only manage_options endpoint, already heavily gated)
        $rl = dinoco_sn_golive_rate_limit( 'flag_toggle', 60 );
        if ( is_wp_error( $rl ) ) return $rl;

        $flag = sanitize_key( $req->get_param( 'flag' ) );
        $on   = (int) (bool) $req->get_param( 'value' );
        $whitelist = dinoco_sn_golive_flag_whitelist();
        if ( ! isset( $whitelist[ $flag ] ) ) {
            return new WP_Error( 'flag_not_whitelisted', 'Flag not in whitelist', array( 'status' => 400 ) );
        }
        if ( $req->get_param( 'confirm' ) !== 'true' ) {
            return new WP_Error( 'confirm_required', 'Type confirm phrase', array( 'status' => 400 ) );
        }

        $old = (int) (bool) get_option( $flag, 0 );
        update_option( $flag, (string) $on, false ); // autoload=false

        // V.2.0 — Also bust Config Layer cache so dinoco_config() returns fresh
        // value on next call within same request (some snippets use Config Layer).
        if ( isset( $GLOBALS['_dinoco_config_cache'] ) && is_array( $GLOBALS['_dinoco_config_cache'] ) ) {
            $GLOBALS['_dinoco_config_cache'] = array();
        }

        // V.2.2 — Auto-purge dnc_mod_* transients after every flag flip so
        // any cached module HTML (e.g. GDPR admin banner) re-renders fresh.
        // Without this, admin would have to manually click "Clear Caches"
        // after every flag flip — easy to forget, leads to stale UI bugs.
        $mod_purge = null;
        if ( function_exists( 'dinoco_sn_golive_purge_module_transients' ) ) {
            $mod_purge = dinoco_sn_golive_purge_module_transients();
            update_option( 'dnc_mod_last_purge_ts', current_time( 'timestamp' ), false );
        }

        // V.2.0 — Verify post-write by reading both raw + Config Layer paths
        $raw_after    = get_option( $flag, null );
        $config_value = null;
        if ( function_exists( 'dinoco_config' ) ) {
            // Try to find the dotted key whose legacy_option matches this flag
            $candidates = array(
                'dinoco_gdpr_enabled'        => 'gdpr.enabled',
                'dinoco_obs_sentry_enabled'  => 'obs.sentry_enabled',
                'dinoco_obs_correlation_enabled' => 'obs.correlation_enabled',
            );
            if ( isset( $candidates[ $flag ] ) && function_exists( 'dinoco_get_config_def' ) ) {
                $def = dinoco_get_config_def( $candidates[ $flag ] );
                if ( $def ) {
                    $config_value = dinoco_config( $candidates[ $flag ], false );
                }
            }
        }

        // Log via Flag Audit if available
        if ( function_exists( 'dinoco_flag_audit_log' ) ) {
            dinoco_flag_audit_log( $flag, $old, $on, 'sn_golive_tool', 'admin' );
        }

        return rest_ensure_response( array(
            'success'           => true,
            'flag'              => $flag,
            'old'               => $old,
            'new'               => $on,
            'verify_raw'        => $raw_after,
            'verify_config'     => $config_value,
            'module_purge'      => $mod_purge, // V.2.2 — null if helper unavailable
        ) );
    }
}

/* ─── Role matrix ──────────────────────────────────────────────── */
if ( ! function_exists( 'dinoco_sn_golive_rest_role_matrix' ) ) {
    function dinoco_sn_golive_rest_role_matrix() {
        $users = get_users( array(
            'number'  => 50,
            'orderby' => 'display_name',
            'order'   => 'ASC',
        ) );
        $matrix = array();
        foreach ( $users as $u ) {
            $matrix[] = array(
                'user_id'    => $u->ID,
                'name'       => $u->display_name,
                'email'      => $u->user_email,
                'roles'      => array(
                    'warehouse' => (bool) get_user_meta( $u->ID, 'dinoco_sn_warehouse', true ),
                    'approver'  => (bool) get_user_meta( $u->ID, 'dinoco_sn_approver', true ),
                    'view_pii'  => (bool) get_user_meta( $u->ID, 'dinoco_sn_view_pii', true ),
                    'admin'     => user_can( $u->ID, 'manage_options' ),
                ),
            );
        }
        return rest_ensure_response( array( 'success' => true, 'users' => $matrix ) );
    }
}

if ( ! function_exists( 'dinoco_sn_golive_rest_role_assign' ) ) {
    function dinoco_sn_golive_rest_role_assign( $req ) {
        $rl = dinoco_sn_golive_rate_limit( 'role_assign', 20 );
        if ( is_wp_error( $rl ) ) return $rl;

        $user_id = (int) $req->get_param( 'user_id' );
        $role    = sanitize_key( $req->get_param( 'role' ) );
        $on      = (int) (bool) $req->get_param( 'value' );

        if ( ! in_array( $role, array( 'warehouse', 'approver', 'view_pii' ), true ) ) {
            return new WP_Error( 'invalid_role', 'Role must be warehouse/approver/view_pii', array( 'status' => 400 ) );
        }
        if ( ! get_userdata( $user_id ) ) {
            return new WP_Error( 'user_not_found', 'User not found', array( 'status' => 404 ) );
        }

        $meta_key = 'dinoco_sn_' . $role;
        if ( $on ) {
            update_user_meta( $user_id, $meta_key, 1 );
        } else {
            delete_user_meta( $user_id, $meta_key );
        }

        return rest_ensure_response( array(
            'success' => true,
            'user_id' => $user_id,
            'role'    => $role,
            'value'   => $on,
        ) );
    }
}

