            </div>

            <!-- Stage 1: Preflight -->
            <div class="gl-stage">
                <h3><span class="gl-num">1</span>Preflight Check — ตรวจระบบก่อน</h3>
                <button class="gl-btn" data-action="preflight">↻ รัน Preflight</button>
                <div id="gl-preflight-result" style="margin-top: 12px;"></div>
            </div>

            <!-- Stage 2: Schema Install -->
            <div class="gl-stage">
                <h3><span class="gl-num">2</span>Schema Install — ติดตั้ง 15 ตาราง SN</h3>
                <p class="gl-hint">ปกติ lazy install ทำให้อัตโนมัติแล้ว — กดถ้า preflight check #2/3 ไม่ผ่าน</p>
                <button class="gl-btn" data-action="schema-install">📦 Install Schema</button>
                <div id="gl-schema-result" style="margin-top: 12px;"></div>
            </div>

            <!-- Stage 3: Role Matrix -->
            <div class="gl-stage">
                <h3><span class="gl-num">3</span>Role Matrix — กำหนดสิทธิ์ผู้ใช้</h3>
                <button class="gl-btn" data-action="role-load">↻ โหลดรายชื่อ</button>
                <div id="gl-role-table" style="margin-top: 12px;"></div>
            </div>

            <!-- Stage 4: Flag Control -->
            <div class="gl-stage" id="gl-stage-flags">
                <h3><span class="gl-num">4</span>Feature Flags — เปิด/ปิดระบบทีละตัว</h3>
                <div class="gl-banner warn">
                    ⚠️ <strong>ลำดับแนะนำ:</strong> Master Kill Switch (1) → Marketplace (1) → Notifications (5) → Agent Webhook (1) → GDPR (1) → Sentry (2)
                </div>
                <button class="gl-btn" data-action="flag-load">↻ โหลดสถานะ Flags</button>
                <div id="gl-flag-table" style="margin-top: 12px;"></div>
            </div>

            <!-- Stage 5: Monitor -->
            <div class="gl-stage">
                <h3><span class="gl-num">5</span>Monitor — ดูสถานะระบบ 24 ชม.</h3>
                <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
                    <button class="gl-btn" data-action="monitor-load">↻ Refresh</button>
                    <button class="gl-btn" data-action="reschedule-crons" style="background:#b45309;">🔧 Force Reschedule Crons</button>
                    <button class="gl-btn" data-action="clear-caches" style="background:#7c3aed;">🧹 Clear Caches</button>
                    <button class="gl-btn" data-action="diagnose-gdpr" style="background:#1f2937;">🔬 วินิจฉัย GDPR Flag</button>
                </div>
                <div id="gl-monitor-result" style="margin-top: 12px;"></div>
                <div id="gl-diagnose-result" style="margin-top: 12px;"></div>
            </div>
        </div>

        <script>
        (function() {
            var ROOT = document.querySelector('.dnc-sn-gl');
            if (!ROOT) return;
            var NONCE = ROOT.getAttribute('data-nonce');
            var BASE = '/wp-json/dinoco-sn-golive/v1';

            function toast(msg, isError) {
                var t = document.createElement('div');
                t.className = 'gl-toast';
                if (isError) t.style.background = '#dc2626';
                t.textContent = msg;
                document.body.appendChild(t);
                setTimeout(function() { t.remove(); }, 3500);
            }

            function api(method, path, body) {
                var opts = {
                    method: method,
                    headers: { 'X-WP-Nonce': NONCE, 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                };
                if (body) opts.body = JSON.stringify(body);
                return fetch(BASE + path, opts).then(function(r) {
                    return r.json().then(function(d) {
                        if (!r.ok) throw new Error(d.message || ('HTTP ' + r.status));
                        return d;
                    });
                });
            }

            function esc(s) {
                if (s === null || s === undefined) return '';
                return String(s).replace(/[&<>"']/g, function(c) {
                    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
                });
            }

            function renderPreflight(data) {
                var html = '<div class="gl-banner ' + (data.all_pass ? 'success' : 'warn') + '">';
                html += '<strong>' + data.summary.passed + '/' + data.summary.total + ' checks pass</strong> ';
                html += data.all_pass ? '— พร้อมเปิดระบบ ✅' : '— แก้ปัญหาก่อนเปิด';
                html += '</div>';
                html += '<table class="gl-table">';
                data.checks.forEach(function(c) {
                    html += '<tr><td>' + (c.pass ? '✅' : '❌') + '</td>';
                    html += '<td><strong>' + esc(c.label) + '</strong>';
                    if (!c.pass) html += '<div class="gl-hint">' + esc(c.hint) + '</div>';
                    html += '</td></tr>';
                });
                html += '</table>';

                // V.1.6 — Next-step CTA when all checks pass
                if (data.all_pass) {
                    html += '<div class="gl-banner success" style="margin-top:16px;font-size:15px;">';
                    html += '<strong>🎯 ขั้นต่อไป — กดเปิด Feature Flags ใน Stage 4 ด้านล่าง</strong>';
                    html += '<div style="margin-top:6px;font-size:13px;">';
                    html += 'Preflight แค่ตรวจสถานะ ไม่ได้เปิดระบบให้. ต้องเลื่อนลงไป Stage 4 → กดโหลด → flip flag <code>dinoco_sn_system_enabled</code> + flags อื่นๆ ทีละตัว.';
                    html += '</div>';
                    html += '<div style="margin-top:10px;">';
                    html += '<button class="gl-btn success" data-action="jump-to-flags">⬇ ไป Stage 4 Feature Flags</button>';
                    html += '</div>';
                    html += '</div>';
                }

                document.getElementById('gl-preflight-result').innerHTML = html;
            }

            function renderRoleMatrix(users) {
                var html = '<table class="gl-table"><thead><tr><th>ผู้ใช้</th><th>Email</th><th>คลัง</th><th>Approver</th><th>View PII</th><th>Admin</th></tr></thead><tbody>';
                users.forEach(function(u) {
                    html += '<tr data-uid="' + u.user_id + '">';
                    html += '<td><strong>' + esc(u.name) + '</strong></td>';
                    html += '<td>' + esc(u.email) + '</td>';
                    ['warehouse', 'approver', 'view_pii'].forEach(function(role) {
                        var on = u.roles[role];
                        html += '<td><button class="' + (on ? 'gl-on' : 'gl-off') + '" data-role-toggle="' + role + '" data-uid="' + u.user_id + '" data-current="' + (on ? '1' : '0') + '">' + (on ? '✓ เปิด' : 'ปิด') + '</button></td>';
                    });
                    html += '<td>' + (u.roles.admin ? '🛡️' : '—') + '</td>';
                    html += '</tr>';
                });
                html += '</tbody></table>';
                document.getElementById('gl-role-table').innerHTML = html;
            }

            function renderFlagTable(flags) {
                var html = '<table class="gl-table"><thead><tr><th>Flag</th><th>คำอธิบาย</th><th>สถานะ</th></tr></thead><tbody>';
                flags.forEach(function(f) {
                    var on = f.value === 1;
                    html += '<tr><td><code style="font-size:11px;">' + esc(f.flag) + '</code></td>';
                    html += '<td>' + esc(f.label) + '</td>';
                    html += '<td><button class="' + (on ? 'gl-on' : 'gl-off') + '" data-flag-toggle="' + esc(f.flag) + '" data-current="' + (on ? '1' : '0') + '">' + (on ? '✓ เปิด' : 'ปิด') + '</button></td>';
                    html += '</tr>';
                });
                html += '</tbody></table>';
                document.getElementById('gl-flag-table').innerHTML = html;
            }

            function renderDiagnose(data) {
                // V.2.4 — Render diagnose-flag response as parsed verdict + raw JSON
                var paths = data.paths || {};
                var verdicts = [];

                // 1) Raw get_option
                var raw = paths.raw_get_option || {};
                var rawExists = !!raw.exists;
                var rawVal = raw.value;
                var rawValDisplay = (rawVal === null || rawVal === undefined) ? '(null)' : JSON.stringify(rawVal);
                verdicts.push({
                    pass: rawExists && rawVal === '1',
                    label: 'Raw option (<code>get_option(\'' + esc(data.flag) + '\')</code>)',
                    detail: rawExists
                        ? ('value: <code>' + esc(rawValDisplay) + '</code> · type: <code>' + esc(raw.value_type) + '</code>')
                        : '<strong style="color:#dc2626;">option ไม่มีใน wp_options เลย</strong> — บอสยังไม่ได้กดเปิดใน Stage 4'
                });

                // 2) Strict === '1' check (legacy fallback path)
                var strictPass = !!paths.strict_eq_string_1;
                verdicts.push({
                    pass: strictPass,
                    label: 'Strict <code>=== \'1\'</code> check (legacy fallback path)',
                    detail: strictPass
                        ? 'ผ่าน — ถ้า Config Layer ไม่ทำงาน path เก่าจะคืน true อย่างน้อย'
                        : '<strong style="color:#dc2626;">ไม่ผ่าน</strong> — ค่า raw ไม่ใช่ string <code>\'1\'</code> เป๊ะ ๆ (อาจเป็น <code>1</code> int, <code>true</code> bool, หรือ <code>\'on\'</code>) → legacy fallback คืน false'
                });

                // 3) Config Layer
                var cfg = paths.config_layer || {};
                if (cfg.dotted_key) {
                    var cfgFnExists = !!cfg.function_exists_dinoco_config;
                    var defReg = !!cfg.def_registered;
                    var resolvedMatch = !!cfg.resolved_option_matches;

                    verdicts.push({
                        pass: cfgFnExists,
                        label: 'Config Layer functions loaded',
                        detail: cfgFnExists
                            ? '<code>dinoco_config()</code> + <code>dinoco_get_config_def()</code> พร้อมใช้'
                            : '<strong style="color:#dc2626;">Config Layer snippet ไม่ทำงาน</strong> — GDPR fallback ไป path เก่า'
                    });

                    verdicts.push({
                        pass: defReg,
                        label: 'Schema <code>gdpr.enabled</code> registered',
                        detail: defReg
                            ? 'type: <code>' + esc(cfg.def_type || '') + '</code> · legacy_option: <code>' + esc(cfg.def_legacy_option || '') + '</code>'
                            : '<strong style="color:#dc2626;">def ยังไม่ถูก register</strong> — hook init priority 10 ของ Config Layer ยังไม่ fire (race condition)'
                    });

                    if (cfg.resolved_option_key) {
                        verdicts.push({
                            pass: resolvedMatch,
                            label: 'Resolved option key matches request',
                            detail: 'Config Layer mapped <code>' + esc(cfg.dotted_key) + '</code> → <code>' + esc(cfg.resolved_option_key) + '</code>' +
                                    (resolvedMatch ? '' : ' <strong style="color:#dc2626;">≠ ' + esc(data.flag) + '</strong> (legacy_option ผิด)')
                        });
                    }

                    if ('dinoco_config_returns' in cfg) {
                        var cfgVal = cfg.dinoco_config_returns;
                        var cfgValDisplay = JSON.stringify(cfgVal);
                        var boolCast = !!cfg.bool_cast;
                        verdicts.push({
                            pass: boolCast,
                            label: 'Config Layer resolved value (<code>dinoco_config(\'gdpr.enabled\')</code>)',
                            detail: 'returns: <code>' + esc(cfgValDisplay) + '</code> · type: <code>' + esc(cfg.dinoco_config_type) + '</code> · (bool): <code>' + (boolCast ? 'true' : 'false') + '</code>' +
                                    (boolCast ? '' : ' <strong style="color:#dc2626;">— coerce ตีค่าเป็น false (อาจเป็นเพราะ raw ไม่ใช่ \'1\'/1/\'true\'/true)</strong>')
                        });
                    }
                }

                // 4) GDPR-specific
                if (paths.dinoco_gdpr_is_enabled) {
                    var gdpr = paths.dinoco_gdpr_is_enabled;
                    var gdprFn = !!gdpr.function_exists;
                    var gdprRet = !!gdpr.returns;
                    verdicts.push({
                        pass: gdprFn,
                        label: '<code>dinoco_gdpr_is_enabled()</code> function exists',
                        detail: gdprFn ? 'GDPR snippet loaded' : '<strong style="color:#dc2626;">GDPR snippet ไม่ active</strong>'
                    });
                    if (gdprFn) {
                        verdicts.push({
                            pass: gdprRet,
                            label: '<code>dinoco_gdpr_is_enabled()</code> returns',
                            detail: '<strong>' + (gdprRet ? '✅ TRUE (banner ควร ACTIVE)' : '❌ FALSE (banner จะแสดง FLAG OFF)') + '</strong>'
                        });
                    }
                }

                // Compose final verdict banner
                var finalPass = !!(paths.dinoco_gdpr_is_enabled && paths.dinoco_gdpr_is_enabled.returns);
                var html = '<div class="gl-banner ' + (finalPass ? 'success' : 'warn') + '">';
                html += '<strong>🔬 ผล Diagnose Flag <code>' + esc(data.flag) + '</code>:</strong> ';
                html += finalPass
                    ? '<span style="color:#065f46;">ระบบเปิดอยู่จริง — ถ้าหน้า banner ยังขึ้น OFF = cache layer อื่นที่เรายังไม่ได้ purge (เช่น CDN, Cloudflare, ServiceWorker)</span>'
                    : '<span style="color:#92400e;">ระบบยัง OFF จริง — ดู verdict ด้านล่างว่า path ไหนตก</span>';
                html += '</div>';

                html += '<table class="gl-table"><thead><tr><th style="width:30px;"></th><th>Check</th><th>Detail</th></tr></thead><tbody>';
                verdicts.forEach(function(v) {
                    html += '<tr><td>' + (v.pass ? '✅' : '❌') + '</td>';
                    html += '<td>' + v.label + '</td>';
                    html += '<td style="font-size:12px;">' + v.detail + '</td></tr>';
                });
                html += '</tbody></table>';

                // Raw JSON for boss to screenshot to support
                html += '<details style="margin-top:12px;"><summary style="cursor:pointer;font-weight:bold;color:#1A3A5C;">📋 Raw JSON response (กดเพื่อขยาย / copy-paste ส่งกลับ)</summary>';
                html += '<pre style="background:#f3f4f6;border:1px solid #e5e7eb;border-radius:6px;padding:12px;margin-top:6px;font-size:11px;font-family:Menlo,Monaco,monospace;overflow-x:auto;max-height:400px;overflow-y:auto;white-space:pre-wrap;word-break:break-all;">';
                html += esc(JSON.stringify(data, null, 2));
                html += '</pre></details>';

                // Action hints based on findings
                var hints = [];
                if (!rawExists) {
                    hints.push('1. ไป Stage 4 → กด "↻ โหลดสถานะ Flags" → flip <code>dinoco_gdpr_enabled</code> ON');
                } else if (rawVal !== '1') {
                    hints.push('1. <strong>Raw value ผิด format</strong>: ค่าตอนนี้ <code>' + esc(rawValDisplay) + '</code> — Go-Live Tool flag-toggle เขียน <code>\'1\'</code>/<code>\'0\'</code> string. ถ้าบอสไป update_option เองด้วยค่าอื่น (เช่น <code>1</code> int หรือ <code>true</code>) ให้กลับมา flip ผ่าน Stage 4');
                }
                if (cfg.dotted_key && cfg.function_exists_dinoco_config === false) {
                    hints.push('2. <strong>Config Layer snippet ไม่ active</strong> — ตรวจ <code>[Admin System] DINOCO Config Layer</code> ใน WP admin Code Snippets ว่า active');
                }
                if (cfg.dotted_key && cfg.def_registered === false && cfg.function_exists_dinoco_config) {
                    hints.push('3. <strong>Schema ไม่ถูก register</strong> — hook init ยังไม่ fire ก่อนที่จะเรียก <code>dinoco_config()</code>. กด Clear Caches แล้ว reload ใหม่');
                }
                if (hints.length > 0) {
                    html += '<div class="gl-banner info" style="margin-top:12px;font-size:13px;">';
                    html += '<strong>💡 ขั้นต่อไป:</strong><ul style="margin:6px 0 0 18px;padding:0;">';
                    hints.forEach(function(h) { html += '<li style="margin-bottom:4px;">' + h + '</li>'; });
                    html += '</ul></div>';
                }

                document.getElementById('gl-diagnose-result').innerHTML = html;
            }

            function renderMonitor(data) {
                var html = '<div class="gl-banner info">As of: ' + esc(data.as_of) + '</div>';
                html += '<h4 style="margin:12px 0 4px;">Pool Status</h4>';
                if (data.pool.length === 0) {
                    html += '<div class="gl-hint">ไม่มีข้อมูลในตาราง sn_pool</div>';
                } else {
                    html += '<table class="gl-table"><tr><th>Status</th><th>Count</th></tr>';
                    data.pool.forEach(function(p) {
                        html += '<tr><td>' + esc(p.status) + '</td><td>' + p.count + '</td></tr>';
                    });
                    html += '</table>';
                }
                html += '<h4 style="margin:12px 0 4px;">Audit Events (24h)</h4>';
                if (data.audit_24h.length === 0) {
                    html += '<div class="gl-hint">ไม่มี audit events ใน 24 ชม. ที่ผ่านมา</div>';
                } else {
                    html += '<table class="gl-table"><tr><th>Event</th><th>Count</th></tr>';
                    data.audit_24h.forEach(function(a) {
                        html += '<tr><td>' + esc(a.event_type) + '</td><td>' + a.count + '</td></tr>';
                    });
                    html += '</table>';
                }
                html += '<h4 style="margin:12px 0 4px;">Cron Health</h4>';
                html += '<table class="gl-table"><tr><th></th><th>Hook</th><th>Last Run</th><th>Next Run</th></tr>';
                data.crons.forEach(function(c) {
                    html += '<tr><td>' + (c.healthy ? '✅' : '⚠️') + '</td>';
                    html += '<td>' + esc(c.label) + '</td>';
                    html += '<td><code style="font-size:11px;">' + esc(c.last_run) + '</code></td>';
                    html += '<td><code style="font-size:11px;">' + esc(c.next_run) + '</code></td></tr>';
                });
                html += '</table>';
                document.getElementById('gl-monitor-result').innerHTML = html;
            }

            // Event delegation
            ROOT.addEventListener('click', function(e) {
                var t = e.target;
                var action = t.getAttribute('data-action');
                if (action === 'preflight') {
                    api('GET', '/preflight').then(function(d) { renderPreflight(d); }).catch(function(e) { toast(e.message, true); });
                }
                else if (action === 'schema-install') {
                    if (!confirm('Install schema 15 tables? ปลอดภัย — dbDelta idempotent.')) return;
                    api('POST', '/schema-install', { confirm: 'true' }).then(function(d) {
                        document.getElementById('gl-schema-result').innerHTML =
                            '<div class="gl-banner success">✅ ติดตั้งสำเร็จ — พบ ' + d.tables_count + ' ตาราง</div>';
                        toast('Schema installed: ' + d.tables_count + ' tables');
                    }).catch(function(e) { toast(e.message, true); });
                }
                else if (action === 'role-load') {
                    api('GET', '/role-matrix').then(function(d) { renderRoleMatrix(d.users); }).catch(function(e) { toast(e.message, true); });
                }
                else if (action === 'flag-load') {
                    api('GET', '/flag-status').then(function(d) { renderFlagTable(d.flags); }).catch(function(e) { toast(e.message, true); });
                }
                else if (action === 'monitor-load') {
                    api('GET', '/monitor').then(function(d) { renderMonitor(d); }).catch(function(e) { toast(e.message, true); });
                }
                else if (action === 'reschedule-crons') {
                    if (!confirm('Force reschedule cron jobs?\n\nเรียก dinoco_sn_reevaluate_flag_aware_crons() ทันที — จะ unschedule + re-schedule ทุก SN cron ตาม flag state ปัจจุบัน')) return;
                    api('POST', '/reschedule-crons', {}).then(function(d) {
                        toast(d.message || 'Rescheduled');
                        // Auto-refresh monitor after 500ms to show updated state
                        setTimeout(function() {
                            var btn = document.querySelector('[data-action="monitor-load"]');
                            if (btn) btn.click();
                        }, 500);
                    }).catch(function(e) { toast(e.message, true); });
                }
                else if (action === 'clear-caches') {
                    // V.2.3 — UI button for /clear-caches REST endpoint
                    if (!confirm('Clear all caches?\n\n• WP object cache (Redis/Memcached)\n• WP Fastest Cache (page HTML)\n• Config Layer (per-request)\n• dnc_mod_* lazy-load transients (SQL + object cache)\n• sn_pool_stats transient\n\nหลังกดต้อง hard-refresh หน้าที่ค้าง (Cmd+Shift+R) เพื่อให้ HTML สด')) return;
                    var btn = t;
                    btn.disabled = true;
                    var orig = btn.textContent;
                    btn.textContent = '⏳ กำลังเคลียร์...';
                    api('POST', '/clear-caches', {}).then(function(d) {
                        btn.disabled = false;
                        btn.textContent = orig;
                        // Show summary in monitor result panel
                        var lines = (d.cleared || []).map(function(c) { return '✓ ' + c; }).join('\n');
                        var html = '<div class="gl-banner success" style="margin-top:12px;">';
                        html += '<strong>🧹 เคลียร์ ' + (d.count || 0) + ' caches</strong>';
                        html += '<pre style="margin:8px 0 0;font-size:12px;white-space:pre-wrap;">' + esc(lines) + '</pre>';
                        html += '<div style="margin-top:8px;font-size:12px;">→ Hard-refresh หน้า admin-command-center (Cmd+Shift+R) แล้ว banner จะอัพเดท</div>';
                        html += '</div>';
                        var resultEl = document.getElementById('gl-monitor-result');
                        if (resultEl) resultEl.innerHTML = html;
                        toast('Cleared ' + (d.count || 0) + ' caches');
                    }).catch(function(e) {
                        btn.disabled = false;
                        btn.textContent = orig;
                        toast(e.message, true);
                    });
                }
                else if (action === 'diagnose-gdpr') {
                    // V.2.4 — Call existing /diagnose-flag REST endpoint + render parsed verdict
                    var btn = t;
                    btn.disabled = true;
                    var orig = btn.textContent;
                    btn.textContent = '⏳ กำลังวินิจฉัย...';
                    api('GET', '/diagnose-flag?flag=dinoco_gdpr_enabled', null).then(function(d) {
                        btn.disabled = false;
                        btn.textContent = orig;
                        renderDiagnose(d);
                        toast('Diagnose complete — ดูผลด้านล่าง');
                        // Scroll to result
                        var resultEl = document.getElementById('gl-diagnose-result');
                        if (resultEl) resultEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }).catch(function(e) {
                        btn.disabled = false;
                        btn.textContent = orig;
                        toast(e.message, true);
                    });
                }
                else if (action === 'jump-to-flags') {
                    // V.1.6 — scroll to Stage 4 + auto-load flags
                    var target = document.getElementById('gl-stage-flags');
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        // Auto-load flags after scroll animation
                        setTimeout(function() {
                            var loadBtn = target.querySelector('[data-action="flag-load"]');
                            if (loadBtn) loadBtn.click();
                        }, 600);
                    }
                }

                var roleToggle = t.getAttribute('data-role-toggle');
                if (roleToggle) {
                    var uid = parseInt(t.getAttribute('data-uid'), 10);
                    var current = t.getAttribute('data-current') === '1';
                    var newVal = current ? 0 : 1;
                    api('POST', '/role-assign', { user_id: uid, role: roleToggle, value: newVal }).then(function(d) {
                        t.className = newVal ? 'gl-on' : 'gl-off';
                        t.textContent = newVal ? '✓ เปิด' : 'ปิด';
                        t.setAttribute('data-current', newVal);
                        toast('Role ' + roleToggle + ' = ' + (newVal ? 'ON' : 'OFF'));
                    }).catch(function(e) { toast(e.message, true); });
                }

                var flagToggle = t.getAttribute('data-flag-toggle');
                if (flagToggle) {
                    var current = t.getAttribute('data-current') === '1';
                    var newVal = current ? 0 : 1;
                    var verb = newVal ? 'เปิด' : 'ปิด';
                    if (!confirm(verb + ' flag "' + flagToggle + '"?\n\nผลกระทบ: ทำงานทันที + บันทึก audit log')) return;
                    // V.1.7 — disable button during request to prevent double-click 429
                    t.disabled = true;
                    var origText = t.textContent;
                    t.textContent = '...';
                    api('POST', '/flag-toggle', { flag: flagToggle, value: newVal, confirm: 'true' }).then(function(d) {
                        t.className = newVal ? 'gl-on' : 'gl-off';
                        t.textContent = newVal ? '✓ เปิด' : 'ปิด';
                        t.setAttribute('data-current', newVal);
                        t.disabled = false;
                        toast('Flag ' + flagToggle + ' = ' + (newVal ? 'ON' : 'OFF'));
                    }).catch(function(e) {
                        t.textContent = origText;
                        t.disabled = false;
                        // V.1.7 — handle 429 specifically with helpful message
                        if (/429|rate/i.test(e.message)) {
                            toast('Rate limit hit — รอ 10 วินาทีแล้วลองใหม่', true);
                        } else {
                            toast(e.message, true);
                        }
                    });
                }
            });

            // Auto-run preflight on page load
            setTimeout(function() {
                var btn = ROOT.querySelector('[data-action="preflight"]');
                if (btn) btn.click();
            }, 200);
        })();
        </script>
        <?php
        return ob_get_clean();
    }
