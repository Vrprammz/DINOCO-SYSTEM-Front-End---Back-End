if ( ! function_exists( 'dinoco_sn_golive_template_redirect' ) ) {
    function dinoco_sn_golive_template_redirect() {
        $req = isset( $_SERVER['REQUEST_URI'] ) ? (string) $_SERVER['REQUEST_URI'] : '';
        $path = strtok( $req, '?' );
        // Accept both with/without trailing slash
        $is_match = ( $path === '/dinoco-sn-golive' || $path === '/dinoco-sn-golive/' );
        if ( ! $is_match ) return;

        // Auth gate — redirect to login if not admin
        if ( ! is_user_logged_in() ) {
            wp_safe_redirect( wp_login_url( home_url( '/dinoco-sn-golive/' ) ) );
            exit;
        }
        if ( ! current_user_can( 'manage_options' ) ) {
            status_header( 403 );
            nocache_headers();
            echo '<!doctype html><html lang="th"><head><meta charset="utf-8"><title>403</title></head>';
            echo '<body style="font-family:sans-serif;padding:40px;"><h1>403 — Admin only</h1>';
            echo '<p>SN Go-Live tool ใช้ได้เฉพาะ admin (manage_options).</p></body></html>';
            exit;
        }

        // Render standalone page — full DOCTYPE, no theme, no Elementor
        nocache_headers();
        header( 'Content-Type: text/html; charset=utf-8' );
        echo '<!doctype html><html lang="th"><head>';
        echo '<meta charset="utf-8">';
        echo '<meta name="viewport" content="width=device-width,initial-scale=1">';
        echo '<title>🚀 SN Go-Live | DINOCO</title>';
        echo '<style>body{margin:0;background:#f3f4f6;}</style>';
        // wp_head() pulls minimal scripts (jQuery if needed by other DINOCO modules);
        // we use vanilla fetch so this is mostly cosmetic but keeps Sentry/observability injects working.
        wp_head();
        echo '</head><body>';
        echo dinoco_sn_golive_render(); // phpcs:ignore WordPress.Security.EscapeOutput.OutputNotEscaped
        wp_footer();
        echo '</body></html>';
        exit;
    }
    add_action( 'template_redirect', 'dinoco_sn_golive_template_redirect', 5 );
}

