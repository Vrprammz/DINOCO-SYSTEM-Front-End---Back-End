                    '</div></div>',
                showCancelButton: true,
                confirmButtonText: '<i class="fa-solid fa-check"></i> Save',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#1e293b',
                preConfirm: function() {
                    var name = document.getElementById('swal-name').value.trim();
                    if (!name) { Swal.showValidationMessage('Name required'); return false; }
                    return { name:name, logo_url:document.getElementById('swal-logo').value.trim(), sort_order:document.getElementById('swal-sort').value, is_active:document.getElementById('swal-active').value, slug: b ? b.slug : name };
                }
            }).then(function(r) {
                if (!r.isConfirmed) return;
                post('save_brand', r.value, function(res) {
                    if (res.success) { Swal.fire({icon:'success',title:'Saved',timer:800,showConfirmButton:false}); loadBrands(); }
