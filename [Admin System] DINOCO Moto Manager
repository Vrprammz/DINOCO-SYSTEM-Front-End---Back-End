    <script>
    (function(){
        var $ = jQuery;
        var NONCE = '<?php echo $nonce; ?>';
        var brandsData = [];

        function post(action, data, cb) {
            data.dinoco_moto_mgr_action = action;
            data._nonce = NONCE;
            $.post('', data, function(r) { cb(r); }, 'json').fail(function() { cb({success:false,message:'Network error'}); });
        }

        // ─── TABS ───
        window.mmTab = function(t) {
            $('.mm-tab').removeClass('active');
            $('.mm-view').hide();
            if (t==='brands') { $('.mm-tab:eq(0)').addClass('active'); $('#mm-v-brands').show(); }
            else if (t==='models') { $('.mm-tab:eq(1)').addClass('active'); $('#mm-v-models').show(); }
            else { $('.mm-tab:eq(2)').addClass('active'); $('#mm-v-settings').show(); }
        };

        // ─── LOAD BRANDS ───
        function loadBrands() {
            post('get_data', {}, function(r) {
                if (!r.success) return;
                brandsData = r.brands || [];
                renderBrands();
                // Fill brand filter dropdown
                var sel = $('#mm-brand-filter');
                sel.find('option:gt(0)').remove();
                brandsData.forEach(function(b) { sel.append('<option value="'+b.slug+'">'+b.name+'</option>'); });
                // Year range
                if (r.year_range) { $('#mm-year-min').val(r.year_range.min); $('#mm-year-max').val(r.year_range.max); }
            });
        }

        function renderBrands() {
            var grid = $('#mm-brands-grid').empty();
            $('#mm-brand-count').text(brandsData.length + ' brands');
            brandsData.forEach(function(b) {
                var logo = b.logo_url ? '<img src="'+b.logo_url+'" class="mm-brand-logo">' : '<div class="mm-brand-logo" style="display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:16px;"><i class="fa-solid fa-motorcycle"></i></div>';
                var status = b.is_active == 1 ? '<span class="mm-badge green">Active</span>' : '<span class="mm-badge red">Inactive</span>';
                grid.append(
                    '<div class="mm-brand-card '+(b.is_active!=1?'inactive':'')+'" onclick="mmSelectBrand(\''+b.slug+'\')">' +
                    '<div style="display:flex;align-items:center;gap:10px;">'+logo+'<div>'+status+'</div></div>' +
                    '<div class="mm-brand-name">'+b.name+'</div>' +
                    '<div class="mm-brand-count">slug: '+b.slug+' | sort: '+b.sort_order+'</div>' +
                    '<div style="position:absolute;top:8px;right:8px;display:flex;gap:4px;">' +
                    '<button class="mm-btn mm-btn-sm mm-btn-outline" onclick="event.stopPropagation();mmEditBrand(\''+b.slug+'\')"><i class="fa-solid fa-pen"></i></button>' +
                    '<button class="mm-btn mm-btn-sm mm-btn-danger" onclick="event.stopPropagation();mmDeleteBrand(\''+b.slug+'\',\''+b.name+'\')"><i class="fa-solid fa-trash"></i></button>' +
                    '</div></div>'
                );
            });
        }

