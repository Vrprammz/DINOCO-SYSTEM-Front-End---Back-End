// AJAX HANDLER (init hook — ตาม Inventory pattern)
// ════════════════════════════════════════════

add_action('init', function() {
    if ( $_SERVER['REQUEST_METHOD'] !== 'POST' || ! isset($_POST['dinoco_moto_mgr_action']) ) return;
    if ( ob_get_length() ) ob_clean();
    error_reporting(0); @ini_set('display_errors', 0);
    if ( ! headers_sent() ) {
        header('Content-Type: application/json; charset=utf-8');
        header('Cache-Control: no-store, no-cache, must-revalidate, max-age=0');
        header('Pragma: no-cache');
    }
    if ( ! current_user_can('manage_options') ) {
        echo json_encode(['success' => false, 'message' => 'Access Denied']); exit;
    }
    if ( ! class_exists('DINOCO_MotoDB') ) {
        echo json_encode(['success' => false, 'message' => 'DINOCO_MotoDB class not loaded. Activate Snippet 15.']); exit;
    }

    $act = sanitize_text_field($_POST['dinoco_moto_mgr_action']);
    $write_actions = ['save_brand','delete_brand','save_model','delete_model','save_year_range','reseed'];

    if ( in_array($act, $write_actions, true) ) {
        if ( ! isset($_POST['_nonce']) || ! wp_verify_nonce($_POST['_nonce'], 'dinoco_moto_mgr') ) {
            echo json_encode(['success' => false, 'message' => 'Security token invalid.']); exit;
        }
    }

    try {
        switch ($act) {
            case 'get_data':
                echo json_encode([
                    'success' => true,
                    'brands'  => DINOCO_MotoDB::get_brands(false),
                    'year_range' => DINOCO_MotoDB::get_year_range(),
                ]); break;

            case 'get_models':
                $slug = sanitize_text_field($_POST['brand_slug'] ?? '');
                $models = DINOCO_MotoDB::get_models($slug, false);
                foreach ($models as &$m) { $m['user_count'] = DINOCO_MotoDB::count_users_by_model($m['name']); }
                echo json_encode(['success' => true, 'models' => $models]); break;

            case 'save_brand':
                $data = [
                    'slug'       => sanitize_text_field($_POST['slug'] ?? $_POST['name'] ?? ''),
                    'name'       => sanitize_text_field($_POST['name'] ?? ''),
                    'logo_url'   => esc_url_raw($_POST['logo_url'] ?? ''),
                    'sort_order' => intval($_POST['sort_order'] ?? 0),
                    'is_active'  => intval($_POST['is_active'] ?? 1),
                ];
                $result = DINOCO_MotoDB::upsert_brand($data);
                echo json_encode(['success' => !!$result, 'id' => $result]); break;

            case 'delete_brand':
                $slug = sanitize_text_field($_POST['slug'] ?? '');
                $result = DINOCO_MotoDB::delete_brand($slug);
                if ( is_wp_error($result) ) {
                    echo json_encode(['success' => false, 'message' => $result->get_error_message()]);
                } else {
                    echo json_encode(['success' => true]);
                }
                break;

            case 'save_model':
                $aliases_raw = sanitize_text_field($_POST['aliases'] ?? '');
                // Convert comma-separated to JSON array
                if ( !empty($aliases_raw) && substr($aliases_raw, 0, 1) !== '[' ) {
                    $arr = array_map('trim', explode(',', $aliases_raw));
                    $aliases_raw = json_encode(array_values(array_filter($arr)), JSON_UNESCAPED_UNICODE);
                }
                $data = [
                    'brand_slug' => sanitize_text_field($_POST['brand_slug'] ?? ''),
                    'slug'       => sanitize_text_field($_POST['slug'] ?? $_POST['name'] ?? ''),
                    'name'       => sanitize_text_field($_POST['name'] ?? ''),
                    'image_url'  => esc_url_raw($_POST['image_url'] ?? ''),
                    'aliases'    => $aliases_raw,
                    'sort_order' => intval($_POST['sort_order'] ?? 0),
                    'is_active'  => intval($_POST['is_active'] ?? 1),
                ];
                $result = DINOCO_MotoDB::upsert_model($data);
                if ( is_wp_error($result) ) {
                    echo json_encode(['success' => false, 'message' => $result->get_error_message()]);
                } else {
                    echo json_encode(['success' => !!$result, 'id' => $result]);
                }
                break;

            case 'delete_model':
                $slug = sanitize_text_field($_POST['slug'] ?? '');
                DINOCO_MotoDB::delete_model($slug);
                echo json_encode(['success' => true]); break;

            case 'save_year_range':
                DINOCO_MotoDB::set_year_range(intval($_POST['min']), intval($_POST['max']));
                echo json_encode(['success' => true]); break;

            case 'reseed':
                delete_option('_dinoco_moto_seeded');
                $r = DINOCO_MotoDB::seed_from_hardcode();
                echo json_encode(['success' => true, 'result' => $r]); break;

            default:
                echo json_encode(['success' => false, 'message' => 'Unknown action']); break;
        }
    } catch (Exception $e) {
        echo json_encode(['success' => false, 'message' => $e->getMessage()]);
    }
    exit;
});

