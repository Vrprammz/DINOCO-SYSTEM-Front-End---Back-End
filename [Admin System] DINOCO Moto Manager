                });
            });
        };

        // ─── EDIT MODEL ───
        window.mmEditModel = function(slug) {
            var brandSlug = $('#mm-brand-filter').val() || '';
            // If editing existing, fetch data
            var m = null;
            if (slug) {
                var rows = $('#mm-models-body tr');
                // We'll just re-fetch via form
            }
            var aliasesStr = '';

            Swal.fire({
                title: slug ? 'Edit Model' : 'Add Model',
                width: 600,
                html:
                    '<div style="text-align:left;font-family:inherit;">' +
                    '<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:3px;">BRAND</label><select id="swal-m-brand" class="swal2-input" style="width:100%;margin:0;">' +
                    brandsData.map(function(b){return '<option value="'+b.slug+'" '+(b.slug===brandSlug?'selected':'')+'>'+b.name+'</option>';}).join('') +
                    '</select></div>' +
                    '<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:3px;">MODEL NAME</label><input id="swal-m-name" class="swal2-input" style="width:100%;margin:0;"></div>' +
                    '<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:3px;">IMAGE URL</label><input id="swal-m-img" class="swal2-input" style="width:100%;margin:0;"></div>' +
                    '<div style="margin-bottom:12px;"><label style="font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:3px;">ALIASES (comma separated)</label><input id="swal-m-aliases" class="swal2-input" style="width:100%;margin:0;" placeholder="forza350, forza 350, ฟอร์ซ่า"></div>' +
                    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">' +
                    '<div><label style="font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:3px;">SORT ORDER</label><input id="swal-m-sort" type="number" class="swal2-input" style="width:100%;margin:0;" value="0"></div>' +
                    '<div><label style="font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:3px;">STATUS</label><select id="swal-m-active" class="swal2-input" style="width:100%;margin:0;"><option value="1">Active</option><option value="0">Inactive</option></select></div>' +
                    '</div>' +
                    '<div id="swal-m-preview" style="margin-top:12px;display:none;"><img style="max-height:80px;border-radius:8px;" id="swal-m-preview-img"></div>' +
                    '</div>',
                showCancelButton: true,
                confirmButtonText: '<i class="fa-solid fa-check"></i> Save',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#1e293b',
                didOpen: function() {
                    // Image preview
                    document.getElementById('swal-m-img').addEventListener('input', function() {
                        var url = this.value.trim();
                        if (url) { document.getElementById('swal-m-preview-img').src = url; document.getElementById('swal-m-preview').style.display = ''; }
                        else { document.getElementById('swal-m-preview').style.display = 'none'; }
                    });
                    // Pre-fill if editing existing (from DOM data)
                    if (slug) {
                        post('get_models', {brand_slug:brandSlug}, function(r) {
                            if (!r.success) return;
                            var found = (r.models||[]).find(function(x){return x.slug===slug;});
                            if (found) {
                                document.getElementById('swal-m-brand').value = found.brand_slug;
                                document.getElementById('swal-m-name').value = found.name;
                                document.getElementById('swal-m-img').value = found.image_url || '';
                                try { document.getElementById('swal-m-aliases').value = found.aliases ? JSON.parse(found.aliases).join(', ') : ''; } catch(e) { document.getElementById('swal-m-aliases').value = found.aliases || ''; }
                                document.getElementById('swal-m-sort').value = found.sort_order;
                                document.getElementById('swal-m-active').value = found.is_active;
                                if (found.image_url) { document.getElementById('swal-m-preview-img').src = found.image_url; document.getElementById('swal-m-preview').style.display = ''; }
                            }
                        });
                    }
                },
                preConfirm: function() {
                    var name = document.getElementById('swal-m-name').value.trim();
                    if (!name) { Swal.showValidationMessage('Model name required'); return false; }
                    return {
                        brand_slug: document.getElementById('swal-m-brand').value,
                        name: name,
                        slug: slug || name,
                        image_url: document.getElementById('swal-m-img').value.trim(),
                        aliases: document.getElementById('swal-m-aliases').value.trim(),
                        sort_order: document.getElementById('swal-m-sort').value,
                        is_active: document.getElementById('swal-m-active').value,
                    };
                }
            }).then(function(r) {
                if (!r.isConfirmed) return;
                post('save_model', r.value, function(res) {
                    if (res.success) { Swal.fire({icon:'success',title:'Saved',timer:800,showConfirmButton:false}); mmLoadModels(); }
                    else Swal.fire('Error', res.message||'Failed', 'error');
                });
            });
        };

        window.mmDeleteModel = function(slug, name) {
            Swal.fire({
                title: 'ลบ Model "'+name+'"?',
                text: 'Soft-delete — สามารถกู้คืนได้',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'ลบ',
                cancelButtonText: 'ยกเลิก'
            }).then(function(r) {
                if (!r.isConfirmed) return;
                post('delete_model', {slug:slug}, function(res) {
                    if (res.success) { Swal.fire({icon:'success',title:'Deleted',timer:800,showConfirmButton:false}); mmLoadModels(); }
                    else Swal.fire('Error', res.message||'Failed', 'error');
                });
            });
        };

        // ─── SETTINGS ───
        window.mmSaveYearRange = function() {
            post('save_year_range', {min:$('#mm-year-min').val(), max:$('#mm-year-max').val()}, function(r) {
                if (r.success) Swal.fire({icon:'success',title:'Saved',timer:800,showConfirmButton:false});
                else Swal.fire('Error', r.message||'Failed', 'error');
            });
        };

        window.mmReseed = function() {
            Swal.fire({
                title: 'Re-seed from Hardcode?',
                text: 'จะ import ข้อมูลเดิม 13 brands + 19 models (upsert — ไม่ลบข้อมูลที่เพิ่มเอง)',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Re-seed',
                confirmButtonColor: '#1e293b'
            }).then(function(r) {
                if (!r.isConfirmed) return;
                post('reseed', {}, function(res) {
                    if (res.success) { Swal.fire({icon:'success',title:'Seeded!',timer:1000,showConfirmButton:false}); loadBrands(); }
                    else Swal.fire('Error', res.message||'Failed', 'error');
                });
            });
        };

        // ─── INIT ───
        loadBrands();
    })();
    </script>

    <?php
    return ob_get_clean();
});
