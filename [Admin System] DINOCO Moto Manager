            $('#mm-brand-filter').val(slug);
            mmTab('models');
            mmLoadModels();
        };

        // ─── EDIT BRAND (modal via SweetAlert) ───
        window.mmEditBrand = function(slug) {
            var b = slug ? brandsData.find(function(x){return x.slug===slug;}) : null;
            Swal.fire({
                title: b ? 'Edit Brand' : 'Add Brand',
