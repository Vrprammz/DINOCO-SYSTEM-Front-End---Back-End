if ( ! wp_next_scheduled( 'dinoco_gdpr_sla_reminder_cron' ) ) {
    $first_run = strtotime( 'tomorrow 09:00' );
    if ( ! $first_run ) $first_run = time() + DAY_IN_SECONDS;
    wp_schedule_event( $first_run, 'daily', 'dinoco_gdpr_sla_reminder_cron' );
}
if ( function_exists( 'dinoco_register_cron' ) ) {
    dinoco_register_cron( 'dinoco_gdpr_sla_reminder_cron', 'daily', 'dinoco_gdpr_sla_reminder_run' );
} else {
    add_action( 'dinoco_gdpr_sla_reminder_cron', 'dinoco_gdpr_sla_reminder_run' );
}

