                var statusBadge = '<span class="dnc-gdpr-badge dnc-gdpr-badge-' + esc(row.status) + '">' + esc(row.status) + '</span>';
                var ageBadge = '<span class="' + ageBadgeClass(row.age_days) + '">⏱ ' + esc(row.age_days) + ' วัน</span>';

                var legalHoldWarn = '';
                if (row.type === 'delete' && rs.has_open_debt) {
                    legalHoldWarn = '<div class="dnc-gdpr-banner dnc-gdpr-banner-warn" style="margin-top:8px;font-size:12px;">' +
                        '⚠️ <strong>Legal Hold candidate:</strong> Distributor มีหนี้ค้าง ' +
                        esc(Number(rs.open_debt_thb).toLocaleString('th-TH', {minimumFractionDigits: 2})) + ' ฿ — ' +
                        'ควร reject reason=legal_hold จนกว่าจะเคลียร์</div>';
                }

                var actionsHtml = '';
                if (panelKey === 'pending') {
                    actionsHtml =
                        '<div class="dnc-gdpr-actions">' +
                            '<button type="button" class="dnc-gdpr-btn dnc-gdpr-btn-success" data-action="approve" data-id="' + row.id + '">✅ Approve</button>' +
                            '<button type="button" class="dnc-gdpr-btn dnc-gdpr-btn-danger" data-action="reject" data-id="' + row.id + '">❌ Reject</button>' +
                            '<button type="button" class="dnc-gdpr-btn dnc-gdpr-btn-secondary" data-action="manual" data-id="' + row.id + '">⚙️ Manual Process</button>' +
                        '</div>';
                } else if (panelKey === 'processing') {
                    var windowAt = row.cancellation_window_at || '';
                    actionsHtml =
                        '<div class="dnc-gdpr-actions">' +
                            '<button type="button" class="dnc-gdpr-btn dnc-gdpr-btn-secondary" data-action="undo" data-id="' + row.id + '" data-window-at="' + esc(windowAt) + '">↩️ Undo (30s window)</button>' +
                        '</div>';
                } else if (panelKey === 'failed') {
                    actionsHtml =
                        '<div class="dnc-gdpr-actions">' +
                            '<button type="button" class="dnc-gdpr-btn dnc-gdpr-btn-primary" data-action="retry" data-id="' + row.id + '">🔄 Retry (Manual)</button>' +
                        '</div>';
                } else if (panelKey === 'ready') {
                    var scope = {};
                    try { scope = row.scope_json ? JSON.parse(row.scope_json) : {}; } catch(e){}
                    if (row.type === 'export' && scope.download_url) {
                        actionsHtml =
                            '<div class="dnc-gdpr-actions">' +
                                '<a class="dnc-gdpr-btn dnc-gdpr-btn-primary" href="' + esc(scope.download_url) + '" target="_blank" rel="noopener">📦 Download ZIP</a>' +
                                '<span style="font-size:12px;color:#6b7280;align-self:center;">หมดอายุ: ' + esc(row.expires_at || '—') + '</span>' +
                            '</div>';
                    }
                }

                return '<div class="dnc-gdpr-card" data-id="' + row.id + '" data-panel="' + esc(panelKey) + '">' +
                    '<div class="dnc-gdpr-card-head">' +
                        '<div>' +
                            '<div class="dnc-gdpr-card-title">' + typeBadge + ' ' + statusBadge + ' ' + ageBadge + '</div>' +
                            '<div class="dnc-gdpr-card-meta">' +
                                'Ticket: <code>' + esc(row.ticket_id) + '</code> · ' +
                                'User: ' + esc(u.display_name || '(unknown)') + ' (' + esc(u.user_email || '—') + ') · ID #' + esc(u.id) +
                                (u.line_uid ? ' · LINE: <code>' + esc(u.line_uid.substring(0, 12)) + '…</code>' : '') +
                                (u.distributor_id ? ' · Dist #' + esc(u.distributor_id) : '') +
                            '</div>' +
                            '<div class="dnc-gdpr-card-meta">Submitted: ' + esc(row.created_at) + '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="dnc-gdpr-stats">' +
                        '<div class="dnc-gdpr-stat"><span class="dnc-gdpr-stat-label">Warranties:</span> <span class="dnc-gdpr-stat-val">' + esc(rs.warranties || 0) + '</span></div>' +
                        '<div class="dnc-gdpr-stat"><span class="dnc-gdpr-stat-label">Claims:</span> <span class="dnc-gdpr-stat-val">' + esc(rs.claims || 0) + '</span></div>' +
                        '<div class="dnc-gdpr-stat"><span class="dnc-gdpr-stat-label">Orders:</span> <span class="dnc-gdpr-stat-val">' + esc(rs.orders || 0) + '</span></div>' +
                    '</div>' +
                    legalHoldWarn +
                    (row.notes ? '<div class="dnc-gdpr-card-body" style="margin-top:8px;color:#7f1d1d;font-size:12px;">📝 ' + esc(row.notes) + '</div>' : '') +
                    actionsHtml +
                '</div>';
            }

            function loadTab(tab) {
                if (tab === 'audit') return loadAuditLog();
                var panel = root.querySelector('.dnc-gdpr-panel[data-panel="' + tab + '"]');
                if (!panel) return;
                panel.innerHTML = '<div class="dnc-gdpr-loading">กำลังโหลด...</div>';
                api('/requests?status=' + encodeURIComponent(tab) + '&per_page=50', {})
                    .then(function(res) {
                        if (res.status === 503) {
                            panel.innerHTML = '<div class="dnc-gdpr-banner dnc-gdpr-banner-warn">⚠️ ระบบยังไม่เปิดใช้งาน (flag OFF)</div>';
                            return;
                        }
                        if (res.status !== 200 || !res.body || res.body.success !== true) {
                            panel.innerHTML = '<div class="dnc-gdpr-empty">โหลดไม่สำเร็จ — ' + esc((res.body && res.body.code) || 'error') + '</div>';
                            return;
                        }
                        // Update tab counts
                        if (res.body.bucket_counts) {
                            Object.keys(res.body.bucket_counts).forEach(function(k) {
                                var el = root.querySelector('.dnc-gdpr-tab-count[data-count="' + k + '"]');
                                if (el) el.textContent = res.body.bucket_counts[k];
                            });
                        }
                        var rows = res.body.data || [];
                        if (!rows.length) {
                            panel.innerHTML = '<div class="dnc-gdpr-empty">ไม่มีคำขอใน bucket นี้</div>';
                            return;
                        }
                        panel.innerHTML = rows.map(function(r) { return renderRequestCard(r, tab); }).join('');
                    })
                    .catch(function(e) {
                        panel.innerHTML = '<div class="dnc-gdpr-empty">โหลดไม่สำเร็จ: ' + esc(e.message || 'network error') + '</div>';
                    });
            }

            function loadAuditLog() {
                var panel = root.querySelector('.dnc-gdpr-panel[data-panel="audit"]');
                var loadingEl = panel.querySelector('.dnc-gdpr-loading');
                var existingTable = panel.querySelector('.dnc-gdpr-audit-table-wrap');
                if (existingTable) existingTable.remove();
                if (!loadingEl) {
                    loadingEl = document.createElement('div');
                    loadingEl.className = 'dnc-gdpr-loading';
                    loadingEl.textContent = 'กำลังโหลด...';
                    panel.appendChild(loadingEl);
                } else {
                    loadingEl.style.display = 'block';
                }

                var qs = '';
                ['actor_user_id', 'action', 'date_from', 'date_to'].forEach(function(k) {
                    var el = panel.querySelector('[data-audit-filter="' + k + '"]');
                    if (el && el.value) qs += '&' + k + '=' + encodeURIComponent(el.value);
                });
                api('/audit-log?per_page=100' + qs, {})
                    .then(function(res) {
                        if (loadingEl) loadingEl.style.display = 'none';
                        if (res.status === 503) {
                            var w = document.createElement('div');
                            w.className = 'dnc-gdpr-banner dnc-gdpr-banner-warn';
                            w.textContent = '⚠️ ระบบยังไม่เปิดใช้งาน (flag OFF)';
                            panel.appendChild(w);
                            return;
                        }
                        if (res.status !== 200 || !res.body.success) {
                            var e = document.createElement('div');
                            e.className = 'dnc-gdpr-empty';
                            e.textContent = 'โหลดไม่สำเร็จ';
                            panel.appendChild(e);
                            return;
                        }
                        var rows = res.body.data || [];
                        var wrap = document.createElement('div');
                        wrap.className = 'dnc-gdpr-audit-table-wrap';
                        if (!rows.length) {
                            wrap.innerHTML = '<div class="dnc-gdpr-empty">ไม่มี audit entries (ลอง clear filters)</div>';
                        } else {
                            var html = '<table class="dnc-gdpr-audit-table"><thead><tr>' +
                                '<th>เวลา</th><th>Action</th><th>Actor</th><th>Request</th>' +
                                '<th>From → To</th><th>Reason</th><th>Note</th><th>IP</th>' +
                                '</tr></thead><tbody>';
                            rows.forEach(function(r) {
                                html += '<tr>' +
                                    '<td>' + esc(r.created_at) + '</td>' +
                                    '<td class="col-action">' + esc(r.action) + '</td>' +
                                    '<td>' + esc(r.actor_login || '#' + r.actor_user_id) + '</td>' +
                                    '<td>#' + esc(r.request_id) + '</td>' +
                                    '<td>' + esc(r.from_status || '—') + ' → ' + esc(r.to_status || '—') + '</td>' +
                                    '<td>' + esc(r.reason || '') + '</td>' +
                                    '<td>' + esc(r.note || '') + '</td>' +
                                    '<td><code>' + esc(r.actor_ip || '—') + '</code></td>' +
                                '</tr>';
                            });
                            html += '</tbody></table>';
                            wrap.innerHTML = html;
                        }
                        panel.appendChild(wrap);
                    });
            }

            // Audit filter handlers
            var auditPanel = root.querySelector('.dnc-gdpr-panel[data-panel="audit"]');
            if (auditPanel) {
                auditPanel.addEventListener('click', function(e) {
                    var btn = e.target.closest('[data-audit-action]');
                    if (!btn) return;
                    var act = btn.getAttribute('data-audit-action');
                    if (act === 'apply') {
                        loadAuditLog();
                    } else if (act === 'export-csv') {
                        var qs = 'export=csv&_wpnonce=' + encodeURIComponent(NONCE);
                        ['actor_user_id', 'action', 'date_from', 'date_to'].forEach(function(k) {
                            var el = auditPanel.querySelector('[data-audit-filter="' + k + '"]');
                            if (el && el.value) qs += '&' + k + '=' + encodeURIComponent(el.value);
                        });
                        window.location.href = REST + '/audit-log?' + qs;
                    }
                });
            }

            // Action button delegation
            root.addEventListener('click', function(e) {
                var btn = e.target.closest('[data-action]');
                if (!btn) return;
                var act = btn.getAttribute('data-action');
                var id = parseInt(btn.getAttribute('data-id'), 10);
                if (!id) return;
                if (act === 'approve') return doApprove(id);
                if (act === 'reject')  return doReject(id);
                if (act === 'manual')  return doManual(id);
                if (act === 'retry')   return doManual(id);
                if (act === 'undo')    return doUndo(id, btn.getAttribute('data-window-at'));
            });

            function doApprove(id) {
                _confirm({
                    title: 'อนุมัติคำขอ #' + id,
                    message: 'Worker จะรันหลัง 30 วินาที (มี Undo button) — ดำเนินการต่อ?',
                    confirmText: 'อนุมัติ',
                    cancelText: 'ยกเลิก'
                }).then(function(ok) {
                    if (!ok) return;
                    api('/request/' + id + '/approve', { method: 'POST', body: { confirm_text: 'APPROVE' } })
                        .then(function(res) {
                            if (res.body.success) {
                                _alert({ title: '✅ อนุมัติแล้ว', message: 'Worker จะทำงานหลัง 30s (' + res.body.scheduled_at + ') — ไปแท็บ Processing เพื่อ Undo', type: 'success' });
                                loadTab('pending');
                            } else {
                                _alert({ title: '❌ ผิดพลาด', message: (res.body.message || res.body.code || 'unknown'), type: 'error' });
                            }
                        });
                });
            }

            function doReject(id) {
                // Two-step: pick reason then optional note
                _prompt({
                    title: 'เหตุผลการปฏิเสธ #' + id,
                    message: 'พิมพ์ reason: legal_hold | fraud | cooling_off | other',
                    placeholder: 'legal_hold',
                    defaultValue: 'legal_hold',
                    required: true,
                    maxLength: 40
                }).then(function(reason) {
                    if (!reason) return;
                    var validReasons = ['legal_hold', 'fraud', 'cooling_off', 'other'];
                    if (validReasons.indexOf(reason) === -1) {
                        return _alert({ title: 'รหัสไม่ถูกต้อง', message: 'reason ต้องเป็น: ' + validReasons.join(', '), type: 'error' });
                    }
                    var promptNote = (reason === 'other') ? 'note (>=5 ตัวอักษร, บังคับเมื่อ reason=other)' : 'note เพิ่มเติม (ทางเลือก)';
                    _prompt({
                        title: 'หมายเหตุ',
                        message: promptNote,
                        placeholder: 'รายละเอียด...',
                        required: reason === 'other',
                        multiline: true,
                        maxLength: 1000
                    }).then(function(note) {
                        if (note === null) return;
                        api('/request/' + id + '/reject', { method: 'POST', body: { reason: reason, note: note || '' } })
                            .then(function(res) {
                                if (res.body.success) {
                                    _alert({ title: '✅ ปฏิเสธแล้ว', message: 'User ได้รับ email แจ้งแล้ว', type: 'success' });
                                    loadTab('pending');
                                } else {
                                    _alert({ title: '❌ ผิดพลาด', message: (res.body.message || res.body.code), type: 'error' });
                                }
                            });
                    });
                });
            }

            function doManual(id) {
                _confirm({
                    title: 'รัน Worker แบบ Synchronous #' + id,
                    message: '⚠️ การลบเป็น irreversible — ระบบจะรัน worker ทันทีโดยไม่มี undo window\n\nพิมพ์ "PROCESS" ในหน้าถัดไปเพื่อยืนยัน',
                    confirmText: 'ดำเนินการ',
                    cancelText: 'ยกเลิก',
                    danger: true
                }).then(function(ok) {
                    if (!ok) return;
                    _prompt({
                        title: 'พิมพ์ "PROCESS" เพื่อยืนยัน',
                        message: 'การ manual run จะทำงานทันทีและไม่สามารถ undo ได้',
                        placeholder: 'PROCESS',
                        required: true,
                        maxLength: 20
                    }).then(function(typed) {
                        if (typed !== 'PROCESS') {
                            return _alert({ title: 'ยกเลิก', message: 'ต้องพิมพ์ "PROCESS" ตรง ๆ', type: 'warning' });
                        }
                        api('/request/' + id + '/manual-export', { method: 'POST', body: { confirm_text: 'PROCESS' } })
                            .then(function(res) {
                                if (res.body.success) {
                                    _alert({ title: '✅ Manual run เสร็จ', message: 'final_status: ' + (res.body.final_status || '?'), type: 'success' });
                                    loadTab('pending');
                                    loadTab('failed');
                                } else {
                                    _alert({ title: '❌ ผิดพลาด', message: (res.body.message || res.body.code), type: 'error' });
                                }
                            });
                    });
                });
            }

            function doUndo(id, windowAt) {
                _confirm({
                    title: 'ยกเลิกการอนุมัติ #' + id,
                    message: 'จะยกเลิกการอนุมัติและ unschedule worker (ใช้ได้ภายใน 30s window)',
                    confirmText: 'ยกเลิกการอนุมัติ',
                    cancelText: 'กลับ',
                    danger: true
                }).then(function(ok) {
                    if (!ok) return;
                    api('/request/' + id + '/undo', { method: 'POST', body: {} })
                        .then(function(res) {
                            if (res.body.success) {
                                _alert({ title: '✅ ยกเลิกแล้ว', message: 'Worker ถูก unschedule', type: 'success' });
                                loadTab('processing');
                            } else if (res.body.code === 'window_expired') {
                                _alert({ title: '⏱ หมดเวลา', message: '30s window หมดแล้ว — worker เริ่มทำงานแล้ว ไม่สามารถ undo', type: 'warning' });
                                loadTab('processing');
                            } else {
                                _alert({ title: '❌ ผิดพลาด', message: (res.body.message || res.body.code), type: 'error' });
                            }
                        });
                });
            }

            // Initial load: pending tab
            if (FLAG_ON) {
                loadTab('pending');
                // Refresh count badges by loading all status buckets in background
                ['processing', 'ready', 'failed'].forEach(function(t) {
                    setTimeout(function() {
                        api('/requests?status=' + t + '&per_page=1', {}).then(function(res) {
                            if (res.body && res.body.bucket_counts) {
                                Object.keys(res.body.bucket_counts).forEach(function(k) {
                                    var el = root.querySelector('.dnc-gdpr-tab-count[data-count="' + k + '"]');
                                    if (el) el.textContent = res.body.bucket_counts[k];
                                });
                            }
                        });
                    }, 100);
                });
            }
        })();
        </script>
        <?php
        return ob_get_clean();
    }
}

