    /**
     * GET /admin/requests
     * Filters (query params): status, type, user, age_days, page, per_page
     */
    function dinoco_gdpr_rest_admin_list( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_requests';

        $valid_status = array( 'pending', 'processing', 'ready', 'failed', 'rejected', 'cancelled', 'expired' );
        $valid_type   = array( 'export', 'delete' );

        $status   = sanitize_key( (string) $request->get_param( 'status' ) );
        $type     = sanitize_key( (string) $request->get_param( 'type' ) );
        $user_id  = absint( $request->get_param( 'user' ) );
        $age_days = absint( $request->get_param( 'age_days' ) );
        $page     = max( 1, absint( $request->get_param( 'page' ) ) ?: 1 );
        $per_page = max( 1, min( 100, absint( $request->get_param( 'per_page' ) ) ?: 25 ) );
        $offset   = ( $page - 1 ) * $per_page;

        $where  = array( '1=1' );
        $params = array();
        if ( $status && in_array( $status, $valid_status, true ) ) {
            $where[]  = 'status = %s';
            $params[] = $status;
        }
        if ( $type && in_array( $type, $valid_type, true ) ) {
            $where[]  = 'type = %s';
            $params[] = $type;
        }
        if ( $user_id > 0 ) {
            $where[]  = 'user_id = %d';
            $params[] = $user_id;
        }
        if ( $age_days > 0 ) {
            $cutoff   = gmdate( 'Y-m-d H:i:s', strtotime( '-' . $age_days . ' days' ) );
            $where[]  = 'created_at <= %s';
            $params[] = $cutoff;
        }

        $where_sql = implode( ' AND ', $where );
        // Sort: pending oldest first (priority), then by created_at DESC for everything else.
        // Simpler: pending bucket first, then everything else by created DESC.
        $order_sql = "ORDER BY (status='pending') DESC, created_at " .
            ( $status === 'pending' ? 'ASC' : 'DESC' );

        $count_sql = "SELECT COUNT(*) FROM {$tbl} WHERE {$where_sql}";
        $total = $params
            ? (int) $wpdb->get_var( $wpdb->prepare( $count_sql, $params ) )
            : (int) $wpdb->get_var( $count_sql );

        $rows_sql = "SELECT id, user_id, type, status, ticket_id, request_ip, request_ua,
                            notes, scope_json, expires_at, reviewed_by, reviewed_at,
                            cancellation_window_at, created_at, processed_at
                     FROM {$tbl}
                     WHERE {$where_sql}
                     {$order_sql}
                     LIMIT %d OFFSET %d";
        $params_with_paging = array_merge( $params, array( $per_page, $offset ) );
        $rows = $wpdb->get_results( $wpdb->prepare( $rows_sql, $params_with_paging ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        // Enrich with user summary + record summary
        $now = time();
        foreach ( $rows as &$row ) {
            $row['user']            = dinoco_gdpr_admin_user_summary( (int) $row['user_id'] );
            $row['record_summary']  = dinoco_gdpr_admin_record_summary( (int) $row['user_id'] );
            $row['age_days']        = floor( ( $now - strtotime( $row['created_at'] ) ) / DAY_IN_SECONDS );
            // Don't expose download_token to list view (only single detail)
        }
        unset( $row );

        // Bucket counts (overview)
        $buckets = $wpdb->get_results( "SELECT status, COUNT(*) c FROM {$tbl} GROUP BY status", ARRAY_A );
        $bucket_counts = array(
            'pending'    => 0,
            'processing' => 0,
            'ready'      => 0,
            'failed'     => 0,
            'rejected'   => 0,
            'cancelled'  => 0,
            'expired'    => 0,
        );
        if ( is_array( $buckets ) ) {
            foreach ( $buckets as $b ) {
                $key = isset( $b['status'] ) ? (string) $b['status'] : '';
                if ( isset( $bucket_counts[ $key ] ) ) {
                    $bucket_counts[ $key ] = (int) $b['c'];
                }
            }
        }

        return new WP_REST_Response( array(
            'success'        => true,
            'data'           => $rows,
            'total'          => $total,
            'page'           => $page,
            'per_page'       => $per_page,
            'bucket_counts'  => $bucket_counts,
            'filters_used'   => array(
                'status'   => $status,
                'type'     => $type,
                'user'     => $user_id,
                'age_days' => $age_days,
            ),
        ), 200 );
    }
}

