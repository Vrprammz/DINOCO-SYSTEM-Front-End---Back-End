// ═══════════════════════════════════════════════════════════════════
// Client IP Resolver (V.1.1 M3) — Cloudflare / proxy aware
// ═══════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_gdpr_get_client_ip' ) ) {
    /**
     * Resolve real client IP behind trusted proxies (Cloudflare, generic forwarded).
     * Order: CF-Connecting-IP → X-Forwarded-For (first) → X-Real-IP → REMOTE_ADDR.
     * Optionally gate on `DINOCO_TRUSTED_PROXIES` constant (array of CIDR/IP).
     *
     * Without real IP → audit trail records upstream proxy (useless for abuse tracking
     * + misleading for PDPA Section 30 / GDPR Article 15 data subject identification).
     *
     * @return string IP address (may be empty string if all sources invalid)
     */
    function dinoco_gdpr_get_client_ip() {
        $trusted = defined( 'DINOCO_TRUSTED_PROXIES' ) ? (array) DINOCO_TRUSTED_PROXIES : array();
        $remote  = isset( $_SERVER['REMOTE_ADDR'] ) ? (string) $_SERVER['REMOTE_ADDR'] : '';
        // If no trusted proxy config, accept Cloudflare + X-Forwarded-For by default (Cloudflare is common)
        unset( $trusted ); // reserved for future CIDR gating
        $headers = array( 'HTTP_CF_CONNECTING_IP', 'HTTP_X_FORWARDED_FOR', 'HTTP_X_REAL_IP' );
        foreach ( $headers as $h ) {
            if ( empty( $_SERVER[ $h ] ) ) continue;
            $val       = explode( ',', (string) $_SERVER[ $h ] );
            $candidate = trim( $val[0] );
            if ( filter_var( $candidate, FILTER_VALIDATE_IP ) ) {
                return $candidate;
            }
        }
        return $remote;
    }
}

