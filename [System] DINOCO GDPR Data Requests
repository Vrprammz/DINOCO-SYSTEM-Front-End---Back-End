// ───────────────────────────────────────────────────────────────────
// V.2.0 — Queue Worker
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_run_worker' ) ) {
    /**
     * Process a queued GDPR request. Called via wp_schedule_single_event
     * (which fires after dinoco_gdpr_queue_request inserts).
     *
     * State machine: queued → processing → ready | failed.
     *
     * Critical safety:
     *   - FOR UPDATE lock prevents 2 workers stepping on same request
     *   - Status check ('queued' only) prevents re-running already-processing/done
     *   - Try/catch ensures failed status + notes captured even on fatal
     *
     * NOT FIRED until dinoco_gdpr_enabled=1.
     *
     * @param int $request_id wp_dinoco_gdpr_requests.id
     * @return void
     */
    function dinoco_gdpr_run_worker( $request_id ) {
        // Defensive flag gate — even if this hook fires somehow, do nothing if disabled
        if ( ! function_exists( 'dinoco_gdpr_is_enabled' ) || ! dinoco_gdpr_is_enabled() ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[GDPR] Worker SKIPPED request_id=%d (flag OFF)', (int) $request_id ) );
            }
            return;
        }

        global $wpdb;
        $request_id = absint( $request_id );
        if ( $request_id <= 0 ) return;

        $table = $wpdb->prefix . 'dinoco_gdpr_requests';

        // Stage 1: claim the request via FOR UPDATE
        $wpdb->query( 'START TRANSACTION' );
        $req = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$table} WHERE id = %d AND status = 'pending' FOR UPDATE",
            $request_id
        ) );
        if ( ! $req ) {
            $wpdb->query( 'COMMIT' );
            // Already processing/done/expired — silent return (worker idempotent on retry)
            return;
        }

        $wpdb->update(
            $table,
            array(
                'status'       => 'processing',
                'processed_at' => current_time( 'mysql' ),
            ),
            array( 'id' => $request_id ),
            array( '%s', '%s' ),
            array( '%d' )
        );
        $wpdb->query( 'COMMIT' );

        // Stage 2: execute outside transaction (heavy work — ZIP build / cascade delete)
        try {
            $user_id = (int) $req->user_id;
            $type    = (string) $req->type;

            $result_payload = array();
            $download_token = null;
            $expires_at     = null;

            if ( $type === 'export' ) {
                $export = function_exists( 'dinoco_gdpr_build_export' )
                    ? dinoco_gdpr_build_export( $user_id )
                    : array( 'success' => false, 'error' => 'build_export_unavailable' );
                if ( ! empty( $export['success'] ) ) {
                    $download_token = isset( $export['token'] ) ? (string) $export['token'] : '';
                    $expires_at     = isset( $export['expires_at'] ) ? (string) $export['expires_at'] : '';
                    $result_payload = array(
                        'zip_path'       => isset( $export['zip_path'] ) ? $export['zip_path'] : '',
                        'download_url'   => isset( $export['download_url'] ) ? $export['download_url'] : '',
                        'size_bytes'     => isset( $export['size_bytes'] ) ? (int) $export['size_bytes'] : 0,
                        'record_counts'  => isset( $export['record_counts'] ) ? $export['record_counts'] : array(),
                    );
                    if ( function_exists( 'dinoco_gdpr_email_user' ) ) {
                        dinoco_gdpr_email_user( $user_id, 'export_ready', $result_payload );
                    }
                } else {
                    throw new \Exception( isset( $export['error'] ) ? (string) $export['error'] : 'export_failed' );
                }
            } elseif ( $type === 'delete' ) {
                $deletion = function_exists( 'dinoco_gdpr_execute_deletion' )
                    ? dinoco_gdpr_execute_deletion( $user_id )
                    : array( 'success' => false, 'error' => 'execute_deletion_unavailable' );
                if ( ! empty( $deletion['success'] ) ) {
                    $result_payload = isset( $deletion['report'] ) ? $deletion['report'] : array();
                    if ( function_exists( 'dinoco_gdpr_email_user' ) ) {
                        dinoco_gdpr_email_user( $user_id, 'deletion_complete', $result_payload );
                    }
                } else {
                    throw new \Exception( isset( $deletion['error'] ) ? (string) $deletion['error'] : 'deletion_failed' );
                }
            } else {
                throw new \Exception( 'Unknown request type: ' . $type );
            }

            // Stage 3: mark ready
            $update_data = array(
                'status'     => 'ready',
                'scope_json' => function_exists( 'wp_json_encode' ) ? wp_json_encode( $result_payload ) : json_encode( $result_payload ),
            );
            $update_format = array( '%s', '%s' );
            if ( $download_token ) {
                $update_data['download_token'] = substr( $download_token, 0, 64 );
                $update_format[] = '%s';
            }
            if ( $expires_at ) {
                $update_data['expires_at'] = $expires_at;
                $update_format[] = '%s';
            }
            $wpdb->update( $table, $update_data, array( 'id' => $request_id ), $update_format, array( '%d' ) );

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[GDPR] Worker SUCCESS request_id=%d type=%s user_id=%d', $request_id, $type, $user_id ) );
            }
        } catch ( \Throwable $e ) {
            // Failure path — record error in notes for admin review, fire alert
            $wpdb->update(
                $table,
                array(
                    'status' => 'failed',
                    'notes'  => 'Worker error: ' . substr( $e->getMessage(), 0, 1000 ),
                ),
                array( 'id' => $request_id ),
                array( '%s', '%s' ),
                array( '%d' )
            );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[GDPR] Worker FAILED request_id=%d err=%s', $request_id, $e->getMessage() ) );
            }
            // Optional Telegram alert if helper exists
            if ( function_exists( 'b2b_push_to_admin' ) ) {
                b2b_push_to_admin( sprintf( '[GDPR] Worker failed: request_id=%d err=%s', $request_id, $e->getMessage() ) );
            }
        }
    }
}

// Hook worker — listener registered always (cheap), but body gates on flag
add_action( 'dinoco_gdpr_process_request', 'dinoco_gdpr_run_worker', 10, 1 );

