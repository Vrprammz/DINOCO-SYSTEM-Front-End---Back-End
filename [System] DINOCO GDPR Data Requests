if ( ! function_exists( 'dinoco_gdpr_rest_admin_approve' ) ) {
    /**
     * POST /admin/request/{id}/approve
     * Body: confirm_text (required, must equal "APPROVE" for safety)
     * Behavior:
     *   - Verify status='pending' (FOR UPDATE)
     *   - Set status='processing' + reviewed_by/at + cancellation_window_at = now+30s
     *   - Schedule wp_schedule_single_event('dinoco_gdpr_process_request', now+30s)
     *   - Return scheduled_at + window_until
     */
    function dinoco_gdpr_rest_admin_approve( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }
        $id = absint( $request->get_param( 'id' ) );
        if ( $id <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'code' => 'invalid_id' ), 400 );
        }

        // Round 57 — Idempotency wrap on irreversible approve→processing transition.
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco-gdpr/v1::admin-approve';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'request_id'    => (int) $id,
                'confirm_text'  => (string) $request->get_param( 'confirm_text' ),
                'actor_user_id' => (int) get_current_user_id(),
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) {
                $code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 200;
                unset( $cached['_idem_code'] );
                return new WP_REST_Response( $cached, $code );
            }
        }

        // Confirmation gate — caller must pass "APPROVE" (matches dinocoModal.confirm typed input)
        $confirm = (string) $request->get_param( 'confirm_text' );
        if ( $confirm !== 'APPROVE' ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'confirmation_required',
                'message' => 'Pass confirm_text=APPROVE to proceed',
            ), 400 );
        }

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_requests';

        $wpdb->query( 'START TRANSACTION' );
        try {
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, status, type, user_id FROM {$tbl} WHERE id = %d FOR UPDATE", $id
            ), ARRAY_A );
            if ( ! $row ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array( 'success' => false, 'code' => 'not_found' ), 404 );
            }
            if ( $row['status'] !== 'pending' ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array(
                    'success' => false,
                    'code'    => 'invalid_state',
                    'message' => 'Request must be in pending state, currently: ' . $row['status'],
                    'current_status' => $row['status'],
                ), 409 );
            }
            // State machine validate
            if ( ! dinoco_gdpr_is_valid_status_transition( $row['status'], 'processing' ) ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array(
                    'success' => false,
                    'code'    => 'invalid_transition',
                    'message' => 'pending → processing transition rejected by state machine',
                ), 409 );
            }

            $now             = current_time( 'mysql' );
            $window_until    = gmdate( 'Y-m-d H:i:s', strtotime( current_time( 'mysql', 1 ) ) + 30 );
            $window_until_ts = time() + 30;

            $wpdb->update(
                $tbl,
                array(
                    'status'                 => 'processing',
                    'reviewed_by'            => get_current_user_id(),
                    'reviewed_at'            => $now,
                    'cancellation_window_at' => $window_until,
                ),
                array( 'id' => $id ),
                array( '%s', '%d', '%s', '%s' ),
                array( '%d' )
            );
            $wpdb->query( 'COMMIT' );
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_REST_Response( array( 'success' => false, 'code' => 'db_error', 'message' => $e->getMessage() ), 500 );
        }

        // Schedule worker AFTER 30s undo window. wp_schedule_single_event uses GMT timestamp.
        $scheduled = wp_schedule_single_event( $window_until_ts, 'dinoco_gdpr_process_request', array( $id ) );

        dinoco_gdpr_audit_log( $id, 'approve', array(
            'from_status' => 'pending',
            'to_status'   => 'processing',
            'note'        => 'Worker scheduled at ' . $window_until . ' (30s undo window)',
        ) );

        $resp_arr = array(
            'success'         => true,
            'request_id'      => $id,
            'scheduled'       => (bool) $scheduled,
            'scheduled_at'    => $window_until,
            'window_seconds'  => 30,
            'message'         => 'Approved. Worker fires after 30s undo window.',
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $resp_arr, array( '_idem_code' => 200 ) ), 200 );
        }
        return new WP_REST_Response( $resp_arr, 200 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_admin_reject' ) ) {
    /**
     * POST /admin/request/{id}/reject
     * Body: reason (enum), note (optional)
     */
    function dinoco_gdpr_rest_admin_reject( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }
        $id     = absint( $request->get_param( 'id' ) );
        $reason = sanitize_key( (string) $request->get_param( 'reason' ) );

        // Round 57 — Idempotency wrap. reason discriminator catches admin re-evaluation.
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco-gdpr/v1::admin-reject';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'request_id'    => (int) $id,
                'reason'        => $reason,
                'actor_user_id' => (int) get_current_user_id(),
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) {
                $code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 200;
                unset( $cached['_idem_code'] );
                return new WP_REST_Response( $cached, $code );
            }
        }
        $note   = sanitize_textarea_field( (string) $request->get_param( 'note' ) );
        if ( $id <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'code' => 'invalid_id' ), 400 );
        }
        $valid_reasons = array( 'legal_hold', 'fraud', 'cooling_off', 'other' );
        if ( ! in_array( $reason, $valid_reasons, true ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'invalid_reason',
                'message' => 'reason must be one of: ' . implode( ', ', $valid_reasons ),
            ), 400 );
        }
        if ( $reason === 'other' && strlen( trim( $note ) ) < 5 ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'note_required',
                'message' => 'note (>=5 chars) is required when reason=other',
            ), 400 );
        }

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_requests';

        $wpdb->query( 'START TRANSACTION' );
        try {
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, status, user_id FROM {$tbl} WHERE id = %d FOR UPDATE", $id
            ), ARRAY_A );
            if ( ! $row ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array( 'success' => false, 'code' => 'not_found' ), 404 );
            }
            if ( $row['status'] !== 'pending' ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array(
                    'success' => false,
                    'code'    => 'invalid_state',
                    'current_status' => $row['status'],
                ), 409 );
            }
            if ( ! dinoco_gdpr_is_valid_status_transition( $row['status'], 'rejected' ) ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array( 'success' => false, 'code' => 'invalid_transition' ), 409 );
            }

            $combined_note = '[REJECTED reason=' . $reason . '] ' . $note;
            if ( strlen( $combined_note ) > 1000 ) $combined_note = substr( $combined_note, 0, 1000 );

            $wpdb->update(
                $tbl,
                array(
                    'status'       => 'rejected',
                    'reviewed_by'  => get_current_user_id(),
                    'reviewed_at'  => current_time( 'mysql' ),
                    'processed_at' => current_time( 'mysql' ),
                    'notes'        => $combined_note,
                ),
                array( 'id' => $id ),
                array( '%s', '%d', '%s', '%s', '%s' ),
                array( '%d' )
            );
            $wpdb->query( 'COMMIT' );
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_REST_Response( array( 'success' => false, 'code' => 'db_error' ), 500 );
        }

        dinoco_gdpr_audit_log( $id, 'reject', array(
            'from_status' => 'pending',
            'to_status'   => 'rejected',
            'reason'      => $reason,
            'note'        => $note,
        ) );

        // Notify user via email if helper available
        if ( function_exists( 'dinoco_gdpr_email_user' ) ) {
            $payload = array( 'reason' => 'reason=' . $reason . ( $note ? '; ' . $note : '' ) );
            dinoco_gdpr_email_user( (int) $row['user_id'], 'rejection', $payload );
        }

        $resp_arr = array(
            'success'    => true,
            'request_id' => $id,
            'message'    => 'Request rejected. User notified via email.',
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $resp_arr, array( '_idem_code' => 200 ) ), 200 );
        }
        return new WP_REST_Response( $resp_arr, 200 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_admin_undo' ) ) {
    /**
     * POST /admin/request/{id}/undo
     * Cancels an approval within the 30-second window. Removes scheduled event.
     */
    function dinoco_gdpr_rest_admin_undo( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }
        $id = absint( $request->get_param( 'id' ) );
        if ( $id <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'code' => 'invalid_id' ), 400 );
        }

        // Round 57 — Idempotency wrap on undo (30s window).
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco-gdpr/v1::admin-undo';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array( 'request_id' => (int) $id, 'actor_user_id' => (int) get_current_user_id() );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) {
                $code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 200;
                unset( $cached['_idem_code'] );
                return new WP_REST_Response( $cached, $code );
            }
        }

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_requests';

        $wpdb->query( 'START TRANSACTION' );
        try {
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, status, cancellation_window_at FROM {$tbl} WHERE id = %d FOR UPDATE", $id
            ), ARRAY_A );
            if ( ! $row ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array( 'success' => false, 'code' => 'not_found' ), 404 );
            }
            if ( $row['status'] !== 'processing' ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array(
                    'success' => false,
                    'code'    => 'invalid_state',
                    'message' => 'Undo only allowed during processing (within 30s window)',
                    'current_status' => $row['status'],
                ), 409 );
            }
            // 30s window check
            $window_at = $row['cancellation_window_at'];
            if ( ! $window_at || strtotime( $window_at ) < time() ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array(
                    'success' => false,
                    'code'    => 'window_expired',
                    'message' => '30-second undo window has expired. Worker may have already started.',
                ), 410 );
            }
            if ( ! dinoco_gdpr_is_valid_status_transition( $row['status'], 'cancelled' ) ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_REST_Response( array( 'success' => false, 'code' => 'invalid_transition' ), 409 );
            }

            $wpdb->update(
                $tbl,
                array(
                    'status'       => 'cancelled',
                    'reviewed_by'  => get_current_user_id(),
                    'reviewed_at'  => current_time( 'mysql' ),
                    'processed_at' => current_time( 'mysql' ),
                    'notes'        => 'Cancelled by admin undo within 30s window',
                ),
                array( 'id' => $id ),
                array( '%s', '%d', '%s', '%s', '%s' ),
                array( '%d' )
            );
            $wpdb->query( 'COMMIT' );
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_REST_Response( array( 'success' => false, 'code' => 'db_error' ), 500 );
        }

        // Unschedule worker (best-effort — wp_unschedule_event removes by hook+args+timestamp)
        $next = wp_next_scheduled( 'dinoco_gdpr_process_request', array( $id ) );
        if ( $next ) {
            wp_unschedule_event( $next, 'dinoco_gdpr_process_request', array( $id ) );
        }

        dinoco_gdpr_audit_log( $id, 'undo', array(
            'from_status' => 'processing',
            'to_status'   => 'cancelled',
            'note'        => 'Cancelled via 30s undo window',
        ) );

        $resp_arr = array(
            'success'    => true,
            'request_id' => $id,
            'message'    => 'Approval cancelled. Worker unscheduled.',
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $resp_arr, array( '_idem_code' => 200 ) ), 200 );
        }
        return new WP_REST_Response( $resp_arr, 200 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_admin_manual_export' ) ) {
    /**
     * POST /admin/request/{id}/manual-export
     * Admin manual trigger for failed/stuck requests. Synchronous — runs worker NOW.
     * Useful to retry failed exports without waiting for cron.
     */
    function dinoco_gdpr_rest_admin_manual_export( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }
        $id = absint( $request->get_param( 'id' ) );
        if ( $id <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'code' => 'invalid_id' ), 400 );
        }

        // Round 57 — Idempotency wrap. Synchronous worker run = heavy DB+I/O cascade.
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco-gdpr/v1::admin-manual-export';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'request_id'    => (int) $id,
                'confirm_text'  => (string) $request->get_param( 'confirm_text' ),
                'actor_user_id' => (int) get_current_user_id(),
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) {
                $code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 200;
                unset( $cached['_idem_code'] );
                return new WP_REST_Response( $cached, $code );
            }
        }

        $confirm = (string) $request->get_param( 'confirm_text' );
        if ( $confirm !== 'PROCESS' ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'confirmation_required',
                'message' => 'Pass confirm_text=PROCESS to proceed (synchronous run)',
            ), 400 );
        }

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_requests';
        $row = $wpdb->get_row( $wpdb->prepare( "SELECT id, status FROM {$tbl} WHERE id = %d", $id ), ARRAY_A );
        if ( ! $row ) {
            return new WP_REST_Response( array( 'success' => false, 'code' => 'not_found' ), 404 );
        }
        // Allowed states for manual processing: failed (retry) or pending (skip undo window)
        if ( ! in_array( $row['status'], array( 'failed', 'pending' ), true ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'invalid_state',
                'message' => 'Manual export only allowed from pending or failed state',
                'current_status' => $row['status'],
            ), 409 );
        }

        // Reset to pending so worker's FOR UPDATE 'pending' check passes
        $wpdb->update(
            $tbl,
            array(
                'status'      => 'pending',
                'reviewed_by' => get_current_user_id(),
                'reviewed_at' => current_time( 'mysql' ),
                'notes'       => 'Manual processing trigger',
            ),
            array( 'id' => $id ),
            array( '%s', '%d', '%s', '%s' ),
            array( '%d' )
        );

        dinoco_gdpr_audit_log( $id, 'manual_export', array(
            'from_status' => $row['status'],
            'to_status'   => 'pending',
            'note'        => 'Synchronous manual processing initiated',
        ) );

        // Run worker synchronously — gives admin immediate feedback
        if ( function_exists( 'dinoco_gdpr_run_worker' ) ) {
            dinoco_gdpr_run_worker( $id );
        }

        // Re-read final state
        $final = $wpdb->get_row( $wpdb->prepare( "SELECT id, status, notes FROM {$tbl} WHERE id = %d", $id ), ARRAY_A );

        $resp_arr = array(
            'success'      => true,
            'request_id'   => $id,
            'final_status' => $final ? $final['status'] : '?',
            'message'      => 'Manual processing complete (synchronous)',
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $resp_arr, array( '_idem_code' => 200 ) ), 200 );
        }
        return new WP_REST_Response( $resp_arr, 200 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_admin_audit_log' ) ) {
    /**
     * GET /admin/audit-log
     * Filters: request_id, actor_user_id, action, date_from, date_to
     */
    function dinoco_gdpr_rest_admin_audit_log( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_audit_log';

        $request_id = absint( $request->get_param( 'request_id' ) );
        $actor_id   = absint( $request->get_param( 'actor_user_id' ) );
        $action     = sanitize_key( (string) $request->get_param( 'action' ) );
        $date_from  = sanitize_text_field( (string) $request->get_param( 'date_from' ) );
        $date_to    = sanitize_text_field( (string) $request->get_param( 'date_to' ) );
        $page       = max( 1, absint( $request->get_param( 'page' ) ) ?: 1 );
        $per_page   = max( 1, min( 200, absint( $request->get_param( 'per_page' ) ) ?: 50 ) );
        $offset     = ( $page - 1 ) * $per_page;

        $where  = array( '1=1' );
        $params = array();
        if ( $request_id > 0 ) {
            $where[]  = 'request_id = %d';
            $params[] = $request_id;
        }
        if ( $actor_id > 0 ) {
            $where[]  = 'actor_user_id = %d';
            $params[] = $actor_id;
        }
        if ( $action ) {
            $where[]  = 'action = %s';
            $params[] = $action;
        }
        if ( $date_from && preg_match( '/^\d{4}-\d{2}-\d{2}/', $date_from ) ) {
            $where[]  = 'created_at >= %s';
            $params[] = substr( $date_from, 0, 10 ) . ' 00:00:00';
        }
        if ( $date_to && preg_match( '/^\d{4}-\d{2}-\d{2}/', $date_to ) ) {
            $where[]  = 'created_at <= %s';
            $params[] = substr( $date_to, 0, 10 ) . ' 23:59:59';
        }
        $where_sql = implode( ' AND ', $where );

        $count_sql = "SELECT COUNT(*) FROM {$tbl} WHERE {$where_sql}";
        $total = $params
            ? (int) $wpdb->get_var( $wpdb->prepare( $count_sql, $params ) )
            : (int) $wpdb->get_var( $count_sql );

        $rows_sql = "SELECT id, request_id, actor_user_id, actor_login, action,
                            from_status, to_status, reason, note, actor_ip, created_at
                     FROM {$tbl}
                     WHERE {$where_sql}
                     ORDER BY id DESC
                     LIMIT %d OFFSET %d";
        $rows = $wpdb->get_results( $wpdb->prepare( $rows_sql, array_merge( $params, array( $per_page, $offset ) ) ), ARRAY_A );

        // CSV export support — ?export=csv
        if ( (string) $request->get_param( 'export' ) === 'csv' ) {
            // Cap export to 5000 rows for safety
            $rows_sql_csv = "SELECT id, request_id, actor_user_id, actor_login, action,
                                    from_status, to_status, reason, note, actor_ip, created_at
                             FROM {$tbl}
                             WHERE {$where_sql}
                             ORDER BY id DESC
                             LIMIT 5000";
            $csv_rows = $params
                ? $wpdb->get_results( $wpdb->prepare( $rows_sql_csv, $params ), ARRAY_A )
                : $wpdb->get_results( $rows_sql_csv, ARRAY_A );

            // Build CSV with UTF-8 BOM (Thai-friendly)
            $csv = "\xEF\xBB\xBF"; // BOM
            $csv .= "id,request_id,actor_user_id,actor_login,action,from_status,to_status,reason,note,actor_ip,created_at\n";
            if ( is_array( $csv_rows ) ) {
                foreach ( $csv_rows as $r ) {
                    $csv .= sprintf( "%d,%d,%d,\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\"\n",
                        (int) $r['id'],
                        (int) $r['request_id'],
                        (int) $r['actor_user_id'],
                        str_replace( '"', '""', (string) $r['actor_login'] ),
                        str_replace( '"', '""', (string) $r['action'] ),
                        str_replace( '"', '""', (string) $r['from_status'] ),
                        str_replace( '"', '""', (string) $r['to_status'] ),
                        str_replace( '"', '""', (string) $r['reason'] ),
                        str_replace( '"', '""', str_replace( "\n", ' ', (string) $r['note'] ) ),
                        str_replace( '"', '""', (string) $r['actor_ip'] ),
                        (string) $r['created_at']
                    );
                }
            }
            $resp = new WP_REST_Response( $csv, 200 );
            $resp->header( 'Content-Type', 'text/csv; charset=utf-8' );
            $resp->header( 'Content-Disposition', 'attachment; filename=gdpr-audit-' . gmdate( 'Ymd' ) . '.csv' );
            return $resp;
        }

        return new WP_REST_Response( array(
            'success'  => true,
            'data'     => is_array( $rows ) ? $rows : array(),
            'total'    => $total,
            'page'     => $page,
            'per_page' => $per_page,
        ), 200 );
    }
}

