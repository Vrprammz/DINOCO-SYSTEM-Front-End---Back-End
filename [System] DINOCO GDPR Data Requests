}

if ( ! function_exists( 'dinoco_gdpr_admin_record_summary' ) ) {
    /**
     * Quick stats summary of records linked to a user. Stats only — no PII.
     * Used in Pending Review card to give admin context before approval.
     *
     * @param int $user_id
     * @return array { warranties: int, claims: int, orders: int, has_open_debt: bool }
     */
    function dinoco_gdpr_admin_record_summary( $user_id ) {
        $user_id = (int) $user_id;
        $summary = array(
            'warranties'    => 0,
            'claims'        => 0,
            'orders'        => 0,
            'has_open_debt' => false,
            'open_debt_thb' => 0.0,
        );
        if ( $user_id <= 0 ) return $summary;

        // Warranties (post_author)
        $w = new WP_Query( array(
            'post_type'      => 'dinoco_warranty',
            'post_status'    => 'any',
            'author'         => $user_id,
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'no_found_rows'  => false,
        ) );
        $summary['warranties'] = (int) $w->found_posts;

        // Claims (post_author)
        $c = new WP_Query( array(
            'post_type'      => 'claim_ticket',
            'post_status'    => 'any',
            'author'         => $user_id,
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'no_found_rows'  => false,
        ) );
        $summary['claims'] = (int) $c->found_posts;

        // Orders (linked distributor)
        $linked_dist_id = (int) get_user_meta( $user_id, 'linked_distributor_id', true );
        if ( $linked_dist_id > 0 ) {
            $o = new WP_Query( array(
                'post_type'      => 'b2b_order',
                'post_status'    => 'any',
                'posts_per_page' => 1,
                'fields'         => 'ids',
                'no_found_rows'  => false,
                'meta_query'     => array(
                    array( 'key' => 'distributor_id', 'value' => $linked_dist_id ),
                ),
            ) );
            $summary['orders'] = (int) $o->found_posts;

            // Open debt check (legal hold candidate)
            $debt = function_exists( 'get_field' ) ? (float) get_field( 'current_debt', $linked_dist_id ) : 0.0;
            if ( $debt > 0 ) {
                $summary['has_open_debt'] = true;
                $summary['open_debt_thb'] = $debt;
            }
        }
        return $summary;
    }
}

