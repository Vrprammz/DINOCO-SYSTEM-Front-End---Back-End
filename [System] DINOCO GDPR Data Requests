// V.4.0 — LINE Messages Export (cross-system, OpenClaw MongoDB)
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_export_line_messages' ) ) {
    /**
     * V.4.0 — Fetch LINE conversation history from OpenClaw agent (MongoDB).
     *
     * Cross-system call to agent:3000 (containerized OpenClaw proxy). Returns
     * array shape: { messages: [...], claims: [...], leads: [...], total_count }.
     * On any failure (timeout, 4xx/5xx, missing constants) returns empty array
     * + logs warning — does NOT block the rest of the export.
     *
     * Auth: Bearer LIFF_AI_AGENT_KEY (same env constant used by liff_ai_call_agent).
     * Rate limit enforced agent-side (1 export/line_uid/hour, MongoDB-backed).
     *
     * @param string $line_uid    LINE user ID (e.g. "U1234567890abc...") from
     *                           wp_usermeta `dinoco_line_uid`.
     * @param int    $request_id  GDPR request_id for audit correlation (passed
     *                           as ?request_id= query param to agent).
     * @return array {
     *     @type array  $messages    LINE conversation history (timestamp, direction, text, type)
     *     @type array  $claims      Claim logs originated via LINE (created_at, status, claim_id)
     *     @type array  $leads       Lead records (created_at, status, product_interest, lead_id)
     *     @type int    $total_count Sum of above lengths
     *     @type string $generated_at ISO 8601 timestamp from agent
     *     @type bool   $unavailable True if agent unreachable (caller skip)
     * }
     */
    function dinoco_gdpr_export_line_messages( $line_uid, $request_id = 0 ) {
        $empty = array(
            'messages'     => array(),
            'claims'       => array(),
            'leads'        => array(),
            'total_count'  => 0,
            'generated_at' => '',
            'unavailable'  => false,
        );

        $line_uid = trim( (string) $line_uid );
        if ( $line_uid === '' || strlen( $line_uid ) < 5 ) {
            return $empty;
        }

        // Required constants
        if ( ! defined( 'LIFF_AI_AGENT_URL' ) || ! defined( 'LIFF_AI_AGENT_KEY' ) ) {
            error_log( '[GDPR-LINE] Skipped: LIFF_AI_AGENT_URL or LIFF_AI_AGENT_KEY undefined' );
            $empty['unavailable'] = true;
            return $empty;
        }

        $base_url = rtrim( LIFF_AI_AGENT_URL, '/' );
        $endpoint = $base_url . '/api/gdpr/line-messages';
        $url = add_query_arg( array(
            'line_uid'   => $line_uid,
            'request_id' => (int) $request_id,
        ), $endpoint );

        $args = array(
            'method'  => 'GET',
            'headers' => array(
                'Authorization' => 'Bearer ' . LIFF_AI_AGENT_KEY,
                'Accept'        => 'application/json',
            ),
            'timeout' => 10,
        );

        // Try once, then retry on transient network failure (max 1 retry)
        $response = wp_remote_request( $url, $args );
        if ( is_wp_error( $response ) ) {
            error_log( '[GDPR-LINE] First attempt failed for uid=' . substr( $line_uid, 0, 6 ) . '...: ' . $response->get_error_message() . ' — retrying once' );
            // Fallback: try localhost if URL contains agent: hostname (Docker compat)
            if ( strpos( $url, 'agent:' ) !== false ) {
                $fallback_url = str_replace( 'agent:', 'localhost:', $url );
                $response = wp_remote_request( $fallback_url, $args );
            } else {
                $response = wp_remote_request( $url, $args );  // simple retry
            }
            if ( is_wp_error( $response ) ) {
                error_log( '[GDPR-LINE] Retry failed: ' . $response->get_error_message() );
                $empty['unavailable'] = true;
                return $empty;
            }
        }

        $code = wp_remote_retrieve_response_code( $response );
        $body_str = wp_remote_retrieve_body( $response );

        // 429 rate-limited (recent export already issued) → return empty + log
        if ( $code === 429 ) {
            error_log( '[GDPR-LINE] Rate limited for uid=' . substr( $line_uid, 0, 6 ) . '... (1/hour cap)' );
            $empty['unavailable'] = true;
            return $empty;
        }
        // 503 db unavailable → log + empty
        if ( $code >= 500 ) {
            error_log( '[GDPR-LINE] Server error code=' . $code . ' body=' . substr( $body_str, 0, 200 ) );
            $empty['unavailable'] = true;
            return $empty;
        }
        if ( $code >= 400 ) {
            error_log( '[GDPR-LINE] Client error code=' . $code . ' body=' . substr( $body_str, 0, 200 ) );
            return $empty;  // not unavailable — likely missing line_uid validation; treat as no data
        }

        $data = json_decode( $body_str, true );
        if ( ! is_array( $data ) || empty( $data['ok'] ) ) {
            error_log( '[GDPR-LINE] Malformed agent response for uid=' . substr( $line_uid, 0, 6 ) . '...' );
            return $empty;
        }

        return array(
            'messages'     => isset( $data['messages'] ) && is_array( $data['messages'] ) ? $data['messages'] : array(),
            'claims'       => isset( $data['claims'] ) && is_array( $data['claims'] ) ? $data['claims'] : array(),
            'leads'        => isset( $data['leads'] ) && is_array( $data['leads'] ) ? $data['leads'] : array(),
            'total_count'  => isset( $data['total_count'] ) ? (int) $data['total_count'] : 0,
            'generated_at' => isset( $data['generated_at'] ) ? (string) $data['generated_at'] : '',
            'unavailable'  => false,
        );
    }
}

// ───────────────────────────────────────────────────────────────────
// V.4.2 — S/N Management CSV Exporters (Phase 4 W14.4)
// ───────────────────────────────────────────────────────────────────
//
// These helpers supplement the V.4.1 JSON exports. They produce
// regulator-friendly CSV (UTF-8 BOM + RFC 4180) for the two highest-
// priority S/N tables: sn_pool (plates owned by user) + sn_audit
// (events where user was actor or approver).
//
// Defensive contract:
//   - Table existence checked via INFORMATION_SCHEMA.TABLES probe
//   - Missing table → write *-UNAVAILABLE.txt placeholder (does NOT
//     throw; orchestrator continues)
//   - Empty result with table present → CSV header row only (NOT
//     UNAVAILABLE — the user simply has no rows yet)
//   - All cross-snippet calls wrapped in function_exists() guards
//   - Audit log entries written best-effort via dinoco_gdpr_audit_log()

if ( ! function_exists( 'dinoco_gdpr_csv_escape_cell' ) ) {
    /**
     * Escape a single cell per RFC 4180:
     *   - If value contains comma, double-quote, CR, or LF: wrap in
     *     double-quotes and double any embedded double-quotes.
     *   - Otherwise emit as-is.
     *   - null / empty → empty cell.
     *
     * @param mixed $v
     * @return string
     */
    function dinoco_gdpr_csv_escape_cell( $v ) {
        if ( $v === null ) return '';
        $s = (string) $v;
        if ( $s === '' ) return '';
        if ( preg_match( '/[",\r\n]/', $s ) ) {
            return '"' . str_replace( '"', '""', $s ) . '"';
        }
        return $s;
    }
}

if ( ! function_exists( 'dinoco_gdpr_csv_build_row' ) ) {
    /**
     * Build a single CSV row from an associative array given a column
     * order. Missing keys → empty cells (defensive — schema variations).
     *
     * @param array $row     associative
     * @param array $columns ordered list of column names
     * @return string CSV line (no trailing newline)
     */
    function dinoco_gdpr_csv_build_row( $row, $columns ) {
        $cells = array();
        foreach ( $columns as $col ) {
            $val = isset( $row[ $col ] ) ? $row[ $col ] : null;
            $cells[] = dinoco_gdpr_csv_escape_cell( $val );
        }
        return implode( ',', $cells );
    }
}

if ( ! function_exists( 'dinoco_gdpr_csv_redact_audit_context' ) ) {
    /**
     * Defensive PII strip on sn_audit.context_json before CSV write.
     * Keys removed: phone, email, line_uid, national_id, credit_card,
     * password, token, secret. Returns empty string if input cannot be
     * decoded (treats as already-empty).
     *
     * @param string|null $raw
     * @return string redacted JSON (or '' if input empty/invalid)
     */
    function dinoco_gdpr_csv_redact_audit_context( $raw ) {
        if ( $raw === null || $raw === '' ) return '';
        $decoded = json_decode( (string) $raw, true );
        if ( ! is_array( $decoded ) ) return '';
        $pii_keys = array(
            'phone', 'email', 'line_uid', 'national_id',
            'credit_card', 'password', 'token', 'secret',
            'authorization', 'api_key', 'bearer',
        );
        foreach ( $pii_keys as $k ) {
            if ( array_key_exists( $k, $decoded ) ) {
                unset( $decoded[ $k ] );
            }
        }
        $out = wp_json_encode( $decoded, JSON_UNESCAPED_UNICODE );
        return is_string( $out ) ? $out : '';
    }
}

if ( ! function_exists( 'dinoco_gdpr_export_sn_pool_data' ) ) {
    /**
     * Export sn_pool + sn_pool_meta data for a user as CSV.
     *
     * Output: associative result array. Caller (orchestrator) decides
     * whether to write CSV string to ZIP or write UNAVAILABLE placeholder.
     *
     * @param int $user_id     WP user ID (registered_user_id)
     * @param int $request_id  wp_dinoco_gdpr_requests.id (for audit log)
     * @return array {
     *   @type bool   $success
     *   @type bool   $table_existed
     *   @type string $csv               '' if table missing
     *   @type string $placeholder_text  '' unless UNAVAILABLE
     *   @type int    $rows_exported
     *   @type int    $file_size_bytes
     * }
     */
    function dinoco_gdpr_export_sn_pool_data( $user_id, $request_id = 0 ) {
        $user_id    = absint( $user_id );
        $request_id = absint( $request_id );

        $result = array(
            'success'          => false,
            'table_existed'    => false,
            'csv'              => '',
            'placeholder_text' => '',
            'rows_exported'    => 0,
            'file_size_bytes'  => 0,
        );

        if ( $user_id <= 0 ) {
            $result['placeholder_text'] = "S/N pool export unavailable: invalid user_id\n";
            return $result;
        }

        global $wpdb;
        $tbl      = $wpdb->prefix . 'dinoco_sn_pool';
        $meta_tbl = $wpdb->prefix . 'dinoco_sn_pool_meta';

        // INFORMATION_SCHEMA probe — defensive against missing table
        $tbl_exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        if ( ! ( (int) $tbl_exists > 0 ) ) {
            $result['placeholder_text'] = "wp_dinoco_sn_pool table not installed.\n" .
                "S/N system may not yet be activated on this site.\n" .
                "Generated: " . gmdate( 'c' ) . "\n";
            // Best-effort audit log
            if ( $request_id > 0 && function_exists( 'dinoco_gdpr_audit_log' ) ) {
                dinoco_gdpr_audit_log( $request_id, 'export_sn_pool', array(
                    'note' => wp_json_encode( array(
                        'rows_exported'   => 0,
                        'table_existed'   => false,
                        'file_size_bytes' => strlen( $result['placeholder_text'] ),
                    ) ),
                ) );
            }
            return $result;
        }

        $result['table_existed'] = true;

        // Check meta table existence (optional join)
        $meta_exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $meta_tbl
        ) );
        $has_meta = ( (int) $meta_exists > 0 );

        // Hot path columns (always present)
        $columns = array(
            'sn',
            'batch_id',
            'linked_sku',
            'status',
            'prev_status',
            'lock_version',
            'registered_user_id',
            'registered_at',
            'created_at',
        );
        if ( $has_meta ) {
            $columns = array_merge( $columns, array(
                'purchase_dealer_id',
                'purchase_date',
                'top_set_sku',
                'replaced_by_sn',
                'replaces_sn',
                'stolen_at',
            ) );
        }

        // Build query — LEFT JOIN if meta available
        if ( $has_meta ) {
            $sql = "SELECT p.sn, p.batch_id, p.linked_sku, p.status, p.prev_status,
                           p.lock_version, p.registered_user_id, p.registered_at,
                           p.created_at,
                           m.purchase_dealer_id, m.purchase_date, m.top_set_sku,
                           m.replaced_by_sn, m.replaces_sn, m.stolen_at
                    FROM {$tbl} p
                    LEFT JOIN {$meta_tbl} m ON m.sn = p.sn
                    WHERE p.registered_user_id = %d
                    ORDER BY p.registered_at DESC";
        } else {
            $sql = "SELECT sn, batch_id, linked_sku, status, prev_status,
                           lock_version, registered_user_id, registered_at, created_at
                    FROM {$tbl}
                    WHERE registered_user_id = %d
                    ORDER BY registered_at DESC";
        }

        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $user_id ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        // Build CSV with UTF-8 BOM + RFC 4180. Empty-but-table-present is
        // valid (header row only) — NOT UNAVAILABLE.
        $bom = "\xEF\xBB\xBF";
        $lines = array();
        $lines[] = dinoco_gdpr_csv_build_row( array_combine( $columns, $columns ), $columns );
        foreach ( $rows as $row ) {
            $lines[] = dinoco_gdpr_csv_build_row( $row, $columns );
        }
        $csv = $bom . implode( "\r\n", $lines ) . "\r\n";

        $result['csv']             = $csv;
        $result['rows_exported']   = count( $rows );
        $result['file_size_bytes'] = strlen( $csv );
        $result['success']         = true;

        // Audit log (best-effort)
        if ( $request_id > 0 && function_exists( 'dinoco_gdpr_audit_log' ) ) {
            dinoco_gdpr_audit_log( $request_id, 'export_sn_pool', array(
                'note' => wp_json_encode( array(
                    'rows_exported'   => $result['rows_exported'],
                    'table_existed'   => true,
                    'file_size_bytes' => $result['file_size_bytes'],
                    'has_meta_join'   => $has_meta,
                ) ),
            ) );
        }

        // Optional cross-snippet observability hook
        if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
            dinoco_sn_obs_capture( null, array(
                'event'         => 'gdpr_export_sn_pool',
                'user_id'       => $user_id,
                'request_id'    => $request_id,
                'rows_exported' => $result['rows_exported'],
            ) );
        }

        return $result;
    }
}

if ( ! function_exists( 'dinoco_gdpr_export_sn_audit_data' ) ) {
    /**
     * Export sn_audit data for a user as CSV (where user was actor OR
     * approver). PII redacted from context_json before write.
     *
     * @param int $user_id
     * @param int $request_id
     * @return array see dinoco_gdpr_export_sn_pool_data() return shape
     */
    function dinoco_gdpr_export_sn_audit_data( $user_id, $request_id = 0 ) {
        $user_id    = absint( $user_id );
        $request_id = absint( $request_id );

        $result = array(
            'success'          => false,
            'table_existed'    => false,
            'csv'              => '',
            'placeholder_text' => '',
            'rows_exported'    => 0,
            'file_size_bytes'  => 0,
        );

        if ( $user_id <= 0 ) {
            $result['placeholder_text'] = "S/N audit export unavailable: invalid user_id\n";
            return $result;
        }

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_sn_audit';

        $tbl_exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        if ( ! ( (int) $tbl_exists > 0 ) ) {
            $result['placeholder_text'] = "wp_dinoco_sn_audit table not installed.\n" .
                "S/N system may not yet be activated on this site.\n" .
                "Generated: " . gmdate( 'c' ) . "\n";
            if ( $request_id > 0 && function_exists( 'dinoco_gdpr_audit_log' ) ) {
                dinoco_gdpr_audit_log( $request_id, 'export_sn_audit', array(
                    'note' => wp_json_encode( array(
                        'rows_exported'   => 0,
                        'table_existed'   => false,
                        'file_size_bytes' => strlen( $result['placeholder_text'] ),
                    ) ),
                ) );
            }
            return $result;
        }

        $result['table_existed'] = true;

        $columns = array(
            'id',
            'sn',
            'event_type',
            'status_from',
            'status_to',
            'role',           // actor | approver | both — derived
            'actor_user_id',
            'approver_user_id',
            'reason',
            'reason_category',
            'context_json_redacted',
            'is_sensitive',
            'created_at',
        );

        // 5,000 cap defensive
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, sn, event_type, status_from, status_to,
                    actor_user_id, approver_user_id, reason, reason_category,
                    context_json, is_sensitive, created_at
             FROM {$tbl}
             WHERE actor_user_id = %d OR approver_user_id = %d
             ORDER BY created_at DESC
             LIMIT 5000",
            $user_id, $user_id
        ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        // Augment each row with role + redacted context
        foreach ( $rows as &$r ) {
            $is_actor    = ( (int) $r['actor_user_id']    === $user_id );
            $is_approver = ( (int) $r['approver_user_id'] === $user_id );
            if ( $is_actor && $is_approver ) {
                $r['role'] = 'both';
            } elseif ( $is_actor ) {
                $r['role'] = 'actor';
            } elseif ( $is_approver ) {
                $r['role'] = 'approver';
            } else {
                $r['role'] = 'unknown';
            }
            $r['context_json_redacted'] = dinoco_gdpr_csv_redact_audit_context(
                isset( $r['context_json'] ) ? $r['context_json'] : ''
            );
        }
        unset( $r );

        $bom = "\xEF\xBB\xBF";
        $lines = array();
        $lines[] = dinoco_gdpr_csv_build_row( array_combine( $columns, $columns ), $columns );
        foreach ( $rows as $row ) {
            $lines[] = dinoco_gdpr_csv_build_row( $row, $columns );
        }
        $csv = $bom . implode( "\r\n", $lines ) . "\r\n";

        $result['csv']             = $csv;
        $result['rows_exported']   = count( $rows );
        $result['file_size_bytes'] = strlen( $csv );
        $result['success']         = true;

        if ( $request_id > 0 && function_exists( 'dinoco_gdpr_audit_log' ) ) {
            dinoco_gdpr_audit_log( $request_id, 'export_sn_audit', array(
                'note' => wp_json_encode( array(
                    'rows_exported'   => $result['rows_exported'],
                    'table_existed'   => true,
                    'file_size_bytes' => $result['file_size_bytes'],
                    'capped_at_5000'  => ( $result['rows_exported'] === 5000 ),
                ) ),
            ) );
        }

        if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
            dinoco_sn_obs_capture( null, array(
                'event'         => 'gdpr_export_sn_audit',
                'user_id'       => $user_id,
                'request_id'    => $request_id,
                'rows_exported' => $result['rows_exported'],
            ) );
        }

        return $result;
    }
}

