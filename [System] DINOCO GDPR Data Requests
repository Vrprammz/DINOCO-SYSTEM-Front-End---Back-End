    if ( ! $first_run ) $first_run = time() + DAY_IN_SECONDS;
    wp_schedule_event( $first_run, 'daily', 'dinoco_gdpr_export_cleanup_cron' );
}
if ( function_exists( 'dinoco_register_cron' ) ) {
