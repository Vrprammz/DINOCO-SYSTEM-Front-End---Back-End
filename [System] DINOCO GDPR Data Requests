// V.2.0 — Export Builder
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_build_export' ) ) {
    /**
     * Build a GDPR/PDPA data export ZIP for a user. Uses ZipArchive (PHP zip extension).
     *
     * Whitelist scope per docs/compliance/GDPR-PHASE-6-DESIGN.md:
     *   - account.json    : wp_users core profile (id, email, display_name, registered)
     *   - usermeta.json   : wp_usermeta filtered to PII whitelist keys (NEVER wildcard)
     *   - warranties.csv  : dinoco_warranty CPT (post_author = user)
     *   - claims/         : claim_ticket CPT JSON + photo URLs
     *   - orders.csv      : b2b_order CPT (only if user has linked distributor)
     *
     * Privacy hardening:
     *   - Output to wp-content/uploads/gdpr/{user_id}/ (gitignored, not web-accessible
     *     unless .htaccess is missing — install_dir() ensures .htaccess deny exists)
     *   - Token random_bytes(32) → 64 hex chars
     *   - 7-day TTL via expires_at (cleanup cron deletes file + nulls token)
     *
     * NOT FIRED until dinoco_gdpr_enabled=1.
     *
     * @param int $user_id WP user ID
     * @return array {
     *   @type bool   $success
     *   @type string $error          (if !success)
     *   @type string $zip_path       absolute filesystem path
     *   @type string $download_url   public URL (token-protected)
     *   @type string $token          download token
     *   @type string $expires_at     mysql DATETIME (now + 7 days)
     *   @type int    $size_bytes
     *   @type array  $record_counts  per-section count (warranties, claims, orders)
     * }
     */
    function dinoco_gdpr_build_export( $user_id ) {
        $user_id = absint( $user_id );
        if ( $user_id <= 0 ) {
            return array( 'success' => false, 'error' => 'invalid_user' );
        }
        if ( ! class_exists( 'ZipArchive' ) ) {
            return array( 'success' => false, 'error' => 'zip_extension_missing' );
        }

        $user = get_userdata( $user_id );
        if ( ! $user ) {
            return array( 'success' => false, 'error' => 'user_not_found' );
        }

        // Set up output directory (gitignored; .htaccess deny applied below)
        $upload  = wp_upload_dir();
        $base    = trailingslashit( $upload['basedir'] ) . 'gdpr/' . $user_id;
        $base_url = trailingslashit( $upload['baseurl'] ) . 'gdpr/' . $user_id;

        if ( ! wp_mkdir_p( $base ) ) {
            return array( 'success' => false, 'error' => 'mkdir_failed' );
        }

        // Defense-in-depth: deny all + noindex robots in this directory
        $htaccess = $base . '/.htaccess';
        if ( ! file_exists( $htaccess ) ) {
            @file_put_contents( $htaccess,
                "Require all denied\n" .
                "<IfModule mod_authz_core.c>\nRequire all denied\n</IfModule>\n" .
                "<IfModule !mod_authz_core.c>\nDeny from all\n</IfModule>\n"
            );
        }
        $robots = $base . '/robots.txt';
        if ( ! file_exists( $robots ) ) {
            @file_put_contents( $robots, "User-agent: *\nDisallow: /\n" );
        }

        // Generate secure token
        try {
            $token = bin2hex( random_bytes( 32 ) );
        } catch ( \Throwable $e ) {
            $token = wp_generate_password( 64, false, false );
        }

        $zip_filename = 'gdpr-export-' . $user_id . '-' . gmdate( 'Ymd-His' ) . '-' . substr( $token, 0, 8 ) . '.zip';
        $zip_path     = $base . '/' . $zip_filename;

        $zip = new \ZipArchive();
        if ( $zip->open( $zip_path, \ZipArchive::CREATE | \ZipArchive::OVERWRITE ) !== true ) {
            return array( 'success' => false, 'error' => 'zip_open_failed' );
        }

        $record_counts = array(
            'warranties' => 0,
            'claims'     => 0,
            'orders'     => 0,
        );

        // ── README.txt ──
        $readme = "DINOCO GDPR / Thai PDPA Data Export\n" .
            "===================================\n\n" .
            "User ID: {$user_id}\n" .
            "Email: " . ( $user->user_email ?: '(unknown)' ) . "\n" .
            "Generated: " . current_time( 'mysql' ) . "\n" .
            "Expires: " . gmdate( 'Y-m-d H:i:s', time() + 7 * DAY_IN_SECONDS ) . "\n\n" .
            "Contents:\n" .
            "  account.json     - Your WordPress account profile\n" .
            "  usermeta.json    - PII metadata (LINE UID, phone, address)\n" .
            "  warranties.csv   - Registered products + warranty history\n" .
            "  claims/          - Claim tickets (one JSON per claim)\n" .
            "  orders.csv       - B2B order history (distributors only)\n\n" .
            "Legal references:\n" .
            "  Thai PDPA Section 30-31 (Right of Access + Portability)\n" .
            "  GDPR Article 15 (Right of Access) + Article 20 (Data Portability)\n\n" .
            "Contact: support@dinoco.in.th\n";
        $zip->addFromString( 'README.txt', $readme );

        // ── account.json — WP user core profile (whitelist) ──
        $account = array(
            'id'                   => (int) $user->ID,
            'user_email'           => (string) $user->user_email,
            'display_name'         => (string) $user->display_name,
            'user_registered'      => (string) $user->user_registered,
            'user_url'             => (string) $user->user_url,
            'roles'                => is_array( $user->roles ) ? array_values( $user->roles ) : array(),
            'export_generated_at'  => current_time( 'mysql' ),
        );
        $zip->addFromString( 'account.json', wp_json_encode( $account, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ) );

        // ── usermeta.json — PII whitelist only ──
        $pii_keys = function_exists( 'dinoco_gdpr_pii_meta_key_whitelist' ) ? dinoco_gdpr_pii_meta_key_whitelist() : array();
        $usermeta = array();
        foreach ( $pii_keys as $key ) {
            $val = get_user_meta( $user_id, $key, true );
            if ( $val !== '' && $val !== null && $val !== false ) {
                $usermeta[ $key ] = $val;
            }
        }
        $zip->addFromString( 'usermeta.json', wp_json_encode( $usermeta, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ) );

        // ── warranties.csv — dinoco_warranty CPT ──
        $warranty_posts = get_posts( array(
            'post_type'      => 'dinoco_warranty',
            'post_status'    => 'any',
            'author'         => $user_id,
            'posts_per_page' => -1,
            'fields'         => 'ids',
        ) );
        $warranty_csv = "id,title,product_sku,brand,model,registration_date,status\n";
        foreach ( $warranty_posts as $wid ) {
            $title = (string) get_the_title( $wid );
            $sku   = (string) get_field( 'product_sku', $wid );
            $brand = (string) get_field( 'motorcycle_brand', $wid );
            $model = (string) get_field( 'motorcycle_model', $wid );
            $reg   = (string) get_field( 'registration_date', $wid );
            $stat  = (string) get_field( 'warranty_status', $wid );
            $warranty_csv .= sprintf( "%d,\"%s\",\"%s\",\"%s\",\"%s\",\"%s\",\"%s\"\n",
                $wid,
                str_replace( '"', '""', $title ),
                str_replace( '"', '""', $sku ),
                str_replace( '"', '""', $brand ),
                str_replace( '"', '""', $model ),
                str_replace( '"', '""', $reg ),
                str_replace( '"', '""', $stat )
            );
        }
        $zip->addFromString( 'warranties.csv', $warranty_csv );
        $record_counts['warranties'] = count( $warranty_posts );

        // ── claims/ — one JSON per claim_ticket ──
        $claim_posts = get_posts( array(
            'post_type'      => 'claim_ticket',
            'post_status'    => 'any',
            'author'         => $user_id,
            'posts_per_page' => -1,
            'fields'         => 'ids',
        ) );
        foreach ( $claim_posts as $cid ) {
            $claim = array(
                'id'             => $cid,
                'title'          => get_the_title( $cid ),
                'date_created'   => get_the_date( 'c', $cid ),
                'ticket_status'  => (string) get_field( 'ticket_status', $cid ),
                'product_sku'    => (string) get_field( 'product_sku', $cid ),
                'description'    => (string) get_field( 'claim_description', $cid ),
                'photo_count'    => count( (array) get_field( 'claim_photos', $cid ) ?: array() ),
                // photos themselves not embedded — too heavy; URLs included as references
                'photo_urls'     => array_values( array_filter( (array) get_field( 'claim_photos', $cid ) ?: array(), 'is_string' ) ),
            );
            $zip->addFromString( 'claims/claim-' . $cid . '.json',
                wp_json_encode( $claim, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ) );
        }
        $record_counts['claims'] = count( $claim_posts );

        // ── orders.csv — b2b_order CPT (linked distributor) ──
        $linked_dist_id = (int) get_user_meta( $user_id, 'linked_distributor_id', true );
        if ( $linked_dist_id > 0 ) {
            $order_posts = get_posts( array(
                'post_type'      => 'b2b_order',
                'post_status'    => 'any',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => array(
                    array(
                        'key'   => 'distributor_id',
                        'value' => $linked_dist_id,
                    ),
                ),
            ) );
            $orders_csv = "id,date,status,total,is_billed\n";
            foreach ( $order_posts as $oid ) {
                $orders_csv .= sprintf( "%d,\"%s\",\"%s\",%.2f,%d\n",
                    $oid,
                    get_the_date( 'c', $oid ),
                    (string) get_field( 'order_status', $oid ),
                    (float) get_field( 'total_amount', $oid ),
                    (int) get_field( 'is_billed', $oid )
                );
            }
            $zip->addFromString( 'orders.csv', $orders_csv );
            $record_counts['orders'] = count( $order_posts );
        }

        $zip->close();

        $size_bytes = file_exists( $zip_path ) ? filesize( $zip_path ) : 0;
        $expires_at = gmdate( 'Y-m-d H:i:s', time() + 7 * DAY_IN_SECONDS );

        return array(
            'success'       => true,
            'zip_path'      => $zip_path,
            'download_url'  => $base_url . '/' . $zip_filename . '?token=' . $token,
            'token'         => $token,
            'expires_at'    => $expires_at,
            'size_bytes'    => (int) $size_bytes,
            'record_counts' => $record_counts,
        );
    }
}

// ───────────────────────────────────────────────────────────────────
// V.2.0 — Deletion Executor (decision matrix)
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_execute_deletion' ) ) {
    /**
     * Execute a deletion request per the documented decision matrix.
     *
     * Strategy:
     *   wp_users.user_email → hash to deleted-{hash}@anon.local
     *   wp_usermeta PII keys → DELETE row
     *   warranty/claim/order CPTs → anonymize customer_* fields (preserve record)
     *   debt_log / payable_log → PRESERVE (legal hold)
     *
     * Returns per-table report. NOT fired until dinoco_gdpr_enabled=1.
     *
     * @param int $user_id
     * @return array { success: bool, error?: string, report?: array }
     */
    function dinoco_gdpr_execute_deletion( $user_id ) {
        $user_id = absint( $user_id );
        if ( $user_id <= 0 ) {
            return array( 'success' => false, 'error' => 'invalid_user' );
        }

        $user = get_userdata( $user_id );
        if ( ! $user ) {
            return array( 'success' => false, 'error' => 'user_not_found' );
        }

        $report = array(
            'wp_users'              => array( 'action' => 'pending', 'count' => 0 ),
            'wp_usermeta_pii'       => array( 'action' => 'pending', 'count' => 0 ),
            'dinoco_warranty'       => array( 'action' => 'pending', 'count' => 0 ),
            'claim_ticket'          => array( 'action' => 'pending', 'count' => 0 ),
            'b2b_order'             => array( 'action' => 'pending', 'count' => 0 ),
            'dinoco_debt_log'       => array( 'action' => 'preserved_legal_hold', 'count' => 0 ),
            'b2f_payable_log'       => array( 'action' => 'preserved_legal_hold', 'count' => 0 ),
        );

        try {
            // 1. Anonymize wp_users.user_email (ref integrity preserved)
            $email_hash = substr( md5( $user->user_email . $user_id . microtime( true ) ), 0, 12 );
            wp_update_user( array(
                'ID'           => $user_id,
                'user_email'   => 'deleted-' . $email_hash . '@anon.local',
                'display_name' => 'Deleted User',
                'user_url'     => '',
            ) );
            $report['wp_users']['action'] = 'anonymized';
            $report['wp_users']['count']  = 1;

            // 2. DELETE PII usermeta rows (whitelist only)
            $pii_keys   = function_exists( 'dinoco_gdpr_pii_meta_key_whitelist' ) ? dinoco_gdpr_pii_meta_key_whitelist() : array();
            $deleted_meta = 0;
            foreach ( $pii_keys as $key ) {
                if ( delete_user_meta( $user_id, $key ) ) {
                    $deleted_meta++;
                }
            }
            $report['wp_usermeta_pii']['action'] = 'deleted';
            $report['wp_usermeta_pii']['count']  = $deleted_meta;

            // 3. Anonymize warranties (preserve product/SKU but strip customer fields)
            $w_posts = get_posts( array(
                'post_type'      => 'dinoco_warranty',
                'post_status'    => 'any',
                'author'         => $user_id,
                'posts_per_page' => -1,
                'fields'         => 'ids',
            ) );
            foreach ( $w_posts as $wid ) {
                update_field( 'customer_name', '[Anonymized]', $wid );
                update_field( 'customer_phone', '', $wid );
                update_field( 'customer_email', '', $wid );
                update_field( 'customer_address', '', $wid );
            }
            $report['dinoco_warranty']['action'] = 'anonymized';
            $report['dinoco_warranty']['count']  = count( $w_posts );

            // 4. Anonymize claims (preserve product defect record)
            $c_posts = get_posts( array(
                'post_type'      => 'claim_ticket',
                'post_status'    => 'any',
                'author'         => $user_id,
                'posts_per_page' => -1,
                'fields'         => 'ids',
            ) );
            foreach ( $c_posts as $cid ) {
                update_field( 'customer_name', '[Anonymized]', $cid );
                update_field( 'customer_phone', '', $cid );
                update_field( 'customer_email', '', $cid );
            }
            $report['claim_ticket']['action'] = 'anonymized';
            $report['claim_ticket']['count']  = count( $c_posts );

            // 5. Anonymize b2b_orders (linked distributor)
            $linked_dist_id = (int) get_user_meta( $user_id, 'linked_distributor_id', true );
            if ( $linked_dist_id > 0 ) {
                $o_posts = get_posts( array(
                    'post_type'      => 'b2b_order',
                    'post_status'    => 'any',
                    'posts_per_page' => -1,
                    'fields'         => 'ids',
                    'meta_query'     => array(
                        array(
                            'key'   => 'distributor_id',
                            'value' => $linked_dist_id,
                        ),
                    ),
                ) );
                foreach ( $o_posts as $oid ) {
                    update_field( 'dist_name', '[Anonymized]', $oid );
                    update_field( 'dist_phone', '', $oid );
                    update_field( 'dist_address', '', $oid );
                }
                $report['b2b_order']['action'] = 'anonymized';
                $report['b2b_order']['count']  = count( $o_posts );
            } else {
                $report['b2b_order']['action'] = 'none';
            }

            return array( 'success' => true, 'report' => $report );
        } catch ( \Throwable $e ) {
            return array(
                'success' => false,
                'error'   => 'deletion_failed: ' . $e->getMessage(),
                'report'  => $report,
            );
        }
    }
}

// ───────────────────────────────────────────────────────────────────
// V.2.0 — Email Notification (templates skeleton)
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_email_user' ) ) {
    /**
     * Send completion email to user. Thai default with English fallback.
     * Templates skeleton — admin can extend via filter `dinoco_gdpr_email_subject_*`
     * and `dinoco_gdpr_email_body_*`.
     *
     * NOT FIRED until dinoco_gdpr_enabled=1 (worker is the sole caller).
     *
     * @param int    $user_id
     * @param string $template 'export_ready' | 'deletion_complete' | 'rejection'
     * @param array  $payload  Per-template payload (download_url for export, report for deletion)
     * @return bool wp_mail() result
     */
    function dinoco_gdpr_email_user( $user_id, $template, $payload = array() ) {
        $user = get_userdata( $user_id );
        if ( ! $user || ! $user->user_email ) return false;

        $subject = '';
        $body    = '';

        switch ( $template ) {
            case 'export_ready':
                $subject = apply_filters( 'dinoco_gdpr_email_subject_export', '[DINOCO] ข้อมูลของคุณพร้อมดาวน์โหลด — Your data export is ready' );
                $url     = isset( $payload['download_url'] ) ? esc_url_raw( $payload['download_url'] ) : '';
                $body    = "เรียนคุณ {$user->display_name},\n\n" .
                    "ข้อมูลส่วนตัวของคุณพร้อมดาวน์โหลดแล้ว ลิงก์หมดอายุใน 7 วัน:\n\n" .
                    "{$url}\n\n" .
                    "หากมีคำถามกรุณาติดต่อ support@dinoco.in.th\n\n" .
                    "---\n\n" .
                    "Dear {$user->display_name},\n\n" .
                    "Your personal data export is ready for download. Link expires in 7 days:\n\n" .
                    "{$url}\n\n" .
                    "Contact support@dinoco.in.th for any questions.\n\n" .
                    "Legal: Thailand PDPA §31 / GDPR Article 20.\n";
                break;
            case 'deletion_complete':
                $subject = apply_filters( 'dinoco_gdpr_email_subject_deletion', '[DINOCO] ดำเนินการลบข้อมูลเรียบร้อย — Deletion complete' );
                $report  = is_array( $payload ) ? $payload : array();
                $body    = "เรียนคุณ {$user->display_name},\n\n" .
                    "เราได้ลบข้อมูลส่วนตัวของคุณตามคำขอเรียบร้อยแล้ว\n" .
                    "หมายเหตุ: ข้อมูลทางการเงิน/ใบเสร็จต้องเก็บ 5 ปีตามกฎหมาย (Thai Revenue Code §86/14)\n\n" .
                    "Summary: " . wp_json_encode( $report, JSON_UNESCAPED_UNICODE ) . "\n\n" .
                    "---\n\n" .
                    "Dear {$user->display_name},\n\n" .
                    "Your data deletion request has been processed.\n" .
                    "Note: Financial records preserved per Thai Revenue Code §86/14 (5-year retention).\n\n" .
                    "Legal: Thailand PDPA §32 / GDPR Article 17.\n";
                break;
            case 'rejection':
                $subject = '[DINOCO] คำขอของคุณถูกปฏิเสธ — Request rejected';
                $reason  = isset( $payload['reason'] ) ? (string) $payload['reason'] : '(no reason provided)';
                $body    = "เรียนคุณ {$user->display_name},\n\n" .
                    "คำขอของคุณถูกปฏิเสธโดยผู้ดูแลระบบ:\n\n" .
                    "เหตุผล: {$reason}\n\n" .
                    "หากต้องการอุทธรณ์ กรุณาติดต่อ support@dinoco.in.th\n\n" .
                    "---\n\nReason: {$reason}\n\n" .
                    "Legal: Thailand PDPA §35 / GDPR Article 12.\n";
                break;
            default:
                return false;
        }

        return (bool) wp_mail( $user->user_email, $subject, $body );
    }
}

// ───────────────────────────────────────────────────────────────────
// V.2.0 — Export Cleanup Cron (daily 03:30; prune ZIP files >7d)
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_export_cleanup_run' ) ) {
    /**
     * Daily cron: delete export ZIP files past expires_at + null download_token
     * in the request row. Runs even if flag OFF (defensive — clean up legacy
     * test data even after rollback).
     *
     * @return int count of files deleted
     */
    function dinoco_gdpr_export_cleanup_run() {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_gdpr_requests';

        // Defensive — schema may not be at v2.0 yet
        $col_exists = $wpdb->get_var( $wpdb->prepare(
            "SHOW COLUMNS FROM {$tbl} LIKE %s", 'expires_at'
        ) );
        if ( ! $col_exists ) return 0;

        $expired = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, scope_json FROM {$tbl}
             WHERE type = 'export'
               AND status = 'ready'
               AND expires_at IS NOT NULL
               AND expires_at < %s
             LIMIT 200",
            current_time( 'mysql' )
        ) );
        if ( ! is_array( $expired ) || empty( $expired ) ) return 0;

        $deleted_files = 0;
        foreach ( $expired as $row ) {
            $scope = json_decode( (string) $row->scope_json, true );
            if ( is_array( $scope ) && ! empty( $scope['zip_path'] ) ) {
                $path = (string) $scope['zip_path'];
                if ( file_exists( $path ) && @unlink( $path ) ) {
                    $deleted_files++;
                }
            }
            // Null token + mark expired in status
            $wpdb->update(
                $tbl,
                array(
                    'status'         => 'expired',
                    'download_token' => null,
                    'notes'          => 'Auto-pruned 7d post-creation',
                ),
                array( 'id' => (int) $row->id ),
                array( '%s', '%s', '%s' ),
                array( '%d' )
            );
        }

        if ( $deleted_files > 0 && function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[GDPR] Export cleanup pruned %d files', $deleted_files ) );
        }

        return $deleted_files;
    }
}

// Schedule daily 03:30 (offset from idempotency cleanup at 03:15 + flag-audit retention at 03:00)
if ( ! wp_next_scheduled( 'dinoco_gdpr_export_cleanup_cron' ) ) {
    $first_run = strtotime( 'tomorrow 03:30' );
    if ( ! $first_run ) $first_run = time() + DAY_IN_SECONDS;
    wp_schedule_event( $first_run, 'daily', 'dinoco_gdpr_export_cleanup_cron' );
}
if ( function_exists( 'dinoco_register_cron' ) ) {
    dinoco_register_cron( 'dinoco_gdpr_export_cleanup_cron', 'daily', 'dinoco_gdpr_export_cleanup_run' );
} else {
    add_action( 'dinoco_gdpr_export_cleanup_cron', 'dinoco_gdpr_export_cleanup_run' );
}

