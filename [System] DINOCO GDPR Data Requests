if ( ! function_exists( 'dinoco_gdpr_rest_export' ) ) {
    function dinoco_gdpr_rest_export( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }

        $user_id = get_current_user_id();
        $queued  = dinoco_gdpr_queue_request( $user_id, 'export' );
        if ( is_wp_error( $queued ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => $queued->get_error_code(),
                'message' => $queued->get_error_message(),
                'data'    => $queued->get_error_data(),
            ), isset( $queued->get_error_data()['status'] ) ? $queued->get_error_data()['status'] : 400 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'code'    => 'queued',
            'message' => 'Export request received. You will receive a download link via email within 30 days (PDPA Section 30).',
            'data'    => $queued,
        ), 202 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_delete' ) ) {
    function dinoco_gdpr_rest_delete( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }

        // Require explicit confirmation (defense against accidental calls)
        $confirm = $request->get_param( 'confirm' );
        if ( $confirm !== 'DELETE_MY_ACCOUNT' ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'confirmation_required',
                'message' => 'Pass confirm=DELETE_MY_ACCOUNT to proceed. This action is irreversible.',
            ), 400 );
        }

        $user_id = get_current_user_id();
        $queued  = dinoco_gdpr_queue_request( $user_id, 'delete' );
        if ( is_wp_error( $queued ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => $queued->get_error_code(),
                'message' => $queued->get_error_message(),
                'data'    => $queued->get_error_data(),
            ), isset( $queued->get_error_data()['status'] ) ? $queued->get_error_data()['status'] : 400 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'code'    => 'queued',
            'message' => 'Deletion request received. Admin will review within 30 days (PDPA Section 33). Account remains active until processed.',
            'data'    => $queued,
        ), 202 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_status' ) ) {
    function dinoco_gdpr_rest_status( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }

        global $wpdb;
        $user_id = get_current_user_id();
        $table   = $wpdb->prefix . 'dinoco_gdpr_requests';

        // Ensure schema exists before query
        dinoco_gdpr_schema_install();

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, type, status, ticket_id, created_at, processed_at, notes
             FROM {$table}
             WHERE user_id = %d
             ORDER BY created_at DESC
             LIMIT 20",
            $user_id
        ), ARRAY_A );

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => array(
                'requests' => $rows ?: array(),
                'user_id'  => $user_id,
            ),
        ), 200 );
    }
}

// ═══════════════════════════════════════════════════════════════════
// V.2.0 Round 23 Phase 2 — Phase 6 FOUNDATION (FLAG-GATED OFF DEFAULT)
//
// All helpers below are DORMANT until `dinoco_gdpr_enabled=1` is flipped.
// REST endpoints + worker invocation gate on flag — adding these helpers
// has ZERO behavior change on production.
//
// Architecture (per docs/compliance/GDPR-PHASE-6-DESIGN.md):
//   1. User POSTs /my-data-{export|delete} → queue request → schedule worker event
//   2. Worker (wp_schedule_single_event) picks up → FOR UPDATE lock → state machine
//   3. Worker calls dinoco_gdpr_build_export() OR dinoco_gdpr_execute_deletion()
//   4. Worker emails user via dinoco_gdpr_email_user() with completion + download URL
//   5. Daily 03:30 cron prunes ZIP files >7 days (download_token table column expires)
//
// Decision matrix (deletion):
//   wp_users.user_email   → anonymize (preserve referential integrity)
//   wp_usermeta PII       → DELETE row (no legal need)
//   dinoco_warranty CPT   → anonymize customer_* (5yr Consumer Protection retention)
//   claim_ticket CPT      → anonymize customer name (preserve defect record)
//   b2b_order CPT         → anonymize dist_name + delete addresses (5yr Tax Code)
//   dinoco_debt_log       → NEVER DELETE (Thai Revenue Code §86/14 audit trail)
//   b2f_payable_log       → NEVER DELETE (same)
//   LINE messages MongoDB → hard delete (no business obligation)
//   slip images           → hard delete (PII-rich bank account)
// ═══════════════════════════════════════════════════════════════════

// ───────────────────────────────────────────────────────────────────
// V.2.0 — Decision matrix helper (PURE — testable without WP/DB)
// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_decide_action_for_record' ) ) {
    /**
     * Pure decision-matrix lookup. Returns the action to take for a given
     * record type per the deletion strategy.
     *
     * @param string $record_type Record type identifier
     *   Recognized values:
     *   - 'wp_users'             → 'anonymize'
     *   - 'wp_usermeta_pii'      → 'delete'
     *   - 'wp_usermeta_non_pii'  → 'preserve'
     *   - 'dinoco_warranty'      → 'anonymize'
     *   - 'claim_ticket'         → 'anonymize'
     *   - 'b2b_order'            → 'anonymize'
     *   - 'dinoco_debt_log'      → 'preserve'    (legal hold)
     *   - 'b2f_payable_log'      → 'preserve'    (legal hold)
     *   - 'line_messages_mongo'  → 'delete'
     *   - 'slip_images_fs'       → 'delete'
     *   - (unknown)              → 'preserve'    (safe default — never accidentally delete)
     *
     * @return string One of: 'anonymize' | 'delete' | 'preserve'
     */
    function dinoco_gdpr_decide_action_for_record( $record_type ) {
        // Whitelist mapping — explicitly covers each known record type.
        // SAFETY: unknown types fall through to 'preserve' (never destroy data we don't recognize).
        $matrix = array(
            // PII-bearing records — anonymize to preserve referential integrity
            'wp_users'             => 'anonymize',
            'dinoco_warranty'      => 'anonymize',
            'claim_ticket'         => 'anonymize',
            'b2b_order'            => 'anonymize',

            // Non-essential PII — delete row entirely
            'wp_usermeta_pii'      => 'delete',
            'line_messages_mongo'  => 'delete',
            'slip_images_fs'       => 'delete',

            // Legal hold — financial audit trail (Thai Revenue Code §86/14, 5-year retention)
            'dinoco_debt_log'      => 'preserve',
            'b2f_payable_log'      => 'preserve',
            'b2b_invoice'          => 'preserve',  // tax record retention

            // Non-PII metadata — preserve as-is
            'wp_usermeta_non_pii'  => 'preserve',
        );

        $type = is_string( $record_type ) ? strtolower( trim( $record_type ) ) : '';
        return isset( $matrix[ $type ] ) ? $matrix[ $type ] : 'preserve';
    }
}

if ( ! function_exists( 'dinoco_gdpr_pii_meta_key_whitelist' ) ) {
    /**
     * Whitelist of wp_usermeta keys considered PII for deletion.
     * Conservative list — admin can extend via filter `dinoco_gdpr_pii_meta_keys`.
     *
     * @return array<string>
     */
    function dinoco_gdpr_pii_meta_key_whitelist() {
        $defaults = array(
            // LINE-linked auth (member-facing PII)
            'dinoco_line_uid',
            'dinoco_line_display_name',
            'dinoco_line_picture_url',

            // Distributor-linked records
            'linked_distributor_id',  // foreign key — preserve relationship; PII is in CPT
            'dinoco_phone',
            'dinoco_email_secondary',

            // Address fragments (rare — most addresses are in CPT not usermeta)
            'dinoco_address_line',
            'dinoco_address_district',
            'dinoco_address_city',
            'dinoco_address_province',
            'dinoco_address_postcode',
        );
        return apply_filters( 'dinoco_gdpr_pii_meta_keys', $defaults );
    }
}

