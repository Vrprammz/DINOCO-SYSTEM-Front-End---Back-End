add_action( 'rest_api_init', function() {

    $auth_logged_in = function() {
        if ( ! is_user_logged_in() ) {
            return new WP_Error( 'not_logged_in', 'Login required', array( 'status' => 401 ) );
        }
        return true;
    };

    // POST /my-data-export
    register_rest_route( 'dinoco-gdpr/v1', '/my-data-export', array(
        'methods'             => 'POST',
        'permission_callback' => $auth_logged_in,
        'callback'            => 'dinoco_gdpr_rest_export',
    ) );

    // POST /my-data-delete
    register_rest_route( 'dinoco-gdpr/v1', '/my-data-delete', array(
        'methods'             => 'POST',
        'permission_callback' => $auth_logged_in,
        'callback'            => 'dinoco_gdpr_rest_delete',
    ) );

    // GET /my-data-status
    register_rest_route( 'dinoco-gdpr/v1', '/my-data-status', array(
        'methods'             => 'GET',
        'permission_callback' => $auth_logged_in,
        'callback'            => 'dinoco_gdpr_rest_status',
    ) );

    // ═══════════════════════════════════════════════════════════════════
    // V.3.0 Round 24 Phase 7 — Admin Review REST endpoints
    // Permission: manage_options + wp_rest nonce (X-WP-Nonce header)
    // Rate limit: 60/min/user (best-effort transient)
    // Flag gate: ALL endpoints return 503 when dinoco_gdpr_enabled=0
    // ═══════════════════════════════════════════════════════════════════

    $auth_admin = function( $request ) {
        if ( ! is_user_logged_in() ) {
            return new WP_Error( 'not_logged_in', 'Login required', array( 'status' => 401 ) );
        }
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'forbidden', 'Admin capability required', array( 'status' => 403 ) );
        }
        // CSRF — nonce check on POST only (GET endpoints are read-only).
        // Note: WP REST cookie auth automatically requires X-WP-Nonce on cookie-authed
        // requests, but we double-check here for explicit POST verification.
        $method = $request->get_method();
        if ( $method !== 'GET' ) {
            $nonce = $request->get_header( 'X-WP-Nonce' );
            if ( ! $nonce ) {
                $nonce = $request->get_param( '_wpnonce' );
            }
            if ( ! $nonce || ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
                return new WP_Error( 'rest_cookie_invalid_nonce', 'Cookie nonce is invalid', array( 'status' => 403 ) );
            }
        }
        // Rate limit 60/min/user — best-effort transient
        $uid       = get_current_user_id();
        $bucket    = 'dnc_gdpr_admin_rl_' . $uid . '_' . floor( time() / 60 );
        $hits      = (int) get_transient( $bucket );
        if ( $hits >= 60 ) {
            return new WP_Error( 'rate_limited', 'Too many admin requests (60/min cap)', array( 'status' => 429 ) );
        }
        set_transient( $bucket, $hits + 1, 70 );
        return true;
    };

    // GET /admin/requests — list (filters: status, type, age, user)
    register_rest_route( 'dinoco-gdpr/v1', '/admin/requests', array(
        'methods'             => 'GET',
