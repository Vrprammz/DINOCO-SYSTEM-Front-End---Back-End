if ( ! function_exists( 'dinoco_gdpr_schema_install' ) ) {
    /**
     * Install wp_dinoco_gdpr_requests table via dbDelta (idempotent).
     * Tracks schema version in wp_option 'dinoco_gdpr_schema_version'.
     *
     * V.2.0: schema bumped to 2.0 — adds 3 Phase 6 columns (download_token, scope_json, expires_at).
     * dbDelta handles ALTER TABLE for existing v1.0 installs (additive only — no destructive changes).
     *
     * @return void
     */
    function dinoco_gdpr_schema_install() {
        global $wpdb;

        $current_version = get_option( 'dinoco_gdpr_schema_version', '0' );
        $target_version  = '3.0';
        if ( $current_version === $target_version ) return;

        $table   = $wpdb->prefix . 'dinoco_gdpr_requests';
        $charset = $wpdb->get_charset_collate();

        // V.2.0 Phase 6: +3 columns. dbDelta detects + ALTERs existing tables additively.
        //   download_token VARCHAR(64) — secure random token for export ZIP signed URL (Phase 6)
        //   scope_json LONGTEXT — full snapshot of records affected (admin audit trail; PII redacted)
        //   expires_at DATETIME — when downloadable export expires (7 days post-creation; cron prunes)
        // V.3.0 Phase 7: +3 columns for admin review workflow.
        //   reviewed_by BIGINT — WP user_id of admin who approved/rejected/manual-processed
        //   reviewed_at DATETIME — when admin took the action (audit trail)
        //   cancellation_window_at DATETIME — 30s undo window after approval (worker fires after this)
        $sql = "CREATE TABLE {$table} (
            id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
            user_id BIGINT(20) UNSIGNED NOT NULL,
            type VARCHAR(20) NOT NULL,
            status VARCHAR(20) NOT NULL DEFAULT 'pending',
            ticket_id VARCHAR(40) NOT NULL,
            request_ip VARCHAR(45) DEFAULT NULL,
            request_ua VARCHAR(255) DEFAULT NULL,
            notes TEXT DEFAULT NULL,
            download_token VARCHAR(64) DEFAULT NULL,
            scope_json LONGTEXT DEFAULT NULL,
            expires_at DATETIME DEFAULT NULL,
            reviewed_by BIGINT(20) UNSIGNED DEFAULT NULL,
            reviewed_at DATETIME DEFAULT NULL,
            cancellation_window_at DATETIME DEFAULT NULL,
            created_at DATETIME NOT NULL,
            processed_at DATETIME DEFAULT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY uq_ticket (ticket_id),
            KEY idx_user_status (user_id, status),
            KEY idx_status_created (status, created_at),
            KEY idx_expires_at (expires_at),
            KEY idx_reviewed_by (reviewed_by)
        ) {$charset};";

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';
        dbDelta( $sql );

        // V.3.0 Phase 7: Audit log table — immutable append-only decision trail.
        // Records EVERY admin action (approve, reject, manual-export, undo, status change, view).
        // PDPA §39 documentation requirement + GDPR Article 30 records of processing.
        $audit_table = $wpdb->prefix . 'dinoco_gdpr_audit_log';
        $sql_audit = "CREATE TABLE {$audit_table} (
            id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
            request_id BIGINT(20) UNSIGNED NOT NULL,
            actor_user_id BIGINT(20) UNSIGNED NOT NULL,
            actor_login VARCHAR(60) DEFAULT NULL,
            action VARCHAR(40) NOT NULL,
            from_status VARCHAR(20) DEFAULT NULL,
            to_status VARCHAR(20) DEFAULT NULL,
            reason VARCHAR(40) DEFAULT NULL,
            note TEXT DEFAULT NULL,
            actor_ip VARCHAR(45) DEFAULT NULL,
            created_at DATETIME NOT NULL,
            PRIMARY KEY  (id),
            KEY idx_request (request_id),
            KEY idx_actor (actor_user_id),
            KEY idx_action_created (action, created_at)
        ) {$charset};";
        dbDelta( $sql_audit );

        update_option( 'dinoco_gdpr_schema_version', $target_version, false );
    }
}

// Lazy install on admin_init (safe: runs once per admin page load, dbDelta is idempotent)
add_action( 'admin_init', function() {
    if ( get_option( 'dinoco_gdpr_schema_version', '0' ) !== '3.0' ) {
        dinoco_gdpr_schema_install();
