// ───────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_gdpr_audit_log' ) ) {
    /**
     * Insert immutable audit log row. PDPA §39 documentation requirement.
     *
     * @param int    $request_id   wp_dinoco_gdpr_requests.id
     * @param string $action       e.g. 'approve', 'reject', 'undo', 'manual_export', 'view', 'transition'
     * @param array  $opts         {
     *     @type string $from_status
     *     @type string $to_status
     *     @type string $reason     enum: legal_hold|fraud|cooling_off|other
     *     @type string $note       free text (truncated to 1000 chars)
     * }
     * @return int|false insert_id or false on fail
     */
    function dinoco_gdpr_audit_log( $request_id, $action, $opts = array() ) {
        global $wpdb;
        $tbl  = $wpdb->prefix . 'dinoco_gdpr_audit_log';
        $user = wp_get_current_user();
        $ip   = function_exists( 'dinoco_gdpr_get_client_ip' ) ? dinoco_gdpr_get_client_ip() : '';

        $note = isset( $opts['note'] ) ? (string) $opts['note'] : '';
        if ( strlen( $note ) > 1000 ) $note = substr( $note, 0, 1000 );

        $data = array(
            'request_id'    => (int) $request_id,
            'actor_user_id' => $user ? (int) $user->ID : 0,
            'actor_login'   => $user && isset( $user->user_login ) ? substr( (string) $user->user_login, 0, 60 ) : null,
            'action'        => substr( (string) $action, 0, 40 ),
            'from_status'   => isset( $opts['from_status'] ) ? substr( (string) $opts['from_status'], 0, 20 ) : null,
            'to_status'     => isset( $opts['to_status'] ) ? substr( (string) $opts['to_status'], 0, 20 ) : null,
            'reason'        => isset( $opts['reason'] ) ? substr( (string) $opts['reason'], 0, 40 ) : null,
            'note'          => $note ?: null,
            'actor_ip'      => $ip ? substr( (string) $ip, 0, 45 ) : null,
            'created_at'    => current_time( 'mysql' ),
        );
        $formats = array( '%d', '%d', '%s', '%s', '%s', '%s', '%s', '%s', '%s', '%s' );
        $ok = $wpdb->insert( $tbl, $data, $formats );
        return $ok ? (int) $wpdb->insert_id : false;
    }
}

