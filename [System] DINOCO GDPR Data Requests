        <script>
        (function() {
            'use strict';
            var root = document.querySelector('.dinoco-gdpr-admin');
            if (!root || root.__inited) return;
            root.__inited = true;

            var REST = root.getAttribute('data-rest-base');
            var NONCE = root.getAttribute('data-nonce');
            var FLAG_ON = <?php echo $flag_enabled ? 'true' : 'false'; ?>;

            // Modal helper shim — fall back to native if dinocoModal absent
            function _confirm(opts) {
                if (window.dinocoModal && typeof window.dinocoModal.confirm === 'function') {
                    try { return window.dinocoModal.confirm(opts); } catch(e){}
                }
                return Promise.resolve(window.confirm((opts.title || '') + '\n' + (opts.message || '')));
            }
            function _alert(opts) {
                if (window.dinocoModal && typeof window.dinocoModal.alert === 'function') {
                    try { return window.dinocoModal.alert(opts); } catch(e){}
                }
                try { window.alert((opts.title || '') + '\n' + (opts.message || '')); } catch(e){}
                return Promise.resolve();
            }
            function _prompt(opts) {
                if (window.dinocoModal && typeof window.dinocoModal.prompt === 'function') {
                    try { return window.dinocoModal.prompt(opts); } catch(e){}
                }
                var v = window.prompt((opts.title || '') + '\n' + (opts.message || ''), opts.defaultValue || '');
                return Promise.resolve(v);
            }

            function esc(s) {
                if (s === null || s === undefined) return '';
                return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            function api(path, opts) {
                opts = opts || {};
                var headers = opts.headers || {};
                headers['X-WP-Nonce'] = NONCE;
                if (opts.method && opts.method !== 'GET') headers['Content-Type'] = 'application/json';
                return fetch(REST + path, {
                    method: opts.method || 'GET',
                    headers: headers,
                    credentials: 'same-origin',
                    body: opts.body ? JSON.stringify(opts.body) : undefined
                }).then(function(r) {
                    return r.json().then(function(j) { return { status: r.status, body: j }; })
                        .catch(function() { return { status: r.status, body: { success: false, code: 'parse_error' } }; });
                });
            }

            // Tab navigation
            root.querySelectorAll('.dnc-gdpr-tab').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var tab = btn.getAttribute('data-tab');
                    root.querySelectorAll('.dnc-gdpr-tab').forEach(function(b) { b.classList.remove('active'); });
                    root.querySelectorAll('.dnc-gdpr-panel').forEach(function(p) { p.classList.remove('active'); });
                    btn.classList.add('active');
                    var panel = root.querySelector('.dnc-gdpr-panel[data-panel="' + tab + '"]');
                    if (panel) panel.classList.add('active');
                    loadTab(tab);
                });
            });

            function ageBadgeClass(days) {
                if (days >= 25) return 'dnc-gdpr-badge dnc-gdpr-badge-age-danger';
                if (days >= 14) return 'dnc-gdpr-badge dnc-gdpr-badge-age-warn';
                return 'dnc-gdpr-badge dnc-gdpr-badge-age';
            }

            function renderRequestCard(row, panelKey) {
                var u = row.user || {};
                var rs = row.record_summary || {};
                var typeBadge = '<span class="dnc-gdpr-badge dnc-gdpr-badge-' + esc(row.type) + '">' +
