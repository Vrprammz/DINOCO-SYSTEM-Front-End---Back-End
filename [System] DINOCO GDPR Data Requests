     */
    function dinoco_gdpr_admin_user_summary( $user_id ) {
        $user = get_userdata( (int) $user_id );
        if ( ! $user ) {
            return array(
                'id'              => (int) $user_id,
                'display_name'    => '(unknown)',
                'user_email'      => '',
                'user_registered' => '',
                'line_uid'        => '',
                'distributor_id'  => 0,
                'roles'           => array(),
                'exists'          => false,
            );
        }
        return array(
            'id'              => (int) $user->ID,
            'display_name'    => (string) $user->display_name,
            'user_email'      => (string) $user->user_email,
            'user_registered' => (string) $user->user_registered,
            'line_uid'        => (string) get_user_meta( $user->ID, 'dinoco_line_uid', true ),
            'distributor_id'  => (int) get_user_meta( $user->ID, 'linked_distributor_id', true ),
            'roles'           => is_array( $user->roles ) ? array_values( $user->roles ) : array(),
            'exists'          => true,
