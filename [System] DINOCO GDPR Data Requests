if ( ! function_exists( 'dinoco_gdpr_rest_export' ) ) {
    function dinoco_gdpr_rest_export( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }

        // Round 57 — Idempotency wrap. Customer "ขอ Export ข้อมูล" double-click → 2× queue
        // request + 2× email confirmation. dinoco_gdpr_queue_request has dup-check 24hr
        // window (returns existing pending) but cached idempotency adds full-TTL replay.
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco-gdpr/v1::my-data-export';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array( 'user_id' => (int) get_current_user_id(), 'type' => 'export' );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) { unset( $cached['_idem_code'] ); return new WP_REST_Response( $cached, 202 ); }
        }

        $user_id = get_current_user_id();
        $queued  = dinoco_gdpr_queue_request( $user_id, 'export' );
        if ( is_wp_error( $queued ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => $queued->get_error_code(),
                'message' => $queued->get_error_message(),
                'data'    => $queued->get_error_data(),
            ), isset( $queued->get_error_data()['status'] ) ? $queued->get_error_data()['status'] : 400 );
        }

        $resp_arr = array(
            'success' => true,
            'code'    => 'queued',
            'message' => 'Export request received. You will receive a download link via email within 30 days (PDPA Section 30).',
            'data'    => $queued,
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $resp_arr, array( '_idem_code' => 202 ) ), 202 );
        }
        return new WP_REST_Response( $resp_arr, 202 );
    }
}

if ( ! function_exists( 'dinoco_gdpr_rest_delete' ) ) {
    function dinoco_gdpr_rest_delete( WP_REST_Request $request ) {
        if ( ! dinoco_gdpr_is_enabled() ) {
            return dinoco_gdpr_disabled_response();
        }

        // Round 57 — Idempotency wrap on irreversible account deletion request.
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco-gdpr/v1::my-data-delete';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'user_id' => (int) get_current_user_id(),
                'type'    => 'delete',
                'confirm' => (string) $request->get_param( 'confirm' ),
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) {
                $code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 202;
                unset( $cached['_idem_code'] );
                return new WP_REST_Response( $cached, $code );
            }
        }

        // Require explicit confirmation (defense against accidental calls)
        $confirm = $request->get_param( 'confirm' );
        if ( $confirm !== 'DELETE_MY_ACCOUNT' ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => 'confirmation_required',
                'message' => 'Pass confirm=DELETE_MY_ACCOUNT to proceed. This action is irreversible.',
            ), 400 );
        }

        $user_id = get_current_user_id();
        $queued  = dinoco_gdpr_queue_request( $user_id, 'delete' );
        if ( is_wp_error( $queued ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'code'    => $queued->get_error_code(),
                'message' => $queued->get_error_message(),
                'data'    => $queued->get_error_data(),
            ), isset( $queued->get_error_data()['status'] ) ? $queued->get_error_data()['status'] : 400 );
        }

        $resp_arr = array(
            'success' => true,
            'code'    => 'queued',
            'message' => 'Deletion request received. Admin will review within 30 days (PDPA Section 33). Account remains active until processed.',
            'data'    => $queued,
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $resp_arr, array( '_idem_code' => 202 ) ), 202 );
        }
        return new WP_REST_Response( $resp_arr, 202 );
    }
}

