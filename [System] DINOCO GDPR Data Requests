// ═══════════════════════════════════════════════════════════════════
// Request Queue
// ═══════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_gdpr_queue_request' ) ) {
    /**
     * Queue a GDPR/PDPA request.
     *
     * @param int    $user_id WP user ID (must be logged in)
     * @param string $type    'export' | 'delete'
     * @return array|WP_Error { ticket_id, request_id, created_at } on success
     */
    function dinoco_gdpr_queue_request( $user_id, $type ) {
        global $wpdb;

        $user_id = absint( $user_id );
        $type    = strtolower( sanitize_key( $type ) );

        if ( $user_id <= 0 ) {
            return new WP_Error( 'invalid_user', 'User ID required', array( 'status' => 400 ) );
        }
        if ( ! in_array( $type, array( 'export', 'delete' ), true ) ) {
            return new WP_Error( 'invalid_type', 'Type must be export or delete', array( 'status' => 400 ) );
        }

        // Ensure schema is ready
        dinoco_gdpr_schema_install();

        $table = $wpdb->prefix . 'dinoco_gdpr_requests';

        $ticket_id = 'GDPR-' . strtoupper( substr( md5( $user_id . $type . microtime( true ) . wp_generate_password( 8, false ) ), 0, 12 ) );
        $now       = current_time( 'mysql' );
        $ip        = dinoco_gdpr_get_client_ip(); // V.1.1 M3: Cloudflare/proxy aware
        $ip        = $ip ? sanitize_text_field( $ip ) : '';
        $ua        = isset( $_SERVER['HTTP_USER_AGENT'] ) ? substr( sanitize_text_field( $_SERVER['HTTP_USER_AGENT'] ), 0, 255 ) : '';

        // V.1.1 L1: wrap SELECT+INSERT in transaction with FOR UPDATE to prevent
        // double-queue race (two rapid calls each seeing no pending → both insert).
        $wpdb->query( 'START TRANSACTION' );
        try {
            // Block duplicate pending requests (per-user per-type)
            $existing = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, ticket_id, status, created_at FROM {$table}
                 WHERE user_id = %d AND type = %s AND status IN ('pending','processing')
                 LIMIT 1 FOR UPDATE",
                $user_id, $type
            ), ARRAY_A );
            if ( $existing ) {
                $wpdb->query( 'COMMIT' );
                return new WP_Error(
                    'duplicate_request',
                    'You already have an active request of this type',
                    array( 'status' => 409, 'existing' => $existing )
                );
            }

            $inserted = $wpdb->insert(
                $table,
                array(
                    'user_id'    => $user_id,
                    'type'       => $type,
                    'status'     => 'pending',
                    'ticket_id'  => $ticket_id,
                    'request_ip' => $ip,
                    'request_ua' => $ua,
                    'created_at' => $now,
                ),
                array( '%d', '%s', '%s', '%s', '%s', '%s', '%s' )
            );

            if ( false === $inserted ) {
                throw new Exception( 'insert failed: ' . $wpdb->last_error );
            }

            $insert_id = (int) $wpdb->insert_id;
            $wpdb->query( 'COMMIT' );
        } catch ( Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_Error( 'db_error', 'Failed to queue request: ' . $e->getMessage(), array( 'status' => 500 ) );
        }

        return array(
            'ticket_id'  => $ticket_id,
            'request_id' => $insert_id,
            'created_at' => $now,
        );
    }
}

// ═══════════════════════════════════════════════════════════════════
// V.1.1 M3 — PII Retention Cron (PDPA Section 17 / GDPR Article 5(e))
// ═══════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_gdpr_retention_cleanup' ) ) {
    /**
     * Prune PII (ip + ua) from gdpr_requests rows 90+ days after processed_at.
     * Keeps row structure for audit (request_id, user_id, type, status, ticket_id)
     * but scrubs identifying network headers — aligns with PDPA §17 minimize-retention
     * and GDPR Article 5(1)(e) storage limitation.
     *
     * @return void
     */
    function dinoco_gdpr_retention_cleanup() {
        global $wpdb;
        $tbl       = $wpdb->prefix . 'dinoco_gdpr_requests';
        $threshold = gmdate( 'Y-m-d H:i:s', strtotime( '-90 days' ) );
        $wpdb->query( $wpdb->prepare(
            "UPDATE {$tbl}
             SET request_ip = NULL, request_ua = NULL
             WHERE processed_at IS NOT NULL
               AND processed_at < %s
               AND (request_ip IS NOT NULL OR request_ua IS NOT NULL)",
            $threshold
        ) );
    }
}
// V.1.2 Phase 4f: schedule + register heartbeat tracking via dinoco_register_cron
// (registry wrapper handles add_action + heartbeat write; legacy add_action is fallback).
if ( ! wp_next_scheduled( 'dinoco_gdpr_retention_cron' ) ) {
    wp_schedule_event( time(), 'daily', 'dinoco_gdpr_retention_cron' );
}
if ( function_exists( 'dinoco_register_cron' ) ) {
    dinoco_register_cron( 'dinoco_gdpr_retention_cron', 'daily', 'dinoco_gdpr_retention_cleanup' );
} else {
    add_action( 'dinoco_gdpr_retention_cron', 'dinoco_gdpr_retention_cleanup' );
}

