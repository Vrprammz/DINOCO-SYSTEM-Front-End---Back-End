if ( ! defined( 'ABSPATH' ) ) exit;
if ( defined( 'B2F_DISABLED' ) && B2F_DISABLED ) return;

// ════════════════════════════════════════════
// 1. REGISTER CRON SCHEDULES + EVENTS
// ════════════════════════════════════════════

add_action( 'init', function () {
    // ใช้ interval ที่มีอยู่ (จาก WP Fastest Cache หรือ built-in)
    $avail = wp_get_schedules();
    $daily = 'daily';
    $weekly = 'weekly';

    $events = array(
        'b2f_cron_delivery_reminder'  => array( 'time' => '01:30:00', 'recurrence' => $daily ),  // 08:30 ICT
        'b2f_cron_overdue_check'      => array( 'time' => '02:00:00', 'recurrence' => $daily ),  // 09:00 ICT
        'b2f_cron_maker_noresponse'   => array( 'time' => '02:30:00', 'recurrence' => $daily ),  // 09:30 ICT
        'b2f_cron_payment_reminder'   => array( 'time' => '03:00:00', 'recurrence' => $daily ),  // 10:00 ICT
        'b2f_cron_daily_summary'      => array( 'time' => '11:00:00', 'recurrence' => $daily ),  // 18:00 ICT
    );

    foreach ( $events as $hook => $cfg ) {
        if ( ! wp_next_scheduled( $hook ) ) {
            $next = strtotime( 'today ' . $cfg['time'] . ' UTC' );
            if ( $next < time() ) $next = strtotime( 'tomorrow ' . $cfg['time'] . ' UTC' );
            wp_schedule_event( $next, $cfg['recurrence'], $hook );
        }
    }

    // Weekly summary
    if ( ! wp_next_scheduled( 'b2f_cron_weekly_summary' ) ) {
        $next_mon = strtotime( 'next monday 02:00:00 UTC' );
        wp_schedule_event( $next_mon, $weekly, 'b2f_cron_weekly_summary' );
    }

    // V.1.4: Flex retry cron — ทุก 2 นาที
    $retry_interval = isset( $avail['every_2min_b2f'] ) ? 'every_2min_b2f' : ( isset( $avail['every_1min_b2b'] ) ? 'every_1min_b2b' : 'hourly' );
    if ( ! wp_next_scheduled( 'b2f_flex_retry_cron' ) ) {
        wp_schedule_event( time() + 60, $retry_interval, 'b2f_flex_retry_cron' );
    }

    // V.2.2: Phase 2 diff detection cron — hourly
    if ( ! wp_next_scheduled( 'b2f_diff_cron_hourly' ) ) {
        wp_schedule_event( time() + 300, 'hourly', 'b2f_diff_cron_hourly' );
    }

    // V.2.2: Observations TTL cleanup — daily at 20:00 ICT (13:00 UTC)
    if ( ! wp_next_scheduled( 'b2f_observations_ttl_cron' ) ) {
        $next = strtotime( 'today 13:00:00 UTC' );
        if ( $next < time() ) $next = strtotime( 'tomorrow 13:00:00 UTC' );
        wp_schedule_event( $next, $daily, 'b2f_observations_ttl_cron' );
    }
} );

// V.1.4: Register 2-min interval
add_filter( 'cron_schedules', function ( $schedules ) {
    if ( ! isset( $schedules['every_2min_b2f'] ) ) {
        $schedules['every_2min_b2f'] = array( 'interval' => 120, 'display' => 'Every 2 minutes (B2F)' );
    }
    return $schedules;
} );

// ════════════════════════════════════════════
// 2. เตือนจัดส่ง (D-3, D-1, D-day)
// ════════════════════════════════════════════

add_action( 'b2f_cron_delivery_reminder', 'b2f_run_delivery_reminder' );

if ( ! function_exists( 'b2f_run_delivery_reminder' ) ) {
    function b2f_run_delivery_reminder() {
        global $wpdb;
        $today = wp_date( 'Y-m-d' );

        // Query PO ที่ confirmed + มี expected_date
        $pos = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.ID FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} ps ON ps.post_id = p.ID AND ps.meta_key = 'po_status'
             JOIN {$wpdb->postmeta} pe ON pe.post_id = p.ID AND pe.meta_key = 'po_expected_date'
             WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
             AND ps.meta_value IN ('confirmed', 'delivering')
             AND pe.meta_value != '' AND pe.meta_value >= %s
             ORDER BY pe.meta_value ASC",
            date( 'Y-m-d', strtotime( '-1 day' ) ) // รวม D-day
        ) );

        if ( empty( $pos ) ) return;

        foreach ( $pos as $po ) {
            $eta = get_field( 'po_expected_date', $po->ID );
            if ( empty( $eta ) ) continue;

            $days = (int) round( ( strtotime( $eta ) - strtotime( $today ) ) / 86400 );
            $last_sent = get_post_meta( $po->ID, '_b2f_last_reminder_date', true );
            if ( $last_sent === $today ) continue; // ส่งแล้ววันนี้

            $send = false;
            $emoji = '📦';
            $msg = '';

            if ( $days === 3 ) {
                $send = true; $emoji = '📦'; $msg = 'เหลืออีก 3 วัน จะถึงกำหนดส่ง';
            } elseif ( $days === 1 ) {
                $send = true; $emoji = '⚠️'; $msg = 'พรุ่งนี้ครบกำหนดส่ง';
            } elseif ( $days === 0 ) {
                $send = true; $emoji = '🔴'; $msg = 'วันนี้ครบกำหนดส่ง';
            }

            if ( $send ) {
                $po_number = get_field( 'po_number', $po->ID ) ?: '#' . $po->ID;
                $maker_id = get_field( 'po_maker_id', $po->ID );
                $maker_group = is_numeric( $maker_id ) ? get_field( 'maker_line_group_id', $maker_id ) : '';
                $maker_name = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: '' ) : '';
                $thai_date = date( 'd/m/Y', strtotime( $eta ) );

                // V.1.6: ENG labels for non-THB Maker
                $po_cur_cron = get_field( 'po_currency', $po->ID ) ?: 'THB';
                $cron_eng = $po_cur_cron !== 'THB';
                $msg_eng_map = array( 3 => '3 days until delivery deadline', 1 => 'Delivery deadline is tomorrow', 0 => 'Delivery deadline is today' );
                $msg_zh_map = array( 3 => '距交货期限还有3天', 1 => '明天到交货期限', 0 => '今天是交货期限' );
                $msg_display = b2f_t($msg, $msg_eng_map[ $days ] ?? $msg, $msg_zh_map[ $days ] ?? ($msg_eng_map[ $days ] ?? $msg), $po_cur_cron);

                // V.1.1: ใช้ Flex builder แทน text
                $flex_sent = false;
                if ( $maker_group && function_exists( 'b2f_build_flex_eta_reminder' ) && function_exists( 'b2f_line_push' ) ) {
                    $flex = b2f_build_flex_eta_reminder( $po->ID, $days );
                    if ( $flex ) {
                        b2f_line_push( $maker_group, is_array( $flex ) && isset( $flex['type'] ) ? array( $flex ) : $flex );
                        $flex_sent = true;
                    }
                }
                if ( ! $flex_sent && $maker_group && function_exists( 'b2f_line_push' ) ) {
                    $text = b2f_t(
                        "{$emoji} เตือนจัดส่ง\nPO: {$po_number}\nกำหนดส่ง: {$thai_date}\n{$msg}",
                        "{$emoji} Delivery Reminder\nPO: {$po_number}\nDeadline: {$thai_date}\n{$msg_display}",
                        "{$emoji} 交货提醒\nPO: {$po_number}\n交货日期: {$thai_date}\n{$msg_display}",
                        $po_cur_cron);
                    b2f_line_push( $maker_group, array( array( 'type' => 'text', 'text' => $text ) ) );
                }
                // ส่ง Admin (D-1 + D-day)
                if ( $days <= 1 && defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
                    b2f_line_push( B2B_ADMIN_GROUP_ID, array( array( 'type' => 'text', 'text' => "{$emoji} B2F เตือนจัดส่ง\n{$po_number} · {$maker_name}\n{$msg}" ) ) );
                }

                update_post_meta( $po->ID, '_b2f_last_reminder_date', $today );
            }
        }
    }
}

// ════════════════════════════════════════════
// 3. เตือนล่าช้า (D+1, D+3, D+7+)
// ════════════════════════════════════════════

add_action( 'b2f_cron_overdue_check', 'b2f_run_overdue_check' );

if ( ! function_exists( 'b2f_run_overdue_check' ) ) {
    function b2f_run_overdue_check() {
        global $wpdb;
        $today = wp_date( 'Y-m-d' );

        // WARN-04 fix: ใช้ $wpdb->prepare()
        $pos = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.ID FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} ps ON ps.post_id = p.ID AND ps.meta_key = %s
             JOIN {$wpdb->postmeta} pe ON pe.post_id = p.ID AND pe.meta_key = %s
             WHERE p.post_type = %s AND p.post_status = 'publish'
             AND ps.meta_value IN ('confirmed', 'delivering')
             AND pe.meta_value != '' AND pe.meta_value < CURDATE()",
            'po_status', 'po_expected_date', 'b2f_order'
        ) );

        foreach ( $pos as $po ) {
            $eta = get_field( 'po_expected_date', $po->ID );
            $days_late = (int) floor( ( strtotime( $today ) - strtotime( $eta ) ) / 86400 );
            $last_sent = get_post_meta( $po->ID, '_b2f_last_overdue_date', true );
            if ( $last_sent === $today ) continue;

            $send = false;
            if ( $days_late === 1 || $days_late === 3 || ( $days_late >= 7 && $days_late % 3 === 0 ) ) {
                $send = true;
            }

            if ( $send ) {
                $po_number = get_field( 'po_number', $po->ID ) ?: '#' . $po->ID;
                $maker_id = get_field( 'po_maker_id', $po->ID );
                $maker_group = is_numeric( $maker_id ) ? get_field( 'maker_line_group_id', $maker_id ) : '';
                $maker_name = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: '' ) : '';
                $color = $days_late >= 7 ? '🚨' : ( $days_late >= 3 ? '🔴' : '⚠️' );

                // V.1.6: ENG labels for non-THB Maker
                $po_cur_od = get_field( 'po_currency', $po->ID ) ?: 'THB';
                $od_eng = $po_cur_od !== 'THB';

                // V.1.1: ส่ง Maker ด้วย Flex
                $flex_sent = false;
                if ( $maker_group && function_exists( 'b2f_build_flex_overdue_alert' ) && function_exists( 'b2f_line_push' ) ) {
                    $flex = b2f_build_flex_overdue_alert( $po->ID, $days_late );
                    if ( $flex ) {
                        b2f_line_push( $maker_group, is_array( $flex ) && isset( $flex['type'] ) ? array( $flex ) : $flex );
                        $flex_sent = true;
                    }
                }
                if ( ! $flex_sent && $maker_group && function_exists( 'b2f_line_push' ) ) {
                    $overdue_text = b2f_t(
                        "{$color} PO ล่าช้า {$days_late} วัน\n{$po_number}\nกรุณาจัดส่งโดยเร็ว",
                        "{$color} PO overdue by {$days_late} days\n{$po_number}\nPlease ship as soon as possible",
                        "{$color} PO 逾期{$days_late}天\n{$po_number}\n请尽快发货",
                        $po_cur_od);
                    b2f_line_push( $maker_group, array( array( 'type' => 'text', 'text' => $overdue_text ) ) );
                }
                // ส่ง Admin (ยังเป็น text — ข้อมูลย่อ ไม่จำเป็นต้อง Flex)
                if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
                    b2f_line_push( B2B_ADMIN_GROUP_ID, array( array( 'type' => 'text', 'text' => "{$color} B2F ล่าช้า {$days_late} วัน\n{$po_number} · {$maker_name}\nกรุณาติดต่อโรงงาน" ) ) );
                }

                update_post_meta( $po->ID, '_b2f_last_overdue_date', $today );
            }
        }
    }
}

// ════════════════════════════════════════════
// 4. เตือน Maker ไม่ตอบ (24h, 48h, escalate 72h)
// ════════════════════════════════════════════

add_action( 'b2f_cron_maker_noresponse', 'b2f_run_maker_noresponse' );

if ( ! function_exists( 'b2f_run_maker_noresponse' ) ) {
    function b2f_run_maker_noresponse() {
        $pos = get_posts( array(
            'post_type' => 'b2f_order', 'posts_per_page' => -1, 'post_status' => 'publish',
            'meta_query' => array( array( 'key' => 'po_status', 'value' => 'submitted' ) ),
        ) );

        foreach ( $pos as $po ) {
            $created = get_post_time( 'U', true, $po->ID );
            $hours = ( time() - $created ) / 3600;
            $last_sent = get_post_meta( $po->ID, '_b2f_noresponse_hours', true );

            $send_at = 0;
            if ( $hours >= 72 && $last_sent < 72 ) $send_at = 72;
            elseif ( $hours >= 48 && $last_sent < 48 ) $send_at = 48;
            elseif ( $hours >= 24 && $last_sent < 24 ) $send_at = 24;

            if ( $send_at > 0 ) {
                $po_number = get_field( 'po_number', $po->ID ) ?: '#' . $po->ID;
                $maker_id = get_field( 'po_maker_id', $po->ID );
                $maker_group = is_numeric( $maker_id ) ? get_field( 'maker_line_group_id', $maker_id ) : '';
                $maker_name = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: '' ) : '';

                // V.1.6: ENG labels for non-THB Maker
                $po_cur_nr = get_field( 'po_currency', $po->ID ) ?: 'THB';
                $nr_eng = $po_cur_nr !== 'THB';

                if ( $send_at < 72 ) {
                    // เตือน Maker
                    if ( $maker_group && function_exists( 'b2f_line_push' ) ) {
                        $nr_text = b2f_t(
                            "📋 เตือน: PO {$po_number} รอการยืนยัน\nกรุณายืนยันหรือปฏิเสธใบสั่งซื้อ",
                            "📋 Reminder: PO {$po_number} awaiting confirmation\nPlease confirm or reject the purchase order",
                            "📋 提醒: PO {$po_number} 等待确认\n请确认或拒绝采购订单",
                            $po_cur_nr);
                        b2f_line_push( $maker_group, array( array( 'type' => 'text', 'text' => $nr_text ) ) );
                    }
                } else {
                    // Escalate ไป Admin
                    if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
                        b2f_line_push( B2B_ADMIN_GROUP_ID, array( array( 'type' => 'text', 'text' => "🚨 Maker ไม่ตอบ 72 ชม.\nPO: {$po_number}\nโรงงาน: {$maker_name}\nกรุณาติดต่อโรงงานโดยตรง" ) ) );
                    }
                }

                update_post_meta( $po->ID, '_b2f_noresponse_hours', $send_at );
            }
        }

        // V.2.1: Check rejected POs that admin hasn't acted on for 7+ days
        $rejected_pos = get_posts( array(
            'post_type' => 'b2f_order', 'posts_per_page' => -1, 'post_status' => 'publish',
            'meta_query' => array( array( 'key' => 'po_status', 'value' => 'rejected' ) ),
        ) );

        $stale_rejected = array();
        foreach ( $rejected_pos as $rpo ) {
            $modified = get_post_modified_time( 'U', true, $rpo->ID );
            $days = ( time() - $modified ) / 86400;
            if ( $days >= 7 ) {
                $po_number = get_field( 'po_number', $rpo->ID ) ?: '#' . $rpo->ID;
                $maker_id  = get_field( 'po_maker_id', $rpo->ID );
                $maker_name = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: 'Unknown' ) : 'Unknown';
                $stale_rejected[] = sprintf( '%s (%s) - %d วัน', $po_number, $maker_name, floor( $days ) );
            }
        }

        if ( ! empty( $stale_rejected ) && defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
            $msg = "⚠️ PO ถูกปฏิเสธค้างไม่มีการดำเนินการ:\n" . implode( "\n", $stale_rejected ) . "\n\nกรุณาแก้ไข/ยกเลิก PO เหล่านี้";
            b2f_line_push( B2B_ADMIN_GROUP_ID, array( array( 'type' => 'text', 'text' => $msg ) ) );
        }
    }
}

// ════════════════════════════════════════════
// 5. เตือนชำระเงิน Admin (credit term)
// ════════════════════════════════════════════

add_action( 'b2f_cron_payment_reminder', 'b2f_run_payment_reminder' );

if ( ! function_exists( 'b2f_run_payment_reminder' ) ) {
    function b2f_run_payment_reminder() {
        // หา PO ที่ received + ยังไม่จ่าย/จ่ายบางส่วน
        $pos = get_posts( array(
            'post_type' => 'b2f_order', 'posts_per_page' => -1, 'post_status' => 'publish',
            'meta_query' => array(
                array( 'key' => 'po_status', 'value' => array( 'received', 'partial_received', 'partial_paid' ), 'compare' => 'IN' ),
            ),
        ) );

        $today = wp_date( 'Y-m-d' );

        foreach ( $pos as $po ) {
            $maker_id = get_field( 'po_maker_id', $po->ID );
            $credit_term = is_numeric( $maker_id ) ? intval( get_field( 'maker_credit_term_days', $maker_id ) ?: 30 ) : 30;

            // คำนวณวันครบกำหนดจ่าย = วันที่ตรวจรับ + credit term
            $received_date = '';
            // หาวันที่ตรวจรับล่าสุด
            $rcvs = get_posts( array( 'post_type' => 'b2f_receiving', 'posts_per_page' => 1,
                'meta_query' => array( array( 'key' => 'rcv_po_id', 'value' => $po->ID ) ),
                'orderby' => 'date', 'order' => 'DESC' ) );
            if ( ! empty( $rcvs ) ) {
                $received_date = get_field( 'rcv_date', $rcvs[0]->ID ) ?: get_the_date( 'Y-m-d', $rcvs[0]->ID );
            }
            if ( empty( $received_date ) ) continue;

            $due_date = date( 'Y-m-d', strtotime( $received_date . ' + ' . $credit_term . ' days' ) );
            $days_to_due = (int) round( ( strtotime( $due_date ) - strtotime( $today ) ) / 86400 );

            $last_sent = get_post_meta( $po->ID, '_b2f_payment_reminder_date', true );
            if ( $last_sent === $today ) continue;

            $send = false;
            $msg = '';
            $emoji = '💰';

            if ( $days_to_due === 7 ) {
                $send = true; $emoji = '💰'; $msg = 'ใกล้ครบกำหนดจ่ายอีก 7 วัน';
            } elseif ( $days_to_due === 3 ) {
                $send = true; $emoji = '⚠️'; $msg = 'ใกล้ครบกำหนดจ่ายอีก 3 วัน';
            } elseif ( $days_to_due === 0 ) {
                $send = true; $emoji = '🔴'; $msg = 'วันนี้ครบกำหนดจ่ายเงิน';
            } elseif ( $days_to_due === -3 ) {
                $send = true; $emoji = '🚨'; $msg = 'เลยกำหนดจ่าย 3 วัน';
            } elseif ( $days_to_due === -7 ) {
                $send = true; $emoji = '🚨'; $msg = 'เลยกำหนดจ่าย 7 วัน — ระงับเครดิตอัตโนมัติ';
                // Auto credit hold (CRIT-08 fix: ใช้ MySQL lock ป้องกัน race condition กับ payable_subtract)
                if ( is_numeric( $maker_id ) ) {
                    global $wpdb;
                    $lock_name = 'b2f_fin_' . intval( $maker_id );
                    $got_lock  = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
                    if ( $got_lock ) {
                        update_field( 'maker_credit_hold', true, $maker_id );
                        update_post_meta( $maker_id, 'maker_credit_hold_reason', 'auto' );
                        wp_cache_delete( $maker_id, 'post_meta' );
                        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                        if ( function_exists( 'b2f_log' ) ) b2f_log( "[Cron] Auto credit hold maker #{$maker_id} — overdue 7 days (locked)" );
                        // GAP-12: Push Flex credit hold ส่ง Maker
                        if ( function_exists( 'b2f_build_flex_credit_hold' ) ) {
                            $m_group = get_field( 'maker_line_group_id', $maker_id );
                            if ( ! empty( $m_group ) ) {
                                $flex_hold = b2f_build_flex_credit_hold( intval( $maker_id ), 'auto' );
                                if ( $flex_hold ) b2f_line_push( $m_group, array( $flex_hold ) );
                            }
                        }
                    }
                }
            }

            if ( $send && defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
                $po_number = get_field( 'po_number', $po->ID ) ?: '#' . $po->ID;
                $maker_name = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: '' ) : '';
                $total = floatval( get_field( 'po_total_amount', $po->ID ) ?: 0 );
                $paid = floatval( get_field( 'po_paid_amount', $po->ID ) ?: 0 );
                $remaining = $total - $paid;

                $po_cur = get_field( 'po_currency', $po->ID ) ?: 'THB';
                $cur_note = ( $po_cur !== 'THB' ) ? ' (' . $po_cur . ')' : '';
                b2f_line_push( B2B_ADMIN_GROUP_ID, array( array( 'type' => 'text',
                    'text' => "{$emoji} เตือนชำระเงินโรงงาน\nPO: {$po_number}\nโรงงาน: {$maker_name}{$cur_note}\nยอดค้าง: ฿" . number_format( $remaining, 2 ) . "\nครบกำหนด: " . date( 'd/m/Y', strtotime( $due_date ) ) . "\n{$msg}",
                ) ) );

                update_post_meta( $po->ID, '_b2f_payment_reminder_date', $today );
            }
        }
    }
}

