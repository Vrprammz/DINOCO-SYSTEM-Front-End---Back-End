// ════════════════════════════════════════════
// 8. V.1.4: FLEX RETRY CRON (guaranteed push)
// Retry _b2f_pending_push ทุก 2 นาที สูงสุด 5 ครั้ง
// ════════════════════════════════════════════

add_action( 'b2f_flex_retry_cron', 'b2f_run_flex_retry' );

if ( ! function_exists( 'b2f_run_flex_retry' ) ) {
    function b2f_run_flex_retry() {
        $posts = get_posts( array(
            'post_type'      => array( 'b2f_order', 'b2f_maker' ),
            'meta_key'       => '_b2f_pending_push',
            'posts_per_page' => 50,
            'fields'         => 'ids',
        ) );
        if ( empty( $posts ) ) return;

        // V.2.4 PERF-M8: prime postmeta cache for the batch (up to 50 rows) — avoids
        // per-post cold `get_post_meta` below. Also warms `delete_post_meta` +
        // `add_post_meta` subsequent calls within this tick.
        update_meta_cache( 'post', $posts );

        $ok = 0; $retry = 0; $failed = 0;
        foreach ( $posts as $pid ) {
            $entries = get_post_meta( $pid, '_b2f_pending_push', false );
            delete_post_meta( $pid, '_b2f_pending_push' );

            foreach ( $entries as $entry ) {
                if ( ! is_array( $entry ) || empty( $entry['messages'] ) || empty( $entry['group_id'] ) ) continue;

                $success = function_exists( 'b2f_line_push' ) ? b2f_line_push( $entry['group_id'], $entry['messages'] ) : false;

                if ( $success ) {
                    $ok++;
                    if ( function_exists( 'b2f_log' ) ) b2f_log( '[FlexRetry] OK #' . $pid . ' type=' . ( $entry['push_type'] ?? 'unknown' ) );
                } elseif ( intval( $entry['attempts'] ?? 1 ) < 5 ) {
                    $entry['attempts'] = intval( $entry['attempts'] ?? 1 ) + 1;
                    add_post_meta( $pid, '_b2f_pending_push', $entry );
                    $retry++;
                } else {
                    $failed++;
                    if ( function_exists( 'b2f_log' ) ) b2f_log( '[FlexRetry] GAVE UP #' . $pid . ' type=' . ( $entry['push_type'] ?? 'unknown' ) . ' after 5 attempts' );
                    // Alert Admin
                    if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
                        b2f_line_push( B2B_ADMIN_GROUP_ID, array( array( 'type' => 'text',
                            'text' => "B2F Flex retry failed\nPO #" . $pid . "\nType: " . ( $entry['push_type'] ?? '' ) . "\n5 attempts exhausted" ) ) );
                    }
                }
            }
        }
        if ( $ok + $retry + $failed > 0 && function_exists( 'b2f_log' ) ) {
            b2f_log( '[FlexRetry] Summary: ' . $ok . ' ok, ' . $retry . ' retry, ' . $failed . ' gave up' );
        }
    }
}

// ════════════════════════════════════════════
// V.2.2 — PHASE 2: DIFF DETECTION CRON (HOURLY)
// ════════════════════════════════════════════
// เปรียบเทียบ CPT vs junction table field-by-field → เขียน observation
// diff_detected=1 → drift alert (log + aggregate daily)

add_action( 'b2f_diff_cron_hourly', 'b2f_run_diff_detection' );

if ( ! function_exists( 'b2f_run_diff_detection' ) ) {
    function b2f_run_diff_detection() {
        global $wpdb;
        if ( ! get_option( 'b2f_schema_v10_activated' ) ) return;

        // V.2.3 DB-H7 FIX: gate on shadow_write flag. When Phase 3 cut-over is active and
        // shadow_write is disabled, junction is the source of truth and CPT is frozen (or
        // being retired) — running this hourly diff is wasted work (~500 rows × 6 ACF
        // reads/hr ≈ 3K uncached reads/hr) and produces noise observations. Only useful
        // while dual-write is live.
        if ( ! function_exists( 'b2f_is_flag_enabled' ) || ! b2f_is_flag_enabled( 'b2f_flag_shadow_write' ) ) {
            return;
        }

        $tbl_jn = $wpdb->prefix . 'dinoco_product_makers';
        $tbl_ob = $wpdb->prefix . 'dinoco_maker_product_observations';

        // Load all active junction rows
        $rows = $wpdb->get_results(
            "SELECT id, product_sku, maker_id, unit_cost, moq, lead_time_days,
                    shipping_land, shipping_sea, status, legacy_cpt_id
             FROM {$tbl_jn}
             WHERE deleted_at IS NULL
             LIMIT 500",
            ARRAY_A
        );
        if ( ! is_array( $rows ) ) $rows = array();

        $now = current_time( 'mysql' );
        $diff_count = 0;
        $checked = 0;

        $fields = array(
            'unit_cost'      => 'mp_unit_cost',
            'moq'            => 'mp_moq',
            'lead_time_days' => 'mp_lead_time_days',
            'shipping_land'  => 'mp_shipping_land',
            'shipping_sea'   => 'mp_shipping_sea',
            'status'         => 'mp_status',
        );

        foreach ( $rows as $r ) {
            $mp_id = intval( $r['legacy_cpt_id'] );
            if ( ! $mp_id ) continue;
            // Verify CPT still exists
            $post = get_post( $mp_id );
            if ( ! $post || $post->post_type !== 'b2f_maker_product' ) continue;
            if ( ! function_exists( 'get_field' ) ) continue;

            $checked++;
            foreach ( $fields as $jn_col => $acf_field ) {
                $cpt_val = get_field( $acf_field, $mp_id );
                $jn_val  = $r[ $jn_col ];

                // Normalize numeric comparison (0.00 vs 0)
                if ( in_array( $jn_col, array( 'unit_cost', 'shipping_land', 'shipping_sea' ), true ) ) {
                    $diff = abs( floatval( $cpt_val ) - floatval( $jn_val ) ) > 0.001;
                    $cpt_norm = number_format( floatval( $cpt_val ), 2, '.', '' );
                    $jn_norm  = number_format( floatval( $jn_val ), 2, '.', '' );
                } elseif ( in_array( $jn_col, array( 'moq', 'lead_time_days' ), true ) ) {
                    $diff = intval( $cpt_val ) !== intval( $jn_val );
                    $cpt_norm = (string) intval( $cpt_val );
                    $jn_norm  = (string) intval( $jn_val );
                } else {
                    $diff = (string) $cpt_val !== (string) $jn_val;
                    $cpt_norm = (string) $cpt_val;
                    $jn_norm  = (string) $jn_val;
                }

                if ( $diff ) {
                    $diff_count++;
                    $wpdb->insert( $tbl_ob, array(
                        'observed_at'    => $now,
                        'source'         => 'diff',
                        'sku'            => $r['product_sku'],
                        'maker_id'       => $r['maker_id'],
                        'field_name'     => $jn_col,
                        'cpt_value'      => $cpt_norm,
                        'junction_value' => $jn_norm,
                        'diff_detected'  => 1,
                    ) );
                }
            }
        }

        // Aggregate: update rolling 7-day history
        b2f_aggregate_drift_history_7d();

        if ( $diff_count > 0 && function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( '[DiffCron] checked=%d diffs=%d (drift detected)', $checked, $diff_count ) );
        }
    }
}

/**
 * Rolling 7-day drift history — update wp_option 'b2f_drift_history_7d'
 * Aggregation: observations per day (orphan/stale/diff counts)
 */
if ( ! function_exists( 'b2f_aggregate_drift_history_7d' ) ) {
    function b2f_aggregate_drift_history_7d() {
        global $wpdb;
        $tbl_ob = $wpdb->prefix . 'dinoco_maker_product_observations';

        $rows = $wpdb->get_results(
            "SELECT DATE(observed_at) AS day,
                    COUNT(DISTINCT CASE WHEN diff_detected = 1 THEN CONCAT(maker_id, '-', sku) END) AS stale_count,
                    COUNT(CASE WHEN source = 'cpt' THEN 1 END) AS writes,
                    COUNT(CASE WHEN diff_detected = 1 THEN 1 END) AS diff_rows
             FROM {$tbl_ob}
             WHERE observed_at >= DATE_SUB(NOW(), INTERVAL 7 DAY)
             GROUP BY DATE(observed_at)
             ORDER BY day DESC",
            ARRAY_A
        );
        if ( ! is_array( $rows ) ) $rows = array();

        // Attach orphan_count (point-in-time snapshot จาก audit helper)
        $orphan_count_today = 0;
        if ( function_exists( 'b2f_audit_get_orphan_sets' ) ) {
            $orphans = b2f_audit_get_orphan_sets();
            $orphan_count_today = is_array( $orphans ) ? count( $orphans ) : 0;
        }
        $today_key = wp_date( 'Y-m-d' );
        $annotated = array();
        foreach ( $rows as $row ) {
            $annotated[] = array(
                'date'         => $row['day'],
                'stale_count'  => intval( $row['stale_count'] ),
                'diff_rows'    => intval( $row['diff_rows'] ),
                'writes'       => intval( $row['writes'] ),
                'orphan_count' => ( $row['day'] === $today_key ) ? $orphan_count_today : null,
            );
        }
        update_option( 'b2f_drift_history_7d', $annotated, false );
    }
}

// ════════════════════════════════════════════
// V.2.2 — PHASE 2: OBSERVATIONS TTL CLEANUP (DAILY)
// ════════════════════════════════════════════

add_action( 'b2f_observations_ttl_cron', 'b2f_run_observations_ttl' );

if ( ! function_exists( 'b2f_run_observations_ttl' ) ) {
    function b2f_run_observations_ttl() {
        global $wpdb;
        if ( ! get_option( 'b2f_schema_v10_activated' ) ) return;
        $tbl_ob = $wpdb->prefix . 'dinoco_maker_product_observations';

        // V.2.3 DB-H8 FIX: chunked DELETE (mirror Snippet 16 attempt-log cleanup pattern).
        // Observations can peak ~110K rows (60-day TTL × diff cron hourly × 500 junction rows
        // × up to 6 fields). A bulk DELETE holds a table-level write lock minutes on that
        // volume → blocks Phase 3 reads + concurrent diff-cron inserts. Chunk 1000 rows/iter
        // + 50ms cooperation gap + hard cap 20 iterations/run (≤20K rows purged per day —
        // steady-state is only ~1.8K rows/day from diff cron, so cap is comfortable).
        // Cutoff computed in PHP to use GMT consistently (DATE_SUB(NOW(), ...) depends on
        // server TZ which is unreliable; current_time('mysql', true) = UTC).
        $cutoff     = date( 'Y-m-d H:i:s', time() - ( 60 * DAY_IN_SECONDS ) );
        $total_del  = 0;
        $max_iter   = 20;
        $chunk_size = 1000;

        for ( $i = 0; $i < $max_iter; $i++ ) {
            $affected = $wpdb->query( $wpdb->prepare(
                "DELETE FROM {$tbl_ob}
                 WHERE observed_at < %s
                 ORDER BY observed_at ASC
                 LIMIT %d",
                $cutoff, $chunk_size
            ) );
            if ( $affected === false || $affected < 1 ) break;
            $total_del += intval( $affected );
            // 50ms cooperative gap — let concurrent inserts proceed, avoid lock escalation.
            usleep( 50000 );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( '[TTL V.2.3] Purged %d observation rows older than 60 days (cutoff=%s, chunks=%d)',
                $total_del, $cutoff, min( $i, $max_iter ) ) );
        }
    }
}
