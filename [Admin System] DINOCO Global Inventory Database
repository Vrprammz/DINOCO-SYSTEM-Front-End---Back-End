        window.DipStockManager = {
            _session: null,
            _items: [],
            _filter: 'all',

            /* Check session and render appropriate state */
            checkSession: function() {
                const self = this;
                $.ajax({
                    url: STOCK_API + '/dip-stock/current',
                    method: 'GET',
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        if (res.active && res.session) {
                            self._session = res.session;
                            self._items = res.items || [];
                            self.renderActive();
                        } else {
                            self._session = null;
                            self._items = [];
                            self.renderNoSession();
                        }
                    },
                    error: function() {
                        self.renderNoSession();
                    }
                });
            },

            /* Render: no active session */
            renderNoSession: function() {
                $('#dip-no-session').show();
                $('#dip-active-session').hide();
                $('#dip-report').hide();
                this.loadHistory();

                // Last dip stock info
                $.ajax({
                    url: STOCK_API + '/dip-stock/history',
                    method: 'GET',
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        const sessions = res.sessions || [];
                        const completed = sessions.filter(s => s.status === 'completed');
                        let infoHtml = '';
                        if (completed.length > 0) {
                            const last = completed[0];
                            const lastDate = new Date(last.session_date);
                            const daysAgo = Math.floor((Date.now() - lastDate.getTime()) / 86400000);
                            const interval = parseInt($('#stg-dip').val()) || 30;
                            infoHtml = 'นับล่าสุด: ' + lastDate.toLocaleDateString('th-TH', {day:'2-digit',month:'short',year:'numeric'}) +
                                ' (' + daysAgo + ' วันที่แล้ว) | ' + last.total_skus + ' SKU';
                        } else {
                            infoHtml = 'ยังไม่เคยนับสต็อก — กดเริ่มเพื่อตั้งค่าสต็อกเริ่มต้น';
                        }
                        $('#dip-last-info').html(infoHtml);
                    }
                });
            },

            /* Render: active session counting form */
            renderActive: function() {
                const self = this;
                $('#dip-no-session').hide();
                $('#dip-active-session').show();
                $('#dip-report').hide();

                const s = self._session;
                const counted = self._items.filter(i => i.actual_qty !== null).length;
                const total = self._items.length;
                const pct = total > 0 ? Math.round((counted / total) * 100) : 0;

                $('#dip-session-info').text('Session #' + s.id + ' | ' + s.session_date + ' | เริ่มเมื่อ ' + (s.created_at || ''));
                $('#dip-progress-text').text(counted + '/' + total + ' SKU (' + pct + '%) — ไม่รวม SET');
                $('#dip-progress-bar').css('width', pct + '%');

                self.renderItems();
            },

            /* Render item cards */
            renderItems: function() {
                const self = this;
                const search = ($('#dip-search').val() || '').toLowerCase();
                let filtered = self._items;

                if (search) {
                    filtered = filtered.filter(i =>
                        (i.sku || '').toLowerCase().includes(search) ||
                        (i.name || '').toLowerCase().includes(search)
                    );
                }

                if (self._filter === 'uncounted') {
                    filtered = filtered.filter(i => i.actual_qty === null);
                } else if (self._filter === 'counted') {
                    filtered = filtered.filter(i => i.actual_qty !== null);
                } else if (self._filter === 'variance') {
                    filtered = filtered.filter(i => i.variance !== null && i.variance !== 0);
                }

                if (filtered.length === 0) {
                    $('#dip-items-list').html('<div class="content-box" style="text-align:center;color:#94a3b8;padding:30px;">ไม่พบรายการ</div>');
                    return;
                }

                let html = '';
                filtered.forEach(function(item) {
                    const isCounted = item.actual_qty !== null;
                    const cls = isCounted ? 'dip-counted' : '';
                    const imgHtml = item.image_url
                        ? '<img src="'+item.image_url+'" class="dip-thumb" onerror="this.style.display=\'none\'">'
                        : '';
                    const curVal = isCounted ? item.actual_qty : '';
                    const varianceHtml = isCounted && item.variance !== null && item.variance !== 0
                        ? '<span class="dip-variance-badge ' + (Math.abs(item.variance_pct) > 5 ? 'dip-vb-red' : (Math.abs(item.variance_pct) > 0 ? 'dip-vb-yellow' : 'dip-vb-green')) + '">' + (item.variance > 0 ? '+' : '') + item.variance + ' (' + (item.variance > 0 ? '+' : '') + item.variance_pct + '%)</span>'
                        : (isCounted ? '<span class="dip-variance-badge dip-vb-green">ตรง</span>' : '');

                    html += '<div class="dip-card ' + cls + '">' +
                        '<div style="display:flex;gap:12px;align-items:center;">' +
                            imgHtml +
                            '<div style="flex:1;min-width:0;">' +
                                '<span class="dip-sku">' + esc(item.sku) + '</span>' +
                                '<div class="dip-name" title="' + esc(item.name || '') + '">' + esc(item.name || item.sku) + '</div>' +
                                '<div class="dip-expected">ระบบ: <b>' + item.expected_qty + '</b> ชิ้น ' + varianceHtml + '</div>' +
                            '</div>' +
                            '<div style="text-align:right;">' +
                                '<input type="number" class="dip-input" data-sku="' + item.sku + '" placeholder="-" min="0" value="' + curVal + '" onchange="DipStockManager.countSingle(this)">' +
                                '<div style="font-size:0.65rem;color:#94a3b8;margin-top:2px;">นับจริง</div>' +
                            '</div>' +
                        '</div>' +
                        '<input type="text" class="dip-note-input" data-sku-note="' + item.sku + '" placeholder="หมายเหตุ (ไม่บังคับ)" value="' + (item.note || '') + '">' +
                    '</div>';
                });

                $('#dip-items-list').html(html);
            },

            /* Filter items */
            filterItems: function() { this.renderItems(); },

            /* Set filter pill */
            setFilter: function(f) {
                this._filter = f;
                $('[data-dip-filter]').removeClass('active');
                $('[data-dip-filter="'+f+'"]').addClass('active');
                this.renderItems();
            },

            /* Count single item */
            countSingle: function(el) {
                const self = this;
                const sku = $(el).data('sku');
                const actual = parseInt($(el).val());
                const noteEl = $('[data-sku-note="'+sku+'"]');
                const note = noteEl.val() || '';

                if (isNaN(actual) || actual < 0) return;

                $.ajax({
                    url: STOCK_API + '/dip-stock/count',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        session_id: self._session.id,
                        items: [{ sku: sku, actual_qty: actual, note: note }]
                    }),
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        if (res.success) {
                            // Update local item
                            const item = self._items.find(i => i.sku === sku);
                            if (item) {
                                item.actual_qty = actual;
                                item.variance = actual - item.expected_qty;
                                item.variance_pct = item.expected_qty > 0
                                    ? parseFloat(((item.variance / item.expected_qty) * 100).toFixed(2))
                                    : (actual > 0 ? 100 : 0);
                                item.note = note;
                            }
                            // Update progress
                            const counted = self._items.filter(i => i.actual_qty !== null).length;
                            const total = self._items.length;
                            const pct = total > 0 ? Math.round((counted / total) * 100) : 0;
                            $('#dip-progress-text').text(counted + '/' + total + ' SKU (' + pct + '%) — ไม่รวม SET');
                            $('#dip-progress-bar').css('width', pct + '%');

                            // Brief success indicator
                            $(el).css('border-color', '#22c55e');
                            setTimeout(function() { $(el).css('border-color', '#e2e8f0'); }, 800);
                        }
                    }
                });
            },

            /* Start session */
            startSession: function() {
                const self = this;
                Swal.fire({
                    title: 'เริ่มนับสต็อก?',
                    html: 'ระบบจะ snapshot สต็อกปัจจุบันทั้งหมด<br>แล้วเปิดฟอร์มให้กรอกจำนวนนับจริง',
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-play"></i> เริ่มนับ',
                    cancelButtonText: 'ยกเลิก',
                    confirmButtonColor: '#1e293b',
                }).then(function(r) {
                    if (!r.isConfirmed) return;
                    Swal.fire({ title: 'กำลังสร้าง session...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });
                    $.ajax({
                        url: STOCK_API + '/dip-stock/start',
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({}),
                        beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire({ icon: 'success', title: 'เริ่มนับสต็อก', text: 'Snapshot ' + res.total_skus + ' SKU สำเร็จ', timer: 1500, showConfirmButton: false });
                                setTimeout(function() { self.checkSession(); }, 1600);
                            } else {
                                Swal.fire('Error', res.message || 'ไม่สามารถเริ่ม session ได้', 'error');
                            }
                        },
                        error: function(xhr) {
                            const res = xhr.responseJSON || {};
                            if (xhr.status === 409) {
                                Swal.fire({
                                    icon: 'warning',
                                    title: 'มี session ค้างอยู่',
                                    text: 'Session #' + (res.session_id || '') + ' ยังเปิดอยู่ กรุณาปิดก่อนหรือ Force Close',
                                    confirmButtonColor: '#1e293b'
                                });
                            } else {
                                Swal.fire('Error', res.message || 'เกิดข้อผิดพลาด', 'error');
                            }
                        }
                    });
                });
            },

            /* Show Variance Report */
            showReport: function() {
                const self = this;
                $('#dip-active-session').hide();
                $('#dip-report').show();

                const counted = self._items.filter(i => i.actual_qty !== null);
                const withVariance = counted.filter(i => i.variance !== null && i.variance !== 0);
                const matched = counted.length - withVariance.length;

                $('#dip-report-summary').html(
                    'นับแล้ว: <b>' + counted.length + '/' + self._items.length + '</b> SKU | ' +
                    'ตรง: <b style="color:#16a34a">' + matched + '</b> | ' +
                    'ต่าง: <b style="color:#dc2626">' + withVariance.length + '</b>'
                );

                // Sort by abs variance_pct desc, then matched items
                const sorted = [...counted].sort(function(a, b) {
                    const aPct = Math.abs(a.variance_pct || 0);
                    const bPct = Math.abs(b.variance_pct || 0);
                    return bPct - aPct;
                });

                let html = '';
                sorted.forEach(function(item) {
                    const v = item.variance || 0;
                    const vp = item.variance_pct || 0;
                    let colorCls = 'dip-vb-green';
                    let borderCls = 'dip-match';
                    if (Math.abs(vp) > 5) { colorCls = 'dip-vb-red'; borderCls = 'dip-variance-neg'; }
                    else if (Math.abs(vp) > 0) { colorCls = 'dip-vb-yellow'; borderCls = 'dip-variance-pos'; }

                    const needsAdjust = v !== 0 && !item.adjusted;
                    const checkboxHtml = needsAdjust
                        ? '<input type="checkbox" class="dip-rpt-checkbox" data-approve-sku="'+item.sku+'" checked onchange="DipStockManager.updateApproveCount()">'
                        : (item.adjusted ? '<i class="fa-solid fa-check-circle" style="color:#22c55e;font-size:1.2rem;" title="ปรับแล้ว"></i>' : '<i class="fa-solid fa-check" style="color:#22c55e;" title="ตรง"></i>');

                    html += '<div class="dip-report-card ' + borderCls + '">' +
                        checkboxHtml +
                        '<div style="flex:1;min-width:0;">' +
                            '<span class="dip-sku">' + esc(item.sku) + '</span>' +
                            '<div style="font-weight:600;color:#334155;font-size:0.85rem;margin:2px 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(item.name || item.sku) + '</div>' +
                            '<div style="font-size:0.8rem;color:#64748b;">' +
                                'ระบบ: <b>' + item.expected_qty + '</b> | นับจริง: <b>' + item.actual_qty + '</b>' +
                            '</div>' +
                            (item.note ? '<div style="font-size:0.75rem;color:#94a3b8;margin-top:2px;"><i class="fa-solid fa-quote-left" style="font-size:8px;"></i> ' + item.note + '</div>' : '') +
                        '</div>' +
                        '<div style="text-align:right;">' +
                            '<span class="dip-variance-badge ' + colorCls + '">' + (v > 0 ? '+' : '') + v + '</span>' +
                            '<div style="font-size:0.7rem;color:#94a3b8;margin-top:2px;">' + (v !== 0 ? (vp > 0 ? '+' : '') + vp + '%' : 'ตรง') + '</div>' +
                        '</div>' +
                    '</div>';
                });

                $('#dip-report-items').html(html || '<div style="text-align:center;color:#94a3b8;padding:30px;">ยังไม่มีข้อมูลนับ</div>');
                self.updateApproveCount();
            },

            /* Back to counting form */
            backToCount: function() {
                $('#dip-report').hide();
                $('#dip-active-session').show();
            },

            /* Update approve count */
            updateApproveCount: function() {
                const count = $('[data-approve-sku]:checked').length;
                $('#dip-approve-count').text(count);
            },

            /* Approve selected adjustments */
            approveSelected: function() {
                const self = this;
                const checked = $('[data-approve-sku]:checked');
                const skus = [];
                checked.each(function() { skus.push($(this).data('approve-sku')); });

                if (skus.length === 0) {
                    Swal.fire('ไม่มีรายการ', 'กรุณาเลือกรายการที่ต้องการปรับสต็อก', 'info');
                    return;
                }

                Swal.fire({
                    title: 'ปรับสต็อก ' + skus.length + ' รายการ?',
                    html: 'ระบบจะปรับ stock_qty ให้ตรงกับจำนวนนับจริง<br>และบันทึก transaction log',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-check-double"></i> ยืนยันปรับสต็อก',
                    cancelButtonText: 'ยกเลิก',
                    confirmButtonColor: '#1e293b',
                }).then(function(r) {
                    if (!r.isConfirmed) return;
                    Swal.fire({ title: 'กำลังปรับสต็อก...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

                    $.ajax({
                        url: STOCK_API + '/dip-stock/approve',
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({ session_id: self._session.id, skus: skus }),
                        beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                        success: function(res) {
                            if (res.success) {
                                const msg = 'ปรับสต็อก ' + res.adjusted_count + ' รายการสำเร็จ';
                                if (res.completed) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'นับสต็อกเสร็จสมบูรณ์',
                                        text: msg,
                                        confirmButtonColor: '#1e293b'
                                    }).then(function() { self.checkSession(); });
                                } else {
                                    Swal.fire({ icon: 'success', title: msg, timer: 1500, showConfirmButton: false });
                                    setTimeout(function() { self.checkSession(); }, 1600);
                                }
                            } else {
                                Swal.fire('Error', res.message || 'ปรับสต็อกล้มเหลว', 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Error', 'เกิดข้อผิดพลาด', 'error');
                        }
                    });
                });
            },

            /* Force close session */
            forceClose: function() {
                const self = this;
                Swal.fire({
                    title: 'Force Close?',
                    text: 'ปิด session นับสต็อกนี้ (ข้อมูลนับจะยังอยู่แต่ไม่สามารถแก้ไขได้)',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Force Close',
                    confirmButtonColor: '#ef4444',
                    cancelButtonText: 'ยกเลิก',
                }).then(function(r) {
                    if (!r.isConfirmed) return;
                    $.ajax({
                        url: STOCK_API + '/dip-stock/force-close',
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({ session_id: self._session ? self._session.id : 0 }),
                        beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                        success: function() {
                            Swal.fire({ icon: 'success', title: 'ปิด session สำเร็จ', timer: 1200, showConfirmButton: false });
                            setTimeout(function() { self.checkSession(); }, 1300);
                        }
                    });
                });
            },

            /* Load history */
            loadHistory: function() {
                $.ajax({
                    url: STOCK_API + '/dip-stock/history',
                    method: 'GET',
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        const sessions = res.sessions || [];
                        if (sessions.length === 0) {
                            $('#dip-history-list').html('<div style="text-align:center;color:#94a3b8;padding:20px;">ยังไม่มีประวัติ</div>');
                            return;
                        }
                        let html = '';
                        sessions.forEach(function(s) {
                            const statusMap = { completed: 'dip-st-completed', expired: 'dip-st-expired', in_progress: 'dip-st-in_progress' };
                            const statusLabel = { completed: 'สำเร็จ', expired: 'หมดอายุ', in_progress: 'กำลังนับ' };
                            const d = new Date(s.session_date);
                            const dateStr = d.toLocaleDateString('th-TH', {day:'2-digit',month:'short',year:'numeric'});
                            html += '<div class="dip-history-item">' +
                                '<div>' +
                                    '<div style="font-weight:700;color:#334155;font-size:0.9rem;">DIP-' + s.id + ': ' + dateStr + '</div>' +
                                    '<div style="font-size:0.75rem;color:#94a3b8;">' + s.total_skus + ' SKU | ตรง: ' + s.match_count + ' | ต่าง: ' + s.variance_count + ' | โดย: ' + s.started_by_name + '</div>' +
                                '</div>' +
                                '<span class="dip-status-badge ' + (statusMap[s.status]||'') + '">' + (statusLabel[s.status]||s.status) + '</span>' +
                            '</div>';
                        });
                        $('#dip-history-list').html(html);
                    }
                });
            },

            /* Export Dip Stock CSV */
            exportDipCSV: function() {
                const self = this;
                const counted = self._items.filter(i => i.actual_qty !== null);
                if (counted.length === 0) {
                    Swal.fire('No Data', 'ไม่มีข้อมูลนับ', 'info');
                    return;
                }
                let csv = '\uFEFFSKU,ชื่อสินค้า,สต็อกระบบ,นับจริง,ส่วนต่าง,ส่วนต่าง(%),หมายเหตุ\n';
                counted.forEach(function(i) {
                    csv += '"' + i.sku + '","' + (i.name||'') + '",' + i.expected_qty + ',' + i.actual_qty + ',' + (i.variance||0) + ',' + (i.variance_pct||0) + ',"' + (i.note||'') + '"\n';
                });
                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = 'dip_stock_' + (self._session ? self._session.session_date : new Date().toISOString().slice(0,10)) + '.csv';
                link.click();
            }
        };

        loadAnalytics(); loadCatalogDataForSelect();

        // Auto-refresh: reload analytics every 30s when global toggle is ON
        // Managed by Admin Dashboard's setInterval override (blocks when OFF)
        setInterval(function(){
            if(document.getElementById('view-dash') && document.getElementById('view-dash').style.display !== 'none') {
                loadAnalytics();
            }
        }, 30000);
    });
    </script>
