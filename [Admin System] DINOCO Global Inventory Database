add_action('rest_api_init', function() {

    // --- GET /dinoco-stock/v1/stock/list ---
    register_rest_route('dinoco-stock/v1', '/stock/list', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_products';

            $page     = max(1, intval($request->get_param('page') ?: 1));
            $per_page = max(1, min(100, intval($request->get_param('per_page') ?: 20)));
            $status   = sanitize_text_field($request->get_param('status') ?: 'all');
            $search   = sanitize_text_field($request->get_param('search') ?: '');

            $where = ['is_active = 1'];
            $params = [];

            // Search filter
            if ($search !== '') {
                $like = '%' . $wpdb->esc_like($search) . '%';
                $where[] = '(sku LIKE %s OR name LIKE %s)';
                $params[] = $like;
                $params[] = $like;
            }

            // Status filter (computed from stock_qty + threshold + manual_hold)
            // We filter in PHP after fetch for correctness, unless optimizing later
            $where_sql = implode(' AND ', $where);
            $count_sql = "SELECT COUNT(*) FROM {$table} WHERE {$where_sql}";
            $total_all = (int) $wpdb->get_var( empty($params) ? $count_sql : $wpdb->prepare($count_sql, ...$params) );

            $sql = "SELECT sku, name, image_url, stock_qty, low_stock_threshold, reorder_point, manual_hold, manual_hold_reason, stock_status, stock_updated_at
                    FROM {$table} WHERE {$where_sql} ORDER BY name ASC";
            $all_rows = empty($params) ? $wpdb->get_results($sql) : $wpdb->get_results($wpdb->prepare($sql, ...$params));

            // Compute stock_display for each row + filter by status
            $filtered = [];
            $counts = ['in_stock' => 0, 'low_stock' => 0, 'out_of_stock' => 0, 'hold' => 0, 'total' => 0];
            foreach ($all_rows as $row) {
                $counts['total']++;
                $display = 'in_stock';
                if ((int)$row->manual_hold) {
                    $display = 'hold';
                } elseif ((int)$row->stock_qty <= 0) {
                    $display = 'out_of_stock';
                } elseif ((int)$row->stock_qty <= (int)$row->low_stock_threshold) {
                    $display = 'low_stock';
                }
                $counts[$display]++;

                if ($status !== 'all' && $display !== $status) continue;

                $row->stock_display = $display;
                $filtered[] = $row;
            }

            $total_filtered = count($filtered);
            $pages = max(1, ceil($total_filtered / $per_page));
            $offset = ($page - 1) * $per_page;
            $paged = array_slice($filtered, $offset, $per_page);

            $data = [];
            foreach ($paged as $row) {
                $data[] = [
                    'sku'                 => $row->sku,
                    'name'                => $row->name,
                    'image_url'           => $row->image_url,
                    'stock_qty'           => (int) $row->stock_qty,
                    'stock_display'       => $row->stock_display,
                    'low_stock_threshold' => (int) $row->low_stock_threshold,
                    'reorder_point'       => (int) $row->reorder_point,
                    'manual_hold'         => (bool) $row->manual_hold,
                    'manual_hold_reason'  => $row->manual_hold_reason ?: '',
                    'stock_updated_at'    => $row->stock_updated_at ?: '',
                ];
            }

            return rest_ensure_response([
                'success' => true,
                'data'    => $data,
                'total'   => $total_filtered,
                'pages'   => $pages,
                'counts'  => $counts,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/stock/adjust ---
    register_rest_route('dinoco-stock/v1', '/stock/adjust', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $table_p   = $wpdb->prefix . 'dinoco_products';
            $table_txn = $wpdb->prefix . 'dinoco_stock_transactions';

            $sku    = sanitize_text_field($request->get_param('sku'));
            $type   = sanitize_text_field($request->get_param('type')); // add|subtract
            $qty    = max(0, intval($request->get_param('qty')));
            $reason = sanitize_text_field($request->get_param('reason'));

            if (!$sku || !in_array($type, ['add','subtract']) || $qty <= 0) {
                return new WP_Error('invalid_params', 'Missing sku, type (add/subtract), or qty', ['status' => 400]);
            }
            if (empty($reason)) {
                return new WP_Error('missing_reason', 'กรุณาระบุเหตุผล', ['status' => 400]);
            }

            $wpdb->query('START TRANSACTION');
            $current = $wpdb->get_row($wpdb->prepare(
                "SELECT stock_qty, low_stock_threshold FROM {$table_p} WHERE sku = %s FOR UPDATE", $sku
            ));
            if (!$current) {
                $wpdb->query('ROLLBACK');
                return new WP_Error('sku_not_found', "SKU {$sku} not found", ['status' => 404]);
            }

            $qty_before = (int) $current->stock_qty;
            $change     = ($type === 'add') ? $qty : -$qty;
            $qty_after  = max(0, $qty_before + $change);
            $txn_type   = ($type === 'add') ? 'manual_add' : 'manual_subtract';

            $wpdb->update($table_p,
                ['stock_qty' => $qty_after, 'stock_updated_at' => current_time('mysql')],
                ['sku' => $sku]
            );

            $wpdb->insert($table_txn, [
                'sku'            => $sku,
                'type'           => $txn_type,
                'qty_change'     => $change,
                'qty_before'     => $qty_before,
                'qty_after'      => $qty_after,
                'reason'         => $reason,
                'user_id'        => get_current_user_id(),
                'created_at'     => current_time('mysql'),
            ]);
            $txn_id = $wpdb->insert_id;

            $wpdb->query('COMMIT');

            // Compute new display status
            $threshold = (int) $current->low_stock_threshold;
            $display = 'in_stock';
            if ($qty_after <= 0) $display = 'out_of_stock';
            elseif ($qty_after <= $threshold) $display = 'low_stock';

            // Auto-update stock_status on b2b_product CPT for backward compat
            $b2b_status = ($qty_after <= 0) ? 'out_of_stock' : 'in_stock';
            if (class_exists('DINOCO_Catalog')) {
                DINOCO_Catalog::set_stock_status($sku, $b2b_status);
            }

            return rest_ensure_response([
                'success'       => true,
                'new_qty'       => $qty_after,
                'stock_display' => $display,
                'transaction_id'=> $txn_id,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- GET /dinoco-stock/v1/stock/transactions ---
    register_rest_route('dinoco-stock/v1', '/stock/transactions', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_stock_transactions';

            $sku       = sanitize_text_field($request->get_param('sku'));
            $page      = max(1, intval($request->get_param('page') ?: 1));
            $per_page  = max(1, min(50, intval($request->get_param('per_page') ?: 20)));
            $type_filter = sanitize_text_field($request->get_param('type_filter') ?: '');

            if (!$sku) {
                return new WP_Error('missing_sku', 'SKU is required', ['status' => 400]);
            }

            $where = ['sku = %s'];
            $params = [$sku];

            if ($type_filter) {
                $where[] = 'type = %s';
                $params[] = $type_filter;
            }

            $where_sql = implode(' AND ', $where);
            $total = (int) $wpdb->get_var($wpdb->prepare("SELECT COUNT(*) FROM {$table} WHERE {$where_sql}", ...$params));

            $offset = ($page - 1) * $per_page;
            $rows = $wpdb->get_results($wpdb->prepare(
                "SELECT id, type, qty_change, qty_before, qty_after, reason, user_id, created_at, reference_type, reference_id
                 FROM {$table} WHERE {$where_sql} ORDER BY created_at DESC LIMIT %d OFFSET %d",
                ...array_merge($params, [$per_page, $offset])
            ));

            $data = [];
            foreach ($rows as $r) {
                $user_name = '';
                if ($r->user_id) {
                    $u = get_userdata($r->user_id);
                    $user_name = $u ? $u->display_name : 'User #' . $r->user_id;
                }
                $data[] = [
                    'id'             => (int) $r->id,
                    'type'           => $r->type,
                    'qty_change'     => (int) $r->qty_change,
                    'qty_before'     => (int) $r->qty_before,
                    'qty_after'      => (int) $r->qty_after,
                    'reason'         => $r->reason,
                    'user_name'      => $user_name,
                    'created_at'     => $r->created_at,
                    'reference_type' => $r->reference_type,
                    'reference_id'   => $r->reference_id ? (int) $r->reference_id : null,
                ];
            }

            return rest_ensure_response([
                'success' => true,
                'data'    => $data,
                'total'   => $total,
                'pages'   => max(1, ceil($total / $per_page)),
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/stock/settings ---
    register_rest_route('dinoco-stock/v1', '/stock/settings', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            $fields = [
                'default_threshold' => 'dinoco_inv_default_low_threshold',
                'default_reorder'   => 'dinoco_inv_default_reorder_point',
                'alert_enabled'     => 'dinoco_inv_alert_enabled',
                'dip_interval'      => 'dinoco_inv_dip_stock_interval_days',
            ];
            foreach ($fields as $param => $option) {
                $val = $request->get_param($param);
                if ($val !== null) {
                    if ($param === 'alert_enabled') {
                        update_option($option, $val ? '1' : '0');
                    } else {
                        update_option($option, max(0, intval($val)));
                    }
                }
            }
            return rest_ensure_response(['success' => true]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- GET /dinoco-stock/v1/stock/settings ---
    register_rest_route('dinoco-stock/v1', '/stock/settings', [
        'methods'  => 'GET',
        'callback' => function() {
            return rest_ensure_response([
                'success' => true,
                'data'    => [
                    'default_threshold' => (int) get_option('dinoco_inv_default_low_threshold', 10),
                    'default_reorder'   => (int) get_option('dinoco_inv_default_reorder_point', 5),
                    'alert_enabled'     => (bool) get_option('dinoco_inv_alert_enabled', true),
                    'dip_interval'      => (int) get_option('dinoco_inv_dip_stock_interval_days', 30),
                    'initialized'       => (bool) get_option('dinoco_inv_initialized', false),
                ],
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/stock/hold ---
    register_rest_route('dinoco-stock/v1', '/stock/hold', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_products';
            $sku    = sanitize_text_field($request->get_param('sku'));
            $hold   = (bool) $request->get_param('hold');
            $reason = sanitize_text_field($request->get_param('reason') ?: '');

            if (!$sku) return new WP_Error('missing_sku', 'SKU required', ['status' => 400]);

            $exists = $wpdb->get_var($wpdb->prepare("SELECT sku FROM {$table} WHERE sku = %s", $sku));
            if (!$exists) return new WP_Error('sku_not_found', "SKU {$sku} not found", ['status' => 404]);

            $update = [
                'manual_hold'        => $hold ? 1 : 0,
                'manual_hold_reason' => $hold ? $reason : null,
                'manual_hold_by'     => $hold ? get_current_user_id() : null,
                'stock_updated_at'   => current_time('mysql'),
            ];
            $wpdb->update($table, $update, ['sku' => $sku]);

            // Sync stock_status on b2b_product CPT
            if ($hold && class_exists('DINOCO_Catalog')) {
                DINOCO_Catalog::set_stock_status($sku, 'out_of_stock');
            } elseif (!$hold) {
                $qty = (int) $wpdb->get_var($wpdb->prepare("SELECT stock_qty FROM {$table} WHERE sku = %s", $sku));
                if ($qty > 0 && class_exists('DINOCO_Catalog')) {
                    DINOCO_Catalog::set_stock_status($sku, 'in_stock');
                }
            }

            return rest_ensure_response(['success' => true]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/stock/initialize ---
    register_rest_route('dinoco-stock/v1', '/stock/initialize', [
        'methods'  => 'POST',
