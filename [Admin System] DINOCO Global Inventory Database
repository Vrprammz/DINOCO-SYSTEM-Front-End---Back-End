        window.saveCatalogItem = function() {
            let sku = $('#cat-sku').val(); if(!sku) return Swal.fire('Error', 'SKU Required', 'error');
            // Auto-add model ถ้ามีเลือกใน dropdown แต่ยังไม่ได้กด +
            var pendingModel = $('#cat-moto-model').val();
            if (pendingModel) { addMotoCompat(); }
            /* [FIX] Use unique action key */
            console.log('[Save] _compatModels before save:', JSON.parse(JSON.stringify(_compatModels)));
            let d = { dinoco_inventory_action: 'save_product', dinoco_admin_nonce: DINOCO_NONCE, sku: sku, name: $('#cat-name').val(), img: $('#cat-img').val(), price: $('#cat-price').val(), years: $('#cat-years').val(), sub: '-', b2b_visible: $('#cat-b2b-visible').is(':checked') ? '1' : '0', compatible_models: JSON.stringify(_compatModels) };
            console.log('[Save] compatible_models JSON:', d.compatible_models);
            let children = skuRelations[sku] || [];

            // V.35: Pricing data via REST API (dual-write)
            let pricingData = {
                sku: sku,
                discount_percent: parseFloat($('#cat-discount').val()) || 0,
                price_standard: parseFloat($('#cat-ps').val()) || 0,
                price_silver: parseFloat($('#cat-psi').val()) || 0,
                price_gold: parseFloat($('#cat-pg').val()) || 0,
                price_platinum: parseFloat($('#cat-pp').val()) || 0,
                price_diamond: parseFloat($('#cat-pd').val()) || 0,
                category: $('#cat-category').val() || '',
                moq: parseInt($('#cat-moq').val()) || 1,
                boxes_per_unit: parseInt($('#cat-bpu').val()) || 1,
                b2b_visible: $('#cat-b2b-visible').is(':checked') ? 1 : 0,
                compatible_models: _compatModels
            };

            // Save sequential: product → relations → pricing (ป้องกัน race condition)
            $.post('', d).done(function(r1) {
                var res = typeof r1 === 'string' ? JSON.parse(r1) : r1;
                // V.38.2: Debug logging
                if (res && res.debug) console.log('[SaveProduct] debug:', res.debug);
                if (res && res.success === false) { Swal.fire('Error', res.message || 'Save failed', 'error'); return; }

                // Relations + Pricing พร้อมกัน (ไม่ depend กัน)
                $.when(
                    $.post('', { dinoco_inventory_action: 'save_sku_relation', dinoco_admin_nonce: DINOCO_NONCE, parent_sku: sku, child_skus: children }),
                    $.ajax({ url: STOCK_API_EARLY + '/product/pricing', method: 'POST', contentType: 'application/json', headers: { 'X-WP-Nonce': STOCK_NONCE_EARLY }, data: JSON.stringify(pricingData) }).done(function(pr) { console.log('[Pricing] response:', pr); })
                ).done(function() {
                    Swal.fire({icon:'success', title:'บันทึกสำเร็จ', timer:1000, showConfirmButton:false});
                    document.body.style.overflow = '';
                    $('#modal-catalog-editor').fadeOut(150);
                    loadCatalog();
                }).fail(function() {
                    // product saved but pricing/relations failed
                    Swal.fire('Warning', 'บันทึกสินค้าแล้วแต่ pricing/relations อาจไม่สมบูรณ์', 'warning');
                    document.body.style.overflow = '';
                    $('#modal-catalog-editor').fadeOut(150);
                    loadCatalog();
                });
            }).fail(function(err) {
                Swal.fire('Error', 'Save failed: ' + (err.responseJSON ? err.responseJSON.message : err.statusText), 'error');
            });
        };

