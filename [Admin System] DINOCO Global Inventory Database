        /* Auto-calculate tier prices from retail price + discount % */
        window.autoCalcTierPrices = function() {
            var retail = parseFloat(String($('#cat-price').val()).replace(/,/g,'')) || 0;
            var disc = parseFloat($('#cat-discount').val()) || 0;
            if (retail <= 0 || disc <= 0) return;
            
            // Standard = retail * (1 - disc/100)
            // Then each tier gets additional discount steps
            var tierMultipliers = {
                ps: 1.0,       // Standard: base discount
                psi: 0.875,    // Silver: 12.5% extra off standard
                pg: 0.8125,    // Gold: further
                pp: 0.75,      // Platinum
                pd: 0.6875     // Diamond
            };
            var stdPrice = Math.round(retail * (1 - disc/100));
            var tierIds = ['ps','psi','pg','pp','pd'];
            var factors = [1.0, 0.875, 0.8125, 0.75, 0.6875];
            
            tierIds.forEach(function(tid, idx) {
                var calcPrice = Math.round(retail * factors[idx] * (1 - disc/100 * (idx === 0 ? 1 : 1)));
                // Simpler: evenly spaced between stdPrice and deeper discount
                calcPrice = Math.round(stdPrice - (stdPrice * 0.05 * idx));
                var el = $('#cat-' + tid);
                // Only auto-fill if current value is 0 or matches previous auto-calc
                var cur = parseFloat(el.val()) || 0;
                if (cur === 0 || el.data('auto-set')) {
                    el.val(calcPrice).data('auto-set', true);
                }
                updateTierMargin(el[0], tid);
            });
        };
        
        window.updateTierMargin = function(el, tid) {
            var retail = parseFloat(String($('#cat-price').val()).replace(/,/g,'')) || 0;
            var tierPrice = parseFloat($(el).val()) || 0;
            var marginEl = $('#margin-' + tid);
            if (retail > 0 && tierPrice > 0) {
                var margin = ((retail - tierPrice) / retail * 100).toFixed(1);
                marginEl.text('-' + margin + '%');
                marginEl.removeClass('positive negative zero');
                if (parseFloat(margin) > 0) marginEl.addClass('positive');
                else if (parseFloat(margin) < 0) marginEl.addClass('negative');
                else marginEl.addClass('zero');
            } else {
                marginEl.text('').removeClass('positive negative zero');
            }
            // Mark as manually edited
            $(el).data('auto-set', false);
        };

        /* Autocomplete for child component search */
        window.filterChildOptions = function(query) {
            var q = (query || '').trim().toLowerCase();
            var dd = $('#cat-child-dropdown');
            var parentSku = $('#cat-sku').val();
            var currentChildren = skuRelations[parentSku] || [];
            var html = '';
            var count = 0;
            Object.keys(catalogData).forEach(function(sku) {
                if (sku === parentSku) return;  // cannot add self
                if (currentChildren.indexOf(sku) !== -1) return;  // already added
                var item = catalogData[sku];
                var match = q === '' || sku.toLowerCase().indexOf(q) !== -1 || (item.name && item.name.toLowerCase().indexOf(q) !== -1);
                if (!match) return;
                if (count >= 20) return;  // limit results
                var imgHtml = item.img ? '<img src="' + esc(item.img) + '" onerror="this.style.display=\'none\'">' : '';
                html += '<div class="cedit-child-option" onclick="selectChildComponent(\'' + sku + '\')">' + imgHtml + '<div><div class="opt-sku">' + esc(sku) + '</div><div class="opt-name">' + esc(item.name) + '</div></div></div>';
                count++;
            });
            dd.html(html || '<div style="padding:12px;text-align:center;color:#94a3b8;font-size:0.8rem;">No matching products</div>');
            dd.show();
        };
        
        window.selectChildComponent = function(childSku) {
            var parentSku = $('#cat-sku').val();
            if (!parentSku) return;
            if (!skuRelations[parentSku]) skuRelations[parentSku] = [];
            skuRelations[parentSku].push(childSku);
            renderCatChildren(parentSku);
            $('#cat-child-search').val('');
            $('#cat-child-dropdown').hide();
            // Show SET badge
            $('#cat-set-badge').show();
        };
        
        // Close dropdown on outside click
        $(document).on('click', function(e) {
            if (!$(e.target).closest('.cedit-child-search-wrap').length) {
                $('#cat-child-dropdown').hide();
            }
        });

        /* === Category Management === */
        var _categoryList = [];

        // Filter: category ที่ถูกต้อง (ไม่ใช่ SKU, ไม่มี +, สั้นกว่า 30 ตัว, ไม่ขึ้นต้นด้วย DNC)
        function isValidCategory(c) {
            if (!c || c === '-' || c.length > 40) return false;
            if (/^DNC/i.test(c)) return false;        // SKU pattern
            if (/\+/.test(c)) return false;            // SKU relations (A + B)
            if (/^[A-Z0-9\-]+$/i.test(c) && c.length > 8) return false; // pure SKU
            return true;
        }

        function loadCategories(selectedVal) {
            var cats = new Set();
            // จาก catalog data (filter เฉพาะที่ valid)
            if (catalogData) {
                Object.keys(catalogData).forEach(function(sku) {
                    var c = (catalogData[sku].product_category || catalogData[sku].category || '').trim();
                    if (isValidCategory(c)) cats.add(c);
                });
            }
            // จาก saved custom categories
            var saved = JSON.parse(localStorage.getItem('dinoco_categories') || '[]');
            saved.forEach(function(c) { if (c && isValidCategory(c)) cats.add(c); });

            _categoryList = Array.from(cats).sort();

            var $sel = $('#cat-category');
            $sel.html('<option value="">-- เลือกหมวดหมู่ --</option>');
            _categoryList.forEach(function(c) {
                $sel.append('<option value="' + esc(c) + '">' + esc(c) + '</option>');
            });
            // ถ้า selectedVal ไม่อยู่ใน list (ข้อมูลเก่า) → เพิ่มเข้าไปชั่วคราว
            if (selectedVal && !cats.has(selectedVal)) {
                $sel.append('<option value="' + esc(selectedVal) + '">' + esc(selectedVal) + ' ⚠️</option>');
            }
            if (selectedVal) $sel.val(selectedVal);
        }

        window.addNewCategory = function() {
            Swal.fire({
                title: 'เพิ่มหมวดหมู่ใหม่',
                input: 'text',
                inputPlaceholder: 'เช่น กันล้ม, กล่องอลูมิเนียม, แร็ค...',
                showCancelButton: true,
                confirmButtonText: 'เพิ่ม',
                cancelButtonText: 'ยกเลิก',
                confirmButtonColor: '#1e293b',
                inputValidator: function(v) {
                    if (!v || !v.trim()) return 'กรุณากรอกชื่อหมวดหมู่';
                    if (_categoryList.includes(v.trim())) return 'หมวดหมู่นี้มีอยู่แล้ว';
                }
            }).then(function(r) {
                if (r.isConfirmed && r.value) {
                    var newCat = r.value.trim();
                    // Save to localStorage (persistent across sessions)
                    var saved = JSON.parse(localStorage.getItem('dinoco_categories') || '[]');
                    if (!saved.includes(newCat)) {
                        saved.push(newCat);
                        localStorage.setItem('dinoco_categories', JSON.stringify(saved));
                    }
                    loadCategories(newCat);
                }
            });
        };

        window.manageCategoriesModal = function() {
            // นับสินค้าต่อ category
            var catCount = {};
            if (catalogData) {
                Object.keys(catalogData).forEach(function(sku) {
                    var c = (catalogData[sku].product_category || catalogData[sku].category || '').trim();
                    if (c && c !== '-') {
                        catCount[c] = (catCount[c] || 0) + 1;
                    }
                });
            }

            var html = '<div style="max-height:400px;overflow-y:auto;">';
            html += '<table style="width:100%;border-collapse:collapse;font-size:14px;">';
            html += '<tr style="background:#f8fafc;"><th style="text-align:left;padding:8px;">หมวดหมู่</th><th style="text-align:center;padding:8px;width:80px;">สินค้า</th><th style="text-align:center;padding:8px;width:60px;">ลบ</th></tr>';

            _categoryList.forEach(function(c) {
                var count = catCount[c] || 0;
                var canDelete = count === 0;
                html += '<tr style="border-bottom:1px solid #f1f5f9;">' +
                    '<td style="padding:8px;">' + esc(c) + '</td>' +
                    '<td style="text-align:center;padding:8px;color:#64748b;">' + count + '</td>' +
                    '<td style="text-align:center;padding:8px;">' +
                    (canDelete
                        ? '<button onclick="deleteCategory(\'' + esc(c).replace(/'/g, "\\'") + '\')" style="background:#fee2e2;color:#dc2626;border:none;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px;"><i class="fa-solid fa-trash"></i></button>'
                        : '<span style="color:#cbd5e1;font-size:11px;">ใช้อยู่</span>') +
                    '</td></tr>';
            });

            // แสดง invalid categories ที่มีใน data (สำหรับ cleanup)
            var invalidCats = [];
            if (catalogData) {
                Object.keys(catalogData).forEach(function(sku) {
                    var c = (catalogData[sku].product_category || catalogData[sku].category || '').trim();
                    if (c && c !== '-' && !isValidCategory(c) && invalidCats.indexOf(c) === -1) {
                        invalidCats.push(c);
                    }
                });
            }
            if (invalidCats.length > 0) {
                // นับ total invalid SKUs
