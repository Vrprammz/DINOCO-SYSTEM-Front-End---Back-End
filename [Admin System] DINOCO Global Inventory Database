                });
            },

            _adjType: 'add',
            _adjSetType: function(type) {
                this._adjType = type;
                $('#adj-type').val(type);
                if (type === 'add') {
                    $('#adj-type-add').css({border:'2px solid #22c55e', background:'#dcfce7', color:'#166534'});
                    $('#adj-type-sub').css({border:'2px solid #e2e8f0', background:'white', color:'#64748b'});
                } else {
                    $('#adj-type-sub').css({border:'2px solid #ef4444', background:'#fee2e2', color:'#991b1b'});
                    $('#adj-type-add').css({border:'2px solid #e2e8f0', background:'white', color:'#64748b'});
                }
                this._adjPreview();
            },

            _adjPreview: function() {
                const cur = parseInt($('#adj-current').text()) || 0;
                const qty = parseInt($('#adj-qty').val()) || 0;
                const type = $('#adj-type').val();
                const after = type === 'add' ? cur + qty : Math.max(0, cur - qty);
                $('#adj-after').text(after);
                if (after <= 0) {
                    $('#adj-after').css('color', '#ef4444');
                } else {
                    $('#adj-after').css('color', '#1e40af');
                }
            },

            _adjSkuChanged: function() {
                const sku = $('#adj-sku').val();
                const p = this._allData.find(x => x.sku === sku);
                if (p) {
                    $('#adj-pname').text(p.name);
                    $('#adj-current').text(p.stock_qty);
                    $('#adj-reserved').text(p.reserved_qty || 0);
                    $('#adj-available').text(p.available_qty || 0);
                    $('#adj-product-info').show();
