    // --- GET /dinoco-stock/v1/dip-stock/history ---
    register_rest_route('dinoco-stock/v1', '/dip-stock/history', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $dip_table = $wpdb->prefix . 'dinoco_dip_stock';

            $sessions = $wpdb->get_results(
                "SELECT id, session_date, status, started_by, completed_at, total_skus, counted_skus, adjusted_skus, notes, created_at
                 FROM {$dip_table}
                 ORDER BY id DESC
                 LIMIT 20",
                ARRAY_A
            );

            foreach ( $sessions as &$s ) {
                $s['id']            = (int) $s['id'];
                $s['total_skus']    = (int) $s['total_skus'];
                $s['counted_skus']  = (int) $s['counted_skus'];
                $s['adjusted_skus'] = (int) $s['adjusted_skus'];

                // Compute variance summary
                $items_table = $wpdb->prefix . 'dinoco_dip_stock_items';
                $variance_count = (int) $wpdb->get_var( $wpdb->prepare(
                    "SELECT COUNT(*) FROM {$items_table} WHERE dip_stock_id = %d AND variance IS NOT NULL AND variance != 0",
                    $s['id']
                ) );
                $s['variance_count'] = $variance_count;
                $s['match_count']    = $s['counted_skus'] - $variance_count;

                // User display name
                if ( $s['started_by'] ) {
                    $user = get_userdata( $s['started_by'] );
                    $s['started_by_name'] = $user ? $user->display_name : 'User #' . $s['started_by'];
                } else {
                    $s['started_by_name'] = '-';
                }
            }

            return rest_ensure_response([
                'success'  => true,
                'sessions' => $sessions,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // ─── Phase 5: Warehouse CRUD ────────────────────────

    // GET /dinoco-stock/v1/warehouses
    register_rest_route('dinoco-stock/v1', '/warehouses', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            $warehouses = function_exists('dinoco_get_warehouses') ? dinoco_get_warehouses(false) : [];
            foreach ($warehouses as &$w) {
                $w['id']         = (int) $w['id'];
                $w['is_default'] = (bool) $w['is_default'];
                $w['is_active']  = (bool) $w['is_active'];
            }
            return rest_ensure_response([ 'success' => true, 'data' => $warehouses ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // POST /dinoco-stock/v1/warehouse — create or update
    register_rest_route('dinoco-stock/v1', '/warehouse', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_warehouses';

            $id      = intval($request->get_param('id'));
            $name    = sanitize_text_field($request->get_param('name'));
            $code    = strtoupper(sanitize_text_field($request->get_param('code')));
            $address = sanitize_textarea_field($request->get_param('address') ?: '');
            $default = (bool) $request->get_param('is_default');
            $active  = $request->get_param('is_active') !== null ? (bool) $request->get_param('is_active') : true;

            if (empty($name) || empty($code)) {
                return new WP_Error('missing_fields', 'ต้องระบุชื่อและรหัสคลัง', ['status' => 400]);
            }

            // Code unique check
            $existing = $wpdb->get_row($wpdb->prepare("SELECT id FROM {$table} WHERE code = %s AND id != %d", $code, $id));
            if ($existing) {
                return new WP_Error('code_exists', "รหัสคลัง '{$code}' ถูกใช้แล้ว", ['status' => 400]);
            }

            // If setting as default, unset others
            if ($default) {
                $wpdb->update($table, ['is_default' => 0], ['is_default' => 1]);
            }

            if ($id > 0) {
                $wpdb->update($table, [
                    'name' => $name, 'code' => $code, 'address' => $address,
                    'is_default' => $default ? 1 : 0, 'is_active' => $active ? 1 : 0,
                ], ['id' => $id]);
            } else {
                $wpdb->insert($table, [
                    'name' => $name, 'code' => $code, 'address' => $address,
                    'is_default' => $default ? 1 : 0, 'is_active' => $active ? 1 : 0,
                    'created_at' => current_time('mysql'),
                ]);
                $id = $wpdb->insert_id;
            }

            return rest_ensure_response([ 'success' => true, 'id' => $id ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // POST /dinoco-stock/v1/stock/transfer
    register_rest_route('dinoco-stock/v1', '/stock/transfer', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            $sku     = sanitize_text_field($request->get_param('sku'));
            $from_wh = intval($request->get_param('from_warehouse_id'));
            $to_wh   = intval($request->get_param('to_warehouse_id'));
            $qty     = max(0, intval($request->get_param('qty')));
            $reason  = sanitize_text_field($request->get_param('reason') ?: '');

            if (!$sku || !$from_wh || !$to_wh || $qty <= 0) {
                return new WP_Error('invalid_params', 'ข้อมูลไม่ครบ', ['status' => 400]);
            }

            if (!function_exists('dinoco_transfer_stock')) {
                return new WP_Error('not_available', 'Multi-warehouse not available', ['status' => 500]);
            }

            $result = dinoco_transfer_stock($sku, $from_wh, $to_wh, $qty, $reason);
            if (is_wp_error($result)) {
                return $result;
            }
            return rest_ensure_response([ 'success' => true, 'data' => $result ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // GET /dinoco-stock/v1/valuation
    register_rest_route('dinoco-stock/v1', '/valuation', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            if (!function_exists('dinoco_get_inventory_valuation')) {
                return new WP_Error('not_available', 'Valuation not available', ['status' => 500]);
            }
            return rest_ensure_response([ 'success' => true, 'data' => dinoco_get_inventory_valuation() ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // GET /dinoco-stock/v1/forecast
    register_rest_route('dinoco-stock/v1', '/forecast', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            $days  = max(7, intval($request->get_param('days') ?: 30));
            $limit = max(1, min(100, intval($request->get_param('limit') ?: 20)));

            if (!function_exists('dinoco_get_stock_forecast_all')) {
                return new WP_Error('not_available', 'Forecast not available', ['status' => 500]);
            }
            return rest_ensure_response([
                'success' => true,
                'data'    => dinoco_get_stock_forecast_all($days, $limit),
                'period'  => $days,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/product/pricing --- V.35.0: Save discount + tier prices (dual-write)
    register_rest_route('dinoco-stock/v1', '/product/pricing', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_products';

            $sku = sanitize_text_field($request->get_param('sku'));
            if (empty($sku)) {
                return new WP_REST_Response(['success' => false, 'message' => 'SKU required'], 400);
            }

            // V.38.1: Selective update — only update fields that were actually sent
            $params = $request->get_json_params();
            if (!is_array($params)) $params = [];

            $custom_data = [];
            $acf_data = [];

            if (array_key_exists('discount_percent', $params)) {
                $discount = max(0, min(100, floatval($params['discount_percent'])));
                $custom_data['b2b_discount_percent'] = $discount;
                $acf_data['b2b_discount_percent'] = $discount;
            }
            if (array_key_exists('price_standard', $params)) {
                $ps = max(0, floatval($params['price_standard']));
                $acf_data['price_standard'] = $ps;
            }
            if (array_key_exists('price_silver', $params)) {
                $psi = max(0, floatval($params['price_silver']));
                $custom_data['price_silver'] = $psi;
                $acf_data['price_silver'] = $psi;
            }
            if (array_key_exists('price_gold', $params)) {
                $pg = max(0, floatval($params['price_gold']));
                $custom_data['price_gold'] = $pg;
                $acf_data['price_gold'] = $pg;
            }
            if (array_key_exists('price_platinum', $params)) {
                $pp = max(0, floatval($params['price_platinum']));
                $custom_data['price_platinum'] = $pp;
                $acf_data['price_platinum'] = $pp;
            }
            if (array_key_exists('price_diamond', $params)) {
                $pd = max(0, floatval($params['price_diamond']));
                $custom_data['price_diamond'] = $pd;
                $acf_data['price_diamond'] = $pd;
            }
            if (array_key_exists('category', $params)) {
                $cat = sanitize_text_field($params['category'] ?: '');
                $custom_data['category'] = $cat;
                $acf_data['product_category'] = $cat;
            }
            if (array_key_exists('moq', $params)) {
                $moq = max(1, intval($params['moq'] ?: 1));
                $custom_data['min_order_qty'] = $moq;
                $acf_data['min_order_qty'] = $moq;
            }
            if (array_key_exists('boxes_per_unit', $params)) {
                $bpu = max(1, intval($params['boxes_per_unit'] ?: 1));
                $custom_data['boxes_per_unit'] = $bpu;
                $acf_data['boxes_per_unit'] = $bpu;
            }
            if (array_key_exists('b2b_visible', $params)) {
                $b2b_visible = intval($params['b2b_visible']) ? 1 : 0;
                $custom_data['b2b_visible'] = $b2b_visible;
            }
            // V.38.2: compatible_models via pricing endpoint
            if (array_key_exists('compatible_models', $params)) {
                $cm_raw = $params['compatible_models'];
                $cm_decoded = is_array($cm_raw) ? $cm_raw : json_decode($cm_raw, true);
                $custom_data['compatible_models'] = is_array($cm_decoded) ? wp_json_encode($cm_decoded) : '[]';
            }

            // V.38.1: Ensure b2b_visible column exists (ALTER TABLE fallback)
            $col_check = $wpdb->get_var("SHOW COLUMNS FROM {$table} LIKE 'b2b_visible'");
            if (!$col_check) {
                $wpdb->query("ALTER TABLE {$table} ADD COLUMN b2b_visible TINYINT(1) NOT NULL DEFAULT 1 AFTER is_active");
            }

            // V.38.2: Ensure compatible_models column exists
            $compat_check = $wpdb->get_var("SHOW COLUMNS FROM {$table} LIKE 'compatible_models'");
            if (!$compat_check) {
                $wpdb->query("ALTER TABLE {$table} ADD COLUMN compatible_models TEXT DEFAULT NULL AFTER manual_hold_by");
            }

            $debug = ['custom_data' => $custom_data, 'acf_data' => array_keys($acf_data)];

            // 1) Update dinoco_products custom table (only changed fields)
            if (!empty($custom_data)) {
                $exists = $wpdb->get_var($wpdb->prepare("SELECT id FROM {$table} WHERE sku = %s AND is_active = 1", $sku));
                if ($exists) {
                    $upd_result = $wpdb->update($table, $custom_data, ['sku' => $sku]);
                    $debug['ct_update'] = $upd_result;
                    $debug['ct_error'] = $wpdb->last_error;
                } else {
                    // Product should exist in custom table — create minimal row
                    $custom_data['sku'] = $sku;
                    $custom_data['name'] = $sku;
                    $ins_result = $wpdb->insert($table, $custom_data);
                    $debug['ct_insert'] = $ins_result;
                    $debug['ct_error'] = $wpdb->last_error;
                }
            }

            // 2) Dual-write to b2b_product ACF postmeta (only if ACF fields were sent)
            if (!empty($acf_data)) {
                $b2b_posts = get_posts([
                    'post_type'      => 'b2b_product',
                    'posts_per_page' => 1,
                    'post_status'    => 'publish',
                    'meta_query'     => [['key' => 'product_sku', 'value' => $sku]],
                ]);
                $b2b_id = !empty($b2b_posts) ? $b2b_posts[0]->ID : 0;
                if (!$b2b_id) {
                    // Auto-create b2b_product post
                    $catalog = dinoco_get_current_catalog();
                    $name = isset($catalog[$sku]['name']) ? $catalog[$sku]['name'] : $sku;
                    $b2b_id = wp_insert_post([
                        'post_type'   => 'b2b_product',
                        'post_title'  => $name . ' (' . $sku . ')',
                        'post_status' => 'publish',
                    ]);
                    if (is_wp_error($b2b_id)) {
                        return new WP_REST_Response(['success' => false, 'message' => 'Failed to create b2b_product'], 500);
                    }
                    update_field('product_sku', $sku, $b2b_id);
                    update_field('stock_status', 'in_stock', $b2b_id);
                }
                // V.38.1: Selective ACF dual-write — only update fields that were sent
                foreach ($acf_data as $acf_key => $acf_val) {
                    update_field($acf_key, $acf_val, $b2b_id);
                }
                $debug['b2b_id'] = $b2b_id;
            }

            // V.38.2: Verify saved values
            $verify = $wpdb->get_row($wpdb->prepare("SELECT b2b_visible, category, compatible_models FROM {$table} WHERE sku = %s AND is_active = 1", $sku), ARRAY_A);
            $debug['verified'] = $verify;

            // 3) Clear transient cache
            delete_transient('b2b_sku_data_map');

            return new WP_REST_Response(['success' => true, 'message' => 'Pricing saved for ' . $sku, 'b2b_post_id' => isset($b2b_id) ? $b2b_id : 0, 'debug' => $debug], 200);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/product/upload-image --- V.37.0: Upload product image to WP Media Library
    register_rest_route('dinoco-stock/v1', '/product/upload-image', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            // Require wp-admin media functions
            if ( ! function_exists('media_handle_upload') ) {
                require_once ABSPATH . 'wp-admin/includes/image.php';
                require_once ABSPATH . 'wp-admin/includes/file.php';
                require_once ABSPATH . 'wp-admin/includes/media.php';
            }

            if ( empty($_FILES['product_image']) ) {
                return new WP_REST_Response(['success' => false, 'message' => 'No file uploaded'], 400);
            }

            // Validate file type
            $allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
            if ( ! in_array($_FILES['product_image']['type'], $allowed) ) {
                return new WP_REST_Response(['success' => false, 'message' => 'Invalid file type. Allowed: JPG, PNG, WebP, GIF'], 400);
            }

            // Validate file size (max 5MB)
            if ( $_FILES['product_image']['size'] > 5 * 1024 * 1024 ) {
                return new WP_REST_Response(['success' => false, 'message' => 'File too large. Max 5MB'], 400);
            }

            $sku = sanitize_text_field($request->get_param('sku'));

            // Upload to WordPress Media Library
            $attachment_id = media_handle_upload('product_image', 0);
            if ( is_wp_error($attachment_id) ) {
                return new WP_REST_Response(['success' => false, 'message' => $attachment_id->get_error_message()], 500);
            }

            $url = wp_get_attachment_url($attachment_id);

            // If SKU provided, update catalog image
            if ( $sku ) {
                // 1) Update wp_options catalog
                $catalog = dinoco_get_current_catalog();
                if ( isset($catalog[$sku]) ) {
                    $catalog[$sku]['img'] = $url;
                    update_option('dinoco_product_catalog', $catalog);
                }
                // 2) Update custom table
                if ( class_exists('DINOCO_Catalog') ) {
                    global $wpdb;
                    $wpdb->update($wpdb->prefix . 'dinoco_products', ['image_url' => $url], ['sku' => $sku]);
                }
                // 3) Update b2b_product ACF
                $b2b_posts = get_posts([
                    'post_type'      => 'b2b_product',
                    'posts_per_page' => 1,
                    'post_status'    => 'publish',
                    'meta_query'     => [['key' => 'product_sku', 'value' => $sku]],
                ]);
                if ( ! empty($b2b_posts) ) {
                    update_field('product_image', $url, $b2b_posts[0]->ID);
                    // Also set post thumbnail
                    set_post_thumbnail($b2b_posts[0]->ID, $attachment_id);
                }
            }

            return new WP_REST_Response([
                'success'       => true,
                'url'           => $url,
                'attachment_id' => $attachment_id,
                'message'       => 'Image uploaded successfully',
            ], 200);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- GET /dinoco-stock/v1/moto/brands --- V.38.0: Moto Catalog brands for Compatible Models
    register_rest_route('dinoco-stock/v1', '/moto/brands', [
        'methods'  => 'GET',
        'callback' => function() {
            if ( ! class_exists('DINOCO_MotoDB') ) return rest_ensure_response(['brands' => []]);
            $brands = DINOCO_MotoDB::get_brands();
            return rest_ensure_response(['brands' => $brands]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- GET /dinoco-stock/v1/moto/models?brand=honda --- V.38.0: Moto Catalog models by brand
    register_rest_route('dinoco-stock/v1', '/moto/models', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $req ) {
            $brand = sanitize_text_field( $req->get_param('brand') );
            if ( ! class_exists('DINOCO_MotoDB') || ! $brand ) return rest_ensure_response(['models' => []]);
            $models = DINOCO_MotoDB::get_models( $brand );
            return rest_ensure_response(['models' => $models]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

});

