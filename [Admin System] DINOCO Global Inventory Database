    // --- POST /dinoco-stock/v1/dip-stock/start ---
    register_rest_route('dinoco-stock/v1', '/dip-stock/start', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $dip_table   = $wpdb->prefix . 'dinoco_dip_stock';
            $items_table = $wpdb->prefix . 'dinoco_dip_stock_items';
            $prod_table  = $wpdb->prefix . 'dinoco_products';

            // ตรวจว่าไม่มี session ค้าง
            $existing = $wpdb->get_row( "SELECT id FROM {$dip_table} WHERE status = 'in_progress' LIMIT 1" );
            if ( $existing ) {
                return new WP_REST_Response([
                    'success'    => false,
                    'message'    => 'มีการนับสต็อกค้างอยู่ กรุณาปิด session เดิมก่อน',
                    'session_id' => (int) $existing->id,
                ], 409);
            }

            $now = current_time( 'mysql' );

            $wpdb->insert( $dip_table, [
                'session_date' => current_time( 'Y-m-d' ),
                'status'       => 'in_progress',
                'started_by'   => get_current_user_id(),
                'snapshot_at'  => $now,
                'created_at'   => $now,
            ] );
            $session_id = $wpdb->insert_id;

            if ( ! $session_id ) {
                return rest_ensure_response([ 'success' => false, 'message' => 'สร้าง session ล้มเหลว' ]);
            }

            // Snapshot: active products ที่ไม่ใช่ SET (แม่)
            // SET (แม่) ไม่เก็บ stock จริง — stock = MIN(children) → นับแค่ลูก
            $sku_relations = get_option('dinoco_sku_relations', []);
            $parent_skus = is_array($sku_relations) ? array_keys($sku_relations) : [];

            $products = $wpdb->get_results(
                "SELECT sku, stock_qty FROM {$prod_table} WHERE is_active = 1 ORDER BY sku"
            );

            // Filter: เอา parent SKU (SET) ออก
            if (!empty($parent_skus)) {
                $products = array_filter($products, function($p) use ($parent_skus) {
                    return !in_array($p->sku, $parent_skus);
                });
                $products = array_values($products);
            }

            if ( empty( $products ) ) {
                // ถ้าไม่มี products → ลบ session ที่สร้างไป
                $wpdb->delete( $dip_table, [ 'id' => $session_id ] );
                return rest_ensure_response([ 'success' => false, 'message' => 'ไม่พบสินค้าใน catalog (dinoco_products table อาจว่าง)' ]);
            }

            $total = 0;
            $errors = 0;
            foreach ( $products as $p ) {
                $inserted = $wpdb->insert( $items_table, [
                    'dip_stock_id' => $session_id,
                    'sku'          => $p->sku,
                    'expected_qty' => (int) $p->stock_qty,
                ] );
                if ( $inserted ) {
                    $total++;
                } else {
                    $errors++;
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( "[DipStock] ERROR insert item: sku={$p->sku} error={$wpdb->last_error}" );
                    }
                }
            }

            if ( $total === 0 ) {
                $wpdb->delete( $dip_table, [ 'id' => $session_id ] );
                return rest_ensure_response([ 'success' => false, 'message' => 'Insert items ล้มเหลว — ตรวจว่า dinoco_dip_stock_items table มีอยู่จริง. Error: ' . $wpdb->last_error ]);
            }

            $wpdb->update( $dip_table, [ 'total_skus' => $total ], [ 'id' => $session_id ] );

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[DipStock] Started session #{$session_id}, {$total} SKUs snapshot" );
            }

            return rest_ensure_response([
                'success'    => true,
                'session_id' => (int) $session_id,
                'total_skus' => $total,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- GET /dinoco-stock/v1/dip-stock/current ---
    register_rest_route('dinoco-stock/v1', '/dip-stock/current', [
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $dip_table   = $wpdb->prefix . 'dinoco_dip_stock';
            $items_table = $wpdb->prefix . 'dinoco_dip_stock_items';
            $prod_table  = $wpdb->prefix . 'dinoco_products';

            $session = $wpdb->get_row( "SELECT * FROM {$dip_table} WHERE status = 'in_progress' ORDER BY id DESC LIMIT 1", ARRAY_A );

            if ( ! $session ) {
                return rest_ensure_response([
                    'success' => true,
                    'active'  => false,
                    'session' => null,
                    'items'   => [],
                ]);
            }

            $items = $wpdb->get_results( $wpdb->prepare(
                "SELECT di.*, p.name, p.image_url
                 FROM {$items_table} di
                 LEFT JOIN {$prod_table} p ON di.sku = p.sku
                 WHERE di.dip_stock_id = %d
                 ORDER BY di.sku",
                $session['id']
            ), ARRAY_A );

            // Recount counted_skus from actual data
            $counted = 0;
            foreach ( $items as &$item ) {
                $item['expected_qty'] = (int) $item['expected_qty'];
                $item['actual_qty']   = $item['actual_qty'] !== null ? (int) $item['actual_qty'] : null;
                $item['variance']     = $item['variance'] !== null ? (int) $item['variance'] : null;
                $item['variance_pct'] = $item['variance_pct'] !== null ? (float) $item['variance_pct'] : null;
                $item['adjusted']     = (bool) $item['adjusted'];
                if ( $item['actual_qty'] !== null ) $counted++;
            }

            $session['total_skus']   = (int) $session['total_skus'];
            $session['counted_skus'] = $counted;
            $session['adjusted_skus'] = (int) $session['adjusted_skus'];

            return rest_ensure_response([
                'success' => true,
                'active'  => true,
                'session' => $session,
                'items'   => $items,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/dip-stock/count ---
    register_rest_route('dinoco-stock/v1', '/dip-stock/count', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $dip_table   = $wpdb->prefix . 'dinoco_dip_stock';
            $items_table = $wpdb->prefix . 'dinoco_dip_stock_items';

            $session_id = (int) $request->get_param('session_id');
            $items      = $request->get_param('items');

            if ( ! $session_id || ! is_array( $items ) || empty( $items ) ) {
                return new WP_REST_Response([ 'success' => false, 'message' => 'ข้อมูลไม่ครบ' ], 400);
            }

            // Validate session
            $session = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, status FROM {$dip_table} WHERE id = %d", $session_id
            ) );
            if ( ! $session || $session->status !== 'in_progress' ) {
                return new WP_REST_Response([ 'success' => false, 'message' => 'Session ไม่ถูกต้องหรือปิดแล้ว' ], 400);
            }

            $updated_count = 0;
            foreach ( $items as $item ) {
                $sku       = strtoupper( trim( sanitize_text_field( $item['sku'] ?? '' ) ) );
                $actual    = isset( $item['actual_qty'] ) ? max( 0, (int) $item['actual_qty'] ) : null;
                $note      = sanitize_text_field( $item['note'] ?? '' );

                if ( ! $sku || $actual === null ) continue;

                // Get expected_qty for variance calc
                $row = $wpdb->get_row( $wpdb->prepare(
                    "SELECT id, expected_qty FROM {$items_table} WHERE dip_stock_id = %d AND sku = %s",
                    $session_id, $sku
                ) );
                if ( ! $row ) continue;

                $expected = (int) $row->expected_qty;
                $variance = $actual - $expected;
                $variance_pct = $expected > 0
                    ? round( ( $variance / $expected ) * 100, 2 )
                    : ( $actual > 0 ? 100.00 : 0.00 );

                $wpdb->update( $items_table, [
                    'actual_qty'   => $actual,
                    'variance'     => $variance,
                    'variance_pct' => $variance_pct,
                    'note'         => $note,
                ], [ 'id' => $row->id ] );

                $updated_count++;
            }

            // Update session counted_skus
            $counted = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$items_table} WHERE dip_stock_id = %d AND actual_qty IS NOT NULL",
                $session_id
            ) );
            $total = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT total_skus FROM {$dip_table} WHERE id = %d", $session_id
            ) );
            $wpdb->update( $dip_table, [ 'counted_skus' => $counted ], [ 'id' => $session_id ] );

            return rest_ensure_response([
                'success'   => true,
                'updated'   => $updated_count,
                'counted'   => $counted,
                'remaining' => $total - $counted,
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

    // --- POST /dinoco-stock/v1/dip-stock/approve ---
    register_rest_route('dinoco-stock/v1', '/dip-stock/approve', [
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $request ) {
            global $wpdb;
            $dip_table   = $wpdb->prefix . 'dinoco_dip_stock';
            $items_table = $wpdb->prefix . 'dinoco_dip_stock_items';
            $prod_table  = $wpdb->prefix . 'dinoco_products';

            $session_id = (int) $request->get_param('session_id');
            $skus       = $request->get_param('skus');

            if ( ! $session_id ) {
                return new WP_REST_Response([ 'success' => false, 'message' => 'ไม่ได้ระบุ session_id' ], 400);
            }

            $session = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, status FROM {$dip_table} WHERE id = %d", $session_id
            ) );
            if ( ! $session || $session->status !== 'in_progress' ) {
                return new WP_REST_Response([ 'success' => false, 'message' => 'Session ไม่ถูกต้อง' ], 400);
            }

            $batch_id = 'DIP-' . $session_id;

            // ถ้า skus ว่าง = approve ทั้งหมดที่นับแล้ว+ยังไม่ adjusted
            $where_sku = '';
            if ( ! empty( $skus ) && is_array( $skus ) ) {
                $placeholders = implode( ',', array_fill( 0, count( $skus ), '%s' ) );
                $where_sku = $wpdb->prepare( " AND di.sku IN ({$placeholders})", ...$skus );
            }

            $items_to_approve = $wpdb->get_results( $wpdb->prepare(
                "SELECT di.id, di.sku, di.expected_qty, di.actual_qty
                 FROM {$items_table} di
                 WHERE di.dip_stock_id = %d AND di.actual_qty IS NOT NULL AND di.adjusted = 0 {$where_sku}",
                $session_id
            ) );

            $adjusted_count = 0;
            foreach ( $items_to_approve as $item ) {
                $expected = (int) $item->expected_qty;
                $actual   = (int) $item->actual_qty;
                $delta    = $actual - $expected;

                if ( $delta !== 0 ) {
                    // ใช้ stock_add/subtract ให้ได้ transaction log ถูกต้อง
                    if ( $delta > 0 ) {
                        if ( function_exists( 'dinoco_stock_add' ) ) {
                            dinoco_stock_add( $item->sku, abs( $delta ), 'dip_stock_adjust', 'dip_stock', $session_id, 'Dip Stock adjust', $batch_id );
                        }
                    } else {
                        if ( function_exists( 'dinoco_stock_subtract' ) ) {
                            dinoco_stock_subtract( $item->sku, abs( $delta ), 'dip_stock_adjust', 'dip_stock', $session_id, 'Dip Stock adjust', $batch_id );
                        }
                    }
                } elseif ( $delta === 0 ) {
                    // ไม่ต้อง adjust — แค่ mark เป็น adjusted
                }

                // Update last_dip_stock_date + last_dip_stock_qty
                $wpdb->update( $prod_table, [
                    'last_dip_stock_date' => current_time( 'Y-m-d' ),
                    'last_dip_stock_qty'  => $actual,
                ], [ 'sku' => $item->sku ] );

                // Mark adjusted
                $wpdb->update( $items_table, [ 'adjusted' => 1 ], [ 'id' => $item->id ] );
                $adjusted_count++;
            }

            // Update session
            $total_adjusted = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$items_table} WHERE dip_stock_id = %d AND adjusted = 1",
                $session_id
            ) );
            $total_items = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT total_skus FROM {$dip_table} WHERE id = %d", $session_id
            ) );
            $total_counted = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$items_table} WHERE dip_stock_id = %d AND actual_qty IS NOT NULL",
                $session_id
            ) );

            $update_data = [ 'adjusted_skus' => $total_adjusted ];

            // ถ้า approve ทั้งหมดแล้ว → completed
            if ( $total_adjusted >= $total_counted ) {
                $update_data['status']       = 'completed';
                $update_data['completed_at'] = current_time( 'mysql' );
            }

            $wpdb->update( $dip_table, $update_data, [ 'id' => $session_id ] );

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[DipStock] Approved {$adjusted_count} SKUs for session #{$session_id}" );
            }

            return rest_ensure_response([
                'success'        => true,
                'adjusted_count' => $adjusted_count,
                'completed'      => isset( $update_data['status'] ) && $update_data['status'] === 'completed',
            ]);
        },
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ]);

