        // V.38.2: Sequential cleanup helper — sends ONLY category:'' (no price reset)
        // Uses STOCK_API_EARLY / STOCK_NONCE_EARLY from local const (same jQuery.ready scope)
        function _cleanupSkuList(skuList) {
            var idx = 0;
            var failCount = 0;
            function next() {
                if (idx >= skuList.length) {
                    if (failCount > 0) console.warn('[Cleanup] Done with ' + failCount + ' failures out of ' + skuList.length);
                    return Promise.resolve();
                }
                var sku = skuList[idx++];
                catalogData[sku].product_category = '';
                catalogData[sku].category = '';
                return $.ajax({
                    url: STOCK_API_EARLY + '/product/pricing',
                    method: 'POST',
                    contentType: 'application/json',
                    headers: { 'X-WP-Nonce': STOCK_NONCE_EARLY },
                    data: JSON.stringify({ sku: sku, category: '' }),
                }).then(function(res) {
                    console.log('[Cleanup] OK', sku, res);
                    return next();
                }, function(err) {
                    failCount++;
                    console.error('[Cleanup] FAIL', sku, err.status, err.responseText);
                    return next(); // continue even if one fails
                });
            }
            return next();
        }

        // V.38.1: Bulk cleanup all invalid categories at once
        window.cleanupAllInvalid = function() {
            var affectedSkus = [];
            Object.keys(catalogData).forEach(function(sku) {
                var c = (catalogData[sku].product_category || catalogData[sku].category || '').trim();
                if (c && c !== '-' && !isValidCategory(c)) {
                    affectedSkus.push(sku);
                }
            });
            if (affectedSkus.length === 0) {
                Swal.fire({ icon: 'info', title: 'ไม่มีรายการต้องล้าง', timer: 1200, showConfirmButton: false });
                return;
            }
            Swal.fire({
                title: 'ล้างหมวดหมู่ไม่ถูกต้องทั้งหมด',
                text: 'จะล้าง ' + affectedSkus.length + ' สินค้า — ยืนยัน?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'ล้างทั้งหมด (' + affectedSkus.length + ')',
                confirmButtonColor: '#dc2626',
            }).then(function(r) {
                if (r.isConfirmed) {
                    Swal.fire({ title: 'กำลังล้าง...', text: '0 / ' + affectedSkus.length, allowOutsideClick: false, didOpen: function() { Swal.showLoading(); } });
                    var done = 0;
                    var total = affectedSkus.length;
                    // Process sequentially to avoid server overload
                    var idx = 0;
                    function nextCleanup() {
                        if (idx >= total) {
                            loadCategories('');
                            loadCatalog();
                            Swal.fire({ icon: 'success', title: 'ล้างเรียบร้อย ' + total + ' รายการ', timer: 2000, showConfirmButton: false });
                            return;
                        }
                        var sku = affectedSkus[idx++];
                        catalogData[sku].product_category = '';
                        catalogData[sku].category = '';
                        $.ajax({
                            url: STOCK_API_EARLY + '/product/pricing',
                            method: 'POST',
                            contentType: 'application/json',
                            headers: { 'X-WP-Nonce': STOCK_NONCE_EARLY },
                            data: JSON.stringify({ sku: sku, category: '' }),
                        }).always(function() {
                            done++;
                            Swal.update({ text: done + ' / ' + total });
                            nextCleanup();
                        });
                    }
                    nextCleanup();
                }
            });
        };

