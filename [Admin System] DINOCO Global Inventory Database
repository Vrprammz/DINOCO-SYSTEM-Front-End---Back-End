                };
                return map[type] || type;
            },

            /* Filter by status (called from pills and KPI cards) */
            filterByStatus: function(status) {
                this._status = status;
                this._page = 1;
                $('#stock-filter-tabs .stock-filter-pill').removeClass('active');
                $(`#stock-filter-tabs .stock-filter-pill[data-status="${status}"]`).addClass('active');
                this.loadStock();
            },

            /* Load stock list from API */
            loadStock: function(page) {
                const self = this;
                if (page) self._page = page;
                self._search = $('#stock-search').val() || '';

                $.ajax({
                    url: STOCK_API + '/stock/list',
                    method: 'GET',
                    data: { page: self._page, per_page: 20, status: self._status, search: self._search },
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        if (!res.success) return;
                        self._allData = res.data;

                        // Update KPIs
                        const c = res.counts || {};
                        $('#skpi-total').text((c.total || 0).toLocaleString());
                        $('#skpi-in-stock').text((c.in_stock || 0).toLocaleString());
                        $('#skpi-low-stock').text((c.low_stock || 0).toLocaleString());
                        $('#skpi-oos').text((c.out_of_stock || 0).toLocaleString());
                        $('#skpi-hold').text((c.hold || 0).toLocaleString());

                        // Render desktop table
                        if (res.data.length === 0) {
                            $('#stock-tbody').html('<tr><td colspan="8" class="text-center py-16 text-slate-400">ไม่พบสินค้า</td></tr>');
                            $('#stock-card-list').html('<div class="text-center py-10 text-slate-400">ไม่พบสินค้า</div>');
                        } else {
                            let thtml = '';
                            let chtml = '';
                            res.data.forEach(function(p) {
                                thtml += `<tr>
                                    <td>${self.thumb(p.image_url)}</td>
                                    <td class="font-mono text-xs font-bold">${p.sku}</td>
                                    <td class="text-xs font-bold text-slate-700" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${p.name}">${p.name}</td>
                                    <td class="text-center font-bold text-lg">${p.stock_qty.toLocaleString()}</td>
                                    <td>${self.badge(p.stock_display)}</td>
                                    <td class="text-center text-xs text-slate-500">${p.low_stock_threshold}</td>
                                    <td class="text-center text-xs text-slate-400">${self.fmtDate(p.stock_updated_at)}</td>
                                    <td class="text-center">
                                        <div class="flex gap-1 justify-center">
                                            <button class="bg-slate-100 hover:bg-slate-200 text-slate-600 w-8 h-8 rounded flex items-center justify-center text-xs" onclick="StockManager.openLog('${p.sku}')" title="ประวัติ"><i class="fa-solid fa-clock-rotate-left"></i></button>
                                            <button class="bg-blue-50 hover:bg-blue-100 text-blue-600 w-8 h-8 rounded flex items-center justify-center text-xs" onclick="StockManager.openAdjust('${p.sku}')" title="ปรับสต็อก"><i class="fa-solid fa-plus-minus"></i></button>
                                            <button class="bg-purple-50 hover:bg-purple-100 text-purple-600 w-8 h-8 rounded flex items-center justify-center text-xs" onclick="StockManager.toggleHold('${p.sku}', ${!p.manual_hold})" title="${p.manual_hold ? 'ปลด Hold' : 'Hold'}"><i class="fa-solid fa-${p.manual_hold ? 'lock-open' : 'lock'}"></i></button>
                                        </div>
                                    </td>
                                </tr>`;

                                // Mobile card
                                chtml += `<div class="stock-card-item">
                                    <div class="sc-header">
                                        ${p.image_url ? '<img src="'+p.image_url+'" class="sc-thumb" onerror="this.style.display=\'none\'">' : ''}
                                        <div class="sc-info">
                                            <div class="sc-name">${p.name}</div>
                                            <div class="sc-sku">${p.sku}</div>
                                        </div>
                                        ${self.badge(p.stock_display)}
                                    </div>
                                    <div class="sc-row"><span class="sc-label">สต็อก</span><span class="sc-val">${p.stock_qty.toLocaleString()} ชิ้น</span></div>
                                    <div class="sc-row"><span class="sc-label">Threshold</span><span class="sc-val">${p.low_stock_threshold}</span></div>
                                    <div class="sc-actions">
                                        <button class="btn btn-outline btn-sm flex-1" onclick="StockManager.openLog('${p.sku}')"><i class="fa-solid fa-clock-rotate-left"></i> ประวัติ</button>
                                        <button class="btn btn-primary btn-sm flex-1" onclick="StockManager.openAdjust('${p.sku}')"><i class="fa-solid fa-plus-minus"></i> ปรับ</button>
                                    </div>
                                </div>`;
                            });
                            $('#stock-tbody').html(thtml);
                            $('#stock-card-list').html(chtml);
                        }

                        // Pagination
                        self.renderPagination(res.pages, self._page);
                    },
                    error: function() {
                        $('#stock-tbody').html('<tr><td colspan="8" class="text-center py-10 text-red-400">โหลดข้อมูลล้มเหลว</td></tr>');
                    }
                });
            },

            /* Render pagination */
            renderPagination: function(totalPages, current) {
                if (totalPages <= 1) { $('#stock-pagination, #stock-pagination-mobile').html(''); return; }
                let html = `<button ${current<=1?'disabled':''} onclick="StockManager.loadStock(${current-1})">&laquo;</button>`;
                for (let i = 1; i <= totalPages; i++) {
                    if (totalPages > 7 && Math.abs(i - current) > 2 && i !== 1 && i !== totalPages) {
                        if (i === 2 || i === totalPages - 1) html += '<button disabled>...</button>';
                        continue;
                    }
                    html += `<button class="${i===current?'active':''}" onclick="StockManager.loadStock(${i})">${i}</button>`;
                }
                html += `<button ${current>=totalPages?'disabled':''} onclick="StockManager.loadStock(${current+1})">&raquo;</button>`;
                $('#stock-pagination, #stock-pagination-mobile').html(html);
            },

            /* Open Adjust Modal */
            openAdjust: function(sku) {
                const self = this;
                let product = null;
                if (sku) {
                    product = self._allData.find(p => p.sku === sku);
                }

                // Build product options from catalog
                let options = '<option value="">-- เลือกสินค้า --</option>';
                if (Object.keys(catalogData).length) {
                    Object.keys(catalogData).forEach(function(k) {
                        let sel = (k === sku) ? 'selected' : '';
                        options += `<option value="${k}" ${sel}>[${k}] ${catalogData[k].name}</option>`;
                    });
                } else if (self._allData.length) {
                    self._allData.forEach(function(p) {
                        let sel = (p.sku === sku) ? 'selected' : '';
                        options += `<option value="${p.sku}" ${sel}>[${p.sku}] ${p.name}</option>`;
                    });
                }

                const currentQty = product ? product.stock_qty : 0;
                const pName = product ? product.name : '';

                const html = `<div style="text-align:left;font-family:'Noto Sans Thai',sans-serif;">
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">สินค้า</label>
                        <select id="adj-sku" class="w-full border p-3 rounded-lg" onchange="StockManager._adjSkuChanged()">${options}</select>
                    </div>
                    <div id="adj-product-info" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px;margin-bottom:16px;${product?'':'display:none'}">
                        <div style="font-weight:700;color:#334155;font-size:0.9rem;" id="adj-pname">${pName}</div>
                        <div style="font-size:0.8rem;color:#64748b;">สต็อกปัจจุบัน: <b id="adj-current" style="color:#0f172a;font-size:1.1rem;">${currentQty}</b> ชิ้น</div>
                    </div>
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">ประเภท</label>
                        <div style="display:flex;gap:8px;">
                            <label style="flex:1;padding:10px;border:2px solid #22c55e;border-radius:8px;text-align:center;cursor:pointer;background:#dcfce7;font-weight:700;color:#166534;" id="adj-type-add" onclick="StockManager._adjSetType('add')"><i class="fa-solid fa-plus"></i> เพิ่มสต็อก</label>
                            <label style="flex:1;padding:10px;border:2px solid #e2e8f0;border-radius:8px;text-align:center;cursor:pointer;background:white;font-weight:600;color:#64748b;" id="adj-type-sub" onclick="StockManager._adjSetType('subtract')"><i class="fa-solid fa-minus"></i> ลดสต็อก</label>
                        </div>
                        <input type="hidden" id="adj-type" value="add">
                    </div>
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">จำนวน</label>
                        <input type="number" id="adj-qty" class="w-full border p-3 rounded-lg font-bold text-lg" value="1" min="1" oninput="StockManager._adjPreview()">
                    </div>
                    <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:12px;margin-bottom:16px;text-align:center;" id="adj-preview">
                        <span style="font-size:0.8rem;color:#3b82f6;">สต็อกหลังปรับ:</span>
                        <span style="font-size:1.5rem;font-weight:800;color:#1e40af;margin-left:8px;" id="adj-after">${currentQty + 1}</span>
                        <span style="font-size:0.8rem;color:#3b82f6;"> ชิ้น</span>
                    </div>
                    <div style="margin-bottom:8px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">เหตุผล <span style="color:#ef4444;">*</span></label>
                        <input type="text" id="adj-reason" class="w-full border p-3 rounded-lg" placeholder="เช่น รับของจากซัพพลายเออร์, ตรวจนับพบขาด...">
                    </div>
                </div>`;

                Swal.fire({
                    title: 'ปรับสต็อก',
                    html: html,
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-save"></i> บันทึก',
                    cancelButtonText: 'ยกเลิก',
                    confirmButtonColor: '#1e293b',
                    width: 500,
                    preConfirm: function() { return self.submitAdjust(); }
                });
            },

            _adjType: 'add',
            _adjSetType: function(type) {
                this._adjType = type;
                $('#adj-type').val(type);
                if (type === 'add') {
                    $('#adj-type-add').css({border:'2px solid #22c55e', background:'#dcfce7', color:'#166534'});
                    $('#adj-type-sub').css({border:'2px solid #e2e8f0', background:'white', color:'#64748b'});
                } else {
                    $('#adj-type-sub').css({border:'2px solid #ef4444', background:'#fee2e2', color:'#991b1b'});
                    $('#adj-type-add').css({border:'2px solid #e2e8f0', background:'white', color:'#64748b'});
                }
                this._adjPreview();
            },

            _adjPreview: function() {
                const cur = parseInt($('#adj-current').text()) || 0;
                const qty = parseInt($('#adj-qty').val()) || 0;
                const type = $('#adj-type').val();
                const after = type === 'add' ? cur + qty : Math.max(0, cur - qty);
                $('#adj-after').text(after);
                if (after <= 0) {
                    $('#adj-after').css('color', '#ef4444');
                } else {
                    $('#adj-after').css('color', '#1e40af');
                }
            },

            _adjSkuChanged: function() {
                const sku = $('#adj-sku').val();
                const p = this._allData.find(x => x.sku === sku);
                if (p) {
                    $('#adj-pname').text(p.name);
                    $('#adj-current').text(p.stock_qty);
                    $('#adj-product-info').show();
                } else if (sku && catalogData[sku]) {
                    $('#adj-pname').text(catalogData[sku].name);
                    $('#adj-current').text('0');
                    $('#adj-product-info').show();
                } else {
                    $('#adj-product-info').hide();
                }
                this._adjPreview();
            },

            /* Submit adjust */
            submitAdjust: function() {
                const self = this;
                const sku = $('#adj-sku').val();
                const type = $('#adj-type').val();
                const qty = parseInt($('#adj-qty').val()) || 0;
                const reason = $('#adj-reason').val().trim();

                if (!sku) { Swal.showValidationMessage('กรุณาเลือกสินค้า'); return false; }
                if (qty <= 0) { Swal.showValidationMessage('กรุณาระบุจำนวน'); return false; }
                if (!reason) { Swal.showValidationMessage('กรุณาระบุเหตุผล'); return false; }

                // Check if subtract to 0
                const cur = parseInt($('#adj-current').text()) || 0;
                if (type === 'subtract' && qty >= cur) {
                    // Continue — server will cap at 0
                }

                return $.ajax({
                    url: STOCK_API + '/stock/adjust',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ sku, type, qty, reason }),
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                }).then(function(res) {
                    if (res.success) {
                        Swal.fire({icon:'success', title:'บันทึกสำเร็จ', text:'สต็อกใหม่: ' + res.new_qty, timer:1500, showConfirmButton:false});
                        self.loadStock();
                    } else {
                        Swal.fire('Error', res.message || 'บันทึกล้มเหลว', 'error');
                    }
                    return res;
                }).catch(function(err) {
                    const msg = err.responseJSON ? err.responseJSON.message : 'เกิดข้อผิดพลาด';
                    Swal.showValidationMessage(msg);
                });
            },

            /* Open Transaction Log Modal */
            openLog: function(sku) {
                const self = this;
                Swal.fire({ title: 'โหลดประวัติ...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

                $.ajax({
                    url: STOCK_API + '/stock/transactions',
                    method: 'GET',
                    data: { sku: sku, per_page: 30 },
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        if (!res.success || !res.data.length) {
                            Swal.fire({ title: 'ประวัติสต็อก — ' + sku, html: '<div style="text-align:center;color:#94a3b8;padding:30px;">ยังไม่มีรายการ</div>', confirmButtonColor:'#1e293b', width:550 });
                            return;
                        }

                        let thtml = '<div class="txn-timeline" style="max-height:60vh;overflow-y:auto;padding-right:8px;">';
                        res.data.forEach(function(t) {
                            const isAdd = t.qty_change > 0;
                            const cls = isAdd ? 'txn-add' : (t.qty_change < 0 ? 'txn-sub' : 'txn-neutral');
                            const sign = isAdd ? '+' : '';
                            const color = isAdd ? '#22c55e' : '#ef4444';
                            thtml += `<div class="txn-item ${cls}">
                                <div style="display:flex;justify-content:space-between;align-items:center;">
                                    <span class="txn-type" style="color:${color}">${self.typeLabel(t.type)}</span>
                                    <span class="txn-change" style="color:${color}">${sign}${t.qty_change}</span>
                                </div>
                                <div style="display:flex;justify-content:space-between;margin-top:4px;">
                                    <span style="font-size:0.75rem;color:#94a3b8;">${t.qty_before} &rarr; ${t.qty_after}</span>
                                    <span class="txn-date">${self.fmtDate(t.created_at)}</span>
                                </div>
                                ${t.reason ? '<div class="txn-reason"><i class="fa-solid fa-quote-left" style="font-size:8px;margin-right:4px;"></i>' + t.reason + '</div>' : ''}
                                ${t.user_name ? '<div style="font-size:0.7rem;color:#94a3b8;margin-top:2px;"><i class="fa-solid fa-user" style="font-size:8px;margin-right:4px;"></i>' + t.user_name + '</div>' : ''}
                                ${t.reference_type ? '<div style="font-size:0.65rem;color:#cbd5e1;margin-top:2px;">Ref: ' + t.reference_type + (t.reference_id ? ' #'+t.reference_id : '') + '</div>' : ''}
                            </div>`;
                        });
                        thtml += '</div>';

                        Swal.fire({
                            title: '<i class="fa-solid fa-clock-rotate-left" style="margin-right:8px;"></i>ประวัติสต็อก — ' + sku,
                            html: thtml,
                            confirmButtonColor: '#1e293b',
                            confirmButtonText: 'ปิด',
                            width: 550,
                        });
                    }
                });
            },

            /* Open Settings Modal */
            openSettings: function() {
                const self = this;
                $.ajax({
                    url: STOCK_API + '/stock/settings',
                    method: 'GET',
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        const d = res.data || {};
                        const initBtn = d.initialized
                            ? '<div style="background:#dcfce7;border:1px solid #bbf7d0;border-radius:8px;padding:10px;text-align:center;color:#166534;font-weight:700;font-size:0.85rem;"><i class="fa-solid fa-check-circle"></i> ระบบสต็อกเปิดใช้งานแล้ว</div>'
                            : '<button class="btn btn-primary w-full" style="background:#dc2626;border-color:#dc2626;" onclick="StockManager.initialize()"><i class="fa-solid fa-power-off"></i> เปิดระบบสต็อก</button>';

                        const html = `<div style="text-align:left;font-family:'Noto Sans Thai',sans-serif;">
                            <div style="margin-bottom:14px;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">Default Low Stock Threshold</label>
                                <input type="number" id="stg-threshold" class="w-full border p-3 rounded-lg" value="${d.default_threshold || 10}">
                            </div>
                            <div style="margin-bottom:14px;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">Default Reorder Point</label>
                                <input type="number" id="stg-reorder" class="w-full border p-3 rounded-lg" value="${d.default_reorder || 5}">
                            </div>
                            <div style="margin-bottom:14px;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">Dip Stock Interval (วัน)</label>
                                <input type="number" id="stg-dip" class="w-full border p-3 rounded-lg" value="${d.dip_interval || 30}">
                            </div>
                            <div style="margin-bottom:14px;">
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                                    <input type="checkbox" id="stg-alert" ${d.alert_enabled ? 'checked' : ''} style="width:18px;height:18px;">
                                    <span style="font-size:0.85rem;font-weight:600;color:#334155;">เปิดแจ้งเตือน LINE (Low Stock Alert)</span>
                                </label>
                            </div>
                            <div style="border-top:1px solid #e2e8f0;padding-top:14px;margin-top:14px;">
                                ${initBtn}
                            </div>
                        </div>`;

                        Swal.fire({
                            title: '<i class="fa-solid fa-gear" style="margin-right:8px;"></i>ตั้งค่าระบบสต็อก',
                            html: html,
                            showCancelButton: true,
                            confirmButtonText: '<i class="fa-solid fa-save"></i> บันทึก',
                            cancelButtonText: 'ยกเลิก',
                            confirmButtonColor: '#1e293b',
                            width: 450,
                            preConfirm: function() { return self.saveSettings(); }
                        });
                    }
                });
            },

            /* Save settings */
            saveSettings: function() {
                const self = this;
                return $.ajax({
                    url: STOCK_API + '/stock/settings',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        default_threshold: parseInt($('#stg-threshold').val()) || 10,
                        default_reorder: parseInt($('#stg-reorder').val()) || 5,
                        dip_interval: parseInt($('#stg-dip').val()) || 30,
                        alert_enabled: $('#stg-alert').is(':checked'),
                    }),
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                }).then(function(res) {
                    if (res.success) {
                        Swal.fire({icon:'success', title:'บันทึกสำเร็จ', timer:1200, showConfirmButton:false});
                    }
                    return res;
                });
            },

            /* Toggle hold */
            toggleHold: function(sku, hold) {
                const self = this;
                if (hold) {
                    Swal.fire({
                        title: 'Hold สินค้า',
                        input: 'text',
                        inputLabel: 'เหตุผล (เช่น รอ QC, ของเสีย)',
                        inputPlaceholder: 'ระบุเหตุผล...',
                        showCancelButton: true,
                        confirmButtonText: '<i class="fa-solid fa-lock"></i> Hold',
                        confirmButtonColor: '#6b21a8',
                        cancelButtonText: 'ยกเลิก',
                        preConfirm: function(reason) {
                            return $.ajax({
                                url: STOCK_API + '/stock/hold',
                                method: 'POST',
                                contentType: 'application/json',
                                data: JSON.stringify({ sku: sku, hold: true, reason: reason || '' }),
                                beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                            }).then(function(r) {
                                self.loadStock();
                                return r;
                            });
                        }
                    });
                } else {
                    Swal.fire({
                        title: 'ปลด Hold?',
                        text: 'สินค้า ' + sku + ' จะกลับมาแสดงสถานะปกติ',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: '<i class="fa-solid fa-lock-open"></i> ปลด Hold',
                        confirmButtonColor: '#1e293b',
                        cancelButtonText: 'ยกเลิก',
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            $.ajax({
                                url: STOCK_API + '/stock/hold',
                                method: 'POST',
                                contentType: 'application/json',
                                data: JSON.stringify({ sku: sku, hold: false }),
                                beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                                success: function() {
                                    Swal.fire({icon:'success', title:'ปลด Hold สำเร็จ', timer:1000, showConfirmButton:false});
                                    self.loadStock();
                                }
                            });
                        }
                    });
                }
            },

            /* Initialize stock system */
            initialize: function() {
                const self = this;
                Swal.fire({
                    title: 'เปิดระบบสต็อก?',
                    text: 'ระบบจะเริ่มติดตามจำนวนสต็อกทุกสินค้า กรุณายืนยัน',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'ยืนยัน เปิดระบบ',
                    confirmButtonColor: '#dc2626',
                    cancelButtonText: 'ยกเลิก',
                }).then(function(r1) {
                    if (r1.isConfirmed) {
                        Swal.fire({
                            title: 'ยืนยันอีกครั้ง',
                            text: 'การเปิดระบบสต็อกจะเริ่มนับจำนวนสินค้าจาก 0 กรุณานับสต็อก (Dip Stock) ทันทีหลังเปิด',
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'ยืนยัน',
                            confirmButtonColor: '#dc2626',
                        }).then(function(r2) {
                            if (r2.isConfirmed) {
                                $.ajax({
                                    url: STOCK_API + '/stock/initialize',
                                    method: 'POST',
                                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                                    success: function() {
                                        Swal.fire({icon:'success', title:'เปิดระบบสต็อกสำเร็จ', text:'กรุณานับสต็อก (Dip Stock) เพื่อตั้งค่าจำนวนเริ่มต้น', confirmButtonColor:'#1e293b'});
                                    }
                                });
                            }
                        });
                    }
                });
            },

            /* Export CSV */
            exportCSV: function() {
                const self = this;
                // Fetch all data for export
                $.ajax({
                    url: STOCK_API + '/stock/list',
                    method: 'GET',
                    data: { page: 1, per_page: 9999, status: 'all' },
                    beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                    success: function(res) {
                        if (!res.success || !res.data.length) {
                            Swal.fire('No Data', 'ไม่มีข้อมูลสำหรับ export', 'info');
                            return;
                        }
                        let csv = '\uFEFFSKU,ชื่อสินค้า,สต็อก,สถานะ,Threshold,Reorder Point,Hold,อัพเดทล่าสุด\n';
                        res.data.forEach(function(p) {
                            const statusMap = { in_stock:'มีสินค้า', low_stock:'ใกล้หมด', out_of_stock:'หมดสต็อก', hold:'Hold' };
                            csv += `"${p.sku}","${p.name}",${p.stock_qty},"${statusMap[p.stock_display]||p.stock_display}",${p.low_stock_threshold},${p.reorder_point},${p.manual_hold?'Yes':'No'},"${p.stock_updated_at||''}"\n`;
                        });
                        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                        const link = document.createElement('a');
                        link.href = URL.createObjectURL(blob);
                        link.download = 'stock_export_' + new Date().toISOString().slice(0,10) + '.csv';
                        link.click();
                    }
                });
            }
        };

        loadAnalytics(); loadCatalogDataForSelect();

        // Auto-refresh: reload analytics every 30s when global toggle is ON
        // Managed by Admin Dashboard's setInterval override (blocks when OFF)
        setInterval(function(){
            if(document.getElementById('view-dash') && document.getElementById('view-dash').style.display !== 'none') {
                loadAnalytics();
            }
        }, 30000);
    });
    </script>
