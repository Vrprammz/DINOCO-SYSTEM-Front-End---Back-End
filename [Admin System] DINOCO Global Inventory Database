        /* =======================================================
         * StockManager additions — Valuation + Forecast (V.34.0 Phase 5)
         * ======================================================= */
        StockManager.loadValuation = function() {
            const self = this;
            $.ajax({
                url: STOCK_API + '/valuation', method: 'GET',
                beforeSend: function(xhr) { xhr.setRequestHeader('X-WP-Nonce', STOCK_NONCE); },
                success: function(res) {
                    if (!res.success) return;
                    const d = res.data;
                    $('#val-total-value').text(Number(d.total_value).toLocaleString('th-TH', {minimumFractionDigits:2}));
                    $('#val-summary').text(d.costed_skus + '/' + d.total_skus + ' SKU มีข้อมูลต้นทุน');
                    self._valuationData = d.items;

                    if (!d.items.length) {
                        $('#val-tbody').html('<tr><td colspan="5" class="text-center py-8 text-slate-400">ไม่มีข้อมูล</td></tr>');
                        return;
                    }

                    let html = '';
                    d.items.forEach(function(i) {
                        if (i.avg_cost <= 0 && i.stock_qty <= 0) return;
                        const costStr = i.avg_cost > 0 ? Number(i.avg_cost).toLocaleString('th-TH', {minimumFractionDigits:2}) : '<span style="color:#94a3b8">-</span>';
                        const valStr  = i.total_value > 0 ? Number(i.total_value).toLocaleString('th-TH', {minimumFractionDigits:2}) : '<span style="color:#94a3b8">-</span>';
                        html += '<tr><td class="font-mono text-xs font-bold">' + esc(i.sku) + '</td><td class="text-xs">' + esc(i.name) + '</td><td class="text-center font-bold">' + i.stock_qty.toLocaleString() + '</td><td class="text-center">' + costStr + '</td><td class="text-center font-bold">' + valStr + '</td></tr>';
                    });
                    $('#val-tbody').html(html);
                },
