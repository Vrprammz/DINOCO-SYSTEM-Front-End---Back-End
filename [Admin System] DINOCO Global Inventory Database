                    }
                });
            },

            /* Render pagination */
            renderPagination: function(totalPages, current) {
                if (totalPages <= 1) { $('#stock-pagination, #stock-pagination-mobile').html(''); return; }
                let html = `<button ${current<=1?'disabled':''} onclick="StockManager.loadStock(${current-1})">&laquo;</button>`;
                for (let i = 1; i <= totalPages; i++) {
                    if (totalPages > 7 && Math.abs(i - current) > 2 && i !== 1 && i !== totalPages) {
                        if (i === 2 || i === totalPages - 1) html += '<button disabled>...</button>';
                        continue;
                    }
                    html += `<button class="${i===current?'active':''}" onclick="StockManager.loadStock(${i})">${i}</button>`;
                }
                html += `<button ${current>=totalPages?'disabled':''} onclick="StockManager.loadStock(${current+1})">&raquo;</button>`;
                $('#stock-pagination, #stock-pagination-mobile').html(html);
            },

            /* Open Adjust Modal */
            openAdjust: function(sku) {
                const self = this;
                let product = null;
                if (sku) {
                    product = self._allData.find(p => p.sku === sku);
                }

                // Build product options from catalog
                let options = '<option value="">-- เลือกสินค้า --</option>';
