                                </div>
                                ${t.reason ? '<div class="txn-reason"><i class="fa-solid fa-quote-left" style="font-size:8px;margin-right:4px;"></i>' + esc(t.reason) + '</div>' : ''}
                                ${t.user_name ? '<div style="font-size:0.7rem;color:#94a3b8;margin-top:2px;"><i class="fa-solid fa-user" style="font-size:8px;margin-right:4px;"></i>' + esc(t.user_name) + '</div>' : ''}
                                ${t.reference_type ? '<div style="font-size:0.65rem;color:#cbd5e1;margin-top:2px;">Ref: ' + esc(t.reference_type) + (t.reference_id ? ' #'+t.reference_id : '') + '</div>' : ''}
                            </div>`;
                        });
                        thtml += '</div>';

                        Swal.fire({
                            title: '<i class="fa-solid fa-clock-rotate-left" style="margin-right:8px;"></i>ประวัติสต็อก — ' + sku,
                            html: thtml,
                            confirmButtonColor: '#1e293b',
                            confirmButtonText: 'ปิด',
                            width: 550,
                        });
                    }
                });
            },

