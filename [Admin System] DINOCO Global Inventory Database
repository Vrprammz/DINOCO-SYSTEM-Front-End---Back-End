                        <div style="font-size:0.8rem;color:#64748b;">สต็อกปัจจุบัน: <b id="adj-current" style="color:#0f172a;font-size:1.1rem;">${currentQty}</b> ชิ้น</div>
                        <div style="font-size:0.75rem;color:#64748b;margin-top:4px;">จอง: <b style="color:#f59e0b;" id="adj-reserved">${product ? (product.reserved_qty || 0) : 0}</b> ชิ้น | คงเหลือจริง: <b style="color:#22c55e;" id="adj-available">${product ? (product.available_qty || 0) : 0}</b> ชิ้น</div>
                    </div>
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">ประเภท</label>
                        <div style="display:flex;gap:8px;">
                            <label style="flex:1;padding:10px;border:2px solid #22c55e;border-radius:8px;text-align:center;cursor:pointer;background:#dcfce7;font-weight:700;color:#166534;" id="adj-type-add" onclick="StockManager._adjSetType('add')"><i class="fa-solid fa-plus"></i> เพิ่มสต็อก</label>
                            <label style="flex:1;padding:10px;border:2px solid #e2e8f0;border-radius:8px;text-align:center;cursor:pointer;background:white;font-weight:600;color:#64748b;" id="adj-type-sub" onclick="StockManager._adjSetType('subtract')"><i class="fa-solid fa-minus"></i> ลดสต็อก</label>
                        </div>
                        <input type="hidden" id="adj-type" value="add">
                    </div>
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">จำนวน</label>
                        <input type="number" id="adj-qty" class="w-full border p-3 rounded-lg font-bold text-lg" value="1" min="1" oninput="StockManager._adjPreview()">
                    </div>
                    <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:12px;margin-bottom:16px;text-align:center;" id="adj-preview">
                        <span style="font-size:0.8rem;color:#3b82f6;">สต็อกหลังปรับ:</span>
                        <span style="font-size:1.5rem;font-weight:800;color:#1e40af;margin-left:8px;" id="adj-after">${currentQty + 1}</span>
                        <span style="font-size:0.8rem;color:#3b82f6;"> ชิ้น</span>
                    </div>
                    <div style="margin-bottom:8px;">
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:4px;">เหตุผล <span style="color:#ef4444;">*</span></label>
                        <input type="text" id="adj-reason" class="w-full border p-3 rounded-lg" placeholder="เช่น รับของจากซัพพลายเออร์, ตรวจนับพบขาด...">
                    </div>
                </div>`;

                Swal.fire({
                    title: 'ปรับสต็อก',
                    html: html,
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-save"></i> บันทึก',
                    cancelButtonText: 'ยกเลิก',
                    confirmButtonColor: '#1e293b',
