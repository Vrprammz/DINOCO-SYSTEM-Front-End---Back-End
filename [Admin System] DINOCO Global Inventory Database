        /* --- GOD MODE v2 --- */
        (function() {
            var badge = document.getElementById('version-badge');
            if (!badge) return;
            var timer = null;
            var fired = false; // true once 2.5s elapsed — prevents mouseup from cancelling

            function activate() {
                fired = true;
                badge.classList.remove('god-holding');
                var pin = window.prompt('🔐 DINOCO GOD MODE\nกรอก PIN:');
                fired = false;
                if (pin === null) return;
                if (checkPin(pin)) {
                    document.body.classList.add('god-mode');
                    var tb = document.getElementById('god-mode-toolbar');
                    if (tb) { tb.classList.remove('hidden'); tb.style.display = 'flex'; }
                    var fi = document.getElementById('inv-filter');
                    if (fi) { fi.style.display = 'block'; fi.classList.add('active'); }
                    alert('✅ God Mode Active\nAdvanced Search + แก้ไขสินค้า Unlocked');
                } else {
                    alert('❌ PIN ไม่ถูกต้อง');
                }
            }

            function start(e) {
                e.preventDefault();
                fired = false;
                clearTimeout(timer);
                badge.classList.add('god-holding');
                timer = setTimeout(activate, 2500);
            }

            function cancel() {
                if (fired) return; // timer already fired — let activate() finish
                clearTimeout(timer);
                badge.classList.remove('god-holding');
            }

            badge.addEventListener('mousedown',   start);
            badge.addEventListener('touchstart',  start, { passive: false });
            document.addEventListener('mouseup',  cancel);
            badge.addEventListener('touchend',    cancel);
            badge.addEventListener('touchcancel', cancel);
            badge.addEventListener('contextmenu', function(e) { e.preventDefault(); });
        })();
        window.verifyPin = function() { let pin = $('#auth-pin').val(); if (checkPin(pin)) { $('#pin-lock-screen').fadeOut(200, function() { $('#generator-interface').fadeIn(); }); } else { Swal.fire('Error', 'PIN Incorrect', 'error'); $('#auth-pin').val(''); } };

        /* --- CATALOG & SET EDITOR (UNIFIED) — V.37.0: Full-screen, single-page layout --- */
        
        /* Image upload handler */
        window.handleProductImageUpload = function(input) {
            if (!input.files || !input.files[0]) return;
            var file = input.files[0];
            // Validate
            if (file.size > 5 * 1024 * 1024) { Swal.fire('Error', 'File too large (max 5MB)', 'error'); return; }
            var allowed = ['image/jpeg','image/png','image/webp','image/gif'];
            if (allowed.indexOf(file.type) === -1) { Swal.fire('Error', 'Invalid file type', 'error'); return; }
            
            // Preview immediately
            var reader = new FileReader();
            reader.onload = function(e) {
                $('#cat-img-tag').attr('src', e.target.result).show();
                $('#cat-img-placeholder').hide();
                $('.cedit-image-preview').addClass('has-image');
            };
            reader.readAsDataURL(file);
            
            // Upload to WP
            var formData = new FormData();
            formData.append('product_image', file);
            var sku = $('#cat-sku').val();
            if (sku) formData.append('sku', sku);
            
            $('#cat-img-upload-progress').show();
            $('#cat-img-progress-fill').css('width', '30%');
            $('#cat-img-progress-text').text('Uploading...');
            
            $.ajax({
                url: STOCK_API_EARLY + '/product/upload-image',
                method: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: { 'X-WP-Nonce': STOCK_NONCE_EARLY },
                xhr: function() {
                    var xhr = new window.XMLHttpRequest();
                    xhr.upload.addEventListener('progress', function(e) {
                        if (e.lengthComputable) {
                            var pct = Math.round((e.loaded / e.total) * 100);
                            $('#cat-img-progress-fill').css('width', pct + '%');
                        }
                    });
                    return xhr;
                },
                success: function(res) {
                    if (res.success && res.url) {
                        $('#cat-img').val(res.url);
                        $('#cat-img-tag').attr('src', res.url).show();
                        $('#cat-img-placeholder').hide();
                        $('.cedit-image-preview').addClass('has-image');
                        $('#cat-img-progress-text').text('Uploaded!');
                        setTimeout(function() { $('#cat-img-upload-progress').fadeOut(); }, 1500);
                    } else {
                        $('#cat-img-progress-text').text('Failed: ' + (res.message || 'Unknown error'));
                    }
                },
                error: function(err) {
                    $('#cat-img-progress-text').text('Upload failed');
                    Swal.fire('Upload Error', err.responseJSON ? err.responseJSON.message : 'Network error', 'error');
                }
            });
        };
        
        window.toggleImageUrlInput = function() {
            $('#cat-img-url-row').toggle();
            if ($('#cat-img-url-row').is(':visible')) $('#cat-img').focus();
        };
        
        window.previewImageUrl = function(url) {
