                            Swal.fire('No Data', 'ไม่มีข้อมูลสำหรับ export', 'info');
                            return;
                        }
                        let csv = '\uFEFFSKU,ชื่อสินค้า,สต็อก,สถานะ,Threshold,Reorder Point,Hold,อัพเดทล่าสุด\n';
                        res.data.forEach(function(p) {
                            const statusMap = { in_stock:'มีสินค้า', low_stock:'ใกล้หมด', out_of_stock:'หมดสต็อก', hold:'Hold' };
                            csv += `"${p.sku}","${p.name}",${p.stock_qty},"${statusMap[p.stock_display]||p.stock_display}",${p.low_stock_threshold},${p.reorder_point},${p.manual_hold?'Yes':'No'},"${p.stock_updated_at||''}"\n`;
