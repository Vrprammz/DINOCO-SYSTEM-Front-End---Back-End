            // ─────────────────────────────────────────────
            // V.3.3: Phase 4 — V.7.0 Classification Migration UI
            // ─────────────────────────────────────────────
            function renderPhase4State(state, flagsData) {
                var wrap = root.querySelector('[data-target="phase4-state-card"]');
                var mysqlWrap = root.querySelector('[data-target="phase4-mysql"]');
                if (!wrap) return;

                // MySQL capability
                var mysql = (state && state.mysql_check) || (flagsData && flagsData.mysql_check) || {};
                if (mysqlWrap && mysql.version) {
                    var active = !!mysql.check_constraints_active;
                    mysqlWrap.className = 'b2f-audit-phase4-mysql' + (active ? '' : ' warn');
                    mysqlWrap.innerHTML = (active
                        ? '✅ MySQL <code>' + esc(mysql.version) + '</code> — CHECK constraints <strong>enforced</strong> ที่ DB layer'
                        : '⚠️ MySQL <code>' + esc(mysql.version) + '</code> — CHECK constraints <strong>silently ignored</strong> (PHP validator เป็นกำแพงแทน)');
                }

                // Last run state
                var s = (state && state.state) || {};
                if (!s || !s.started_at) {
                    wrap.className = 'b2f-audit-phase4-state';
                    wrap.innerHTML = '<strong>📋 ยังไม่เคย run Phase 4 migration</strong> — กด Dry-Run ก่อนเพื่อ preview.';
                } else {
                    var done = !!s.finished_at && (!s.errors || !s.errors.length);
                    var inProgress = !!(state.in_progress);
                    wrap.className = 'b2f-audit-phase4-state ' + (done ? 'ok' : (inProgress ? 'warn' : ''));
                    var lines = [];
                    lines.push('<strong>' + (s.dry_run ? '🧪 Last Dry-Run' : (done ? '✅ Last Live Run' : '⚠️ Last Run')) + '</strong>' +
                               ' · started ' + esc(s.started_at) +
                               (s.finished_at ? ' · finished ' + esc(s.finished_at) : ' · in-progress') +
                               ' · ' + (s.elapsed_ms || 0) + 'ms');
                    lines.push('processed=' + (s.processed||0) + '/' + (s.total_rows||0) +
                               ' · set=' + (s.classified_set_assembled||0) +
                               ' · sub=' + (s.classified_sub_unit||0) +
                               ' · single=' + (s.classified_single||0) +
                               ' · cross=' + (s.classified_cross_factory||0) +
                               ' · hidden=' + (s.auto_hidden_count||0) +
                               ' · preserved=' + (s.confirmed_preserved||0));
                    if (s.errors && s.errors.length) {
                        lines.push('🔴 errors: ' + s.errors.length + ' — ' + esc(JSON.stringify(s.errors.slice(0,3))));
                    }
                    if (inProgress) lines.push('🔒 <strong>migration lock ACTIVE</strong> — dual-write deferred');
                    wrap.innerHTML = lines.join('<br>');
                }

                // Step A state badge
                var a = root.querySelector('[data-step="p4-dry"] [data-k="p4-dry-state"]');
                if (a) {
                    if (s && s.dry_run) {
                        a.className = 'b2f-audit-phase2-step-state done';
                        a.textContent = '✓ dry-run available';
                    } else {
                        a.className = 'b2f-audit-phase2-step-state pending';
                        a.textContent = 'ready';
                    }
                }
                // Step B state badge
                var b = root.querySelector('[data-step="p4-live"] [data-k="p4-live-state"]');
                if (b) {
                    if (s && s.finished_at && !s.dry_run && (!s.errors || !s.errors.length)) {
                        b.className = 'b2f-audit-phase2-step-state done';
                        b.textContent = '✓ migrated ' + (s.processed||0);
                    } else if (state && state.in_progress) {
                        b.className = 'b2f-audit-phase2-step-state pending';
                        b.textContent = 'running…';
                    } else {
                        b.className = 'b2f-audit-phase2-step-state pending';
                        b.textContent = 'pending';
                    }
                }

                // Flag rows (v11_explicit_mode / order_intent / ungroup_auto_hide)
                var flags = (flagsData && flagsData.flags) || {};
                // V.3.8 (Phase 1 audit BUG-H8): dropped `b2f_flag_ungroup_auto_hide` renderer + summary slot
                // — flag removed from whitelist (auto-hide driven by admin_display_mode column instead).
                renderPhase4FlagRow('b2f_flag_v11_explicit_mode', 'flag-v11-state', flags);
                renderPhase4FlagRow('b2f_flag_order_intent',      'flag-oi-state',  flags, !flags['b2f_flag_v11_explicit_mode'] || !flags['b2f_flag_v11_explicit_mode'].value ? 'blocked (v11 OFF)' : null);

                // Step C badge summary (2 flags now — V.3.8)
                var c = root.querySelector('[data-step="p4-flags"] [data-k="p4-flags-state"]');
                if (c) {
                    var onCount = 0;
                    ['b2f_flag_v11_explicit_mode','b2f_flag_order_intent'].forEach(function(k){
                        if (flags[k] && flags[k].value) onCount++;
                    });
                    c.className = 'b2f-audit-phase2-step-state ' + (onCount === 2 ? 'done' : (onCount > 0 ? 'pending' : ''));
                    c.textContent = onCount + '/2 ON';
                }
            }

            function renderPhase4FlagRow(flag, stateKey, allFlags, blockedReason) {
                var el = root.querySelector('[data-k="' + stateKey + '"]');
                if (!el) return;
                var f = allFlags[flag];
                var on = !!(f && f.value);
                if (blockedReason) {
                    el.className = 'b2f-audit-phase4-flag-state blocked';
                    el.textContent = '🔒 ' + blockedReason;
                } else {
                    el.className = 'b2f-audit-phase4-flag-state ' + (on ? 'on' : 'off');
                    el.textContent = on ? '✅ ENABLED' : '⬜ disabled';
                }
                // Disable enable-button if blocked or already ON; enable disable-button only when ON
                var row = root.querySelector('[data-flag="' + flag + '"]');
                if (!row) return;
                var btnEn = row.querySelector('[data-action="phase4-flag-toggle"][data-value="1"]');
                var btnDi = row.querySelector('[data-action="phase4-flag-toggle"][data-value="0"]');
                if (btnEn) btnEn.disabled = !!blockedReason || on;
                if (btnDi) btnDi.disabled = !on;
            }

