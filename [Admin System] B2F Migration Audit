            .b2f-audit-phase4-flag-state.on { background: #dcfce7; color: #166534; }
            .b2f-audit-phase4-flag-state.off { background: #f1f5f9; color: #64748b; }
            .b2f-audit-phase4-flag-state.blocked { background: #fee2e2; color: #991b1b; }

            /* V.3.12 Phase 3 Group H — sr-only utility (UX-H15) */
            .b2f-audit-root .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

            /* V.3.12 Phase 3 Group H — Mobile breakpoint (UX-H1) */
            @media (max-width: 768px) {
              .b2f-audit-root { padding: 0 12px; margin: 12px auto; }
              .b2f-audit-header { padding: 18px 16px; }
