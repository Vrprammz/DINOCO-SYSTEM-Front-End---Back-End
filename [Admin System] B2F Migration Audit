                resultEl.innerHTML = '';
                setStatus('[data-target="' + resKey + '-status"]',
                          '⏳ ' + (dryRun ? 'กำลัง dry-run…' : 'กำลัง run LIVE migration… (30-60 sec)'), false);

                api('phase4-migration', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ confirm: !dryRun, dry_run: !!dryRun })
                }).then(function(r){
                    btn.disabled = false;
                    if (r.ok && r.json && r.json.success) {
                        var d = r.json.data;
                        setStatus('[data-target="' + resKey + '-status"]',
                                  '✅ ' + (d.dry_run ? 'dry-run' : 'migration') + ' complete — ' +
                                  'processed ' + d.rows_updated + ', preserved ' + d.rows_skipped_confirmed +
                                  ', errors ' + ((d.errors||[]).length) + ' (' + d.elapsed_ms + 'ms)', false);
                        resultEl.classList.add('shown');
                        resultEl.innerHTML =
                            '<div><strong>Summary:</strong></div>' +
                            '<div>set_assembled: ' + d.classified_set_assembled + '</div>' +
                            '<div>sub_unit: ' + d.classified_sub_unit + '</div>' +
                            '<div>single: ' + d.classified_single + '</div>' +
                            '<div>cross_factory_assembly: ' + d.classified_cross_factory + '</div>' +
                            '<div>auto_hidden (as_parts): ' + d.auto_hidden_count + '</div>' +
                            '<div>confirmed preserved: ' + d.rows_skipped_confirmed + '</div>' +
                            ((d.errors||[]).length ? '<pre>' + esc(JSON.stringify(d.errors, null, 2)) + '</pre>' : '');

                        // Expose CSV link for dry-run
                        if (d.dry_run && d.csv_url) {
                            var link = root.querySelector('[data-target="p4-csv-link"]');
                            if (link) {
                                link.href = d.csv_url;
                                link.style.display = '';
                                link.textContent = '📥 Download Dry-Run CSV';
                            }
                        }
                        loadAll();
                    } else {
                        var code = (r.json && r.json.code) || '';
                        var msg = (r.json && r.json.message) ? r.json.message : ('HTTP ' + r.status);
                        setStatus('[data-target="' + resKey + '-status"]', '❌ ' + msg +
                                  (code === 'not_implemented' ? ' (Audit V.3.3 ยังไม่ sync)' : ''), true);
                        // V.3.4 FIX: surface error details + partial summary in result panel
                        var d = (r.json && r.json.data) || {};
                        var errs = d.errors || [];
                        if (errs.length || d.schema_alter) {
                            resultEl.classList.add('shown');
                            resultEl.innerHTML =
                                '<div><strong>❌ Details:</strong></div>' +
                                (d.total_rows !== undefined ? '<div>total_rows scanned: ' + d.total_rows + '</div>' : '') +
                                (d.rows_updated !== undefined ? '<div>rows_updated: ' + d.rows_updated + '</div>' : '') +
                                (errs.length ? '<div><strong>errors[' + errs.length + ']:</strong></div><pre>' + esc(JSON.stringify(errs, null, 2)) + '</pre>' : '') +
                                (d.schema_alter ? '<div><strong>schema_alter:</strong></div><pre>' + esc(JSON.stringify(d.schema_alter, null, 2)) + '</pre>' : '') +
                                (d.mysql_check ? '<div><strong>mysql_check:</strong></div><pre>' + esc(JSON.stringify(d.mysql_check, null, 2)) + '</pre>' : '');
                        }
                    }
                });
            }

            function doPhase4FlagToggle(btn) {
                var flag = btn.getAttribute('data-flag');
                var value = btn.getAttribute('data-value') === '1';
                if (!confirm('ยืนยัน ' + (value ? 'ENABLE' : 'DISABLE') + ' ' + flag + '?\n\n' +
                            'Dependency chain:\n' +
                            '  order_intent → ต้องเปิด v11_explicit_mode ก่อน\n' +
                            '  ungroup_auto_hide → ต้อง Phase 4 finished_at\n\n' +
                            'ถ้าปิด v11_explicit_mode ขณะที่ order_intent ยัง ON → backend จะ block')) return;
                btn.disabled = true;
                var statusKey = btn.closest('.b2f-audit-phase4-flagrow').querySelector('.b2f-audit-status').getAttribute('data-target');
                setStatus('[data-target="' + statusKey + '"]', '⏳ toggling…', false);
                api('feature-flags/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ flag_name: flag, value: value, confirm: true })
                }).then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        var d = r.json.data;
                        setStatus('[data-target="' + statusKey + '"]',
                                  '✅ ' + d.flag_name + ': ' + d.old_value + ' → ' + d.new_value, false);
                        loadAll();
                    } else {
                        var msg = (r.json && r.json.message) ? r.json.message : ('HTTP ' + r.status);
                        setStatus('[data-target="' + statusKey + '"]', '❌ ' + msg, true);
                        btn.disabled = false;
                    }
                });
            }

            // V.3.7: Sync Missing Intermediates (Coverage Rule cleanup)
            function doSyncIntermediates(btn, dryRun) {
                var label = dryRun ? 'Dry-Run' : 'Sync Missing Intermediates (LIVE)';
                if (!confirm((dryRun ? '🧪 ' : '⚡ ') + 'ยืนยัน ' + label + '?\n\n' +
                    (dryRun
                        ? 'จะสแกนเฉยๆ ไม่แก้ DB.\nExpected: หา sub-unit/SET ที่ลูกครบแต่ตัวเองยังไม่ register.'
                        : '⚡ LIVE SYNC\n  • จะ INSERT เข้า junction table จริง\n  • unit_cost=0 (LIFF auto-compute จากลูก)\n  • Idempotent — รันซ้ำจะไม่ซ้ำข้อมูล\n  • Respects blacklist + migration lock'))) return;
                btn.disabled = true;
                var resKey = 'sync-intermediates';
                var resultEl = root.querySelector('[data-target="' + resKey + '-result"]');
                if (resultEl) { resultEl.className = 'b2f-audit-phase2-backfill-result'; resultEl.innerHTML = ''; }
                setStatus('[data-target="' + resKey + '-status"]', '⏳ กำลัง ' + (dryRun ? 'scan…' : 'sync…'), false);
                api('sync-missing-intermediates', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ confirm: !dryRun, dry_run: !!dryRun })
                }).then(function(r){
                    btn.disabled = false;
                    if (r.ok && r.json && r.json.success) {
                        var d = r.json.data;
                        setStatus('[data-target="' + resKey + '-status"]',
                                  '✅ ' + (r.json.message || '') + ' (' + d.count + ' SKUs)', false);
                        if (resultEl) {
                            resultEl.classList.add('shown');
                            var html = '<div><strong>Summary by maker:</strong></div>';
                            var makerKeys = Object.keys(d.by_maker || {});
                            if (!makerKeys.length) {
                                html += '<div style="color:#16a34a;">✅ ไม่มี intermediate ที่ต้อง sync — junction สมบูรณ์</div>';
                            } else {
                                makerKeys.forEach(function(mid){
                                    html += '<div>maker_id=' + esc(mid) + ': ' + d.by_maker[mid].length + ' SKUs</div>';
                                    html += '<ul>' + d.by_maker[mid].slice(0, 30).map(function(s){ return '<li>' + esc(s) + '</li>'; }).join('') + '</ul>';
                                });
                            }
                            if ((d.errors||[]).length) {
                                html += '<div><strong>❌ errors:</strong></div><pre>' + esc(JSON.stringify(d.errors, null, 2)) + '</pre>';
                            }
                            resultEl.innerHTML = html;
                        }
                        loadAll();
                    } else {
                        var msg = (r.json && r.json.message) ? r.json.message : ('HTTP ' + r.status);
                        var code = (r.json && r.json.code) || '';
                        setStatus('[data-target="' + resKey + '-status"]', '❌ ' + msg +
                                  (code === 'not_implemented' ? ' (Snippet 1 V.7.1 ยังไม่ sync)' : ''), true);
                    }
                });
            }

            root.addEventListener('click', function(e){
                var t = e.target;
                if (t.matches('[data-action="refresh-all"]')) {
                    e.preventDefault();
                    loadAll();
                }
                if (t.matches('[data-action="dry-run"]')) {
                    e.preventDefault();
                    t.disabled = true;
                    var s = root.querySelector('[data-target="dry-run-status"]');
                    s.className = 'b2f-audit-status'; s.textContent = 'กำลังสร้าง CSV…';
                    var url = BASE + 'dry-run?_wpnonce=' + encodeURIComponent(NONCE);
                    var a = document.createElement('a');
                    a.href = url; a.style.display = 'none';
                    document.body.appendChild(a); a.click(); document.body.removeChild(a);
                    setTimeout(function(){
                        s.textContent = '✅ ส่ง request แล้ว (ตรวจ browser download)';
                        t.disabled = false;
                    }, 1500);
                }
                if (t.matches('[data-action="activate-schema"]')) { e.preventDefault(); doActivateSchema(t); }
                if (t.matches('[data-action="backfill"]')) { e.preventDefault(); doBackfill(t, t.getAttribute('data-dry') === '1'); }
                if (t.matches('[data-action="toggle-shadow"]')) { e.preventDefault(); doToggleShadow(t, t.getAttribute('data-value')); }
                if (t.matches('[data-action="toggle-junction-read"]')) { e.preventDefault(); doToggleJunctionRead(t, t.getAttribute('data-value')); }
                if (t.matches('[data-action="flag-toggle"]')) { e.preventDefault(); doFlagToggle(t); }
                if (t.matches('[data-action="reload-junction"]')) { e.preventDefault(); loadJunctionSnapshot(); }
                if (t.matches('[data-action="reload-obs"]')) { e.preventDefault(); loadObservations(); }
                // V.3.3: Phase 4 actions
                if (t.matches('[data-action="phase4-run"]')) { e.preventDefault(); doPhase4Run(t, t.getAttribute('data-dry') === '1'); }
                if (t.matches('[data-action="phase4-flag-toggle"]')) { e.preventDefault(); doPhase4FlagToggle(t); }
                // V.3.7: Sync Missing Intermediates (Coverage Rule cleanup)
                if (t.matches('[data-action="sync-intermediates"]')) { e.preventDefault(); doSyncIntermediates(t, t.getAttribute('data-dry') === '1'); }
            });

            root.addEventListener('change', function(e){
                var t = e.target;
                if (t.matches('[data-target="junction-maker"], [data-target="junction-status"]')) {
                    loadJunctionSnapshot();
                }
                if (t.matches('[data-target="obs-diff-only"]')) {
                    loadObservations();
                }
            });

            loadAll();
        })();
