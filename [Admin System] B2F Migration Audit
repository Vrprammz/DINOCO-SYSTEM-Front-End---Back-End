    // ─────────────────────────────────────────────
    // GET /junction-snapshot — V.2.0 read recent junction rows
    // Params: maker_id (optional), status (optional), limit (default 50)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/junction-snapshot', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'junction_snapshot' );
            if ( is_wp_error( $check ) ) return $check;

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง (Activate Schema ก่อน)', array( 'status' => 404 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';

            $maker_id = intval( $req->get_param( 'maker_id' ) );
            $status   = sanitize_text_field( (string) $req->get_param( 'status' ) );
            $limit    = max( 1, min( 500, intval( $req->get_param( 'limit' ) ) ?: 50 ) );

            $where  = array( '1=1' );
            $params = array();
            if ( $maker_id > 0 ) { $where[] = 'maker_id = %d'; $params[] = $maker_id; }
            if ( $status !== '' && in_array( $status, array('active','discontinued','pending'), true ) ) {
                $where[] = 'status = %s'; $params[] = $status;
            }
            $where_sql = implode( ' AND ', $where );

            $sql = "SELECT id, product_sku, maker_id, unit_cost, moq, lead_time_days, shipping_land, shipping_sea,
                           status, notes, legacy_cpt_id, created_by, updated_by, created_at, updated_at, deleted_at
                    FROM {$tbl}
                    WHERE {$where_sql}
                    ORDER BY updated_at DESC
                    LIMIT %d";
            $params[] = $limit;
            $rows = $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );
            if ( ! is_array( $rows ) ) $rows = array();

            // Enrich with maker names
            $maker_ids = array_unique( array_map( 'intval', array_column( $rows, 'maker_id' ) ) );
            $maker_names = array();
            foreach ( $maker_ids as $mid ) {
                if ( $mid ) $maker_names[ $mid ] = get_the_title( $mid );
            }
            foreach ( $rows as &$r ) {
                $r['maker_name'] = $maker_names[ intval( $r['maker_id'] ) ] ?? '';
            }
            unset( $r );

            // Summary counts
            $total      = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl}" ) );
            $active     = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE status='active' AND deleted_at IS NULL" ) );
            $discont    = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE status='discontinued'" ) );

            // CPT count for comparison
            $cpt_count = intval( $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->posts} WHERE post_type=%s AND post_status IN ('publish','draft')",
                'b2f_maker_product'
            ) ) );

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'rows'        => $rows,
                    'returned'    => count( $rows ),
                    'limit'       => $limit,
                    'summary'     => array(
                        'total'        => $total,
                        'active'       => $active,
                        'discontinued' => $discont,
                        'cpt_count'    => $cpt_count,
                        'diff_vs_cpt'  => $total - $cpt_count,
                    ),
                    'generated_at'=> current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /observations — V.2.0 read recent diff observations
    // Params: diff_only (bool), maker_id, limit (default 50)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/observations', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'observations' );
            if ( is_wp_error( $check ) ) return $check;

            if ( ! b2f_audit_observations_table_exists() ) {
                return new WP_Error( 'table_missing', 'observations table ยังไม่ถูกสร้าง (Activate Schema ก่อน)', array( 'status' => 404 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_maker_product_observations';

            $diff_only = filter_var( $req->get_param( 'diff_only' ), FILTER_VALIDATE_BOOLEAN );
            $maker_id  = intval( $req->get_param( 'maker_id' ) );
            $limit     = max( 1, min( 500, intval( $req->get_param( 'limit' ) ) ?: 50 ) );

            $where  = array( '1=1' );
            $params = array();
            if ( $diff_only )      { $where[] = 'diff_detected = 1'; }
            if ( $maker_id > 0 )   { $where[] = 'maker_id = %d'; $params[] = $maker_id; }
            $where_sql = implode( ' AND ', $where );

            $sql = "SELECT id, observed_at, source, sku, maker_id, field_name, cpt_value, junction_value, diff_detected
                    FROM {$tbl}
                    WHERE {$where_sql}
                    ORDER BY observed_at DESC
                    LIMIT %d";
            // V.3.1: $params always ends with $limit (and may include maker_id) →
            //        single prepare() call works either way (ternary was dead code).
            $params[] = $limit;
            $rows = $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );
            if ( ! is_array( $rows ) ) $rows = array();

            $maker_ids = array_unique( array_map( 'intval', array_column( $rows, 'maker_id' ) ) );
            $maker_names = array();
            foreach ( $maker_ids as $mid ) { if ( $mid ) $maker_names[ $mid ] = get_the_title( $mid ); }
            foreach ( $rows as &$r ) {
                $r['maker_name'] = $maker_names[ intval( $r['maker_id'] ) ] ?? '';
            }
            unset( $r );

            $total = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl}" ) );
            $diffs = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE diff_detected=1" ) );
            $last24 = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE observed_at > DATE_SUB(NOW(), INTERVAL 24 HOUR)" ) );

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'rows'        => $rows,
                    'returned'    => count( $rows ),
                    'limit'       => $limit,
                    'summary'     => array(
                        'total'       => $total,
                        'diffs'       => $diffs,
                        'last_24h'    => $last24,
                    ),
                    'generated_at'=> current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

    // ═══════════════════════════════════════════════════════════════════
    // V.3.2: Option F Hybrid Admin Control — 4 endpoints
    // ═══════════════════════════════════════════════════════════════════

    // ─────────────────────────────────────────────
    // GET /maker-products-with-source/{maker_id}
    //   — list junction rows for a maker with source = 'cpt' | 'auto'
    //   — source derived from legacy_cpt_id (NOT NULL > 0 → cpt, else auto)
    //   — includes is_blacklisted flag from b2f_autosync_blacklist
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/maker-products-with-source/(?P<maker_id>\d+)', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'mp_with_source' );
            if ( is_wp_error( $check ) ) return $check;

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง (Activate Schema ก่อน)', array( 'status' => 404 ) );
            }

            $maker_id = intval( $req->get_param( 'maker_id' ) );
            if ( ! $maker_id ) {
                return new WP_Error( 'bad_maker', 'invalid maker_id', array( 'status' => 400 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';

            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, product_sku, maker_id, unit_cost, moq, lead_time_days,
                        shipping_land, shipping_sea, status, notes, legacy_cpt_id,
                        created_by, updated_by, created_at, updated_at, deleted_at
                 FROM {$tbl}
                 WHERE maker_id = %d AND deleted_at IS NULL
                 ORDER BY (legacy_cpt_id IS NULL) ASC, product_sku ASC",
                $maker_id
            ), ARRAY_A );
            if ( ! is_array( $rows ) ) $rows = array();

            // Enrich with maker name + source + is_blacklisted
            $maker_name = get_the_title( $maker_id ) ?: '';
            $blacklist_for_maker = b2f_autosync_blacklist_get( $maker_id );

            $cpt_count = 0;
            $auto_count = 0;
            $blacklisted_count = 0;

            foreach ( $rows as &$r ) {
                $lid = intval( $r['legacy_cpt_id'] ?? 0 );
                $is_auto = ( $lid <= 0 );
                $r['source'] = $is_auto ? 'auto' : 'cpt';
                $r['is_auto_synced'] = $is_auto;
                $sku_u = strtoupper( (string) ( $r['product_sku'] ?? '' ) );
                $r['is_blacklisted'] = in_array( $sku_u, $blacklist_for_maker, true );
                $r['maker_name'] = $maker_name;
                if ( $is_auto ) $auto_count++; else $cpt_count++;
                if ( $r['is_blacklisted'] ) $blacklisted_count++;
            }
            unset( $r );

            return rest_ensure_response( array(
                'success' => true,
                'data'    => $rows,
                'summary' => array(
                    'total'       => count( $rows ),
                    'cpt'         => $cpt_count,
                    'auto'        => $auto_count,
                    'blacklisted' => $blacklisted_count,
                ),
                'maker'   => array(
                    'id'   => $maker_id,
                    'name' => $maker_name,
                ),
                'blacklist_for_maker' => $blacklist_for_maker,
                'generated_at' => current_time( 'mysql' ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /junction-bulk-delete
    //   Body: { maker_id, skus[], add_to_blacklist (bool), only_auto_synced (bool), confirm }
    //   - Soft-delete via UPDATE (status='discontinued', deleted_at=NOW())
    //   - Server-side guard: only_auto_synced=true → SQL AND (legacy_cpt_id IS NULL OR legacy_cpt_id=0)
    //   - If add_to_blacklist=true → add each SKU to b2f_autosync_blacklist[maker_id]
    //   Rate limit: 5/min/user
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/junction-bulk-delete', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_write,
        'callback'            => function ( $req ) {
            // Rate limit: 5/min/user (tighter than default 20/hour)
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_bulk_delete_' . $uid, 5, MINUTE_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง', array( 'status' => 404 ) );
            }

            $maker_id  = intval( $req->get_param( 'maker_id' ) );
            $skus_raw  = $req->get_param( 'skus' );
            $confirm   = filter_var( $req->get_param( 'confirm' ), FILTER_VALIDATE_BOOLEAN );
            $add_bl    = filter_var( $req->get_param( 'add_to_blacklist' ), FILTER_VALIDATE_BOOLEAN );
            $only_auto = ( $req->get_param( 'only_auto_synced' ) === null ) ? true : filter_var( $req->get_param( 'only_auto_synced' ), FILTER_VALIDATE_BOOLEAN );

            if ( ! $maker_id ) {
                return new WP_Error( 'bad_maker', 'maker_id required', array( 'status' => 400 ) );
            }
            if ( ! $confirm ) {
                return new WP_Error( 'not_confirmed', 'confirm=true required', array( 'status' => 400 ) );
            }
            if ( ! is_array( $skus_raw ) || empty( $skus_raw ) ) {
                return new WP_Error( 'no_skus', 'skus array required', array( 'status' => 400 ) );
            }
            if ( count( $skus_raw ) > 200 ) {
                return new WP_Error( 'too_many', 'max 200 SKUs per request', array( 'status' => 400 ) );
            }

            // Normalize SKUs: uppercase + dedup + drop empty
            $skus = array();
            foreach ( $skus_raw as $s ) {
                $u = strtoupper( trim( (string) $s ) );
                if ( $u !== '' && ! in_array( $u, $skus, true ) ) $skus[] = $u;
            }
            if ( empty( $skus ) ) {
                return new WP_Error( 'no_skus', 'no valid SKUs after normalization', array( 'status' => 400 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            $uid = get_current_user_id();
            $now = current_time( 'mysql' );

            // Count CPT rows that WOULD be targeted (for skipped_cpt_protected metric)
            $placeholders = implode( ',', array_fill( 0, count( $skus ), '%s' ) );
            $params_cpt = array_merge( array( $maker_id ), $skus );
            $cpt_would_match = 0;
            if ( $only_auto ) {
                $sql_cpt_probe = "SELECT COUNT(*) FROM {$tbl}
                                   WHERE maker_id = %d
                                     AND UPPER(product_sku) IN ({$placeholders})
                                     AND deleted_at IS NULL
                                     AND legacy_cpt_id IS NOT NULL
                                     AND legacy_cpt_id > 0";
                $cpt_would_match = intval( $wpdb->get_var( $wpdb->prepare( $sql_cpt_probe, $params_cpt ) ) );
            }

            // Build UPDATE
            $sql = "UPDATE {$tbl}
                       SET status = 'discontinued',
                           deleted_at = %s,
                           updated_by = %d,
                           updated_at = %s
                     WHERE maker_id = %d
                       AND UPPER(product_sku) IN ({$placeholders})
                       AND deleted_at IS NULL";
            if ( $only_auto ) {
                $sql .= " AND (legacy_cpt_id IS NULL OR legacy_cpt_id = 0)";
            }

            $params = array_merge( array( $now, $uid, $now, $maker_id ), $skus );
            $affected = $wpdb->query( $wpdb->prepare( $sql, $params ) );

            if ( $affected === false ) {
                return new WP_Error( 'db_error', 'UPDATE failed: ' . $wpdb->last_error, array( 'status' => 500 ) );
            }

            // Blacklist add (best-effort — don't fail bulk-delete if blacklist write errors)
            $blacklisted = 0;
            if ( $add_bl ) {
                foreach ( $skus as $sku_u ) {
                    if ( b2f_autosync_blacklist_add( $maker_id, $sku_u ) ) $blacklisted++;
                }
            }

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[B2F Autosync Bulk-Delete] uid=%d maker=%d skus=%d deleted=%d blacklisted=%d cpt_protected=%d',
                    $uid, $maker_id, count( $skus ), intval( $affected ), $blacklisted, $cpt_would_match
                ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'deleted'               => intval( $affected ),
                    'blacklisted'           => $blacklisted,
                    'skipped_cpt_protected' => $cpt_would_match,
                    'errors'                => array(),
                    'updated_blacklist_count' => count( b2f_autosync_blacklist_get( $maker_id ) ),
                ),
            ) );
        },
    ) );

