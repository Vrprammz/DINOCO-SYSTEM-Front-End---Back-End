    // ═══════════════════════════════════════════════════════════════════
    // V.3.3: V.7.0 PHASE 4 CLASSIFICATION ENDPOINTS (4)
    // ═══════════════════════════════════════════════════════════════════
    //
    // All 4 endpoints:
    //   - Permission: manage_options (LIFF admin JWT via b2f_verify_admin_token
    //     honored if helper exists — falls back to WP cap check)
    //   - Audit trail: observations table (source='classification_change') — written
    //     by Snippet 1 V.7.0 `b2f_junction_update_classification()` helper
    //   - Cache: central hook `do_action('b2f_junction_updated', $maker_id)`
    //   - Error codes: B2F_ERR_* registry in Snippet 1 V.7.0
    //
    // Helper: accept LIFF admin JWT (Snippet 2 V.10.x pattern). Admin manage_options
    // on WP session overrides (covers dashboard calls).

    $perm_admin_or_liff = function ( $req ) {
        // V.3.9 (S5): WP admin path → cap + X-WP-Nonce. LIFF JWT path uses X-B2F-Token
        // (orthogonal credential, not browser cookie-based → CSRF-immune by design).
        if ( current_user_can( 'manage_options' ) ) {
            $nonce = $req instanceof WP_REST_Request ? $req->get_header( 'X-WP-Nonce' ) : '';
            if ( empty( $nonce ) ) {
                // Fallback: if caller also supplied X-B2F-Token, let the LIFF branch try
                if ( function_exists( 'b2f_verify_admin_token' ) ) {
                    $verdict = b2f_verify_admin_token( $req );
                    if ( is_array( $verdict ) && ! empty( $verdict['is_admin'] ) ) return true;
                }
                return new WP_Error( 'rest_missing_nonce', 'Missing X-WP-Nonce header', array( 'status' => 403 ) );
            }
            if ( ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
                return new WP_Error( 'rest_invalid_nonce', 'Invalid or expired nonce', array( 'status' => 403 ) );
            }
            return true;
        }
        if ( function_exists( 'b2f_verify_admin_token' ) ) {
            $verdict = b2f_verify_admin_token( $req );
            if ( is_array( $verdict ) && ! empty( $verdict['is_admin'] ) ) return true;
        }
        return new WP_Error( 'rest_forbidden', 'Admin only', array( 'status' => 403 ) );
    };

    // ─────────────────────────────────────────────
    // POST /junction-update-classification
    //   Request: { maker_id, sku, production_mode, confirmation_status?,
    //              admin_display_mode?, reason?, expected_updated_at? }
    //   Delegates to Snippet 1 V.7.0 `b2f_junction_update_classification()`.
    //   Errors: 400 invalid_field/invalid_enum_value, 404 row_not_found,
    //           409 stale_write, 422 check_constraint_violation, 429 rate_limited
    //   Rate limit: 5/min/user
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/junction-update-classification', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_or_liff,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_classify_' . $uid, 5, MINUTE_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            if ( ! function_exists( 'b2f_junction_update_classification' ) ) {
                return new WP_Error(
                    'not_implemented',
                    'b2f_junction_update_classification() ไม่พบ — Snippet 1 V.7.0 ต้อง active',
                    array( 'status' => 501 )
                );
            }

            $maker_id  = intval( $req->get_param( 'maker_id' ) );
            $sku       = (string) $req->get_param( 'sku' );
            $prod      = $req->get_param( 'production_mode' );
            $conf      = $req->get_param( 'confirmation_status' );
            $display   = $req->get_param( 'admin_display_mode' );
            $expected  = $req->get_param( 'expected_updated_at' );

            if ( ! $maker_id || trim( $sku ) === '' ) {
                return new WP_Error( 'invalid_field', 'maker_id + sku required', array( 'status' => 400 ) );
            }

            // Optimistic concurrency (optional) — compare updated_at before delegating
            if ( $expected ) {
                global $wpdb;
                $tbl = $wpdb->prefix . 'dinoco_product_makers';
                $current = $wpdb->get_var( $wpdb->prepare(
                    "SELECT updated_at FROM {$tbl}
                     WHERE BINARY UPPER(product_sku) = UPPER(%s) AND maker_id = %d AND deleted_at IS NULL
                     LIMIT 1",
                    $sku, $maker_id
                ) );
                if ( $current === null ) {
                    return new WP_Error( 'row_not_found', 'junction row not found', array( 'status' => 404 ) );
                }
                // Compare as ISO strings (normalize both sides)
                $exp_ts = strtotime( (string) $expected );
                $cur_ts = strtotime( (string) $current );
                if ( $exp_ts && $cur_ts && abs( $cur_ts - $exp_ts ) > 1 ) {
                    return new WP_Error(
                        defined( 'B2F_ERR_STALE_JUNCTION_WRITE' ) ? B2F_ERR_STALE_JUNCTION_WRITE : 'stale_junction_write',
                        'row updated by another actor since ' . $expected . ' (current=' . $current . ')',
                        array( 'status' => 409 )
                    );
                }
            }

            $fields = array();
            if ( $prod !== null && $prod !== '' )        $fields['production_mode']     = (string) $prod;
            if ( $conf !== null && $conf !== '' )        $fields['confirmation_status'] = (string) $conf;
            if ( $display !== null && $display !== '' )  $fields['admin_display_mode']  = (string) $display;
            if ( empty( $fields ) ) {
                return new WP_Error( 'invalid_field', 'at least one classification field required', array( 'status' => 400 ) );
            }

            $uid = get_current_user_id();
            $res = b2f_junction_update_classification( $sku, $maker_id, $fields, $uid );
            if ( is_wp_error( $res ) ) return $res;

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[B2F Audit] classification update uid=%d maker=%d sku=%s fields=%s',
                    $uid, $maker_id, strtoupper( $sku ), implode( ',', array_keys( $fields ) )
                ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'row_id'          => $res['row_id'] ?? 0,
                    'old_values'      => $res['old'] ?? array(),
                    'new_values'      => $res['new'] ?? array(),
                    'observations_id' => $res['observations_id'] ?? 0,
                    'reason'          => sanitize_text_field( (string) $req->get_param( 'reason' ) ),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /junction-bulk-update-display
    //   Request: { maker_id, skus[] (max 200), admin_display_mode, confirm, idempotency_key? }
    //   Atomic: START TRANSACTION + per-SKU FOR UPDATE
    //   Errors: 400 bulk_limit_exceeded, 422 mixed_maker_error, 429 rate_limited
    //   Rate limit: 5/min/user
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/junction-bulk-update-display', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_or_liff,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_bulk_display_' . $uid, 5, MINUTE_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง', array( 'status' => 404 ) );
            }

            $maker_id  = intval( $req->get_param( 'maker_id' ) );
            $skus_raw  = $req->get_param( 'skus' );
            $display   = (string) $req->get_param( 'admin_display_mode' );
            $confirm   = filter_var( $req->get_param( 'confirm' ), FILTER_VALIDATE_BOOLEAN );
            $idem_key  = sanitize_text_field( (string) $req->get_param( 'idempotency_key' ) );

            if ( ! $maker_id ) {
                return new WP_Error( 'bad_maker', 'maker_id required', array( 'status' => 400 ) );
            }
            if ( ! $confirm ) {
                return new WP_Error( 'not_confirmed', 'confirm=true required', array( 'status' => 400 ) );
            }
            $enum_display = array( 'auto', 'as_set', 'as_parts' );
            if ( ! in_array( $display, $enum_display, true ) ) {
                return new WP_Error( 'invalid_enum_value',
                    'admin_display_mode must be one of: auto/as_set/as_parts',
                    array( 'status' => 400 ) );
            }
            if ( ! is_array( $skus_raw ) || empty( $skus_raw ) ) {
                return new WP_Error( 'no_skus', 'skus array required', array( 'status' => 400 ) );
            }
            if ( count( $skus_raw ) > 200 ) {
                return new WP_Error(
                    defined( 'B2F_ERR_BULK_LIMIT_EXCEEDED' ) ? B2F_ERR_BULK_LIMIT_EXCEEDED : 'bulk_limit_exceeded',
                    'max 200 SKUs per request',
                    array( 'status' => 400 )
                );
            }

            // Idempotency — transient 60s
            if ( $idem_key !== '' ) {
                $tkey = 'b2f_bulk_disp_' . get_current_user_id() . '_' . md5( $idem_key );
                $prev = get_transient( $tkey );
                if ( $prev !== false ) {
                    return rest_ensure_response( array(
                        'success' => true,
                        'data'    => $prev,
                        'cached'  => true,
                    ) );
                }
            }

            // Normalize SKUs
            $skus = array();
            foreach ( $skus_raw as $s ) {
                $u = strtoupper( trim( (string) $s ) );
                if ( $u !== '' && ! in_array( $u, $skus, true ) ) $skus[] = $u;
            }
            if ( empty( $skus ) ) {
                return new WP_Error( 'no_skus', 'no valid SKUs after normalization', array( 'status' => 400 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            $obs = $wpdb->prefix . 'dinoco_maker_product_observations';
            $uid = get_current_user_id();
            $now = current_time( 'mysql' );

            // Server-side PHP validator (MED-2 CHECK equivalent): single + as_parts blocked
            // We cannot know production_mode of each row yet — fetch first (inside transaction).

            $wpdb->query( 'START TRANSACTION' );
            try {
                $placeholders = implode( ',', array_fill( 0, count( $skus ), '%s' ) );
                $params = array_merge( array( $maker_id ), $skus );
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT id, product_sku, maker_id, production_mode, admin_display_mode, confirmation_status
                     FROM {$tbl}
                     WHERE maker_id = %d AND BINARY UPPER(product_sku) IN ({$placeholders}) AND deleted_at IS NULL
                     FOR UPDATE",
                    $params
                ), ARRAY_A );

                $seen_makers = array();
                $updated = 0;
                $skipped = array();
                $rows_by_sku = array();
                foreach ( (array) $rows as $row ) {
                    $rows_by_sku[ strtoupper( $row['product_sku'] ) ] = $row;
                    $seen_makers[ (int) $row['maker_id'] ] = true;
                }

                // Mixed maker guard (shouldn't happen since WHERE maker_id=%d, but defensive)
                if ( count( $seen_makers ) > 1 ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'mixed_maker_error',
                        'SKUs from multiple makers', array( 'status' => 422 ) );
                }

                foreach ( $skus as $sku_u ) {
                    if ( ! isset( $rows_by_sku[ $sku_u ] ) ) {
                        $skipped[] = array( 'sku' => $sku_u, 'reason' => 'not_found' );
                        continue;
                    }
                    $row = $rows_by_sku[ $sku_u ];
                    $old_display = (string) $row['admin_display_mode'];
                    if ( $old_display === $display ) {
                        $skipped[] = array( 'sku' => $sku_u, 'reason' => 'no_change' );
                        continue;
                    }
                    // CHECK equivalent — production_mode='single' + display='as_parts' → invalid
                    $prod = (string) $row['production_mode'];
                    if ( $prod === 'single' && $display === 'as_parts' ) {
                        $skipped[] = array( 'sku' => $sku_u, 'reason' => 'single_cannot_as_parts' );
                        continue;
                    }
                    $ok = $wpdb->update(
                        $tbl,
                        array(
                            'admin_display_mode' => $display,
                            'updated_by'         => $uid,
                            'updated_at'         => $now,
                        ),
                        array( 'id' => (int) $row['id'] ),
                        array( '%s', '%d', '%s' ),
                        array( '%d' )
                    );
                    if ( $ok === false ) {
                        throw new Exception( 'UPDATE sku=' . $sku_u . ' failed: ' . $wpdb->last_error );
                    }
                    $updated++;

                    // Audit
                    if ( b2f_audit_observations_table_exists() ) {
                        $wpdb->insert(
                            $obs,
                            array(
                                'observed_at'    => $now,
                                'source'         => 'classification_change',
                                'sku'            => $sku_u,
                                'maker_id'       => $maker_id,
                                'field_name'     => 'admin_display_mode',
                                'cpt_value'      => $old_display,
                                'junction_value' => $display,
                                'diff_detected'  => 1,
                            ),
                            array( '%s','%s','%s','%d','%s','%s','%s','%d' )
                        );
                    }
                }

                $wpdb->query( 'COMMIT' );
            } catch ( Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] bulk-update-display: ' . $e->getMessage() );
                }
                return new WP_Error( 'db_error', $e->getMessage(), array( 'status' => 500 ) );
            }

            // Fire central hook ONCE (not per SKU) — HIGH-4
            do_action( 'b2f_junction_updated', $maker_id );

            $payload = array(
                'updated'         => $updated,
                'skipped_invalid' => $skipped,
                'rows_affected'   => $updated,
                'admin_display_mode' => $display,
            );
            if ( isset( $idem_key ) && $idem_key !== '' ) {
                set_transient( 'b2f_bulk_disp_' . $uid . '_' . md5( $idem_key ), $payload, 60 );
            }

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[B2F Audit] bulk-update-display uid=%d maker=%d updated=%d skipped=%d display=%s',
                    $uid, $maker_id, $updated, count( $skipped ), $display
                ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => $payload,
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /junction-confirm-classification
    //   Request: { maker_id, skus[] }
    //   Idempotent — re-confirm returns 200 with already_confirmed[]
    //   MED-2 CHECK: (confirmation_status='auto_synced') OR (confirmed_by+at NOT NULL)
    //   Rate limit: 5/min/user
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/junction-confirm-classification', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_or_liff,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_confirm_' . $uid, 5, MINUTE_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง', array( 'status' => 404 ) );
            }

            $maker_id = intval( $req->get_param( 'maker_id' ) );
            $skus_raw = $req->get_param( 'skus' );

            if ( ! $maker_id ) {
                return new WP_Error( 'bad_maker', 'maker_id required', array( 'status' => 400 ) );
            }
            if ( ! is_array( $skus_raw ) || empty( $skus_raw ) ) {
                return new WP_Error( 'no_skus', 'skus array required', array( 'status' => 400 ) );
            }
            if ( count( $skus_raw ) > 200 ) {
                return new WP_Error(
                    defined( 'B2F_ERR_BULK_LIMIT_EXCEEDED' ) ? B2F_ERR_BULK_LIMIT_EXCEEDED : 'bulk_limit_exceeded',
                    'max 200 SKUs per request',
                    array( 'status' => 400 )
                );
            }

            $skus = array();
            foreach ( $skus_raw as $s ) {
                $u = strtoupper( trim( (string) $s ) );
                if ( $u !== '' && ! in_array( $u, $skus, true ) ) $skus[] = $u;
            }
            if ( empty( $skus ) ) {
                return new WP_Error( 'no_skus', 'no valid SKUs after normalization', array( 'status' => 400 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            $obs = $wpdb->prefix . 'dinoco_maker_product_observations';
            $uid = get_current_user_id();
            $now = current_time( 'mysql' );

            $already = array();
            $confirmed_count = 0;
            $skipped = array();

            $wpdb->query( 'START TRANSACTION' );
            try {
                $placeholders = implode( ',', array_fill( 0, count( $skus ), '%s' ) );
                $params = array_merge( array( $maker_id ), $skus );
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT id, product_sku, confirmation_status, confirmed_by, confirmed_at
                     FROM {$tbl}
                     WHERE maker_id = %d AND BINARY UPPER(product_sku) IN ({$placeholders}) AND deleted_at IS NULL
                     FOR UPDATE",
                    $params
                ), ARRAY_A );
                $rows_by_sku = array();
                foreach ( (array) $rows as $row ) $rows_by_sku[ strtoupper( $row['product_sku'] ) ] = $row;

                foreach ( $skus as $sku_u ) {
                    if ( ! isset( $rows_by_sku[ $sku_u ] ) ) {
                        $skipped[] = array( 'sku' => $sku_u, 'reason' => 'not_found' );
                        continue;
                    }
                    $row = $rows_by_sku[ $sku_u ];
                    if ( (string) $row['confirmation_status'] === 'confirmed' ) {
                        $already[] = $sku_u;
                        continue; // idempotent — already confirmed
                    }
                    $ok = $wpdb->update(
                        $tbl,
                        array(
                            'confirmation_status' => 'confirmed',
                            'confirmed_by'        => $uid,
                            'confirmed_at'        => $now,
                            'updated_by'          => $uid,
                            'updated_at'          => $now,
                        ),
                        array( 'id' => (int) $row['id'] ),
                        array( '%s', '%d', '%s', '%d', '%s' ),
                        array( '%d' )
                    );
                    if ( $ok === false ) {
                        throw new Exception( 'UPDATE confirm sku=' . $sku_u . ' failed: ' . $wpdb->last_error );
                    }
                    $confirmed_count++;

                    if ( b2f_audit_observations_table_exists() ) {
                        $wpdb->insert(
                            $obs,
                            array(
                                'observed_at'    => $now,
                                'source'         => 'classification_change',
                                'sku'            => $sku_u,
                                'maker_id'       => $maker_id,
                                'field_name'     => 'confirmation_status',
                                'cpt_value'      => (string) $row['confirmation_status'],
                                'junction_value' => 'confirmed',
                                'diff_detected'  => 1,
                            ),
                            array( '%s','%s','%s','%d','%s','%s','%s','%d' )
                        );
                    }
                }
                $wpdb->query( 'COMMIT' );
            } catch ( Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] confirm-classification: ' . $e->getMessage() );
                }
                return new WP_Error( 'db_error', $e->getMessage(), array( 'status' => 500 ) );
            }

            do_action( 'b2f_junction_updated', $maker_id );

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[B2F Audit] confirm uid=%d maker=%d confirmed=%d already=%d skipped=%d',
                    $uid, $maker_id, $confirmed_count, count( $already ), count( $skipped )
                ) );
            }

            return rest_ensure_response( array(
                'success'         => true,
                'confirmed_count' => $confirmed_count,
                'already_confirmed' => $already,
                'skipped'         => $skipped,
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // V.3.6: POST /purge-stale-prices
    //   User reported bug: LIFF แสดง DNCSETNX500X001 = ฿666 — stale bug value
    //   migrated from ACF era via Phase 2 backfill. Design intent: unit_cost = ราคาที่
    //   admin ตั้งใน Makers tab. Utility to zero-out junction.unit_cost = <sentinel>
    //   so admin MUST re-enter correct price via Makers tab (Snippet 5).
    //   Body: { sentinel_value (default 666), confirm, dry_run }
    //   Response: { updated_count, affected_rows[{id,sku,maker_id,old_cost}] }
    //   Guards: confirm=true required for live; rate limit 3/hr (destructive)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/purge-stale-prices', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_write,
        'callback'            => function ( $req ) {
            global $wpdb;
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_purge_prices_' . $uid, 3, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm  = filter_var( $req->get_param( 'confirm' ), FILTER_VALIDATE_BOOLEAN );
            $dry_run  = filter_var( $req->get_param( 'dry_run' ), FILTER_VALIDATE_BOOLEAN );
            $sentinel = floatval( $req->get_param( 'sentinel_value' ) );
            if ( $sentinel <= 0 ) $sentinel = 666;

            if ( ! $confirm && ! $dry_run ) {
                return new WP_Error( 'confirm_required', 'confirm=true or dry_run=1 required', array( 'status' => 400 ) );
            }

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง', array( 'status' => 404 ) );
            }

            $tbl = $wpdb->prefix . 'dinoco_product_makers';

            // Preview affected rows (always run — even for live, so caller sees what changed)
            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, product_sku, maker_id, unit_cost
                 FROM {$tbl}
                 WHERE unit_cost = %f AND deleted_at IS NULL
                 ORDER BY maker_id ASC, product_sku ASC",
                $sentinel
            ), ARRAY_A );
            if ( ! is_array( $rows ) ) $rows = array();

            $affected = array();
            foreach ( $rows as $r ) {
                $affected[] = array(
                    'id'       => intval( $r['id'] ),
                    'sku'      => (string) $r['product_sku'],
                    'maker_id' => intval( $r['maker_id'] ),
                    'old_cost' => floatval( $r['unit_cost'] ),
                );
            }

            $updated = 0;
            if ( ! $dry_run && ! empty( $rows ) ) {
                $uid_update = get_current_user_id();
                $now        = current_time( 'mysql' );
                $ok = $wpdb->query( $wpdb->prepare(
                    "UPDATE {$tbl}
                     SET unit_cost = 0,
                         updated_by = %d,
                         updated_at = %s
                     WHERE unit_cost = %f AND deleted_at IS NULL",
                    $uid_update, $now, $sentinel
                ) );
                $updated = ( $ok !== false ) ? intval( $ok ) : 0;

                // Fire cache invalidation (affected makers)
                $maker_ids = array_unique( array_map( function( $a ) { return $a['maker_id']; }, $affected ) );
                foreach ( $maker_ids as $mid ) {
                    do_action( 'b2f_junction_updated', $mid );
                }
            }

            return rest_ensure_response( array(
                'success' => true,
                'message' => $dry_run
                    ? sprintf( 'preview: %d row(s) would have unit_cost=%.2f cleared to 0', count( $affected ), $sentinel )
                    : sprintf( 'cleared %d row(s) with unit_cost=%.2f → admin must re-enter via Makers tab', $updated, $sentinel ),
                'data'    => array(
                    'sentinel_value'  => $sentinel,
                    'dry_run'         => $dry_run,
                    'updated_count'   => $updated,
                    'preview_count'   => count( $affected ),
                    'affected_rows'   => $affected,
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /phase4-migration
    //   Request: { confirm, dry_run, batch_size? }
    //   Rate limit: 5/HOUR (heavy op)
    //   Delegates to b2f_phase4_run_classification_migration($dry_run, $batch)
    //   dry_run=true → CSV emitted to wp-content/b2f-backups/dry-run-{ts}.csv
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/phase4-migration', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_or_liff,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_phase4_' . $uid, 5, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm = filter_var( $req->get_param( 'confirm' ), FILTER_VALIDATE_BOOLEAN );
            $dry_run = filter_var( $req->get_param( 'dry_run' ), FILTER_VALIDATE_BOOLEAN );
            $batch   = intval( $req->get_param( 'batch_size' ) );
            if ( $batch <= 0 ) $batch = 200;

            if ( ! $confirm && ! $dry_run ) {
                return new WP_Error( 'confirm_required', 'confirm=true or dry_run=1 required', array( 'status' => 400 ) );
            }

            if ( ! function_exists( 'b2f_phase4_run_classification_migration' ) ) {
                return new WP_Error(
                    'not_implemented',
                    'b2f_phase4_run_classification_migration() missing — Audit V.3.3 active?',
                    array( 'status' => 501 )
                );
            }

            // Guard — migration already in progress (CRIT-4 lock)
            if ( get_option( 'b2f_phase4_migration_in_progress' ) && ! $dry_run ) {
                return new WP_Error(
                    defined( 'B2F_ERR_MIGRATION_IN_PROGRESS' ) ? B2F_ERR_MIGRATION_IN_PROGRESS : 'migration_in_progress',
                    'Phase 4 migration already running — wait for lock to clear',
                    array( 'status' => 503 )
                );
            }

            // Schema V10 prerequisite — Phase 4 ALTERs require junction table
            if ( ! b2f_audit_is_schema_activated() ) {
                return new WP_Error(
                    'schema_not_ready',
                    'Activate Schema (Phase 2) required before Phase 4 migration',
                    array( 'status' => 409 )
                );
            }

            $state = b2f_phase4_run_classification_migration( $dry_run, $batch );

            // Build CSV URL (if present)
            $csv_url = null;
            if ( ! empty( $state['csv_path'] ) ) {
                // Map WP_CONTENT_DIR path → content_url
                $rel = str_replace( WP_CONTENT_DIR, '', (string) $state['csv_path'] );
                $csv_url = content_url( $rel );
            }

            $has_errors = ! empty( $state['errors'] );
            $msg = $has_errors
                ? ( 'migration reported ' . count( $state['errors'] ) . ' error(s): ' . implode( ' | ', array_slice( (array) $state['errors'], 0, 3 ) ) )
                : ( $state['dry_run']
                    ? 'dry-run complete'
                    : 'migration complete' );

            return rest_ensure_response( array(
                'success' => ! $has_errors,
                'message' => $msg,
                'data'    => array(
                    'ran_at'                  => $state['started_at'] ?? current_time( 'mysql' ),
                    'finished_at'             => $state['finished_at'] ?? null,
                    'total_rows'              => intval( $state['total_rows'] ?? 0 ),
                    'rows_updated'            => intval( $state['processed'] ?? 0 ),
                    'rows_skipped_confirmed'  => intval( $state['confirmed_preserved'] ?? 0 ),
                    'classified_set_assembled'=> intval( $state['classified_set_assembled'] ?? 0 ),
                    'classified_sub_unit'     => intval( $state['classified_sub_unit'] ?? 0 ),
                    'classified_single'       => intval( $state['classified_single'] ?? 0 ),
                    'classified_cross_factory'=> intval( $state['classified_cross_factory'] ?? 0 ),
                    'auto_hidden_count'       => intval( $state['auto_hidden_count'] ?? 0 ),
                    'orphans_added'           => 0,
                    'errors'                  => $state['errors'] ?? array(),
                    'elapsed_ms'              => $state['elapsed_ms'] ?? 0,
                    'dry_run'                 => (bool) ( $state['dry_run'] ?? false ),
                    'csv_url'                 => $csv_url,
                    'mysql_check'             => $state['mysql_check'] ?? array(),
                    'schema_alter'            => $state['schema_alter'] ?? array(),
                    'snapshot'                => $state['snapshot'] ?? array(),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /phase4-migration-state — read last run state
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/phase4-migration-state', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin_or_liff,
        'callback'            => function () {
            // V.3.11 (DB-H6): self-heal stale lock on admin dashboard open
            $stale_cleared = b2f_audit_phase4_stale_lock_autoclear( 3600 );
            $state = b2f_audit_get_phase4_state();
            $mysql = function_exists( 'b2f_audit_check_mysql_version' ) ? b2f_audit_check_mysql_version() : array();
            $in_progress = (bool) get_option( 'b2f_phase4_migration_in_progress' );
            $lock_age    = $in_progress ? ( time() - (int) get_option( 'b2f_phase4_migration_started_at', 0 ) ) : null;
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'state'           => $state,
                    'in_progress'     => $in_progress,
                    'lock_age_sec'    => $lock_age,
                    'stale_cleared'   => (bool) $stale_cleared,
                    'schema_version'  => (string) get_option( 'b2f_schema_version', '0' ),
                    'v11_activated'   => (bool) get_option( 'b2f_schema_v11_activated' ),
                    'mysql_check'     => $mysql,
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // V.3.7: POST /sync-missing-intermediates
    //   Bulk cleanup companion to Snippet 0.5 V.1.4 reactive auto-sync. Scans the
    //   entire junction table via b2f_detect_missing_intermediates() (Snippet 1 V.7.1)
    //   and inserts any SKU that SHOULD be registered per the coverage rule but isn't
    //   (all descendants covered for maker M but SKU unregistered).
    //   Body: { confirm, dry_run, maker_id? }
    //   Rate limit: 5/hr
    //   Guards: schema activated + helpers exist (501 not_implemented otherwise).
    //   Idempotent — 2nd run returns 0 new rows.
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/sync-missing-intermediates', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_write,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_sync_intermediates_' . $uid, 5, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm = filter_var( $req->get_param( 'confirm' ), FILTER_VALIDATE_BOOLEAN );
            $dry_run = filter_var( $req->get_param( 'dry_run' ), FILTER_VALIDATE_BOOLEAN );
            $maker_id_filter = intval( $req->get_param( 'maker_id' ) );
            if ( ! $confirm && ! $dry_run ) {
                return new WP_Error( 'confirm_required', 'confirm=true or dry_run=1 required', array( 'status' => 400 ) );
            }
            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง', array( 'status' => 404 ) );
            }
            if ( ! function_exists( 'b2f_detect_missing_intermediates' ) ) {
                return new WP_Error( 'not_implemented', 'Snippet 1 V.7.1 ยังไม่ sync — missing b2f_detect_missing_intermediates()', array( 'status' => 501 ) );
            }

            $missing = b2f_detect_missing_intermediates( $maker_id_filter > 0 ? $maker_id_filter : 0 );

            $inserted = array();
            $errors = array();
            if ( ! $dry_run && ! empty( $missing ) ) {
                foreach ( $missing as $m ) {
                    if ( function_exists( 'b2f_insert_auto_sync_junction_row' ) ) {
                        $ok = b2f_insert_auto_sync_junction_row( $m['sku'], intval( $m['maker_id'] ) );
                        if ( $ok ) {
                            $inserted[] = $m;
                        } else {
                            $errors[] = 'insert failed for maker=' . $m['maker_id'] . ' sku=' . $m['sku'];
                        }
                    }
                }
            }

            // Group by maker for cleaner UI output
            $by_maker = array();
            $target = $dry_run ? $missing : $inserted;
            foreach ( $target as $row ) {
                $mid = intval( $row['maker_id'] );
                if ( ! isset( $by_maker[ $mid ] ) ) $by_maker[ $mid ] = array();
                $by_maker[ $mid ][] = $row['sku'];
            }

            return rest_ensure_response( array(
                'success' => empty( $errors ),
                'message' => $dry_run
                    ? sprintf( 'preview: %d intermediate SKU(s) would be added across %d maker(s)', count( $missing ), count( $by_maker ) )
                    : sprintf( 'added %d intermediate SKU(s) across %d maker(s)', count( $inserted ), count( $by_maker ) ),
                'data' => array(
                    'dry_run'         => $dry_run,
                    'maker_id_filter' => $maker_id_filter > 0 ? $maker_id_filter : null,
                    'count'           => $dry_run ? count( $missing ) : count( $inserted ),
                    'by_maker'        => $by_maker,
                    'flat'            => $dry_run ? $missing : $inserted,
                    'errors'          => $errors,
                ),
            ) );
        },
    ) );

} );


