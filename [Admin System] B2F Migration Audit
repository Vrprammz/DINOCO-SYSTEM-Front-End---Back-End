/**
 * V.3.11 (DB-H6) — Phase 4 migration lock self-heal.
 * If the lock option is set but the companion timestamp is > $max_age seconds old,
 * assume the prior run crashed (PHP OOM / fatal / Apache kill) and clear both options.
 * Returns true if a stale lock was cleared, false otherwise.
 */
if ( ! function_exists( 'b2f_audit_phase4_stale_lock_autoclear' ) ) {
    function b2f_audit_phase4_stale_lock_autoclear( $max_age = 3600 ) {
        if ( ! get_option( 'b2f_phase4_migration_in_progress' ) ) {
            return false;
        }
        $started = (int) get_option( 'b2f_phase4_migration_started_at', 0 );
        // No timestamp (lock set by pre-V.3.11 code) — trust age 0 means unknown, clear
        // only if older than max_age relative to a safety ceiling (1hr default).
        if ( $started <= 0 ) {
            // Unknown age — do NOT auto-clear immediately; set timestamp NOW to start
            // the clock. Next call in max_age seconds will clear if still set.
            update_option( 'b2f_phase4_migration_started_at', time(), false );
            return false;
        }
        $age = time() - $started;
        if ( $age > (int) $max_age ) {
            delete_option( 'b2f_phase4_migration_in_progress' );
            delete_option( 'b2f_phase4_migration_started_at' );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[B2F Phase4] Stale lock auto-cleared (age=%ds > max=%ds)', $age, $max_age ) );
            } else {
                error_log( sprintf( '[B2F Phase4] Stale lock auto-cleared (age=%ds > max=%ds)', $age, $max_age ) );
            }
            return true;
        }
        return false;
    }
}

