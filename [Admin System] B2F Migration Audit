// ═══════════════════════════════════════════════════════════════════
// SECTION 2: REST API REGISTRATION
// ═══════════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {

    // V.3.9 (S5): split perm closure into read (GET) vs write (POST/DELETE).
    // READ — cap only. Safe GETs don't need CSRF (browser won't leak JSON cross-origin).
    $perm_admin_read = function () {
        return current_user_can( 'manage_options' );
    };

    // WRITE — cap + X-WP-Nonce `wp_rest` verify. Dashboard JS sends nonce already.
    // Missing/invalid nonce → 403 (CSRF defense).
    $perm_admin_write = function ( $request ) {
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'rest_forbidden', 'Admin only', array( 'status' => 403 ) );
        }
        $nonce = $request instanceof WP_REST_Request ? $request->get_header( 'X-WP-Nonce' ) : '';
        if ( empty( $nonce ) ) {
            return new WP_Error( 'rest_missing_nonce', 'Missing X-WP-Nonce header', array( 'status' => 403 ) );
        }
        if ( ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
            return new WP_Error( 'rest_invalid_nonce', 'Invalid or expired nonce', array( 'status' => 403 ) );
        }
        return true;
    };

    // Back-compat alias — existing GET routes below reference `$perm_admin` (read-only).
    // Closure copies PHP ≥5.4 safe via direct assignment — does not rewrap.
    $perm_admin = $perm_admin_read;

    // Rate limit wrapper — 20 req/hour per user per endpoint
    $rl = function( $endpoint ) {
        if ( ! function_exists( 'b2b_rate_limit' ) ) return true;
        $uid = get_current_user_id();
        $chk = b2b_rate_limit( 'b2f_audit_' . $endpoint . '_' . $uid, 20, HOUR_IN_SECONDS );
        return $chk;
    };

    // ─────────────────────────────────────────────
    // GET /drift — orphan SETs per maker
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/drift', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function () use ( $rl ) {
            $check = $rl( 'drift' );
            if ( is_wp_error( $check ) ) return $check;

            $orphans = b2f_audit_get_orphan_sets();
            // group by maker for UI
            $by_maker = array();
            foreach ( $orphans as $o ) {
                $mid = $o['maker_id'];
                if ( ! isset( $by_maker[ $mid ] ) ) {
                    $by_maker[ $mid ] = array(
                        'maker_id'    => $mid,
                        'maker_name'  => $o['maker_name'],
                        'orphan_count'=> 0,
                        'orphans'     => array(),
                    );
                }
                $by_maker[ $mid ]['orphans'][] = array(
                    'sku'    => $o['orphan_sku'],
                    'name'   => $o['orphan_name'],
                    'reason' => $o['reason'],
                );
                $by_maker[ $mid ]['orphan_count']++;
            }
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'total_orphans' => count( $orphans ),
                    'by_maker'      => array_values( $by_maker ),
                    'generated_at'  => current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /stale — stale mp_unit_cost records
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/stale', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'stale' );
            if ( is_wp_error( $check ) ) return $check;

            $days = intval( $req->get_param( 'days' ) );
