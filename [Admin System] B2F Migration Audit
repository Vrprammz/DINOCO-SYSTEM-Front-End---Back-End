    // ─────────────────────────────────────────────
    // POST /feature-flags/toggle — V.2.0 toggle whitelist flag
    // Params: { flag_name, value (bool), confirm (true required) }
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/feature-flags/toggle', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_write,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'flag_toggle' );
            if ( is_wp_error( $check ) ) return $check;

            $flag    = sanitize_key( (string) $req->get_param( 'flag_name' ) );
            $value   = filter_var( $req->get_param( 'value' ), FILTER_VALIDATE_BOOLEAN, FILTER_NULL_ON_FAILURE );
            $confirm = (bool) $req->get_param( 'confirm' );

            if ( ! $confirm ) {
                return new WP_Error( 'confirm_required', 'ต้องส่ง confirm=true เพื่อยืนยันการ toggle flag', array( 'status' => 400 ) );
            }
            if ( $value === null ) {
                return new WP_Error( 'invalid_value', 'value ต้องเป็น boolean (true/false)', array( 'status' => 400 ) );
            }
            if ( ! in_array( $flag, b2f_audit_allowed_flags(), true ) ) {
                return new WP_Error( 'invalid_flag', 'flag_name ไม่อยู่ใน allowed list', array( 'status' => 400 ) );
            }
            if ( ! in_array( $flag, b2f_audit_phase2_toggleable_flags(), true ) ) {
                return new WP_Error(
                    'flag_locked',
                    sprintf( 'Flag %s ยังล็อคอยู่ (Phase 2.5 หรือ Phase 3 เท่านั้น)', $flag ),
                    array( 'status' => 403 )
                );
            }

            // Guard: shadow_write ต้องมี schema + backfill เสร็จก่อน
            if ( $flag === 'b2f_flag_shadow_write' && $value === true ) {
                if ( ! b2f_audit_is_schema_activated() ) {
                    return new WP_Error(
                        'schema_not_ready',
                        'ต้อง Activate Schema ก่อนเปิด shadow_write',
                        array( 'status' => 409 )
                    );
                }
                $state = b2f_audit_get_backfill_state();
                if ( empty( $state['ran_at'] ) ) {
                    return new WP_Error(
                        'backfill_not_ready',
                        'ต้อง Run Backfill ก่อนเปิด shadow_write',
                        array( 'status' => 409 )
                    );
                }
            }

            // V.3.0: Guard — read_from_junction (Phase 3 cut-over) requires schema + backfill + shadow_write ON
            if ( $flag === 'b2f_flag_read_from_junction' && $value === true ) {
                if ( ! b2f_audit_is_schema_activated() ) {
                    return new WP_Error(
                        'schema_not_ready',
                        'ต้อง Activate Schema ก่อนเปิด read_from_junction',
                        array( 'status' => 409 )
                    );
                }
                $state = b2f_audit_get_backfill_state();
                if ( empty( $state['ran_at'] ) ) {
                    return new WP_Error(
                        'backfill_not_ready',
                        'ต้อง Run Backfill ก่อนเปิด read_from_junction',
                        array( 'status' => 409 )
                    );
                }
                if ( ! (bool) get_option( 'b2f_flag_shadow_write', false ) ) {
                    return new WP_Error(
                        'shadow_not_ready',
                        'ต้องเปิด shadow_write ก่อนเปิด read_from_junction (Phase 3 ต้อง dual-write stable)',
                        array( 'status' => 409 )
                    );
                }
            }

            // V.3.3: Dependency chain — V.7.0 Phase 4 flags
            //   order_intent requires v11_explicit_mode ON
            //   ungroup_auto_hide requires Phase 4 migration finished_at
            if ( $flag === 'b2f_flag_order_intent' && $value === true ) {
                if ( ! (bool) get_option( 'b2f_flag_v11_explicit_mode', false ) ) {
                    return new WP_Error(
                        'dependency_missing',
                        'ต้องเปิด v11_explicit_mode ก่อน (order_intent ใช้ production_mode จาก API)',
                        array( 'status' => 400 )
                    );
                }
            }
            // V.3.8 (Phase 1 audit BUG-H8): removed dependency check for `b2f_flag_ungroup_auto_hide`
            // — flag is no longer in the whitelist (see b2f_audit_allowed_flags).
            // Turning OFF v11_explicit_mode while order_intent still ON is unsafe — block
            if ( $flag === 'b2f_flag_v11_explicit_mode' && $value === false ) {
                if ( (bool) get_option( 'b2f_flag_order_intent', false ) ) {
                    return new WP_Error(
                        'dependent_flag_on',
                        'ปิด v11_explicit_mode ไม่ได้ — order_intent ยัง ON (ปิด order_intent ก่อน)',
                        array( 'status' => 400 )
                    );
                }
            }

            $old = (bool) get_option( $flag, false );
            $new = (bool) $value;
            update_option( $flag, $new, false );
            if ( function_exists( 'b2f_log_flag_change' ) ) {
                b2f_log_flag_change( $flag, $old, $new, get_current_user_id() );
            } elseif ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[B2F Audit] flag toggle %s: %s → %s by uid=%d', $flag, var_export($old,true), var_export($new,true), get_current_user_id() ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'flag_name' => $flag,
                    'old_value' => $old,
                    'new_value' => $new,
                    'changed_at'=> current_time( 'mysql' ),
                    'uid'       => get_current_user_id(),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /activate-schema — V.2.0 dbDelta canonical tables
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/activate-schema', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_write,
        'callback'            => function ( $req ) use ( $rl ) {
            // destructive action — stricter rate limit (5/hr)
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_activate_' . $uid, 5, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm = (bool) $req->get_param( 'confirm' );
            if ( ! $confirm ) {
                return new WP_Error( 'confirm_required', 'ต้องส่ง confirm=true เพื่อยืนยัน schema activation (destructive action)', array( 'status' => 400 ) );
            }

            if ( b2f_audit_is_schema_activated() ) {
                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'already_activated' => true,
                        'activated_at'      => get_option( 'b2f_schema_v10_activated' ),
                        'schema_version'    => get_option( 'b2f_schema_version', 'unknown' ),
                        'junction_exists'   => b2f_audit_junction_table_exists(),
                    ),
                ) );
            }

            if ( ! function_exists( 'b2f_audit_activate_schema_v10' ) ) {
                // database-expert ยังไม่ commit
                return new WP_Error(
                    'not_implemented',
                    'b2f_audit_activate_schema_v10() ยังไม่ deploy (รอ database-expert commit). ตรวจสอบว่า Phase 2 schema snippet sync แล้วหรือยัง',
                    array( 'status' => 501 )
                );
            }

            try {
                $started = microtime( true );
                $result  = b2f_audit_activate_schema_v10();
                $elapsed = round( ( microtime( true ) - $started ) * 1000, 1 );

                $junction_ok = b2f_audit_junction_table_exists();
                $obs_ok      = b2f_audit_observations_table_exists();

                if ( $junction_ok ) {
                    update_option( 'b2f_schema_v10_activated', current_time( 'mysql' ), false );
                    if ( ! get_option( 'b2f_schema_version' ) ) {
                        update_option( 'b2f_schema_version', '10.1', false );
                    }
                }

                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( sprintf(
                        '[B2F Audit] Schema activation: junction=%d obs=%d elapsed=%sms by uid=%d',
                        $junction_ok ? 1 : 0, $obs_ok ? 1 : 0, $elapsed, get_current_user_id()
                    ) );
                }

                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'junction_created'    => $junction_ok,
                        'observations_created'=> $obs_ok,
                        'schema_version'      => get_option( 'b2f_schema_version', '10.1' ),
                        'activated_at'        => get_option( 'b2f_schema_v10_activated' ),
                        'elapsed_ms'          => $elapsed,
                        'raw_result'          => is_array( $result ) ? $result : array(),
                    ),
                ) );
            } catch ( Throwable $e ) {
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] Schema activation error: ' . $e->getMessage() );
                }
                return new WP_Error( 'activation_failed', 'Schema activation failed: ' . $e->getMessage(), array( 'status' => 500 ) );
            }
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /backfill — V.2.0 run Phase 2 backfill script
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/backfill', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin_write,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_backfill_' . $uid, 5, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm = (bool) $req->get_param( 'confirm' );
            $dry_run = (bool) $req->get_param( 'dry_run' );
            if ( ! $confirm && ! $dry_run ) {
                return new WP_Error( 'confirm_required', 'ต้องส่ง confirm=true หรือ dry_run=1', array( 'status' => 400 ) );
            }

            if ( ! b2f_audit_is_schema_activated() ) {
                return new WP_Error( 'schema_not_ready', 'ต้อง Activate Schema ก่อน run Backfill', array( 'status' => 409 ) );
            }

            // V.2.1: inline backfill (ไม่ต้องใช้ script ภายนอก — WP Code Snippets ไม่ sync scripts/ folder)
            if ( ! function_exists( 'b2f_phase2_run_backfill' ) ) {
                return new WP_Error(
                    'not_implemented',
                    'b2f_phase2_run_backfill() ไม่พบ — audit snippet V.2.1 ต้อง activate',
                    array( 'status' => 501 )
                );
            }

            $started = microtime( true );
            $result = array();

            try {
                $result = b2f_phase2_run_backfill( $dry_run, get_current_user_id() );
                if ( ! is_array( $result ) ) $result = array();
            } catch ( Throwable $e ) {
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] Backfill error: ' . $e->getMessage() );
                }
                return new WP_Error( 'backfill_failed', 'Backfill failed: ' . $e->getMessage(), array( 'status' => 500 ) );
            }

            $elapsed = round( ( microtime( true ) - $started ) * 1000, 1 );

            // Normalize result keys
            $summary = array(
                'ran_at'        => current_time( 'mysql' ),
                'dry_run'       => $dry_run,
                'cpt_migrated'  => intval( $result['cpt_migrated'] ?? ( $result['migrated'] ?? 0 ) ),
                'orphans_added' => intval( $result['orphans_added'] ?? 0 ),
                'errors'        => is_array( $result['errors'] ?? null ) ? $result['errors'] : array(),
                'skipped'       => intval( $result['skipped'] ?? 0 ),
                'elapsed_ms'    => $elapsed,
                'uid'           => get_current_user_id(),
            );

            // Persist state only for real runs
            if ( ! $dry_run ) {
                b2f_audit_set_backfill_state( $summary );
            }

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[B2F Audit] Backfill %s: migrated=%d orphans=%d errors=%d elapsed=%sms by uid=%d',
                    $dry_run ? 'DRY' : 'LIVE',
                    $summary['cpt_migrated'], $summary['orphans_added'], count( $summary['errors'] ),
                    $elapsed, get_current_user_id()
                ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => $summary,
            ) );
        },
    ) );

