/**
 * ดึง orphan SETs per maker — SET ที่ maker "แตะ" (มี child/leaf ของตัว SET
 * registered ใน b2f_maker_product CPT) แต่ตัว SET เองไม่ถูก registered
 *
 * TODO (Phase 1 handoff): ถ้า database-expert commit scripts/b2f-audit-queries.sql
 * ให้ refactor ใช้ SQL helper ของเขาแทน inline logic นี้
 */
if ( ! function_exists( 'b2f_audit_get_orphan_sets' ) ) {
    /**
     * V.1.1 STRICT RULE: SET orphan = SET ที่ maker ไม่ได้ register
     *                    + children/descendants ทั้งหมดของ SET covered โดย maker (recursive)
     *
     * FIX: เดิมใช้ "≥1 descendant" → false positive ในกรณี multi-maker SET
     * (เช่น Full Set Case = racks จาก HTP + boxes จาก maker อื่น → HTP ไม่ควร register SET)
     *
     * Coverage rule:
     * - SKU covered ถ้า (a) registered ตรงๆ หรือ (b) เป็น SET + ทุก child covered recursive
     * - leaf ที่ไม่ registered และไม่มี children → NOT covered
     */
    function b2f_audit_get_orphan_sets() {
        global $wpdb;

        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) || empty( $relations ) ) return array();

        // Normalize relations: UPPERCASE keys + children
        $rel_upper = array();
        foreach ( $relations as $parent => $children ) {
            if ( ! is_array( $children ) ) continue;
            $p_u = strtoupper( (string) $parent );
            $rel_upper[ $p_u ] = array_map( function( $c ) { return strtoupper( (string) $c ); }, $children );
        }

        // ดึง maker products ทั้งหมด
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.ID AS post_id,
                    mk.meta_value AS maker_id,
                    sk.meta_value AS sku
             FROM {$wpdb->posts} p
             LEFT JOIN {$wpdb->postmeta} mk ON mk.post_id = p.ID AND mk.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} sk ON sk.post_id = p.ID AND sk.meta_key = %s
             WHERE p.post_type = %s AND p.post_status IN ('publish','draft')",
            'mp_maker_id', 'mp_product_sku', 'b2f_maker_product'
        ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        // จัดกลุ่ม sku per maker
        $maker_skus = array();
        foreach ( $rows as $r ) {
            $mid = intval( $r['maker_id'] );
            $sku = strtoupper( trim( (string) $r['sku'] ) );
            if ( ! $mid || ! $sku ) continue;
            if ( ! isset( $maker_skus[ $mid ] ) ) $maker_skus[ $mid ] = array();
            $maker_skus[ $mid ][ $sku ] = true;
        }

        // Recursive coverage check — value-copy $visited per branch (V.7.1 pattern)
        $is_sku_covered = function( $sku_u, $maker_sku_set, $visited = array() ) use ( &$is_sku_covered, $rel_upper ) {
            if ( isset( $visited[ $sku_u ] ) ) return false; // circular guard
            $visited[ $sku_u ] = true;

            // (a) registered ตรงๆ → covered
            if ( isset( $maker_sku_set[ $sku_u ] ) ) return true;

            // (b) เป็น SET? ถ้ามี children ต้อง covered ทุกตัว
            if ( ! isset( $rel_upper[ $sku_u ] ) || empty( $rel_upper[ $sku_u ] ) ) {
                return false; // leaf + not registered → NOT covered
            }

            foreach ( $rel_upper[ $sku_u ] as $child_u ) {
                if ( ! $is_sku_covered( $child_u, $maker_sku_set, $visited ) ) {
                    return false; // any child not covered → SET not covered
                }
            }
            return true; // all children covered
        };

        // Find top-level SETs
        $all_children = array();
        foreach ( $rel_upper as $parent_u => $children ) {
            foreach ( $children as $c ) $all_children[ $c ] = true;
        }
        $top_level_sets = array();
        foreach ( $rel_upper as $parent_u => $_ ) {
            if ( ! isset( $all_children[ $parent_u ] ) ) $top_level_sets[] = $parent_u;
        }

        // Check each top-level SET per maker
        $orphans = array();
        foreach ( $maker_skus as $mid => $sku_set ) {
            foreach ( $top_level_sets as $set_sku ) {
                // skip ถ้า SET registered แล้ว
                if ( isset( $sku_set[ $set_sku ] ) ) continue;

                // STRICT: ตรวจ children ของ SET ว่า covered ครบไหม
                $all_children_covered = true;
                foreach ( $rel_upper[ $set_sku ] as $child_u ) {
                    if ( ! $is_sku_covered( $child_u, $sku_set ) ) {
                        $all_children_covered = false;
                        break;
                    }
                }

                if ( $all_children_covered ) {
                    // V.1.1: collect all leaves (grandchildren) recursively
                    $collect_leaves = function( $sku_u, $visited = array() ) use ( &$collect_leaves, $rel_upper ) {
                        if ( isset( $visited[ $sku_u ] ) ) return array();
                        $visited[ $sku_u ] = true;
                        if ( empty( $rel_upper[ $sku_u ] ) ) return array( $sku_u ); // leaf
                        $leaves = array();
                        foreach ( $rel_upper[ $sku_u ] as $child_u ) {
                            $leaves = array_merge( $leaves, $collect_leaves( $child_u, $visited ) );
                        }
                        return array_values( array_unique( $leaves ) );
                    };
                    $leaves = $collect_leaves( $set_sku );

                    // V.1.1: classify each descendant: registered | covered_by_intermediate
                    $children_detail = array();
                    foreach ( $rel_upper[ $set_sku ] as $child_u ) {
                        $leaves_of_child = $collect_leaves( $child_u );
                        $child_registered = isset( $sku_set[ $child_u ] );
                        $children_detail[] = array(
                            'sku'        => $child_u,
                            'name'       => b2f_audit_catalog_name( $child_u ),
                            'registered' => $child_registered,
                            'leaves'     => $leaves_of_child,
                            'is_set'     => ! empty( $rel_upper[ $child_u ] ),
                        );
                    }

                    // V.1.2: fetch compatible_models + category
                    $meta = function_exists( 'b2f_audit_catalog_meta' ) ? b2f_audit_catalog_meta( $set_sku ) : array( 'models' => '', 'category' => '' );

                    $orphans[] = array(
                        'maker_id'          => $mid,
                        'maker_name'        => get_the_title( $mid ),
                        'orphan_sku'        => $set_sku,
                        'orphan_name'       => b2f_audit_catalog_name( $set_sku ),
                        'compatible_models' => $meta['models'],
                        'category'          => $meta['category'],
                        'reason'            => 'Maker has ALL descendants registered — SET ควร sync',
                        'leaves'            => $leaves,
                        'leaves_count'      => count( $leaves ),
                        'children'          => $children_detail,
                        'children_count'    => count( $children_detail ),
                    );
                }
            }
        }
        return $orphans;
    }
}

/**
 * หา stale mp_unit_cost — records ที่ไม่ถูก update นานเกิน threshold (90 วัน default)
 * หรือ unit_cost ≤ 0 ทั้งที่ product อยู่ในระบบ
 */
if ( ! function_exists( 'b2f_audit_get_stale_records' ) ) {
    function b2f_audit_get_stale_records( $days = 90 ) {
        global $wpdb;
        $threshold = gmdate( 'Y-m-d H:i:s', time() - ( $days * DAY_IN_SECONDS ) );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.ID AS post_id,
                    p.post_modified_gmt,
                    mk.meta_value AS maker_id,
                    sk.meta_value AS sku,
                    uc.meta_value AS unit_cost,
                    st.meta_value AS status
             FROM {$wpdb->posts} p
             LEFT JOIN {$wpdb->postmeta} mk ON mk.post_id = p.ID AND mk.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} sk ON sk.post_id = p.ID AND sk.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} uc ON uc.post_id = p.ID AND uc.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} st ON st.post_id = p.ID AND st.meta_key = %s
             WHERE p.post_type = %s
               AND p.post_status IN ('publish','draft')
               AND ( p.post_modified_gmt < %s OR CAST(uc.meta_value AS DECIMAL(12,2)) <= 0 )
             ORDER BY p.post_modified_gmt ASC",
            'mp_maker_id', 'mp_product_sku', 'mp_unit_cost', 'mp_status',
            'b2f_maker_product', $threshold
        ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        $out = array();
        foreach ( $rows as $r ) {
            $unit = floatval( $r['unit_cost'] );
            $out[] = array(
                'post_id'      => intval( $r['post_id'] ),
                'maker_id'     => intval( $r['maker_id'] ),
                'maker_name'   => get_the_title( intval( $r['maker_id'] ) ),
                'sku'          => strtoupper( (string) $r['sku'] ),
                'unit_cost'    => $unit,
                'status'       => (string) $r['status'],
                'last_updated' => (string) $r['post_modified_gmt'],
                'reason'       => $unit <= 0 ? 'unit_cost ≤ 0' : sprintf( 'no update > %d days', $days ),
            );
        }
        return $out;
    }
}

/**
 * Per-maker parity snapshot — นับจำนวน products, orphan sets, stale records per maker
 */
if ( ! function_exists( 'b2f_audit_maker_parity' ) ) {
    function b2f_audit_maker_parity( $maker_id ) {
        global $wpdb;
        $maker_id = intval( $maker_id );
        if ( ! $maker_id ) return null;

        $maker = get_post( $maker_id );
        if ( ! $maker || $maker->post_type !== 'b2f_maker' ) return null;

        // Product count
        $count = intval( $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*)
             FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = %s AND pm.meta_value = %s
             WHERE p.post_type = %s AND p.post_status IN ('publish','draft')",
            'mp_maker_id', $maker_id, 'b2f_maker_product'
        ) ) );

        // Orphan SETs (filter from full list)
        $all_orphans = b2f_audit_get_orphan_sets();
        $my_orphans = array_values( array_filter( $all_orphans, function( $o ) use ( $maker_id ) {
            return intval( $o['maker_id'] ) === $maker_id;
        } ) );

        // Stale records (filter)
        $all_stale = b2f_audit_get_stale_records( 90 );
        $my_stale = array_values( array_filter( $all_stale, function( $s ) use ( $maker_id ) {
            return intval( $s['maker_id'] ) === $maker_id;
        } ) );

        return array(
            'maker_id'        => $maker_id,
            'maker_name'      => $maker->post_title,
            'product_count'   => $count,
            'orphan_sets'     => $my_orphans,
            'orphan_count'    => count( $my_orphans ),
            'stale_records'   => $my_stale,
            'stale_count'     => count( $my_stale ),
            'parity_score'    => b2f_audit_compute_parity_score( $count, count( $my_orphans ), count( $my_stale ) ),
        );
    }
}

if ( ! function_exists( 'b2f_audit_compute_parity_score' ) ) {
    function b2f_audit_compute_parity_score( $total, $orphans, $stale ) {
        if ( $total <= 0 ) return 100;
        $deduction = ( ( $orphans + $stale ) / max( 1, $total ) ) * 100;
        $score = max( 0, 100 - $deduction );
        return round( $score, 1 );
    }
}

/**
 * ดึง catalog name สำหรับ SKU (best-effort จาก wp_dinoco_products)
 */
if ( ! function_exists( 'b2f_audit_catalog_name' ) ) {
    function b2f_audit_catalog_name( $sku ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT name FROM {$tbl} WHERE UPPER(sku) = %s LIMIT 1",
            strtoupper( $sku )
        ) );
        return $row && $row->name ? $row->name : $sku;
    }
}

/**
 * V.1.2: ดึง compatible_models + category สำหรับ SKU (parse JSON + normalize)
 * รองรับ format: [{"brand_name":"Honda","name":"NX500"}, ...] (V.42.0 H-11)
 * Return: ['models' => 'Honda NX500, Honda CB500X', 'category' => '...']
 */
if ( ! function_exists( 'b2f_audit_catalog_meta' ) ) {
    function b2f_audit_catalog_meta( $sku ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT compatible_models, category FROM {$tbl} WHERE UPPER(sku) = %s LIMIT 1",
            strtoupper( $sku )
        ), ARRAY_A );
        if ( ! $row ) return array( 'models' => '', 'category' => '' );

        $models_str = '';
        $raw = $row['compatible_models'] ?? '';
        if ( ! empty( $raw ) ) {
            $parsed = is_string( $raw ) ? json_decode( $raw, true ) : $raw;
            if ( is_array( $parsed ) ) {
                $names = array();
                foreach ( $parsed as $m ) {
                    if ( is_string( $m ) ) {
                        $names[] = $m;
                    } elseif ( is_array( $m ) ) {
                        $brand = $m['brand_name'] ?? $m['brand'] ?? '';
                        $name  = $m['name'] ?? $m['model_name'] ?? $m['slug'] ?? '';
                        if ( $name ) {
                            $names[] = $brand ? trim( $brand . ' ' . $name ) : $name;
                        }
                    }
                }
                $models_str = implode( ', ', array_filter( $names ) );
            }
        }
        return array(
            'models'   => $models_str,
            'category' => $row['category'] ?? '',
        );
    }
}

/**
 * Build dry-run CSV (in-memory)
 *
 * Delegates to `scripts/b2f-migrate-dry-run.php` (database-expert deliverable) ถ้ามี:
 *   — script outputs CSV ไปที่ php://output ตรง → capture ด้วย ob_start
 *   — columns ของ script: maker_id, maker_name, sku, action, current_cost, computed_cost, reason, notes
 *   — actions: ADD | FLAG_STALE | REMOVE_ORPHAN
 * Fallback: inline drift + stale CSV (columns: maker_id, maker_name, sku, issue_type, details)
 *
 * NOTE: script ยิง header() + echo BOM เมื่อ non-CLI — เรา capture ob แล้ว strip BOM
 * REST endpoint จะตั้ง header เอง (ไม่ให้ซ้อน)
 */
if ( ! function_exists( 'b2f_audit_build_dry_run_csv' ) ) {
    function b2f_audit_build_dry_run_csv() {
        // V.1.1: Use inline fallback directly (script has bugged ACF field names — fix Phase 1.2)
        // Strict rule now implemented in b2f_audit_get_orphan_sets() — skip script path
        $script_path = null;
        $_candidates_disabled = array(
            ABSPATH . '../scripts/b2f-migrate-dry-run.php',
            ABSPATH . 'scripts/b2f-migrate-dry-run.php',
            dirname( ABSPATH ) . '/scripts/b2f-migrate-dry-run.php',
            WP_CONTENT_DIR . '/scripts/b2f-migrate-dry-run.php',
        );
        foreach ( $candidates as $p ) {
            if ( $p && file_exists( $p ) ) { $script_path = $p; break; }
        }

        if ( $script_path ) {
            // Capture script's direct output (it streams fputcsv to php://output)
            // WARNING: script also calls header() — acceptable เพราะ REST endpoint
            // ยัง redirect header ของตัวเองทีหลัง (WordPress tolerant, buffer catches stray echo)
            ob_start();
            try {
                // @include — script may echo or @set_time_limit
                @include $script_path;
            } catch ( Throwable $e ) {
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] dry-run script error: ' . $e->getMessage() );
                }
            }
            $csv = ob_get_clean();
            // Strip UTF-8 BOM if script added it (REST layer will add its own)
            if ( is_string( $csv ) && substr( $csv, 0, 3 ) === "\xEF\xBB\xBF" ) {
                $csv = substr( $csv, 3 );
            }
            if ( is_string( $csv ) && strlen( $csv ) > 50 ) return $csv;
            // else fall through to inline fallback
        }

        // Fallback: inline drift + stale CSV
        $orphans = b2f_audit_get_orphan_sets();
        $stale   = b2f_audit_get_stale_records( 90 );

        $fh = fopen( 'php://temp', 'w+' );
        // V.1.3: + tree_view column (visual hierarchy)
        fputcsv( $fh, array(
            'maker_id', 'maker_name', 'sku', 'sku_name', 'compatible_models', 'category', 'issue_type',
            'children_count', 'leaves_count', 'children_with_grandchildren', 'all_leaves', 'tree_view', 'details'
        ) );

        foreach ( $orphans as $o ) {
            // V.1.3: children with nested grandchildren inline
            // Format: "DNCNX500001B ✓ [หลาน: -L ✓, -R ✓] | DNCNX500002B ✓ [หลาน: -L ✓, -R ✓]"
            $children_display = array();
            $tree_lines = array( '📦 ' . $o['orphan_sku'] ); // tree view column
            if ( ! empty( $o['children'] ) ) {
                foreach ( $o['children'] as $c_idx => $c ) {
                    $mark = $c['registered'] ? '✓' : ( $c['is_set'] ? '(SET covered)' : '✗' );
                    $grandchildren = ! empty( $c['leaves'] ) ? $c['leaves'] : array();
                    // remove self if this child IS a leaf
                    if ( count( $grandchildren ) === 1 && $grandchildren[0] === $c['sku'] ) {
                        $grandchildren = array(); // leaf, not a SET with grandchildren
                    }
                    if ( ! empty( $grandchildren ) ) {
                        $children_display[] = $c['sku'] . ' ' . $mark . ' [หลาน: ' . implode( ', ', $grandchildren ) . ']';
                    } else {
                        $children_display[] = $c['sku'] . ' ' . $mark . ' (leaf)';
                    }
                    // Tree view
                    $is_last = ( $c_idx === count( $o['children'] ) - 1 );
                    $prefix  = $is_last ? '└─ ' : '├─ ';
                    $tree_lines[] = $prefix . $c['sku'] . ' ' . $mark;
                    foreach ( $grandchildren as $gc_idx => $gc ) {
                        $gc_is_last = ( $gc_idx === count( $grandchildren ) - 1 );
                        $gc_prefix = ( $is_last ? '   ' : '│  ' ) . ( $gc_is_last ? '└─ ' : '├─ ' );
                        $tree_lines[] = $gc_prefix . $gc;
                    }
                }
            }
            fputcsv( $fh, array(
                $o['maker_id'],
                $o['maker_name'],
                $o['orphan_sku'],
                $o['orphan_name'] ?? '',
                $o['compatible_models'] ?? '',
                $o['category'] ?? '',
                'orphan',
                $o['children_count'] ?? 0,
                $o['leaves_count'] ?? 0,
                implode( ' | ', $children_display ),
                implode( ' | ', $o['leaves'] ?? array() ),
                implode( "\n", $tree_lines ), // V.1.3: tree view column
                $o['reason']
            ) );
        }
        foreach ( $stale as $s ) {
            fputcsv( $fh, array(
                $s['maker_id'], $s['maker_name'], $s['sku'], '', '', '',
                'stale', 0, 0, '', '', '',
                $s['reason'] . ' (last=' . $s['last_updated'] . ')'
            ) );
        }

        rewind( $fh );
        $csv = stream_get_contents( $fh );
        fclose( $fh );
        return $csv;
    }
}

