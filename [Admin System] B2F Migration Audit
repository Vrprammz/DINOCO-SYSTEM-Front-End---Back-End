                          '  • ALTER TABLE — เพิ่ม 6 columns + 2 indexes + 2 CHECK\n' +
                          '  • UPDATE ทุก junction row (auto_synced หรือ unconfirmed)\n' +
                          '  • Preserve admin-confirmed rows (idempotent)\n' +
                          '  • Lock flag ป้องกัน dual-write race\n' +
                          '  • Pre-migration mysqldump → wp-content/b2f-backups/\n\n' +
                          'กดยืนยันเท่านั้นถ้าผ่าน dry-run แล้ว.'
                    ) + '\n\nกด OK เพื่อดำเนินการ'
