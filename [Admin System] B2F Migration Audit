        </style>

        <script>
        (function(){
            var root = document.querySelector('.b2f-audit-root');
            if (!root) return;
            var NONCE = root.getAttribute('data-nonce');
            var BASE  = root.getAttribute('data-base');

            function api(path, opts) {
                opts = opts || {};
                opts.headers = opts.headers || {};
                opts.headers['X-WP-Nonce'] = NONCE;
                opts.headers['Accept'] = 'application/json';
                opts.credentials = 'same-origin';
                return fetch(BASE + path, opts).then(function(r){
                    var ct = r.headers.get('Content-Type') || '';
                    if (ct.indexOf('application/json') >= 0) return r.json().then(function(j){ return { ok: r.ok, json: j, status: r.status }; });
                    return r.text().then(function(t){ return { ok: r.ok, text: t, status: r.status }; });
                });
            }

            function esc(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){
                    return ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
                });
            }

            function renderOrphans(data) {
                var wrap = root.querySelector('[data-target="orphans-table"]');
                if (!data || !data.by_maker || data.by_maker.length === 0) {
                    wrap.innerHTML = '<div class="b2f-audit-empty">✅ ไม่มี orphan SET (parity 100%)</div>';
                    return;
                }
                var html = '<table class="b2f-audit-table"><thead><tr>' +
                    '<th>Maker</th><th>Count</th><th>Orphan SKUs</th>' +
                    '</tr></thead><tbody>';
                data.by_maker.forEach(function(m){
                    var skus = m.orphans.map(function(o){
                        return '<span class="b2f-audit-badge b2f-audit-badge-orphan">' + esc(o.sku) + '</span>';
                    }).join(' ');
                    html += '<tr data-filter="' + esc((m.maker_name||'') + ' ' + m.orphans.map(function(o){return o.sku;}).join(' ')) + '">' +
                        '<td>' + esc(m.maker_name) + ' <small>#' + m.maker_id + '</small></td>' +
                        '<td><strong>' + m.orphan_count + '</strong></td>' +
                        '<td>' + skus + '</td>' +
                        '</tr>';
                });
                html += '</tbody></table>';
                wrap.innerHTML = html;

                // attach filter
                var f = root.querySelector('.b2f-audit-filter[data-target="orphans"]');
                if (f) {
                    f.oninput = function() {
                        var q = this.value.toLowerCase();
                        wrap.querySelectorAll('tr[data-filter]').forEach(function(tr){
                            tr.style.display = tr.getAttribute('data-filter').toLowerCase().indexOf(q) >= 0 ? '' : 'none';
                        });
                    };
                }
            }

            function renderStale(data) {
                var wrap = root.querySelector('[data-target="stale-table"]');
                if (!data || !data.records || data.records.length === 0) {
                    wrap.innerHTML = '<div class="b2f-audit-empty">✅ ไม่มี stale records (ทุก record update ใน 90 วันและ cost > 0)</div>';
                    return;
                }
                var html = '<table class="b2f-audit-table"><thead><tr>' +
                    '<th>Maker</th><th>SKU</th><th>Cost</th><th>Status</th><th>Last Updated</th><th>Reason</th>' +
                    '</tr></thead><tbody>';
                data.records.slice(0, 100).forEach(function(r){
                    html += '<tr>' +
                        '<td>' + esc(r.maker_name) + '</td>' +
                        '<td><code>' + esc(r.sku) + '</code></td>' +
                        '<td>' + (r.unit_cost > 0 ? r.unit_cost.toFixed(2) : '<span class="b2f-audit-badge b2f-audit-badge-stale">0</span>') + '</td>' +
                        '<td>' + esc(r.status) + '</td>' +
                        '<td>' + esc(r.last_updated) + '</td>' +
                        '<td>' + esc(r.reason) + '</td>' +
                        '</tr>';
                });
                html += '</tbody></table>';
                if (data.records.length > 100) {
                    html += '<p class="b2f-audit-note">แสดง 100 records แรก (จากทั้งหมด ' + data.records.length + ')</p>';
                }
                wrap.innerHTML = html;
            }

            function renderFlags(data) {
                var wrap = root.querySelector('[data-target="flags-panel"]');
                if (!data || !data.flags) { wrap.innerHTML = '<div class="b2f-audit-empty">โหลด flags ไม่สำเร็จ</div>'; return; }
                var html = '';
                Object.keys(data.flags).forEach(function(k){
                    var f = data.flags[k];
                    var on = !!f.value;
                    var toggleable = !!f.toggleable;
                    var btn = toggleable
                        ? '<button class="b2f-audit-flag-toggle" data-action="flag-toggle" data-flag="' + esc(k) + '" data-value="' + (on ? '0' : '1') + '">' + (on ? '⏸ disable' : '▶ enable') + '</button>'
                        : '<span class="b2f-audit-flag-toggle locked" title="' + esc(f.lock_reason || 'locked') + '">🔒 locked</span>';
                    html += '<div class="b2f-audit-flag ' + (on ? 'on' : 'off') + '">' +
                        '<div class="b2f-audit-flag-name">' + (toggleable ? '🔓' : '🔒') + ' ' + esc(k) + btn + '</div>' +
                        '<div class="b2f-audit-flag-state">' + (on ? '✅ ENABLED' : '⬜ disabled') + '</div>' +
                        (f.lock_reason ? '<div class="b2f-audit-flag-lockreason">' + esc(f.lock_reason) + '</div>' : '') +
                        '</div>';
                });
                wrap.innerHTML = html;
            }

            // V.2.0: Phase 2 status renderer
            function renderPhase2Status(data) {
                if (!data) return;
                var schemaActivated = !!data.schema_activated;
                var backfillState = data.backfill_state || {};
                var backfillDone = !!backfillState.ran_at;
                var shadowOn = !!(data.flags && data.flags.b2f_flag_shadow_write && data.flags.b2f_flag_shadow_write.value);

                // Overall state
                var statusEl = root.querySelector('[data-target="phase2-status"] [data-k="state"]');
                if (statusEl) {
                    if (shadowOn) {
                        statusEl.innerHTML = '🟢 <strong>Phase 2 Active</strong> — Shadow-Write ON. CPT saves กำลัง dual-write เข้า junction.';
                    } else if (backfillDone) {
                        statusEl.innerHTML = '🟡 <strong>Phase 2 Ready</strong> — Backfill done. พร้อมเปิด shadow_write flag.';
                    } else if (schemaActivated) {
                        statusEl.innerHTML = '🔵 <strong>Schema Activated</strong> — รอ backfill. ยังไม่กระทบ production.';
                    } else {
                        statusEl.innerHTML = '⏳ <strong>Phase 1 Active</strong> — observe-only. กด "Activate Schema" เพื่อเริ่ม Phase 2.';
                    }
                }

                // Step states
                var s1 = root.querySelector('[data-step="1"] [data-k="schema-state"]');
                if (s1) {
                    s1.className = 'b2f-audit-phase2-step-state ' + (schemaActivated ? 'done' : 'pending');
                    s1.textContent = schemaActivated ? '✓ activated' : 'pending';
                }
                var s2 = root.querySelector('[data-step="2"] [data-k="backfill-state"]');
                if (s2) {
                    if (!schemaActivated) {
                        s2.className = 'b2f-audit-phase2-step-state blocked';
                        s2.textContent = 'blocked (no schema)';
                    } else if (backfillDone) {
                        s2.className = 'b2f-audit-phase2-step-state done';
                        s2.textContent = '✓ ' + (backfillState.cpt_migrated || 0) + ' migrated';
                    } else {
                        s2.className = 'b2f-audit-phase2-step-state pending';
                        s2.textContent = 'pending';
                    }
                }
                var s3 = root.querySelector('[data-step="3"] [data-k="shadow-state"]');
                if (s3) {
                    if (!backfillDone) {
                        s3.className = 'b2f-audit-phase2-step-state blocked';
                        s3.textContent = 'blocked (no backfill)';
                    } else if (shadowOn) {
                        s3.className = 'b2f-audit-phase2-step-state done';
                        s3.textContent = '✓ enabled';
                    } else {
                        s3.className = 'b2f-audit-phase2-step-state pending';
                        s3.textContent = 'pending';
                    }
                }

                // Disable buttons accordingly
                var btnActivate = root.querySelector('[data-action="activate-schema"]');
                if (btnActivate) {
                    btnActivate.disabled = schemaActivated;
                    if (schemaActivated) btnActivate.textContent = '✅ Activated';
                }
                root.querySelectorAll('[data-action="backfill"]').forEach(function(b){
                    b.disabled = !schemaActivated;
                });
                root.querySelectorAll('[data-action="toggle-shadow"]').forEach(function(b){
                    b.disabled = !backfillDone;
                });
            }

            function renderJunctionSnapshot(data) {
                var wrap = root.querySelector('[data-target="junction-table"]');
                var sumWrap = root.querySelector('[data-target="junction-summary"]');
                if (!data) { wrap.innerHTML = '<div class="b2f-audit-empty">โหลดไม่สำเร็จ</div>'; return; }
                var s = data.summary || {};
                var diffClass = (s.diff_vs_cpt === 0) ? 'ok' : (Math.abs(s.diff_vs_cpt) > 5 ? 'warn' : '');
                sumWrap.innerHTML =
                    '<div class="b2f-audit-summary-pill">Total: <strong>' + (s.total||0) + '</strong></div>' +
                    '<div class="b2f-audit-summary-pill ok">Active: <strong>' + (s.active||0) + '</strong></div>' +
                    '<div class="b2f-audit-summary-pill">Discontinued: <strong>' + (s.discontinued||0) + '</strong></div>' +
                    '<div class="b2f-audit-summary-pill">CPT count: <strong>' + (s.cpt_count||0) + '</strong></div>' +
                    '<div class="b2f-audit-summary-pill ' + diffClass + '">Diff vs CPT: <strong>' + (s.diff_vs_cpt>=0?'+':'') + (s.diff_vs_cpt||0) + '</strong></div>';
                if (!data.rows || !data.rows.length) {
                    wrap.innerHTML = '<div class="b2f-audit-empty">ไม่มีข้อมูล (junction table ว่าง — กด "Run Backfill")</div>';
                    return;
                }
                var html = '<table class="b2f-audit-table"><thead><tr>' +
                    '<th>SKU</th><th>Maker</th><th>Unit Cost</th><th>MOQ</th><th>Status</th><th>Updated</th><th>Legacy ID</th>' +
                    '</tr></thead><tbody>';
                data.rows.forEach(function(r){
                    html += '<tr>' +
                        '<td><code>' + esc(r.product_sku) + '</code></td>' +
                        '<td>' + esc(r.maker_name || '#' + r.maker_id) + '</td>' +
                        '<td>' + parseFloat(r.unit_cost || 0).toFixed(2) + '</td>' +
                        '<td>' + esc(r.moq) + '</td>' +
                        '<td><span class="b2f-audit-badge b2f-audit-badge-' + (r.status === 'active' ? 'orphan' : 'stale') + '">' + esc(r.status) + '</span></td>' +
                        '<td><small>' + esc(r.updated_at) + '</small></td>' +
                        '<td>' + esc(r.legacy_cpt_id || '–') + '</td>' +
                        '</tr>';
                });
                html += '</tbody></table>';
                if (data.returned < s.total) {
                    html += '<p class="b2f-audit-note">แสดง ' + data.returned + ' rows จาก ' + s.total + ' total (เพิ่ม ?limit= ใน endpoint หรือ filter)</p>';
                }
                wrap.innerHTML = html;
            }

            function renderObservations(data) {
                var wrap = root.querySelector('[data-target="obs-table"]');
                var sumWrap = root.querySelector('[data-target="obs-summary"]');
                if (!data) { wrap.innerHTML = '<div class="b2f-audit-empty">โหลดไม่สำเร็จ</div>'; return; }
                var s = data.summary || {};
                sumWrap.innerHTML =
                    '<div class="b2f-audit-summary-pill">Total: <strong>' + (s.total||0) + '</strong></div>' +
                    '<div class="b2f-audit-summary-pill ' + ((s.diffs||0) > 0 ? 'warn' : 'ok') + '">Drifts: <strong>' + (s.diffs||0) + '</strong></div>' +
                    '<div class="b2f-audit-summary-pill">Last 24h: <strong>' + (s.last_24h||0) + '</strong></div>';
                if (!data.rows || !data.rows.length) {
                    wrap.innerHTML = '<div class="b2f-audit-empty">ไม่มี observations (shadow_write ยังไม่เปิด หรือยังไม่มี CPT save หลัง Phase 2)</div>';
                    return;
                }
                var html = '<table class="b2f-audit-table"><thead><tr>' +
                    '<th>Observed</th><th>Source</th><th>Maker</th><th>SKU</th><th>Field</th><th>CPT Value</th><th>Junction Value</th><th>Diff</th>' +
                    '</tr></thead><tbody>';
                data.rows.forEach(function(r){
                    var cls = r.diff_detected == 1 ? 'b2f-audit-row-diff' : 'b2f-audit-row-match';
                    html += '<tr class="' + cls + '">' +
                        '<td><small>' + esc(r.observed_at) + '</small></td>' +
                        '<td>' + esc(r.source) + '</td>' +
                        '<td>' + esc(r.maker_name || '#' + r.maker_id) + '</td>' +
                        '<td><code>' + esc(r.sku) + '</code></td>' +
                        '<td>' + esc(r.field_name) + '</td>' +
                        '<td>' + esc(r.cpt_value) + '</td>' +
                        '<td>' + esc(r.junction_value) + '</td>' +
                        '<td>' + (r.diff_detected == 1 ? '🔴' : '⚪') + '</td>' +
                        '</tr>';
                });
                html += '</tbody></table>';
                wrap.innerHTML = html;
            }

            function renderCards(drift, stale) {
                var c = root.querySelector('[data-target="parity-cards"]');
                if (!c) return;
                var makers = (drift && drift.by_maker) ? drift.by_maker.length : 0;
                var orphans = drift ? drift.total_orphans : 0;
                var staleN = stale ? stale.total_stale : 0;
                c.querySelector('[data-k="makers"]').textContent = makers;
                c.querySelector('[data-k="orphans"]').textContent = orphans;
                c.querySelector('[data-k="stale"]').textContent = staleN;
                c.querySelector('[data-k="virtual"]').textContent = '—'; // Phase 2+ จะเริ่มเก็บ
            }

            function renderHistory() {
                // Phase 1: no data yet — placeholder stays
            }

            function loadAll() {
                var driftData = null, staleData = null, flagsData = null;

                api('drift').then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        driftData = r.json.data;
                        renderOrphans(driftData);
                    } else {
                        root.querySelector('[data-target="orphans-table"]').innerHTML = '<div class="b2f-audit-empty">❌ โหลด drift ไม่สำเร็จ</div>';
                    }
                    return api('stale');
                }).then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        staleData = r.json.data;
                        renderStale(staleData);
                    } else {
                        root.querySelector('[data-target="stale-table"]').innerHTML = '<div class="b2f-audit-empty">❌ โหลด stale ไม่สำเร็จ</div>';
                    }
                    renderCards(driftData, staleData);
                    return api('feature-flags');
                }).then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        flagsData = r.json.data;
                        renderFlags(flagsData);
                        renderPhase2Status(flagsData);
                        if (flagsData.schema_activated) {
                            loadJunctionSnapshot();
                            loadObservations();
                        }
                    }
                });

                renderHistory();
            }

            function loadJunctionSnapshot() {
                var maker = root.querySelector('[data-target="junction-maker"]').value;
                var status = root.querySelector('[data-target="junction-status"]').value;
                var qs = [];
                if (maker) qs.push('maker_id=' + encodeURIComponent(maker));
                if (status) qs.push('status=' + encodeURIComponent(status));
                qs.push('limit=50');
                var wrap = root.querySelector('[data-target="junction-table"]');
                wrap.innerHTML = '<div class="b2f-audit-empty">กำลังโหลด…</div>';
                api('junction-snapshot?' + qs.join('&')).then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        renderJunctionSnapshot(r.json.data);
                        var sel = root.querySelector('[data-target="junction-maker"]');
                        if (sel && sel.options.length <= 1 && r.json.data.rows) {
                            var seen = {};
                            r.json.data.rows.forEach(function(row){
                                if (row.maker_id && !seen[row.maker_id]) {
                                    seen[row.maker_id] = true;
                                    var opt = document.createElement('option');
                                    opt.value = row.maker_id;
                                    opt.textContent = (row.maker_name || '#' + row.maker_id);
                                    sel.appendChild(opt);
                                }
                            });
                        }
                    } else {
                        var msg = (r.json && r.json.message) ? r.json.message : 'โหลด junction ไม่สำเร็จ';
                        wrap.innerHTML = '<div class="b2f-audit-empty">❌ ' + esc(msg) + '</div>';
                    }
                });
            }

            function loadObservations() {
                var diffOnly = root.querySelector('[data-target="obs-diff-only"]').checked;
                var qs = [ 'limit=50' ];
                if (diffOnly) qs.push('diff_only=1');
                var wrap = root.querySelector('[data-target="obs-table"]');
                wrap.innerHTML = '<div class="b2f-audit-empty">กำลังโหลด…</div>';
                api('observations?' + qs.join('&')).then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        renderObservations(r.json.data);
                    } else {
                        var msg = (r.json && r.json.message) ? r.json.message : 'โหลด observations ไม่สำเร็จ';
                        wrap.innerHTML = '<div class="b2f-audit-empty">❌ ' + esc(msg) + '</div>';
                    }
                });
            }

            function setStatus(selector, msg, isErr) {
                var el = root.querySelector(selector);
                if (!el) return;
                el.className = 'b2f-audit-status' + (isErr ? ' err' : '');
                el.textContent = msg;
            }

            function doActivateSchema(btn) {
                if (!confirm(
                    '⚠️ ยืนยันการ Activate Schema?\n\n' +
                    'การกระทำนี้จะสร้าง 2 tables ใหม่:\n' +
                    '  • dinoco_product_makers\n' +
                    '  • dinoco_maker_product_observations\n\n' +
                    'คุณได้ backup database แล้วใช่ไหม? (ไม่มี undo button)\n\n' +
                    'กด OK เพื่อดำเนินการ'
                )) return;
                btn.disabled = true;
                setStatus('[data-target="activate-status"]', '⏳ กำลัง activate schema…', false);
                api('activate-schema', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ confirm: true })
                }).then(function(r){
                    btn.disabled = false;
                    if (r.ok && r.json && r.json.success) {
                        var d = r.json.data;
                        if (d.already_activated) {
                            setStatus('[data-target="activate-status"]', '✅ schema already activated (' + esc(d.activated_at) + ')', false);
                        } else {
                            setStatus('[data-target="activate-status"]', '✅ schema activated (junction=' + (d.junction_created?'✓':'✗') + ', obs=' + (d.observations_created?'✓':'✗') + ', ' + d.elapsed_ms + 'ms)', false);
                        }
                        loadAll();
                    } else {
                        var code = r.json && r.json.code || '';
                        var msg = (r.json && r.json.message) ? r.json.message : ('HTTP ' + r.status);
                        setStatus('[data-target="activate-status"]', '❌ ' + msg + (code === 'not_implemented' ? ' (database-expert ยังไม่ commit — รอ sync)' : ''), true);
                    }
                });
            }

            function doBackfill(btn, dryRun) {
                var label = dryRun ? 'Dry Run' : 'Run Backfill (LIVE)';
                if (!confirm(
                    (dryRun ? '🧪 ' : '⚠️ ') + 'ยืนยัน ' + label + '?\n\n' +
                    (dryRun ? 'Dry Run ไม่แก้ database — แค่ preview' : 'Live backfill จะ INSERT เข้า junction table จริง') + '.\n\n' +
                    'Expected: ~103 CPT migrated + ~13 orphans added = ~116 rows.\n\n' +
                    'กด OK เพื่อดำเนินการ'
                )) return;
                btn.disabled = true;
                var resultEl = root.querySelector('[data-target="backfill-result"]');
                resultEl.className = 'b2f-audit-phase2-backfill-result';
                resultEl.innerHTML = '';
                setStatus('[data-target="backfill-status"]', '⏳ กำลัง run backfill… (อาจใช้เวลา 10-30 วินาที)', false);
                api('backfill', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ confirm: !dryRun, dry_run: dryRun })
                }).then(function(r){
                    btn.disabled = false;
                    if (r.ok && r.json && r.json.success) {
                        var d = r.json.data;
                        setStatus('[data-target="backfill-status"]', '✅ ' + (d.dry_run ? 'dry run' : 'backfill') + ' complete — migrated ' + d.cpt_migrated + ', orphans ' + d.orphans_added + ', errors ' + (d.errors||[]).length + ' (' + d.elapsed_ms + 'ms)', false);
                        resultEl.classList.add('shown');
                        resultEl.innerHTML =
                            '<div><strong>Summary:</strong></div>' +
                            '<div>CPT migrated: ' + d.cpt_migrated + '</div>' +
                            '<div>Orphans added: ' + d.orphans_added + '</div>' +
                            '<div>Skipped: ' + (d.skipped||0) + '</div>' +
                            '<div>Errors: ' + (d.errors||[]).length + '</div>' +
                            ((d.errors||[]).length ? '<pre>' + esc(JSON.stringify(d.errors, null, 2)) + '</pre>' : '');
                        loadAll();
                    } else {
                        var code = r.json && r.json.code || '';
                        var msg = (r.json && r.json.message) ? r.json.message : ('HTTP ' + r.status);
                        setStatus('[data-target="backfill-status"]', '❌ ' + msg + (code === 'not_implemented' ? ' (scripts/b2f-phase2-backfill.php ยังไม่ sync)' : ''), true);
                    }
                });
            }

            function doToggleShadow(btn, value) {
                var want = value === '1';
                if (!confirm(
                    (want ? '▶ ' : '⏸ ') + 'ยืนยัน ' + (want ? 'Enable' : 'Disable') + ' shadow_write flag?\n\n' +
                    (want
                        ? 'หลังเปิดแล้ว: CPT saves จะ dual-write เข้า junction + บันทึก observations ทุกครั้ง.\nCPT ยังเป็น source of truth (Phase 3 ถึงจะ cut-over reads).'
                        : 'หลังปิดแล้ว: dual-write จะหยุด. junction data จะ freeze.') + '\n\n' +
                    'กด OK เพื่อดำเนินการ'
                )) return;
                btn.disabled = true;
                setStatus('[data-target="shadow-status"]', '⏳ กำลัง toggle flag…', false);
                api('feature-flags/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ flag_name: 'b2f_flag_shadow_write', value: want, confirm: true })
                }).then(function(r){
                    btn.disabled = false;
                    if (r.ok && r.json && r.json.success) {
                        var d = r.json.data;
                        setStatus('[data-target="shadow-status"]', '✅ flag ' + d.flag_name + ': ' + d.old_value + ' → ' + d.new_value + ' (uid=' + d.uid + ')', false);
                        loadAll();
                    } else {
                        var msg = (r.json && r.json.message) ? r.json.message : ('HTTP ' + r.status);
                        setStatus('[data-target="shadow-status"]', '❌ ' + msg, true);
                    }
                });
            }

            function doFlagToggle(btn) {
                var flag = btn.getAttribute('data-flag');
                var value = btn.getAttribute('data-value') === '1';
                if (!confirm('ยืนยัน toggle ' + flag + ' → ' + (value ? 'ENABLED' : 'disabled') + '?')) return;
                btn.disabled = true;
                api('feature-flags/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ flag_name: flag, value: value, confirm: true })
                }).then(function(r){
                    if (r.ok && r.json && r.json.success) {
                        loadAll();
                    } else {
                        alert((r.json && r.json.message) || 'Toggle failed');
                        btn.disabled = false;
                    }
                });
            }

            root.addEventListener('click', function(e){
                var t = e.target;
                if (t.matches('[data-action="refresh-all"]')) {
                    e.preventDefault();
                    loadAll();
                }
                if (t.matches('[data-action="dry-run"]')) {
                    e.preventDefault();
                    t.disabled = true;
                    var s = root.querySelector('[data-target="dry-run-status"]');
                    s.className = 'b2f-audit-status'; s.textContent = 'กำลังสร้าง CSV…';
                    var url = BASE + 'dry-run?_wpnonce=' + encodeURIComponent(NONCE);
                    var a = document.createElement('a');
                    a.href = url; a.style.display = 'none';
                    document.body.appendChild(a); a.click(); document.body.removeChild(a);
                    setTimeout(function(){
                        s.textContent = '✅ ส่ง request แล้ว (ตรวจ browser download)';
                        t.disabled = false;
                    }, 1500);
                }
                if (t.matches('[data-action="activate-schema"]')) { e.preventDefault(); doActivateSchema(t); }
                if (t.matches('[data-action="backfill"]')) { e.preventDefault(); doBackfill(t, t.getAttribute('data-dry') === '1'); }
                if (t.matches('[data-action="toggle-shadow"]')) { e.preventDefault(); doToggleShadow(t, t.getAttribute('data-value')); }
                if (t.matches('[data-action="flag-toggle"]')) { e.preventDefault(); doFlagToggle(t); }
                if (t.matches('[data-action="reload-junction"]')) { e.preventDefault(); loadJunctionSnapshot(); }
                if (t.matches('[data-action="reload-obs"]')) { e.preventDefault(); loadObservations(); }
            });

            root.addEventListener('change', function(e){
                var t = e.target;
                if (t.matches('[data-target="junction-maker"], [data-target="junction-status"]')) {
                    loadJunctionSnapshot();
                }
                if (t.matches('[data-target="obs-diff-only"]')) {
                    loadObservations();
                }
            });

            loadAll();
        })();
        </script>

        <?php
        return ob_get_clean();
    }
    add_shortcode( 'b2f_migration_audit', 'b2f_migration_audit_shortcode' );
}
