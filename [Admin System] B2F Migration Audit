/**
 * V.2.0: Phase 2 schema activation — dbDelta เพื่อสร้าง 2 canonical tables
 *   - wp_dinoco_product_makers (junction table, UNIQUE sku+maker)
 *   - wp_dinoco_maker_product_observations (shadow-write drift log)
 *
 * V.3.1: COLLATION DECISION (explicit, do not change without migration plan):
 *   - dbDelta() ไม่ support per-column COLLATE clause well (parser quirks),
 *     และ Codex docs แนะนำให้ใช้ table-default $wpdb->get_charset_collate()
 *     ซึ่ง MySQL/MariaDB defaults = utf8mb4_unicode_ci (case-INSENSITIVE).
 *   - ผลกระทบ: SQL query "WHERE product_sku = 'dncxxx'" จะ match row 'DNCXXX'
 *     ที่ database layer. ถ้า business rule ต้องการ case-sensitive (DNCXXX ≠ dncxxx
 *     เป็นคนละ SKU) ระบบนี้ "จะแตก".
 *   - DECISION: case-sensitivity NOT required (DINOCO SKU ทุกตัว uppercase by convention).
 *     Application layer (b2f_read_maker_product, b2f_audit_catalog_name) ยังบังคับ
 *     `$sku = strtoupper( trim( $sku ) )` + UPPER(product_sku) ใน WHERE clause
 *     เพื่อ defense-in-depth + ป้องกัน data ที่ legacy CPT บันทึก mixed case
 *     (mp_product_sku stored verbatim ใน postmeta).
 *   - ถ้า future requirement = case-sensitive SKUs:
 *     ALTER TABLE wp_dinoco_product_makers MODIFY product_sku VARCHAR(50) COLLATE utf8mb4_bin;
 *     ALTER TABLE wp_dinoco_maker_product_observations MODIFY sku VARCHAR(50) COLLATE utf8mb4_bin;
 *     + remove all UPPER() / strtoupper() normalize calls.
 *
 * Idempotent: dbDelta เช็ค schema diff → run CREATE / ALTER เฉพาะที่ต่าง
 *
 * @return array { junction_created, observations_created, dbdelta_log }
 */
if ( ! function_exists( 'b2f_audit_activate_schema_v10' ) ) {
    function b2f_audit_activate_schema_v10() {
        global $wpdb;
        $charset = $wpdb->get_charset_collate();

        // TABLE 1 — Junction
        $tbl_main = $wpdb->prefix . 'dinoco_product_makers';
        $sql_main = "CREATE TABLE {$tbl_main} (
            id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            product_sku VARCHAR(50) NOT NULL,
            maker_id BIGINT UNSIGNED NOT NULL,
            unit_cost DECIMAL(12,2) NOT NULL DEFAULT 0,
            moq INT UNSIGNED NOT NULL DEFAULT 1,
            lead_time_days INT UNSIGNED NOT NULL DEFAULT 7,
            shipping_land DECIMAL(10,2) NOT NULL DEFAULT 0,
            shipping_sea DECIMAL(10,2) NOT NULL DEFAULT 0,
            status VARCHAR(20) NOT NULL DEFAULT 'active',
            notes TEXT DEFAULT NULL,
            legacy_cpt_id BIGINT UNSIGNED DEFAULT NULL,
            created_by BIGINT UNSIGNED DEFAULT NULL,
            updated_by BIGINT UNSIGNED DEFAULT NULL,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
            deleted_at DATETIME DEFAULT NULL,
            UNIQUE KEY uq_sku_maker (product_sku, maker_id),
            KEY idx_maker (maker_id),
            KEY idx_sku (product_sku),
            KEY idx_status (status),
            KEY idx_maker_status (maker_id, status),
            KEY idx_legacy_cpt (legacy_cpt_id),
            KEY idx_deleted (deleted_at)
        ) {$charset};";

        // TABLE 2 — Observations
        $tbl_obs = $wpdb->prefix . 'dinoco_maker_product_observations';
        $sql_obs = "CREATE TABLE {$tbl_obs} (
            id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
            observed_at DATETIME NOT NULL,
            source VARCHAR(20) NOT NULL,
            sku VARCHAR(50) DEFAULT NULL,
            maker_id BIGINT UNSIGNED DEFAULT NULL,
            field_name VARCHAR(50) DEFAULT NULL,
            cpt_value TEXT,
            junction_value TEXT,
            diff_detected TINYINT(1) DEFAULT 0,
            KEY idx_observed (observed_at),
            KEY idx_diff (diff_detected),
            KEY idx_maker_sku (maker_id, sku)
        ) {$charset};";

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';
        $dbdelta_log = array();
        $dbdelta_log['main'] = dbDelta( $sql_main );
        $dbdelta_log['obs']  = dbDelta( $sql_obs );

        $junction_ok = b2f_audit_junction_table_exists();
        $obs_ok      = b2f_audit_observations_table_exists();

        if ( $junction_ok && ! get_option( 'b2f_schema_v10_activated' ) ) {
            update_option( 'b2f_schema_v10_activated', current_time( 'mysql' ), false );
        }
        if ( ! get_option( 'b2f_schema_version' ) ) {
            update_option( 'b2f_schema_version', '10.1', false );
        }

        return array(
            'junction_created'     => $junction_ok,
            'observations_created' => $obs_ok,
            'dbdelta_log'          => $dbdelta_log,
        );
    }
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 0.5: AUTO-SYNC BLACKLIST (V.3.2 — Option F Hybrid Admin Control)
// ═══════════════════════════════════════════════════════════════════
// Purpose: Admin-curated list of (maker_id, sku) pairs that MUST NOT be
// auto-injected by Phase 2 backfill's orphan-SET logic, even if they
// pass the "all descendants covered" strict rule.
//
// Shape (wp_option `b2f_autosync_blacklist`):
//   { "<maker_id>": ["SKU1", "SKU2", ...], "<maker_id2>": [...] }
//
// Write path: admin bulk-delete endpoint (POST /junction-bulk-delete) or
// direct toggle (POST /autosync-blacklist).
// Read path: b2f_phase2_run_backfill() STEP 3 — skips orphan INSERT when
// b2f_autosync_is_blacklisted($maker_id, $sku) returns true.

if ( ! function_exists( 'b2f_autosync_blacklist_get_all' ) ) {
    function b2f_autosync_blacklist_get_all() {
        $raw = get_option( 'b2f_autosync_blacklist', array() );
        if ( is_string( $raw ) ) {
            $decoded = json_decode( $raw, true );
            $raw = is_array( $decoded ) ? $decoded : array();
        }
        if ( ! is_array( $raw ) ) $raw = array();
        // Normalize: keys as string, values as uppercase SKU arrays
        $out = array();
        foreach ( $raw as $mid => $skus ) {
            if ( ! is_array( $skus ) ) continue;
            $mid_key = (string) intval( $mid );
            if ( $mid_key === '0' ) continue;
            $clean = array();
            foreach ( $skus as $s ) {
                $u = strtoupper( trim( (string) $s ) );
                if ( $u !== '' && ! in_array( $u, $clean, true ) ) $clean[] = $u;
            }
            if ( ! empty( $clean ) ) $out[ $mid_key ] = $clean;
        }
        return $out;
    }
}

if ( ! function_exists( 'b2f_autosync_blacklist_save' ) ) {
    /**
     * Internal — persist normalized blacklist. Warns if size > 100KB.
     */
    function b2f_autosync_blacklist_save( $blacklist ) {
        $encoded = wp_json_encode( $blacklist );
        if ( is_string( $encoded ) && strlen( $encoded ) > 102400 ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[B2F Autosync Blacklist] size=%d bytes > 100KB cap', strlen( $encoded ) ) );
            }
        }
        return update_option( 'b2f_autosync_blacklist', $blacklist, false );
    }
}

if ( ! function_exists( 'b2f_autosync_blacklist_get' ) ) {
    function b2f_autosync_blacklist_get( $maker_id ) {
        $all = b2f_autosync_blacklist_get_all();
        $key = (string) intval( $maker_id );
        return isset( $all[ $key ] ) ? $all[ $key ] : array();
    }
}

if ( ! function_exists( 'b2f_autosync_blacklist_add' ) ) {
    function b2f_autosync_blacklist_add( $maker_id, $sku ) {
        $maker_id = intval( $maker_id );
        $sku = strtoupper( trim( (string) $sku ) );
        if ( ! $maker_id || $sku === '' ) return false;
        $all = b2f_autosync_blacklist_get_all();
        $key = (string) $maker_id;
        if ( ! isset( $all[ $key ] ) || ! is_array( $all[ $key ] ) ) $all[ $key ] = array();
        if ( ! in_array( $sku, $all[ $key ], true ) ) {
            $all[ $key ][] = $sku;
            b2f_autosync_blacklist_save( $all );
        }
        return true;
    }
}

if ( ! function_exists( 'b2f_autosync_blacklist_remove' ) ) {
    function b2f_autosync_blacklist_remove( $maker_id, $sku ) {
        $maker_id = intval( $maker_id );
        $sku = strtoupper( trim( (string) $sku ) );
        if ( ! $maker_id || $sku === '' ) return false;
        $all = b2f_autosync_blacklist_get_all();
        $key = (string) $maker_id;
        if ( ! isset( $all[ $key ] ) ) return true; // no-op
        $all[ $key ] = array_values( array_filter( $all[ $key ], function( $s ) use ( $sku ) {
            return $s !== $sku;
        } ) );
        if ( empty( $all[ $key ] ) ) unset( $all[ $key ] );
        b2f_autosync_blacklist_save( $all );
        return true;
    }
}

if ( ! function_exists( 'b2f_autosync_is_blacklisted' ) ) {
    function b2f_autosync_is_blacklisted( $maker_id, $sku ) {
        $list = b2f_autosync_blacklist_get( $maker_id );
        $u = strtoupper( trim( (string) $sku ) );
        return in_array( $u, $list, true );
    }
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 1: HELPERS — DRIFT / STALE / PARITY QUERIES
// ═══════════════════════════════════════════════════════════════════

/**
 * V.2.1: Inline Phase 2 backfill (replaces external scripts/b2f-phase2-backfill.php)
 * Reason: WP Code Snippets ไม่ sync scripts/ folder → file ไม่อยู่บน server
 * Solution: embed เข้า audit snippet ตรงๆ → sync ผ่าน webhook ปกติ
 */
if ( ! function_exists( 'b2f_phase2_run_backfill' ) ) {
    function b2f_phase2_run_backfill( $dry_run = false, $actor_uid = 0 ) {
        global $wpdb;

        $result = array(
            'success'              => false,
            'dry_run'              => (bool) $dry_run,
            'cpt_migrated'         => 0,
            'orphans_added'        => 0,
            'skipped'              => 0,
            'skipped_blacklisted'  => array(), // V.3.2: SKUs skipped due to admin blacklist
            'errors'               => array(),
            'started_at'           => current_time( 'mysql' ),
            'finished_at'          => null,
        );

        // Guard 1: schema activated
        if ( ! get_option( 'b2f_schema_v10_activated', 0 ) ) {
            $result['errors'][] = 'Schema V10 ยังไม่ activate — กด Activate Schema ก่อน';
            return $result;
        }

        $tbl = $wpdb->prefix . 'dinoco_product_makers';

        // Guard 2: table exists
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.TABLES WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s",
            DB_NAME, $tbl
        ) );
        if ( ! $exists ) {
            $result['errors'][] = "Table {$tbl} ไม่มีอยู่จริง — run Activate Schema อีกครั้ง";
            return $result;
        }

        // STEP 1: Load b2f_maker_product CPTs
        $maker_products = get_posts( array(
            'post_type'      => 'b2f_maker_product',
            'post_status'    => array( 'publish', 'draft' ),
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'no_found_rows'  => true,
        ) );

        // V.3.1: Pre-warm postmeta cache BEFORE transaction begins.
        // get_field()/get_post_meta() inside the loop become cache hits → no row-level
        // SELECTs while the InnoDB transaction holds locks. Significant scaling win
        // for makers with hundreds of products (avoids 8 SELECTs per CPT inside lock).
        if ( ! empty( $maker_products ) && function_exists( 'update_postmeta_cache' ) ) {
            update_postmeta_cache( $maker_products );
        }

        if ( ! $dry_run ) $wpdb->query( 'START TRANSACTION' );

        $actor_uid = intval( $actor_uid );
        $now = current_time( 'mysql' );

        // STEP 2: Copy CPT → junction
        foreach ( $maker_products as $mp_id ) {
            try {
                $sku       = function_exists( 'get_field' ) ? get_field( 'mp_product_sku', $mp_id ) : '';
                $maker_id  = function_exists( 'get_field' ) ? get_field( 'mp_maker_id', $mp_id ) : 0;
                $unit_cost = function_exists( 'get_field' ) ? floatval( get_field( 'mp_unit_cost', $mp_id ) ) : 0;
                $moq       = function_exists( 'get_field' ) ? intval( get_field( 'mp_moq', $mp_id ) ) : 1;
                $lead_time = function_exists( 'get_field' ) ? intval( get_field( 'mp_lead_time_days', $mp_id ) ) : 7;
                $ship_land = function_exists( 'get_field' ) ? floatval( get_field( 'mp_shipping_land', $mp_id ) ) : 0;
                $ship_sea  = function_exists( 'get_field' ) ? floatval( get_field( 'mp_shipping_sea', $mp_id ) ) : 0;
                $notes     = function_exists( 'get_field' ) ? ( get_field( 'mp_notes', $mp_id ) ?: '' ) : '';
                $status    = function_exists( 'get_field' ) ? ( get_field( 'mp_status', $mp_id ) ?: 'active' ) : 'active';

                $sku = strtoupper( trim( (string) $sku ) );
                $maker_id = intval( $maker_id );
                if ( ! $sku || ! $maker_id ) { $result['skipped']++; continue; }
                if ( ! in_array( $status, array( 'active', 'discontinued', 'pending' ), true ) ) $status = 'active';
                if ( $moq < 1 ) $moq = 1;
                if ( $lead_time < 0 ) $lead_time = 7;

                if ( $dry_run ) { $result['cpt_migrated']++; continue; }

                $sql = $wpdb->prepare(
                    "INSERT INTO {$tbl}
                        (product_sku, maker_id, unit_cost, moq, lead_time_days,
                         shipping_land, shipping_sea, status, notes,
                         legacy_cpt_id, created_by, updated_by, created_at, updated_at)
                     VALUES (%s, %d, %f, %d, %d, %f, %f, %s, %s, %d, %d, %d, %s, %s)
                     ON DUPLICATE KEY UPDATE
                        unit_cost=VALUES(unit_cost), moq=VALUES(moq),
                        lead_time_days=VALUES(lead_time_days),
                        shipping_land=VALUES(shipping_land), shipping_sea=VALUES(shipping_sea),
                        status=VALUES(status), notes=VALUES(notes),
                        legacy_cpt_id=VALUES(legacy_cpt_id),
                        updated_by=VALUES(updated_by), updated_at=VALUES(updated_at)",
                    $sku, $maker_id, $unit_cost, $moq, $lead_time,
                    $ship_land, $ship_sea, $status, $notes,
                    $mp_id, $actor_uid, $actor_uid, $now, $now
                );
                $ok = $wpdb->query( $sql );
                if ( $ok === false ) throw new Exception( 'INSERT failed mp_id=' . $mp_id . ' — ' . $wpdb->last_error );
                $result['cpt_migrated']++;
            } catch ( Throwable $e ) {
                $result['errors'][] = 'mp_id=' . $mp_id . ': ' . $e->getMessage();
                if ( ! $dry_run ) {
                    $wpdb->query( 'ROLLBACK' );
                    $result['finished_at'] = current_time( 'mysql' );
                    return $result;
                }
            }
        }

        // STEP 3: Inject orphan SETs (reuse strict rule)
        if ( ! function_exists( 'b2f_audit_get_orphan_sets' ) ) {
            if ( ! $dry_run ) $wpdb->query( 'ROLLBACK' );
            $result['errors'][] = 'b2f_audit_get_orphan_sets() ไม่พบ';
            $result['finished_at'] = current_time( 'mysql' );
            return $result;
        }

        $orphans = b2f_audit_get_orphan_sets();
        if ( ! is_array( $orphans ) ) $orphans = array();

        foreach ( $orphans as $orphan ) {
            $sku = ''; $maker_id = 0;
            try {
                $sku      = strtoupper( trim( (string) ( $orphan['orphan_sku'] ?? '' ) ) );
                $maker_id = intval( $orphan['maker_id'] ?? 0 );
                $leaves   = is_array( $orphan['leaves'] ?? null ) ? $orphan['leaves'] : array();

                if ( ! $sku || ! $maker_id ) { $result['skipped']++; continue; }

                // V.3.2: Blacklist check — admin opted out of auto-sync for this (maker, sku)
                // Takes effect BEFORE INSERT to prevent re-add on backfill re-run.
                if ( function_exists( 'b2f_autosync_is_blacklisted' )
                  && b2f_autosync_is_blacklisted( $maker_id, $sku ) ) {
                    $result['skipped']++;
                    $result['skipped_blacklisted'][] = $sku . '@' . $maker_id;
                    continue;
                }

                // Compute SET cost = sum of registered leaves (from junction, just inserted)
                $sum_cost = 0.0; $sum_land = 0.0; $sum_sea = 0.0; $max_lt = 7;
                foreach ( $leaves as $leaf_sku ) {
                    $leaf_u = strtoupper( trim( (string) $leaf_sku ) );
                    $row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT unit_cost, lead_time_days, shipping_land, shipping_sea
                         FROM {$tbl}
                         WHERE product_sku = %s AND maker_id = %d AND deleted_at IS NULL
                         LIMIT 1",
                        $leaf_u, $maker_id
                    ), ARRAY_A );
                    if ( $row ) {
                        $sum_cost += floatval( $row['unit_cost'] );
                        $sum_land += floatval( $row['shipping_land'] );
                        $sum_sea  += floatval( $row['shipping_sea'] );
                        $lt = intval( $row['lead_time_days'] );
                        if ( $lt > $max_lt ) $max_lt = $lt;
                    }
                }

                $auto_notes = 'Auto-added by Phase 2 migration ' . wp_date( 'Y-m-d' ) . ' — leaves=' . implode( ',', $leaves );

                if ( $dry_run ) { $result['orphans_added']++; continue; }

                // V.3.1: Recompute fields on re-run (was no-op `id = id` → re-running backfill
                // after registering more leaves left orphan SET cost stale at first-run value).
                // lead_time uses GREATEST() to honor newly-discovered slower leaves.
                //
                // V.3.3 (H-1) ON DUPLICATE KEY UPDATE semantics (INTENTIONAL):
                //   - `status` + `deleted_at` are INTENTIONALLY EXCLUDED from UPDATE list
                //   - Rationale: admin soft-deletes orphan SET via Option F bulk-delete UI
                //     (sets status='discontinued' + deleted_at=NOW + adds SKU to autosync blacklist).
                //     Blacklist check (L476-481 above) skips this INSERT for blacklisted pairs →
                //     normally unreachable. But if admin removes blacklist entry, re-run SHOULD
                //     preserve deletion state (not auto-revive) — admin must explicitly restore via:
                //       UPDATE wp_dinoco_product_makers SET deleted_at=NULL, status='active'
                //       WHERE product_sku=? AND maker_id=?
                //   - Fields that ARE recomputed: unit_cost, lead_time_days (GREATEST), shipping_*,
                //     notes, updated_by, updated_at → honor newly-discovered leaf changes without
                //     resurrecting deleted records.
                //   - TOCTOU note: blacklist check + INSERT is a 2-step; we rely on the transaction
                //     (START TRANSACTION at STEP 0) + admin UI single-user assumption. If two admins
                //     race (one blacklists while other runs backfill), worst case = stale insert,
                //     which next backfill re-run will skip. Acceptable for Phase 2/3 ops cadence.
                $sql = $wpdb->prepare(
                    "INSERT INTO {$tbl}
                        (product_sku, maker_id, unit_cost, moq, lead_time_days,
                         shipping_land, shipping_sea, status, notes,
                         legacy_cpt_id, created_by, updated_by, created_at, updated_at)
                     VALUES (%s, %d, %f, %d, %d, %f, %f, %s, %s, NULL, %d, %d, %s, %s)
                     ON DUPLICATE KEY UPDATE
                        unit_cost      = VALUES(unit_cost),
                        lead_time_days = GREATEST(lead_time_days, VALUES(lead_time_days)),
                        shipping_land  = VALUES(shipping_land),
                        shipping_sea   = VALUES(shipping_sea),
                        notes          = VALUES(notes),
                        updated_by     = VALUES(updated_by),
                        updated_at     = VALUES(updated_at)",
                    $sku, $maker_id, $sum_cost, 1, $max_lt,
                    $sum_land, $sum_sea, 'active', $auto_notes,
                    $actor_uid, $actor_uid, $now, $now
                );
                $ok = $wpdb->query( $sql );
                if ( $ok === false ) throw new Exception( 'Orphan INSERT failed sku=' . $sku . ' — ' . $wpdb->last_error );
                if ( $wpdb->rows_affected >= 1 ) $result['orphans_added']++;
                else $result['skipped']++;

            } catch ( Throwable $e ) {
                $result['errors'][] = 'orphan sku=' . $sku . ' maker=' . $maker_id . ': ' . $e->getMessage();
                if ( ! $dry_run ) {
                    $wpdb->query( 'ROLLBACK' );
                    $result['finished_at'] = current_time( 'mysql' );
                    return $result;
                }
            }
        }

        // STEP 4: Commit
        if ( ! $dry_run ) {
            $wpdb->query( 'COMMIT' );
            update_option( 'b2f_phase2_backfill_completed', time() );
        }

        $result['success'] = empty( $result['errors'] );
        $result['finished_at'] = current_time( 'mysql' );

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf(
                '[B2F Phase2 Backfill] dry_run=%d success=%d cpt=%d orphans=%d skipped=%d blacklisted=%d errors=%d',
                $result['dry_run'] ? 1 : 0, $result['success'] ? 1 : 0,
                $result['cpt_migrated'], $result['orphans_added'], $result['skipped'],
                count( $result['skipped_blacklisted'] ), count( $result['errors'] )
            ) );
        }

        return $result;
    }
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 0.7: V.3.3 — PHASE 4 CLASSIFICATION MIGRATION
// ═══════════════════════════════════════════════════════════════════
//
// Plan reference: .claude/plans/sunny-spinning-quill.md (Migration Logic lines ~450-540)
//
// Entry point: b2f_phase4_run_classification_migration( $dry_run = true )
//
// Pipeline (7 steps):
//   STEP 0  update_option('b2f_phase4_migration_in_progress', true)  ← CRIT-4 lock
//   STEP 1  b2f_audit_check_mysql_version()        ← non-blocking log
//   STEP 2  Pre-migration mysqldump                ← 0700 perms + .htaccess deny
//   STEP 3  Idempotent ALTER TABLE                 ← INFORMATION_SCHEMA per-column check
//           (observations.source ENUM + junction 6 columns + 2 indexes + CHECK)
//   STEP 4  Classification loop                    ← 200 rows/tx, 50ms gap
//           Branching (CRIT-3 cross_factory branch):
//             has_children AND missing_leaves > 0 → cross_factory_assembly + as_parts
//             has_children AND has_parent         → sub_unit
//             has_children                         → set_assembled
//             else                                 → single
//           Idempotent guard: only rows where
//             (confirmation_status='auto_synced' OR confirmed_at IS NULL)
//   STEP 5  Persist state JSON                     ← b2f_phase4_migration_state (HIGH-6)
//   STEP 6  delete_option(lock)                    ← Snippet 0.5 V.1.2 resumes dual-write
//   STEP 7  do_action('b2f_junction_updated', 0)   ← invalidate all maker transients
//
// Dry-run:
//   - STEP 2/3/4 emit CSV to wp-content/b2f-backups/dry-run-{timestamp}.csv
//   - No DB mutation (no ALTER, no UPDATE)
//   - State NOT persisted (so live run still possible)

/**
 * V.3.3: Ensure `wp-content/b2f-backups/` exists with secure perms + .htaccess deny.
 * Returns absolute path to the backup dir (or WP_Error on failure).
 */
if ( ! function_exists( 'b2f_phase4_ensure_backup_dir' ) ) {
    function b2f_phase4_ensure_backup_dir() {
        $base = WP_CONTENT_DIR . '/b2f-backups';
        if ( ! is_dir( $base ) ) {
            if ( ! wp_mkdir_p( $base ) ) {
                return new WP_Error( 'backup_dir_failed', 'Cannot create ' . $base );
            }
        }
        @chmod( $base, 0700 );
        $htaccess = $base . '/.htaccess';
        if ( ! file_exists( $htaccess ) ) {
            @file_put_contents( $htaccess, "Require all denied\n<IfModule !mod_authz_core.c>\nDeny from all\n</IfModule>\n" );
            @chmod( $htaccess, 0600 );
        }
        $index = $base . '/index.html';
        if ( ! file_exists( $index ) ) {
            @file_put_contents( $index, '' );
        }
        return $base;
    }
}

/**
 * V.3.3: Phase 4 — STEP 2 best-effort mysqldump snapshot.
 *  - Tries shell_exec('mysqldump ...') — if unavailable or disabled, logs warning.
 *  - Output file: wp-content/b2f-backups/b2f_v11_{timestamp}.sql (chmod 0600)
 *  - Returns ['path' => ..., 'ok' => bool, 'message' => ...]
 */
if ( ! function_exists( 'b2f_phase4_dump_snapshot' ) ) {
    function b2f_phase4_dump_snapshot() {
        $dir = b2f_phase4_ensure_backup_dir();
        if ( is_wp_error( $dir ) ) {
            return array( 'ok' => false, 'path' => '', 'message' => $dir->get_error_message() );
        }
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $ts  = gmdate( 'Ymd-His' );
        $fname = "b2f_v11_{$ts}.sql";
        $path  = $dir . '/' . $fname;

        // Soft guard: if table doesn't exist yet → write "no-op" marker.
        if ( ! b2f_audit_junction_table_exists() ) {
            @file_put_contents( $path, "-- junction table missing at time of snapshot — fresh V11 schema expected\n" );
            @chmod( $path, 0600 );
            return array( 'ok' => true, 'path' => $path, 'message' => 'no_table_to_dump' );
        }

        $shell_ok = function_exists( 'shell_exec' );
        if ( $shell_ok ) {
            $disabled = explode( ',', (string) ini_get( 'disable_functions' ) );
            $disabled = array_map( 'trim', $disabled );
            if ( in_array( 'shell_exec', $disabled, true ) ) $shell_ok = false;
        }
        if ( ! $shell_ok ) {
            // Fallback — dump structure + data via wpdb (slower, but portable).
            $rows = $wpdb->get_results( "SELECT * FROM {$tbl}", ARRAY_A );
            $lines = array( "-- fallback dump (shell_exec unavailable) " . wp_date( 'c' ), "-- table {$tbl}" );
            foreach ( (array) $rows as $r ) {
                $lines[] = '-- ' . wp_json_encode( $r );
            }
            @file_put_contents( $path, implode( "\n", $lines ) . "\n" );
            @chmod( $path, 0600 );
            return array( 'ok' => true, 'path' => $path, 'message' => 'fallback_wpdb_dump' );
        }

        // Best-effort mysqldump — host/user/password from DB_* constants
        $host = defined( 'DB_HOST' ) ? DB_HOST : 'localhost';
        $user = defined( 'DB_USER' ) ? DB_USER : '';
        $pass = defined( 'DB_PASSWORD' ) ? DB_PASSWORD : '';
        $name = defined( 'DB_NAME' ) ? DB_NAME : '';
        $cmd = sprintf(
            'mysqldump --single-transaction --skip-lock-tables -h %s -u %s %s %s %s > %s 2>&1',
            escapeshellarg( $host ),
            escapeshellarg( $user ),
            $pass !== '' ? '-p' . escapeshellarg( $pass ) : '',
            escapeshellarg( $name ),
            escapeshellarg( $tbl ),
            escapeshellarg( $path )
        );
        @shell_exec( $cmd );
        if ( file_exists( $path ) && filesize( $path ) > 0 ) {
            @chmod( $path, 0600 );
            return array( 'ok' => true, 'path' => $path, 'message' => 'mysqldump_ok' );
        }
        return array( 'ok' => false, 'path' => $path, 'message' => 'mysqldump_failed' );
    }
}

/**
 * V.3.3: Idempotent STEP 3 — ALTER junction + observations to V11 schema.
 * Uses INFORMATION_SCHEMA per-column check. Runs only missing pieces.
 *
 * Returns ['altered_columns' => [...], 'altered_indexes' => [...], 'check_added' => bool, 'errors' => [...]]
 */
if ( ! function_exists( 'b2f_phase4_activate_schema_v11' ) ) {
    function b2f_phase4_activate_schema_v11() {
        global $wpdb;
        $out = array( 'altered_columns' => array(), 'altered_indexes' => array(), 'check_added' => false, 'errors' => array() );

        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $obs = $wpdb->prefix . 'dinoco_maker_product_observations';

        // STEP 3.0 — Extend observations.source ENUM (MED-1)
        if ( b2f_audit_observations_table_exists() ) {
            // Check current ENUM value set
            $col = $wpdb->get_row( $wpdb->prepare(
                "SELECT COLUMN_TYPE FROM INFORMATION_SCHEMA.COLUMNS
                 WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s AND COLUMN_NAME = %s",
                DB_NAME, $obs, 'source'
            ) );
            if ( $col && strpos( (string) $col->COLUMN_TYPE, 'classification_change' ) === false ) {
                $sql = "ALTER TABLE {$obs} MODIFY COLUMN `source` ENUM('cpt','junction','diff','classification_change') NOT NULL";
                $ok = $wpdb->query( $sql );
                if ( $ok === false ) $out['errors'][] = 'obs ENUM ALTER failed: ' . $wpdb->last_error;
                else $out['altered_columns'][] = 'observations.source';
            }
        }

        // STEP 3.1 — junction V11 columns
        $v11_columns = array(
            'production_mode'      => "ADD COLUMN `production_mode` ENUM('set_assembled','sub_unit','single','cross_factory_assembly') NOT NULL DEFAULT 'single' AFTER `status`",
            'confirmation_status'  => "ADD COLUMN `confirmation_status` ENUM('confirmed','auto_synced') NOT NULL DEFAULT 'auto_synced' AFTER `production_mode`",
            'admin_display_mode'   => "ADD COLUMN `admin_display_mode` ENUM('auto','as_set','as_parts') NOT NULL DEFAULT 'auto' AFTER `confirmation_status`",
            'missing_leaves_count' => "ADD COLUMN `missing_leaves_count` SMALLINT UNSIGNED NOT NULL DEFAULT 0 AFTER `admin_display_mode`",
            'confirmed_by'         => "ADD COLUMN `confirmed_by` BIGINT UNSIGNED DEFAULT NULL",
            'confirmed_at'         => "ADD COLUMN `confirmed_at` DATETIME DEFAULT NULL",
        );
        foreach ( $v11_columns as $col_name => $clause ) {
            if ( b2f_audit_column_exists( $tbl, $col_name ) ) continue;
            $sql = "ALTER TABLE {$tbl} {$clause}";
            $ok = $wpdb->query( $sql );
            if ( $ok === false ) $out['errors'][] = "ALTER {$col_name} failed: " . $wpdb->last_error;
            else $out['altered_columns'][] = $col_name;
        }

        // STEP 3.2 — Composite indexes (HIGH-5)
        $v11_indexes = array(
            'idx_maker_prod_display' => "ADD KEY `idx_maker_prod_display` (`maker_id`, `production_mode`, `admin_display_mode`)",
            'idx_maker_confirmation' => "ADD KEY `idx_maker_confirmation` (`maker_id`, `confirmation_status`)",
        );
        foreach ( $v11_indexes as $idx_name => $clause ) {
            if ( b2f_audit_index_exists( $tbl, $idx_name ) ) continue;
            $sql = "ALTER TABLE {$tbl} {$clause}";
            $ok = $wpdb->query( $sql );
            if ( $ok === false ) $out['errors'][] = "ADD INDEX {$idx_name} failed: " . $wpdb->last_error;
            else $out['altered_indexes'][] = $idx_name;
        }

        // STEP 3.3 — CHECK constraints (MySQL 8.0.16+ / MariaDB 10.2.1+ only)
        // We probe via INFORMATION_SCHEMA.CHECK_CONSTRAINTS — silent no-op on lower versions.
        $cap = function_exists( 'b2f_audit_check_mysql_version' ) ? b2f_audit_check_mysql_version() : array();
        $check_active = ! empty( $cap['check_constraints_active'] );
        if ( $check_active ) {
            // See if already present
            $have = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM INFORMATION_SCHEMA.CHECK_CONSTRAINTS
                 WHERE CONSTRAINT_SCHEMA = %s AND CONSTRAINT_NAME IN ('chk_mode_display','chk_confirmed_consistency')",
                DB_NAME
            ) );
            if ( $have < 2 ) {
                // Attempt ADD — individual ADD wrapped in try/catch since already-exists errors are non-fatal.
                foreach ( array(
                    'chk_mode_display'          => "ADD CONSTRAINT `chk_mode_display` CHECK (NOT (`production_mode` = 'single' AND `admin_display_mode` = 'as_parts'))",
                    'chk_confirmed_consistency' => "ADD CONSTRAINT `chk_confirmed_consistency` CHECK (`confirmation_status` = 'auto_synced' OR (`confirmed_by` IS NOT NULL AND `confirmed_at` IS NOT NULL))",
                ) as $cname => $clause ) {
                    $sql = "ALTER TABLE {$tbl} {$clause}";
                    $ok = @$wpdb->query( $sql );
                    if ( $ok === false ) {
                        // tolerate "Duplicate check constraint name"
                        if ( stripos( (string) $wpdb->last_error, 'Duplicate' ) === false ) {
                            $out['errors'][] = "ADD CONSTRAINT {$cname}: " . $wpdb->last_error;
                        }
                    }
                }
                $out['check_added'] = true;
            }
        }

        // STEP 3.4 — Schema version markers
        if ( empty( $out['errors'] ) ) {
            update_option( 'b2f_schema_version', '11.0', false );
            if ( ! get_option( 'b2f_schema_v11_activated' ) ) {
                update_option( 'b2f_schema_v11_activated', current_time( 'mysql' ), false );
            }
        }

        return $out;
    }
}

/**
 * V.3.3: Phase 4 classification decision — pure function (no DB writes).
 * Mirrors Snippet 1 V.7.0 `b2f_infer_production_mode_from_relations()` branching,
 * but returns ALL classification fields at once for bulk UPDATE.
 *
 * Input:  $sku, $maker_id, $has_children, $has_parent, $missing_leaves, $legacy_cpt_id
 * Output: [ 'production_mode', 'admin_display_mode', 'confirmation_status', 'missing_leaves_count' ]
 *
 * CRIT-3: cross_factory_assembly branch is REACHABLE (was dead code in earlier plans).
 */
if ( ! function_exists( 'b2f_phase4_classify_row' ) ) {
    function b2f_phase4_classify_row( $has_children, $has_parent, $missing_leaves, $legacy_cpt_id ) {
        $missing_leaves = max( 0, (int) $missing_leaves );
        $has_children   = (bool) $has_children;
        $has_parent     = (bool) $has_parent;
        $legacy_cpt     = (int) $legacy_cpt_id > 0;

        // CRIT-3: cross_factory branch (must check FIRST before set_assembled)
        if ( $has_children && $missing_leaves > 0 ) {
            return array(
                'production_mode'      => 'cross_factory_assembly',
                'admin_display_mode'   => 'as_parts',
                'confirmation_status'  => 'auto_synced',
                'missing_leaves_count' => $missing_leaves,
            );
        }
        if ( $has_children && $has_parent ) {
            return array(
                'production_mode'      => 'sub_unit',
                'admin_display_mode'   => 'auto',
                'confirmation_status'  => $legacy_cpt ? 'confirmed' : 'auto_synced',
                'missing_leaves_count' => 0,
            );
        }
        if ( $has_children ) {
            return array(
                'production_mode'      => 'set_assembled',
                'admin_display_mode'   => 'auto',
                'confirmation_status'  => $legacy_cpt ? 'confirmed' : 'auto_synced',
                'missing_leaves_count' => 0,
            );
        }
        return array(
            'production_mode'      => 'single',
            'admin_display_mode'   => 'auto',
            'confirmation_status'  => $legacy_cpt ? 'confirmed' : 'auto_synced',
            'missing_leaves_count' => 0,
        );
    }
}

/**
 * V.3.3: Missing-leaves probe — count leaves of $sku that maker has NOT registered.
 * Uses sku_relations + junction table (fast path) or CPT postmeta (cold path).
 */
if ( ! function_exists( 'b2f_phase4_count_missing_leaves' ) ) {
    function b2f_phase4_count_missing_leaves( $sku, $maker_id, $maker_sku_set ) {
        $sku = strtoupper( trim( (string) $sku ) );
        if ( $sku === '' ) return 0;

        // Resolve leaves (Snippet 15 helper if available; else walk sku_relations)
        $leaves = array();
        if ( function_exists( 'dinoco_get_leaf_skus' ) ) {
            $leaves = dinoco_get_leaf_skus( $sku );
        }
        if ( ! is_array( $leaves ) || empty( $leaves ) ) {
            // Walk relations manually
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) return 0;
            $rel_upper = array();
            foreach ( $relations as $p => $kids ) {
                if ( ! is_array( $kids ) ) continue;
                $rel_upper[ strtoupper( (string) $p ) ] = array_map( 'strtoupper', array_map( 'strval', $kids ) );
            }
            $stack = array( $sku ); $seen = array();
            while ( ! empty( $stack ) ) {
                $node = array_pop( $stack );
                if ( isset( $seen[ $node ] ) ) continue;
                $seen[ $node ] = true;
                if ( empty( $rel_upper[ $node ] ) ) {
                    if ( $node !== $sku ) $leaves[] = $node;
                    continue;
                }
                foreach ( $rel_upper[ $node ] as $c ) $stack[] = $c;
            }
            $leaves = array_values( array_unique( array_map( 'strtoupper', $leaves ) ) );
        } else {
            $leaves = array_values( array_unique( array_map( 'strtoupper', array_map( 'strval', $leaves ) ) ) );
        }
        if ( empty( $leaves ) ) return 0;

        // Count leaves NOT in maker_sku_set (fast in-memory check)
        $missing = 0;
        foreach ( $leaves as $leaf ) {
            if ( ! isset( $maker_sku_set[ $leaf ] ) ) $missing++;
        }
        return $missing;
    }
}

/**
 * V.3.3: MAIN Phase 4 classification migration — returns result array (HIGH-6 shape).
 *
 * @param bool $dry_run  Preview only — no DB mutation, emits CSV.
 * @param int  $batch    Rows per transaction (default 200).
 * @return array state JSON
 */
if ( ! function_exists( 'b2f_phase4_run_classification_migration' ) ) {
    function b2f_phase4_run_classification_migration( $dry_run = true, $batch = 200 ) {
        global $wpdb;
        $started = microtime( true );
        $started_at = current_time( 'mysql' );
        $uid = get_current_user_id();

        $state = array(
            'started_at'                 => $started_at,
            'finished_at'                => null,
            'total_rows'                 => 0,
            'processed'                  => 0,
            'classified_set_assembled'   => 0,
            'classified_sub_unit'        => 0,
            'classified_single'          => 0,
            'classified_cross_factory'   => 0,
            'auto_hidden_count'          => 0,
            'confirmed_preserved'        => 0,
            'errors'                     => array(),
            'elapsed_ms'                 => 0,
            'uid'                        => $uid,
            'dry_run'                    => (bool) $dry_run,
            'mysql_check'                => array(),
            'snapshot'                   => array(),
            'schema_alter'               => array(),
            'csv_path'                   => null,
        );

        // Normalize batch size
        $batch = max( 50, min( 2000, (int) $batch ?: 200 ) );

        // STEP 0 — lock flag (even for dry-run we set it, so concurrent CPT saves don't race)
        // V.3.11 (DB-H6): auto-clear stale lock from prior crashed run before acquiring new lock
        b2f_audit_phase4_stale_lock_autoclear( 3600 );
        if ( ! $dry_run ) {
            update_option( 'b2f_phase4_migration_in_progress', true, false );
            update_option( 'b2f_phase4_migration_started_at', time(), false );
        }

        try {
            // STEP 1 — MySQL capability probe (non-blocking)
            if ( function_exists( 'b2f_audit_check_mysql_version' ) ) {
                $state['mysql_check'] = b2f_audit_check_mysql_version();
            }

            // STEP 2 — Pre-migration snapshot (skipped in dry-run — no mutation to roll back)
            if ( ! $dry_run ) {
                if ( function_exists( 'b2f_phase4_dump_snapshot' ) ) {
                    $state['snapshot'] = b2f_phase4_dump_snapshot();
                }
            }

            // STEP 3 — Idempotent ALTER (runs ALWAYS, even in dry-run — ALTER is additive
            // + INFORMATION_SCHEMA-guarded, so it's safe and makes dry-run's SELECT work
            // without errors. Dry-run still skips row UPDATEs; only schema is made consistent.)
            if ( ! b2f_audit_junction_table_exists() ) {
                $state['errors'][] = 'junction table missing — run Activate Schema (Phase 2) first';
                $state['finished_at'] = current_time( 'mysql' );
                $state['elapsed_ms']  = round( ( microtime( true ) - $started ) * 1000, 1 );
                return $state;
            }
            $state['schema_alter'] = b2f_phase4_activate_schema_v11();
            if ( ! empty( $state['schema_alter']['errors'] ) ) {
                foreach ( $state['schema_alter']['errors'] as $se ) $state['errors'][] = 'schema_alter: ' . $se;
                // Continue — columns likely already present; SELECT will fail below if truly broken
            }

            // STEP 4 — Classification loop
            $tbl = $wpdb->prefix . 'dinoco_product_makers';

            if ( ! b2f_audit_junction_table_exists() ) {
                $state['errors'][] = 'junction table still missing — classification loop aborted';
                $state['finished_at'] = current_time( 'mysql' );
                $state['elapsed_ms']  = round( ( microtime( true ) - $started ) * 1000, 1 );
                return $state;
            }

            // Fetch all active junction rows (deleted_at IS NULL)
            // V.3.4 FIX: detect silent SELECT failure (missing V11 columns) + surface last_error
            $wpdb->last_error = '';
            $rows = $wpdb->get_results(
                "SELECT id, product_sku, maker_id, confirmation_status, confirmed_at, admin_display_mode, production_mode, legacy_cpt_id
                 FROM {$tbl}
                 WHERE deleted_at IS NULL
                 ORDER BY maker_id ASC, id ASC",
                ARRAY_A
            );
            if ( ! empty( $wpdb->last_error ) ) {
                $state['errors'][] = 'SELECT junction failed: ' . $wpdb->last_error;
                $state['finished_at'] = current_time( 'mysql' );
                $state['elapsed_ms']  = round( ( microtime( true ) - $started ) * 1000, 1 );
                if ( ! $dry_run ) {
                    delete_option( 'b2f_phase4_migration_in_progress' );
                    delete_option( 'b2f_phase4_migration_started_at' );
                }
                return $state;
            }
            if ( ! is_array( $rows ) ) $rows = array();
            $state['total_rows'] = count( $rows );

            // Build per-maker sku set (for missing-leaves probe — in-memory)
            $maker_sku_sets = array();
            foreach ( $rows as $r ) {
                $mid = (int) $r['maker_id'];
                $sku = strtoupper( trim( (string) $r['product_sku'] ) );
                if ( ! $mid || $sku === '' ) continue;
                if ( ! isset( $maker_sku_sets[ $mid ] ) ) $maker_sku_sets[ $mid ] = array();
                $maker_sku_sets[ $mid ][ $sku ] = true;
            }

            // Build sku_relations forward map (UPPERCASE keys/values)
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
            $rel_upper = array(); $all_children_map = array();
            foreach ( $relations as $p => $kids ) {
                if ( ! is_array( $kids ) ) continue;
                $p_u = strtoupper( (string) $p );
                $rel_upper[ $p_u ] = array_map( function( $c ) { return strtoupper( (string) $c ); }, $kids );
                foreach ( $rel_upper[ $p_u ] as $c ) $all_children_map[ $c ] = true;
            }

            // CSV rows for dry-run export
            $csv_rows = array();
            if ( $dry_run ) {
                $csv_rows[] = array(
                    'id','product_sku','maker_id','has_children','has_parent','missing_leaves_count',
                    'old_production_mode','new_production_mode',
                    'old_admin_display_mode','new_admin_display_mode',
                    'old_confirmation_status','new_confirmation_status',
                    'legacy_cpt_id','action'
                );
            }

            // Process in batches of $batch — START TRANSACTION per batch + 50ms gap
            $chunks = array_chunk( $rows, $batch );
            foreach ( $chunks as $chunk_idx => $chunk ) {
                if ( ! $dry_run ) $wpdb->query( 'START TRANSACTION' );
                $chunk_err = false;

                foreach ( $chunk as $row ) {
                    try {
                        $id       = (int) $row['id'];
                        $sku      = strtoupper( trim( (string) $row['product_sku'] ) );
                        $maker_id = (int) $row['maker_id'];
                        if ( ! $id || $sku === '' || ! $maker_id ) continue;

                        $maker_sku_set = isset( $maker_sku_sets[ $maker_id ] ) ? $maker_sku_sets[ $maker_id ] : array();

                        $has_children = isset( $rel_upper[ $sku ] ) && ! empty( $rel_upper[ $sku ] );
                        $has_parent   = isset( $all_children_map[ $sku ] );
                        $missing      = $has_children
                            ? b2f_phase4_count_missing_leaves( $sku, $maker_id, $maker_sku_set )
                            : 0;
                        $legacy_cpt   = (int) ( $row['legacy_cpt_id'] ?? 0 );

                        $decision = b2f_phase4_classify_row( $has_children, $has_parent, $missing, $legacy_cpt );

                        // Idempotent guard: skip rows where admin already confirmed
                        $old_conf = (string) ( $row['confirmation_status'] ?? 'auto_synced' );
                        $old_confirmed_at = $row['confirmed_at'] ?? null;
                        $is_admin_confirmed = ( $old_conf === 'confirmed' && ! empty( $old_confirmed_at ) );

                        $action = 'classify';
                        if ( $is_admin_confirmed ) {
                            // Preserve admin choice — but still update missing_leaves_count (denormalized cache)
                            $state['confirmed_preserved']++;
                            $action = 'preserve_confirmed';
                        }

                        // Track classification counts (based on decision — NOT on whether we'll write)
                        switch ( $decision['production_mode'] ) {
                            case 'set_assembled':          $state['classified_set_assembled']++; break;
                            case 'sub_unit':               $state['classified_sub_unit']++; break;
                            case 'single':                 $state['classified_single']++; break;
                            case 'cross_factory_assembly': $state['classified_cross_factory']++; break;
                        }
                        if ( $decision['admin_display_mode'] === 'as_parts' ) $state['auto_hidden_count']++;

                        if ( $dry_run ) {
                            $csv_rows[] = array(
                                $id, $sku, $maker_id,
                                $has_children ? 1 : 0,
                                $has_parent ? 1 : 0,
                                $missing,
                                (string) ( $row['production_mode'] ?? '' ),
                                $decision['production_mode'],
                                (string) ( $row['admin_display_mode'] ?? '' ),
                                $is_admin_confirmed ? (string) ( $row['admin_display_mode'] ?? '' ) : $decision['admin_display_mode'],
                                $old_conf,
                                $is_admin_confirmed ? $old_conf : $decision['confirmation_status'],
                                $legacy_cpt,
                                $is_admin_confirmed ? 'preserve_confirmed' : 'classify',
                            );
                            $state['processed']++;
                            continue;
                        }

                        // LIVE — build UPDATE
                        if ( $is_admin_confirmed ) {
                            // Only update denormalized missing_leaves_count (do not touch classification)
                            $ok = $wpdb->update(
                                $tbl,
                                array(
                                    'missing_leaves_count' => $decision['missing_leaves_count'],
                                    'updated_by'           => $uid,
                                    'updated_at'           => current_time( 'mysql' ),
                                ),
                                array( 'id' => $id ),
                                array( '%d', '%d', '%s' ),
                                array( '%d' )
                            );
                        } else {
                            // Full classification update (guarded WHERE to prevent double-flip)
                            // V.3.5 FIX: when decision->confirmation_status='confirmed' (legacy_cpt rows),
                            // CHECK constraint chk_confirmed_consistency requires confirmed_by AND
                            // confirmed_at NOT NULL. Populate both with migration uid + now.
                            $now = current_time( 'mysql' );
                            if ( $decision['confirmation_status'] === 'confirmed' ) {
                                $sql = $wpdb->prepare(
                                    "UPDATE {$tbl}
                                       SET production_mode      = %s,
                                           admin_display_mode   = %s,
                                           confirmation_status  = %s,
                                           missing_leaves_count = %d,
                                           confirmed_by         = %d,
                                           confirmed_at         = %s,
                                           updated_by           = %d,
                                           updated_at           = %s
                                     WHERE id = %d
                                       AND (confirmation_status = 'auto_synced' OR confirmed_at IS NULL)",
                                    $decision['production_mode'],
                                    $decision['admin_display_mode'],
                                    $decision['confirmation_status'],
                                    $decision['missing_leaves_count'],
                                    max( 0, (int) $uid ),
                                    $now,
                                    $uid,
                                    $now,
                                    $id
                                );
                            } else {
                                $sql = $wpdb->prepare(
                                    "UPDATE {$tbl}
                                       SET production_mode      = %s,
                                           admin_display_mode   = %s,
                                           confirmation_status  = %s,
                                           missing_leaves_count = %d,
                                           updated_by           = %d,
                                           updated_at           = %s
                                     WHERE id = %d
                                       AND (confirmation_status = 'auto_synced' OR confirmed_at IS NULL)",
                                    $decision['production_mode'],
                                    $decision['admin_display_mode'],
                                    $decision['confirmation_status'],
                                    $decision['missing_leaves_count'],
                                    $uid,
                                    $now,
                                    $id
                                );
                            }
                            $ok = $wpdb->query( $sql );
                        }
                        if ( $ok === false ) {
                            throw new Exception( 'UPDATE id=' . $id . ' failed: ' . $wpdb->last_error );
                        }
                        $state['processed']++;

                    } catch ( Throwable $e ) {
                        $state['errors'][] = 'row id=' . ( $row['id'] ?? '?' ) . ': ' . $e->getMessage();
                        $chunk_err = true;
                        break;
                    }
                } // end chunk rows

                if ( ! $dry_run ) {
                    if ( $chunk_err ) $wpdb->query( 'ROLLBACK' );
                    else              $wpdb->query( 'COMMIT' );
                }

                // Inter-batch gap to relieve lock pressure (50ms)
                if ( count( $chunks ) > 1 && $chunk_idx < count( $chunks ) - 1 ) {
                    usleep( 50000 );
                }
            }

            // Dry-run — emit CSV to b2f-backups/
            if ( $dry_run && ! empty( $csv_rows ) ) {
                $dir = b2f_phase4_ensure_backup_dir();
                if ( ! is_wp_error( $dir ) ) {
                    $ts = gmdate( 'Ymd-His' );
                    $path = $dir . "/dry-run-{$ts}.csv";
                    $fp = @fopen( $path, 'w' );
                    if ( $fp ) {
                        foreach ( $csv_rows as $line ) fputcsv( $fp, $line );
                        fclose( $fp );
                        @chmod( $path, 0600 );
                        $state['csv_path'] = $path;
                    } else {
                        $state['errors'][] = 'CSV write failed: ' . $path;
                    }
                }
            }

            // STEP 5 — Persist state (only for LIVE run)
            $state['finished_at'] = current_time( 'mysql' );
            $state['elapsed_ms']  = round( ( microtime( true ) - $started ) * 1000, 1 );
            if ( ! $dry_run ) {
                b2f_audit_set_phase4_state( $state );
            }

        } catch ( Throwable $e ) {
            $state['errors'][] = 'fatal: ' . $e->getMessage();
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[B2F Phase4] fatal exception: ' . $e->getMessage() );
            }
            $state['finished_at'] = current_time( 'mysql' );
            $state['elapsed_ms']  = round( ( microtime( true ) - $started ) * 1000, 1 );
        }

        // STEP 6 — Clear lock (always — even if we threw)
        if ( ! $dry_run ) {
            delete_option( 'b2f_phase4_migration_in_progress' );
            delete_option( 'b2f_phase4_migration_started_at' );
        }

        // STEP 7 — Fire central cache hook (maker_id=0 = global sweep)
        if ( ! $dry_run ) {
            do_action( 'b2f_junction_updated', 0 );
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf(
                '[B2F Phase4] %s processed=%d errors=%d elapsed=%sms uid=%d',
                $dry_run ? 'DRY-RUN' : 'LIVE',
                $state['processed'], count( $state['errors'] ), $state['elapsed_ms'], $uid
            ) );
        }

        return $state;
    }
}

/**
 * ดึง orphan SETs per maker — SET ที่ maker "แตะ" (มี child/leaf ของตัว SET
 * registered ใน b2f_maker_product CPT) แต่ตัว SET เองไม่ถูก registered
 */
if ( ! function_exists( 'b2f_audit_get_orphan_sets' ) ) {
    /**
     * V.1.1 STRICT RULE: SET orphan = SET ที่ maker ไม่ได้ register
     *                    + children/descendants ทั้งหมดของ SET covered โดย maker (recursive)
     *
     * FIX: เดิมใช้ "≥1 descendant" → false positive ในกรณี multi-maker SET
     * (เช่น Full Set Case = racks จาก HTP + boxes จาก maker อื่น → HTP ไม่ควร register SET)
     *
     * Coverage rule:
     * - SKU covered ถ้า (a) registered ตรงๆ หรือ (b) เป็น SET + ทุก child covered recursive
     * - leaf ที่ไม่ registered และไม่มี children → NOT covered
     */
    function b2f_audit_get_orphan_sets() {
        global $wpdb;

        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) || empty( $relations ) ) return array();

        // Normalize relations: UPPERCASE keys + children
        $rel_upper = array();
        foreach ( $relations as $parent => $children ) {
            if ( ! is_array( $children ) ) continue;
            $p_u = strtoupper( (string) $parent );
            $rel_upper[ $p_u ] = array_map( function( $c ) { return strtoupper( (string) $c ); }, $children );
        }

        // ดึง maker products ทั้งหมด
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.ID AS post_id,
                    mk.meta_value AS maker_id,
                    sk.meta_value AS sku
             FROM {$wpdb->posts} p
             LEFT JOIN {$wpdb->postmeta} mk ON mk.post_id = p.ID AND mk.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} sk ON sk.post_id = p.ID AND sk.meta_key = %s
             WHERE p.post_type = %s AND p.post_status IN ('publish','draft')",
            'mp_maker_id', 'mp_product_sku', 'b2f_maker_product'
        ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        // จัดกลุ่ม sku per maker
        $maker_skus = array();
        foreach ( $rows as $r ) {
            $mid = intval( $r['maker_id'] );
            $sku = strtoupper( trim( (string) $r['sku'] ) );
            if ( ! $mid || ! $sku ) continue;
            if ( ! isset( $maker_skus[ $mid ] ) ) $maker_skus[ $mid ] = array();
            $maker_skus[ $mid ][ $sku ] = true;
        }

        // Recursive coverage check — value-copy $visited per branch (V.7.1 pattern)
        $is_sku_covered = function( $sku_u, $maker_sku_set, $visited = array() ) use ( &$is_sku_covered, $rel_upper ) {
            if ( isset( $visited[ $sku_u ] ) ) return false; // circular guard
            $visited[ $sku_u ] = true;

            // (a) registered ตรงๆ → covered
            if ( isset( $maker_sku_set[ $sku_u ] ) ) return true;

            // (b) เป็น SET? ถ้ามี children ต้อง covered ทุกตัว
            if ( ! isset( $rel_upper[ $sku_u ] ) || empty( $rel_upper[ $sku_u ] ) ) {
                return false; // leaf + not registered → NOT covered
            }

            foreach ( $rel_upper[ $sku_u ] as $child_u ) {
                if ( ! $is_sku_covered( $child_u, $maker_sku_set, $visited ) ) {
                    return false; // any child not covered → SET not covered
                }
            }
            return true; // all children covered
        };

        // Find top-level SETs
        $all_children = array();
        foreach ( $rel_upper as $parent_u => $children ) {
            foreach ( $children as $c ) $all_children[ $c ] = true;
        }
        $top_level_sets = array();
        foreach ( $rel_upper as $parent_u => $_ ) {
            if ( ! isset( $all_children[ $parent_u ] ) ) $top_level_sets[] = $parent_u;
        }

        // Check each top-level SET per maker
        $orphans = array();
        foreach ( $maker_skus as $mid => $sku_set ) {
            foreach ( $top_level_sets as $set_sku ) {
                // skip ถ้า SET registered แล้ว
                if ( isset( $sku_set[ $set_sku ] ) ) continue;

                // STRICT: ตรวจ children ของ SET ว่า covered ครบไหม
                $all_children_covered = true;
                foreach ( $rel_upper[ $set_sku ] as $child_u ) {
                    if ( ! $is_sku_covered( $child_u, $sku_set ) ) {
                        $all_children_covered = false;
                        break;
                    }
                }

                if ( $all_children_covered ) {
                    // V.1.1: collect all leaves (grandchildren) recursively
                    $collect_leaves = function( $sku_u, $visited = array() ) use ( &$collect_leaves, $rel_upper ) {
                        if ( isset( $visited[ $sku_u ] ) ) return array();
                        $visited[ $sku_u ] = true;
                        if ( empty( $rel_upper[ $sku_u ] ) ) return array( $sku_u ); // leaf
                        $leaves = array();
                        foreach ( $rel_upper[ $sku_u ] as $child_u ) {
                            $leaves = array_merge( $leaves, $collect_leaves( $child_u, $visited ) );
                        }
                        return array_values( array_unique( $leaves ) );
                    };
                    $leaves = $collect_leaves( $set_sku );

                    // V.1.1: classify each descendant: registered | covered_by_intermediate
                    $children_detail = array();
                    foreach ( $rel_upper[ $set_sku ] as $child_u ) {
                        $leaves_of_child = $collect_leaves( $child_u );
                        $child_registered = isset( $sku_set[ $child_u ] );
                        $children_detail[] = array(
                            'sku'        => $child_u,
                            'name'       => b2f_audit_catalog_name( $child_u ),
                            'registered' => $child_registered,
                            'leaves'     => $leaves_of_child,
                            'is_set'     => ! empty( $rel_upper[ $child_u ] ),
                        );
                    }

                    // V.1.2: fetch compatible_models + category
                    $meta = function_exists( 'b2f_audit_catalog_meta' ) ? b2f_audit_catalog_meta( $set_sku ) : array( 'models' => '', 'category' => '' );

                    $orphans[] = array(
                        'maker_id'          => $mid,
                        'maker_name'        => get_the_title( $mid ),
                        'orphan_sku'        => $set_sku,
                        'orphan_name'       => b2f_audit_catalog_name( $set_sku ),
                        'compatible_models' => $meta['models'],
                        'category'          => $meta['category'],
                        'reason'            => 'Maker has ALL descendants registered — SET ควร sync',
                        'leaves'            => $leaves,
                        'leaves_count'      => count( $leaves ),
                        'children'          => $children_detail,
                        'children_count'    => count( $children_detail ),
                    );
                }
            }
        }
        return $orphans;
    }
}

/**
 * หา stale mp_unit_cost — records ที่ไม่ถูก update นานเกิน threshold (90 วัน default)
 * หรือ unit_cost ≤ 0 ทั้งที่ product อยู่ในระบบ
 */
if ( ! function_exists( 'b2f_audit_get_stale_records' ) ) {
    function b2f_audit_get_stale_records( $days = 90 ) {
        global $wpdb;
        $threshold = gmdate( 'Y-m-d H:i:s', time() - ( $days * DAY_IN_SECONDS ) );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.ID AS post_id,
                    p.post_modified_gmt,
                    mk.meta_value AS maker_id,
                    sk.meta_value AS sku,
                    uc.meta_value AS unit_cost,
                    st.meta_value AS status
             FROM {$wpdb->posts} p
             LEFT JOIN {$wpdb->postmeta} mk ON mk.post_id = p.ID AND mk.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} sk ON sk.post_id = p.ID AND sk.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} uc ON uc.post_id = p.ID AND uc.meta_key = %s
             LEFT JOIN {$wpdb->postmeta} st ON st.post_id = p.ID AND st.meta_key = %s
             WHERE p.post_type = %s
               AND p.post_status IN ('publish','draft')
               AND ( p.post_modified_gmt < %s OR CAST(uc.meta_value AS DECIMAL(12,2)) <= 0 )
             ORDER BY p.post_modified_gmt ASC",
            'mp_maker_id', 'mp_product_sku', 'mp_unit_cost', 'mp_status',
            'b2f_maker_product', $threshold
        ), ARRAY_A );
        if ( ! is_array( $rows ) ) $rows = array();

        $out = array();
        foreach ( $rows as $r ) {
            $unit = floatval( $r['unit_cost'] );
            $out[] = array(
                'post_id'      => intval( $r['post_id'] ),
                'maker_id'     => intval( $r['maker_id'] ),
                'maker_name'   => get_the_title( intval( $r['maker_id'] ) ),
                'sku'          => strtoupper( (string) $r['sku'] ),
                'unit_cost'    => $unit,
                'status'       => (string) $r['status'],
                'last_updated' => (string) $r['post_modified_gmt'],
                'reason'       => $unit <= 0 ? 'unit_cost ≤ 0' : sprintf( 'no update > %d days', $days ),
            );
        }
        return $out;
    }
}

/**
 * Per-maker parity snapshot — นับจำนวน products, orphan sets, stale records per maker
 */
if ( ! function_exists( 'b2f_audit_maker_parity' ) ) {
    function b2f_audit_maker_parity( $maker_id ) {
        global $wpdb;
        $maker_id = intval( $maker_id );
        if ( ! $maker_id ) return null;

        $maker = get_post( $maker_id );
        if ( ! $maker || $maker->post_type !== 'b2f_maker' ) return null;

        // Product count
        $count = intval( $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*)
             FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = %s AND pm.meta_value = %s
             WHERE p.post_type = %s AND p.post_status IN ('publish','draft')",
            'mp_maker_id', $maker_id, 'b2f_maker_product'
        ) ) );

        // Orphan SETs (filter from full list)
        $all_orphans = b2f_audit_get_orphan_sets();
        $my_orphans = array_values( array_filter( $all_orphans, function( $o ) use ( $maker_id ) {
            return intval( $o['maker_id'] ) === $maker_id;
        } ) );

        // Stale records (filter)
        $all_stale = b2f_audit_get_stale_records( 90 );
        $my_stale = array_values( array_filter( $all_stale, function( $s ) use ( $maker_id ) {
            return intval( $s['maker_id'] ) === $maker_id;
        } ) );

        return array(
            'maker_id'        => $maker_id,
            'maker_name'      => $maker->post_title,
            'product_count'   => $count,
            'orphan_sets'     => $my_orphans,
            'orphan_count'    => count( $my_orphans ),
            'stale_records'   => $my_stale,
            'stale_count'     => count( $my_stale ),
            'parity_score'    => b2f_audit_compute_parity_score( $count, count( $my_orphans ), count( $my_stale ) ),
        );
    }
}

if ( ! function_exists( 'b2f_audit_compute_parity_score' ) ) {
    function b2f_audit_compute_parity_score( $total, $orphans, $stale ) {
        if ( $total <= 0 ) return 100;
        $deduction = ( ( $orphans + $stale ) / max( 1, $total ) ) * 100;
        $score = max( 0, 100 - $deduction );
        return round( $score, 1 );
    }
}

/**
 * ดึง catalog name สำหรับ SKU (best-effort จาก wp_dinoco_products)
 */
if ( ! function_exists( 'b2f_audit_catalog_name' ) ) {
    function b2f_audit_catalog_name( $sku ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT name FROM {$tbl} WHERE UPPER(sku) = %s LIMIT 1",
            strtoupper( $sku )
        ) );
        return $row && $row->name ? $row->name : $sku;
    }
}

/**
 * V.1.2: ดึง compatible_models + category สำหรับ SKU (parse JSON + normalize)
 * รองรับ format: [{"brand_name":"Honda","name":"NX500"}, ...] (V.42.0 H-11)
 * Return: ['models' => 'Honda NX500, Honda CB500X', 'category' => '...']
 */
if ( ! function_exists( 'b2f_audit_catalog_meta' ) ) {
    function b2f_audit_catalog_meta( $sku ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT compatible_models, category FROM {$tbl} WHERE UPPER(sku) = %s LIMIT 1",
            strtoupper( $sku )
        ), ARRAY_A );
        if ( ! $row ) return array( 'models' => '', 'category' => '' );

        $models_str = '';
        $raw = $row['compatible_models'] ?? '';
        if ( ! empty( $raw ) ) {
            $parsed = is_string( $raw ) ? json_decode( $raw, true ) : $raw;
            if ( is_array( $parsed ) ) {
                $names = array();
                foreach ( $parsed as $m ) {
                    if ( is_string( $m ) ) {
                        $names[] = $m;
                    } elseif ( is_array( $m ) ) {
                        $brand = $m['brand_name'] ?? $m['brand'] ?? '';
                        $name  = $m['name'] ?? $m['model_name'] ?? $m['slug'] ?? '';
                        if ( $name ) {
                            $names[] = $brand ? trim( $brand . ' ' . $name ) : $name;
                        }
                    }
                }
                $models_str = implode( ', ', array_filter( $names ) );
            }
        }
        return array(
            'models'   => $models_str,
            'category' => $row['category'] ?? '',
        );
    }
}

/**
 * Build dry-run CSV (in-memory)
 *
 * Delegates to `scripts/b2f-migrate-dry-run.php` (database-expert deliverable) ถ้ามี:
 *   — script outputs CSV ไปที่ php://output ตรง → capture ด้วย ob_start
 *   — columns ของ script: maker_id, maker_name, sku, action, current_cost, computed_cost, reason, notes
 *   — actions: ADD | FLAG_STALE | REMOVE_ORPHAN
 * Fallback: inline drift + stale CSV (columns: maker_id, maker_name, sku, issue_type, details)
 *
 * NOTE: script ยิง header() + echo BOM เมื่อ non-CLI — เรา capture ob แล้ว strip BOM
 * REST endpoint จะตั้ง header เอง (ไม่ให้ซ้อน)
 */
if ( ! function_exists( 'b2f_audit_build_dry_run_csv' ) ) {
    function b2f_audit_build_dry_run_csv() {
        // V.3.1: Script path fully removed (was disabled in V.1.1, dead $candidates loop caused PHP 8.2 fatal).
        // Strict rule implemented inline via b2f_audit_get_orphan_sets() + b2f_audit_get_stale_records().
        $orphans = b2f_audit_get_orphan_sets();
        $stale   = b2f_audit_get_stale_records( 90 );

        $fh = fopen( 'php://temp', 'w+' );
        // V.1.3: + tree_view column (visual hierarchy)
        fputcsv( $fh, array(
            'maker_id', 'maker_name', 'sku', 'sku_name', 'compatible_models', 'category', 'issue_type',
            'children_count', 'leaves_count', 'children_with_grandchildren', 'all_leaves', 'tree_view', 'details'
        ) );

        foreach ( $orphans as $o ) {
            // V.1.3: children with nested grandchildren inline
            // Format: "DNCNX500001B ✓ [หลาน: -L ✓, -R ✓] | DNCNX500002B ✓ [หลาน: -L ✓, -R ✓]"
            $children_display = array();
            $tree_lines = array( '📦 ' . $o['orphan_sku'] ); // tree view column
            if ( ! empty( $o['children'] ) ) {
                foreach ( $o['children'] as $c_idx => $c ) {
                    $mark = $c['registered'] ? '✓' : ( $c['is_set'] ? '(SET covered)' : '✗' );
                    $grandchildren = ! empty( $c['leaves'] ) ? $c['leaves'] : array();
                    // remove self if this child IS a leaf
                    if ( count( $grandchildren ) === 1 && $grandchildren[0] === $c['sku'] ) {
                        $grandchildren = array(); // leaf, not a SET with grandchildren
                    }
                    if ( ! empty( $grandchildren ) ) {
                        $children_display[] = $c['sku'] . ' ' . $mark . ' [หลาน: ' . implode( ', ', $grandchildren ) . ']';
                    } else {
                        $children_display[] = $c['sku'] . ' ' . $mark . ' (leaf)';
                    }
                    // Tree view
                    $is_last = ( $c_idx === count( $o['children'] ) - 1 );
                    $prefix  = $is_last ? '└─ ' : '├─ ';
                    $tree_lines[] = $prefix . $c['sku'] . ' ' . $mark;
                    foreach ( $grandchildren as $gc_idx => $gc ) {
                        $gc_is_last = ( $gc_idx === count( $grandchildren ) - 1 );
                        $gc_prefix = ( $is_last ? '   ' : '│  ' ) . ( $gc_is_last ? '└─ ' : '├─ ' );
                        $tree_lines[] = $gc_prefix . $gc;
                    }
                }
            }
            fputcsv( $fh, array(
                $o['maker_id'],
                $o['maker_name'],
                $o['orphan_sku'],
                $o['orphan_name'] ?? '',
                $o['compatible_models'] ?? '',
                $o['category'] ?? '',
                'orphan',
                $o['children_count'] ?? 0,
                $o['leaves_count'] ?? 0,
                implode( ' | ', $children_display ),
                implode( ' | ', $o['leaves'] ?? array() ),
                implode( "\n", $tree_lines ), // V.1.3: tree view column
                $o['reason']
            ) );
        }
        foreach ( $stale as $s ) {
            fputcsv( $fh, array(
                $s['maker_id'], $s['maker_name'], $s['sku'], '', '', '',
                'stale', 0, 0, '', '', '',
                $s['reason'] . ' (last=' . $s['last_updated'] . ')'
            ) );
        }

        rewind( $fh );
        $csv = stream_get_contents( $fh );
        fclose( $fh );
        return $csv;
    }
}

