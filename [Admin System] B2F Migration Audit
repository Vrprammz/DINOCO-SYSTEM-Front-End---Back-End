add_action( 'rest_api_init', function () {

    $perm_admin = function () {
        return current_user_can( 'manage_options' );
    };

    // Rate limit wrapper — 20 req/hour per user per endpoint
    $rl = function( $endpoint ) {
        if ( ! function_exists( 'b2b_rate_limit' ) ) return true;
        $uid = get_current_user_id();
        $chk = b2b_rate_limit( 'b2f_audit_' . $endpoint . '_' . $uid, 20, HOUR_IN_SECONDS );
        return $chk;
    };

    // ─────────────────────────────────────────────
    // GET /drift — orphan SETs per maker
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/drift', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function () use ( $rl ) {
            $check = $rl( 'drift' );
            if ( is_wp_error( $check ) ) return $check;

            $orphans = b2f_audit_get_orphan_sets();
            // group by maker for UI
            $by_maker = array();
            foreach ( $orphans as $o ) {
                $mid = $o['maker_id'];
                if ( ! isset( $by_maker[ $mid ] ) ) {
                    $by_maker[ $mid ] = array(
                        'maker_id'    => $mid,
                        'maker_name'  => $o['maker_name'],
                        'orphan_count'=> 0,
                        'orphans'     => array(),
                    );
                }
                $by_maker[ $mid ]['orphans'][] = array(
                    'sku'    => $o['orphan_sku'],
                    'name'   => $o['orphan_name'],
                    'reason' => $o['reason'],
                );
                $by_maker[ $mid ]['orphan_count']++;
            }
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'total_orphans' => count( $orphans ),
                    'by_maker'      => array_values( $by_maker ),
                    'generated_at'  => current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /stale — stale mp_unit_cost records
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/stale', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'stale' );
            if ( is_wp_error( $check ) ) return $check;

            $days = intval( $req->get_param( 'days' ) );
            if ( $days <= 0 ) $days = 90;

            $stale = b2f_audit_get_stale_records( $days );
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'threshold_days' => $days,
                    'total_stale'    => count( $stale ),
                    'records'        => $stale,
                    'generated_at'   => current_time( 'mysql' ),
                ),
            ) );
        },
        'args' => array(
            'days' => array( 'type' => 'integer', 'default' => 90 ),
        ),
    ) );

    // ─────────────────────────────────────────────
    // GET /parity/{maker_id} — per-maker parity
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/parity/(?P<maker_id>\d+)', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'parity' );
            if ( is_wp_error( $check ) ) return $check;

            $mid = intval( $req->get_param( 'maker_id' ) );
            $data = b2f_audit_maker_parity( $mid );
            if ( ! $data ) {
                return new WP_Error( 'not_found', 'Maker not found', array( 'status' => 404 ) );
            }
            return rest_ensure_response( array(
                'success' => true,
                'data'    => $data,
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /dry-run — trigger + CSV download
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/dry-run', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'dryrun' );
            if ( is_wp_error( $check ) ) return $check;

            $csv = b2f_audit_build_dry_run_csv();
            $stamp = gmdate( 'Ymd-His' );
            $fname = "b2f-migration-dry-run-{$stamp}.csv";

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[B2F Audit] dry-run triggered by uid=%d', get_current_user_id() ) );
            }

            // ถ้า ?preview=1 → return JSON (for modal preview), ไม่ download
            if ( $req->get_param( 'preview' ) ) {
                $lines = array_slice( explode( "\n", $csv ), 0, 50 );
                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'preview_lines' => $lines,
                        'filename'      => $fname,
                        'size_bytes'    => strlen( $csv ),
                    ),
                ) );
            }

            if ( ! headers_sent() ) {
                header( 'Content-Type: text/csv; charset=utf-8' );
                header( 'Content-Disposition: attachment; filename="' . $fname . '"' );
                header( 'Cache-Control: no-store, no-cache, must-revalidate' );
            }
            echo $csv;
            exit;
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /feature-flags — Phase 1 LOCKED (403)
    // GET /feature-flags — readable (flag state view)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/feature-flags', array(
        array(
            'methods'             => 'GET',
            'permission_callback' => $perm_admin,
            'callback'            => function () {
                $flags = array();
                foreach ( b2f_audit_allowed_flags() as $f ) {
                    $flags[ $f ] = (bool) get_option( $f, false );
                }
                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'flags'       => $flags,
                        'phase'       => 1,
                        'setter_locked' => true,
                        'lock_reason' => 'Phase 1 = observe-only. Flag setter จะเปิดใน Phase 2 หลัง review baseline',
                    ),
                ) );
            },
        ),
        array(
            'methods'             => 'POST',
            'permission_callback' => $perm_admin,
            'callback'            => function () {
                // PHASE 1: HARDCODED 403 — setter ถูกล็อค
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( sprintf(
                        '[B2F Audit] Flag setter blocked (Phase 1 lock) — attempted by uid=%d',
                        get_current_user_id()
                    ) );
                }
                return new WP_Error(
                    'phase1_locked',
                    'Feature flag setter ล็อคใน Phase 1 (observe-only). จะเปิดใน Phase 2',
                    array( 'status' => 403 )
                );
            },
        ),
    ) );

} );


