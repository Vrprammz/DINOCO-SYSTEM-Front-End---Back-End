// ═══════════════════════════════════════════════════════════════════
// SECTION 2: REST API REGISTRATION
// ═══════════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {

    $perm_admin = function () {
        return current_user_can( 'manage_options' );
    };

    // Rate limit wrapper — 20 req/hour per user per endpoint
    $rl = function( $endpoint ) {
        if ( ! function_exists( 'b2b_rate_limit' ) ) return true;
        $uid = get_current_user_id();
        $chk = b2b_rate_limit( 'b2f_audit_' . $endpoint . '_' . $uid, 20, HOUR_IN_SECONDS );
        return $chk;
    };

    // ─────────────────────────────────────────────
    // GET /drift — orphan SETs per maker
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/drift', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function () use ( $rl ) {
            $check = $rl( 'drift' );
            if ( is_wp_error( $check ) ) return $check;

            $orphans = b2f_audit_get_orphan_sets();
            // group by maker for UI
            $by_maker = array();
            foreach ( $orphans as $o ) {
                $mid = $o['maker_id'];
                if ( ! isset( $by_maker[ $mid ] ) ) {
                    $by_maker[ $mid ] = array(
                        'maker_id'    => $mid,
                        'maker_name'  => $o['maker_name'],
                        'orphan_count'=> 0,
                        'orphans'     => array(),
                    );
                }
                $by_maker[ $mid ]['orphans'][] = array(
                    'sku'    => $o['orphan_sku'],
                    'name'   => $o['orphan_name'],
                    'reason' => $o['reason'],
                );
                $by_maker[ $mid ]['orphan_count']++;
            }
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'total_orphans' => count( $orphans ),
                    'by_maker'      => array_values( $by_maker ),
                    'generated_at'  => current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /stale — stale mp_unit_cost records
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/stale', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'stale' );
            if ( is_wp_error( $check ) ) return $check;

            $days = intval( $req->get_param( 'days' ) );
            if ( $days <= 0 ) $days = 90;

            $stale = b2f_audit_get_stale_records( $days );
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'threshold_days' => $days,
                    'total_stale'    => count( $stale ),
                    'records'        => $stale,
                    'generated_at'   => current_time( 'mysql' ),
                ),
            ) );
        },
        'args' => array(
            'days' => array( 'type' => 'integer', 'default' => 90 ),
        ),
    ) );

    // ─────────────────────────────────────────────
    // GET /parity/{maker_id} — per-maker parity
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/parity/(?P<maker_id>\d+)', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'parity' );
            if ( is_wp_error( $check ) ) return $check;

            $mid = intval( $req->get_param( 'maker_id' ) );
            $data = b2f_audit_maker_parity( $mid );
            if ( ! $data ) {
                return new WP_Error( 'not_found', 'Maker not found', array( 'status' => 404 ) );
            }
            return rest_ensure_response( array(
                'success' => true,
                'data'    => $data,
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /dry-run — trigger + CSV download
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/dry-run', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'dryrun' );
            if ( is_wp_error( $check ) ) return $check;

            $csv = b2f_audit_build_dry_run_csv();
            $stamp = gmdate( 'Ymd-His' );
            $fname = "b2f-migration-dry-run-{$stamp}.csv";

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[B2F Audit] dry-run triggered by uid=%d', get_current_user_id() ) );
            }

            // ถ้า ?preview=1 → return JSON (for modal preview), ไม่ download
            if ( $req->get_param( 'preview' ) ) {
                $lines = array_slice( explode( "\n", $csv ), 0, 50 );
                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'preview_lines' => $lines,
                        'filename'      => $fname,
                        'size_bytes'    => strlen( $csv ),
                    ),
                ) );
            }

            if ( ! headers_sent() ) {
                header( 'Content-Type: text/csv; charset=utf-8' );
                header( 'Content-Disposition: attachment; filename="' . $fname . '"' );
                header( 'Cache-Control: no-store, no-cache, must-revalidate' );
            }
            echo $csv;
            exit;
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /feature-flags — readable (flag state + phase info)
    // POST /feature-flags — DEPRECATED (ใช้ /feature-flags/toggle V.2.0 แทน)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/feature-flags', array(
        array(
            'methods'             => 'GET',
            'permission_callback' => $perm_admin,
            'callback'            => function () {
                $flags = array();
                $toggleable = b2f_audit_phase2_toggleable_flags();
                foreach ( b2f_audit_allowed_flags() as $f ) {
                    $flags[ $f ] = array(
                        'value'       => (bool) get_option( $f, false ),
                        'toggleable'  => in_array( $f, $toggleable, true ),
                        'lock_reason' => in_array( $f, $toggleable, true )
                            ? null
                            : ( $f === 'b2f_flag_auto_sync_sets'
                                ? 'Phase 2.5 flag — auto-sync SETs ต้อง review baseline ก่อน'
                                : 'Phase 3 flag — cut-over read path ต้อง dual-write stable ก่อน' ),
                    );
                }
                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'flags'              => $flags,
                        'phase'              => 2,
                        'schema_activated'   => b2f_audit_is_schema_activated(),
                        'backfill_state'     => b2f_audit_get_backfill_state(),
                        'junction_exists'    => b2f_audit_junction_table_exists(),
                        'observations_exists'=> b2f_audit_observations_table_exists(),
                    ),
                ) );
            },
        ),
        array(
            'methods'             => 'POST',
            'permission_callback' => $perm_admin,
            'callback'            => function () {
                return new WP_Error(
                    'deprecated',
                    'ใช้ POST /feature-flags/toggle แทน (V.2.0)',
                    array( 'status' => 410 )
                );
            },
        ),
    ) );

    // ─────────────────────────────────────────────
    // POST /feature-flags/toggle — V.2.0 toggle whitelist flag
    // Params: { flag_name, value (bool), confirm (true required) }
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/feature-flags/toggle', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'flag_toggle' );
            if ( is_wp_error( $check ) ) return $check;

            $flag    = sanitize_key( (string) $req->get_param( 'flag_name' ) );
            $value   = filter_var( $req->get_param( 'value' ), FILTER_VALIDATE_BOOLEAN, FILTER_NULL_ON_FAILURE );
            $confirm = (bool) $req->get_param( 'confirm' );

            if ( ! $confirm ) {
                return new WP_Error( 'confirm_required', 'ต้องส่ง confirm=true เพื่อยืนยันการ toggle flag', array( 'status' => 400 ) );
            }
            if ( $value === null ) {
                return new WP_Error( 'invalid_value', 'value ต้องเป็น boolean (true/false)', array( 'status' => 400 ) );
            }
            if ( ! in_array( $flag, b2f_audit_allowed_flags(), true ) ) {
                return new WP_Error( 'invalid_flag', 'flag_name ไม่อยู่ใน allowed list', array( 'status' => 400 ) );
            }
            if ( ! in_array( $flag, b2f_audit_phase2_toggleable_flags(), true ) ) {
                return new WP_Error(
                    'flag_locked',
                    sprintf( 'Flag %s ยังล็อคอยู่ (Phase 2.5 หรือ Phase 3 เท่านั้น)', $flag ),
                    array( 'status' => 403 )
                );
            }

            // Guard: shadow_write ต้องมี schema + backfill เสร็จก่อน
            if ( $flag === 'b2f_flag_shadow_write' && $value === true ) {
                if ( ! b2f_audit_is_schema_activated() ) {
                    return new WP_Error(
                        'schema_not_ready',
                        'ต้อง Activate Schema ก่อนเปิด shadow_write',
                        array( 'status' => 409 )
                    );
                }
                $state = b2f_audit_get_backfill_state();
                if ( empty( $state['ran_at'] ) ) {
                    return new WP_Error(
                        'backfill_not_ready',
                        'ต้อง Run Backfill ก่อนเปิด shadow_write',
                        array( 'status' => 409 )
                    );
                }
            }

            $old = (bool) get_option( $flag, false );
            $new = (bool) $value;
            update_option( $flag, $new, false );
            if ( function_exists( 'b2f_log_flag_change' ) ) {
                b2f_log_flag_change( $flag, $old, $new, get_current_user_id() );
            } elseif ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[B2F Audit] flag toggle %s: %s → %s by uid=%d', $flag, var_export($old,true), var_export($new,true), get_current_user_id() ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'flag_name' => $flag,
                    'old_value' => $old,
                    'new_value' => $new,
                    'changed_at'=> current_time( 'mysql' ),
                    'uid'       => get_current_user_id(),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /activate-schema — V.2.0 dbDelta canonical tables
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/activate-schema', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            // destructive action — stricter rate limit (5/hr)
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_activate_' . $uid, 5, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm = (bool) $req->get_param( 'confirm' );
            if ( ! $confirm ) {
                return new WP_Error( 'confirm_required', 'ต้องส่ง confirm=true เพื่อยืนยัน schema activation (destructive action)', array( 'status' => 400 ) );
            }

            if ( b2f_audit_is_schema_activated() ) {
                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'already_activated' => true,
                        'activated_at'      => get_option( 'b2f_schema_v10_activated' ),
                        'schema_version'    => get_option( 'b2f_schema_version', 'unknown' ),
                        'junction_exists'   => b2f_audit_junction_table_exists(),
                    ),
                ) );
            }

            if ( ! function_exists( 'b2f_audit_activate_schema_v10' ) ) {
                // database-expert ยังไม่ commit
                return new WP_Error(
                    'not_implemented',
                    'b2f_audit_activate_schema_v10() ยังไม่ deploy (รอ database-expert commit). ตรวจสอบว่า Phase 2 schema snippet sync แล้วหรือยัง',
                    array( 'status' => 501 )
                );
            }

            try {
                $started = microtime( true );
                $result  = b2f_audit_activate_schema_v10();
                $elapsed = round( ( microtime( true ) - $started ) * 1000, 1 );

                $junction_ok = b2f_audit_junction_table_exists();
                $obs_ok      = b2f_audit_observations_table_exists();

                if ( $junction_ok ) {
                    update_option( 'b2f_schema_v10_activated', current_time( 'mysql' ), false );
                    if ( ! get_option( 'b2f_schema_version' ) ) {
                        update_option( 'b2f_schema_version', '10.1', false );
                    }
                }

                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( sprintf(
                        '[B2F Audit] Schema activation: junction=%d obs=%d elapsed=%sms by uid=%d',
                        $junction_ok ? 1 : 0, $obs_ok ? 1 : 0, $elapsed, get_current_user_id()
                    ) );
                }

                return rest_ensure_response( array(
                    'success' => true,
                    'data'    => array(
                        'junction_created'    => $junction_ok,
                        'observations_created'=> $obs_ok,
                        'schema_version'      => get_option( 'b2f_schema_version', '10.1' ),
                        'activated_at'        => get_option( 'b2f_schema_v10_activated' ),
                        'elapsed_ms'          => $elapsed,
                        'raw_result'          => is_array( $result ) ? $result : array(),
                    ),
                ) );
            } catch ( Throwable $e ) {
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] Schema activation error: ' . $e->getMessage() );
                }
                return new WP_Error( 'activation_failed', 'Schema activation failed: ' . $e->getMessage(), array( 'status' => 500 ) );
            }
        },
    ) );

    // ─────────────────────────────────────────────
    // POST /backfill — V.2.0 run Phase 2 backfill script
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/backfill', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) {
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $uid = get_current_user_id();
                $chk = b2b_rate_limit( 'b2f_audit_backfill_' . $uid, 5, HOUR_IN_SECONDS );
                if ( is_wp_error( $chk ) ) return $chk;
            }

            $confirm = (bool) $req->get_param( 'confirm' );
            $dry_run = (bool) $req->get_param( 'dry_run' );
            if ( ! $confirm && ! $dry_run ) {
                return new WP_Error( 'confirm_required', 'ต้องส่ง confirm=true หรือ dry_run=1', array( 'status' => 400 ) );
            }

            if ( ! b2f_audit_is_schema_activated() ) {
                return new WP_Error( 'schema_not_ready', 'ต้อง Activate Schema ก่อน run Backfill', array( 'status' => 409 ) );
            }

            // V.2.1: inline backfill (ไม่ต้องใช้ script ภายนอก — WP Code Snippets ไม่ sync scripts/ folder)
            if ( ! function_exists( 'b2f_phase2_run_backfill' ) ) {
                return new WP_Error(
                    'not_implemented',
                    'b2f_phase2_run_backfill() ไม่พบ — audit snippet V.2.1 ต้อง activate',
                    array( 'status' => 501 )
                );
            }

            $started = microtime( true );
            $result = array();

            try {
                $result = b2f_phase2_run_backfill( $dry_run, get_current_user_id() );
                if ( ! is_array( $result ) ) $result = array();
            } catch ( Throwable $e ) {
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[B2F Audit] Backfill error: ' . $e->getMessage() );
                }
                return new WP_Error( 'backfill_failed', 'Backfill failed: ' . $e->getMessage(), array( 'status' => 500 ) );
            }

            $elapsed = round( ( microtime( true ) - $started ) * 1000, 1 );

            // Normalize result keys
            $summary = array(
                'ran_at'        => current_time( 'mysql' ),
                'dry_run'       => $dry_run,
                'cpt_migrated'  => intval( $result['cpt_migrated'] ?? ( $result['migrated'] ?? 0 ) ),
                'orphans_added' => intval( $result['orphans_added'] ?? 0 ),
                'errors'        => is_array( $result['errors'] ?? null ) ? $result['errors'] : array(),
                'skipped'       => intval( $result['skipped'] ?? 0 ),
                'elapsed_ms'    => $elapsed,
                'uid'           => get_current_user_id(),
            );

            // Persist state only for real runs
            if ( ! $dry_run ) {
                b2f_audit_set_backfill_state( $summary );
            }

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[B2F Audit] Backfill %s: migrated=%d orphans=%d errors=%d elapsed=%sms by uid=%d',
                    $dry_run ? 'DRY' : 'LIVE',
                    $summary['cpt_migrated'], $summary['orphans_added'], count( $summary['errors'] ),
                    $elapsed, get_current_user_id()
                ) );
            }

            return rest_ensure_response( array(
                'success' => true,
                'data'    => $summary,
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /backfill-status — V.2.0 read last run summary
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/backfill-status', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function () {
            $state = b2f_audit_get_backfill_state();
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            $junction_count = b2f_audit_junction_table_exists()
                ? intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl}" ) )
                : null;
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'state'            => $state,
                    'junction_count'   => $junction_count,
                    'schema_activated' => b2f_audit_is_schema_activated(),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /junction-snapshot — V.2.0 read recent junction rows
    // Params: maker_id (optional), status (optional), limit (default 50)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/junction-snapshot', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'junction_snapshot' );
            if ( is_wp_error( $check ) ) return $check;

            if ( ! b2f_audit_junction_table_exists() ) {
                return new WP_Error( 'table_missing', 'junction table ยังไม่ถูกสร้าง (Activate Schema ก่อน)', array( 'status' => 404 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';

            $maker_id = intval( $req->get_param( 'maker_id' ) );
            $status   = sanitize_text_field( (string) $req->get_param( 'status' ) );
            $limit    = max( 1, min( 500, intval( $req->get_param( 'limit' ) ) ?: 50 ) );

            $where  = array( '1=1' );
            $params = array();
            if ( $maker_id > 0 ) { $where[] = 'maker_id = %d'; $params[] = $maker_id; }
            if ( $status !== '' && in_array( $status, array('active','discontinued','pending'), true ) ) {
                $where[] = 'status = %s'; $params[] = $status;
            }
            $where_sql = implode( ' AND ', $where );

            $sql = "SELECT id, product_sku, maker_id, unit_cost, moq, lead_time_days, shipping_land, shipping_sea,
                           status, notes, legacy_cpt_id, created_by, updated_by, created_at, updated_at, deleted_at
                    FROM {$tbl}
                    WHERE {$where_sql}
                    ORDER BY updated_at DESC
                    LIMIT %d";
            $params[] = $limit;
            $rows = $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );
            if ( ! is_array( $rows ) ) $rows = array();

            // Enrich with maker names
            $maker_ids = array_unique( array_map( 'intval', array_column( $rows, 'maker_id' ) ) );
            $maker_names = array();
            foreach ( $maker_ids as $mid ) {
                if ( $mid ) $maker_names[ $mid ] = get_the_title( $mid );
            }
            foreach ( $rows as &$r ) {
                $r['maker_name'] = $maker_names[ intval( $r['maker_id'] ) ] ?? '';
            }
            unset( $r );

            // Summary counts
            $total      = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl}" ) );
            $active     = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE status='active' AND deleted_at IS NULL" ) );
            $discont    = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE status='discontinued'" ) );

            // CPT count for comparison
            $cpt_count = intval( $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->posts} WHERE post_type=%s AND post_status IN ('publish','draft')",
                'b2f_maker_product'
            ) ) );

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'rows'        => $rows,
                    'returned'    => count( $rows ),
                    'limit'       => $limit,
                    'summary'     => array(
                        'total'        => $total,
                        'active'       => $active,
                        'discontinued' => $discont,
                        'cpt_count'    => $cpt_count,
                        'diff_vs_cpt'  => $total - $cpt_count,
                    ),
                    'generated_at'=> current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

    // ─────────────────────────────────────────────
    // GET /observations — V.2.0 read recent diff observations
    // Params: diff_only (bool), maker_id, limit (default 50)
    // ─────────────────────────────────────────────
    register_rest_route( B2F_AUDIT_NS, '/observations', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function ( $req ) use ( $rl ) {
            $check = $rl( 'observations' );
            if ( is_wp_error( $check ) ) return $check;

            if ( ! b2f_audit_observations_table_exists() ) {
                return new WP_Error( 'table_missing', 'observations table ยังไม่ถูกสร้าง (Activate Schema ก่อน)', array( 'status' => 404 ) );
            }

            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_maker_product_observations';

            $diff_only = filter_var( $req->get_param( 'diff_only' ), FILTER_VALIDATE_BOOLEAN );
            $maker_id  = intval( $req->get_param( 'maker_id' ) );
            $limit     = max( 1, min( 500, intval( $req->get_param( 'limit' ) ) ?: 50 ) );

            $where  = array( '1=1' );
            $params = array();
            if ( $diff_only )      { $where[] = 'diff_detected = 1'; }
            if ( $maker_id > 0 )   { $where[] = 'maker_id = %d'; $params[] = $maker_id; }
            $where_sql = implode( ' AND ', $where );

            $sql = "SELECT id, observed_at, source, sku, maker_id, field_name, cpt_value, junction_value, diff_detected
                    FROM {$tbl}
                    WHERE {$where_sql}
                    ORDER BY observed_at DESC
                    LIMIT %d";
            $params[] = $limit;
            $rows = empty( $params ) || count( $params ) === 1
                ? $wpdb->get_results( $wpdb->prepare( $sql, $limit ), ARRAY_A )
                : $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );
            if ( ! is_array( $rows ) ) $rows = array();

            $maker_ids = array_unique( array_map( 'intval', array_column( $rows, 'maker_id' ) ) );
            $maker_names = array();
            foreach ( $maker_ids as $mid ) { if ( $mid ) $maker_names[ $mid ] = get_the_title( $mid ); }
            foreach ( $rows as &$r ) {
                $r['maker_name'] = $maker_names[ intval( $r['maker_id'] ) ] ?? '';
            }
            unset( $r );

            $total = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl}" ) );
            $diffs = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE diff_detected=1" ) );
            $last24 = intval( $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE observed_at > DATE_SUB(NOW(), INTERVAL 24 HOUR)" ) );

            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'rows'        => $rows,
                    'returned'    => count( $rows ),
                    'limit'       => $limit,
                    'summary'     => array(
                        'total'       => $total,
                        'diffs'       => $diffs,
                        'last_24h'    => $last24,
                    ),
                    'generated_at'=> current_time( 'mysql' ),
                ),
            ) );
        },
    ) );

} );


