function showLightbox(photos, idx) {
    var overlay = document.createElement("div");
    overlay.className = "liff-ai-lightbox";
    overlay.innerHTML = '<button class="liff-ai-lightbox-close">&#10005;</button><img src="' + esc(photos[idx] || "") + '" alt="รูปเต็ม">';

    overlay.querySelector(".liff-ai-lightbox-close").addEventListener("click", function() {
        document.body.removeChild(overlay);
    });
    overlay.addEventListener("click", function(e) {
        if (e.target === overlay) document.body.removeChild(overlay);
    });

    // Swipe left/right
    var startX = 0;
    overlay.addEventListener("touchstart", function(e) { startX = e.touches[0].clientX; });
    overlay.addEventListener("touchend", function(e) {
        var diff = e.changedTouches[0].clientX - startX;
        if (Math.abs(diff) > 50) {
            if (diff < 0 && idx < photos.length - 1) idx++;
            else if (diff > 0 && idx > 0) idx--;
            overlay.querySelector("img").src = photos[idx];
        }
    });

    document.body.appendChild(overlay);
}

