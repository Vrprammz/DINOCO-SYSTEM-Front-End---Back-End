// BOTTOM NAVIGATION (V.2.0)
// ══════════════════════════════════════════════════════════════

function renderBottomNav(activePage) {
    // Remove existing
    var existing = document.querySelector(".liff-ai-bottom-nav");
    if (existing) existing.remove();

    var nav = document.createElement("div");
    nav.className = "liff-ai-bottom-nav";

    var items = [];
    if (ROLE === "admin") {
        items = [
            { page: "dashboard", icon: "&#128202;", label: "สรุป" },
            { page: "leads",     icon: "&#127919;", label: "Leads" },
            { page: "claims",    icon: "&#128203;", label: "เคลม" },
            { page: "agent",     icon: "&#129302;", label: "AI" },
        ];
    } else {
        // Dealer — only dashboard + leads
        items = [
            { page: "dealer", icon: "&#128202;", label: "สรุป" },
            { page: "leads",  icon: "&#127919;", label: "Leads" },
        ];
    }

    items.forEach(function(item) {
        var btn = document.createElement("button");
        btn.innerHTML = '<span class="nav-icon">' + item.icon + '</span><span>' + item.label + '</span>';
        if (item.page === activePage) btn.classList.add("active");
        btn.addEventListener("click", function() { navigate(item.page); });
        nav.appendChild(btn);
    });

    document.body.appendChild(nav);
}

function updateBottomNav() {
    var params = new URLSearchParams(window.location.search);
    var page = params.get("page") || (ROLE === "dealer" ? "dealer" : "dashboard");
    var navBtns = document.querySelectorAll(".liff-ai-bottom-nav button");
    // We re-render nav on route, so this is a safety fallback
    if (navBtns.length === 0) renderBottomNav(page);
}


