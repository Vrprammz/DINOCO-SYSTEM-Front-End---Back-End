async function renderLeadList(filter) {
    showLoading("กำลังโหลด Lead...");
    var params = {};
    if (filter && filter !== "all") params.status = filter;

    var res = await api("GET", "leads", params);
    if (!res.success) { showError("โหลดไม่สำเร็จ", res.message || ""); return; }

    var html = '';
    // Header
    html += '<div class="liff-ai-header">';
    html += '<div class="liff-ai-header-top">';
    html += '<button class="liff-ai-detail-back" id="backBtn">&#8592; กลับ</button>';
    html += '<div class="liff-ai-header-info"><div class="liff-ai-header-title">Lead ทั้งหมด</div><div class="liff-ai-header-sub">' + (res.total || 0) + ' รายการ</div></div>';
    html += '</div></div>';

    // Filters
    html += '<div class="liff-ai-filters" style="padding-top:12px;">';
    var filters = [
        { key: "all", label: "ทั้งหมด" },
        { key: "dealer_notified", label: "รอรับ" },
        { key: "checking_contact", label: "กำลังติดต่อ" },
        { key: "waiting_order", label: "รอสั่ง" },
        { key: "closed_satisfied", label: "ปิดงาน" },
    ];
    filters.forEach(function(f) {
        var active = (!filter && f.key === "all") || filter === f.key ? " active" : "";
        html += '<button class="liff-ai-filter-btn' + active + '" data-filter="' + f.key + '">' + f.label + '</button>';
    });
    html += '</div>';

    // Leads
    var leads = res.data || [];
    if (leads.length === 0) {
        html += '<div class="liff-ai-empty"><div class="icon">&#128269;</div><p>ไม่พบ Lead</p></div>';
    } else {
        leads.forEach(function(lead) {
            html += renderLeadCard(lead);
        });
    }

    var app = $("#liffAiApp");
    app.innerHTML = html;

    // Bind
    var backBtn = $("#backBtn");
    if (backBtn) backBtn.addEventListener("click", function() {
        navigate(ROLE === "dealer" ? "dealer" : "dashboard");
    });

    app.querySelectorAll("[data-lead-id]").forEach(function(el) {
        el.addEventListener("click", function() {
            navigate("lead", { id: el.dataset.leadId });
        });
    });

    app.querySelectorAll("[data-filter]").forEach(function(el) {
        el.addEventListener("click", function() {
            renderLeadList(el.dataset.filter === "all" ? null : el.dataset.filter);
        });
    });
}

function renderLeadCard(lead) {
    var id = lead._id || lead.id || "";
    var status = lead.status || "lead_created";
    var badgeCls = statusBadgeClass(status);

    var html = '<div class="liff-ai-lead-card" data-lead-id="' + esc(id) + '" style="margin: 0 16px 8px;">';
    html += '<div class="liff-ai-lead-top">';
    html += '<div>';
    html += '<div class="liff-ai-lead-name">' + esc(lead.customerName || "ลูกค้า") + '</div>';
    html += '<div class="liff-ai-lead-product">' + esc(lead.productInterest || "-") + '</div>';
    html += '</div>';
    html += '<span class="liff-ai-badge liff-ai-badge-' + badgeCls + '">' + esc(LEAD_STATUS_TH[status] || status) + '</span>';
    html += '</div>';
    html += '<div class="liff-ai-lead-meta">';
    if (lead.platform) html += '<span>' + esc(lead.platform.toUpperCase()) + '</span>';
    if (lead.province) html += '<span>' + esc(lead.province) + '</span>';
    html += '<span>' + timeAgo(lead.createdAt) + '</span>';
    html += '</div>';
    html += '</div>';
    return html;
}


