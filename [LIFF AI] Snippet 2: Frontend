async function renderClaimList(filter) {
    showLoading("กำลังโหลดเคลม...");
    var params = {};
    if (filter && filter !== "all") params.status = filter;

    var res = await api("GET", "claims", params);
    if (!res.success) { showError("โหลดไม่สำเร็จ", res.message || ""); return; }

    var html = '';
    // Header
    html += '<div class="liff-ai-header">';
    html += '<div class="liff-ai-header-top">';
    html += '<button class="liff-ai-detail-back" id="backBtn">&#8592; กลับ</button>';
    html += '<div class="liff-ai-header-info"><div class="liff-ai-header-title">เคลมทั้งหมด</div><div class="liff-ai-header-sub">' + (res.total || 0) + ' รายการ</div></div>';
    html += '</div></div>';

    // Filters
    html += '<div class="liff-ai-filters" style="padding-top:12px;">';
    var filters = [
        { key: "all", label: "ทั้งหมด" },
        { key: "pending", label: "รอตรวจ" },
        { key: "reviewing", label: "กำลังดำเนินการ" },
        { key: "completed", label: "เสร็จ" },
        { key: "rejected", label: "ปฏิเสธ" },
    ];
    filters.forEach(function(f) {
        var active = (!filter && f.key === "all") || filter === f.key ? " active" : "";
        html += '<button class="liff-ai-filter-btn' + active + '" data-claim-filter="' + f.key + '">' + f.label + '</button>';
    });
    html += '</div>';

    // Claims
    var claims = res.data || [];
    if (claims.length === 0) {
        html += '<div class="liff-ai-empty"><div class="icon">&#128269;</div><p>ไม่พบใบเคลม</p></div>';
    } else {
        claims.forEach(function(claim) {
            html += renderClaimCard(claim);
        });
    }

    var app = $("#liffAiApp");
    app.innerHTML = html;
    renderBottomNav("claims");

    // Bind
    var backBtn = $("#backBtn");
    if (backBtn) backBtn.addEventListener("click", function() { navigate("dashboard"); });

    app.querySelectorAll("[data-claim-id]").forEach(function(el) {
        el.addEventListener("click", function() { navigate("claim", { id: el.dataset.claimId }); });
    });

    app.querySelectorAll("[data-claim-filter]").forEach(function(el) {
        el.addEventListener("click", function() {
            renderClaimList(el.dataset.claimFilter === "all" ? null : el.dataset.claimFilter);
