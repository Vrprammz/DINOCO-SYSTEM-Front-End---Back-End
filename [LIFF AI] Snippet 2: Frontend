        { key: "dealer_notified", label: "รอรับ" },
        { key: "checking_contact", label: "กำลังติดต่อ" },
        { key: "waiting_order", label: "รอสั่ง" },
        { key: "closed_satisfied", label: "ปิดงาน" },
    ];
    filters.forEach(function(f) {
        var active = (!filter && f.key === "all") || filter === f.key ? " active" : "";
        html += '<button class="liff-ai-filter-btn' + active + '" data-filter="' + f.key + '">' + f.label + '</button>';
    });
    html += '</div>';

    // Leads
    var leads = res.data || [];
    if (leads.length === 0) {
        html += '<div class="liff-ai-empty"><div class="icon">&#128269;</div><p>ไม่พบ Lead</p></div>';
