async function loadUrgentSection() {
    var urgentEl = $("#urgentSection");
    if (!urgentEl) return;

    var html = '';
    // Fetch needs_attention leads
    try {
        var leadsRes = await api("GET", "leads", { status: "dealer_no_response", limit: 5 });
        var needsAttention = (leadsRes.success && leadsRes.data) ? leadsRes.data : [];
        needsAttention.forEach(function(lead) {
            html += '<div class="liff-ai-urgent-card" data-nav-lead="' + esc(lead._id || lead.id) + '">';
            html += '<div class="liff-ai-urgent-label">Lead ไม่ตอบ</div>';
            html += '<div class="liff-ai-urgent-text">' + esc(lead.customerName || "ลูกค้า") + ' - ' + esc(lead.productInterest || "") + '</div>';
            html += '<div class="liff-ai-urgent-sub">' + timeAgo(lead.createdAt) + '</div>';
            html += '</div>';
        });
    } catch(e) {}

    // Fetch pending claims
    try {
        var claimsRes = await api("GET", "claims", { status: "pending", limit: 5 });
        var pendingClaims = (claimsRes.success && claimsRes.data) ? claimsRes.data : [];
        pendingClaims.forEach(function(claim) {
            html += '<div class="liff-ai-urgent-card" data-nav-claim="' + claim.id + '">';
            html += '<div class="liff-ai-urgent-label">เคลมรอตรวจ</div>';
            html += '<div class="liff-ai-urgent-text">#' + esc(claim.ticket || claim.id) + ' - ' + esc(claim.customer || "") + '</div>';
            html += '<div class="liff-ai-urgent-sub">' + esc(claim.product || "") + ' | ' + timeAgo(claim.created_at) + '</div>';
            html += '</div>';
        });
    } catch(e) {}

    if (!html) {
        html = '<div class="liff-ai-empty" style="padding:16px;"><p>ไม่มีรายการเร่งด่วน</p></div>';
    }

    urgentEl.innerHTML = html;

    // Bind clicks
    urgentEl.querySelectorAll("[data-nav-lead]").forEach(function(el) {
        el.addEventListener("click", function() { navigate("lead", { id: el.dataset.navLead }); });
    });
    urgentEl.querySelectorAll("[data-nav-claim]").forEach(function(el) {
        el.addEventListener("click", function() { navigate("claim", { id: el.dataset.navClaim }); });
    });
}


