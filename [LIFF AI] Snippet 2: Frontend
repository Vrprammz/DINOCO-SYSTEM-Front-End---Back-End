<script>
(function(){
"use strict";

var LIFF_ID  = <?php echo wp_json_encode( $liff_id ); ?>;
var API      = <?php echo wp_json_encode( $rest_url ); ?>;
var LOGO_URL = <?php echo wp_json_encode( $logo_url ); ?>;

var TOKEN    = null;
var ROLE     = null;
var AUTH     = null;
var LINE_UID = null;

// ══════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════

function $(s) { return document.querySelector(s); }
function $$(s) { return document.querySelectorAll(s); }
function esc(s) { var d = document.createElement("div"); d.appendChild(document.createTextNode(s||"")); return d.innerHTML; }

function api(method, path, body) {
    var headers = { "Content-Type": "application/json" };
    var opts = { method: method, headers: headers };
    if (TOKEN) headers["X-LIFF-AI-Token"] = TOKEN;
    if (body && method !== "GET") opts.body = JSON.stringify(body);
    var url = API + path;
    if (body && method === "GET") {
        var qs = new URLSearchParams(body).toString();
        if (qs) url += (url.indexOf("?") > -1 ? "&" : "?") + qs;
    }
    return fetch(url, opts).then(function(r) { return r.json(); });
}

function toast(msg, type) {
    var el = $("#liffAiToast");
    el.textContent = msg;
    el.className = "liff-ai-toast " + (type||"") + " show";
    setTimeout(function() { el.classList.remove("show"); }, 3000);
}

function timeAgo(dateStr) {
    if (!dateStr) return "-";
    var diff = (Date.now() - new Date(dateStr).getTime()) / 1000;
    if (diff < 60) return "เมื่อสักครู่";
    if (diff < 3600) return Math.floor(diff/60) + " นาทีที่แล้ว";
    if (diff < 86400) return Math.floor(diff/3600) + " ชั่วโมงที่แล้ว";
    return Math.floor(diff/86400) + " วันที่แล้ว";
}

function formatDate(dateStr) {
    if (!dateStr) return "-";
    var d = new Date(dateStr);
    return d.toLocaleDateString("th-TH", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" });
}

var LEAD_STATUS_TH = {
    lead_created: "สร้างใหม่", dealer_notified: "แจ้งตัวแทนแล้ว",
    checking_contact: "กำลังติดต่อ", dealer_contacted: "ติดต่อลูกค้าแล้ว",
    dealer_no_response: "ตัวแทนไม่ตอบ", waiting_order: "รอสั่งซื้อ",
    order_placed: "สั่งซื้อแล้ว", waiting_delivery: "รอจัดส่ง",
    delivered: "จัดส่งแล้ว", waiting_install: "รอติดตั้ง",
    installed: "ติดตั้งแล้ว", satisfaction_checked: "สอบถามแล้ว",
    closed_satisfied: "ปิด (พอใจ)", closed_lost: "ปิด (สูญเสีย)",
    closed_cancelled: "ยกเลิก", admin_escalated: "ส่งต่อแอดมิน", dormant: "พักงาน"
};

function statusBadgeClass(status) {
    if (!status) return "muted";
    if (status.indexOf("closed_satisfied") > -1 || status === "installed" || status === "delivered") return "success";
    if (status.indexOf("closed_") > -1 || status === "dealer_no_response") return "danger";
    if (status === "lead_created" || status === "dealer_notified") return "new";
    return "active";
}

// Lead status timeline steps (simplified for Dealer view)
var TIMELINE_STEPS = [
    { key: "lead_created", label: "สร้าง Lead" },
    { key: "dealer_notified", label: "แจ้งตัวแทน" },
    { key: "checking_contact", label: "กำลังติดต่อ" },
    { key: "dealer_contacted", label: "ติดต่อลูกค้า" },
    { key: "waiting_order", label: "รอสั่งซื้อ" },
    { key: "order_placed", label: "สั่งซื้อแล้ว" },
    { key: "delivered", label: "จัดส่ง" },
    { key: "installed", label: "ติดตั้ง" },
    { key: "closed_satisfied", label: "ปิดงาน" },
];

function getTimelineIndex(status) {
    for (var i = 0; i < TIMELINE_STEPS.length; i++) {
        if (TIMELINE_STEPS[i].key === status) return i;
    }
    return -1;
}

// ══════════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════════

async function init() {
    try {
        if (!LIFF_ID) { showError("ระบบยังไม่ถูกตั้งค่า", "กรุณาตั้งค่า LIFF ID"); return; }

        await liff.init({ liffId: LIFF_ID });

        if (!liff.isLoggedIn()) {
            liff.login({ redirectUri: window.location.href });
            return;
        }

        var profile = await liff.getProfile();
        var idToken = liff.getIDToken() || "";
        LINE_UID = profile.userId;

        // Auth
        var res = await api("POST", "auth", {
            line_user_id: profile.userId,
            id_token: idToken,
        });

        if (!res.authorized) {
            showError("ไม่มีสิทธิ์เข้าใช้งาน", res.message || "กรุณาติดต่อแอดมิน");
            return;
        }

        TOKEN = res.token;
        ROLE  = res.role;
        AUTH  = res;

        // Route
        var params = new URLSearchParams(window.location.search);
        var page = params.get("page") || "";

        if (!page) {
            page = ROLE === "dealer" ? "dealer" : "dashboard";
        }

        route(page, params);

    } catch (err) {
        console.error("LIFF AI init error:", err);
        showError("เกิดข้อผิดพลาด", "ไม่สามารถเปิดหน้านี้ได้ กรุณาลองใหม่");
    }
}

function route(page, params) {
    switch (page) {
        case "dashboard": renderAdminDashboard(); break;
        case "dealer":    renderDealerDashboard(); break;
        case "lead":      renderLeadDetail(params.get("id")); break;
        case "claim":     renderClaimDetail(params.get("id")); break;
        case "leads":     renderLeadList(); break;
        default:
            if (ROLE === "dealer") renderDealerDashboard();
            else renderAdminDashboard();
    }
}

function navigate(page, params) {
    var url = new URL(window.location.href);
    url.searchParams.set("page", page);
    if (params) {
        Object.keys(params).forEach(function(k) { url.searchParams.set(k, params[k]); });
    }
    window.history.pushState({}, "", url);
    var sp = new URLSearchParams(url.search);
    route(page, sp);
}

// Handle browser back
window.addEventListener("popstate", function() {
    var params = new URLSearchParams(window.location.search);
    var page = params.get("page") || (ROLE === "dealer" ? "dealer" : "dashboard");
    route(page, params);
});

function showError(title, msg) {
    var app = $("#liffAiApp");
    app.innerHTML = '<div class="liff-ai-error"><div class="icon">&#128274;</div><h2>' + esc(title) + '</h2><p>' + esc(msg) + '</p></div>';
}

function showLoading(msg) {
    var app = $("#liffAiApp");
