    html += '<div class="liff-ai-header-top">';
    html += '<img src="' + esc(LOGO_URL) + '" class="liff-ai-logo" alt="DINOCO">';
    html += '<div class="liff-ai-header-info"><div class="liff-ai-header-title">AI Assistant</div><div class="liff-ai-header-sub">DINOCO AI</div></div>';
    html += '</div></div>';

    // Chat area
    html += '<div class="liff-ai-chat-messages" id="chatMessages">';
    html += '<div class="liff-ai-chat-bubble bot">สวัสดีครับ ผม DINOCO AI Assistant พร้อมช่วยเหลือคุณ กรุณาเลือกคำถามด้านล่าง หรือพิมพ์คำถามของคุณได้เลย</div>';
    html += '</div>';

    // Quick actions
    html += '<div class="liff-ai-quick-actions">';
    var quickQs = [
        "สรุปยอดวันนี้",
        "Lead ที่ต้องติดตาม",
        "เคลมที่รอดำเนินการ",
        "สินค้าขายดี",
        "ตัวแทนยอดเยี่ยม"
    ];
    quickQs.forEach(function(q) {
        html += '<button class="liff-ai-quick-btn" data-quick="' + esc(q) + '">' + esc(q) + '</button>';
    });
    html += '</div>';

    // Input bar
    html += '<div class="liff-ai-chat-input-bar">';
    html += '<input type="text" id="chatInput" placeholder="พิมพ์คำถาม..." autocomplete="off">';
    html += '<button id="chatSend">&#10148;</button>';
    html += '</div>';

    var app = $("#liffAiApp");
    app.innerHTML = html;
    renderBottomNav("agent");

    // Bind send
    var chatInput = $("#chatInput");
    var chatSend = $("#chatSend");
    var chatMessages = $("#chatMessages");

    function sendMessage(text) {
        if (!text || !text.trim()) return;
        // Add user bubble
        var userBubble = document.createElement("div");
        userBubble.className = "liff-ai-chat-bubble user";
        userBubble.textContent = text.trim();
        chatMessages.appendChild(userBubble);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        chatInput.value = "";

        // Bot reply placeholder
        setTimeout(function() {
            var botBubble = document.createElement("div");
            botBubble.className = "liff-ai-chat-bubble bot";
            botBubble.textContent = "ขออภัยครับ ระบบ AI Assistant กำลังอยู่ระหว่างพัฒนา (Phase 3) จะเปิดให้ใช้งานเร็ว ๆ นี้";
            chatMessages.appendChild(botBubble);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }, 800);
    }

    if (chatSend) chatSend.addEventListener("click", function() { sendMessage(chatInput.value); });
    if (chatInput) chatInput.addEventListener("keydown", function(e) {
        if (e.key === "Enter") { e.preventDefault(); sendMessage(chatInput.value); }
    });

    // Quick actions
    app.querySelectorAll("[data-quick]").forEach(function(el) {
        el.addEventListener("click", function() { sendMessage(el.dataset.quick); });
    });
}


