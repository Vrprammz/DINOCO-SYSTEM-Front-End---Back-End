async function renderLeadList(filter) {
    showLoading("กำลังโหลด Lead...");
    var params = {};
    if (filter && filter !== "all") params.status = filter;

    var res = await api("GET", "leads", params);
    if (!res.success) { showError("โหลดไม่สำเร็จ", res.message || ""); return; }

    var html = '';
    // Header
    html += '<div class="liff-ai-header">';
    html += '<div class="liff-ai-header-top">';
    html += '<button class="liff-ai-detail-back" id="backBtn">&#8592; กลับ</button>';
