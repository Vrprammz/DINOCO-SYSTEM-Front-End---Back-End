if ( ! function_exists( 'dinoco_modal_helpers_js_source' ) ) {
    /**
     * L3 FIX: JS source — returned as string for wp_add_inline_script().
     * Idempotent (`window.dinocoModal.__v` guard) so multiple includes via
     * different registered handles remain safe.
     */
    function dinoco_modal_helpers_js_source() {
        ob_start();
        ?>
(function(){
    if (window.dinocoModal && window.dinocoModal.__v === '1.1') return;

    var activeBackdrop = null;
    var prevFocus = null;

    function esc(s) {
        if (s === null || s === undefined) return '';
        return String(s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function iconFor(type, danger) {
        if (danger) return '⚠️';
        switch (type) {
            case 'success': return '✅';
            case 'error':   return '❌';
            case 'warning': return '⚠️';
            case 'info':    return 'ℹ️';
            default:        return '❓';
        }
    }

    function closeModal(backdrop) {
        if (!backdrop || !backdrop.parentNode) return;
        backdrop.classList.remove('dnc-modal-open');
        try { backdrop.parentNode.removeChild(backdrop); } catch (e) {}
        if (activeBackdrop === backdrop) activeBackdrop = null;
        if (prevFocus && typeof prevFocus.focus === 'function') {
            try { prevFocus.focus(); } catch (e) {}
        }
        prevFocus = null;
    }

    function buildBackdrop(html, onKey) {
        // Close any existing first (defensive)
        if (activeBackdrop) {
            try { closeModal(activeBackdrop); } catch (e) {}
        }
        prevFocus = document.activeElement;
        var backdrop = document.createElement('div');
        backdrop.className = 'dnc-modal-backdrop';
        backdrop.setAttribute('role', 'dialog');
        backdrop.setAttribute('aria-modal', 'true');
        backdrop.innerHTML = html;
        document.body.appendChild(backdrop);
        // Force reflow then open
        void backdrop.offsetWidth;
        backdrop.classList.add('dnc-modal-open');
        activeBackdrop = backdrop;

        // Focus trap + ESC
        backdrop.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' || e.key === 'Esc') {
                if (typeof onKey === 'function') onKey('esc', e);
                return;
            }
            if (e.key !== 'Tab') return;
            var nodes = backdrop.querySelectorAll(
                'button:not([disabled]),input:not([disabled]),textarea:not([disabled]),[tabindex]:not([tabindex="-1"])'
            );
            var vis = [];
            for (var i = 0; i < nodes.length; i++) {
                if (nodes[i].offsetParent !== null) vis.push(nodes[i]);
            }
            if (!vis.length) return;
            var first = vis[0], last = vis[vis.length - 1];
            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault(); last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault(); first.focus();
            }
        });
        return backdrop;
    }

    // ─── confirm() ──────────────────────────────────────────────
    function confirmDialog(opts) {
        opts = opts || {};
        var title       = opts.title || 'ยืนยันการทำรายการ';
        var message     = opts.message || '';
        var confirmText = opts.confirmText || 'ยืนยัน';
        var cancelText  = opts.cancelText  || 'ยกเลิก';
        var danger      = !!opts.danger;
        var closeOnBackdrop = opts.closeOnBackdrop !== false; // default true

        return new Promise(function(resolve) {
            var html =
                '<div class="dnc-modal-dialog" role="document">' +
                    '<div class="dnc-modal-header' + (danger ? ' dnc-modal-danger' : '') + '">' +
                        '<span class="dnc-modal-icon" aria-hidden="true">' + iconFor(danger ? 'warning' : 'info', danger) + '</span>' +
                        '<h3 class="dnc-modal-title">' + esc(title) + '</h3>' +
                    '</div>' +
                    '<div class="dnc-modal-body">' + esc(message) + '</div>' +
                    '<div class="dnc-modal-footer">' +
                        '<button type="button" class="dnc-modal-btn dnc-modal-btn-cancel" data-role="cancel">' + esc(cancelText) + '</button>' +
                        '<button type="button" class="dnc-modal-btn ' + (danger ? 'dnc-modal-btn-danger' : 'dnc-modal-btn-confirm') + '" data-role="confirm">' + esc(confirmText) + '</button>' +
                    '</div>' +
                '</div>';

            var settled = false;
            function settle(val) {
                if (settled) return; settled = true;
                closeModal(backdrop);
                resolve(val);
            }

            var backdrop = buildBackdrop(html, function(key) {
                if (key === 'esc') settle(false);
            });

            backdrop.addEventListener('click', function(e) {
                if (!closeOnBackdrop) return;
                if (e.target === backdrop) settle(false);
            });
            var btnCancel  = backdrop.querySelector('[data-role="cancel"]');
            var btnConfirm = backdrop.querySelector('[data-role="confirm"]');
            if (btnCancel)  btnCancel.addEventListener('click',  function(){ settle(false); });
            if (btnConfirm) btnConfirm.addEventListener('click', function(){ settle(true); });

            // Initial focus on cancel (safer default for destructive)
            setTimeout(function(){
                var target = danger ? btnCancel : btnConfirm;
                if (target) try { target.focus(); } catch(e){}
            }, 20);
        });
    }

    // ─── alert() ────────────────────────────────────────────────
    function alertDialog(opts) {
        opts = opts || {};
        if (typeof opts === 'string') opts = { message: opts };
        var title   = opts.title || '';
        var message = opts.message || '';
        var type    = opts.type || 'info';
        var okText  = opts.okText || 'ตกลง';

        // Auto-title fallback by type
        if (!title) {
            switch (type) {
                case 'success': title = 'สำเร็จ'; break;
                case 'error':   title = 'เกิดข้อผิดพลาด'; break;
                case 'warning': title = 'คำเตือน'; break;
                default:        title = 'แจ้งเตือน';
            }
        }

        return new Promise(function(resolve) {
            var html =
                '<div class="dnc-modal-dialog" role="document">' +
                    '<div class="dnc-modal-header' + (type === 'error' ? ' dnc-modal-danger' : '') + '">' +
                        '<span class="dnc-modal-icon" aria-hidden="true">' + iconFor(type, false) + '</span>' +
                        '<h3 class="dnc-modal-title">' + esc(title) + '</h3>' +
                    '</div>' +
                    '<div class="dnc-modal-body">' + esc(message) + '</div>' +
                    '<div class="dnc-modal-footer">' +
                        '<button type="button" class="dnc-modal-btn ' + (type === 'error' ? 'dnc-modal-btn-danger' : 'dnc-modal-btn-confirm') + '" data-role="ok">' + esc(okText) + '</button>' +
                    '</div>' +
                '</div>';

            var settled = false;
            function settle() {
                if (settled) return; settled = true;
                closeModal(backdrop);
                resolve();
            }

            var backdrop = buildBackdrop(html, function(key) {
                if (key === 'esc') settle();
            });

            backdrop.addEventListener('click', function(e) {
                if (e.target === backdrop) settle();
            });
            var btnOk = backdrop.querySelector('[data-role="ok"]');
            if (btnOk) btnOk.addEventListener('click', settle);

            setTimeout(function(){
                if (btnOk) try { btnOk.focus(); } catch(e){}
            }, 20);
        });
    }

    // ─── prompt() ───────────────────────────────────────────────
    function promptDialog(opts) {
        opts = opts || {};
        var title       = opts.title || 'กรุณากรอกข้อมูล';
        var message     = opts.message || '';
        var placeholder = opts.placeholder || '';
        var required    = opts.required !== false; // default true
        var maxLength   = parseInt(opts.maxLength, 10) || 500;
        var defaultVal  = opts.defaultValue || '';
        var confirmText = opts.confirmText || 'ตกลง';
        var cancelText  = opts.cancelText  || 'ยกเลิก';
        var multiline   = !!opts.multiline;
        var errMsg      = opts.requiredMessage || '⚠️ กรุณากรอกข้อมูล';

        return new Promise(function(resolve) {
            var inputEl = multiline
                ? '<textarea class="dnc-modal-input" rows="3" maxlength="' + maxLength + '" placeholder="' + esc(placeholder) + '">' + esc(defaultVal) + '</textarea>'
                : '<input type="text" class="dnc-modal-input" maxlength="' + maxLength + '" placeholder="' + esc(placeholder) + '" value="' + esc(defaultVal) + '" />';

            var html =
                '<div class="dnc-modal-dialog" role="document">' +
                    '<div class="dnc-modal-header">' +
                        '<span class="dnc-modal-icon" aria-hidden="true">📝</span>' +
                        '<h3 class="dnc-modal-title">' + esc(title) + '</h3>' +
                    '</div>' +
                    '<div class="dnc-modal-body">' +
                        (message ? esc(message) : '') +
                        inputEl +
                        '<div class="dnc-modal-input-error" data-role="err">' + esc(errMsg) + '</div>' +
                    '</div>' +
                    '<div class="dnc-modal-footer">' +
                        '<button type="button" class="dnc-modal-btn dnc-modal-btn-cancel" data-role="cancel">' + esc(cancelText) + '</button>' +
                        '<button type="button" class="dnc-modal-btn dnc-modal-btn-confirm" data-role="confirm">' + esc(confirmText) + '</button>' +
                    '</div>' +
                '</div>';

            var settled = false;
            function settle(val) {
                if (settled) return; settled = true;
                closeModal(backdrop);
                resolve(val);
            }

            var backdrop = buildBackdrop(html, function(key) {
                if (key === 'esc') settle(null);
            });

            backdrop.addEventListener('click', function(e) {
                if (e.target === backdrop) settle(null);
            });

            var input    = backdrop.querySelector('.dnc-modal-input');
            var errEl    = backdrop.querySelector('[data-role="err"]');
            var btnCancel  = backdrop.querySelector('[data-role="cancel"]');
            var btnConfirm = backdrop.querySelector('[data-role="confirm"]');

            function doConfirm() {
                var raw = input ? (input.value || '') : '';
                var trimmed = raw.trim();
                if (required && !trimmed) {
                    if (errEl) errEl.classList.add('dnc-visible');
                    if (input) try { input.focus(); } catch(e){}
                    return;
                }
                settle(trimmed);
            }

            if (btnCancel)  btnCancel.addEventListener('click',  function(){ settle(null); });
            if (btnConfirm) btnConfirm.addEventListener('click', doConfirm);
            if (input) {
                input.addEventListener('input', function(){
                    if (errEl) errEl.classList.remove('dnc-visible');
                });
                if (!multiline) {
                    input.addEventListener('keydown', function(e){
                        if (e.key === 'Enter') { e.preventDefault(); doConfirm(); }
                    });
                }
            }

            setTimeout(function(){
                if (input) try { input.focus(); input.select && input.select(); } catch(e){}
            }, 30);
        });
    }

    // ─── Public API ─────────────────────────────────────────────
    window.dinocoModal = {
        __v: '1.1',
        confirm: function(opts) {
            try { return confirmDialog(opts); }
            catch (e) {
                // Defensive: fall back to native confirm on unexpected error
                try { console && console.warn && console.warn('[dinocoModal] confirm fallback:', e); } catch(_){}
                var msg = ((opts && opts.title) ? opts.title : '') + (opts && opts.message ? '\n' + opts.message : '');
                return Promise.resolve(window.confirm(msg || 'ยืนยัน?'));
            }
        },
        alert: function(opts) {
            try { return alertDialog(opts); }
            catch (e) {
                try { console && console.warn && console.warn('[dinocoModal] alert fallback:', e); } catch(_){}
                var msg = ((opts && opts.title) ? opts.title : '') + (opts && opts.message ? '\n' + opts.message : '');
                try { window.alert(msg); } catch(_){}
                return Promise.resolve();
            }
        },
        prompt: function(opts) {
            try { return promptDialog(opts); }
            catch (e) {
                try { console && console.warn && console.warn('[dinocoModal] prompt fallback:', e); } catch(_){}
                var msg = ((opts && opts.title) ? opts.title : '') + (opts && opts.message ? '\n' + opts.message : '');
                var res = window.prompt(msg || 'กรอกข้อมูล:', (opts && opts.defaultValue) || '');
                if (res === null) return Promise.resolve(null);
                var trimmed = (res || '').trim();
                if (opts && opts.required !== false && !trimmed) {
                    try { window.alert(opts.requiredMessage || '⚠️ กรุณากรอกข้อมูล'); } catch(_){}
                    return Promise.resolve(null);
                }
                return Promise.resolve(trimmed);
            }
        }
    };
})();
