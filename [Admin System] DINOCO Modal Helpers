if ( ! function_exists( 'dinoco_modal_helpers_enqueue' ) ) {
    /**
     * L3 FIX: Register handles + attach inline CSS/JS via wp_add_inline_*.
     * Emitting through registered handles means future CSP nonce/hash
     * configuration becomes a config-time concern (via `wp_inline_script_attributes`
     * / `script_loader_tag` filters) rather than a code refactor.
     *
     * Handles intentionally have empty src so WP prints only the inline blob.
     */
    function dinoco_modal_helpers_enqueue() {
        if ( ! dinoco_modal_helpers_should_load() ) return;

        // CSS handle — empty src (false) with `wp_add_inline_style`.
        if ( ! wp_style_is( 'dinoco-modal', 'registered' ) ) {
            wp_register_style( 'dinoco-modal', false, array(), '1.1' );
        }
        wp_enqueue_style( 'dinoco-modal' );
        wp_add_inline_style( 'dinoco-modal', dinoco_modal_helpers_css_source() );

        // JS handle — empty src ('') with `wp_add_inline_script`.
        if ( ! wp_script_is( 'dinoco-modal', 'registered' ) ) {
            wp_register_script( 'dinoco-modal', '', array(), '1.1', true );
        }
        wp_enqueue_script( 'dinoco-modal' );
        wp_add_inline_script( 'dinoco-modal', dinoco_modal_helpers_js_source() );
    }

    // Priority 5 so downstream admin shortcodes can depend on the handle
    // if they want to (via wp_enqueue_script($handle, ..., ['dinoco-modal'])).
    add_action( 'wp_enqueue_scripts', 'dinoco_modal_helpers_enqueue', 5 );
}
