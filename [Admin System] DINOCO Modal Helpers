if ( ! function_exists( 'dinoco_modal_helpers_should_load' ) ) {
    /**
     * L3 FIX: Shared gating predicate — replaces inline check in the former
     * `wp_footer` handler. Called from `wp_enqueue_scripts` so registration
     * happens with correct priority for CSP-ready handles.
     *
     * @return bool true if current page contains a target admin shortcode.
     */
    function dinoco_modal_helpers_should_load() {
        if ( ! is_user_logged_in() ) return false;
        if ( is_admin() ) return false;

        global $post;
        if ( ! $post ) return false;
        $content = isset( $post->post_content ) ? $post->post_content : '';

        $target_shortcodes = array(
            'dinoco_admin_dashboard',
            'dinoco_admin_inventory',
            'dinoco_admin_claims',
            'dinoco_admin_users',
            'dinoco_admin_transfer',
            'dinoco_admin_legacy',
            'dinoco_admin_finance',
            'dinoco_admin_ai_control',
            'dinoco_manual_invoice',
            'dinoco_sync_dashboard',
            'b2b_admin_dashboard',
            'b2b_admin_control',
            'b2b_discount_mapping',
            'b2b_bo_admin',
            'b2b_bo_flags',
            'b2b_bo_security_log',
            'b2f_admin_orders_tab',
            'b2f_admin_makers_tab',
            'b2f_admin_credit_tab',
            'b2f_migration_audit',
        );

        foreach ( $target_shortcodes as $sc ) {
            if ( has_shortcode( $content, $sc ) ) return true;
        }
        return false;
    }
}

