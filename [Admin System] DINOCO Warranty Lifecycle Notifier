if ( ! function_exists( 'dinoco_sn_compute_anniversary_coupon' ) ) {
    /**
     * Tier-aware anniversary coupon table.
     *
     *   1 year  →  5% off
     *   2 year  →  7% off
     *   3+ year → 10% off (capped)
     *
     * @param int $year_n
     * @return array{discount_pct:int, discount_value:?float, scope:string}
     */
    function dinoco_sn_compute_anniversary_coupon( $year_n ) {
        $y = (int) $year_n;
        if ( $y < 1 ) $y = 1;
        if ( $y === 1 ) {
            $pct = 5;
        } elseif ( $y === 2 ) {
            $pct = 7;
        } else {
            $pct = 10; // 3y / 4y / 5y+ all cap at 10%
        }
        return array(
            'discount_pct'   => $pct,
            'discount_value' => null,
            'scope'          => 'any', // valid against any SKU
        );
    }
}

if ( ! function_exists( 'dinoco_sn_format_thai_date' ) ) {
    /**
     * Convert MySQL DATETIME / Unix timestamp / Y-m-d → "7 พ.ค. 2569".
     *
     * Returns empty string on parse fail (defensive — never throws).
     *
     * Note: Manager V.0.10+ already defines this helper. We guard with
     * function_exists so loading order is irrelevant.
     */
    function dinoco_sn_format_thai_date( $when ) {
        $ts = is_numeric( $when ) ? (int) $when : strtotime( (string) $when );
        if ( ! $ts || $ts <= 0 ) return '';
        $months_th = array(
            1 => 'ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.',
                 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.',
        );
        $d = (int) date( 'j', $ts );
        $m = (int) date( 'n', $ts );
        $y = (int) date( 'Y', $ts ) + 543; // Buddhist era
        $mlabel = isset( $months_th[ $m ] ) ? $months_th[ $m ] : '';
        return $d . ' ' . $mlabel . ' ' . $y;
    }
}

if ( ! function_exists( 'dinoco_sn_compute_days_until_expiry' ) ) {
    /**
     * Days from now → warranty_end (registered_at + N years, default 1).
     * Returns int (negative if already expired) or null on parse fail.
     *
     * @param array|object $row  pool row with registered_at + optional warranty_years
     */
    function dinoco_sn_compute_days_until_expiry( $row ) {
        $registered_at = is_array( $row ) ? ( $row['registered_at'] ?? null ) : ( $row->registered_at ?? null );
        if ( empty( $registered_at ) ) return null;
        $years = is_array( $row )
            ? (int) ( $row['warranty_years'] ?? 0 )
            : (int) ( $row->warranty_years ?? 0 );
        if ( $years < 1 ) {
            $years = (int) get_option( 'dinoco_sn_default_warranty_years', 1 );
            if ( $years < 1 ) $years = 1;
        }
        try {
            $tz    = function_exists( 'wp_timezone' ) ? wp_timezone() : new \DateTimeZone( 'Asia/Bangkok' );
            $start = new \DateTime( (string) $registered_at, $tz );
            $start->modify( '+' . $years . ' years' );
            $now   = new \DateTime( 'now', $tz );
            $diff  = $now->diff( $start );
            return ( $diff->invert ? -1 : 1 ) * (int) $diff->days;
        } catch ( \Throwable $e ) {
            return null;
        }
    }
}

if ( ! function_exists( 'dinoco_sn_should_send_to_user' ) ) {
    /**
     * Honor user notification preferences + LINE UID presence.
     *
     * Per-type opt-out via wp_usermeta keys (default ON for first 3):
     *   - dinoco_sn_notif_expiry        (default '1')
     *   - dinoco_sn_notif_anniversary   (default '1')
     *   - dinoco_sn_notif_review        (default '1')
     *   - dinoco_sn_notif_promo         (default '0')
     *   - dinoco_sn_notif_service       (default '0')
     *
     * @param int    $user_id
     * @param string $notification_type  expiry_30d / anniversary_2y / review_request / etc.
     * @return bool
     */
    function dinoco_sn_should_send_to_user( $user_id, $notification_type ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return false;

        // LINE UID presence is mandatory — Flex push without UID = 100% fail
        $line_uid = get_user_meta( $user_id, 'dinoco_line_uid', true );
        if ( empty( $line_uid ) ) {
            return false;
        }

        // V.0.5 R5 Wiring-G3 — route through canonical Governance helper when
        // available. Single source of truth (dinoco_line_get_user_prefs reads
        // 5 categories incl. NUCLEAR opt-out via dinoco_line_opt_out_all key).
        // Falls back to direct meta read for backward compat when Governance
        // snippet not yet synced.
        if ( function_exists( 'dinoco_line_get_user_prefs' )
            && function_exists( 'dinoco_line_gov_resolve_category' ) ) {
            $category = dinoco_line_gov_resolve_category( (string) $notification_type );
            $prefs    = dinoco_line_get_user_prefs( $user_id );
            if ( is_array( $prefs ) && array_key_exists( $category, $prefs ) ) {
                return ! empty( $prefs[ $category ] );
            }
            // category absent (unknown type) — pass-through preserves prior behavior
            return true;
        }

        $type = (string) $notification_type;
        $pref_key  = '';
        $default_on = true;
        if ( strpos( $type, 'expiry_' ) === 0 ) {
            $pref_key = 'dinoco_sn_notif_expiry';
        } elseif ( strpos( $type, 'anniversary_' ) === 0 ) {
            $pref_key = 'dinoco_sn_notif_anniversary';
        } elseif ( $type === 'review_request' ) {
            $pref_key = 'dinoco_sn_notif_review';
        } elseif ( strpos( $type, 'promo_' ) === 0 ) {
            $pref_key  = 'dinoco_sn_notif_promo';
            $default_on = false;
        } elseif ( strpos( $type, 'service_' ) === 0 ) {
            $pref_key  = 'dinoco_sn_notif_service';
            $default_on = false;
        } else {
            // Unknown type — send (admin-defined custom types pass through)
            return true;
        }

        $val = get_user_meta( $user_id, $pref_key, true );
        if ( $val === '' || $val === false || $val === null ) {
            return $default_on;
        }
        return ! empty( $val ) && $val !== '0';
    }
}

if ( ! function_exists( 'dinoco_sn_lifecycle_random_code' ) ) {
    /**
     * Generate 12-char alphanumeric (A-Z + 0-9) promo code.
     * Uppercase only — case-insensitive lookup at redemption.
     *
     * Pure helper — testable without WP. wp_generate_password used when
     * available; fallback mt_rand for unit tests.
     */
    function dinoco_sn_lifecycle_random_code( $length = 12 ) {
        $length = max( 6, min( 20, (int) $length ) );
        if ( function_exists( 'wp_generate_password' ) ) {
            $raw = wp_generate_password( $length, false, false ); // alnum no-special
            return strtoupper( substr( $raw, 0, $length ) );
        }
        // Fallback — pure PHP (testable)
        $chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        $out   = '';
        for ( $i = 0; $i < $length; $i++ ) {
            $out .= $chars[ mt_rand( 0, strlen( $chars ) - 1 ) ];
        }
        return $out;
    }
}

