        $body_contents[] = array( 'type' => 'separator', 'margin' => 'md' );
        $body_contents[] = array(
            'type'   => 'box',
            'layout' => 'baseline',
            'margin' => 'md',
            'contents' => array(
                array(
                    'type' => 'text', 'text' => 'ยอดรวม (รวม VAT)',
