/* ═══════════════════════════════════════════════════════════════════════════
 * 5. CORE HANDLER — bound to cron hook
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_push_send_receipt' ) ) {
    /**
     * Main entry. Returns array { sent: bool, reason: string, image_url: string }.
     * Idempotent — re-firing on same ext returns sent:true reason:already_sent.
     *
     * @param int $extension_id
     * @return array
     */
    function dinoco_vat_push_send_receipt( $extension_id ) {
        $extension_id = (int) $extension_id;
        if ( $extension_id <= 0 ) {
            return array( 'sent' => false, 'reason' => 'invalid_extension_id' );
        }

        // Idempotency — guard against duplicate cron fires
        if ( dinoco_vat_push_is_already_sent( $extension_id ) ) {
            return array( 'sent' => true, 'reason' => 'already_sent' );
        }

        // Eligibility check via VAT Receipt snippet
        if ( ! function_exists( 'dinoco_vat_receipt_extension_is_eligible' ) ) {
            return array( 'sent' => false, 'reason' => 'vat_receipt_snippet_missing' );
        }
        $eligible = dinoco_vat_receipt_extension_is_eligible( $extension_id );
        if ( ! $eligible['eligible'] ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'info', 'vat_receipt_skip', array(
                    'extension_id' => $extension_id,
                    'reason'       => $eligible['reason'],
                ) );
            }
            return array( 'sent' => false, 'reason' => $eligible['reason'] );
        }

        // LINE UID resolution
        $line_uid = dinoco_vat_push_resolve_line_uid( $extension_id );
        if ( $line_uid === '' ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_no_line_uid', array(
                    'extension_id' => $extension_id,
                    'hint'         => 'customer not linked via LINE — admin may need manual fallback',
                ) );
            }
            return array( 'sent' => false, 'reason' => 'no_line_uid' );
        }

        // Render + persist PNG
        if ( ! function_exists( 'dinoco_vat_receipt_render_png' ) ) {
            return array( 'sent' => false, 'reason' => 'png_renderer_missing' );
        }
        $png = dinoco_vat_receipt_render_png( $extension_id );
        if ( $png === '' ) {
            return array( 'sent' => false, 'reason' => 'png_render_failed' );
        }
        $image_url = dinoco_vat_push_persist_png( $extension_id, $png );
        if ( $image_url === '' ) {
            return array( 'sent' => false, 'reason' => 'png_persist_failed' );
        }

        // Build Flex + push
        $messages = dinoco_vat_push_build_flex( $extension_id, $image_url );
        if ( empty( $messages ) ) {
            return array( 'sent' => false, 'reason' => 'flex_build_failed' );
        }

        $push_ok = false;
        if ( function_exists( 'b2b_push_guaranteed' ) ) {
            // ticket_id=0 — extensions live in custom table, no CPT; failure logs
            // to error_log via b2b_log but no auto-retry persistence (acceptable
            // per "one-shot per extension" design).
            $push_ok = (bool) b2b_push_guaranteed( $line_uid, $messages, 0, 'vat_receipt_extension' );
        } elseif ( function_exists( 'b2b_line_push_raw' ) ) {
            $r = b2b_line_push_raw( $line_uid, $messages );
            $push_ok = is_array( $r ) && isset( $r['code'] ) && (int) $r['code'] === 200;
        }

        if ( $push_ok ) {
            dinoco_vat_push_mark_sent( $extension_id, $line_uid );
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                $tbl_ext = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'extensions' ) : '';
                global $wpdb;
                $sn = $tbl_ext ? (string) $wpdb->get_var( $wpdb->prepare(
                    "SELECT sn FROM {$tbl_ext} WHERE id = %d", $extension_id
                ) ) : '';
                if ( $sn !== '' ) {
                    dinoco_sn_audit_log( strtoupper( $sn ), 'vat_receipt_pushed', null, null, array(
                        'extension_id' => $extension_id,
                        'line_uid'     => substr( $line_uid, 0, 4 ) . '****',
                        'image_url'    => $image_url,
                    ), 0, null, '', 'vat_receipt_line_push', false );
                }
            }
            return array( 'sent' => true, 'reason' => 'ok', 'image_url' => $image_url );
        }

        if ( function_exists( 'dinoco_obs_capture' ) ) {
            dinoco_obs_capture( 'warning', 'vat_receipt_push_failed', array(
                'extension_id' => $extension_id,
                'line_uid'     => substr( $line_uid, 0, 4 ) . '****',
            ) );
        }
        return array( 'sent' => false, 'reason' => 'line_push_failed', 'image_url' => $image_url );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 6. CRON HOOK BINDING — wired to existing SN REST API V.0.50+ scheduler
 * ═══════════════════════════════════════════════════════════════════════════ */

add_action( 'dinoco_sn_marketplace_receipt_async', 'dinoco_vat_push_send_receipt', 10, 1 );

/* ═══════════════════════════════════════════════════════════════════════════
 * 7. REST ENDPOINT — admin manual resend (e.g. customer reports lost receipt)
 * ═══════════════════════════════════════════════════════════════════════════ */

add_action( 'rest_api_init', function() {
    register_rest_route( 'dinoco-vat/v1', '/resend/(?P<id>\d+)', array(
        'methods'             => 'POST',
        'callback'            => function( $req ) {
            $id = (int) $req['id'];
            // Force resend — clear idempotency guard first
            delete_transient( 'dinoco_vat_pushed_' . $id );
            $result = dinoco_vat_push_send_receipt( $id );
            return rest_ensure_response( $result );
        },
        'permission_callback' => function() {
            return current_user_can( 'manage_options' );
        },
        'args' => array(
            'id' => array( 'sanitize_callback' => 'absint' ),
        ),
    ) );

    // Admin diagnostic: dry-run check (does NOT push, just resolves data)
    register_rest_route( 'dinoco-vat/v1', '/push-dry-run/(?P<id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => function( $req ) {
            $id = (int) $req['id'];
            $eligibility = function_exists( 'dinoco_vat_receipt_extension_is_eligible' )
                ? dinoco_vat_receipt_extension_is_eligible( $id )
                : array( 'eligible' => false, 'reason' => 'vat_receipt_snippet_missing' );
            $line_uid = dinoco_vat_push_resolve_line_uid( $id );
            $already_sent = dinoco_vat_push_is_already_sent( $id );
            return rest_ensure_response( array(
                'extension_id' => $id,
                'eligibility'  => $eligibility,
                'line_uid_resolved' => $line_uid !== '',
                'line_uid_mask' => $line_uid !== '' ? substr( $line_uid, 0, 4 ) . '****' : '',
                'already_sent' => $already_sent,
                'would_push'   => ! $already_sent && $eligibility['eligible'] && $line_uid !== '',
            ) );
        },
        'permission_callback' => function() {
            return current_user_can( 'manage_options' );
        },
        'args' => array(
            'id' => array( 'sanitize_callback' => 'absint' ),
        ),
    ) );
} );
