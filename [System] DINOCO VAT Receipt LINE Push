/* ═══════════════════════════════════════════════════════════════════════════
 * 1. UPLOAD DIR HELPER — ensures wp-content/uploads/dinoco-vat-receipts/
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_push_upload_dir' ) ) {
    function dinoco_vat_push_upload_dir() {
        $u = wp_upload_dir();
        $dir = trailingslashit( $u['basedir'] ) . 'dinoco-vat-receipts';
        if ( ! file_exists( $dir ) ) {
            wp_mkdir_p( $dir );
            // V.1.1 CRIT-1: Defense layer 1 — .htaccess deny-all for Apache.
            // (Nginx ignores .htaccess so we ALSO use HMAC filename — see persist_png)
            @file_put_contents(
                trailingslashit( $dir ) . '.htaccess',
                "# DINOCO VAT Receipts — direct access denied.\n" .
                "# Access via REST endpoint /dinoco-vat/v1/receipt/{id}?format=png only.\n" .
                "Order deny,allow\nDeny from all\n" .
                "<IfModule mod_authz_core.c>\n  Require all denied\n</IfModule>\n"
            );
            @file_put_contents( trailingslashit( $dir ) . 'index.php', "<?php // Silence is golden.\n" );
        }
        $url_base = trailingslashit( $u['baseurl'] ) . 'dinoco-vat-receipts';
        return array(
            'dir'      => $dir,
            'url_base' => $url_base,
        );
    }
}

if ( ! function_exists( 'dinoco_vat_push_persist_png' ) ) {
    /**
     * Write PNG bytes to upload dir → return public URL.
     *
     * V.1.1 CRIT-1 + HIGH-3 hardening:
     *   - Filename now includes 24-char HMAC token derived from extension_id +
     *     receipt_no + wp_salt('auth'). Brute force = 120 bits of entropy.
     *     This protects PII even on nginx stacks where .htaccess is ignored.
     *   - 5 MB size cap prevents storage bombs (e.g. font fallback bug
     *     producing oversized PNG).
     *   - PNG magic-byte check confirms input is actually PNG.
     *   - Atomic write via tmp + rename so concurrent readers never see
     *     a partial file (LINE pulling URL during write race).
     *
     * @param int    $extension_id
     * @param string $png_binary
     * @return string public URL (https), or '' on failure
     */
    function dinoco_vat_push_persist_png( $extension_id, $png_binary ) {
        $extension_id = (int) $extension_id;
        if ( $extension_id <= 0 ) return '';
        if ( $png_binary === '' ) return '';

        // V.1.1 HIGH-3: size cap (5 MB ceiling — receipts should be <500 KB)
        if ( strlen( $png_binary ) > 5 * 1024 * 1024 ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_oversize', array(
                    'extension_id' => $extension_id,
                    'bytes'        => strlen( $png_binary ),
                ) );
            }
            return '';
        }
        // V.1.1 HIGH-3: PNG magic byte check
        if ( substr( $png_binary, 0, 8 ) !== "\x89PNG\r\n\x1a\n" ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_not_png', array(
                    'extension_id' => $extension_id,
                ) );
            }
            return '';
        }

        if ( ! function_exists( 'dinoco_vat_receipt_generate_receipt_no' ) ) return '';
        $receipt_no = dinoco_vat_receipt_generate_receipt_no( $extension_id );
        if ( $receipt_no === '' ) return '';

        // V.1.1 CRIT-1: HMAC-derived filename token (24 chars = 120 bits entropy)
        // Brute force requires guessing 2^120 → infeasible. Even with leaked URL
        // structure attacker cannot forge a filename for another extension_id.
        $token = substr( hash_hmac( 'sha256', $extension_id . '|' . $receipt_no, wp_salt( 'auth' ) ), 0, 24 );

        $paths = dinoco_vat_push_upload_dir();
        $fname = $extension_id . '-' . $receipt_no . '-' . $token . '.png';
        $fpath = trailingslashit( $paths['dir'] ) . $fname;

        // V.1.1 HIGH-3: atomic write via tmp + rename
        $tmp = $fpath . '.tmp.' . wp_generate_password( 8, false );
        $written = file_put_contents( $tmp, $png_binary, LOCK_EX );
        if ( $written === false ) {
            @unlink( $tmp );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_write_failed', array(
                    'extension_id' => $extension_id,
                    'path'         => $fpath,
                ) );
            }
            return '';
        }
        if ( ! @rename( $tmp, $fpath ) ) {
            @unlink( $tmp );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_rename_failed', array(
                    'extension_id' => $extension_id,
                    'tmp_path'     => $tmp,
                    'final_path'   => $fpath,
                ) );
            }
            return '';
        }
        // Force HTTPS for LINE API (rejects http://)
        $url = trailingslashit( $paths['url_base'] ) . $fname;
        $url = preg_replace( '#^http://#', 'https://', $url );
        return $url;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. IDEMPOTENCY GUARD
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_push_is_already_sent' ) ) {
    function dinoco_vat_push_is_already_sent( $extension_id ) {
        $key = 'dinoco_vat_pushed_' . (int) $extension_id;
        return (bool) get_transient( $key );
    }
}

if ( ! function_exists( 'dinoco_vat_push_mark_sent' ) ) {
    function dinoco_vat_push_mark_sent( $extension_id, $line_uid = '' ) {
        $key = 'dinoco_vat_pushed_' . (int) $extension_id;
        // V.1.1 MED-2: store masked LINE UID only — full UID in wp_options
        // is readable by any plugin with options access (PDPA leak risk).
        $masked = $line_uid !== '' ? substr( (string) $line_uid, 0, 4 ) . '****' : '';
        $payload = array(
            'sent_at'  => current_time( 'mysql' ),
            'line_uid' => $masked,
        );
        // 30 day TTL — long enough that idempotency holds for retry burst
        set_transient( $key, $payload, 30 * DAY_IN_SECONDS );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 3. LINE UID RESOLVER — customer-side push target
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_push_resolve_line_uid' ) ) {
    /**
     * Resolve LINE UID for the customer who owns the extension.
     * Lookup chain:
     *   1. extension.user_id → WP user meta `line_uid`
     *   2. sn_pool.registered_user_id (fallback if extension.user_id missing)
     *
     * @param int $extension_id
     * @return string LINE UID (Uxxxxxxxx... format) or '' if not found
     */
    function dinoco_vat_push_resolve_line_uid( $extension_id ) {
        global $wpdb;
        $extension_id = (int) $extension_id;
        if ( $extension_id <= 0 ) return '';

        $tbl_ext = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'extensions' ) : '';
        if ( $tbl_ext === '' ) return '';

        $ext = $wpdb->get_row( $wpdb->prepare(
            "SELECT user_id, sn FROM {$tbl_ext} WHERE id = %d LIMIT 1", $extension_id
        ) );
        if ( ! $ext ) return '';

        $uid = (int) $ext->user_id;
        if ( $uid <= 0 ) {
            // Fallback: lookup via sn_pool
            $tbl_pool = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'pool' ) : '';
            if ( $tbl_pool !== '' ) {
                $uid = (int) $wpdb->get_var( $wpdb->prepare(
                    "SELECT registered_user_id FROM {$tbl_pool} WHERE sn = %s LIMIT 1",
                    strtoupper( (string) $ext->sn )
                ) );
            }
        }
        if ( $uid <= 0 ) return '';

        $line_uid = (string) get_user_meta( $uid, 'line_uid', true );
        // Some installations use `dinoco_line_uid` — fallback
        if ( $line_uid === '' ) {
            $line_uid = (string) get_user_meta( $uid, 'dinoco_line_uid', true );
        }
        return trim( $line_uid );
    }
}

