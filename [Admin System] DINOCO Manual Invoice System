window.invDownloadInvImage = function(id) {
    invToast('info', 'аёҒаёіаёҘаёұаёҮаёӘаёЈа№үаёІаёҮаёЈаё№аёӣаёҡаёҙаёҘ...');
    // Snippet 10 endpoint вҖ” admin has manage_options so no HMAC needed
    var url = INV_REST.replace('/b2b/v1', '/b2b/v1') + '/invoice-image?ticket_id=' + id + '&format=json';
    fetch(url, { headers: { 'X-WP-Nonce': INV_NONCE } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success || !data.pages || !data.pages.length) {
                invToast('error', 'аёӘаёЈа№үаёІаёҮаёЈаё№аёӣаёҡаёҙаёҘаёҘа№үаёЎа№Җаё«аёҘаё§');
                return;
            }
            // Download each page
            data.pages.forEach(function(pageUrl, i) {
                var a = document.createElement('a');
                a.href = pageUrl;
                a.download = 'invoice-' + id + (data.pages.length > 1 ? '-p' + (i + 1) : '') + '.png';
                a.target = '_blank';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            });
            invToast('success', 'аё”аёІаё§аёҷа№Ңа№Ӯаё«аёҘаё”аёЈаё№аёӣаёҡаёҙаёҘа№ҒаёҘа№үаё§ (' + data.pages.length + ' аё«аёҷа№үаёІ)');
        })
        .catch(function() { invToast('error', 'аё”аёІаё§аёҷа№Ңа№Ӯаё«аёҘаё”аёҘа№үаёЎа№Җаё«аёҘаё§'); });
};

