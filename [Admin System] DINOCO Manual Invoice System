            '<div>ยอดรวม: <b>฿' + invFmt(inv.total_amount || 0) + '</b></div>' +
            '<div>ยอดชำระสะสม: <b>฿' + invFmt(paid) + '</b>' + (refundedPrev > 0 ? ' (คืนไปแล้ว ฿' + invFmt(refundedPrev) + ')' : '') + '</div>' +
