if (!function_exists('b2b_log')) {
    function b2b_log($msg) { error_log('[DINOCO-INV] ' . $msg); }
}

if (!function_exists('b2b_date')) {
    function b2b_date($format, $timestamp = null) {
        $tz = new DateTimeZone('Asia/Bangkok');
        $dt = $timestamp ? (new DateTime('@' . $timestamp))->setTimezone($tz) : new DateTime('now', $tz);
        return $dt->format($format);
    }
}

if (!function_exists('b2b_add_audit_log')) {
    function b2b_add_audit_log($post_id, $action, $detail) {
        $log = get_post_meta($post_id, '_b2b_audit_log', true) ?: [];
        $log[] = [
            'time'   => b2b_date('Y-m-d H:i:s'),
            'user'   => wp_get_current_user()->user_login ?: 'system',
            'action' => $action,
            'detail' => $detail,
        ];
        if (count($log) > 50) $log = array_slice($log, -50);
        update_post_meta($post_id, '_b2b_audit_log', $log);
    }
}

if (!function_exists('b2b_set_order_status')) {
    function b2b_set_order_status($post_id, $status) {
        $old = get_field('order_status', $post_id);
        update_field('order_status', $status, $post_id);
        $hist = get_post_meta($post_id, '_b2b_status_history', true) ?: [];
        $hist[] = ['from' => $old, 'to' => $status, 'at' => b2b_date('Y-m-d H:i:s')];
        update_post_meta($post_id, '_b2b_status_history', $hist);
    }
}

if (!function_exists('b2b_line_push_raw')) {
    function b2b_line_push_raw($to, $messages) {
        $token = defined('B2B_LINE_ACCESS_TOKEN') ? B2B_LINE_ACCESS_TOKEN : '';
        if (!$token || !$to) return false;
        $body = json_encode(['to' => $to, 'messages' => $messages]);
        $resp = wp_remote_post('https://api.line.me/v2/bot/message/push', [
            'headers' => ['Content-Type' => 'application/json', 'Authorization' => 'Bearer ' . $token],
            'body'    => $body,
            'timeout' => 10,
        ]);
        return !is_wp_error($resp) && wp_remote_retrieve_response_code($resp) === 200;
    }
}

