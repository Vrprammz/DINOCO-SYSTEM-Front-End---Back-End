function invRenderDDProducts(products) {
    var tbody = document.getElementById('inv-dd-product-body');
    if (!products || !products.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="inv-empty"><i class="fa-solid fa-box-open"></i> аёўаёұаёҮа№„аёЎа№ҲаёЎаёөаёӮа№үаёӯаёЎаё№аёҘаёӘаёҙаёҷаё„а№үаёІ</td></tr>';
        return;
    }
    var maxVal = products[0].total_value || 1;
    var rows = products.map(function(p, i) {
        var pct = Math.round((p.total_value / maxVal) * 100);
        return '<tr>' +
            '<td>' + (i + 1) + '</td>' +
            '<td><span style="font-size:0.78rem;color:#94a3b8;">' + escH(p.sku) + '</span><br>' + escH(p.description) + '</td>' +
            '<td style="text-align:right">' + invFmt(p.total_qty) + '</td>' +
            '<td style="text-align:right;font-weight:600;">аёҝ' + invFmt(p.total_value) + '</td>' +
            '<td><div class="inv-dd-bar-wrap"><div class="inv-dd-bar" style="width:' + pct + '%"></div><span class="inv-dd-bar-pct">' + pct + '%</span></div></td>' +
            '</tr>';
    }).join('');
    tbody.innerHTML = rows;
}

function invRenderDDInvoices(invoices, page, pages) {
    var tbody = document.getElementById('inv-dd-invoice-body');
    if (!invoices || !invoices.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="inv-empty"><i class="fa-solid fa-file-invoice"></i> аёўаёұаёҮа№„аёЎа№ҲаёЎаёөа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү</td></tr>';
        document.getElementById('inv-dd-pagination').innerHTML = '';
        return;
    }
    var statusLabel = {draft:'Draft', awaiting_payment:'аёЈаёӯаёҠаёіаёЈаё°', paid:'аёҠаёіаёЈаё°а№ҒаёҘа№үаё§', cancelled:'аёўаёҒа№ҖаёҘаёҙаёҒ', overdue:'а№ҖаёҒаёҙаёҷаёҒаёіаё«аёҷаё”'};
    var rows = invoices.map(function(inv, i) {
        var isPaid = inv.paid_amount > 0 && inv.paid_amount < inv.total_amount;
        var statusClass = isPaid ? 'partial' : inv.status;
        var statusText  = isPaid ? 'аёҲа№ҲаёІаёўаёҡаёІаёҮаёӘа№Ҳаё§аёҷ' : (statusLabel[inv.status] || inv.status);
        var date = inv.issue_date ? new Date(inv.issue_date).toLocaleDateString('th-TH', {day:'numeric',month:'short',year:'numeric'}) : '-';
        var paymentText = inv.status === 'paid' ? 'аёҠаёіаёЈаё°аё„аёЈаёҡ' : (inv.paid_amount > 0 ? 'аёҲа№ҲаёІаёўаёҡаёІаёҮаёӘа№Ҳаё§аёҷ' : (inv.status === 'awaiting_payment' || inv.status === 'overdue' ? 'аёЈаёӯаёҠаёіаёЈаё°' : '-'));
        var paymentColor = inv.status === 'paid' ? '#16a34a' : (inv.paid_amount > 0 ? '#92400e' : (inv.status === 'awaiting_payment' || inv.status === 'overdue' ? '#dc2626' : '#94a3b8'));
        return '<tr>' +
            '<td>' + ((page - 1) * 20 + i + 1) + '</td>' +
            '<td>' + date + '</td>' +
            '<td><span class="inv-num" onclick="invViewFromDetail(' + inv.id + ')">' + escH(inv.inv_number) + '</span></td>' +
            '<td style="text-align:right">' + invFmt(inv.total_amount) + '</td>' +
            '<td><span class="inv-status ' + statusClass + '">' + statusText + '</span></td>' +
            '<td style="color:' + paymentColor + ';font-weight:600;font-size:0.82rem;">' + paymentText + '</td>' +
            '</tr>';
    }).join('');
    tbody.innerHTML = rows;

    // Pagination
    var pEl = document.getElementById('inv-dd-pagination');
    if (pages <= 1) { pEl.innerHTML = ''; return; }
    var html = '';
    for (var pg = 1; pg <= pages; pg++) {
        html += '<button class="inv-btn ' + (pg === page ? 'inv-btn-primary' : 'inv-btn-secondary') + '" onclick="invDistDetailPage(' + pg + ')" style="padding:6px 12px;">' + pg + '</button>';
    }
    pEl.innerHTML = html;
}

