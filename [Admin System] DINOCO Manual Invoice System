// Helper: get rank-based price for a product object
function invGetRankPrice(p) {
    var dist = invDistributors.find(function(d){ return d.id == document.getElementById('inv-f-dist').value; });
    var rank = dist ? (dist.rank_system || 'standard') : 'standard';
    var priceField = 'price_' + rank;
    return parseFloat(p[priceField] || p.catalog_price || p.dealer_price || 0);
}

window.invFilterPicker = function() {
    var q = document.getElementById('inv-picker-search').value.toLowerCase();
    var list = document.getElementById('inv-prod-picker-list');
    var filtered = invProducts.filter(function(p){
        if (invPickerTab === 'set' && !(p.children && p.children.length > 0)) return false;
        return !q || (p.product_sku||'').toLowerCase().includes(q) || (p.title||'').toLowerCase().includes(q);
    });
    if (!filtered.length) { list.innerHTML = '<p style="padding:16px;color:#94a3b8;text-align:center;">ไม่พบสินค้า</p>'; return; }
    list.innerHTML = filtered.slice(0,80).map(function(p) {
        var price = invGetRankPrice(p);
        var isSet = p.children && p.children.length > 0;
        return '<div class="inv-picker-item" onclick="invPickProduct(' + JSON.stringify(p).replace(/"/g,'&quot;') + ',' + (parseFloat(price)||0) + ')">' +
            (p.img ? '<img src="' + escH(p.img) + '" alt="" loading="lazy">' : '<div style="width:52px;height:52px;border-radius:6px;background:#f1f5f9;flex-shrink:0;margin-right:10px;"></div>') +
            '<div style="flex:1;min-width:0;"><span class="pi-name">' + escH(p.title) + '</span>' +
            (isSet ? '<span class="pi-badge">SET</span>' : '') +
            '<br><span class="pi-sku">' + escH(p.product_sku) + '</span></div>' +
            '<span class="pi-price">฿' + invFmt(price) + '</span></div>';
    }).join('');
};

window.invPickProduct = function(p, price) {
    var tbody = document.getElementById('inv-prod-tbody');
    var rows  = tbody.querySelectorAll('tr');
    var tr    = rows[invPickerTarget];
    if (!tr) return;
    tr.querySelector('[data-field="sku"]').value         = p.product_sku || '';
    tr.querySelector('[data-field="description"]').value = p.title || '';
    tr.querySelector('[data-field="unit_price"]').value  = price || 0;
    tr.querySelector('[data-field="type"]').value        = (p.children && p.children.length) ? 'set' : 'product';
    var discPct = parseFloat(p.discount_pct) || 0;
    // Compute effective discount from rank price vs catalog price if available
    var catPrice = parseFloat(p.catalog_price) || 0;
    if (discPct === 0 && catPrice > 0 && price < catPrice) {
        discPct = Math.round((1 - price / catPrice) * 10000) / 100; // e.g. 10.50
    }
    tr.querySelector('[data-field="discount_raw"]').value = discPct > 0 ? discPct + '%' : '';
    // Update children
    var childSkus = (p.children && p.children.length) ? p.children : [];
    var childInput = tr.querySelector('[data-field="children"]');
    if (childInput) childInput.value = JSON.stringify(childSkus);
    _invRenderChildrenRow(tr, childSkus);
    // Update thumbnail
    var imgInput = tr.querySelector('[data-field="img_url"]');
    var imgCell  = tr.querySelector('.cell-img');
    if (imgInput) imgInput.value = p.img || '';
    if (imgCell) {
        var existing = imgCell.querySelector('img, .inv-prod-thumb-placeholder');
