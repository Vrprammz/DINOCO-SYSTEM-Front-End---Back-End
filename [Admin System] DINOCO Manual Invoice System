                    else invToast('error', 'аёӯаёӯаёҒаёҡаёҙаёҘаёҘа№үаёЎа№Җаё«аёҘаё§: ' + (d2&&d2.message||''));
                    invCloseBuilder();
                });
            } else {
                invCloseBuilder();
            }
        });
    } else {
        invApi('POST', '/invoice/create', payload, function(err, data) {
            _invBusy.save = false;
            if (err || !data.success) { invToast('error', 'аёӘаёЈа№үаёІаёҮ invoice аёҘа№үаёЎа№Җаё«аёҘаё§: ' + (data&&data.message||'')); return; }
            invToast('success', 'аёӘаёЈа№үаёІаёҮ ' + data.inv_number + ' а№ҖаёЈаёөаёўаёҡаёЈа№үаёӯаёў');
            if (issue && !data.issued) invToast('error', 'аёӯаёӯаёҒаёҡаёҙаёҘаёҘа№үаёЎа№Җаё«аёҘаё§: ' + (data.issue_error||''));
            else if (issue) invToast('success', 'аёӘа№ҲаёҮ LINE Flex Card а№„аёӣаёўаёұаёҮаё•аёұаё§а№Ғаё—аёҷа№ҒаёҘа№үаё§');
            invCloseBuilder();
        });
    }
};

