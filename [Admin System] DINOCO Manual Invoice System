// [เลือก] button in multi modal — single pick + close
function _invDiscRaw(p, price) {
    var discPct = parseFloat(p.discount_pct) || 0;
    var catPrice = parseFloat(p.catalog_price) || 0;
    if (discPct === 0 && catPrice > 0 && price < catPrice) {
        discPct = Math.round((1 - price / catPrice) * 10000) / 100;
    }
    return discPct > 0 ? discPct + '%' : '';
}
window.invPickSingleFromMulti = function(p, price, btn) {
    // If there is exactly one empty row (sku + description both blank), replace it
    var tbody = document.getElementById('inv-prod-tbody');
    var rows  = tbody.querySelectorAll('tr');
    if (rows.length === 1) {
        var r = rows[0];
        var skuVal  = r.querySelector('[data-field="sku"]').value.trim();
        var descVal = r.querySelector('[data-field="description"]').value.trim();
        if (!skuVal && !descVal) tbody.removeChild(r);
    }
    invAddRow({
        type:        (p.children && p.children.length) ? 'set' : 'product',
        sku:         p.product_sku || '',
        description: p.title || '',
        unit_price:  price || 0,
        discount_raw: _invDiscRaw(p, price),
        qty:         1,
        img_url:     p.img || '',
        children:    p.children || [],
    });
    // Don't close picker — give button feedback so user knows it was added
    if (btn) {
        btn.textContent = '✓ เพิ่มแล้ว';
        btn.style.cssText = 'font-size:0.75rem;padding:3px 10px;border:1px solid #16a34a;border-radius:6px;background:#dcfce7;color:#16a34a;cursor:default;';
        setTimeout(function() {
            btn.textContent = 'เลือก';
            btn.style.cssText = 'font-size:0.75rem;padding:3px 10px;border:1px solid #2563eb;border-radius:6px;background:#fff;color:#2563eb;cursor:pointer;';
        }, 1500);
    }
};
