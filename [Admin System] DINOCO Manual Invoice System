function dinoco_inv_generate_number() {
    $prefix = 'INV-DNC-';
    // Random 5-digit suffix (10000–99999) — intentionally non-sequential
    // so invoice numbers do not reveal total volume to distributors
    $max_attempts = 20;
    do {
        $candidate = $prefix . mt_rand(10000, 99999);
        $collision = get_posts([
            'post_type'      => 'b2b_order',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'post_status'    => ['publish', 'trash'],
            'meta_query'     => [
                ['key' => '_order_source', 'value' => 'manual_invoice'],
                ['key' => '_inv_number',   'value' => $candidate],
            ],
        ]);
        $max_attempts--;
    } while (!empty($collision) && $max_attempts > 0);

    return $candidate;
}

// Safe date → Unix timestamp: handles both Y-m-d (ISO) and d/m/Y (ACF display format)
// Uses DateTime::createFromFormat to avoid strtotime misparse when day<=12 (d/m/Y → m/d/Y)
function _dinoco_inv_parse_date($date_str) {
    if (empty($date_str) || $date_str === '0000-00-00') return false;
    $tz = new DateTimeZone('Asia/Bangkok');
    // Try d/m/Y first (ACF display format) — must come before strtotime to avoid day<=12 misparse
    $dt = DateTime::createFromFormat('d/m/Y', $date_str, $tz);
    if ($dt && $dt->format('d/m/Y') === $date_str) {
        $dt->setTime(0, 0, 0);
        return $dt->getTimestamp();
    }
    // Try Y-m-d (ISO format)
    $dt = DateTime::createFromFormat('Y-m-d', $date_str, $tz);
    if ($dt && $dt->format('Y-m-d') === $date_str) {
        $dt->setTime(0, 0, 0);
        return $dt->getTimestamp();
    }
    // Final fallback: strtotime (for other formats)
    $ts = strtotime($date_str);
    return ($ts && $ts > 86400) ? $ts : false;
}

function dinoco_inv_get_settings() {
    $s   = get_option('b2b_settings', []);
    $reg = get_option('b2b_registered_address', []);
    return [
        'company_name'   => $s['company_name']   ?? (defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO'),
        'bank_name'      => $s['bank_name']       ?? '',
        'bank_account'   => $s['bank_account']    ?? '',
        'bank_holder'    => $s['bank_holder']     ?? '',
        'promptpay_id'   => $s['promptpay_id']    ?? '',
        'logo_url'       => defined('B2B_LOGO_URL') ? B2B_LOGO_URL : '',
        'reg_name'       => $reg['reg_name']      ?? '',
        'reg_address'    => $reg['reg_address']   ?? '',
        'reg_province'   => $reg['reg_province']  ?? '',
        'reg_postcode'   => $reg['reg_postcode']  ?? '',
        'reg_phone'      => $reg['reg_phone']     ?? '',
    ];
}

function dinoco_inv_format_items_text($items) {
    $lines = [];
    foreach ($items as $item) {
        $sku   = !empty($item['sku']) ? '(' . $item['sku'] . ') ' : '';
        $desc  = $item['description'] ?? '';
        $qty   = intval($item['qty'] ?? 1);
        $total = floatval($item['line_total'] ?? 0);
        // Standard B2B format — no [INVOICE] prefix here (would appear as product name in Snippet 10 PDF)
        $lines[] = $sku . $desc . ' x' . $qty . ' = ฿' . number_format($total, 2);
    }
    // ━━━━ separator is stripped by Snippet 10's b2b_inv_parse_items(); anything after it is ignored in the PDF image
    // [INVOICE] marker placed after the separator so B2B Orders list can visually identify manual invoices
    return implode("\n", $lines) . "\n━━━━\n[INVOICE]";
}

// --- BANK & FLEX HELPERS (delegate to B2B equivalents when available) ---
function _dinoco_inv_get_bank_info() {
    if (function_exists('b2b_get_bank_info')) return b2b_get_bank_info();
    $en_map = ['002'=>'Bangkok Bank','004'=>'KBANK','006'=>'Krungthai Bank','011'=>'TMBThanachart',
               '014'=>'SCB','025'=>'CIMB Thai','030'=>'Government Savings Bank',
               '069'=>'Kiatnakin Phatra Bank (KKP)','073'=>'LH Bank'];
    $code = defined('B2B_BANK_CODE') ? B2B_BANK_CODE : '';
    return ['name'    => defined('B2B_BANK_NAME')    ? B2B_BANK_NAME    : '',
            'name_en' => $en_map[$code] ?? '',
            'account' => defined('B2B_BANK_ACCOUNT') ? B2B_BANK_ACCOUNT : '-',
            'holder'  => defined('B2B_BANK_HOLDER')  ? B2B_BANK_HOLDER  : '-'];
}
function _dinoco_inv_get_bank_logo_url() {
    if (function_exists('b2b_get_bank_logo_url')) return b2b_get_bank_logo_url();
    return defined('B2B_BANK_LOGO_URL') ? B2B_BANK_LOGO_URL : '';
}
function _dinoco_inv_get_bank_copy_text() {
    if (function_exists('b2b_get_bank_copy_text')) return b2b_get_bank_copy_text();
    $b = _dinoco_inv_get_bank_info();
    $t = $b['name'];
    if (!empty($b['name_en'])) $t .= ' (' . $b['name_en'] . ')';
    return $t . "\n" . $b['account'] . "\nชื่อ: " . $b['holder'];
}
function _dinoco_inv_flex_header($title, $subtitle = '') {
    if (function_exists('b2b_flex_header')) return b2b_flex_header($title, $subtitle, '#111111');
    $logo  = defined('B2B_LOGO_URL') ? B2B_LOGO_URL : (function_exists('b2b_get_logo_url') ? b2b_get_logo_url() : '');
    if (empty($logo)) $logo = 'https://dinoco.in.th/wp-content/uploads/dinoco-logo.png';
    $title_contents = [
        ['type' => 'text', 'text' => $title,    'weight' => 'bold', 'color' => '#ffffff', 'size' => 'md'],
    ];
    if ($subtitle) {
        $title_contents[] = ['type' => 'text', 'text' => $subtitle, 'color' => '#93c5fd', 'size' => 'xxs', 'margin' => 'xs'];
    }
    $inner = [
        ['type' => 'image', 'url' => $logo, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0],
        ['type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => $title_contents],
    ];
    return ['type' => 'box', 'layout' => 'vertical', 'backgroundColor' => '#111111', 'paddingAll' => '16px',
        'contents' => [['type' => 'box', 'layout' => 'horizontal', 'contents' => $inner, 'alignItems' => 'center']]];
}

function dinoco_inv_build_flex_card($inv, $settings) {
    $items     = json_decode($inv['items_json'] ?? '[]', true) ?: [];
    $total     = floatval($inv['total_amount']);
    $inv_no    = $inv['inv_number'] ?? '';
    $dist      = esc_html($inv['dist_name'] ?? '');
    $term      = intval($inv['credit_term_days'] ?? 0);
    $created_by = intval($inv['created_by'] ?? 0);
    $orderer   = ($created_by && ($ud = get_userdata($created_by))) ? $ud->display_name : 'DINOCO System';

    // Safe due date — ใช้ _dinoco_inv_parse_date แทน strtotime (รองรับ d/m/Y)
    $due_raw  = trim($inv['due_date'] ?? '');
    $due_ts   = (!empty($due_raw) && $due_raw !== '0000-00-00') ? _dinoco_inv_parse_date($due_raw) : false;
    $thai_due = ($due_ts && $due_ts > 86400) ? b2b_date('d/m/Y', $due_ts) : '-';
    // Safe issue date
    $issue_raw = trim($inv['issue_date'] ?? '');
    $issue_ts  = (!empty($issue_raw)) ? _dinoco_inv_parse_date($issue_raw) : false;
    // คำนวณจำนวนวันจริงจากวันที่บิล → วันครบกำหนด (ไม่ใช้ credit_term_days)
    $actual_days = '';
    if ($due_ts && $due_ts > 86400 && $issue_ts && $issue_ts > 86400) {
        $actual_days = intval(round(($due_ts - $issue_ts) / 86400));
    }
    $due_text = $thai_due . ($actual_days !== '' ? ' (' . $actual_days . ' วัน)' : '');

    // ── Item rows ──
    $item_rows       = [['type' => 'text', 'text' => '📦 รายการสินค้า', 'weight' => 'bold', 'size' => 'sm', 'margin' => 'md']];
    $inv_total_retail = 0;
    foreach ($items as $item) {
        $qty        = max(1, intval($item['qty'] ?? 1));
        $unit_price = floatval($item['unit_price'] ?? 0); // catalog/list price
        $disc_pct   = floatval($item['discount_pct'] ?? 0);
        $disc_val   = floatval($item['discount_val'] ?? 0);
        $line_total = floatval($item['line_total'] ?? 0);
        $img_url    = $item['img_url'] ?? '';
        $desc       = esc_html($item['description'] ?? '');
        $inv_total_retail += $unit_price * $qty;

        // Build discount display: prefer % over flat ฿
        if ($disc_pct > 0) {
            $disc_text = number_format($disc_pct, 0) . '%';
        } elseif ($disc_val > 0) {
            $disc_text = '-฿' . number_format($disc_val, 0);
        } else {
            $disc_text = '-';
        }

        $row = [];
        if (!empty($img_url)) {
            $row[] = ['type' => 'image', 'url' => $img_url, 'size' => 'xxs',
                      'aspectRatio' => '1:1', 'aspectMode' => 'cover', 'flex' => 0];
        }
        $row[] = ['type' => 'text', 'text' => $desc,       'size' => 'xs', 'flex' => 3, 'wrap' => true,      'color' => '#1e293b'];
        $row[] = ['type' => 'text', 'text' => 'x' . $qty,  'size' => 'xs', 'flex' => 1, 'align' => 'center', 'color' => '#64748b'];
        $row[] = ['type' => 'text', 'text' => $disc_text,  'size' => 'xs', 'flex' => 1, 'align' => 'center', 'color' => '#16a34a'];
        $row[] = ['type' => 'text', 'text' => '฿' . number_format($line_total, 0),
                                                                             'size' => 'xs', 'flex' => 2, 'align' => 'end',     'weight' => 'bold'];
        $item_rows[] = ['type' => 'box', 'layout' => 'horizontal', 'spacing' => 'sm', 'margin' => 'sm', 'contents' => $row];
    }

    // ── Summary rows ──
    $inv_total_discount = ($inv_total_retail > 0 && $inv_total_retail > $total)
        ? round($inv_total_retail - $total, 0) : 0;
    $summary = [['type' => 'separator', 'margin' => 'md']];
    if ($inv_total_retail > 0 && $inv_total_discount > 0) {
        $summary[] = ['type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'contents' => [
            ['type' => 'text', 'text' => 'ราคาจำหน่าย',         'size' => 'sm', 'color' => '#64748b', 'flex' => 3],
            ['type' => 'text', 'text' => '฿' . number_format($inv_total_retail, 0), 'size' => 'sm', 'color' => '#1e293b', 'flex' => 3, 'align' => 'end'],
        ]];
        $summary[] = ['type' => 'box', 'layout' => 'horizontal', 'margin' => 'xs', 'contents' => [
            ['type' => 'text', 'text' => 'ส่วนลดตัวแทน',        'size' => 'sm', 'color' => '#16a34a', 'flex' => 3],
            ['type' => 'text', 'text' => '-฿' . number_format($inv_total_discount, 0), 'size' => 'sm', 'color' => '#16a34a', 'flex' => 3, 'align' => 'end'],
        ]];
        $summary[] = ['type' => 'box', 'layout' => 'horizontal', 'margin' => 'xs', 'contents' => [
            ['type' => 'text', 'text' => 'ราคาตัวแทนรวมส่วนลด', 'size' => 'sm', 'color' => '#64748b', 'flex' => 3],
            ['type' => 'text', 'text' => '฿' . number_format($total, 0), 'size' => 'sm', 'color' => '#1e293b', 'flex' => 3, 'align' => 'end'],
        ]];
    }
    $summary[] = ['type' => 'separator', 'margin' => 'md'];
    $summary[] = ['type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'contents' => [
        ['type' => 'text', 'text' => 'มูลค่ารวมสุทธิ', 'weight' => 'bold', 'size' => 'md', 'flex' => 3],
        ['type' => 'text', 'text' => '฿' . number_format($total, 2), 'weight' => 'bold', 'size' => 'xl', 'color' => '#111111', 'align' => 'end', 'flex' => 3],
    ]];
    $summary[] = ['type' => 'box', 'layout' => 'horizontal', 'margin' => 'sm', 'contents' => [
        ['type' => 'text', 'text' => '📅 กำหนดชำระ', 'size' => 'xs', 'color' => '#dc2626', 'flex' => 2],
        ['type' => 'text', 'text' => $due_text,      'size' => 'xs', 'weight' => 'bold', 'color' => '#dc2626', 'align' => 'end', 'flex' => 3],
    ]];

    // ── Bank card ──
    $bank      = _dinoco_inv_get_bank_info();
    $bank_logo = _dinoco_inv_get_bank_logo_url();
    $bank_copy = _dinoco_inv_get_bank_copy_text();
    $bank_card = [];
    if (!empty($bank_logo)) {
        $bank_card[] = ['type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'contents' => [
            ['type' => 'image', 'url' => $bank_logo, 'size' => 'xxs', 'aspectRatio' => '1:1', 'aspectMode' => 'cover', 'flex' => 0],
            ['type' => 'box', 'layout' => 'vertical', 'flex' => 4, 'contents' => array_filter([
                ['type' => 'text', 'text' => $bank['name'],                   'weight' => 'bold', 'size' => 'sm', 'color' => '#1e293b'],
                !empty($bank['name_en']) ? ['type' => 'text', 'text' => '(' . $bank['name_en'] . ')',    'size' => 'xxs',    'color' => '#94a3b8'] : null,
            ])],
        ]];
    } else {
        $bank_card[] = ['type' => 'text', 'text' => '🏦 ' . $bank['name'], 'weight' => 'bold', 'size' => 'sm', 'color' => '#1e293b'];
    }
    $bank_card[] = ['type' => 'text', 'text' => $bank['account'], 'weight' => 'bold', 'size' => 'xxl', 'color' => '#111111', 'align' => 'center', 'margin' => 'lg'];
    $bank_card[] = ['type' => 'text', 'text' => 'ชื่อบัญชี: ' . $bank['holder'], 'size' => 'xs', 'color' => '#64748b', 'align' => 'center', 'margin' => 'xs'];
    $bank_card[] = ['type' => 'button', 'style' => 'primary', 'color' => '#16a34a', 'height' => 'sm', 'margin' => 'lg',
        'action' => ['type' => 'clipboard', 'label' => '📋 คัดลอกข้อมูลบัญชี', 'clipboardText' => $bank_copy]];
    $payment_section = [['type' => 'box', 'layout' => 'vertical', 'margin' => 'md',
        'backgroundColor' => '#f0fdf4', 'cornerRadius' => '12px', 'paddingAll' => '16px',
        'contents' => $bank_card]];

    // ── Assemble body ──
    $issue_raw = trim($inv['issue_date'] ?? '');
    $issue_ts  = !empty($issue_raw) ? _dinoco_inv_parse_date($issue_raw) : false;
    $now = ($issue_ts && $issue_ts > 86400)
        ? b2b_date('d/m/Y', $issue_ts)
        : b2b_date('d/m/Y');
    $body_contents = array_merge(
        [
            ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                ['type' => 'text', 'text' => 'เลขที่', 'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                // wrap:true so long INV numbers (e.g. INV_BKK_SHOP_TEST_DNC_2026_XXXXXXX) display in full instead of being truncated
                ['type' => 'text', 'text' => $inv_no,  'size' => 'xs', 'weight' => 'bold',   'flex' => 4, 'align' => 'end', 'wrap' => true],
            ]],
            ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                ['type' => 'text', 'text' => 'ตัวแทนจำหน่าย', 'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                ['type' => 'text', 'text' => $dist,           'size' => 'xs', 'weight' => 'bold',   'flex' => 4, 'align' => 'end', 'wrap' => true],
            ]],
            ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                ['type' => 'text', 'text' => 'ผู้สั่ง', 'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                ['type' => 'text', 'text' => $orderer, 'size' => 'xs', 'weight' => 'bold',   'flex' => 4, 'align' => 'end'],
            ]],
            ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                ['type' => 'text', 'text' => 'วันที่', 'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                ['type' => 'text', 'text' => $now,     'size' => 'xs',                        'flex' => 4, 'align' => 'end'],
            ]],
            ['type' => 'separator', 'margin' => 'md'],
        ],
        $item_rows, $summary,
        [
            ['type' => 'separator', 'margin' => 'md'],
            ['type' => 'text', 'text' => '💰 ช่องทางชำระเงิน', 'weight' => 'bold', 'size' => 'sm', 'margin' => 'md'],
        ],
        $payment_section,
        [['type' => 'text', 'text' => '📸 โอนแล้วส่งสลิปเข้ากลุ่มนี้ได้เลยครับ', 'size' => 'xs', 'color' => '#999999', 'margin' => 'md', 'wrap' => true]]
    );

    return [['type' => 'flex',
        'altText'  => mb_substr('🧾 ใบแจ้งหนี้/วางบิล ' . $inv_no . ' ฿' . number_format($total, 0), 0, 400),
        'contents' => [
            'type'   => 'bubble',
            'header' => _dinoco_inv_flex_header('🧾 ใบแจ้งหนี้/วางบิล'),
            'body'   => ['type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $body_contents],
        ],
    ]];
}

// ── SUMMARY FLEX CARD: รวมบิลค้างทั้งหมดของตัวแทน (V.2.5) ──

function _dinoco_inv_get_pending_invoices($dist_id) {
    $dist_id = intval($dist_id);
    if ($dist_id <= 0 || get_post_type($dist_id) !== 'distributor') return null;

    $ids = get_posts([
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => -1,
        'meta_query'     => [
            'relation' => 'AND',
            ['key' => '_order_source', 'value' => 'manual_invoice'],
            ['key' => '_dist_post_id', 'value' => $dist_id, 'type' => 'NUMERIC'],
            ['key' => 'order_status',  'value' => 'awaiting_payment'],
        ],
        'fields' => 'ids',
    ]);
    if (empty($ids)) return ['invoices' => [], 'count' => 0, 'total' => 0, 'dist_name' => get_the_title($dist_id), 'dist_id' => $dist_id];

    update_postmeta_cache($ids);

    $invoices    = [];
    $grand_total = 0;
    $now_ts      = current_time('timestamp');

    foreach ($ids as $id) {
        $inv_no     = get_post_meta($id, '_inv_number', true) ?: ('#' . $id);
        $total      = floatval(get_field('total_amount', $id));
        $paid       = floatval(get_post_meta($id, '_inv_paid_amount', true));
        $remaining  = max(0, $total - $paid);
        $due_raw    = trim(get_field('due_date', $id) ?: '');
        $due_ts     = _dinoco_inv_parse_date($due_raw);
        $days_diff  = 0;
        $overdue    = false;
        if ($due_ts) {
            $days_diff = intval(floor(($due_ts - $now_ts) / 86400));
            $overdue   = $days_diff < 0;
        }
        $invoices[] = [
            'post_id'    => $id,
            'inv_number' => $inv_no,
            'total'      => $total,
            'paid'       => $paid,
            'remaining'  => $remaining,
            'due_date'   => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
            'days_diff'  => $days_diff,
            'overdue'    => $overdue,
        ];
        $grand_total += $remaining;
    }

    usort($invoices, function($a, $b) { return ($a['days_diff'] ?? 0) - ($b['days_diff'] ?? 0); });

    return [
        'invoices'  => $invoices,
        'count'     => count($invoices),
        'total'     => $grand_total,
        'dist_name' => get_the_title($dist_id),
        'dist_id'   => $dist_id,
    ];
}

