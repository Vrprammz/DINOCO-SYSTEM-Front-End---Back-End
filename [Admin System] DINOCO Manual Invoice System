// --- CREATE ---
function dinoco_inv_rest_create(WP_REST_Request $req) {
    $dist_id  = intval($req->get_param('dist_id'));
    $items    = $req->get_param('items') ?: [];
    $note     = sanitize_textarea_field($req->get_param('admin_note') ?? '');
    $ref      = sanitize_text_field($req->get_param('reference') ?? '');
    $due_date = sanitize_text_field($req->get_param('due_date') ?? '');
    $ship_fee = floatval($req->get_param('shipping_fee') ?? 0);
    $disc_val = floatval($req->get_param('global_discount_val') ?? 0);
    $disc_pct = floatval($req->get_param('global_discount_pct') ?? 0);
    $do_issue = (bool) $req->get_param('issue');

    if (!$dist_id || get_post_type($dist_id) !== 'distributor') {
        return new WP_Error('invalid', 'ต้องเลือกตัวแทนจำหน่าย', ['status' => 400]);
    }
    if (empty($items)) {
        return new WP_Error('invalid', 'ต้องมีรายการสินค้าอย่างน้อย 1 รายการ', ['status' => 400]);
    }

    // Sanitize items
    $clean_items = [];
    $subtotal    = 0;
    foreach ($items as $item) {
        $qty       = max(1, intval($item['qty'] ?? 1));
        $unit_price = max(0, floatval($item['unit_price'] ?? 0));
        $disc_unit  = floatval($item['discount_val'] ?? 0);
        $disc_unit_pct = floatval($item['discount_pct'] ?? 0);
        // Prefer pct if both given; pct takes precedence when > 0
        $effective_price = $disc_unit_pct > 0
            ? $unit_price * (1 - $disc_unit_pct / 100)
            : max(0, $unit_price - $disc_unit);
        $line_total = round($effective_price * $qty, 2);
        $subtotal  += $line_total;
        $clean_items[] = [
            'type'         => sanitize_text_field($item['type'] ?? 'product'),
            'sku'          => sanitize_text_field($item['sku'] ?? ''),
            'description'  => sanitize_text_field($item['description'] ?? ''),
            'qty'          => $qty,
            'unit_price'   => $unit_price,
            'discount_val' => $disc_unit,
            'discount_pct' => $disc_unit_pct,
            'line_total'   => $line_total,
            'children'     => array_map('sanitize_text_field', (array)($item['children'] ?? [])),
        ];
    }

    // Apply global discount
    if ($disc_pct > 0) {
        $global_disc = round($subtotal * ($disc_pct / 100), 2);
    } else {
        $global_disc = min($disc_val, $subtotal);
    }
    $total = round($subtotal - $global_disc + $ship_fee, 2);

    // Pull distributor info
    $dist_post = get_post($dist_id);
    $dist_name = get_field('shop_name', $dist_id) ?: $dist_post->post_title;
    $inv_number = dinoco_inv_generate_number($dist_name);

    $post_id = wp_insert_post([
        'post_type'   => 'b2b_order',
        'post_status' => 'publish',
        'post_title'  => $inv_number . ' — ' . $dist_name,
        'post_author' => get_current_user_id(),
    ]);
    if (is_wp_error($post_id)) return new WP_Error('db_error', 'ไม่สามารถสร้าง invoice ได้', ['status' => 500]);

    // Save meta
    update_post_meta($post_id, '_order_source', 'manual_invoice');
    update_post_meta($post_id, '_inv_number', $inv_number);
    update_post_meta($post_id, '_dist_post_id', $dist_id);
    update_post_meta($post_id, '_inv_items', wp_json_encode($clean_items));
    update_post_meta($post_id, '_inv_paid_amount', 0);
    update_post_meta($post_id, '_inv_partial_payments', wp_json_encode([]));
    update_post_meta($post_id, '_inv_created_by', get_current_user_id());
    if ($ref) update_post_meta($post_id, '_inv_reference', $ref);

    // ACF fields
    update_field('order_status', 'draft', $post_id);
    update_field('total_amount', $total, $post_id);
    update_field('dist_name', $dist_name, $post_id);
    update_field('dist_phone', get_field('dist_phone', $dist_id), $post_id);
    update_field('dist_address', get_field('dist_address', $dist_id), $post_id);
    update_field('dist_district', get_field('dist_district', $dist_id), $post_id);
    update_field('dist_city', get_field('dist_city', $dist_id), $post_id);
    update_field('dist_province', get_field('dist_province', $dist_id), $post_id);
    update_field('dist_postcode', get_field('dist_postcode', $dist_id), $post_id);
    update_field('admin_note', $note, $post_id);
    update_field('is_billed', false, $post_id);
    if ($due_date) update_field('due_date', $due_date, $post_id);
    update_field('order_items', dinoco_inv_format_items_text($clean_items), $post_id);

    b2b_add_audit_log($post_id, 'created', 'สร้างใบแจ้งหนี้/วางบิล Draft ฿' . number_format($total, 0));

    if ($do_issue) {
        $issue_result = _dinoco_inv_do_issue($post_id, $dist_id, $total, $dist_name);
        if (is_wp_error($issue_result)) {
            return rest_ensure_response(['success' => true, 'id' => $post_id, 'inv_number' => $inv_number, 'issued' => false, 'issue_error' => $issue_result->get_error_message()]);
        }
    }

    return rest_ensure_response(['success' => true, 'id' => $post_id, 'inv_number' => $inv_number, 'issued' => $do_issue]);
}

