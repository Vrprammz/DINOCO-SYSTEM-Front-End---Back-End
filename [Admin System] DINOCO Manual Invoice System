// Render (or update) tree-style child sub-rows below a SET product row
function _invRenderChildrenRow(parentTr, childSkus) {
    // Remove all existing child rows
    var sib = parentTr.nextElementSibling;
    while (sib && sib.classList.contains('inv-child-tr')) {
        var rem = sib; sib = sib.nextElementSibling; rem.parentNode.removeChild(rem);
    }
    if (!childSkus || !childSkus.length) return;
    var frag = document.createDocumentFragment();
    childSkus.forEach(function(sku) {
        var skuStr = (typeof sku === 'object' && sku.sku) ? sku.sku : sku;
        var cp = invProducts.find(function(p){ return p.product_sku === skuStr; });
        var imgEl = (cp && cp.img)
            ? '<img class="child-img" src="' + escH(cp.img) + '" loading="lazy" alt="">'
            : '<span class="child-img-ph"></span>';
        var name = cp ? escH(cp.title) : escH(skuStr);
        var tr = document.createElement('tr');
        tr.className = 'inv-child-tr';
        var qty = (typeof sku === 'object' && sku.qty) ? sku.qty : 1;
        tr.innerHTML =
            '<td class="child-img-cell">' + imgEl + '</td>' +
            '<td class="child-sku-cell"><span class="child-sku">' + escH(typeof sku === 'object' ? sku.sku : sku) + '</span></td>' +
            '<td><span class="child-name">' + name + '</span></td>' +
            '<td style="text-align:center;"><span style="font-size:0.8rem;color:#475569;font-weight:600;">×' + qty + '</span></td>' +
            '<td colspan="3"></td>' +
            '<td></td>';
        frag.appendChild(tr);
    });
    parentTr.parentNode.insertBefore(frag, parentTr.nextSibling);
}

window.invAddRow = function(item) {
    item = item || {};
    var tbody = document.getElementById('inv-prod-tbody');
    var idx   = tbody.querySelectorAll('tr:not(.inv-child-tr)').length;
    var tr    = document.createElement('tr');
    tr.dataset.idx = idx;
    var discDisp = item.discount_raw !== undefined ? item.discount_raw
                 : (item.discount_pct > 0 ? item.discount_pct + '%'
                 : (item.discount_val > 0 ? item.discount_val : ''));
    var imgUrl = item.img_url || '';
    tr.innerHTML =
        '<td class="cell-img">' +
            '<input type="hidden" data-field="img_url" value="' + escH(imgUrl) + '">' +
            (imgUrl
                ? '<img class="inv-prod-thumb" src="' + escH(imgUrl) + '" alt="" loading="lazy">'
                : '<span class="inv-prod-thumb-placeholder"></span>') +
        '</td>' +
        '<td class="cell-sku">' +
            '<button class="inv-sel-btn" onclick="invOpenPicker(' + idx + ')">เลือก</button>' +
            '<input type="hidden" data-field="type" value="' + escH(item.type || 'custom') + '">' +
            '<input type="hidden" data-field="children" value="' + escH(JSON.stringify(item.children || [])) + '">' +
            '<input type="text" class="inv-input" data-field="sku" value="' + escH(item.sku || '') + '" placeholder="รหัส" style="margin-top:4px;" oninput="invRecalc()">' +
        '</td>' +
        '<td class="cell-name"><input type="text" class="inv-input" data-field="description" value="' + escH(item.description || '') + '" placeholder="ชื่อสินค้า *" oninput="invRecalc()"></td>' +
        '<td class="cell-qty"><input type="number" class="inv-input" data-field="qty" value="' + (item.qty || 1) + '" min="1" oninput="invRecalc()"></td>' +
        '<td class="cell-price"><input type="number" class="inv-input" data-field="unit_price" value="' + (item.unit_price || 0) + '" min="0" step="0.01" oninput="invRecalc()"></td>' +
        '<td class="cell-disc"><input type="text" class="inv-input" data-field="discount_raw" value="' + escH(String(discDisp)) + '" placeholder="฿ หรือ %" oninput="invRecalc()"></td>' +
        '<td class="cell-total"><span data-field="line_total">' + invFmt(item.line_total || 0) + '</span></td>' +
        '<td class="cell-del"><button class="inv-del-row" onclick="invDelRow(this)">✕</button></td>';
    tbody.appendChild(tr);
    // Render children chips for SET products
    if ((item.type === 'set') && item.children && item.children.length) {
        _invRenderChildrenRow(tr, item.children);
    }
    invRecalc();
};

window.invAddCustomRow = function() {
    invAddRow({type:'custom'});
};

window.invDelRow = function(btn) {
    var tr = btn.closest('tr');
    if (tr) {
        var next = tr.nextElementSibling;
        while (next && next.classList.contains('inv-child-tr')) {
            var rem = next; next = next.nextElementSibling; rem.parentNode.removeChild(rem);
        }
        tr.parentNode.removeChild(tr);
        invRecalc();
    }
};

window.invRecalc = function() {
    var subtotal = 0;
    document.querySelectorAll('#inv-prod-tbody tr:not(.inv-child-tr)').forEach(function(tr) {
        var qty    = parseFloat(tr.querySelector('[data-field="qty"]').value) || 0;
        var price  = parseFloat(tr.querySelector('[data-field="unit_price"]').value) || 0;
        var discRaw = tr.querySelector('[data-field="discount_raw"]').value.trim();
        var effective = price;
        if (discRaw.endsWith('%')) {
            var pct = parseFloat(discRaw) || 0;
            effective = price * (1 - pct/100);
        } else if (discRaw !== '') {
            var amt = parseFloat(discRaw) || 0;
            effective = Math.max(0, price - amt);
        }
        var lt = Math.round(effective * qty * 100) / 100;
        tr.querySelector('[data-field="line_total"]').textContent = invFmt(lt);
        subtotal += lt;
    });
    var discRaw = document.getElementById('inv-f-global-disc').value.trim();
    var globalDisc = 0;
    if (discRaw.endsWith('%')) {
        globalDisc = subtotal * (parseFloat(discRaw) / 100);
    } else {
        globalDisc = Math.min(parseFloat(discRaw) || 0, subtotal);
    }
    var ship  = parseFloat(document.getElementById('inv-f-ship').value) || 0;
    var total = Math.round((subtotal - globalDisc + ship) * 100) / 100;
    document.getElementById('inv-grand-total').textContent = '฿' + invFmt(total);
};

