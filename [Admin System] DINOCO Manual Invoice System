            }
        } catch (e) { /* fall through to native */ }
        var msg = (opts && opts.message) || 'а№ғаёӘа№Ҳаё„а№ҲаёІ:';
        resolve(window.prompt(msg, (opts && opts.default) || ''));
    });
}

// ========= TOAST =========
function invToast(type, msg) {
    var t = document.getElementById('inv-toast');
    var d = document.createElement('div');
    d.className = 'inv-toast-item ' + type;
    var span = document.createElement('span');
    span.textContent = msg;
    var btn = document.createElement('button');
    btn.className = 'inv-toast-close';
    btn.innerHTML = '&times;';
    btn.onclick = function(){ if(d.parentNode) d.parentNode.removeChild(d); };
    d.appendChild(span);
    d.appendChild(btn);
    t.appendChild(d);
    // V.33.1: Use original setTimeout to bypass auto-refresh override
    var _realTimeout = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
    var timer = _realTimeout(function(){ if(d.parentNode) d.parentNode.removeChild(d); }, 4000);
    btn.addEventListener('click', function(){ clearTimeout(timer); });
}

// ========= API helper =========
// V.34.10: tightened auth-error detection вҖ” only known auth codes trigger reload.
// `_invNonceReloadShown` is a one-shot guard for **multiple parallel prompts** in the same
// JS tick (NOT retry loop вҖ” JS event loop is single-threaded so flag set is synchronous
// before next dispatch). User cancel resets flag вҶ’ next call can re-prompt.
var _invNonceReloadShown = false;

// V.34.10 HIGH-1: whitelist of auth-related WP REST error codes that warrant auto-reload.
// All other 403s (rate_limited, bo_locked, custom capability checks) fall through to
// normal toast вҖ” admin sees actual error + decides action without forced logout.
var _INV_AUTH_RELOAD_CODES = {
    'rest_cookie_invalid_nonce': 'nonce',  // expired wp_rest nonce вҶ’ reload page (refresh nonce)
    'rest_forbidden':            'logout', // generic WP REST 403 вҶ’ typically logged out
    'rest_user_cannot_access':   'logout', // user lost capability / role removed
    'rest_not_logged_in':        'logout', // 401 equivalent
};

function _invHandleAuthError(status, errCode, errMsg) {
    if (_invNonceReloadShown) return;
    // V.34.10: tighten detection вҖ” only known auth codes (whitelist), not bare 403.
    // Fallback: 403 with literal "cookie check failed" message string (legacy WP < 5.0
    // fallback path that doesn't return code) вҶ’ treat as nonce.
    var authType = errCode && _INV_AUTH_RELOAD_CODES[errCode] ? _INV_AUTH_RELOAD_CODES[errCode] : null;
    if (!authType && status === 403 && typeof errMsg === 'string') {
        var msgLower = errMsg.toLowerCase();
        if (msgLower.indexOf('cookie check failed') !== -1) authType = 'nonce';
    }
    if (!authType) return; // not an auth error вҶ’ fall through to normal toast (rate_limited etc.)
    _invNonceReloadShown = true;
    var msg = authType === 'nonce'
        ? 'рҹ”„ аё«аёҷа№үаёІаёҷаёөа№үа№Җаёӣаёҙаё”аё—аёҙа№үаёҮа№„аё§а№үаёҷаёІаёҷа№ҖаёҒаёҙаёҷа№„аёӣ (Session аё«аёЎаё”аёӯаёІаёўаёё)\n\nаёҒаё” OK а№Җаёһаё·а№Ҳаёӯа№Ӯаё«аёҘаё”аё«аёҷа№үаёІа№ғаё«аёЎа№Ҳ вҖ” аёӮа№үаёӯаёЎаё№аёҘаё—аёөа№ҲаёўаёұаёҮа№„аёЎа№Ҳа№„аё”а№үаёҡаёұаёҷаё—аё¶аёҒаёҲаё°аё«аёІаёўа№„аёӣ'
        : 'вӣ” а№„аёЎа№ҲаёЎаёөаёӘаёҙаё—аёҳаёҙа№Ңа№ҖаёӮа№үаёІаё–аё¶аёҮ вҖ” аёҒаёЈаёёаё“аёІ login а№ғаё«аёЎа№Ҳ\n\nаёҒаё” OK а№Җаёһаё·а№Ҳаёӯа№„аёӣаё«аёҷа№үаёІ Login';
    // V.34.10 LOW-2: setTimeout 100ms ensures cb() completes first вҶ’ toast/UI updates show
    // before confirm() blocks. Intentional ordering: result surface вҶ’ user sees it вҶ’ prompt.
    setTimeout(function() {
        if (confirm(msg)) {
            if (authType === 'nonce') {
                window.location.reload();
            } else {
                window.location.href = '/wp-login.php?redirect_to=' + encodeURIComponent(window.location.href);
            }
        } else {
            _invNonceReloadShown = false; // user cancelled вҖ” allow re-prompt next call
        }
    }, 100);
}

function invApi(method, path, body, cb) {
    var opts = {
        method: method,
        headers: { 'Content-Type': 'application/json', 'X-WP-Nonce': INV_NONCE },
    };
    if (body && (method === 'POST' || method === 'PUT')) opts.body = JSON.stringify(body);
    fetch(INV_REST + path + (method === 'GET' && body ? '?' + new URLSearchParams(body) : ''), opts)
        .then(function(r){
            if (!r.ok) {
                // V.34.10 MED-1: only invoke auth handler on JSON responses (WP REST API).
                // HTML responses (Cloudflare WAF challenge, server error page) вҶ’ infrastructure
                // issue, not stale nonce вҶ’ skip handler to avoid infinite reload loop.
                var ct = r.headers.get('content-type') || '';
                var isJson = ct.indexOf('application/json') !== -1;
                if (isJson) {
                    return r.json().then(function(err){
                        _invHandleAuthError(r.status, err && err.code, err && err.message);
                        cb(null, {success:false, message:err.message||'а№ҖаёҒаёҙаё”аёӮа№үаёӯаёңаёҙаё”аёһаёҘаёІаё”', _http_status: r.status, _err_code: err && err.code});
                    }).catch(function() {
                        // JSON parse failed despite content-type вҶ’ malformed response
                        cb(null, {success:false, message:'HTTP ' + r.status + ' (malformed JSON)', _http_status: r.status});
                    });
                } else {
                    // Non-JSON 403/5xx (Cloudflare/WAF/PHP fatal HTML page) вҶ’ surface status
                    // without auth handler. User sees "HTTP 403" toast and can investigate.
                    return r.text().then(function(t) {
                        var preview = t ? t.substring(0, 80).replace(/\s+/g, ' ') : '';
                        cb(null, {success:false, message:'HTTP ' + r.status + (preview ? ' вҖ” ' + preview : ''), _http_status: r.status, _non_json: true});
                    }).catch(function() {
                        cb(null, {success:false, message:'HTTP ' + r.status, _http_status: r.status});
                    });
                }
            }
            return r.json().then(function(d){ cb(null, d); });
        })
        .catch(function(e){ cb(e, null); });
}

