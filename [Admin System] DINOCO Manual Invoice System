            '<td style="padding:8px 12px;"><input type="checkbox" class="multi-cb" data-sku="' + escH(p.product_sku) + '"></td>' +
            '<td style="padding:4px 6px;">' + (p.img ? '<img src="' + escH(p.img) + '" alt="" loading="lazy" style="width:40px;height:40px;object-fit:cover;border-radius:5px;background:#f1f5f9;">' : '') +
                (isSet ? '<span style="display:block;background:#fef3c7;color:#92400e;font-size:0.7rem;padding:1px 6px;border-radius:8px;margin-top:2px;text-align:center;">SET</span>' : '') + '</td>' +
            '<td style="padding:6px 8px;"><div style="font-weight:600;font-size:0.85rem;">' + escH(p.title) + '</div>' +
                '<div style="color:#94a3b8;font-size:0.75rem;">' + escH(p.product_sku) + '</div></td>' +
