function dinoco_inv_rest_create(WP_REST_Request $req) {
    $dist_id    = intval($req->get_param('dist_id'));
    $items      = $req->get_param('items') ?: [];
    $note       = sanitize_textarea_field($req->get_param('admin_note') ?? '');
    $ref        = sanitize_text_field($req->get_param('reference') ?? '');
    $due_date   = sanitize_text_field($req->get_param('due_date') ?? '');
    $inv_date   = sanitize_text_field($req->get_param('invoice_date') ?? ''); // user-selected date
    $ship_fee   = floatval($req->get_param('shipping_fee') ?? 0);
    $disc_val   = floatval($req->get_param('global_discount_val') ?? 0);
    $disc_pct   = floatval($req->get_param('global_discount_pct') ?? 0);
    $do_issue   = (bool) $req->get_param('issue');

    if (!$dist_id || get_post_type($dist_id) !== 'distributor') {
        return new WP_Error('invalid', 'ต้องเลือกตัวแทนจำหน่าย', ['status' => 400]);
    }
    if (empty($items)) {
        return new WP_Error('invalid', 'ต้องมีรายการสินค้าอย่างน้อย 1 รายการ', ['status' => 400]);
    }

    // Sanitize items
    $clean_items = [];
    $subtotal    = 0;
    foreach ($items as $item) {
        $qty       = max(1, intval($item['qty'] ?? 1));
        $unit_price = max(0, floatval($item['unit_price'] ?? 0));
        $disc_unit  = floatval($item['discount_val'] ?? 0);
        $disc_unit_pct = floatval($item['discount_pct'] ?? 0);
        // Prefer pct if both given; pct takes precedence when > 0
        $effective_price = $disc_unit_pct > 0
            ? $unit_price * (1 - $disc_unit_pct / 100)
            : max(0, $unit_price - $disc_unit);
        $line_total = round($effective_price * $qty, 2);
        $subtotal  += $line_total;
        $clean_items[] = [
            'type'         => sanitize_text_field($item['type'] ?? 'product'),
            'sku'          => sanitize_text_field($item['sku'] ?? ''),
            'description'  => sanitize_text_field($item['description'] ?? ''),
            'qty'          => $qty,
            'unit_price'   => $unit_price,
            'discount_val' => $disc_unit,
            'discount_pct' => $disc_unit_pct,
            'line_total'   => $line_total,
            'img_url'      => esc_url_raw($item['img_url'] ?? ''),
            'children'     => array_map('sanitize_text_field', (array)($item['children'] ?? [])),
        ];
    }

    // Apply global discount
    if ($disc_pct > 0) {
        $global_disc = round($subtotal * ($disc_pct / 100), 2);
    } else {
        $global_disc = min($disc_val, $subtotal);
    }
    $total = round($subtotal - $global_disc + $ship_fee, 2);

    // Pull distributor info
    $dist_post = get_post($dist_id);
    $dist_name = get_field('shop_name', $dist_id) ?: $dist_post->post_title;
    $inv_number = dinoco_inv_generate_number();

    $post_id = wp_insert_post([
        'post_type'   => 'b2b_order',
        'post_status' => 'publish',
        'post_title'  => $inv_number . ' — ' . $dist_name,
        'post_author' => get_current_user_id(),
    ]);
    if (is_wp_error($post_id)) return new WP_Error('db_error', 'ไม่สามารถสร้าง invoice ได้', ['status' => 500]);

    // Save meta
    update_post_meta($post_id, '_order_source', 'manual_invoice');
    update_post_meta($post_id, '_inv_number', $inv_number);
    update_post_meta($post_id, '_dist_post_id', $dist_id);
    // source_group_id is required by b2b_recalculate_debt() — must match distributor's line_group_id
    $dist_group_id = get_field('line_group_id', $dist_id);
    if ($dist_group_id) update_field('source_group_id', $dist_group_id, $post_id);
    update_post_meta($post_id, '_inv_items', wp_json_encode($clean_items, JSON_UNESCAPED_UNICODE));
    update_post_meta($post_id, '_inv_paid_amount', 0);
    update_post_meta($post_id, '_inv_partial_payments', wp_json_encode([]));
    update_post_meta($post_id, '_inv_created_by', get_current_user_id());
    if ($inv_date) {
        update_post_meta($post_id, '_inv_date', $inv_date); // user-selected invoice date
    } else {
        update_post_meta($post_id, '_inv_date', b2b_date('Y-m-d')); // default to today (Bangkok TZ)
    }
    if ($ref) update_post_meta($post_id, '_inv_reference', $ref);

    // ACF fields
    update_field('order_status', 'draft', $post_id);
    update_field('total_amount', $total, $post_id);
    update_field('dist_name', $dist_name, $post_id);
    update_field('dist_phone', get_field('dist_phone', $dist_id), $post_id);
    update_field('dist_address', get_field('dist_address', $dist_id), $post_id);
    update_field('dist_district', get_field('dist_district', $dist_id), $post_id);
    update_field('dist_city', get_field('dist_city', $dist_id), $post_id);
    update_field('dist_province', get_field('dist_province', $dist_id), $post_id);
    update_field('dist_postcode', get_field('dist_postcode', $dist_id), $post_id);
    update_field('admin_note', $note, $post_id);
    update_field('is_billed', false, $post_id);
    if ($due_date) update_field('due_date', $due_date, $post_id);
    update_post_meta($post_id, '_inv_global_disc_pct', $disc_pct);
    update_post_meta($post_id, '_inv_global_disc_val', $disc_val);
    update_post_meta($post_id, '_inv_ship_fee', $ship_fee);
    update_field('order_items', dinoco_inv_format_items_text($clean_items), $post_id);

    b2b_add_audit_log($post_id, 'created', 'สร้างใบแจ้งหนี้/วางบิล Draft ฿' . number_format($total, 0));

    if ($do_issue) {
        $issue_result = _dinoco_inv_do_issue($post_id, $dist_id, $total, $dist_name);
        if (is_wp_error($issue_result)) {
            return rest_ensure_response(['success' => true, 'id' => $post_id, 'inv_number' => $inv_number, 'issued' => false, 'issue_error' => $issue_result->get_error_message()]);
        }
    }

    return rest_ensure_response(['success' => true, 'id' => $post_id, 'inv_number' => $inv_number, 'issued' => $do_issue]);
}

// --- UPDATE (draft only) ---
function dinoco_inv_rest_update(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $status = get_field('order_status', $id);
    if ($status !== 'draft' && $status !== 'awaiting_payment' && $status !== 'overdue') return new WP_REST_Response(array('success'=>false,'message'=>'แก้ไขได้เฉพาะ Draft หรือรอชำระเท่านั้น'),400);

    $dist_id  = intval($req->get_param('dist_id'));
    $items    = $req->get_param('items') ?: [];
    $note     = sanitize_textarea_field($req->get_param('admin_note') ?? '');
    $ref      = sanitize_text_field($req->get_param('reference') ?? '');
    $due_date = sanitize_text_field($req->get_param('due_date') ?? '');
    $inv_date = sanitize_text_field($req->get_param('invoice_date') ?? '');
    $ship_fee = floatval($req->get_param('shipping_fee') ?? 0);
    $disc_val = floatval($req->get_param('global_discount_val') ?? 0);
    $disc_pct = floatval($req->get_param('global_discount_pct') ?? 0);

    $clean_items = [];
    $subtotal = 0;
    foreach ($items as $item) {
        $qty       = max(1, intval($item['qty'] ?? 1));
        $unit_price = max(0, floatval($item['unit_price'] ?? 0));
        $disc_unit  = floatval($item['discount_val'] ?? 0);
        $disc_unit_pct = floatval($item['discount_pct'] ?? 0);
        $effective_price = $disc_unit_pct > 0
            ? $unit_price * (1 - $disc_unit_pct / 100)
            : max(0, $unit_price - $disc_unit);
        $line_total = round($effective_price * $qty, 2);
        $subtotal  += $line_total;
        $clean_items[] = [
            'type'         => sanitize_text_field($item['type'] ?? 'product'),
            'sku'          => sanitize_text_field($item['sku'] ?? ''),
            'description'  => sanitize_text_field($item['description'] ?? ''),
            'qty'          => $qty,
            'unit_price'   => $unit_price,
            'discount_val' => $disc_unit,
            'discount_pct' => $disc_unit_pct,
            'line_total'   => $line_total,
            'img_url'      => esc_url_raw($item['img_url'] ?? ''),
            'children'     => array_map('sanitize_text_field', (array)($item['children'] ?? [])),
        ];
    }
    $global_disc = $disc_pct > 0 ? round($subtotal * ($disc_pct / 100), 2) : min($disc_val, $subtotal);
    $total = round($subtotal - $global_disc + $ship_fee, 2);

    update_post_meta($id, '_inv_items', wp_json_encode($clean_items, JSON_UNESCAPED_UNICODE));
    if ($ref) update_post_meta($id, '_inv_reference', $ref);
    if ($inv_date) update_post_meta($id, '_inv_date', $inv_date);
    update_post_meta($id, '_inv_global_disc_pct', $disc_pct);
    update_post_meta($id, '_inv_global_disc_val', $disc_val);
    update_post_meta($id, '_inv_ship_fee', $ship_fee);
    $old_total = floatval(get_field('total_amount', $id));
    update_field('total_amount', $total, $id);
    // FIX H3: Use atomic debt operations for edit (prevents race condition)
    if (get_field('is_billed', $id)) {
        $delta = $total - $old_total;
        if (abs($delta) > 0.01 && $dist_id) {
            if ($delta > 0 && function_exists('b2b_debt_add')) {
                $result = b2b_debt_add($dist_id, $delta, 'invoice_edit_increase:' . $id, $id);
                if ($result === false) {
                    // Revert total change if credit exceeded
                    update_field('total_amount', $old_total, $id);
                    return new WP_Error('credit_exceeded', 'เกินวงเครดิต: ไม่สามารถเพิ่มยอด ฿' . number_format($delta, 0), ['status' => 403]);
                }
            } elseif ($delta < 0 && function_exists('b2b_debt_subtract')) {
                b2b_debt_subtract($dist_id, abs($delta), 'invoice_edit_decrease:' . $id, $id);
            } elseif (function_exists('b2b_recalculate_debt')) {
                b2b_recalculate_debt($dist_id);
            } else {
                $debt = floatval(get_field('current_debt', $dist_id));
                update_field('current_debt', round($debt + $delta, 2), $dist_id);
            }
            b2b_add_audit_log($id, 'debt_adjusted', 'ปรับหนี้ ' . ($delta > 0 ? '+' : '') . number_format($delta, 2) . ' (แก้ไขบิล)');
        }
    }
    update_field('admin_note', $note, $id);
    if ($due_date) update_field('due_date', $due_date, $id);
    update_field('order_items', dinoco_inv_format_items_text($clean_items), $id);

    // Save distributor info if provided
    if ($dist_id && get_post_type($dist_id) === 'distributor') {
        $old_dist = get_post_meta($id, '_dist_post_id', true);
        if (get_field('is_billed', $id) && $dist_id != intval($old_dist)) {
            return new WP_Error('locked', 'ไม่สามารถเปลี่ยนตัวแทนบนบิลที่ออกแล้ว', ['status' => 400]);
        }
        $dist_post = get_post($dist_id);
        $dist_name = get_field('shop_name', $dist_id) ?: $dist_post->post_title;
        update_post_meta($id, '_dist_post_id', $dist_id);
        $dist_group_id = get_field('line_group_id', $dist_id);
        if ($dist_group_id) update_field('source_group_id', $dist_group_id, $id);
        update_field('dist_name', $dist_name, $id);
        update_field('dist_phone', get_field('dist_phone', $dist_id), $id);
        update_field('dist_address', get_field('dist_address', $dist_id), $id);
        update_field('dist_district', get_field('dist_district', $dist_id), $id);
        update_field('dist_city', get_field('dist_city', $dist_id), $id);
        update_field('dist_province', get_field('dist_province', $dist_id), $id);
        update_field('dist_postcode', get_field('dist_postcode', $dist_id), $id);
    }

    b2b_add_audit_log($id, 'updated', 'อัพเดท Draft ฿' . number_format($total, 0));

    return rest_ensure_response(['success' => true, 'id' => $id, 'total' => $total]);
}

// --- ISSUE ---
function _dinoco_inv_do_issue($post_id, $dist_id, $total, $dist_name) {
    // Guard: already issued
    if (get_field('is_billed', $post_id)) {
        return new WP_Error('already_issued', 'บิลนี้ออกแล้ว ไม่สามารถออกซ้ำได้', ['status' => 400]);
    }

    // Guard: race condition dedup
    $lock_key = 'inv_issue_' . $post_id;
    if (get_transient($lock_key)) {
        return new WP_Error('duplicate', 'กำลังดำเนินการ กรุณารอสักครู่', ['status' => 429]);
    }
    set_transient($lock_key, 1, 10);

    // Guard: credit_hold
    if ($dist_id && get_field('credit_hold', $dist_id)) {
        return new WP_Error('credit_hold', 'ระงับเครดิต: ไม่สามารถออกบิลได้', ['status' => 403]);
    }
    // Guard: credit limit
    if ($dist_id) {
        $limit = floatval(get_field('credit_limit', $dist_id));
        $debt  = floatval(get_field('current_debt', $dist_id));
        if ($limit > 0 && ($debt + $total) > $limit) {
            $avail = max(0, $limit - $debt);
            return new WP_Error('credit_exceeded',
                'เกินวงเครดิต: เหลือ ฿' . number_format($avail, 0) . ' แต่ต้องการ ฿' . number_format($total, 0),
                ['status' => 403]);
        }
    }

    // Ensure due_date is set — calculate from credit_term_days if empty
    $due = get_field('due_date', $post_id);
    if (empty($due)) {
        $term = intval(get_field('credit_term_days', $dist_id) ?: 30);
        $inv_date = get_post_meta($post_id, '_inv_date', true) ?: b2b_date('Y-m-d');
        $due = b2b_date('Y-m-d', strtotime($inv_date . ' +' . $term . ' days'));
        update_field('due_date', $due, $post_id);
    }

    b2b_set_order_status($post_id, 'awaiting_payment');
    update_field('is_billed', true, $post_id);
    // FIX C3: Add debt atomically (prevents race condition with concurrent operations)
    if (function_exists('b2b_debt_add')) {
        $result = b2b_debt_add($dist_id, $total, 'manual_invoice_issue:' . $post_id, $post_id);
        if ($result === false) {
            // Credit limit exceeded inside atomic check — rollback
            update_field('is_billed', false, $post_id);
            b2b_set_order_status($post_id, 'draft');
            delete_transient('inv_issue_' . $post_id);
            $limit = floatval(get_field('credit_limit', $dist_id));
            $debt = floatval(get_field('current_debt', $dist_id));
            $avail = max(0, $limit - $debt);
            return new WP_Error('credit_exceeded',
                'เกินวงเครดิต (atomic check): เหลือ ฿' . number_format($avail, 0) . ' แต่ต้องการ ฿' . number_format($total, 0),
                ['status' => 403]);
        }
    } else {
        $debt = floatval(get_field('current_debt', $dist_id));
        update_field('current_debt', round($debt + $total, 2), $dist_id);
    }
    b2b_add_audit_log($post_id, 'invoice_issued', 'ออกใบแจ้งหนี้/วางบิล ฿' . number_format($total, 0) . ' เพิ่มหนี้ตัวแทน ' . $dist_name);

    // Send LINE Flex Card + Invoice Image
    $line_group = get_field('line_group_id', $dist_id);
    if ($line_group) {
        $settings = dinoco_inv_get_settings();
        $inv_data = [
            'inv_number'      => get_post_meta($post_id, '_inv_number', true),
            'dist_name'       => $dist_name,
            'total_amount'    => $total,
            'due_date'        => get_field('due_date', $post_id),
            'issue_date'      => get_post_meta($post_id, '_inv_date', true) ?: get_the_date('Y-m-d', $post_id),
            'items_json'      => get_post_meta($post_id, '_inv_items', true),
            'credit_term_days'=> intval(get_field('credit_term_days', $dist_id)),
            'created_by'      => intval(get_post_meta($post_id, '_inv_created_by', true)),
        ];
        $flex = dinoco_inv_build_flex_card($inv_data, $settings);
        b2b_line_push_raw($line_group, $flex);
        // Send invoice as image (uses Snippet 10 GD generator if available)
        if (function_exists('b2b_send_invoice_image')) {
            b2b_send_invoice_image($line_group, $post_id);
        }
    }
    return true;
}

function dinoco_inv_rest_issue(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if (get_field('order_status', $id) !== 'draft') return new WP_Error('invalid', 'ออกบิลได้เฉพาะสถานะ Draft', ['status' => 400]);
    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $total   = floatval(get_field('total_amount', $id));
    $dist_name = get_field('dist_name', $id);
    $result = _dinoco_inv_do_issue($id, $dist_id, $total, $dist_name);
    if (is_wp_error($result)) return $result;
    return rest_ensure_response(['success' => true, 'id' => $id, 'status' => 'awaiting_payment']);
}

// --- RECORD PAYMENT ---
function dinoco_inv_rest_record_payment(WP_REST_Request $req) {
    $id     = intval($req->get_param('id'));
    $amount = floatval($req->get_param('amount'));
    $note   = sanitize_text_field($req->get_param('note') ?? '');
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if ($amount <= 0) return new WP_Error('invalid', 'ยอดชำระต้องมากกว่า 0', ['status' => 400]);
    $total_check   = floatval(get_field('total_amount', $id));
    $paid_check    = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $remaining     = round($total_check - $paid_check, 2);
    if ($amount > $remaining + 0.01) { // 0.01 rounding tolerance
        return new WP_Error('overpayment', 'ยอดชำระเกิน: เหลือที่ต้องชำระ ฿' . number_format($remaining, 2), ['status' => 400]);
    }
    $status = get_field('order_status', $id);
    if ($status !== 'awaiting_payment') return new WP_Error('invalid', 'บันทึกการชำระได้เฉพาะสถานะรอชำระเงินเท่านั้น', ['status' => 400]);

    $dist_id    = intval(get_post_meta($id, '_dist_post_id', true));
    $total      = floatval(get_field('total_amount', $id));
    $paid_so_far = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $new_paid   = round($paid_so_far + $amount, 2);
    $payments   = json_decode(get_post_meta($id, '_inv_partial_payments', true) ?: '[]', true);
    $payments[] = ['amount' => $amount, 'date' => b2b_date('Y-m-d H:i:s'), 'note' => $note];

    update_post_meta($id, '_inv_paid_amount', $new_paid);
    update_post_meta($id, '_inv_partial_payments', wp_json_encode($payments, JSON_UNESCAPED_UNICODE));

    if ($new_paid >= $total) {
        // Fully paid
        b2b_set_order_status($id, 'paid');
        update_field('is_billed', false, $id);
        if (function_exists('b2b_recalculate_debt') && $dist_id) {
            b2b_recalculate_debt($dist_id);
        } elseif ($dist_id) {
            $debt = floatval(get_field('current_debt', $dist_id));
            update_field('current_debt', round(max(0, $debt - $total), 2), $dist_id);
        }
        b2b_add_audit_log($id, 'invoice_paid', 'ชำระครบ ฿' . number_format($new_paid, 0));
        return rest_ensure_response(['success' => true, 'fully_paid' => true, 'status' => 'paid']);
    } else {
        // FIX H4: Recalculate debt after partial payment so credit limit + Flex show correct values
        if (function_exists('b2b_recalculate_debt') && $dist_id) {
            b2b_recalculate_debt($dist_id);
        }
        b2b_add_audit_log($id, 'partial_payment', 'รับชำระบางส่วน ฿' . number_format($amount, 0) . ' (รวม ฿' . number_format($new_paid, 0) . '/' . number_format($total, 0) . ')');
        return rest_ensure_response(['success' => true, 'fully_paid' => false, 'paid_amount' => $new_paid]);
    }
}

// --- V.33.3 AUDIT C2: RECORD REFUND (reverse payment) ---
// MVP: admin บันทึกการคืนเงิน — reverse debt + mark invoice refunded + audit trail
// ไม่มี slip upload / LINE notify (ใส่ทีหลังได้)
function dinoco_inv_rest_record_refund(WP_REST_Request $req) {
    $id      = intval($req->get_param('id'));
    $amount  = floatval($req->get_param('amount'));
    $reason  = sanitize_text_field($req->get_param('reason') ?? '');
    $method  = sanitize_text_field($req->get_param('method') ?? 'manual'); // manual|bank_transfer|cash
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if ($amount <= 0) return new WP_Error('invalid', 'จำนวนเงินคืนต้องมากกว่า 0', ['status' => 400]);
    if (empty($reason)) return new WP_Error('invalid', 'กรุณาระบุเหตุผลการคืนเงิน', ['status' => 400]);

    $paid_so_far    = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $refunded_prev  = floatval(get_post_meta($id, '_inv_refunded_amount', true));
    $refundable     = round($paid_so_far - $refunded_prev, 2);
    if ($amount > $refundable + 0.01) {
        return new WP_Error('overrefund', 'คืนเงินเกิน: คืนได้สูงสุด ฿' . number_format($refundable, 2), ['status' => 400]);
    }

    $status = get_field('order_status', $id);
    // อนุญาตคืนเงินได้สำหรับ: paid, awaiting_payment (partial paid), cancelled (ยกเลิกแล้วแต่ลืมคืนเงิน)
    if (!in_array($status, ['paid', 'awaiting_payment', 'cancelled'], true)) {
        return new WP_Error('invalid_status', 'ไม่สามารถบันทึกการคืนเงินในสถานะนี้', ['status' => 400]);
    }

    // Record refund entry
    $new_refunded = round($refunded_prev + $amount, 2);
    $refund_log   = json_decode(get_post_meta($id, '_inv_refunds', true) ?: '[]', true);
    $refund_log[] = [
        'amount'   => $amount,
        'reason'   => $reason,
        'method'   => $method,
        'date'     => b2b_date('Y-m-d H:i:s'),
        'admin_id' => get_current_user_id(),
        'admin'    => wp_get_current_user()->user_login,
    ];
    update_post_meta($id, '_inv_refunded_amount', $new_refunded);
    update_post_meta($id, '_inv_refunds', wp_json_encode($refund_log, JSON_UNESCAPED_UNICODE));

    // Cascade: recalculate debt if dist linked
    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $total   = floatval(get_field('total_amount', $id));

    // ถ้า invoice status = paid และ net paid ตอนนี้ < total → เปลี่ยนกลับเป็น awaiting_payment + re-bill
    $net_paid = round($paid_so_far - $new_refunded, 2);
    if ($status === 'paid' && $net_paid < $total - 0.01) {
        b2b_set_order_status($id, 'awaiting_payment');
        update_field('is_billed', true, $id);
    }

    if (function_exists('b2b_recalculate_debt') && $dist_id) {
        b2b_recalculate_debt($dist_id);
    }

    b2b_add_audit_log(
        $id,
        'refund_recorded',
        sprintf('คืนเงิน ฿%s (%s) — เหตุผล: %s', number_format($amount, 0), $method, $reason)
    );

    return rest_ensure_response([
        'success'       => true,
        'refunded_total'=> $new_refunded,
        'net_paid'      => $net_paid,
        'new_status'    => get_field('order_status', $id),
    ]);
}

// --- VERIFY SLIP ---
function dinoco_inv_rest_verify_slip(WP_REST_Request $req) {
    $id       = intval($req->get_param('id'));
    $slip_url = esc_url_raw($req->get_param('slip_url') ?? '');
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if (!$slip_url) return new WP_Error('invalid', 'กรุณาระบุ URL สลิป', ['status' => 400]);
    $inv_status = get_field('order_status', $id);
    if ($inv_status === 'paid') return new WP_Error('already_paid', 'ใบแจ้งหนี้นี้ชำระครบแล้ว', ['status' => 400]);
    if ($inv_status !== 'awaiting_payment') return new WP_Error('invalid_status', 'ตรวจสลิปได้เฉพาะสถานะรอชำระเงินเท่านั้น', ['status' => 400]);

    $api_url = defined('B2B_SLIP2GO_API_URL') ? B2B_SLIP2GO_API_URL : '';
    $secret  = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';
    if (!$api_url || !$secret) return new WP_Error('config', 'ยังไม่ได้ตั้งค่า Slip2Go API', ['status' => 500]);

    $resp = wp_remote_post($api_url, [
        'headers' => ['Content-Type' => 'application/json', 'Authorization' => 'Bearer ' . $secret],
        'body'    => wp_json_encode(['url' => $slip_url]),
        'timeout' => 15,
    ]);
    if (is_wp_error($resp)) return new WP_Error('api_error', 'ไม่สามารถติดต่อ Slip2Go ได้', ['status' => 502]);

    $body   = json_decode(wp_remote_retrieve_body($resp), true);
    $code   = wp_remote_retrieve_response_code($resp);
    $verified = ($code === 200 && !empty($body['success']));

    if ($verified) {
        $amount = floatval($body['amount'] ?? 0);
        $ref    = sanitize_text_field($body['ref'] ?? '');
        $date   = sanitize_text_field($body['date'] ?? b2b_date('Y-m-d'));
        update_post_meta($id, '_inv_slip_ref', $ref);
        update_post_meta($id, '_inv_slip_verified_at', b2b_date('Y-m-d H:i:s'));
        b2b_add_audit_log($id, 'slip_verified', 'ตรวจสลิปผ่าน ฿' . number_format($amount, 0) . ' ref=' . $ref);
        // Auto record payment
        $fake_req = new WP_REST_Request();
        $fake_req->set_param('id', $id);
        $fake_req->set_param('amount', $amount);
        $fake_req->set_param('note', 'Slip2Go ref=' . $ref . ' วันที่=' . $date);
        return dinoco_inv_rest_record_payment($fake_req);
    }

    $reason = $body['message'] ?? 'Slip2Go ปฏิเสธการตรวจสอบ';
    return rest_ensure_response(['success' => false, 'verified' => false, 'reason' => $reason]);
}

// --- COMBINED SLIP VERIFY (V.2.6) ---
// Accepts slip_url + dist_id → verifies slip → auto-matches to invoices
function dinoco_inv_rest_verify_slip_combined(WP_REST_Request $req) {
    $slip_url = esc_url_raw($req->get_param('slip_url') ?? '');
    $dist_id  = intval($req->get_param('dist_id'));
    $manual_ids = $req->get_param('invoice_ids'); // optional: admin pre-selects invoices
    if (!$slip_url) return new WP_Error('invalid', 'กรุณาระบุ URL สลิป', ['status' => 400]);

    // Call Slip2Go
    $api_url = defined('B2B_SLIP2GO_API_URL') ? B2B_SLIP2GO_API_URL : '';
    $secret  = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';
    if (!$api_url || !$secret) return new WP_Error('config', 'ยังไม่ได้ตั้งค่า Slip2Go API', ['status' => 500]);

    $resp = wp_remote_post($api_url, [
        'headers' => ['Content-Type' => 'application/json', 'Authorization' => 'Bearer ' . $secret],
        'body'    => wp_json_encode(['url' => $slip_url]),
        'timeout' => 15,
    ]);
    if (is_wp_error($resp)) return new WP_Error('api_error', 'ไม่สามารถติดต่อ Slip2Go ได้', ['status' => 502]);

    $body     = json_decode(wp_remote_retrieve_body($resp), true);
    $code     = wp_remote_retrieve_response_code($resp);
    $verified = ($code === 200 && !empty($body['success']));
    if (!$verified) {
        return rest_ensure_response(['success' => false, 'verified' => false,
            'reason' => $body['message'] ?? 'Slip2Go ปฏิเสธการตรวจสอบ']);
    }

    $slip_amount = floatval($body['amount'] ?? 0);
    $slip_ref    = sanitize_text_field($body['ref'] ?? '');
    $slip_date   = sanitize_text_field($body['date'] ?? b2b_date('Y-m-d'));
    if ($slip_amount <= 0) return new WP_Error('invalid', 'ยอดสลิปเป็น 0', ['status' => 400]);

    // Get all pending invoices for this distributor
    $pending_data = $dist_id ? _dinoco_inv_get_pending_invoices($dist_id) : null;
    $pending = $pending_data ? $pending_data['invoices'] : [];

    // If admin pre-selected invoices, filter to those
    if (!empty($manual_ids) && is_array($manual_ids)) {
        $manual_ids = array_map('intval', $manual_ids);
        $pending = array_filter($pending, function($inv) use ($manual_ids) {
            return in_array($inv['post_id'], $manual_ids);
        });
        $pending = array_values($pending);
    }

    if (empty($pending)) {
        return rest_ensure_response(['success' => true, 'verified' => true, 'slip_amount' => $slip_amount,
            'slip_ref' => $slip_ref, 'match_type' => 'no_pending', 'matched' => [], 'message' => 'ไม่มีบิลค้างชำระ']);
    }

    // ── AUTO-MATCH LOGIC ──
    $match_type = 'no_match';
    $matched    = [];
    $tolerance  = 0.02; // 2% tolerance (same as B2B)

    // Strategy 1: Exact match to single invoice (remaining amount)
    foreach ($pending as $inv) {
        if (abs($slip_amount - $inv['remaining']) <= $inv['remaining'] * $tolerance + 0.5) {
            $match_type = 'single';
            $matched = [$inv];
            break;
        }
    }

    // Strategy 2: Match to combined total of all pending
    if ($match_type === 'no_match') {
        $combined_total = array_sum(array_column($pending, 'remaining'));
        if (abs($slip_amount - $combined_total) <= $combined_total * $tolerance + 0.5) {
            $match_type = 'combined_all';
            $matched = $pending;
        }
    }

    // Strategy 3: Find subset of invoices that sums to slip amount (greedy: oldest first)
    if ($match_type === 'no_match') {
        $running = 0;
        $subset  = [];
        foreach ($pending as $inv) {
            $running += $inv['remaining'];
            $subset[] = $inv;
            if (abs($running - $slip_amount) <= $running * $tolerance + 0.5) {
                $match_type = 'combined_subset';
                $matched = $subset;
                break;
            }
            if ($running > $slip_amount) break;
        }
    }

    // ── Apply payment if matched ──
    $paid_invoices = [];
    if (!empty($matched)) {
        $note = 'Slip2Go ref=' . $slip_ref . ' วันที่=' . $slip_date . ' (combined ' . count($matched) . ' ใบ)';
        foreach ($matched as $inv) {
            $pay_amount = min($inv['remaining'], $slip_amount);
            $slip_amount -= $pay_amount;

            update_post_meta($inv['post_id'], '_inv_slip_ref', $slip_ref);
            update_post_meta($inv['post_id'], '_inv_slip_verified_at', b2b_date('Y-m-d H:i:s'));

            $fake_req = new WP_REST_Request();
            $fake_req->set_param('id', $inv['post_id']);
            $fake_req->set_param('amount', $pay_amount);
            $fake_req->set_param('note', $note);
            dinoco_inv_rest_record_payment($fake_req);

            $paid_invoices[] = [
                'inv_number' => $inv['inv_number'],
                'amount'     => $pay_amount,
                'post_id'    => $inv['post_id'],
            ];
        }
    }

    // Build response
    $result = [
        'success'     => true,
        'verified'    => true,
        'slip_amount' => floatval($body['amount'] ?? 0),
        'slip_ref'    => $slip_ref,
        'match_type'  => $match_type,
        'matched'     => $paid_invoices,
        'message'     => '',
    ];

    switch ($match_type) {
        case 'single':
            $result['message'] = 'สลิปตรงกับ ' . $paid_invoices[0]['inv_number'] . ' — บันทึกชำระแล้ว';
            break;
        case 'combined_all':
            $result['message'] = 'สลิปตรงกับยอดรวม ' . count($paid_invoices) . ' บิล — บันทึกชำระทั้งหมดแล้ว';
            break;
        case 'combined_subset':
            $result['message'] = 'สลิปตรงกับ ' . count($paid_invoices) . ' บิล (บางส่วน) — บันทึกชำระแล้ว';
            break;
        default:
            $result['message'] = 'ยอดสลิป ฿' . number_format(floatval($body['amount'] ?? 0), 0) .
                ' ไม่ตรงกับบิลใดๆ — กรุณาเลือกบิลที่ต้องการตัดยอดด้านล่าง';
            // Return pending invoices for admin to manually allocate
            $result['pending'] = array_map(function($inv) {
                return ['post_id' => $inv['post_id'], 'inv_number' => $inv['inv_number'],
                    'remaining' => $inv['remaining'], 'due_date' => $inv['due_date']];
            }, $pending);
            break;
    }

    b2b_add_audit_log(0, 'combined_slip_verify',
        'ตรวจสลิปรวม ฿' . number_format(floatval($body['amount'] ?? 0), 0) . ' ref=' . $slip_ref .
        ' match=' . $match_type . ' (' . count($paid_invoices) . ' ใบ) dist=' . ($pending_data['dist_name'] ?? ''));

    return rest_ensure_response($result);
}

// --- UPLOAD SLIP (V.2.7) — base64 image from dashboard ---
function dinoco_inv_rest_upload_slip(WP_REST_Request $req) {
    $id    = intval($req->get_param('id'));
    $image = $req->get_param('image'); // base64 data URI: data:image/...;base64,...
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if (empty($image)) return new WP_Error('invalid', 'กรุณาอัพโหลดรูปสลิป', ['status' => 400]);

    $inv_status = get_field('order_status', $id);
    if ($inv_status === 'paid') return new WP_Error('already_paid', 'ใบแจ้งหนี้นี้ชำระครบแล้ว', ['status' => 400]);
    if ($inv_status !== 'awaiting_payment') return new WP_Error('invalid_status', 'ตรวจสลิปได้เฉพาะสถานะรอชำระเงินเท่านั้น', ['status' => 400]);

    // Validate base64 data URI format
    if (!preg_match('/^data:image\/(jpeg|png|webp|jpg);base64,/', $image)) {
        return new WP_Error('invalid', 'รูปภาพไม่ถูกต้อง (รองรับ JPEG, PNG, WebP)', ['status' => 400]);
    }

    $api_url = defined('B2B_SLIP2GO_API_URL')
        ? B2B_SLIP2GO_API_URL
        : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';
    $secret  = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';
    if (!$secret) return new WP_Error('config', 'ยังไม่ได้ตั้งค่า Slip2Go API', ['status' => 500]);

    // Build request body (same format as B2B Snippet 2)
    $check_condition = ['checkDuplicate' => true];
    $bank_info = function_exists('b2b_get_bank_info') ? b2b_get_bank_info() : null;
    if ($bank_info && !empty($bank_info['account'])) {
        $account_number = preg_replace('/[^0-9]/', '', $bank_info['account']);
        $receiver = ['accountNumber' => $account_number];
        if (!empty($bank_info['bank_code'])) {
            $receiver['accountType'] = '01' . str_pad($bank_info['bank_code'], 3, '0', STR_PAD_LEFT);
        }
        $check_condition['checkReceiver'] = [$receiver];
    }

    $resp = wp_remote_post($api_url, [
        'headers' => [
            'Authorization' => 'Bearer ' . $secret,
            'Content-Type'  => 'application/json',
        ],
        'body' => wp_json_encode([
            'payload' => [
                'imageBase64'    => $image,
                'checkCondition' => $check_condition,
            ],
        ]),
        'timeout' => 45,
    ]);
    if (is_wp_error($resp)) return new WP_Error('api_error', 'ไม่สามารถติดต่อ Slip2Go ได้', ['status' => 502]);

    $http_code = wp_remote_retrieve_response_code($resp);
    $raw_body  = wp_remote_retrieve_body($resp);
    $slip      = json_decode($raw_body, true);

    if ($http_code !== 200 || !is_array($slip)) {
        return rest_ensure_response(['success' => false, 'verified' => false, 'reason' => 'Slip2Go ไม่ตอบกลับ (HTTP ' . $http_code . ')']);
    }

    $slip_code = isset($slip['code']) ? $slip['code'] : '';
    $data      = isset($slip['data']) && is_array($slip['data']) ? $slip['data'] : [];
    $amount    = floatval($data['amount'] ?? 0);
    $sender    = sanitize_text_field($data['sender']['account']['name'] ?? '');
    $receiver  = sanitize_text_field($data['receiver']['account']['name'] ?? '');
    $trans_ref = sanitize_text_field($data['transRef'] ?? '');
    $trans_date = sanitize_text_field($data['transDate'] ?? $data['date'] ?? '');

    // Duplicate slip
    if ($slip_code === '200501') {
        return rest_ensure_response([
            'success' => false, 'verified' => false,
            'reason'  => 'สลิปนี้เคยใช้แล้ว (TransRef: ' . $trans_ref . ')',
            'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
        ]);
    }

    // Wrong receiver
    if ($slip_code === '200401') {
        return rest_ensure_response([
            'success' => false, 'verified' => false,
            'reason'  => 'สลิปโอนไปบัญชีอื่น (ผู้รับ: ' . $receiver . ')',
            'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
        ]);
    }

    // Slip not found / fake
    if ($slip_code === '200404') {
        return rest_ensure_response([
            'success' => false, 'verified' => false,
            'reason'  => 'ไม่พบข้อมูลสลิปในระบบธนาคาร (อาจเป็นสลิปปลอม)',
        ]);
    }

    // Success codes
    if ($slip_code === '200000' || $slip_code === '200200') {
        if (empty($data) || $amount <= 0) {
            return rest_ensure_response(['success' => false, 'verified' => false, 'reason' => 'ระบบตรวจสลิปไม่พบยอดเงิน']);
        }

        // Check conditionResult for duplicate/receiver
        $cond = isset($slip['conditionResult']) ? $slip['conditionResult'] : null;
        if ($cond && isset($cond['isDuplicate']) && $cond['isDuplicate'] === true) {
            return rest_ensure_response([
                'success' => false, 'verified' => false,
                'reason'  => 'สลิปนี้เคยใช้แล้ว (TransRef: ' . $trans_ref . ')',
                'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
            ]);
        }
        if ($cond && isset($cond['isReceiverValid']) && !$cond['isReceiverValid']) {
            return rest_ensure_response([
                'success' => false, 'verified' => false,
                'reason'  => 'สลิปโอนไปบัญชีอื่น (ผู้รับ: ' . $receiver . ')',
                'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
            ]);
        }

        // Verified — save metadata
        update_post_meta($id, '_inv_slip_ref', $trans_ref);
        update_post_meta($id, '_inv_slip_verified_at', b2b_date('Y-m-d H:i:s'));
        b2b_add_audit_log($id, 'slip_uploaded', 'อัพโหลดสลิปผ่าน ฿' . number_format($amount, 0) . ' ref=' . $trans_ref . ' ผู้โอน=' . $sender);

        // Auto record payment
        $fake_req = new WP_REST_Request();
        $fake_req->set_param('id', $id);
        $fake_req->set_param('amount', $amount);
        $fake_req->set_param('note', 'อัพโหลดสลิป ref=' . $trans_ref . ' ผู้โอน=' . $sender . ' วันที่=' . $trans_date);
        $pay_result = dinoco_inv_rest_record_payment($fake_req);
        $pay_data = $pay_result->get_data();
        $fully_paid = !empty($pay_data['fully_paid']);

        // ส่ง LINE Flex แจ้งตัวแทน (Invoice system custom — ไม่เกี่ยวกับ B2B Snippet)
        $gid = get_field('source_group_id', $id);
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        $dist_name = get_field('dist_name', $id);
        // FIX: recalculate debt from order statuses to avoid stale ACF cache
        $new_debt = function_exists('b2b_recalculate_debt') ? b2b_recalculate_debt($dist_id) : floatval(get_field('current_debt', $dist_id));
        $old_debt = $new_debt + $amount; // reconstruct pre-payment debt
        $credit_limit = floatval(get_field('credit_limit', $dist_id));
        // นับบิลค้างชำระที่เหลือ
        $pending_count = 0;
        $pending_q = get_posts(['post_type'=>'b2b_order','posts_per_page'=>-1,'meta_query'=>[
            ['key'=>'_order_source','value'=>'manual_invoice'],
            ['key'=>'_dist_post_id','value'=>$dist_id],
        ]]);
        foreach ($pending_q as $pq) { if (get_field('order_status', $pq->ID) === 'awaiting_payment') $pending_count++; }

        if ($gid && function_exists('b2b_line_push_raw')) {
            $inv_no = get_post_meta($id, '_inv_number', true) ?: '#'.$id;
            $credit_remain = max(0, $credit_limit - $new_debt);
            $body = [
                ['type'=>'text','text'=>'✅ รับชำระเงินแล้ว','weight'=>'bold','size'=>'lg','color'=>'#16a34a'],
                ['type'=>'text','text'=>$dist_name,'size'=>'xs','color'=>'#64748b','margin'=>'xs'],
                ['type'=>'separator','margin'=>'md'],
                ['type'=>'box','layout'=>'vertical','margin'=>'md','spacing'=>'sm','contents'=>[
                    ['type'=>'box','layout'=>'horizontal','contents'=>[
                        ['type'=>'text','text'=>'เลขที่บิล','size'=>'xs','color'=>'#64748b','flex'=>3],
                        ['type'=>'text','text'=>$inv_no,'size'=>'sm','weight'=>'bold','flex'=>5,'align'=>'end']]],
                    ['type'=>'box','layout'=>'horizontal','contents'=>[
                        ['type'=>'text','text'=>'ยอดโอน','size'=>'xs','color'=>'#64748b','flex'=>3],
                        ['type'=>'text','text'=>'฿'.number_format($amount,2),'size'=>'lg','weight'=>'bold','color'=>'#16a34a','flex'=>5,'align'=>'end']]],
                    ['type'=>'box','layout'=>'horizontal','contents'=>[
                        ['type'=>'text','text'=>'ผู้โอน','size'=>'xs','color'=>'#64748b','flex'=>3],
                        ['type'=>'text','text'=>$sender ?: '-','size'=>'sm','flex'=>5,'align'=>'end','wrap'=>true]]],
                ]],
            ];
            if ($trans_ref) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>[
                ['type'=>'text','text'=>'Ref','size'=>'xxs','color'=>'#94a3b8','flex'=>3],
                ['type'=>'text','text'=>$trans_ref,'size'=>'xxs','color'=>'#94a3b8','flex'=>5,'align'=>'end']]];
            $body[] = ['type'=>'separator','margin'=>'lg'];
            $body[] = ['type'=>'text','text'=>'💰 สรุปบัญชี','size'=>'xs','weight'=>'bold','color'=>'#1e293b','margin'=>'lg'];
            $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>[
                ['type'=>'text','text'=>'หนี้ก่อนโอน','size'=>'xs','color'=>'#64748b','flex'=>5],
                ['type'=>'text','text'=>'฿'.number_format($old_debt,2),'size'=>'xs','color'=>'#64748b','flex'=>5,'align'=>'end','decoration'=>'line-through']]];
            $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>[
                ['type'=>'text','text'=>'หนี้คงเหลือ','size'=>'sm','weight'=>'bold','flex'=>5],
                ['type'=>'text','text'=>'฿'.number_format($new_debt,2),'size'=>'md','weight'=>'bold','color'=>($new_debt>0?'#dc2626':'#16a34a'),'flex'=>5,'align'=>'end']]];
            if ($credit_limit > 0) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>[
                ['type'=>'text','text'=>'วงเงินเหลือ','size'=>'xs','color'=>'#64748b','flex'=>5],
                ['type'=>'text','text'=>'฿'.number_format($credit_remain,0),'size'=>'xs','color'=>'#2563eb','flex'=>5,'align'=>'end']]];
            if ($pending_count > 0) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'sm','paddingAll'=>'6px','cornerRadius'=>'6px','backgroundColor'=>'#fef3c7','contents'=>[
                ['type'=>'text','text'=>'⏳ บิลค้างชำระอีก '.$pending_count.' รายการ','size'=>'xxs','color'=>'#92400e','wrap'=>true]]];
            if ($new_debt <= 0) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'sm','paddingAll'=>'8px','cornerRadius'=>'8px','backgroundColor'=>'#dcfce7','contents'=>[
                ['type'=>'text','text'=>'🎉 ชำระครบแล้ว! ไม่มียอดค้าง','size'=>'xs','weight'=>'bold','color'=>'#16a34a','align'=>'center']]];

            $flex = ['type'=>'flex','altText'=>mb_substr('✅ รับชำระ '.$inv_no.' ฿'.number_format($amount,0),0,400),
                'contents'=>['type'=>'bubble','size'=>'kilo',
                    'body'=>['type'=>'box','layout'=>'vertical','contents'=>$body]]];
            b2b_line_push_raw($gid, [$flex]);
        }

        return rest_ensure_response([
            'success'    => true,
            'verified'   => true,
            'amount'     => $amount,
            'sender'     => $sender,
            'receiver'   => $receiver,
            'ref'        => $trans_ref,
            'date'       => $trans_date,
            'fully_paid' => $fully_paid,
        ]);
    }

    // Other error codes
    return rest_ensure_response([
        'success' => false, 'verified' => false,
        'reason'  => 'Slip2Go รหัส ' . $slip_code . ': ' . ($slip['message'] ?? 'ไม่สามารถตรวจสอบได้'),
        'amount'  => $amount, 'sender' => $sender, 'ref' => $trans_ref,
    ]);
}

// --- CANCEL ---
function dinoco_inv_rest_cancel(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    $force = (bool) $req->get_param('force'); // V.33.3 — allow override after refund recorded
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $status = get_field('order_status', $id);
    if ($status === 'cancelled') return new WP_Error('invalid', 'ยกเลิกแล้ว', ['status' => 400]);
    if ($status === 'paid') return new WP_Error('invalid', 'ชำระแล้ว ไม่สามารถยกเลิกได้', ['status' => 400]);

    // V.33.3 — Audit I7: block cancel ถ้ามี payment ค้างที่ยังไม่ถูก refund
    $paid_so_far = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $refunded    = floatval(get_post_meta($id, '_inv_refunded_amount', true));
    $net_paid    = round($paid_so_far - $refunded, 2);
    if ($net_paid > 0.01 && ! $force) {
        return new WP_Error(
            'has_payments',
            sprintf('ใบแจ้งหนี้นี้มีการชำระแล้ว ฿%s — ต้องบันทึกคืนเงิน (refund) ก่อนจึงจะยกเลิกได้', number_format($net_paid, 2)),
            ['status' => 400, 'net_paid' => $net_paid]
        );
    }
    // Collect info before changing status (used for LINE notification below)
    $inv_no    = get_post_meta($id, '_inv_number', true);
    $dist_name = get_field('dist_name', $id);
