        var resultDiv = document.getElementById('inv-cs-result');
        var html = '';

        if (data.match_type === 'no_match') {
            // ไม่ match — แสดงบิลให้ admin เลือก allocate
            html += '<div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:16px;margin-bottom:12px;">';
            html += '<div style="font-weight:700;color:#dc2626;margin-bottom:8px;">⚠️ ยอดสลิป ฿' + invFmt(data.slip_amount) + ' ไม่ตรงกับบิลใดๆ</div>';
            html += '<p style="font-size:0.82rem;color:#64748b;margin:0;">เลือกบิลที่ต้องการตัดยอด แล้วกด "บันทึกรับเงิน" ด้านล่าง</p>';
            html += '</div>';
