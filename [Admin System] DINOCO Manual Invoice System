        // Heading
        document.getElementById('inv-dd-heading').textContent = 'аёЈаёІаёўаёҘаё°а№Җаёӯаёөаёўаё”аёңаё№а№үаё•аёҙаё”аё•а№Ҳаёӯ (аёЈаё«аёұаёӘ: D' + String(p.id).padStart(4,'0') + ')';

