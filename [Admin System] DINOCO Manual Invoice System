        $subtotal  += $line_total;
        $clean_items[] = [
            'type'         => sanitize_text_field($item['type'] ?? 'product'),
            'sku'          => sanitize_text_field($item['sku'] ?? ''),
            'description'  => sanitize_text_field($item['description'] ?? ''),
            'qty'          => $qty,
            'unit_price'   => $unit_price,
            'discount_val' => $disc_unit,
            'discount_pct' => $disc_unit_pct,
            'line_total'   => $line_total,
            'img_url'      => esc_url_raw($item['img_url'] ?? ''),
            'children'     => array_map('sanitize_text_field', (array)($item['children'] ?? [])),
        ];
    }
    $global_disc = $disc_pct > 0 ? round($subtotal * ($disc_pct / 100), 2) : min($disc_val, $subtotal);
    $total = round($subtotal - $global_disc + $ship_fee, 2);

    update_post_meta($id, '_inv_items', wp_json_encode($clean_items, JSON_UNESCAPED_UNICODE));
    if ($ref) update_post_meta($id, '_inv_reference', $ref);
    if ($inv_date) update_post_meta($id, '_inv_date', $inv_date);
    update_post_meta($id, '_inv_global_disc_pct', $disc_pct);
    update_post_meta($id, '_inv_global_disc_val', $disc_val);
    update_post_meta($id, '_inv_ship_fee', $ship_fee);
    $old_total = floatval(get_field('total_amount', $id));
    update_field('total_amount', $total, $id);
    // FIX H3: Use atomic debt operations for edit (prevents race condition)
    if (get_field('is_billed', $id)) {
        $delta = $total - $old_total;
        if (abs($delta) > 0.01 && $dist_id) {
            if ($delta > 0 && function_exists('b2b_debt_add')) {
                $result = b2b_debt_add($dist_id, $delta, 'invoice_edit_increase:' . $id, $id);
                if ($result === false) {
                    // Revert total change if credit exceeded
                    update_field('total_amount', $old_total, $id);
                    return new WP_Error('credit_exceeded', 'а№ҖаёҒаёҙаёҷаё§аёҮа№Җаё„аёЈаё”аёҙаё•: а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–а№Җаёһаёҙа№ҲаёЎаёўаёӯаё” аёҝ' . number_format($delta, 0), ['status' => 403]);
                }
            } elseif ($delta < 0 && function_exists('b2b_debt_subtract')) {
                b2b_debt_subtract($dist_id, abs($delta), 'invoice_edit_decrease:' . $id, $id);
            } elseif (function_exists('b2b_recalculate_debt')) {
                b2b_recalculate_debt($dist_id);
            } else {
                // V.34.0 HIGH-H14 FIX: removed direct update_field('current_debt') fallback.
                // No atomic helper available вҶ’ revert total + fail loud (а№„аёЎа№Ҳ corrupt debt data).
                update_field('total_amount', $old_total, $id);
                b2b_log('[CRITICAL] Manual Invoice V.34.0 invoice_edit: b2b_debt_add/subtract/recalculate ALL missing for dist=' . $dist_id . ' delta=' . $delta);
                return new WP_Error('debt_helper_missing',
                    'аёЈаё°аёҡаёҡаёҡаёұаёҚаёҠаёөаё«аёҷаёөа№үа№„аёЎа№ҲаёһаёЈа№үаёӯаёЎа№ғаёҠа№үаёҮаёІаёҷ вҖ” аёҒаёЈаёёаё“аёІаё•аёЈаё§аёҲаёӘаёӯаёҡ Snippet 1/13 (revert total)',
                    ['status' => 503]);
            }
            b2b_add_audit_log($id, 'debt_adjusted', 'аёӣаёЈаёұаёҡаё«аёҷаёөа№ү ' . ($delta > 0 ? '+' : '') . number_format($delta, 2) . ' (а№ҒаёҒа№үа№„аёӮаёҡаёҙаёҘ)');
        }
    }
    update_field('admin_note', $note, $id);
    if ($due_date) update_field('due_date', $due_date, $id);
    update_field('order_items', dinoco_inv_format_items_text($clean_items), $id);

    // Save distributor info if provided
    if ($dist_id && get_post_type($dist_id) === 'distributor') {
        $old_dist = get_post_meta($id, '_dist_post_id', true);
        if (get_field('is_billed', $id) && $dist_id != intval($old_dist)) {
            return new WP_Error('locked', 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–а№ҖаёӣаёҘаёөа№Ҳаёўаёҷаё•аёұаё§а№Ғаё—аёҷаёҡаёҷаёҡаёҙаёҘаё—аёөа№ҲаёӯаёӯаёҒа№ҒаёҘа№үаё§', ['status' => 400]);
        }
        $dist_post = get_post($dist_id);
        $dist_name = get_field('shop_name', $dist_id) ?: $dist_post->post_title;
        update_post_meta($id, '_dist_post_id', $dist_id);
        $dist_group_id = get_field('line_group_id', $dist_id);
        if ($dist_group_id) update_field('source_group_id', $dist_group_id, $id);
        update_field('dist_name', $dist_name, $id);
        update_field('dist_phone', get_field('dist_phone', $dist_id), $id);
        update_field('dist_address', get_field('dist_address', $dist_id), $id);
        update_field('dist_district', get_field('dist_district', $dist_id), $id);
        update_field('dist_city', get_field('dist_city', $dist_id), $id);
        update_field('dist_province', get_field('dist_province', $dist_id), $id);
        update_field('dist_postcode', get_field('dist_postcode', $dist_id), $id);
    }

    b2b_add_audit_log($id, 'updated', 'аёӯаёұаёһа№Җаё”аё— Draft аёҝ' . number_format($total, 0));

    return rest_ensure_response(['success' => true, 'id' => $id, 'total' => $total]);
}

// --- ISSUE ---
// V.34.2 Phase 4a Pillar 2: outer orchestration routes through dinoco_transaction()
// when [Admin System] DINOCO Transaction Wrapper snippet is loaded. Validate phase
// holds is_billed/dedup/credit guards. Mutate phase holds the V.34.0 HIGH-H4 ordering
// (debt_add atomic gate FIRST вҶ’ is_billed flip вҶ’ status transition вҶ’ audit log).
// Notify phase holds LINE Flex + invoice image push (runs OUTSIDE lock per Pillar 2 spec).
// Backward compat: function_exists guard falls through to _legacy V.34.1 inline path.
function _dinoco_inv_do_issue($post_id, $dist_id, $total, $dist_name) {
    if ( function_exists('dinoco_transaction') && $dist_id ) {
        $txn_ctx = array(
            'audit_event_type' => 'inv_issue',
            'actor_type'       => 'admin',
            'target_type'      => 'order',
            'target_id'        => (string) $post_id,
            'amount'           => floatval($total),
            'lock_key'         => 'b2b_fin_' . intval($dist_id),
            'lock_timeout'     => 5,
            'audit_context'    => array(
                'dist_id'   => intval($dist_id),
                'dist_name' => (string) $dist_name,
                'inv_number'=> get_post_meta($post_id, '_inv_number', true),
            ),
        );
        $txn_phases = array(
            'validate' => function( $ctx ) use ( $post_id, $dist_id, $total ) {
                return _dinoco_inv_do_issue_validate( $post_id, $dist_id, $total );
            },
            'mutate' => function( $ctx ) use ( $post_id, $dist_id, $total, $dist_name ) {
                return _dinoco_inv_do_issue_mutate( $post_id, $dist_id, $total, $dist_name );
            },
            'notify' => function( $ctx ) use ( $post_id, $dist_id, $total, $dist_name ) {
                _dinoco_inv_do_issue_notify( $post_id, $dist_id, $total, $dist_name );
            },
        );
        $res = dinoco_transaction( 'inv_issue', $txn_phases, $txn_ctx );
        if ( is_wp_error($res) ) {
            // Wrapper-level failure (lock_busy etc) вҖ” release transient before returning so
            // the caller can retry. Validate-phase failures already release transient inline.
            delete_transient('inv_issue_' . $post_id);
            return $res;
        }
        return $res;  // true on success
    }
    // Legacy path вҖ” Transaction Wrapper not loaded (preserves V.34.1 byte-for-byte)
    return _dinoco_inv_do_issue_legacy($post_id, $dist_id, $total, $dist_name);
}

/**
 * V.34.2: validate phase вҖ” pre-checks before lock acquire. Holds existing transient
 * dedup + credit_hold + credit_limit guards. Returns WP_Error to abort or array() to
 * proceed (wrapper merges array into context вҖ” currently empty).
 */
function _dinoco_inv_do_issue_validate($post_id, $dist_id, $total) {
    // Guard: already issued
    if (get_field('is_billed', $post_id)) {
        return new WP_Error('already_issued', 'аёҡаёҙаёҘаёҷаёөа№үаёӯаёӯаёҒа№ҒаёҘа№үаё§ а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёӯаёӯаёҒаёӢа№үаёіа№„аё”а№ү', ['status' => 400]);
    }

    // Guard: race condition dedup (transient lock вҖ” different layer than GET_LOCK,
    // catches same-post double-click within 10s window)
    $lock_key = 'inv_issue_' . $post_id;
    if (get_transient($lock_key)) {
        return new WP_Error('duplicate', 'аёҒаёіаёҘаёұаёҮаё”аёіа№ҖаёҷаёҙаёҷаёҒаёІаёЈ аёҒаёЈаёёаё“аёІаёЈаёӯаёӘаёұаёҒаё„аёЈаё№а№Ҳ', ['status' => 429]);
    }
    set_transient($lock_key, 1, 10);

    // Guard: credit_hold
    if ($dist_id && get_field('credit_hold', $dist_id)) {
        delete_transient($lock_key);
        return new WP_Error('credit_hold', 'аёЈаё°аёҮаёұаёҡа№Җаё„аёЈаё”аёҙаё•: а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёӯаёӯаёҒаёҡаёҙаёҘа№„аё”а№ү', ['status' => 403]);
    }
    // Guard: credit limit (pre-check вҖ” atomic check happens inside b2b_debt_add)
    if ($dist_id) {
        $limit = floatval(get_field('credit_limit', $dist_id));
        $debt  = floatval(get_field('current_debt', $dist_id));
        if ($limit > 0 && ($debt + $total) > $limit) {
            delete_transient($lock_key);
            $avail = max(0, $limit - $debt);
            return new WP_Error('credit_exceeded',
                'а№ҖаёҒаёҙаёҷаё§аёҮа№Җаё„аёЈаё”аёҙаё•: а№Җаё«аёҘаё·аёӯ аёҝ' . number_format($avail, 0) . ' а№Ғаё•а№Ҳаё•а№үаёӯаёҮаёҒаёІаёЈ аёҝ' . number_format($total, 0),
                ['status' => 403]);
        }
    }
    return array();  // proceed вҖ” wrapper continues to LOCK + MUTATE
}

/**
 * V.34.2: mutate phase вҖ” V.34.0 HIGH-H4 ordering preserved exactly. b2b_debt_add()
 * atomic credit gate FIRST вҶ’ is_billed flip вҶ’ status transition вҶ’ audit log.
 * Returns true on success or WP_Error to abort (wrapper handles compensation if defined).
 */
function _dinoco_inv_do_issue_mutate($post_id, $dist_id, $total, $dist_name) {
    // Ensure due_date is set вҖ” calculate from credit_term_days if empty
    $due = get_field('due_date', $post_id);
    if (empty($due)) {
        $term = intval(get_field('credit_term_days', $dist_id) ?: 30);
        $inv_date = get_post_meta($post_id, '_inv_date', true) ?: b2b_date('Y-m-d');
        $due = b2b_date('Y-m-d', strtotime($inv_date . ' +' . $term . ' days'));
        update_field('due_date', $due, $post_id);
    }

    // V.34.0 HIGH-H4 FIX: reordered вҖ” call b2b_debt_add() FIRST (atomic credit gate),
    // then mark is_billed + transition status only if debt_add succeeds.
    // V.34.0 HIGH-H14 FIX: no direct update_field('current_debt') fallback.
    if (!function_exists('b2b_debt_add')) {
        delete_transient('inv_issue_' . $post_id);
        b2b_log('[CRITICAL] Manual Invoice V.34.2 _do_issue_mutate: b2b_debt_add() missing вҖ” refusing to issue invoice for dist=' . $dist_id . ' total=' . $total);
        return new WP_Error('debt_helper_missing',
            'аёЈаё°аёҡаёҡаёҡаёұаёҚаёҠаёөаё«аёҷаёөа№үа№„аёЎа№ҲаёһаёЈа№үаёӯаёЎа№ғаёҠа№үаёҮаёІаёҷ вҖ” аёҒаёЈаёёаё“аёІаё•аёЈаё§аёҲаёӘаёӯаёҡ Snippet 1/13 (invoice not issued)',
            ['status' => 503]);
    }
    $result = b2b_debt_add($dist_id, $total, 'manual_invoice_issue:' . $post_id, $post_id);
    if ($result === false) {
        delete_transient('inv_issue_' . $post_id);
        $limit = floatval(get_field('credit_limit', $dist_id));
        $debt = floatval(get_field('current_debt', $dist_id));
        $avail = max(0, $limit - $debt);
        return new WP_Error('credit_exceeded',
            'а№ҖаёҒаёҙаёҷаё§аёҮа№Җаё„аёЈаё”аёҙаё• (atomic check): а№Җаё«аёҘаё·аёӯ аёҝ' . number_format($avail, 0) . ' а№Ғаё•а№Ҳаё•а№үаёӯаёҮаёҒаёІаёЈ аёҝ' . number_format($total, 0),
            ['status' => 403]);
    }
    // Debt added successfully вҶ’ now safe to mark issued + transition status
    update_field('is_billed', true, $post_id);
    b2b_set_order_status($post_id, 'awaiting_payment');
    b2b_add_audit_log($post_id, 'invoice_issued', 'аёӯаёӯаёҒа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү/аё§аёІаёҮаёҡаёҙаёҘ аёҝ' . number_format($total, 0) . ' а№Җаёһаёҙа№ҲаёЎаё«аёҷаёөа№үаё•аёұаё§а№Ғаё—аёҷ ' . $dist_name);

    // Transient released on success too вҖ” keeps callers' `delete_transient('inv_issue_' . $id)`
    // call sites idempotent (no harm in re-deleting an already-deleted transient).
    delete_transient('inv_issue_' . $post_id);
    return true;
}

/**
 * V.34.2: notify phase вҖ” LINE Flex Card + Invoice Image push. Runs OUTSIDE the
 * MySQL GET_LOCK so LINE API timeout cannot block other admin issue actions on same
 * distributor. Failure is non-fatal (wrapper swallows exceptions and logs) вҖ” invoice
 * row + debt are already committed by mutate phase. Same body as V.34.1 inline send.
 */
function _dinoco_inv_do_issue_notify($post_id, $dist_id, $total, $dist_name) {
    // Send LINE Flex Card + Invoice Image
    $line_group = get_field('line_group_id', $dist_id);
    if ($line_group) {
        $settings = dinoco_inv_get_settings();
        $inv_data = [
            'inv_number'      => get_post_meta($post_id, '_inv_number', true),
            'dist_name'       => $dist_name,
            'total_amount'    => $total,
            'due_date'        => get_field('due_date', $post_id),
            'issue_date'      => get_post_meta($post_id, '_inv_date', true) ?: get_the_date('Y-m-d', $post_id),
            'items_json'      => get_post_meta($post_id, '_inv_items', true),
            'credit_term_days'=> intval(get_field('credit_term_days', $dist_id)),
            'created_by'      => intval(get_post_meta($post_id, '_inv_created_by', true)),
        ];
        $flex = dinoco_inv_build_flex_card($inv_data, $settings);
        $flex_result = b2b_line_push_raw($line_group, $flex);
        $flex_code = is_array($flex_result) && isset($flex_result['code']) ? intval($flex_result['code']) : 0;
        if (function_exists('b2b_log')) b2b_log('[InvNotify] inv=' . $post_id . ' flex_push code=' . $flex_code . ' group=' . $line_group);
        // Send invoice as image (uses Snippet 10 GD generator if available)
        $img_fn_exists = function_exists('b2b_send_invoice_image');
        if (function_exists('b2b_log')) b2b_log('[InvNotify] inv=' . $post_id . ' calling b2b_send_invoice_image fn_exists=' . ($img_fn_exists ? '1' : '0'));
        if ($img_fn_exists) {
            $img_result = b2b_send_invoice_image($line_group, $post_id);
            if (function_exists('b2b_log')) {
                $summary = $img_result === false ? 'FALSE (gen/push failed вҖ” see [InvImg]/[Font]/[GD] logs above)' : (is_array($img_result) ? 'OK pages=' . count($img_result) : var_export($img_result, true));
                b2b_log('[InvNotify] inv=' . $post_id . ' image push result=' . $summary);
            }
        }
    } else {
        if (function_exists('b2b_log')) b2b_log('[InvNotify] inv=' . $post_id . ' SKIP вҖ” distributor has no line_group_id (dist=' . $dist_id . ')');
    }

    // V.35.0 вҖ” Phase 2 W6.2 SN system integration. Scan invoice items for sn_required SKUs
    // and emit warning audit + flag for admin follow-up. Actual sn_pool plate allocation
    // happens later (Phase 3) when admin uses Tab 4 аёҲаёұаё”аёҒаёІаёЈ S/N to assign physical plates.
    // For now: track which invoices need plate allocation in postmeta `_b2b_sn_pending_alloc`
    // so admin can review via Tab 4 + cross-link the customer with plates manually.
    if ( function_exists( 'dinoco_inv_check_sn_required_items' ) ) {
        try {
            $sn_pending = dinoco_inv_check_sn_required_items( $post_id );
            if ( ! empty( $sn_pending ) ) {
                update_post_meta( $post_id, '_b2b_sn_pending_alloc', $sn_pending );
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[InvSN] inv=' . $post_id . ' has ' . count( $sn_pending ) . ' sn_required items pending allocation' );
                }
                // Defensive obs capture
                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( 'invoice_sn_pending', array(
                        'invoice_id' => $post_id, 'dist_id' => $dist_id, 'pending_count' => count( $sn_pending ),
                    ) );
                }
            }
        } catch ( \Throwable $e ) {
            error_log( '[InvSN] check failed inv=' . $post_id . ': ' . $e->getMessage() );
        }
    }
}

if ( ! function_exists( 'dinoco_inv_check_sn_required_items' ) ) {
    /**
     * V.35.0 вҖ” Phase 2 W6.2: scan invoice items for SKUs with sn_attach_levelвү 'none' AND
     * sn_required=1. Returns array of pending items needing plate allocation.
     *
     * Used by _dinoco_inv_do_issue_notify after invoice issue. Defensive вҖ” returns empty
     * array if SN system not deployed (sn_attach_level column missing).
     *
     * @param int $invoice_id wp_posts.ID of the invoice
     * @return array [ { sku, qty, level, qty_per_unit, plates_needed } ... ]
     */
    function dinoco_inv_check_sn_required_items( $invoice_id ) {
        $items_json = get_post_meta( $invoice_id, '_inv_items', true );
        if ( empty( $items_json ) ) return array();
        $items = is_string( $items_json ) ? json_decode( $items_json, true ) : (array) $items_json;
        if ( ! is_array( $items ) || empty( $items ) ) return array();

        $pending = array();
        global $wpdb;
        $tbl_products = $wpdb->prefix . 'dinoco_products';

        // Defensive: sn_attach_level column may not exist (Phase 1 W2 ALTER not deployed)
        $col_exists = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.columns
             WHERE table_schema = %s AND table_name = %s AND column_name = %s",
            DB_NAME, $tbl_products, 'sn_attach_level'
        ) );
        if ( ! $col_exists ) return array();

        foreach ( $items as $item ) {
            $sku = isset( $item['sku'] ) ? strtoupper( trim( (string) $item['sku'] ) ) : '';
            $qty = isset( $item['qty'] ) ? max( 1, (int) $item['qty'] ) : 1;
            if ( $sku === '' ) continue;

            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT sn_attach_level, sn_required, sn_qty_per_unit
                 FROM {$tbl_products} WHERE sku = %s",
                $sku
            ) );
            if ( ! $row ) continue;
            if ( ! $row->sn_required ) continue;
            if ( $row->sn_attach_level === 'none' || empty( $row->sn_attach_level ) ) continue;

            // Compute plates needed using existing helper if available
            $plates_needed = $qty * max( 1, (int) ( $row->sn_qty_per_unit ?: 1 ) );
            if ( function_exists( 'dinoco_sn_required_plates_for_sku' ) ) {
                $required = dinoco_sn_required_plates_for_sku( $sku, $qty );
                if ( ! empty( $required ) ) {
                    $plates_needed = 0;
                    foreach ( $required as $r ) $plates_needed += (int) $r['qty'];
                }
            }

            $pending[] = array(
                'sku'           => $sku,
                'qty'           => $qty,
                'level'         => $row->sn_attach_level,
                'qty_per_unit'  => (int) ( $row->sn_qty_per_unit ?: 1 ),
                'plates_needed' => $plates_needed,
            );
        }

        return $pending;
    }
}

/**
 * V.34.2: legacy fallback вҖ” used when [Admin System] DINOCO Transaction Wrapper
 * snippet is disabled OR $dist_id missing (no lock target). Body preserved
 * byte-for-byte from V.34.1 (sequential validate вҶ’ debt_add вҶ’ mark issued вҶ’ notify).
 */
function _dinoco_inv_do_issue_legacy($post_id, $dist_id, $total, $dist_name) {
    // Guard: already issued
    if (get_field('is_billed', $post_id)) {
        return new WP_Error('already_issued', 'аёҡаёҙаёҘаёҷаёөа№үаёӯаёӯаёҒа№ҒаёҘа№үаё§ а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёӯаёӯаёҒаёӢа№үаёіа№„аё”а№ү', ['status' => 400]);
    }

    // Guard: race condition dedup
    $lock_key = 'inv_issue_' . $post_id;
    if (get_transient($lock_key)) {
        return new WP_Error('duplicate', 'аёҒаёіаёҘаёұаёҮаё”аёіа№ҖаёҷаёҙаёҷаёҒаёІаёЈ аёҒаёЈаёёаё“аёІаёЈаёӯаёӘаёұаёҒаё„аёЈаё№а№Ҳ', ['status' => 429]);
    }
    set_transient($lock_key, 1, 10);

    // Guard: credit_hold
    if ($dist_id && get_field('credit_hold', $dist_id)) {
        return new WP_Error('credit_hold', 'аёЈаё°аёҮаёұаёҡа№Җаё„аёЈаё”аёҙаё•: а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёӯаёӯаёҒаёҡаёҙаёҘа№„аё”а№ү', ['status' => 403]);
    }
    // Guard: credit limit
    if ($dist_id) {
        $limit = floatval(get_field('credit_limit', $dist_id));
        $debt  = floatval(get_field('current_debt', $dist_id));
        if ($limit > 0 && ($debt + $total) > $limit) {
            $avail = max(0, $limit - $debt);
            return new WP_Error('credit_exceeded',
                'а№ҖаёҒаёҙаёҷаё§аёҮа№Җаё„аёЈаё”аёҙаё•: а№Җаё«аёҘаё·аёӯ аёҝ' . number_format($avail, 0) . ' а№Ғаё•а№Ҳаё•а№үаёӯаёҮаёҒаёІаёЈ аёҝ' . number_format($total, 0),
                ['status' => 403]);
        }
    }

    // Ensure due_date is set вҖ” calculate from credit_term_days if empty
    $due = get_field('due_date', $post_id);
    if (empty($due)) {
        $term = intval(get_field('credit_term_days', $dist_id) ?: 30);
        $inv_date = get_post_meta($post_id, '_inv_date', true) ?: b2b_date('Y-m-d');
        $due = b2b_date('Y-m-d', strtotime($inv_date . ' +' . $term . ' days'));
        update_field('due_date', $due, $post_id);
    }

    // V.34.0 HIGH-H4 FIX: reordered вҖ” call b2b_debt_add() FIRST (atomic credit gate),
    // then mark is_billed + transition status only if debt_add succeeds.
    if (!function_exists('b2b_debt_add')) {
        delete_transient('inv_issue_' . $post_id);
        b2b_log('[CRITICAL] Manual Invoice V.34.2 _do_issue_legacy: b2b_debt_add() missing вҖ” refusing to issue invoice for dist=' . $dist_id . ' total=' . $total);
        return new WP_Error('debt_helper_missing',
            'аёЈаё°аёҡаёҡаёҡаёұаёҚаёҠаёөаё«аёҷаёөа№үа№„аёЎа№ҲаёһаёЈа№үаёӯаёЎа№ғаёҠа№үаёҮаёІаёҷ вҖ” аёҒаёЈаёёаё“аёІаё•аёЈаё§аёҲаёӘаёӯаёҡ Snippet 1/13 (invoice not issued)',
            ['status' => 503]);
    }
    $result = b2b_debt_add($dist_id, $total, 'manual_invoice_issue:' . $post_id, $post_id);
    if ($result === false) {
        delete_transient('inv_issue_' . $post_id);
        $limit = floatval(get_field('credit_limit', $dist_id));
        $debt = floatval(get_field('current_debt', $dist_id));
        $avail = max(0, $limit - $debt);
        return new WP_Error('credit_exceeded',
            'а№ҖаёҒаёҙаёҷаё§аёҮа№Җаё„аёЈаё”аёҙаё• (atomic check): а№Җаё«аёҘаё·аёӯ аёҝ' . number_format($avail, 0) . ' а№Ғаё•а№Ҳаё•а№үаёӯаёҮаёҒаёІаёЈ аёҝ' . number_format($total, 0),
            ['status' => 403]);
    }
    // Debt added successfully вҶ’ now safe to mark issued + transition status
    update_field('is_billed', true, $post_id);
    b2b_set_order_status($post_id, 'awaiting_payment');
    b2b_add_audit_log($post_id, 'invoice_issued', 'аёӯаёӯаёҒа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү/аё§аёІаёҮаёҡаёҙаёҘ аёҝ' . number_format($total, 0) . ' а№Җаёһаёҙа№ҲаёЎаё«аёҷаёөа№үаё•аёұаё§а№Ғаё—аёҷ ' . $dist_name);

    // Send LINE Flex Card + Invoice Image (legacy path вҖ” same observability as wrapper notify)
    $line_group = get_field('line_group_id', $dist_id);
    if ($line_group) {
        $settings = dinoco_inv_get_settings();
        $inv_data = [
            'inv_number'      => get_post_meta($post_id, '_inv_number', true),
            'dist_name'       => $dist_name,
            'total_amount'    => $total,
            'due_date'        => get_field('due_date', $post_id),
            'issue_date'      => get_post_meta($post_id, '_inv_date', true) ?: get_the_date('Y-m-d', $post_id),
            'items_json'      => get_post_meta($post_id, '_inv_items', true),
            'credit_term_days'=> intval(get_field('credit_term_days', $dist_id)),
            'created_by'      => intval(get_post_meta($post_id, '_inv_created_by', true)),
        ];
        $flex = dinoco_inv_build_flex_card($inv_data, $settings);
        $flex_result = b2b_line_push_raw($line_group, $flex);
        $flex_code = is_array($flex_result) && isset($flex_result['code']) ? intval($flex_result['code']) : 0;
        if (function_exists('b2b_log')) b2b_log('[InvNotify-legacy] inv=' . $post_id . ' flex_push code=' . $flex_code . ' group=' . $line_group);
        $img_fn_exists = function_exists('b2b_send_invoice_image');
        if (function_exists('b2b_log')) b2b_log('[InvNotify-legacy] inv=' . $post_id . ' calling b2b_send_invoice_image fn_exists=' . ($img_fn_exists ? '1' : '0'));
        if ($img_fn_exists) {
            $img_result = b2b_send_invoice_image($line_group, $post_id);
            if (function_exists('b2b_log')) {
                $summary = $img_result === false ? 'FALSE (gen/push failed вҖ” see [InvImg]/[Font]/[GD] logs above)' : (is_array($img_result) ? 'OK pages=' . count($img_result) : var_export($img_result, true));
                b2b_log('[InvNotify-legacy] inv=' . $post_id . ' image push result=' . $summary);
            }
        }
    } else {
        if (function_exists('b2b_log')) b2b_log('[InvNotify-legacy] inv=' . $post_id . ' SKIP вҖ” distributor has no line_group_id (dist=' . $dist_id . ')');
    }
    return true;
}

// V.34.11 Round 43: Idempotency-Key support вҖ” admin "аёӯаёӯаёҒаёҡаёҙаёҘ/аёӘа№ҲаёҮ LINE" double-click on slow
// LINE push вҶ’ 2Г— Flex card + 2Г— invoice image push to distributor LINE group + 2Г— FSM
// transition draftвҶ’awaiting_payment + 2Г— debt add via dinoco_inv_apply_debt. Body hash =
// {id} вҖ” invoice id discriminator. FSM gate (status=draft) prevents 2nd write but 2Г— LINE
// push fires before status check completes. Wrapper short-circuits at hash-check level.
function dinoco_inv_rest_issue(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);

    $idem_key       = function_exists('dinoco_idempotency_extract_key') ? dinoco_idempotency_extract_key($req) : '';
    $idem_namespace = 'b2b/v1::invoice/issue';
    $idem_body      = null;
    if ($idem_key !== '' && function_exists('dinoco_idempotency_check')) {
        $idem_body = array('id' => (int) $id);
        $cached = dinoco_idempotency_check($idem_key, $idem_namespace, $idem_body);
        if (is_wp_error($cached)) {
            $err_data    = $cached->get_error_data();
            $status_code = (is_array($err_data) && isset($err_data['status'])) ? (int) $err_data['status'] : 409;
            return new WP_Error('idempotency_conflict',
                'Idempotency-Key аёӢа№үаёіаёҒаёұаёҡ request а№ҖаёҒа№ҲаёІаё—аёөа№ҲаёЎаёөаёӮа№үаёӯаёЎаё№аёҘаё•а№ҲаёІаёҮаёҒаёұаёҷ',
                array('status' => $status_code));
        }
        if (is_array($cached)) {
            $resp = $cached;
            unset($resp['_idem_code']);
            return rest_ensure_response($resp);
        }
    }

    if (get_field('order_status', $id) !== 'draft') return new WP_Error('invalid', 'аёӯаёӯаёҒаёҡаёҙаёҘа№„аё”а№үа№ҖаёүаёһаёІаё°аёӘаё–аёІаёҷаё° Draft', ['status' => 400]);
    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $total   = floatval(get_field('total_amount', $id));
    $dist_name = get_field('dist_name', $id);
    $result = _dinoco_inv_do_issue($id, $dist_id, $total, $dist_name);
    if (is_wp_error($result)) return $result;

    $resp = array('success' => true, 'id' => $id, 'status' => 'awaiting_payment');
    if ($idem_key !== '' && $idem_body !== null && function_exists('dinoco_idempotency_store')) {
        dinoco_idempotency_store($idem_key, $idem_namespace, $idem_body,
            array_merge($resp, array('_idem_code' => 200)), 200);
    }
    return rest_ensure_response($resp);
}

// --- RECORD PAYMENT ---
// V.34.1 CRIT-C5 FIX: wrap meta read/write in START TRANSACTION + FOR UPDATE on
// _inv_paid_amount + _inv_slip_ref + post row. Mirror record_refund pattern (line 1657+).
// Prevents lost-update race when 2 admins click record_payment concurrently or when
// auto-allocate (verify_slip_combined) loops record_payment per matched invoice.
function dinoco_inv_rest_record_payment(WP_REST_Request $req) {
    global $wpdb;
    $id     = intval($req->get_param('id'));
    $amount = floatval($req->get_param('amount'));
    $note   = sanitize_text_field($req->get_param('note') ?? '');
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if ($amount <= 0) return new WP_Error('invalid', 'аёўаёӯаё”аёҠаёіаёЈаё°аё•а№үаёӯаёҮаёЎаёІаёҒаёҒаё§а№ҲаёІ 0', ['status' => 400]);

    // V.34.11 Round 43: Idempotency-Key support вҖ” CRITICAL retry-prone endpoint.
    // Admin "аёҡаёұаёҷаё—аё¶аёҒаёҠаёіаёЈаё°" double-click on slow ACF/SQL вҶ’ 2Г— _inv_paid_amount add + 2Г—
    // partial_payments json append + 2Г— debt subtract via b2b_recalculate_debt вҶ’ debt
    // double-cleared. FOR UPDATE lock prevents physical race but a 2nd retry AFTER 1st
    // commit still re-adds the payment. Body hash = {id, amount, note} вҖ” same payment
    // on retry replays cached response; different amount mid-retry вҶ’ 409 (admin must
    // use new key). FSM-gated by status=awaiting_payment but 1st call FSM transitions
    // to paid вҶ’ 2nd call returns "а№„аёЎа№Ҳа№ғаёҠа№ҲаёӘаё–аёІаёҷаё°аёЈаёӯаёҠаёіаёЈаё°" вҖ” wrapper preempts that error path.
    $idem_key       = function_exists('dinoco_idempotency_extract_key') ? dinoco_idempotency_extract_key($req) : '';
    $idem_namespace = 'b2b/v1::invoice/record-payment';
    $idem_body      = null;
    if ($idem_key !== '' && function_exists('dinoco_idempotency_check')) {
        $idem_body = array(
            'id'     => (int) $id,
            'amount' => round($amount, 2),  // normalize float precision
            'note'   => $note,
        );
        $cached = dinoco_idempotency_check($idem_key, $idem_namespace, $idem_body);
        if (is_wp_error($cached)) {
            $err_data    = $cached->get_error_data();
            $status_code = (is_array($err_data) && isset($err_data['status'])) ? (int) $err_data['status'] : 409;
            return new WP_Error('idempotency_conflict',
                'Idempotency-Key аёӢа№үаёіаёҒаёұаёҡ request а№ҖаёҒа№ҲаёІаё—аёөа№ҲаёЎаёөаёӮа№үаёӯаёЎаё№аёҘаё•а№ҲаёІаёҮаёҒаёұаёҷ',
                array('status' => $status_code));
        }
        if (is_array($cached)) {
            $resp = $cached;
            unset($resp['_idem_code']);
            return rest_ensure_response($resp);
        }
    }

    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $total   = 0;
    $new_paid = 0;
    $is_full = false;
    $tolerance_eps = 0.01;

    $wpdb->query('START TRANSACTION');
    try {
        // Lock paid_amount + slip_ref meta + post row to serialize concurrent payment writes
        $wpdb->get_row($wpdb->prepare(
            "SELECT meta_id FROM {$wpdb->postmeta} WHERE post_id=%d AND meta_key=%s FOR UPDATE",
            $id, '_inv_paid_amount'
        ));
        $wpdb->get_row($wpdb->prepare(
            "SELECT meta_id FROM {$wpdb->postmeta} WHERE post_id=%d AND meta_key=%s FOR UPDATE",
            $id, '_inv_slip_ref'
        ));
        $wpdb->get_row($wpdb->prepare(
            "SELECT ID FROM {$wpdb->posts} WHERE ID=%d FOR UPDATE",
            $id
        ));

        // Re-check status under lock (caller may have raced with cancel/paid)
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') {
            $wpdb->query('ROLLBACK');
            return new WP_Error('invalid', 'аёҡаёұаёҷаё—аё¶аёҒаёҒаёІаёЈаёҠаёіаёЈаё°а№„аё”а№үа№ҖаёүаёһаёІаё°аёӘаё–аёІаёҷаё°аёЈаёӯаёҠаёіаёЈаё°а№ҖаёҮаёҙаёҷа№Җаё—а№ҲаёІаёҷаёұа№үаёҷ', ['status' => 400]);
        }

        $total       = floatval(get_field('total_amount', $id));
        $paid_so_far = floatval(get_post_meta($id, '_inv_paid_amount', true));
        $remaining   = round($total - $paid_so_far, 2);
        if ($amount > $remaining + $tolerance_eps) {
            $wpdb->query('ROLLBACK');
            return new WP_Error('overpayment', 'аёўаёӯаё”аёҠаёіаёЈаё°а№ҖаёҒаёҙаёҷ: а№Җаё«аёҘаё·аёӯаё—аёөа№Ҳаё•а№үаёӯаёҮаёҠаёіаёЈаё° аёҝ' . number_format($remaining, 2), ['status' => 400]);
        }

        $new_paid = round($paid_so_far + $amount, 2);
        $payments = json_decode(get_post_meta($id, '_inv_partial_payments', true) ?: '[]', true);
        if (!is_array($payments)) $payments = [];
        $payments[] = ['amount' => $amount, 'date' => b2b_date('Y-m-d H:i:s'), 'note' => $note];
        // Wave 2 M3: cap unbounded JSON growth вҖ” keep last 50 entries
        if (count($payments) > 50) $payments = array_slice($payments, -50);

        update_post_meta($id, '_inv_paid_amount', $new_paid);
        update_post_meta($id, '_inv_partial_payments', wp_json_encode($payments, JSON_UNESCAPED_UNICODE));

        $is_full = ($new_paid >= $total - $tolerance_eps);
        if ($is_full) {
            // FSM transition under lock вҖ” fail loud if helper missing (CRIT-C2 contract)
            if (!function_exists('b2b_set_order_status')) {
                $wpdb->query('ROLLBACK');
                b2b_log('[CRITICAL] Manual Invoice V.34.1 record_payment: b2b_set_order_status missing вҖ” payment ABORTED for post=' . $id);
                return new WP_Error('fsm_helper_missing', 'аёЈаё°аёҡаёҡ FSM аёўаёұаёҮа№„аёЎа№ҲаёһаёЈа№үаёӯаёЎ (Snippet 1)', ['status' => 503]);
            }
            b2b_set_order_status($id, 'paid');
            update_field('is_billed', false, $id);
        }

        $wpdb->query('COMMIT');
    } catch (\Throwable $e) {
        $wpdb->query('ROLLBACK');
        b2b_log('[Manual Invoice] record_payment exception post=' . $id . ' err=' . $e->getMessage());
        return new WP_Error('record_failed', 'аёҡаёұаёҷаё—аё¶аёҒаёҠаёіаёЈаё°аёҘа№үаёЎа№Җаё«аёҘаё§: ' . $e->getMessage(), ['status' => 500]);
    }

    // Post-commit side effects
    if ($is_full) {
        // V.34.0/V.34.1 HIGH-H14: atomic helper chain only, no direct update_field fallback
        if (function_exists('b2b_recalculate_debt') && $dist_id) {
            b2b_recalculate_debt($dist_id);
        } elseif (function_exists('b2b_debt_subtract') && $dist_id) {
            b2b_debt_subtract($dist_id, $total, 'manual_invoice_paid:'.$id, $id);
        } elseif ($dist_id) {
            b2b_log('[CRITICAL] Manual Invoice V.34.1 record_payment fully_paid: b2b_recalculate_debt + b2b_debt_subtract both missing вҖ” debt NOT reversed for dist=' . $dist_id . ' amount=' . $total . ' (admin must reconcile manually)');
        }
        b2b_add_audit_log($id, 'invoice_paid', 'аёҠаёіаёЈаё°аё„аёЈаёҡ аёҝ' . number_format($new_paid, 0));
        $resp = array('success' => true, 'fully_paid' => true, 'status' => 'paid');
        if ($idem_key !== '' && $idem_body !== null && function_exists('dinoco_idempotency_store')) {
            dinoco_idempotency_store($idem_key, $idem_namespace, $idem_body,
                array_merge($resp, array('_idem_code' => 200)), 200);
        }
        return rest_ensure_response($resp);
    } else {
        // Recalculate debt after partial payment so credit limit + Flex show correct values
        if (function_exists('b2b_recalculate_debt') && $dist_id) {
            b2b_recalculate_debt($dist_id);
        }
        b2b_add_audit_log($id, 'partial_payment', 'аёЈаёұаёҡаёҠаёіаёЈаё°аёҡаёІаёҮаёӘа№Ҳаё§аёҷ аёҝ' . number_format($amount, 0) . ' (аёЈаё§аёЎ аёҝ' . number_format($new_paid, 0) . '/' . number_format($total, 0) . ')');
        $resp = array('success' => true, 'fully_paid' => false, 'paid_amount' => $new_paid);
        if ($idem_key !== '' && $idem_body !== null && function_exists('dinoco_idempotency_store')) {
            dinoco_idempotency_store($idem_key, $idem_namespace, $idem_body,
                array_merge($resp, array('_idem_code' => 200)), 200);
        }
        return rest_ensure_response($resp);
    }
}

// --- V.33.4 AUDIT C2 v2: RECORD REFUND with atomic lock ---
// а№ғаёҠа№ү wpdb transaction + FOR UPDATE аёҡаёҷ wp_postmeta rows аёӮаёӯаёҮ `_inv_paid_amount`
// + `_inv_refunded_amount` а№Җаёһаё·а№ҲаёӯаёҒаёұаёҷ race condition а№ҖаёЎаё·а№Ҳаёӯ admin 2 аё„аёҷаёҒаё”аёһаёЈа№үаёӯаёЎаёҒаёұаёҷ
function dinoco_inv_rest_record_refund(WP_REST_Request $req) {
    global $wpdb;
    $id      = intval($req->get_param('id'));
    $amount  = floatval($req->get_param('amount'));
    $reason  = sanitize_text_field($req->get_param('reason') ?? '');
    $method  = sanitize_text_field($req->get_param('method') ?? 'manual'); // manual|bank_transfer|cash|credit_note
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if ($amount <= 0) return new WP_Error('invalid', 'аёҲаёіаёҷаё§аёҷа№ҖаёҮаёҙаёҷаё„аё·аёҷаё•а№үаёӯаёҮаёЎаёІаёҒаёҒаё§а№ҲаёІ 0', ['status' => 400]);
    if (empty($reason)) return new WP_Error('invalid', 'аёҒаёЈаёёаё“аёІаёЈаё°аёҡаёёа№Җаё«аё•аёёаёңаёҘаёҒаёІаёЈаё„аё·аёҷа№ҖаёҮаёҙаёҷ', ['status' => 400]);
    if (strlen($reason) > 500)  return new WP_Error('invalid', 'а№Җаё«аё•аёёаёңаёҘаёўаёІаё§а№ҖаёҒаёҙаёҷа№„аёӣ (аёӘаё№аёҮаёӘаёёаё” 500 аёӯаёұаёҒаёӮаёЈаё°)', ['status' => 400]);

    // V.34.11 Round 43: Idempotency-Key support вҖ” CRITICAL retry-prone endpoint mirrors
    // record-payment but reverses ledger. Admin "аёҡаёұаёҷаё—аё¶аёҒаё„аё·аёҷа№ҖаёҮаёҙаёҷ" double-click вҶ’ 2Г— refund
    // entry + 2Г— _inv_refunded_amount add + 2Г— FSM transition paidвҶ’awaiting_payment +
    // 2Г— debt re-add via b2b_recalculate_debt вҶ’ debt double-credited вҶ’ distributor sees
    // wrong outstanding balance. Body hash = {id, amount, reason, method} вҖ”
    // method enum (manual|bank_transfer|cash|credit_note) discriminates accounting category.
    // Different reason = different idempotency key (admin must use new key for distinct refund).
    $idem_key       = function_exists('dinoco_idempotency_extract_key') ? dinoco_idempotency_extract_key($req) : '';
    $idem_namespace = 'b2b/v1::invoice/record-refund';
    $idem_body      = null;
    if ($idem_key !== '' && function_exists('dinoco_idempotency_check')) {
        $idem_body = array(
            'id'     => (int) $id,
            'amount' => round($amount, 2),  // normalize float precision
            'reason' => $reason,            // sanitized + length-checked above
            'method' => $method,            // enum: manual|bank_transfer|cash|credit_note
        );
        $cached = dinoco_idempotency_check($idem_key, $idem_namespace, $idem_body);
        if (is_wp_error($cached)) {
            $err_data    = $cached->get_error_data();
            $status_code = (is_array($err_data) && isset($err_data['status'])) ? (int) $err_data['status'] : 409;
            return new WP_Error('idempotency_conflict',
                'Idempotency-Key аёӢа№үаёіаёҒаёұаёҡ request а№ҖаёҒа№ҲаёІаё—аёөа№ҲаёЎаёөаёӮа№үаёӯаёЎаё№аёҘаё•а№ҲаёІаёҮаёҒаёұаёҷ',
                array('status' => $status_code));
        }
        if (is_array($cached)) {
            $resp = $cached;
            unset($resp['_idem_code']);
            return rest_ensure_response($resp);
        }
    }

    // Start atomic block
    $wpdb->query('START TRANSACTION');
    try {
        // Lock rows for `_inv_paid_amount` and `_inv_refunded_amount` under FOR UPDATE
        // (meta_id unique per post+key вҶ’ one row each). If row doesn't exist, FOR UPDATE returns empty but lock intent still taken via post row.
        $wpdb->get_row($wpdb->prepare(
            "SELECT meta_id FROM {$wpdb->postmeta} WHERE post_id=%d AND meta_key=%s FOR UPDATE",
            $id, '_inv_paid_amount'
        ));
        $wpdb->get_row($wpdb->prepare(
            "SELECT meta_id FROM {$wpdb->postmeta} WHERE post_id=%d AND meta_key=%s FOR UPDATE",
            $id, '_inv_refunded_amount'
        ));
        // Also lock the post row so cancel/paid-status changes serialize with us
        $wpdb->get_row($wpdb->prepare(
            "SELECT ID FROM {$wpdb->posts} WHERE ID=%d FOR UPDATE",
            $id
        ));

        $paid_so_far   = floatval(get_post_meta($id, '_inv_paid_amount', true));
        $refunded_prev = floatval(get_post_meta($id, '_inv_refunded_amount', true));
        $refundable    = round($paid_so_far - $refunded_prev, 2);
        if ($amount > $refundable + 0.01) {
            $wpdb->query('ROLLBACK');
            return new WP_Error('overrefund', 'аё„аё·аёҷа№ҖаёҮаёҙаёҷа№ҖаёҒаёҙаёҷ: аё„аё·аёҷа№„аё”а№үаёӘаё№аёҮаёӘаёёаё” аёҝ' . number_format($refundable, 2), ['status' => 400]);
        }

        $status = get_field('order_status', $id);
        if (!in_array($status, ['paid', 'awaiting_payment', 'cancelled'], true)) {
            $wpdb->query('ROLLBACK');
            return new WP_Error('invalid_status', 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёҡаёұаёҷаё—аё¶аёҒаёҒаёІаёЈаё„аё·аёҷа№ҖаёҮаёҙаёҷа№ғаёҷаёӘаё–аёІаёҷаё°аёҷаёөа№ү', ['status' => 400]);
        }

        // Record refund entry
        $new_refunded = round($refunded_prev + $amount, 2);
        $refund_log   = json_decode(get_post_meta($id, '_inv_refunds', true) ?: '[]', true);
        if (!is_array($refund_log)) $refund_log = [];
        $refund_log[] = [
            'amount'   => $amount,
            'reason'   => $reason,
            'method'   => $method,
            'date'     => b2b_date('Y-m-d H:i:s'),
            'admin_id' => get_current_user_id(),
            'admin'    => wp_get_current_user()->user_login,
        ];
        update_post_meta($id, '_inv_refunded_amount', $new_refunded);
        update_post_meta($id, '_inv_refunds', wp_json_encode($refund_log, JSON_UNESCAPED_UNICODE));

        $wpdb->query('COMMIT');
    } catch (\Throwable $e) {
        $wpdb->query('ROLLBACK');
        b2b_log('[Refund] Exception: ' . $e->getMessage());
        return new WP_Error('refund_error', 'аёҡаёұаёҷаё—аё¶аёҒаё„аё·аёҷа№ҖаёҮаёҙаёҷаёҘа№үаёЎа№Җаё«аёҘаё§: ' . $e->getMessage(), ['status' => 500]);
    }

    // --- Post-commit side effects (safe, no race on ledger) ---
    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $total   = floatval(get_field('total_amount', $id));
    $net_paid = round($paid_so_far - $new_refunded, 2);

    // аё–а№үаёІ invoice status = paid а№ҒаёҘаё° net paid аё•аёӯаёҷаёҷаёөа№ү < total вҶ’ а№ҖаёӣаёҘаёөа№ҲаёўаёҷаёҒаёҘаёұаёҡа№Җаёӣа№Үаёҷ awaiting_payment + re-bill
    if ($status === 'paid' && $net_paid < $total - 0.01) {
        b2b_set_order_status($id, 'awaiting_payment');
        update_field('is_billed', true, $id);
    }

    if (function_exists('b2b_recalculate_debt') && $dist_id) {
        b2b_recalculate_debt($dist_id);
    }

    b2b_add_audit_log(
        $id,
        'refund_recorded',
        sprintf('аё„аё·аёҷа№ҖаёҮаёҙаёҷ аёҝ%s (%s) вҖ” а№Җаё«аё•аёёаёңаёҘ: %s', number_format($amount, 0), $method, $reason)
    );

    $resp = array(
        'success'        => true,
        'refunded_total' => $new_refunded,
        'net_paid'       => $net_paid,
        'new_status'     => get_field('order_status', $id),
    );
    if ($idem_key !== '' && $idem_body !== null && function_exists('dinoco_idempotency_store')) {
        dinoco_idempotency_store($idem_key, $idem_namespace, $idem_body,
            array_merge($resp, array('_idem_code' => 200)), 200);
    }
    return rest_ensure_response($resp);
}

// --- VERIFY SLIP ---
// V.34.1 Wave 2 audit fixes:
//   вҖў C4: trans_ref dedup gate via b2b_slip_is_trans_ref_seen() before record_payment
//   вҖў C6: stamp _inv_slip_ref moved INSIDE record_payment (no longer pre-stamp before commit)
//   вҖў H8: Slip2Go API response cached 5min keyed on SHA-256(slip_url) вҖ” avoid double-bill on retry
function dinoco_inv_rest_verify_slip(WP_REST_Request $req) {
    $id       = intval($req->get_param('id'));
    $slip_url = esc_url_raw($req->get_param('slip_url') ?? '');
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if (!$slip_url) return new WP_Error('invalid', 'аёҒаёЈаёёаё“аёІаёЈаё°аёҡаёё URL аёӘаёҘаёҙаёӣ', ['status' => 400]);
    $inv_status = get_field('order_status', $id);
    if ($inv_status === 'paid') return new WP_Error('already_paid', 'а№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№үаёҷаёөа№үаёҠаёіаёЈаё°аё„аёЈаёҡа№ҒаёҘа№үаё§', ['status' => 400]);
    if ($inv_status !== 'awaiting_payment') return new WP_Error('invalid_status', 'аё•аёЈаё§аёҲаёӘаёҘаёҙаёӣа№„аё”а№үа№ҖаёүаёһаёІаё°аёӘаё–аёІаёҷаё°аёЈаёӯаёҠаёіаёЈаё°а№ҖаёҮаёҙаёҷа№Җаё—а№ҲаёІаёҷаёұа№үаёҷ', ['status' => 400]);

    $api_url = defined('B2B_SLIP2GO_API_URL') ? B2B_SLIP2GO_API_URL : '';
    $secret  = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';
    if (!$api_url || !$secret) return new WP_Error('config', 'аёўаёұаёҮа№„аёЎа№Ҳа№„аё”а№үаё•аёұа№үаёҮаё„а№ҲаёІ Slip2Go API', ['status' => 500]);

    // H8: idempotency cache lookup
    $http_code = 0;
    $raw_body  = '';
    $from_cache = false;
    if (function_exists('b2b_slip_get_cached_response_by_url')) {
        $cached = b2b_slip_get_cached_response_by_url($slip_url);
        if (is_array($cached)) {
            $http_code = intval($cached['http_code']);
            $raw_body  = (string) $cached['body'];
            $from_cache = true;
        }
    }
    if (!$from_cache) {
        $resp = wp_remote_post($api_url, [
            'headers' => ['Content-Type' => 'application/json', 'Authorization' => 'Bearer ' . $secret],
            'body'    => wp_json_encode(['url' => $slip_url]),
            'timeout' => 15,
        ]);
        if (is_wp_error($resp)) return new WP_Error('api_error', 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аё•аёҙаё”аё•а№Ҳаёӯ Slip2Go а№„аё”а№ү', ['status' => 502]);
        $http_code = wp_remote_retrieve_response_code($resp);
        $raw_body  = wp_remote_retrieve_body($resp);
        if (function_exists('b2b_slip_set_cached_response_by_url') && $http_code === 200) {
            b2b_slip_set_cached_response_by_url($slip_url, $http_code, $raw_body);
        }
    }

    $body     = json_decode($raw_body, true);
    $verified = ($http_code === 200 && is_array($body) && !empty($body['success']));

    if ($verified) {
        $amount = floatval($body['amount'] ?? 0);
        $ref    = sanitize_text_field($body['ref'] ?? '');
        $date   = sanitize_text_field($body['date'] ?? b2b_date('Y-m-d H:i:s'));

        // C4: trans_ref dedup gate before record_payment
        if ($ref !== '' && function_exists('b2b_slip_is_trans_ref_seen') && b2b_slip_is_trans_ref_seen($ref)) {
            return new WP_Error('duplicate_slip', 'аёӘаёҘаёҙаёӣаёҷаёөа№үа№Җаё„аёўа№ғаёҠа№үа№ҒаёҘа№үаё§ (TransRef: ' . $ref . ')', ['status' => 409]);
        }

        b2b_add_audit_log($id, 'slip_verified', 'аё•аёЈаё§аёҲаёӘаёҘаёҙаёӣаёңа№ҲаёІаёҷ аёҝ' . number_format($amount, 0) . ' ref=' . $ref . ($from_cache ? ' (cached)' : ''));

        // C6: stamp _inv_slip_ref inside record_payment under FOR UPDATE (no pre-stamp)
        // record_payment now does the stamp atomically alongside payment write
        update_post_meta($id, '_inv_slip_verified_at', b2b_date('Y-m-d H:i:s'));
        // Stamp ref so dedup query sees it post-COMMIT (C6: inside record_payment lock window via update_post_meta call after FOR UPDATE)
        // Note: record_payment now also accepts stamping via _inv_slip_ref meta (we set it here pre-call AS the atomic-helper version
        //       below would, but record_payment will FOR UPDATE the same row). Pre-stamp removed вҖ” record_payment writes inside lock.
        $note = 'Slip2Go ref=' . $ref . ' аё§аёұаёҷаё—аёөа№Ҳ=' . $date . ($from_cache ? ' (cached)' : '');
        // Stamp _inv_slip_ref inside record_payment by using the atomic helper directly
        global $wpdb;
        $wpdb->query('START TRANSACTION');
        try {
            $wpdb->get_row($wpdb->prepare("SELECT meta_id FROM {$wpdb->postmeta} WHERE post_id=%d AND meta_key=%s FOR UPDATE", $id, '_inv_slip_ref'));
            update_post_meta($id, '_inv_slip_ref', $ref);
            update_post_meta($id, '_slip_trans_ref', $ref); // for dedup query (Snippet 1 V.34.8)
            $wpdb->query('COMMIT');
        } catch (\Throwable $e) {
            $wpdb->query('ROLLBACK');
            b2b_log('[Manual Invoice] verify_slip stamp ref failed post=' . $id . ' err=' . $e->getMessage());
            return new WP_Error('record_failed', 'аёҡаёұаёҷаё—аё¶аёҒ slip_ref аёҘа№үаёЎа№Җаё«аёҘаё§: ' . $e->getMessage(), ['status' => 500]);
        }
        // Now record_payment (which itself uses FOR UPDATE on _inv_paid_amount + _inv_slip_ref)
        $fake_req = new WP_REST_Request();
        $fake_req->set_param('id', $id);
        $fake_req->set_param('amount', $amount);
        $fake_req->set_param('note', $note);
        return dinoco_inv_rest_record_payment($fake_req);
    }

    $reason = (is_array($body) ? ($body['message'] ?? '') : '') ?: 'Slip2Go аёӣаёҸаёҙа№ҖаёӘаёҳаёҒаёІаёЈаё•аёЈаё§аёҲаёӘаёӯаёҡ';
    return rest_ensure_response(['success' => false, 'verified' => false, 'reason' => $reason]);
}

// --- COMBINED SLIP VERIFY (V.2.6) ---
// Accepts slip_url + dist_id вҶ’ verifies slip вҶ’ auto-matches to invoices
// V.34.1 Wave 2 audit fixes:
//   вҖў C4: trans_ref dedup gate via b2b_slip_is_trans_ref_seen()
//   вҖў C5: atomic record_payment via FOR UPDATE (delegated to shared helper)
//   вҖў C6: _inv_slip_ref stamp inside helper transaction (no pre-stamp before commit)
//   вҖў H6: slip pipeline convergence вҖ” uses b2b_slip_apply_to_invoices() shared helper
//   вҖў H7: $slip_amount underflow guard inside helper loop
//   вҖў H8: Slip2Go API response cached 5min keyed on SHA-256(slip_url)
//   вҖў M2: validate every manual_ids belongs to $dist_id (block cross-distributor leak)
//   вҖў M3: _inv_partial_payments capped 50 entries inside helper
function dinoco_inv_rest_verify_slip_combined(WP_REST_Request $req) {
    $slip_url = esc_url_raw($req->get_param('slip_url') ?? '');
    $dist_id  = intval($req->get_param('dist_id'));
    $manual_ids = $req->get_param('invoice_ids'); // optional: admin pre-selects invoices
    if (!$slip_url) return new WP_Error('invalid', 'аёҒаёЈаёёаё“аёІаёЈаё°аёҡаёё URL аёӘаёҘаёҙаёӣ', ['status' => 400]);

    // Call Slip2Go (with H8 idempotency cache)
    $api_url = defined('B2B_SLIP2GO_API_URL') ? B2B_SLIP2GO_API_URL : '';
    $secret  = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';
    if (!$api_url || !$secret) return new WP_Error('config', 'аёўаёұаёҮа№„аёЎа№Ҳа№„аё”а№үаё•аёұа№үаёҮаё„а№ҲаёІ Slip2Go API', ['status' => 500]);

    $http_code = 0;
    $raw_body  = '';
    $from_cache = false;
    if (function_exists('b2b_slip_get_cached_response_by_url')) {
        $cached = b2b_slip_get_cached_response_by_url($slip_url);
        if (is_array($cached)) {
            $http_code = intval($cached['http_code']);
            $raw_body  = (string) $cached['body'];
            $from_cache = true;
        }
    }
    if (!$from_cache) {
        $resp = wp_remote_post($api_url, [
            'headers' => ['Content-Type' => 'application/json', 'Authorization' => 'Bearer ' . $secret],
            'body'    => wp_json_encode(['url' => $slip_url]),
            'timeout' => 15,
        ]);
        if (is_wp_error($resp)) return new WP_Error('api_error', 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аё•аёҙаё”аё•а№Ҳаёӯ Slip2Go а№„аё”а№ү', ['status' => 502]);
        $http_code = wp_remote_retrieve_response_code($resp);
        $raw_body  = wp_remote_retrieve_body($resp);
        if (function_exists('b2b_slip_set_cached_response_by_url') && $http_code === 200) {
            b2b_slip_set_cached_response_by_url($slip_url, $http_code, $raw_body);
        }
    }

    $body     = json_decode($raw_body, true);
    $verified = ($http_code === 200 && is_array($body) && !empty($body['success']));
    if (!$verified) {
        return rest_ensure_response(['success' => false, 'verified' => false,
            'reason' => (is_array($body) ? ($body['message'] ?? '') : '') ?: 'Slip2Go аёӣаёҸаёҙа№ҖаёӘаёҳаёҒаёІаёЈаё•аёЈаё§аёҲаёӘаёӯаёҡ']);
    }

    $slip_amount  = floatval($body['amount'] ?? 0);
    $slip_amount0 = $slip_amount; // preserve original for response
    $slip_ref     = sanitize_text_field($body['ref'] ?? '');
    $slip_date    = sanitize_text_field($body['date'] ?? b2b_date('Y-m-d H:i:s'));
    if ($slip_amount <= 0) return new WP_Error('invalid', 'аёўаёӯаё”аёӘаёҘаёҙаёӣа№Җаёӣа№Үаёҷ 0', ['status' => 400]);

    // C4: trans_ref dedup gate before any mutation
    if ($slip_ref !== '' && function_exists('b2b_slip_is_trans_ref_seen') && b2b_slip_is_trans_ref_seen($slip_ref)) {
        return new WP_Error('duplicate_slip', 'аёӘаёҘаёҙаёӣаёҷаёөа№үа№Җаё„аёўа№ғаёҠа№үа№ҒаёҘа№үаё§ (TransRef: ' . $slip_ref . ')', ['status' => 409]);
    }

    // Get all pending invoices for this distributor
    $pending_data = $dist_id ? _dinoco_inv_get_pending_invoices($dist_id) : null;
    $pending = $pending_data ? $pending_data['invoices'] : [];

    // M2: validate every manual_ids belongs to $dist_id
    if (!empty($manual_ids) && is_array($manual_ids)) {
        $manual_ids = array_map('intval', $manual_ids);
        // First, verify each manual_id is owned by $dist_id at DB level (not just within $pending вҖ”
        // an admin who passes manual_ids for another distributor would silently get filtered out;
        // that's a bug surface for misconfigured UIs and a forensic audit gap).
        if ($dist_id > 0) {
            foreach ($manual_ids as $mid) {
                if ($mid <= 0) continue;
                $owner = intval(get_post_meta($mid, '_dist_post_id', true));
                if ($owner !== $dist_id) {
                    return new WP_Error('invoice_not_owned',
                        'аёһаёҡа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№үаё—аёөа№Ҳа№„аёЎа№Ҳа№„аё”а№үа№Җаёӣа№ҮаёҷаёӮаёӯаёҮаё•аёұаё§а№Ғаё—аёҷаёҷаёөа№ү: #' . $mid,
                        ['status' => 400]);
                }
            }
        }
        $pending = array_filter($pending, function($inv) use ($manual_ids) {
            return in_array($inv['post_id'], $manual_ids);
        });
        $pending = array_values($pending);
    }

    if (empty($pending)) {
        return rest_ensure_response(['success' => true, 'verified' => true, 'slip_amount' => $slip_amount0,
            'slip_ref' => $slip_ref, 'match_type' => 'no_pending', 'matched' => [], 'message' => 'а№„аёЎа№ҲаёЎаёөаёҡаёҙаёҘаё„а№үаёІаёҮаёҠаёіаёЈаё°']);
    }

    // в”Җв”Җ AUTO-MATCH LOGIC в”Җв”Җ
    $match_type = 'no_match';
    $matched    = [];
    $tolerance  = 0.02; // 2% tolerance (same as B2B)

    // Strategy 1: Exact match to single invoice (remaining amount)
    foreach ($pending as $inv) {
        if (abs($slip_amount - $inv['remaining']) <= $inv['remaining'] * $tolerance + 0.5) {
            $match_type = 'single';
            $matched = [$inv];
            break;
        }
    }

    // Strategy 2: Match to combined total of all pending
    if ($match_type === 'no_match') {
        $combined_total = array_sum(array_column($pending, 'remaining'));
        if (abs($slip_amount - $combined_total) <= $combined_total * $tolerance + 0.5) {
            $match_type = 'combined_all';
            $matched = $pending;
        }
    }

    // Strategy 3: Find subset of invoices that sums to slip amount (greedy: oldest first)
    if ($match_type === 'no_match') {
        $running = 0;
        $subset  = [];
        foreach ($pending as $inv) {
            $running += $inv['remaining'];
            $subset[] = $inv;
            if (abs($running - $slip_amount) <= $running * $tolerance + 0.5) {
                $match_type = 'combined_subset';
                $matched = $subset;
                break;
            }
            if ($running > $slip_amount) break;
        }
    }

    // в”Җв”Җ Apply payment via shared helper (H6 convergence) в”Җв”Җ
    $paid_invoices = [];
    if (!empty($matched)) {
        $apply_result = function_exists('b2b_slip_apply_to_invoices') ? b2b_slip_apply_to_invoices(
            [
                'amount'      => $slip_amount0,
                'trans_ref'   => $slip_ref,
                'slip_date'   => b2b_date('Y-m-d H:i:s'),
                'note_prefix' => 'Slip2Go ref=' . $slip_ref . ' аё§аёұаёҷаё—аёөа№Ҳ=' . $slip_date . ' combined=' . count($matched) . ' а№ғаёҡ ',
            ],
            $matched,
            [
                'source'  => 'manual_invoice',
                'dist_id' => $dist_id,
            ]
        ) : null;

        if (!is_array($apply_result) || empty($apply_result['success'])) {
            $err = is_array($apply_result) ? ($apply_result['error_msg'] ?? '') : '';
            $err_code = is_array($apply_result) ? ($apply_result['error_code'] ?? '') : 'helper_missing';
            if ($err_code === 'duplicate_slip') {
                return new WP_Error('duplicate_slip', $err ?: ('аёӘаёҘаёҙаёӣаёҷаёөа№үа№Җаё„аёўа№ғаёҠа№үа№ҒаёҘа№үаё§ ref=' . $slip_ref), ['status' => 409]);
            }
            // Helper missing path = fail loud (Wave 1+2 contract: no silent fallback for atomic ops)
            b2b_log('[CRITICAL] Manual Invoice V.34.1 verify_slip_combined: b2b_slip_apply_to_invoices ' . ($apply_result === null ? 'missing' : 'failed') . ' ref=' . $slip_ref . ' err=' . $err);
            return new WP_Error($err_code ?: 'apply_failed', $err ?: 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёҡаёұаёҷаё—аё¶аёҒаёҠаёіаёЈаё°аёӘаёҘаёҙаёӣа№„аё”а№ү', ['status' => 500]);
        }

        // Build paid_invoices from helper return
        foreach ($apply_result['paid_invoices'] as $pi) {
            $paid_invoices[] = [
                'inv_number' => $pi['inv_number'],
                'amount'     => $pi['amount'],
                'post_id'    => $pi['post_id'],
            ];
        }
        // Recalculate debt for distributor (caller responsibility per helper contract)
        if (function_exists('b2b_recalculate_debt') && $dist_id) {
            b2b_recalculate_debt($dist_id);
        }
    }

    // Build response (use $slip_amount0 = original вҖ” $slip_amount no longer mutated post-helper)
    $result = [
        'success'     => true,
        'verified'    => true,
        'slip_amount' => $slip_amount0,
        'slip_ref'    => $slip_ref,
        'match_type'  => $match_type,
        'matched'     => $paid_invoices,
        'message'     => '',
        'from_cache'  => $from_cache,
    ];

    switch ($match_type) {
        case 'single':
            $result['message'] = 'аёӘаёҘаёҙаёӣаё•аёЈаёҮаёҒаёұаёҡ ' . $paid_invoices[0]['inv_number'] . ' вҖ” аёҡаёұаёҷаё—аё¶аёҒаёҠаёіаёЈаё°а№ҒаёҘа№үаё§';
            break;
        case 'combined_all':
            $result['message'] = 'аёӘаёҘаёҙаёӣаё•аёЈаёҮаёҒаёұаёҡаёўаёӯаё”аёЈаё§аёЎ ' . count($paid_invoices) . ' аёҡаёҙаёҘ вҖ” аёҡаёұаёҷаё—аё¶аёҒаёҠаёіаёЈаё°аё—аёұа№үаёҮаё«аёЎаё”а№ҒаёҘа№үаё§';
            break;
        case 'combined_subset':
            $result['message'] = 'аёӘаёҘаёҙаёӣаё•аёЈаёҮаёҒаёұаёҡ ' . count($paid_invoices) . ' аёҡаёҙаёҘ (аёҡаёІаёҮаёӘа№Ҳаё§аёҷ) вҖ” аёҡаёұаёҷаё—аё¶аёҒаёҠаёіаёЈаё°а№ҒаёҘа№үаё§';
            break;
        default:
            $result['message'] = 'аёўаёӯаё”аёӘаёҘаёҙаёӣ аёҝ' . number_format($slip_amount0, 0) .
                ' а№„аёЎа№Ҳаё•аёЈаёҮаёҒаёұаёҡаёҡаёҙаёҘа№ғаё”а№Ҷ вҖ” аёҒаёЈаёёаё“аёІа№ҖаёҘаё·аёӯаёҒаёҡаёҙаёҘаё—аёөа№Ҳаё•а№үаёӯаёҮаёҒаёІаёЈаё•аёұаё”аёўаёӯаё”аё”а№үаёІаёҷаёҘа№ҲаёІаёҮ';
            // Return pending invoices for admin to manually allocate
            $result['pending'] = array_map(function($inv) {
                return ['post_id' => $inv['post_id'], 'inv_number' => $inv['inv_number'],
                    'remaining' => $inv['remaining'], 'due_date' => $inv['due_date']];
            }, $pending);
            break;
    }

    b2b_add_audit_log(0, 'combined_slip_verify',
        'аё•аёЈаё§аёҲаёӘаёҘаёҙаёӣаёЈаё§аёЎ аёҝ' . number_format($slip_amount0, 0) . ' ref=' . $slip_ref .
        ' match=' . $match_type . ' (' . count($paid_invoices) . ' а№ғаёҡ) dist=' . ($pending_data['dist_name'] ?? '')
        . ($from_cache ? ' (cached)' : ''));

    return rest_ensure_response($result);
}

// --- UPLOAD SLIP (V.2.7) вҖ” base64 image from dashboard ---
function dinoco_inv_rest_upload_slip(WP_REST_Request $req) {
    $id    = intval($req->get_param('id'));
    $image = $req->get_param('image'); // base64 data URI: data:image/...;base64,...
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    if (empty($image)) return new WP_Error('invalid', 'аёҒаёЈаёёаё“аёІаёӯаёұаёһа№Ӯаё«аёҘаё”аёЈаё№аёӣаёӘаёҘаёҙаёӣ', ['status' => 400]);

    $inv_status = get_field('order_status', $id);
    if ($inv_status === 'paid') return new WP_Error('already_paid', 'а№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№үаёҷаёөа№үаёҠаёіаёЈаё°аё„аёЈаёҡа№ҒаёҘа№үаё§', ['status' => 400]);
    if ($inv_status !== 'awaiting_payment') return new WP_Error('invalid_status', 'аё•аёЈаё§аёҲаёӘаёҘаёҙаёӣа№„аё”а№үа№ҖаёүаёһаёІаё°аёӘаё–аёІаёҷаё°аёЈаёӯаёҠаёіаёЈаё°а№ҖаёҮаёҙаёҷа№Җаё—а№ҲаёІаёҷаёұа№үаёҷ', ['status' => 400]);

    // Validate base64 data URI format
    if (!preg_match('/^data:image\/(jpeg|png|webp|jpg);base64,/', $image)) {
        return new WP_Error('invalid', 'аёЈаё№аёӣаё аёІаёһа№„аёЎа№Ҳаё–аё№аёҒаё•а№үаёӯаёҮ (аёЈаёӯаёҮаёЈаёұаёҡ JPEG, PNG, WebP)', ['status' => 400]);
    }

    $api_url = defined('B2B_SLIP2GO_API_URL')
        ? B2B_SLIP2GO_API_URL
        : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';
    $secret  = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';
    if (!$secret) return new WP_Error('config', 'аёўаёұаёҮа№„аёЎа№Ҳа№„аё”а№үаё•аёұа№үаёҮаё„а№ҲаёІ Slip2Go API', ['status' => 500]);

    // Build request body (same format as B2B Snippet 2)
    $check_condition = ['checkDuplicate' => true];
    $bank_info = function_exists('b2b_get_bank_info') ? b2b_get_bank_info() : null;
    if ($bank_info && !empty($bank_info['account'])) {
        $account_number = preg_replace('/[^0-9]/', '', $bank_info['account']);
        $receiver = ['accountNumber' => $account_number];
        if (!empty($bank_info['bank_code'])) {
            $receiver['accountType'] = '01' . str_pad($bank_info['bank_code'], 3, '0', STR_PAD_LEFT);
        }
        $check_condition['checkReceiver'] = [$receiver];
    }

    $resp = wp_remote_post($api_url, [
        'headers' => [
            'Authorization' => 'Bearer ' . $secret,
            'Content-Type'  => 'application/json',
        ],
        'body' => wp_json_encode([
            'payload' => [
                'imageBase64'    => $image,
                'checkCondition' => $check_condition,
            ],
        ]),
        'timeout' => 45,
    ]);
    if (is_wp_error($resp)) return new WP_Error('api_error', 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аё•аёҙаё”аё•а№Ҳаёӯ Slip2Go а№„аё”а№ү', ['status' => 502]);

    $http_code = wp_remote_retrieve_response_code($resp);
    $raw_body  = wp_remote_retrieve_body($resp);
    $slip      = json_decode($raw_body, true);

    if ($http_code !== 200 || !is_array($slip)) {
        return rest_ensure_response(['success' => false, 'verified' => false, 'reason' => 'Slip2Go а№„аёЎа№Ҳаё•аёӯаёҡаёҒаёҘаёұаёҡ (HTTP ' . $http_code . ')']);
    }

    $slip_code = isset($slip['code']) ? $slip['code'] : '';
    $data      = isset($slip['data']) && is_array($slip['data']) ? $slip['data'] : [];
    $amount    = floatval($data['amount'] ?? 0);
    $sender    = sanitize_text_field($data['sender']['account']['name'] ?? '');
    $receiver  = sanitize_text_field($data['receiver']['account']['name'] ?? '');
    $trans_ref = sanitize_text_field($data['transRef'] ?? '');
    $trans_date = sanitize_text_field($data['transDate'] ?? $data['date'] ?? '');

    // Duplicate slip
    if ($slip_code === '200501') {
        return rest_ensure_response([
            'success' => false, 'verified' => false,
            'reason'  => 'аёӘаёҘаёҙаёӣаёҷаёөа№үа№Җаё„аёўа№ғаёҠа№үа№ҒаёҘа№үаё§ (TransRef: ' . $trans_ref . ')',
            'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
        ]);
    }

    // Wrong receiver
    if ($slip_code === '200401') {
        return rest_ensure_response([
            'success' => false, 'verified' => false,
            'reason'  => 'аёӘаёҘаёҙаёӣа№Ӯаёӯаёҷа№„аёӣаёҡаёұаёҚаёҠаёөаёӯаё·а№Ҳаёҷ (аёңаё№а№үаёЈаёұаёҡ: ' . $receiver . ')',
            'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
        ]);
    }

    // Slip not found / fake
    if ($slip_code === '200404') {
        return rest_ensure_response([
            'success' => false, 'verified' => false,
            'reason'  => 'а№„аёЎа№ҲаёһаёҡаёӮа№үаёӯаёЎаё№аёҘаёӘаёҘаёҙаёӣа№ғаёҷаёЈаё°аёҡаёҡаёҳаёҷаёІаё„аёІаёЈ (аёӯаёІаёҲа№Җаёӣа№ҮаёҷаёӘаёҘаёҙаёӣаёӣаёҘаёӯаёЎ)',
        ]);
    }

    // Success codes
    if ($slip_code === '200000' || $slip_code === '200200') {
        if (empty($data) || $amount <= 0) {
            return rest_ensure_response(['success' => false, 'verified' => false, 'reason' => 'аёЈаё°аёҡаёҡаё•аёЈаё§аёҲаёӘаёҘаёҙаёӣа№„аёЎа№Ҳаёһаёҡаёўаёӯаё”а№ҖаёҮаёҙаёҷ']);
        }

        // Check conditionResult for duplicate/receiver
        $cond = isset($slip['conditionResult']) ? $slip['conditionResult'] : null;
        if ($cond && isset($cond['isDuplicate']) && $cond['isDuplicate'] === true) {
            return rest_ensure_response([
                'success' => false, 'verified' => false,
                'reason'  => 'аёӘаёҘаёҙаёӣаёҷаёөа№үа№Җаё„аёўа№ғаёҠа№үа№ҒаёҘа№үаё§ (TransRef: ' . $trans_ref . ')',
                'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
            ]);
        }
        if ($cond && isset($cond['isReceiverValid']) && !$cond['isReceiverValid']) {
            return rest_ensure_response([
                'success' => false, 'verified' => false,
                'reason'  => 'аёӘаёҘаёҙаёӣа№Ӯаёӯаёҷа№„аёӣаёҡаёұаёҚаёҠаёөаёӯаё·а№Ҳаёҷ (аёңаё№а№үаёЈаёұаёҡ: ' . $receiver . ')',
                'amount'  => $amount, 'sender' => $sender, 'receiver' => $receiver, 'ref' => $trans_ref,
            ]);
        }

        // Verified вҖ” save metadata
        update_post_meta($id, '_inv_slip_ref', $trans_ref);
        update_post_meta($id, '_inv_slip_verified_at', b2b_date('Y-m-d H:i:s'));
        b2b_add_audit_log($id, 'slip_uploaded', 'аёӯаёұаёһа№Ӯаё«аёҘаё”аёӘаёҘаёҙаёӣаёңа№ҲаёІаёҷ аёҝ' . number_format($amount, 0) . ' ref=' . $trans_ref . ' аёңаё№а№үа№Ӯаёӯаёҷ=' . $sender);

        // Auto record payment
        $fake_req = new WP_REST_Request();
        $fake_req->set_param('id', $id);
        $fake_req->set_param('amount', $amount);
        $fake_req->set_param('note', 'аёӯаёұаёһа№Ӯаё«аёҘаё”аёӘаёҘаёҙаёӣ ref=' . $trans_ref . ' аёңаё№а№үа№Ӯаёӯаёҷ=' . $sender . ' аё§аёұаёҷаё—аёөа№Ҳ=' . $trans_date);
        $pay_result = dinoco_inv_rest_record_payment($fake_req);
        $pay_data = $pay_result->get_data();
        $fully_paid = !empty($pay_data['fully_paid']);

        // аёӘа№ҲаёҮ LINE Flex а№ҒаёҲа№үаёҮаё•аёұаё§а№Ғаё—аёҷ (Invoice system custom вҖ” а№„аёЎа№Ҳа№ҖаёҒаёөа№Ҳаёўаё§аёҒаёұаёҡ B2B Snippet)
        $gid = get_field('source_group_id', $id);
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        $dist_name = get_field('dist_name', $id);
        // FIX: recalculate debt from order statuses to avoid stale ACF cache
        $new_debt = function_exists('b2b_recalculate_debt') ? b2b_recalculate_debt($dist_id) : floatval(get_field('current_debt', $dist_id));
        $old_debt = $new_debt + $amount; // reconstruct pre-payment debt
        $credit_limit = floatval(get_field('credit_limit', $dist_id));
        // аёҷаёұаёҡаёҡаёҙаёҘаё„а№үаёІаёҮаёҠаёіаёЈаё°аё—аёөа№Ҳа№Җаё«аёҘаё·аёӯ
        $pending_count = 0;
        $pending_q = get_posts(['post_type'=>'b2b_order','posts_per_page'=>-1,'meta_query'=>[
            ['key'=>'_order_source','value'=>'manual_invoice'],
            ['key'=>'_dist_post_id','value'=>$dist_id],
        ]]);
        foreach ($pending_q as $pq) { if (get_field('order_status', $pq->ID) === 'awaiting_payment') $pending_count++; }

        if ($gid && function_exists('b2b_line_push_raw')) {
            $inv_no = get_post_meta($id, '_inv_number', true) ?: '#'.$id;
            $credit_remain = max(0, $credit_limit - $new_debt);
            $body = [
                ['type'=>'text','text'=>'вң… аёЈаёұаёҡаёҠаёіаёЈаё°а№ҖаёҮаёҙаёҷа№ҒаёҘа№үаё§','weight'=>'bold','size'=>'lg','color'=>'#16a34a'],
                ['type'=>'text','text'=>$dist_name,'size'=>'xs','color'=>'#64748b','margin'=>'xs'],
                ['type'=>'separator','margin'=>'md'],
                ['type'=>'box','layout'=>'vertical','margin'=>'md','spacing'=>'sm','contents'=>[
                    ['type'=>'box','layout'=>'horizontal','contents'=>[
                        ['type'=>'text','text'=>'а№ҖаёҘаёӮаё—аёөа№ҲаёҡаёҙаёҘ','size'=>'xs','color'=>'#64748b','flex'=>3],
                        ['type'=>'text','text'=>$inv_no,'size'=>'sm','weight'=>'bold','flex'=>5,'align'=>'end']]],
                    ['type'=>'box','layout'=>'horizontal','contents'=>[
                        ['type'=>'text','text'=>'аёўаёӯаё”а№Ӯаёӯаёҷ','size'=>'xs','color'=>'#64748b','flex'=>3],
                        ['type'=>'text','text'=>'аёҝ'.number_format($amount,2),'size'=>'lg','weight'=>'bold','color'=>'#16a34a','flex'=>5,'align'=>'end']]],
                    ['type'=>'box','layout'=>'horizontal','contents'=>[
                        ['type'=>'text','text'=>'аёңаё№а№үа№Ӯаёӯаёҷ','size'=>'xs','color'=>'#64748b','flex'=>3],
                        ['type'=>'text','text'=>$sender ?: '-','size'=>'sm','flex'=>5,'align'=>'end','wrap'=>true]]],
                ]],
            ];
            if ($trans_ref) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>[
                ['type'=>'text','text'=>'Ref','size'=>'xxs','color'=>'#94a3b8','flex'=>3],
                ['type'=>'text','text'=>$trans_ref,'size'=>'xxs','color'=>'#94a3b8','flex'=>5,'align'=>'end']]];
            $body[] = ['type'=>'separator','margin'=>'lg'];
            $body[] = ['type'=>'text','text'=>'рҹ’° аёӘаёЈаёёаёӣаёҡаёұаёҚаёҠаёө','size'=>'xs','weight'=>'bold','color'=>'#1e293b','margin'=>'lg'];
            $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>[
                ['type'=>'text','text'=>'аё«аёҷаёөа№үаёҒа№Ҳаёӯаёҷа№Ӯаёӯаёҷ','size'=>'xs','color'=>'#64748b','flex'=>5],
                ['type'=>'text','text'=>'аёҝ'.number_format($old_debt,2),'size'=>'xs','color'=>'#64748b','flex'=>5,'align'=>'end','decoration'=>'line-through']]];
            $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>[
                ['type'=>'text','text'=>'аё«аёҷаёөа№үаё„аёҮа№Җаё«аёҘаё·аёӯ','size'=>'sm','weight'=>'bold','flex'=>5],
                ['type'=>'text','text'=>'аёҝ'.number_format($new_debt,2),'size'=>'md','weight'=>'bold','color'=>($new_debt>0?'#dc2626':'#16a34a'),'flex'=>5,'align'=>'end']]];
            if ($credit_limit > 0) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>[
                ['type'=>'text','text'=>'аё§аёҮа№ҖаёҮаёҙаёҷа№Җаё«аёҘаё·аёӯ','size'=>'xs','color'=>'#64748b','flex'=>5],
                ['type'=>'text','text'=>'аёҝ'.number_format($credit_remain,0),'size'=>'xs','color'=>'#2563eb','flex'=>5,'align'=>'end']]];
            if ($pending_count > 0) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'sm','paddingAll'=>'6px','cornerRadius'=>'6px','backgroundColor'=>'#fef3c7','contents'=>[
                ['type'=>'text','text'=>'вҸі аёҡаёҙаёҘаё„а№үаёІаёҮаёҠаёіаёЈаё°аёӯаёөаёҒ '.$pending_count.' аёЈаёІаёўаёҒаёІаёЈ','size'=>'xxs','color'=>'#92400e','wrap'=>true]]];
            if ($new_debt <= 0) $body[] = ['type'=>'box','layout'=>'horizontal','margin'=>'sm','paddingAll'=>'8px','cornerRadius'=>'8px','backgroundColor'=>'#dcfce7','contents'=>[
                ['type'=>'text','text'=>'рҹҺү аёҠаёіаёЈаё°аё„аёЈаёҡа№ҒаёҘа№үаё§! а№„аёЎа№ҲаёЎаёөаёўаёӯаё”аё„а№үаёІаёҮ','size'=>'xs','weight'=>'bold','color'=>'#16a34a','align'=>'center']]];

            $flex = ['type'=>'flex','altText'=>mb_substr('вң… аёЈаёұаёҡаёҠаёіаёЈаё° '.$inv_no.' аёҝ'.number_format($amount,0),0,400),
                'contents'=>['type'=>'bubble','size'=>'kilo',
                    'body'=>['type'=>'box','layout'=>'vertical','contents'=>$body]]];
            b2b_line_push_raw($gid, [$flex]);
        }

        return rest_ensure_response([
            'success'    => true,
            'verified'   => true,
            'amount'     => $amount,
            'sender'     => $sender,
            'receiver'   => $receiver,
            'ref'        => $trans_ref,
            'date'       => $trans_date,
            'fully_paid' => $fully_paid,
        ]);
    }

    // Other error codes
    return rest_ensure_response([
        'success' => false, 'verified' => false,
        'reason'  => 'Slip2Go аёЈаё«аёұаёӘ ' . $slip_code . ': ' . ($slip['message'] ?? 'а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аё•аёЈаё§аёҲаёӘаёӯаёҡа№„аё”а№ү'),
        'amount'  => $amount, 'sender' => $sender, 'ref' => $trans_ref,
    ]);
}

// --- CANCEL ---
// V.34.11 Round 43: Idempotency-Key support вҖ” admin "аёўаёҒа№ҖаёҘаёҙаёҒ" double-click on slow LINE
// push вҶ’ 2Г— cancel Flex card to distributor LINE group + 2Г— FSM transition (2nd вҶ’ 400
// "аёўаёҒа№ҖаёҘаёҙаёҒа№ҒаёҘа№үаё§") + 2Г— dinoco_inv_reverse_debt вҶ’ debt double-reverted (rare but BO race
// possible). Body hash = {id, force, force_reason} вҖ” force boolean discriminator + force
// reason text catches admin re-issuing with different excuse mid-retry. Replay returns
// cached success on retry; different force_reason mid-retry вҶ’ 409 prevents accidental
// override of existing audit log entry.
function dinoco_inv_rest_cancel(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    $force = (bool) $req->get_param('force'); // V.33.3 вҖ” allow override after refund recorded
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);

    $idem_key       = function_exists('dinoco_idempotency_extract_key') ? dinoco_idempotency_extract_key($req) : '';
    $idem_namespace = 'b2b/v1::invoice/cancel';
    $idem_body      = null;
    if ($idem_key !== '' && function_exists('dinoco_idempotency_check')) {
        $idem_body = array(
            'id'           => (int) $id,
            'force'        => $force ? 1 : 0,  // boolean discriminator (force=1 has different audit path)
            'force_reason' => sanitize_text_field($req->get_param('force_reason') ?? ''),
        );
        $cached = dinoco_idempotency_check($idem_key, $idem_namespace, $idem_body);
        if (is_wp_error($cached)) {
            $err_data    = $cached->get_error_data();
            $status_code = (is_array($err_data) && isset($err_data['status'])) ? (int) $err_data['status'] : 409;
            return new WP_Error('idempotency_conflict',
                'Idempotency-Key аёӢа№үаёіаёҒаёұаёҡ request а№ҖаёҒа№ҲаёІаё—аёөа№ҲаёЎаёөаёӮа№үаёӯаёЎаё№аёҘаё•а№ҲаёІаёҮаёҒаёұаёҷ',
                array('status' => $status_code));
        }
        if (is_array($cached)) {
            $resp = $cached;
            unset($resp['_idem_code']);
            return rest_ensure_response($resp);
        }
    }

    $status = get_field('order_status', $id);
    if ($status === 'cancelled') return new WP_Error('invalid', 'аёўаёҒа№ҖаёҘаёҙаёҒа№ҒаёҘа№үаё§', ['status' => 400]);
    if ($status === 'paid') return new WP_Error('invalid', 'аёҠаёіаёЈаё°а№ҒаёҘа№үаё§ а№„аёЎа№ҲаёӘаёІаёЎаёІаёЈаё–аёўаёҒа№ҖаёҘаёҙаёҒа№„аё”а№ү', ['status' => 400]);

    // V.33.3 вҖ” Audit I7: block cancel аё–а№үаёІаёЎаёө payment аё„а№үаёІаёҮаё—аёөа№ҲаёўаёұаёҮа№„аёЎа№Ҳаё–аё№аёҒ refund
    $paid_so_far = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $refunded    = floatval(get_post_meta($id, '_inv_refunded_amount', true));
    $net_paid    = round($paid_so_far - $refunded, 2);
    $force_reason = sanitize_text_field($req->get_param('force_reason') ?? '');
    if ($net_paid > 0.01 && ! $force) {
        return new WP_Error(
            'has_payments',
            sprintf('а№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№үаёҷаёөа№үаёЎаёөаёҒаёІаёЈаёҠаёіаёЈаё°а№ҒаёҘа№үаё§ аёҝ%s вҖ” аё•а№үаёӯаёҮаёҡаёұаёҷаё—аё¶аёҒаё„аё·аёҷа№ҖаёҮаёҙаёҷ (refund) аёҒа№ҲаёӯаёҷаёҲаё¶аёҮаёҲаё°аёўаёҒа№ҖаёҘаёҙаёҒа№„аё”а№ү', number_format($net_paid, 2)),
            ['status' => 400, 'net_paid' => $net_paid]
        );
    }
    // V.33.4 вҖ” Audit H3: force-cancel аё•а№үаёӯаёҮаёЎаёөа№Җаё«аё•аёёаёңаёҘ + аёҡаёұаёҷаё—аё¶аёҒ audit а№ҒаёўаёҒаёҠаёұаё”
    if ($force && $net_paid > 0.01 && empty($force_reason)) {
        return new WP_Error('missing_reason', 'force=1 аё•а№үаёӯаёҮаёЈаё°аёҡаёёа№Җаё«аё•аёёаёңаёҘ (force_reason)', ['status' => 400]);
    }
    // Collect info before changing status (used for LINE notification below)
    $inv_no    = get_post_meta($id, '_inv_number', true);
    $dist_name = get_field('dist_name', $id);
    $total     = floatval(get_field('total_amount', $id));
    $dist_id   = intval(get_post_meta($id, '_dist_post_id', true));
    $line_gid  = $dist_id ? get_field('line_group_id', $dist_id) : '';

    dinoco_inv_reverse_debt($id);
    b2b_set_order_status($id, 'cancelled');
    if ($force && $net_paid > 0.01) {
        b2b_add_audit_log(
            $id,
            'force_cancelled',
            sprintf(
                'вҡ пёҸ FORCE аёўаёҒа№ҖаёҘаёҙаёҒаё—аёұа№үаёҮаё—аёөа№ҲаёЎаёө net_paid аёҝ%s вҖ” а№Җаё«аё•аёёаёңаёҘ: %s вҖ” а№Ӯаё”аёў %s',
                number_format($net_paid, 2),
                $force_reason,
                wp_get_current_user()->user_login
            )
        );
    } else {
        b2b_add_audit_log($id, 'cancelled', 'аёўаёҒа№ҖаёҘаёҙаёҒа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү/аё§аёІаёҮаёҡаёҙаёҘ');
    }

    // Notify distributor LINE group that invoice has been cancelled
    if ($line_gid) {
        $cancel_flex = [['type' => 'flex',
            'altText' => 'вқҢ аёўаёҒа№ҖаёҘаёҙаёҒа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү ' . $inv_no,
            'contents' => [
                'type'   => 'bubble',
                'header' => _dinoco_inv_flex_header('вқҢ аёўаёҒа№ҖаёҘаёҙаёҒа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү/аё§аёІаёҮаёҡаёҙаёҘ'),
                'body'   => ['type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => [
                    ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                        ['type' => 'text', 'text' => 'а№ҖаёҘаёӮаё—аёөа№Ҳ',     'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                        ['type' => 'text', 'text' => $inv_no,      'size' => 'xs', 'weight' => 'bold',   'flex' => 4, 'align' => 'end', 'wrap' => true],
                    ]],
                    ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                        ['type' => 'text', 'text' => 'аё•аёұаё§а№Ғаё—аёҷ',     'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                        ['type' => 'text', 'text' => esc_html($dist_name), 'size' => 'xs', 'weight' => 'bold', 'flex' => 4, 'align' => 'end'],
                    ]],
                    ['type' => 'box', 'layout' => 'horizontal', 'contents' => [
                        ['type' => 'text', 'text' => 'аёЎаё№аёҘаё„а№ҲаёІ',     'size' => 'xs', 'color' => '#999999', 'flex' => 3],
                        ['type' => 'text', 'text' => 'аёҝ' . number_format($total, 0), 'size' => 'xs', 'flex' => 4, 'align' => 'end'],
                    ]],
                    ['type' => 'separator', 'margin' => 'md'],
                    ['type' => 'text', 'text' => "а№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү/аё§аёІаёҮаёҡаёҙаёҘаёүаёҡаёұаёҡаёҷаёөа№үаё–аё№аёҒаёўаёҒа№ҖаёҘаёҙаёҒа№ҒаёҘа№үаё§\nаё«аёІаёҒаёЎаёөаёӮа№үаёӯаёӘаёҮаёӘаёұаёўаёҒаёЈаёёаё“аёІаё•аёҙаё”аё•а№Ҳаёӯ DINOCO",
                     'size' => 'sm', 'color' => '#dc2626', 'wrap' => true, 'margin' => 'md'],
                ]],
            ],
        ]];
        b2b_line_push_raw($line_gid, $cancel_flex);
    }

    $resp = array('success' => true, 'status' => 'cancelled');
    if ($idem_key !== '' && $idem_body !== null && function_exists('dinoco_idempotency_store')) {
        dinoco_idempotency_store($idem_key, $idem_namespace, $idem_body,
            array_merge($resp, array('_idem_code' => 200)), 200);
    }
    return rest_ensure_response($resp);
}

// --- RESEND LINE FLEX CARD + IMAGE ---
function dinoco_inv_rest_resend_line(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'а№„аёЎа№Ҳаёһаёҡа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү', ['status' => 404]);
    $dist_id  = intval(get_post_meta($id, '_dist_post_id', true));
    $line_gid = $dist_id ? get_field('line_group_id', $dist_id) : '';
    if (!$line_gid) return new WP_Error('no_line', 'аё•аёұаё§а№Ғаё—аёҷа№„аёЎа№ҲаёЎаёө LINE Group ID', ['status' => 400]);
    $inv_data = [
        'inv_number'       => get_post_meta($id, '_inv_number', true),
        'dist_name'        => get_field('dist_name', $id),
        'total_amount'     => floatval(get_field('total_amount', $id)),
        'due_date'         => get_field('due_date', $id) ?: '',
        'issue_date'       => get_post_meta($id, '_inv_date', true) ?: get_the_date('Y-m-d', $id),
        'items_json'       => get_post_meta($id, '_inv_items', true) ?: '[]',
        'credit_term_days' => intval(get_field('credit_term_days', $dist_id)),
        'created_by'       => intval(get_post_meta($id, '_inv_created_by', true)),
    ];
    $flex = dinoco_inv_build_flex_card($inv_data, dinoco_inv_get_settings());
    $sent_result = b2b_line_push_raw($line_gid, $flex);
    $sent_code = is_array($sent_result) && isset($sent_result['code']) ? intval($sent_result['code']) : 0;
    $sent_ok = ($sent_code === 200);
    if (function_exists('b2b_log')) b2b_log('[InvNotify-resend] inv=' . $id . ' flex_push code=' . $sent_code . ' group=' . $line_gid);
    // V.34.8: send image regardless of Flex push status (image is independent вҖ” sometimes
    // Flex fails but image succeeds, or vice versa). Old behaviour gated image on $sent
    // truthy which incorrectly treated array(['code'=>0,'body'=>'']) from WP_Error path
    // as truthy "success" вҖ” fine, but masked Flex failures. Now log both outcomes.
    if (function_exists('b2b_send_invoice_image')) {
        $img_result = b2b_send_invoice_image($line_gid, $id);
        if (function_exists('b2b_log')) {
            $summary = $img_result === false ? 'FALSE (gen/push failed вҖ” see [InvImg]/[Font]/[GD] logs above)' : (is_array($img_result) ? 'OK pages=' . count($img_result) : var_export($img_result, true));
            b2b_log('[InvNotify-resend] inv=' . $id . ' image push result=' . $summary);
        }
    }
    b2b_add_audit_log($id, 'resend_line', 'аёӘа№ҲаёҮ LINE Flex Card аёӢа№үаёі а№Ӯаё”аёў ' . wp_get_current_user()->user_login);
    return rest_ensure_response(['success' => $sent_ok, 'message' => $sent_ok ? 'аёӘа№ҲаёҮ LINE аёӘаёіа№ҖаёЈа№ҮаёҲ' : 'аёӘа№ҲаёҮ LINE аёҘа№үаёЎа№Җаё«аёҘаё§ (HTTP ' . $sent_code . ')']);
}

// --- PENDING SUMMARY: Preview (GET) ---
function dinoco_inv_rest_pending_summary(WP_REST_Request $req) {
    $dist_id = intval($req->get_param('dist_id'));
    if ($dist_id <= 0) return new WP_Error('missing', 'аёҒаёЈаёёаё“аёІаёЈаё°аёҡаёёаёЈаё«аёұаёӘаё•аёұаё§а№Ғаё—аёҷаёҲаёіаё«аёҷа№ҲаёІаёў', ['status' => 400]);
    $data = _dinoco_inv_get_pending_invoices($dist_id);
    if ($data === null) return new WP_Error('invalid', 'а№„аёЎа№Ҳаёһаёҡаё•аёұаё§а№Ғаё—аёҷаёҲаёіаё«аёҷа№ҲаёІаёў', ['status' => 404]);
    $line_group = get_field('line_group_id', $dist_id);
    // V.32: include credit info for zero-debt preview
    $debt = function_exists('b2b_recalculate_debt') ? b2b_recalculate_debt($dist_id) : floatval(get_field('current_debt', $dist_id));
    $credit_limit = floatval(get_field('credit_limit', $dist_id));
    $credit_remain = $credit_limit > 0 ? max(0, $credit_limit - $debt) : 0;
    return rest_ensure_response([
        'success'        => true,
        'dist_id'        => $dist_id,
        'dist_name'      => $data['dist_name'],
        'has_line_group'  => !empty($line_group),
        'count'          => $data['count'],
        'total'          => $data['total'],
        'debt'           => $debt,
        'credit_limit'   => $credit_limit,
        'credit_remain'  => $credit_remain,
        'invoices'       => array_map(function($inv) {
            return [
                'inv_number'  => $inv['inv_number'],
                'amount'      => $inv['remaining'],
                'date'        => $inv['due_date'],
                'overdue_days' => $inv['overdue'] ? abs($inv['days_diff']) : -abs($inv['days_diff']),
            ];
        }, $data['invoices']),
    ]);
}

// --- SEND SUMMARY: Send Flex to LINE (POST) ---
function dinoco_inv_rest_send_summary(WP_REST_Request $req) {
    $dist_id = intval($req->get_param('dist_id'));
    if ($dist_id <= 0) return new WP_Error('missing', 'аёҒаёЈаёёаё“аёІаёЈаё°аёҡаёёаёЈаё«аёұаёӘаё•аёұаё§а№Ғаё—аёҷаёҲаёіаё«аёҷа№ҲаёІаёў', ['status' => 400]);

    // Rate limit: 60s per distributor
    $lock = 'inv_summary_lock_' . $dist_id;
    if (get_transient($lock)) return new WP_Error('rate_limited', 'аёҒаёЈаёёаё“аёІаёЈаёӯ 60 аё§аёҙаёҷаёІаё—аёөаёҒа№ҲаёӯаёҷаёӘа№ҲаёҮаёӯаёөаёҒаё„аёЈаёұа№үаёҮ', ['status' => 429]);

    $data = _dinoco_inv_get_pending_invoices($dist_id);
    if ($data === null) return new WP_Error('invalid', 'а№„аёЎа№Ҳаёһаёҡаё•аёұаё§а№Ғаё—аёҷаёҲаёіаё«аёҷа№ҲаёІаёў', ['status' => 404]);

    $line_group = get_field('line_group_id', $dist_id);
    if (!$line_group) return new WP_Error('no_line', 'аё•аёұаё§а№Ғаё—аёҷа№„аёЎа№ҲаёЎаёө LINE group', ['status' => 422]);

    $flex = dinoco_inv_build_flex_summary($data);
    if (empty($flex)) return new WP_Error('build_fail', 'Failed to build Flex card', ['status' => 500]);

    b2b_line_push_raw($line_group, $flex);
    set_transient($lock, 1, 60);

    $admin = wp_get_current_user()->user_login;
    if ($data['count'] > 0) {
        foreach ($data['invoices'] as $inv) {
            b2b_add_audit_log($inv['post_id'], 'summary_sent',
                'аёЈаё§аёЎа№ғаёҷаёӘаёЈаёёаёӣаёҡаёҙаёҘаё„а№үаёІаёҮ аёӘа№ҲаёҮа№Ӯаё”аёў ' . $admin . ' (' . $data['count'] . ' а№ғаёҡ аёҝ' . number_format($data['total'], 0) . ')');
        }
    }

    $msg = $data['count'] > 0
        ? 'аёӘа№ҲаёҮаёӘаёЈаёёаёӣ ' . $data['count'] . ' аёҡаёҙаёҘ аёҝ' . number_format($data['total'], 0) . ' а№ҒаёҘа№үаё§'
        : 'аёӘа№ҲаёҮаёӯаёұаёһа№Җаё”аё—аёўаёӯаё”аёҡаёұаёҚаёҠаёө (а№„аёЎа№ҲаёЎаёөаё„а№үаёІаёҮ) а№ҒаёҘа№үаё§';
    return rest_ensure_response([
        'success'   => true,
        'dist_name' => $data['dist_name'],
        'count'     => $data['count'],
        'total'     => $data['total'],
        'message'   => $msg,
    ]);
}

// --- DISTRIBUTOR DETAIL (V.32.0) ---
function dinoco_inv_rest_distributor_detail(WP_REST_Request $req) {
    $dist_id = intval($req->get_param('dist_id'));
    if (!$dist_id || get_post_type($dist_id) !== 'distributor') {
        return new WP_Error('invalid', 'Distributor not found', ['status' => 404]);
    }
    $page = max(1, intval($req->get_param('page') ?? 1));
    $per  = 20;

    // --- Profile ---
    $profile = [
        'id'               => $dist_id,
        'shop_name'        => get_field('shop_name', $dist_id) ?: get_the_title($dist_id),
        'shop_logo_url'    => get_field('shop_logo_url', $dist_id) ?: '',
        'dist_phone'       => get_field('dist_phone', $dist_id) ?: '',
        'dist_address'     => get_field('dist_address', $dist_id) ?: '',
        'dist_district'    => get_field('dist_district', $dist_id) ?: '',
        'dist_city'        => get_field('dist_city', $dist_id) ?: '',
        'dist_province'    => get_field('dist_province', $dist_id) ?: '',
        'dist_postcode'    => get_field('dist_postcode', $dist_id) ?: '',
        'rank_system'      => get_field('rank_system', $dist_id) ?: 'standard',
        'credit_limit'     => floatval(get_field('credit_limit', $dist_id)),
        'credit_term_days' => intval(get_field('credit_term_days', $dist_id) ?: 30),
        'current_debt'     => function_exists('b2b_recalculate_debt')
            ? floatval(b2b_recalculate_debt($dist_id))
            : floatval(get_field('current_debt', $dist_id)),
    ];

    // --- All non-draft/cancelled invoices for this distributor ---
    $all_ids = get_posts([
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => -1,
        'fields'         => 'ids',
        'meta_query'     => [
            ['key' => '_order_source', 'value' => 'manual_invoice'],
            ['key' => '_dist_post_id', 'value' => $dist_id, 'type' => 'NUMERIC'],
        ],
    ]);

    // Warm meta cache
    if (!empty($all_ids)) update_postmeta_cache($all_ids);

    $tz          = new DateTimeZone('Asia/Bangkok');
    $now         = new DateTime('now', $tz);
    $month_start = $now->format('Y-m-01');
    $year_start  = $now->format('Y-01-01');

    $sales_month = 0;
    $sales_year  = 0;
    $outstanding = 0;
    $product_map = []; // sku => [description, total_qty, total_value]
    $cutoff_12m  = (clone $now)->modify('-12 months')->format('Y-m-d');

    foreach ($all_ids as $pid) {
        $status = get_field('order_status', $pid);
        if (in_array($status, ['draft', 'cancelled'])) continue;

        $total    = floatval(get_field('total_amount', $pid));
        $inv_date = get_post_meta($pid, '_inv_date', true) ?: get_the_date('Y-m-d', $pid);

        // Sales aggregation
        if ($inv_date >= $year_start)  $sales_year  += $total;
        if ($inv_date >= $month_start) $sales_month += $total;

        // Outstanding (awaiting_payment / overdue)
        if (in_array($status, ['awaiting_payment'])) {
            $paid = floatval(get_post_meta($pid, '_inv_paid_amount', true));
            $outstanding += ($total - $paid);
        }

        // Product breakdown (last 12 months)
        if ($inv_date >= $cutoff_12m) {
            $items = json_decode(get_post_meta($pid, '_inv_items', true) ?: '[]', true);
            foreach ($items as $item) {
                $sku = $item['sku'] ?? 'N/A';
                if (!isset($product_map[$sku])) {
                    $product_map[$sku] = ['sku' => $sku, 'description' => $item['description'] ?? $sku, 'total_qty' => 0, 'total_value' => 0];
                }
                $product_map[$sku]['total_qty']   += intval($item['qty'] ?? 1);
                $product_map[$sku]['total_value']  += floatval($item['line_total'] ?? 0);
            }
        }
    }

    // Sort products by value DESC, top 10
    $products = array_values($product_map);
    usort($products, function($a, $b) { return $b['total_value'] <=> $a['total_value']; });
    $products = array_slice($products, 0, 10);

    // --- Paginated invoice history (all statuses) ---
    $inv_query = new WP_Query([
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => $per,
        'paged'          => $page,
        'orderby'        => 'date',
        'order'          => 'DESC',
        'meta_query'     => [
            ['key' => '_order_source', 'value' => 'manual_invoice'],
            ['key' => '_dist_post_id', 'value' => $dist_id, 'type' => 'NUMERIC'],
        ],
    ]);
    $invoices = [];
    foreach ($inv_query->posts as $p) {
        $invoices[] = _dinoco_inv_row($p->ID);
    }

    return rest_ensure_response([
        'success'           => true,
        'profile'           => $profile,
        'sales_this_month'  => round($sales_month, 2),
        'sales_this_year'   => round($sales_year, 2),
        'outstanding_debt'  => round($outstanding, 2),
        'product_breakdown' => $products,
        'invoices'          => $invoices,
        'invoice_count'     => $inv_query->found_posts,
        'invoice_pages'     => $inv_query->max_num_pages,
        'invoice_page'      => $page,
    ]);
}

// --- DELETE ---
function dinoco_inv_rest_delete(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $status = get_field('order_status', $id);
    if (!in_array($status, ['draft', 'cancelled'])) return new WP_Error('invalid', 'аёҘаёҡа№„аё”а№үа№ҖаёүаёһаёІаё° Draft аё«аёЈаё·аёӯ аёўаёҒа№ҖаёҘаёҙаёҒ', ['status' => 400]);
    // Remove the manual_invoice marker so post disappears from invoice list
    // but remains as a b2b_order (visible in B2B Orders tab)
    delete_post_meta($id, '_order_source');
    b2b_add_audit_log($id, 'invoice_removed', 'аёҘаёҡаёӯаёӯаёҒаёҲаёІаёҒаёЈаёІаёўаёҒаёІаёЈа№ғаёҡа№ҒаёҲа№үаёҮаё«аёҷаёөа№ү (b2b_order аёўаёұаёҮаё„аёҮаёӯаёўаё№а№Ҳ)');
    return rest_ensure_response(['success' => true]);
}


