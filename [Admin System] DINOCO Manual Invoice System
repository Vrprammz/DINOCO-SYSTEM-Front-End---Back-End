// Render (or update) tree-style child sub-rows below a SET product row
function _invRenderChildrenRow(parentTr, childSkus) {
    // Remove all existing child rows
    var sib = parentTr.nextElementSibling;
    while (sib && sib.classList.contains('inv-child-tr')) {
        var rem = sib; sib = sib.nextElementSibling; rem.parentNode.removeChild(rem);
    }
    if (!childSkus || !childSkus.length) return;
    var frag = document.createDocumentFragment();
    childSkus.forEach(function(sku) {
        var skuStr = (typeof sku === 'object' && sku.sku) ? sku.sku : sku;
        var cp = invProducts.find(function(p){ return p.product_sku === skuStr; });
        var imgEl = (cp && cp.img)
            ? '<img class="child-img" src="' + escH(cp.img) + '" loading="lazy" alt="">'
            : '<span class="child-img-ph"></span>';
        var name = cp ? escH(cp.title) : escH(skuStr);
        var tr = document.createElement('tr');
        tr.className = 'inv-child-tr';
        var qty = (typeof sku === 'object' && sku.qty) ? sku.qty : 1;
        tr.innerHTML =
            '<td class="child-img-cell">' + imgEl + '</td>' +
            '<td class="child-sku-cell"><span class="child-sku">' + escH(typeof sku === 'object' ? sku.sku : sku) + '</span></td>' +
            '<td><span class="child-name">' + name + '</span></td>' +
            '<td style="text-align:center;"><span style="font-size:0.8rem;color:#475569;font-weight:600;">×' + qty + '</span></td>' +
            '<td colspan="3"></td>' +
            '<td></td>';
        frag.appendChild(tr);
    });
    parentTr.parentNode.insertBefore(frag, parentTr.nextSibling);
}

