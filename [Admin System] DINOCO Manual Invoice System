function dinoco_inv_reverse_debt($post_id) {
    if (get_post_meta($post_id, '_order_source', true) !== 'manual_invoice') return;
    if (!get_field('is_billed', $post_id)) return;
    $dist_id = intval(get_post_meta($post_id, '_dist_post_id', true));
    if (!$dist_id || get_post_type($dist_id) !== 'distributor') return;
    $total = floatval(get_field('total_amount', $post_id));
    if ($total <= 0) return;
    if (function_exists('b2b_recalculate_debt')) {
        update_field('is_billed', false, $post_id);
        b2b_recalculate_debt($dist_id);
    } else {
        $debt = floatval(get_field('current_debt', $dist_id));
        update_field('current_debt', round(max(0, $debt - $total), 2), $dist_id);
        update_field('is_billed', false, $post_id);
    }
    b2b_add_audit_log($post_id, 'debt_reversed', 'ยกเลิกบิล ฿' . number_format($total, 0) . ' — หักหนี้ตัวแทนแล้ว');
}

