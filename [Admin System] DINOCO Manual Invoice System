// CRON: 3-day pre-payment reminder вҖ” V.31: group by distributor, send 1 combined Flex
add_action('b2b_dunning_cron_event', 'dinoco_inv_cron_reminder');
function dinoco_inv_cron_reminder() {
    $now       = time();
    $target_lo = $now + (2 * DAY_IN_SECONDS);
    $target_hi = $now + (4 * DAY_IN_SECONDS);
    $ids = _dinoco_inv_query_awaiting();

    // Group invoices by distributor
    $by_dist = array();
    foreach ($ids as $id) {
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') continue;
        $due = get_field('due_date', $id);
        if (!$due) continue;
        $due_ts = _dinoco_inv_parse_date($due);
        if (!$due_ts || $due_ts < $target_lo || $due_ts > $target_hi) continue;
        if (get_post_meta($id, '_dunning_reminder_3day_sent', true)) continue;
        // V.31: а№„аёЎа№Ҳаё—аё§аёҮаёҡаёҙаёҘаё—аёөа№Ҳа№Җаёһаёҙа№ҲаёҮ issue аё§аёұаёҷа№Җаё”аёөаёўаё§аёҒаёұаёҷ (аёҘаё№аёҒаё„а№үаёІаёўаёұаёҮа№„аёЎа№Ҳаё—аёұаёҷаёӯа№ҲаёІаёҷаёҡаёҙаёҘ)
        $issued_at = get_post_meta($id, '_inv_issued_at', true);
        if (!$issued_at) { $hist = get_post_meta($id, '_b2b_status_history', true); if (is_array($hist)) { foreach ($hist as $h) { if (isset($h['to']) && $h['to'] === 'awaiting_payment' && isset($h['at'])) { $issued_at = $h['at']; break; } } } }
        if ($issued_at && (time() - strtotime($issued_at)) < DAY_IN_SECONDS) continue;
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        if (!$dist_id) continue;
        $by_dist[$dist_id][] = $id;
    }

    // Send 1 combined Flex per distributor
    foreach ($by_dist as $dist_id => $order_ids) {
        $group_id = get_field('line_group_id', $dist_id);
        $dist_name = get_the_title($dist_id);
        $total_debt = floatval(get_field('current_debt', $dist_id));

        $invoices = array();
        foreach ($order_ids as $id) {
            $due = get_field('due_date', $id);
            $due_ts = _dinoco_inv_parse_date($due);
            $days_left = $due_ts ? max(0, (int)ceil(($due_ts - $now) / 86400)) : 0;
            $inv_total = floatval(get_field('total_amount', $id));
            $inv_paid  = floatval(get_post_meta($id, '_inv_paid_amount', true));
            $inv_remaining = max(0, $inv_total - $inv_paid);
            if ($inv_remaining <= 0) continue; // fully paid вҖ” skip
            $invoices[] = array(
                'inv_number'     => get_post_meta($id, '_inv_number', true) ?: '#'.$id,
                'total'          => $inv_total,
                'remaining'      => $inv_remaining,
                'due_date_str'   => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
                'days_until_due' => $days_left,
                'days_overdue'   => 0,
                // Legacy keys (kept for backward compat аё–а№үаёІаёЎаёө caller а№ҖаёҒа№ҲаёІ)
                'due_fmt'        => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
                'urgency'        => "аёӯаёөаёҒ {$days_left} аё§аёұаёҷ",
                'overdue'        => false,
            );
        }

        if ($group_id && !empty($invoices)) {
            // V.33.5: а№ғаёҠа№ү Flex summary builder а№Җаё”аёөаёўаё§аёҒаёұаёҷаё—аёёаёҒ case (single/multi)
            if (function_exists('b2b_build_flex_dunning_summary')) {
                $flex = b2b_build_flex_dunning_summary($dist_id, $invoices, array('show_credit_bar' => true));
                $msgs = $flex ? array($flex) : array();
            } else {
                // Fallback (Snippet 1 аёўаёұаёҮа№„аёЎа№Ҳ active) вҖ” а№ғаёҠа№ү builder а№ҖаёҒа№ҲаёІ
                if (count($invoices) === 1) {
                    $msgs = _dinoco_inv_build_dunning_message($invoices[0]['inv_number'], $invoices[0]['remaining'], get_field('due_date', $order_ids[0]), 0);
                } else {
                    $msgs = array(_dinoco_inv_build_dunning_combined($dist_name, $invoices, $total_debt));
                }
            }
            $pushed = $msgs ? b2b_line_push_raw($group_id, $msgs) : false;
            if ($pushed) {
                foreach ($order_ids as $id) {
                    update_post_meta($id, '_dunning_reminder_3day_sent', b2b_date('Y-m-d H:i:s'));
                }
            }
        }
        foreach ($order_ids as $id) {
            b2b_add_audit_log($id, 'dunning_reminder', 'аёӘа№ҲаёҮа№Җаё•аё·аёӯаёҷаёҘа№Ҳаё§аёҮаё«аёҷа№үаёІ (аёЈаё§аёЎ '.count($invoices).' аёҡаёҙаёҘ)');
        }
    }
}

// CRON: Overdue alerts (1+ day past due) вҖ” V.31: group by distributor
add_action('b2b_bo_overdue_check', 'dinoco_inv_cron_overdue');
function dinoco_inv_cron_overdue() {
    $now = time();
    $ids = _dinoco_inv_query_awaiting();

    // Group overdue invoices by distributor
    $by_dist = array();
    foreach ($ids as $id) {
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') continue;
        $due = get_field('due_date', $id);
        $due_ts = _dinoco_inv_parse_date($due);
        if (!$due_ts || $due_ts >= $now) continue;
        $days_overdue = (int)ceil(($now - $due_ts) / DAY_IN_SECONDS);
        $tier = $days_overdue >= 7 ? 'escalated' : 'day1';
        $sent_key = '_overdue_notice_sent_' . $tier;
        if (get_post_meta($id, $sent_key, true)) continue;
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        if (!$dist_id) continue;
        $by_dist[$dist_id][] = array('id' => $id, 'days_overdue' => $days_overdue, 'tier' => $tier, 'sent_key' => $sent_key);
    }

    // Send 1 combined Flex per distributor
    foreach ($by_dist as $dist_id => $items) {
        $group_id = get_field('line_group_id', $dist_id);
        $dist_name = get_the_title($dist_id);
        $total_debt = floatval(get_field('current_debt', $dist_id));
        $worst_overdue = max(array_column($items, 'days_overdue'));

        $invoices = array();
        foreach ($items as $item) {
            $id = $item['id'];
            $ov_total = floatval(get_field('total_amount', $id));
            $ov_paid  = floatval(get_post_meta($id, '_inv_paid_amount', true));
            $ov_remaining = max(0, $ov_total - $ov_paid);
            if ($ov_remaining <= 0) continue; // fully paid вҖ” skip
            $due       = get_field('due_date', $id);
            $due_ts    = _dinoco_inv_parse_date($due);
            $invoices[] = array(
                'inv_number'     => get_post_meta($id, '_inv_number', true) ?: '#'.$id,
                'total'          => $ov_total,
                'remaining'      => $ov_remaining,
                'due_date_str'   => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
                'days_until_due' => -intval($item['days_overdue']),
                'days_overdue'   => intval($item['days_overdue']),
                // Legacy keys (backward compat)
                'urgency'        => 'а№ҖаёҘаёў '.$item['days_overdue'].' аё§аёұаёҷ',
                'overdue'        => true,
            );
        }

        if ($group_id && !empty($invoices)) {
            // V.33.5: а№ғаёҠа№ү Flex summary builder вҖ” header аёӘаёөа№Ғаё”аёҮа№ҖаёӮа№үаёЎа№ҖаёӘаёЎаёӯ (overdue)
            if (function_exists('b2b_build_flex_dunning_summary')) {
                $flex = b2b_build_flex_dunning_summary($dist_id, $invoices, array(
                    'show_credit_bar' => true,
                    'accent_color'    => '#dc2626',
                    'header_text'     => 'рҹ”ҙ аёҡаёҙаёҘа№ҖаёҘаёўаёҒаёіаё«аёҷаё”аёҠаёіаёЈаё°',
                ));
                $msgs = $flex ? array($flex) : array();
            } else {
                // Fallback (Snippet 1 аёўаёұаёҮа№„аёЎа№Ҳ active)
                if (count($invoices) === 1) {
                    $due = get_field('due_date', $items[0]['id']);
                    $msgs = _dinoco_inv_build_dunning_message($invoices[0]['inv_number'], $invoices[0]['remaining'], $due, $items[0]['days_overdue']);
                } else {
                    $msgs = array(_dinoco_inv_build_dunning_combined($dist_name, $invoices, $total_debt));
                }
            }
            $pushed = $msgs ? b2b_line_push_raw($group_id, $msgs) : false;
            if ($pushed) {
                foreach ($items as $item) {
                    update_post_meta($item['id'], $item['sent_key'], b2b_date('Y-m-d H:i:s'));
                }
            }
        }
        foreach ($items as $item) {
            b2b_add_audit_log($item['id'], 'dunning_overdue', "а№ҒаёҲа№үаёҮа№Җаё•аё·аёӯаёҷаё„а№үаёІаёҮаёҠаёіаёЈаё° {$item['days_overdue']} аё§аёұаёҷ (аёЈаё§аёЎ ".count($invoices)." аёҡаёҙаёҘ)" . ($group_id ? '' : ' (а№„аёЎа№ҲаёЎаёө LINE group)'));
        }
    }
}

// REST: Manual send reminder вҖ” V.33.5: а№ғаёҠа№ү b2b_build_flex_dunning_summary
function dinoco_inv_rest_send_reminder(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $due     = get_field('due_date', $id);
    $total   = floatval(get_field('total_amount', $id));
    $paid    = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $remaining = max(0, $total - $paid);
    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $group   = get_field('line_group_id', $dist_id);
    if (!$group) return new WP_Error('no_line', 'аё•аёұаё§а№Ғаё—аёҷа№„аёЎа№ҲаёЎаёө LINE group', ['status' => 422]);
    $due_ts  = _dinoco_inv_parse_date($due);
    $days_left = $due_ts ? max(0, (int)ceil(($due_ts - time()) / 86400)) : 0;

    if (function_exists('b2b_build_flex_dunning_summary')) {
        $invoices = array(array(
            'inv_number'     => get_post_meta($id, '_inv_number', true) ?: '#'.$id,
            'total'          => $total,
            'remaining'      => $remaining,
            'due_date_str'   => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
            'days_until_due' => $days_left,
            'days_overdue'   => 0,
        ));
        $flex = b2b_build_flex_dunning_summary($dist_id, $invoices, array('show_credit_bar' => true));
        $msgs = $flex ? array($flex) : array();
    } else {
        $msgs = _dinoco_inv_build_dunning_message(get_post_meta($id, '_inv_number', true), $remaining, $due ?: '', 0);
    }
    if ($msgs) b2b_line_push_raw($group, $msgs);
    // Reset flags so cron can re-send later if still unpaid
    delete_post_meta($id, '_dunning_reminder_3day_sent');
    b2b_add_audit_log($id, 'dunning_manual', 'Admin аёӘа№ҲаёҮа№Җаё•аё·аёӯаёҷаёҠаёіаёЈаё°а№ҖаёҮаёҙаёҷаё”а№үаё§аёўаё•аёҷа№ҖаёӯаёҮ');
    return rest_ensure_response(['success' => true, 'message' => 'аёӘа№ҲаёҮа№Җаё•аё·аёӯаёҷаёңа№ҲаёІаёҷ LINE а№ҒаёҘа№үаё§']);
}

// REST: Manual send overdue notice вҖ” V.33.5: а№ғаёҠа№ү b2b_build_flex_dunning_summary
function dinoco_inv_rest_send_overdue_notice(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $due      = get_field('due_date', $id);
    $total    = floatval(get_field('total_amount', $id));
    $paid     = floatval(get_post_meta($id, '_inv_paid_amount', true));
    $remaining = max(0, $total - $paid);
    $dist_id  = intval(get_post_meta($id, '_dist_post_id', true));
    $group    = get_field('line_group_id', $dist_id);
    if (!$group) return new WP_Error('no_line', 'аё•аёұаё§а№Ғаё—аёҷа№„аёЎа№ҲаёЎаёө LINE group', ['status' => 422]);
    $due_ts   = _dinoco_inv_parse_date($due);
    $days_ov  = $due_ts ? max(1, (int)ceil((time() - $due_ts) / DAY_IN_SECONDS)) : 1;

    if (function_exists('b2b_build_flex_dunning_summary')) {
        $invoices = array(array(
            'inv_number'     => get_post_meta($id, '_inv_number', true) ?: '#'.$id,
            'total'          => $total,
            'remaining'      => $remaining,
            'due_date_str'   => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
            'days_until_due' => -$days_ov,
            'days_overdue'   => $days_ov,
        ));
        $flex = b2b_build_flex_dunning_summary($dist_id, $invoices, array(
            'show_credit_bar' => true,
            'accent_color'    => '#dc2626',
            'header_text'     => 'рҹ”ҙ аёҡаёҙаёҘа№ҖаёҘаёўаёҒаёіаё«аёҷаё”аёҠаёіаёЈаё°',
        ));
        $msgs = $flex ? array($flex) : array();
    } else {
        $msgs = _dinoco_inv_build_dunning_message(get_post_meta($id, '_inv_number', true), $remaining, $due ?: '', $days_ov);
    }
    if ($msgs) b2b_line_push_raw($group, $msgs);
    // Reset overdue flags so cron can re-escalate
    delete_post_meta($id, '_overdue_notice_sent_day1');
    delete_post_meta($id, '_overdue_notice_sent_escalated');
    b2b_add_audit_log($id, 'dunning_overdue_manual', "Admin аёӘа№ҲаёҮа№ҒаёҲа№үаёҮа№Җаё•аё·аёӯаёҷаё„а№үаёІаёҮаёҠаёіаёЈаё° {$days_ov} аё§аёұаёҷ аё”а№үаё§аёўаё•аёҷа№ҖаёӯаёҮ");
    return rest_ensure_response(['success' => true, 'message' => "аёӘа№ҲаёҮа№ҒаёҲа№үаёҮа№Җаё•аё·аёӯаёҷаё„а№үаёІаёҮаёҠаёіаёЈаё°аёңа№ҲаёІаёҷ LINE а№ҒаёҘа№үаё§"]);
}

// --- Helpers for REST ---
function _dinoco_inv_row($post_id) {
    $status   = get_field('order_status', $post_id);
    $due_date = get_field('due_date', $post_id); // ACF may return d/m/Y

    // Normalize due_date to timestamp safely (а№ғаёҠа№ү safe parser аёЈаёӯаёҮаёЈаёұаёҡаё—аёұа№үаёҮ d/m/Y а№ҒаёҘаё° Y-m-d)
    $due_ts = false;
    if (!empty($due_date) && $due_date !== '0000-00-00') {
        $due_ts = _dinoco_inv_parse_date($due_date);
        // Legacy fallback (keep for safety)
        if (!$due_ts || $due_ts < 86400) {
            $parts = explode('/', $due_date);
            if (count($parts) === 3) {
                $due_ts = mktime(0, 0, 0, intval($parts[1]), intval($parts[0]), intval($parts[2]));
            }
        }
        if ($due_ts < 86400) $due_ts = false; // reject epoch-zero result
    }

    // Virtual overdue flag: awaiting_payment + past due_date
    $is_overdue = ($status === 'awaiting_payment' && $due_ts && $due_ts < current_time('timestamp'));
    return [
        'id'           => $post_id,
        'inv_number'   => get_post_meta($post_id, '_inv_number', true),
        'dist_name'    => get_field('dist_name', $post_id),
        'dist_id'      => intval(get_post_meta($post_id, '_dist_post_id', true)),
        'status'       => $is_overdue ? 'overdue' : $status,
        'total_amount' => floatval(get_field('total_amount', $post_id)),
        'paid_amount'      => floatval(get_post_meta($post_id, '_inv_paid_amount', true)),
        'refunded_amount'  => floatval(get_post_meta($post_id, '_inv_refunded_amount', true)),
        'due_date'     => $due_ts ? b2b_date('Y-m-d', $due_ts) : '',   // always ISO for <input type="date">
        'issue_date'   => get_post_meta($post_id, '_inv_date', true) ?: get_the_date('Y-m-d', $post_id),
        'created_by'   => intval(get_post_meta($post_id, '_inv_created_by', true)),
        'is_billed'    => (bool) get_field('is_billed', $post_id),
        'is_overdue'   => $is_overdue,
    ];
}

function _dinoco_inv_check_owner($post_id) {
    if (get_post_type($post_id) !== 'b2b_order') return false;
    if (get_post_meta($post_id, '_order_source', true) !== 'manual_invoice') return false;
    return true;
}

// --- LIST ---
function dinoco_inv_rest_list(WP_REST_Request $req) {
    $status  = sanitize_text_field($req->get_param('status') ?? '');
    $dist_id = intval($req->get_param('dist_id') ?? 0);
    $search  = sanitize_text_field($req->get_param('search') ?? '');
    $page    = max(1, intval($req->get_param('page') ?? 1));
    $per     = 30;

    $meta_query = [['key' => '_order_source', 'value' => 'manual_invoice']];
    if ($dist_id > 0) $meta_query[] = ['key' => '_dist_post_id', 'value' => $dist_id];

    $args = [
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => $per,
        'paged'          => $page,
        'orderby'        => 'date',
        'order'          => 'DESC',
        'meta_query'     => $meta_query,
    ];

    if ($status && $status !== 'all') {
        add_filter('posts_where', function($where) use ($status) {
            global $wpdb;
            return $where . $wpdb->prepare(
                " AND ID IN (SELECT post_id FROM {$wpdb->postmeta} WHERE meta_key='order_status' AND meta_value=%s)",
                $status
            );
        });
    }

    if ($search) {
        $args['s'] = $search;
    }

    $query = new WP_Query($args);
    $rows  = [];
    $total_value = 0;
    foreach ($query->posts as $p) {
        $row = _dinoco_inv_row($p->ID);
        if ($status && $status !== 'all' && $row['status'] !== $status) continue;
        if ($search) {
            $hay = strtolower($row['inv_number'] . ' ' . $row['dist_name']);
            if (strpos($hay, strtolower($search)) === false) continue;
        }
        $rows[] = $row;
        $total_value += $row['total_amount'];
    }

    return rest_ensure_response([
        'success'     => true,
        'invoices'    => $rows,
        'total'       => $query->found_posts,
        'total_value' => $total_value,
        'pages'       => $query->max_num_pages,
        'page'        => $page,
    ]);
}

