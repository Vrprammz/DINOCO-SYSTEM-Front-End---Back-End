function dinoco_inv_generate_number($dist_name = '') {
    $year = b2b_date('Y');

    // Build distributor slug from name (keep A-Z 0-9 _ only, uppercase)
    $slug = strtoupper($dist_name);
    $slug = preg_replace('/[\s\-]+/', '_', $slug);      // spaces/hyphens → underscore
    $slug = preg_replace('/[^A-Z0-9_]/', '', $slug);    // strip Thai + special chars
    $slug = trim($slug, '_');
    $slug = preg_replace('/_+/', '_', $slug);            // collapse repeated underscores
    if (strlen($slug) < 2) $slug = 'DIST';              // fallback if all Thai / too short
    $slug = substr($slug, 0, 20);                        // max 20 chars

    // Generate non-sequential random suffix (7 digits, first digit non-zero)
    $max_attempts = 10;
    do {
        $suffix    = (string)mt_rand(1000000, 9999999);
        $candidate = 'INV_' . $slug . '_DNC_' . $year . '_' . $suffix;
        $collision = get_posts([
            'post_type'      => 'b2b_order',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'post_status'    => 'publish',
            'meta_query'     => [
                ['key' => '_order_source', 'value' => 'manual_invoice'],
                ['key' => '_inv_number',   'value' => $candidate],
            ],
        ]);
        $max_attempts--;
    } while (!empty($collision) && $max_attempts > 0);

    return $candidate;
}

function dinoco_inv_get_settings() {
    $s   = get_option('b2b_settings', []);
    $reg = get_option('b2b_registered_address', []);
    return [
        'company_name'   => $s['company_name']   ?? (defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO'),
        'bank_name'      => $s['bank_name']       ?? '',
        'bank_account'   => $s['bank_account']    ?? '',
        'bank_holder'    => $s['bank_holder']     ?? '',
        'promptpay_id'   => $s['promptpay_id']    ?? '',
        'logo_url'       => defined('B2B_LOGO_URL') ? B2B_LOGO_URL : '',
        'reg_name'       => $reg['reg_name']      ?? '',
        'reg_address'    => $reg['reg_address']   ?? '',
        'reg_province'   => $reg['reg_province']  ?? '',
        'reg_postcode'   => $reg['reg_postcode']  ?? '',
        'reg_phone'      => $reg['reg_phone']     ?? '',
    ];
}

function dinoco_inv_format_items_text($items) {
    $lines = [];
    foreach ($items as $item) {
        $sku  = $item['sku'] ? '(' . $item['sku'] . ') ' : '';
        $desc = $item['description'] ?? '';
        $qty  = intval($item['qty'] ?? 1);
        $total = floatval($item['line_total'] ?? 0);
        $lines[] = '[INVOICE] ' . $sku . $desc . ' x' . $qty . ' = ฿' . number_format($total, 0);
    }
    return implode("\n", $lines);
}

