// ========= UTILS =========
function invFmt(n) {
    return parseFloat(n||0).toLocaleString('th-TH', {minimumFractionDigits:0, maximumFractionDigits:2});
}
function escH(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

