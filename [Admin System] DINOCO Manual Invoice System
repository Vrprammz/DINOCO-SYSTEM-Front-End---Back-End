// ========= MODAL HELPER SHIMS (V.33.8 M5) =========
// Consistency layer mirroring Service Center `_scCfm`/`_scAlert` pattern вҖ” removes
// 5 inline try/catch wrappers around `window.dinocoModal.confirm`. Falls back to
// native confirm/alert/prompt if dinocoModal unavailable or throws.
function _miCfm(opts) {
    return new Promise(function(resolve) {
        try {
            if (window.dinocoModal && window.dinocoModal.confirm) {
                return window.dinocoModal.confirm(opts).then(resolve, function(){
                    var msg = (opts && opts.message) || (opts && opts.title) || 'аёўаё·аёҷаёўаёұаёҷ?';
                    resolve(window.confirm(msg));
                });
            }
        } catch (e) { /* fall through to native */ }
        var msg = (opts && opts.message) || (opts && opts.title) || 'аёўаё·аёҷаёўаёұаёҷ?';
        resolve(window.confirm(msg));
    });
}
function _miAlert(opts) {
    return new Promise(function(resolve) {
        try {
            if (window.dinocoModal && window.dinocoModal.alert) {
                return window.dinocoModal.alert(opts).then(resolve, function(){
                    var msg = (opts && opts.message) || (opts && opts.title) || '';
                    window.alert(msg); resolve(true);
                });
            }
        } catch (e) { /* fall through to native */ }
        var msg = (opts && opts.message) || (opts && opts.title) || '';
        window.alert(msg);
        resolve(true);
    });
}
function _miPrompt(opts) {
    return new Promise(function(resolve) {
        try {
            if (window.dinocoModal && window.dinocoModal.prompt) {
                return window.dinocoModal.prompt(opts).then(resolve, function(){
                    var msg = (opts && opts.message) || 'а№ғаёӘа№Ҳаё„а№ҲаёІ:';
                    resolve(window.prompt(msg, (opts && opts.default) || ''));
