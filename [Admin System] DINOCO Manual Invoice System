window.invOnDistChange = function() {
    var id = parseInt(document.getElementById('inv-f-dist').value);
    if (!id) {
        document.getElementById('inv-f-phone').value = '';
        document.getElementById('inv-f-addr').value = '';
        document.getElementById('inv-credit-banner').style.display = 'none';
        return;
    }
    if (!invDistributors.length) { setTimeout(window.invOnDistChange, 250); return; }
    invFillDistInfo(id);
    var dist = invDistributors.find(function(d){ return d.id == id; });
    if (dist && dist.credit_term_days) {
