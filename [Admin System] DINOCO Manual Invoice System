        var next = tr.nextElementSibling;
        while (next && next.classList.contains('inv-child-tr')) {
            var rem = next; next = next.nextElementSibling; rem.parentNode.removeChild(rem);
        }
        tr.parentNode.removeChild(tr);
        invRecalc();
