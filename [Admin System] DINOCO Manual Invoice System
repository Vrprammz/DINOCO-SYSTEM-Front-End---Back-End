function invRenderDDProducts(products) {
    var tbody = document.getElementById('inv-dd-product-body');
    if (!products || !products.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="inv-empty"><i class="fa-solid fa-box-open"></i> ยังไม่มีข้อมูลสินค้า</td></tr>';
        return;
    }
    var maxVal = products[0].total_value || 1;
    var rows = products.map(function(p, i) {
        var pct = Math.round((p.total_value / maxVal) * 100);
        return '<tr>' +
            '<td>' + (i + 1) + '</td>' +
            '<td><span style="font-size:0.78rem;color:#94a3b8;">' + escH(p.sku) + '</span><br>' + escH(p.description) + '</td>' +
            '<td style="text-align:right">' + invFmt(p.total_qty) + '</td>' +
            '<td style="text-align:right;font-weight:600;">฿' + invFmt(p.total_value) + '</td>' +
            '<td><div class="inv-dd-bar-wrap"><div class="inv-dd-bar" style="width:' + pct + '%"></div><span class="inv-dd-bar-pct">' + pct + '%</span></div></td>' +
            '</tr>';
    }).join('');
    tbody.innerHTML = rows;
}

function invRenderDDInvoices(invoices, page, pages) {
    var tbody = document.getElementById('inv-dd-invoice-body');
    if (!invoices || !invoices.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="inv-empty"><i class="fa-solid fa-file-invoice"></i> ยังไม่มีใบแจ้งหนี้</td></tr>';
        document.getElementById('inv-dd-pagination').innerHTML = '';
        return;
    }
    var statusLabel = {draft:'Draft', awaiting_payment:'รอชำระ', paid:'ชำระแล้ว', cancelled:'ยกเลิก', overdue:'เกินกำหนด'};
    var rows = invoices.map(function(inv, i) {
        var isPaid = inv.paid_amount > 0 && inv.paid_amount < inv.total_amount;
        var statusClass = isPaid ? 'partial' : inv.status;
        var statusText  = isPaid ? 'จ่ายบางส่วน' : (statusLabel[inv.status] || inv.status);
        var date = inv.issue_date ? new Date(inv.issue_date).toLocaleDateString('th-TH', {day:'numeric',month:'short',year:'numeric'}) : '-';
        var paymentText = inv.status === 'paid' ? 'ชำระครบ' : (inv.paid_amount > 0 ? 'จ่ายบางส่วน' : (inv.status === 'awaiting_payment' || inv.status === 'overdue' ? 'รอชำระ' : '-'));
        var paymentColor = inv.status === 'paid' ? '#16a34a' : (inv.paid_amount > 0 ? '#92400e' : (inv.status === 'awaiting_payment' || inv.status === 'overdue' ? '#dc2626' : '#94a3b8'));
        return '<tr>' +
            '<td>' + ((page - 1) * 20 + i + 1) + '</td>' +
            '<td>' + date + '</td>' +
            '<td><span class="inv-num" onclick="invViewFromDetail(' + inv.id + ')">' + escH(inv.inv_number) + '</span></td>' +
            '<td style="text-align:right">' + invFmt(inv.total_amount) + '</td>' +
            '<td><span class="inv-status ' + statusClass + '">' + statusText + '</span></td>' +
            '<td style="color:' + paymentColor + ';font-weight:600;font-size:0.82rem;">' + paymentText + '</td>' +
            '</tr>';
    }).join('');
    tbody.innerHTML = rows;

    // Pagination
    var pEl = document.getElementById('inv-dd-pagination');
    if (pages <= 1) { pEl.innerHTML = ''; return; }
    var html = '';
    for (var pg = 1; pg <= pages; pg++) {
        html += '<button class="inv-btn ' + (pg === page ? 'inv-btn-primary' : 'inv-btn-secondary') + '" onclick="invDistDetailPage(' + pg + ')" style="padding:6px 12px;">' + pg + '</button>';
    }
    pEl.innerHTML = html;
}

window.invDistDetailPage = function(page) {
    if (_invDDCurrentDistId) invLoadDistDetail(_invDDCurrentDistId, page);
};

// Navigate from detail view → builder, with return navigation
window.invViewFromDetail = function(invoiceId) {
    _invReturnTo = 'inv-dist-detail-view';
    _invReturnDistId = _invDDCurrentDistId;
    invOpenBuilder(invoiceId);
};

// ========= UTILS =========
function invFmt(n) {
    return parseFloat(n||0).toLocaleString('th-TH', {minimumFractionDigits:0, maximumFractionDigits:2});
}
function escH(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Close modals on backdrop click
document.getElementById('inv-prod-picker').addEventListener('click', function(e){ if(e.target===this) invClosePicker(); });
document.getElementById('inv-payment-modal').addEventListener('click', function(e){ if(e.target===this) this.classList.remove('open'); });
document.getElementById('inv-slip-modal').addEventListener('click', function(e){ if(e.target===this) this.classList.remove('open'); });

// Recalculate due date when invoice date changes (uses selected dist credit term)
document.getElementById('inv-f-date').addEventListener('change', function() {
    var distId = document.getElementById('inv-f-dist').value;
    if (!distId) return;
    var existingDue = document.getElementById('inv-f-due').value;
    if (existingDue) return;
    var dist = invDistributors.find(function(d){ return d.id == distId; });
    if (!dist || !dist.credit_term_days) return;
    var due = new Date(this.value);
    if (isNaN(due.getTime())) return;
    due.setDate(due.getDate() + parseInt(dist.credit_term_days));
    document.getElementById('inv-f-due').value = due.toISOString().slice(0,10);
});

// Init
invLoadList('all', 1);
invLoadDistributors();
invLoadProducts();

// V.31.1: Auto-refresh invoice list (respects global DINOCO_AUTO_REFRESH toggle)
(function(){
    var INV_REFRESH_SEC = 30;
    var _sec = INV_REFRESH_SEC;
    setInterval(function(){
        if (window.DINOCO_AUTO_REFRESH === false) return;
        // Only refresh when list view is active (not builder/modal)
        var listView = document.getElementById('inv-list-view');
        if (!listView || !listView.classList.contains('active')) { _sec = INV_REFRESH_SEC; return; }
        _sec--;
        if (_sec <= 0) {
            _sec = INV_REFRESH_SEC;
            if (typeof window.invLoadList === 'function') window.invLoadList();
        }
    }, 1000);
})();

})();
</script>
