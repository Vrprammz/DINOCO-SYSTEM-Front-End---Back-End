        var r = rows[0];
        var skuVal  = r.querySelector('[data-field="sku"]').value.trim();
        var descVal = r.querySelector('[data-field="description"]').value.trim();
        if (!skuVal && !descVal) tbody.removeChild(r);
    }
    invAddRow({
        type:        (p.children && p.children.length) ? 'set' : 'product',
        sku:         p.product_sku || '',
        description: p.title || '',
        unit_price:  price || 0,
        discount_raw: _invDiscRaw(p, price),
        qty:         1,
        img_url:     p.img || '',
        children:    p.children || [],
    });
    // Don't close picker — give button feedback so user knows it was added
    if (btn) {
        btn.textContent = '✓ เพิ่มแล้ว';
        btn.style.cssText = 'font-size:0.75rem;padding:3px 10px;border:1px solid #16a34a;border-radius:6px;background:#dcfce7;color:#16a34a;cursor:default;';
