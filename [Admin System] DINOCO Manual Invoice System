        }
        var rankEl = document.getElementById('inv-dd-rank');
        rankEl.textContent = rankLabels[p.rank_system] || p.rank_system;
        rankEl.className = 'inv-dist-rank-badge ' + (p.rank_system || 'standard');

        document.getElementById('inv-dd-phone').innerHTML = '<i class="fa-solid fa-phone" style="margin-right:4px;font-size:0.8rem;"></i> ' + escH(p.dist_phone || '-');
