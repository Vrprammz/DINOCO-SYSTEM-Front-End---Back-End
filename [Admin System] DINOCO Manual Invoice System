        document.getElementById('inv-dd-sales-month').textContent = 'аёҝ' + invFmt(data.sales_this_month);
        document.getElementById('inv-dd-sales-year').textContent = 'аёҝ' + invFmt(data.sales_this_year);
        document.getElementById('inv-dd-debt').textContent = 'аёҝ' + invFmt(data.outstanding_debt);

