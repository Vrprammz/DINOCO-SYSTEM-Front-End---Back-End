// CRON: 3-day pre-payment reminder — V.31: group by distributor, send 1 combined Flex
add_action('b2b_dunning_cron_event', 'dinoco_inv_cron_reminder');
function dinoco_inv_cron_reminder() {
    $now       = time();
    $target_lo = $now + (2 * DAY_IN_SECONDS);
    $target_hi = $now + (4 * DAY_IN_SECONDS);
    $ids = _dinoco_inv_query_awaiting();

    // Group invoices by distributor
    $by_dist = array();
    foreach ($ids as $id) {
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') continue;
        $due = get_field('due_date', $id);
        if (!$due) continue;
        $due_ts = _dinoco_inv_parse_date($due);
        if (!$due_ts || $due_ts < $target_lo || $due_ts > $target_hi) continue;
        if (get_post_meta($id, '_dunning_reminder_3day_sent', true)) continue;
        // V.31: ไม่ทวงบิลที่เพิ่ง issue วันเดียวกัน (ลูกค้ายังไม่ทันอ่านบิล)
        $issued_at = get_post_meta($id, '_inv_issued_at', true);
        if (!$issued_at) { $hist = get_post_meta($id, '_b2b_status_history', true); if (is_array($hist)) { foreach ($hist as $h) { if (isset($h['to']) && $h['to'] === 'awaiting_payment' && isset($h['at'])) { $issued_at = $h['at']; break; } } } }
        if ($issued_at && (time() - strtotime($issued_at)) < DAY_IN_SECONDS) continue;
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        if (!$dist_id) continue;
        $by_dist[$dist_id][] = $id;
    }

    // Send 1 combined Flex per distributor
    foreach ($by_dist as $dist_id => $order_ids) {
        $group_id = get_field('line_group_id', $dist_id);
        $dist_name = get_the_title($dist_id);
        $total_debt = floatval(get_field('current_debt', $dist_id));

        $invoices = array();
        foreach ($order_ids as $id) {
            $due = get_field('due_date', $id);
            $due_ts = _dinoco_inv_parse_date($due);
            $days_left = $due_ts ? max(0, (int)ceil(($due_ts - $now) / 86400)) : 0;
            $inv_total = floatval(get_field('total_amount', $id));
            $inv_paid  = floatval(get_post_meta($id, '_inv_paid_amount', true));
            $inv_remaining = max(0, $inv_total - $inv_paid);
            if ($inv_remaining <= 0) continue; // fully paid — skip
            $invoices[] = array(
                'inv_number' => get_post_meta($id, '_inv_number', true) ?: '#'.$id,
                'total'      => $inv_remaining,
                'due_fmt'    => $due_ts ? b2b_date('d/m/Y', $due_ts) : '-',
                'urgency'    => "อีก {$days_left} วัน",
                'overdue'    => false,
            );
        }

        if ($group_id && !empty($invoices)) {
            if (count($invoices) === 1) {
                // Single invoice → single Flex
                $msgs = _dinoco_inv_build_dunning_message($invoices[0]['inv_number'], $invoices[0]['total'], get_field('due_date', $order_ids[0]), 0);
            } else {
                // Multiple invoices → combined Flex
                $msgs = array(_dinoco_inv_build_dunning_combined($dist_name, $invoices, $total_debt));
            }
            $pushed = b2b_line_push_raw($group_id, $msgs);
            if ($pushed) {
                foreach ($order_ids as $id) {
                    update_post_meta($id, '_dunning_reminder_3day_sent', b2b_date('Y-m-d H:i:s'));
                }
            }
        }
        foreach ($order_ids as $id) {
            b2b_add_audit_log($id, 'dunning_reminder', 'ส่งเตือนล่วงหน้า (รวม '.count($invoices).' บิล)');
        }
    }
}

// CRON: Overdue alerts (1+ day past due) — V.31: group by distributor
add_action('b2b_bo_overdue_check', 'dinoco_inv_cron_overdue');
function dinoco_inv_cron_overdue() {
    $now = time();
    $ids = _dinoco_inv_query_awaiting();

    // Group overdue invoices by distributor
    $by_dist = array();
    foreach ($ids as $id) {
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') continue;
        $due = get_field('due_date', $id);
        $due_ts = _dinoco_inv_parse_date($due);
        if (!$due_ts || $due_ts >= $now) continue;
        $days_overdue = (int)ceil(($now - $due_ts) / DAY_IN_SECONDS);
        $tier = $days_overdue >= 7 ? 'escalated' : 'day1';
        $sent_key = '_overdue_notice_sent_' . $tier;
        if (get_post_meta($id, $sent_key, true)) continue;
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        if (!$dist_id) continue;
        $by_dist[$dist_id][] = array('id' => $id, 'days_overdue' => $days_overdue, 'tier' => $tier, 'sent_key' => $sent_key);
    }

    // Send 1 combined Flex per distributor
    foreach ($by_dist as $dist_id => $items) {
        $group_id = get_field('line_group_id', $dist_id);
        $dist_name = get_the_title($dist_id);
        $total_debt = floatval(get_field('current_debt', $dist_id));
        $worst_overdue = max(array_column($items, 'days_overdue'));

        $invoices = array();
        foreach ($items as $item) {
            $id = $item['id'];
            $ov_total = floatval(get_field('total_amount', $id));
            $ov_paid  = floatval(get_post_meta($id, '_inv_paid_amount', true));
            $ov_remaining = max(0, $ov_total - $ov_paid);
            if ($ov_remaining <= 0) continue; // fully paid — skip
            $invoices[] = array(
                'inv_number' => get_post_meta($id, '_inv_number', true) ?: '#'.$id,
                'total'      => $ov_remaining,
                'urgency'    => 'เลย '.$item['days_overdue'].' วัน',
                'overdue'    => true,
            );
        }

        if ($group_id && !empty($invoices)) {
            if (count($invoices) === 1) {
                $due = get_field('due_date', $items[0]['id']);
                $msgs = _dinoco_inv_build_dunning_message($invoices[0]['inv_number'], $invoices[0]['total'], $due, $items[0]['days_overdue']);
            } else {
                $msgs = array(_dinoco_inv_build_dunning_combined($dist_name, $invoices, $total_debt));
            }
            $pushed = b2b_line_push_raw($group_id, $msgs);
            if ($pushed) {
                foreach ($items as $item) {
                    update_post_meta($item['id'], $item['sent_key'], b2b_date('Y-m-d H:i:s'));
                }
            }
        }
        foreach ($items as $item) {
            b2b_add_audit_log($item['id'], 'dunning_overdue', "แจ้งเตือนค้างชำระ {$item['days_overdue']} วัน (รวม ".count($invoices)." บิล)" . ($group_id ? '' : ' (ไม่มี LINE group)'));
        }
    }
}

