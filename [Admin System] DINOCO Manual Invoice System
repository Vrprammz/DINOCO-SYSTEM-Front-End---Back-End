function dinoco_inv_format_items_text($items) {
    $lines = [];
    foreach ($items as $item) {
        $sku   = !empty($item['sku']) ? '(' . $item['sku'] . ') ' : '';
        $desc  = $item['description'] ?? '';
        $qty   = intval($item['qty'] ?? 1);
        $total = floatval($item['line_total'] ?? 0);
        // Standard B2B format вҖ” no [INVOICE] prefix here (would appear as product name in Snippet 10 PDF)
        $lines[] = $sku . $desc . ' x' . $qty . ' = аёҝ' . number_format($total, 2);
    }
    // в”Ғв”Ғв”Ғв”Ғ separator is stripped by Snippet 10's b2b_inv_parse_items(); anything after it is ignored in the PDF image
    // [INVOICE] marker placed after the separator so B2B Orders list can visually identify manual invoices
    return implode("\n", $lines) . "\nв”Ғв”Ғв”Ғв”Ғ\n[INVOICE]";
}

