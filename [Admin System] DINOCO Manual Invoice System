window.invRecalc = function() {
    var subtotal = 0;
    document.querySelectorAll('#inv-prod-tbody tr:not(.inv-child-tr)').forEach(function(tr) {
        var qty    = parseFloat(tr.querySelector('[data-field="qty"]').value) || 0;
        var price  = parseFloat(tr.querySelector('[data-field="unit_price"]').value) || 0;
        var discRaw = tr.querySelector('[data-field="discount_raw"]').value.trim();
        var effective = price;
        if (discRaw.endsWith('%')) {
            var pct = Math.max(0, Math.min(100, parseFloat(discRaw) || 0));
            effective = price * (1 - pct/100);
        } else if (discRaw !== '') {
            var amt = Math.max(0, parseFloat(discRaw) || 0);
            effective = Math.max(0, price - amt);
        }
        var lt = Math.round(effective * qty * 100) / 100;
        tr.querySelector('[data-field="line_total"]').textContent = invFmt(lt);
        subtotal += lt;
    });
    var discRaw = document.getElementById('inv-f-global-disc').value.trim();
    var globalDisc = 0;
    if (discRaw.endsWith('%')) {
        globalDisc = Math.max(0, subtotal * (Math.max(0, parseFloat(discRaw) || 0) / 100));
    } else {
        globalDisc = Math.max(0, Math.min(parseFloat(discRaw) || 0, subtotal));
    }
    var ship  = parseFloat(document.getElementById('inv-f-ship').value) || 0;
    var total = Math.round((subtotal - globalDisc + ship) * 100) / 100;
    document.getElementById('inv-grand-total').textContent = '฿' + invFmt(total);
};

