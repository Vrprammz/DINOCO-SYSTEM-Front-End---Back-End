    }
    $bank_card[] = ['type' => 'text', 'text' => $bank['account'], 'weight' => 'bold', 'size' => 'xxl', 'color' => '#111111', 'align' => 'center', 'margin' => 'lg'];
    $bank_card[] = ['type' => 'text', 'text' => 'аёҠаё·а№ҲаёӯаёҡаёұаёҚаёҠаёө: ' . $bank['holder'], 'size' => 'xs', 'color' => '#64748b', 'align' => 'center', 'margin' => 'xs'];
