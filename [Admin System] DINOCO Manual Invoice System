<script>
(function(){
'use strict';

var INV_NONCE    = <?php echo wp_json_encode($nonce); ?>;
var INV_REST     = <?php echo wp_json_encode($rest_base); ?>;
var INV_SETTINGS = <?php echo $settings_json; ?>;
var invCurrentFilter = 'all';
var invCurrentPage   = 1;
var invSearchTimer   = null;
var invProducts      = [];
var invDistributors  = [];
var invPickerTarget  = null; // row index for picker
var invPickerTab      = 'all'; // 'all' | 'set'
var invMultiPickerTab = 'all'; // 'all' | 'set'
var _invBusy = {};

// ========= TOAST =========
function invToast(type, msg) {
    var t = document.getElementById('inv-toast');
    var d = document.createElement('div');
    d.className = 'inv-toast-item ' + type;
    var span = document.createElement('span');
    span.textContent = msg;
    var btn = document.createElement('button');
    btn.className = 'inv-toast-close';
    btn.innerHTML = '&times;';
    btn.onclick = function(){ if(d.parentNode) d.parentNode.removeChild(d); };
    d.appendChild(span);
    d.appendChild(btn);
    t.appendChild(d);
    // V.33.1: Use original setTimeout to bypass auto-refresh override
    var _realTimeout = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
    var timer = _realTimeout(function(){ if(d.parentNode) d.parentNode.removeChild(d); }, 4000);
    btn.addEventListener('click', function(){ clearTimeout(timer); });
}

// ========= API helper =========
function invApi(method, path, body, cb) {
    var opts = {
        method: method,
        headers: { 'Content-Type': 'application/json', 'X-WP-Nonce': INV_NONCE },
    };
    if (body && (method === 'POST' || method === 'PUT')) opts.body = JSON.stringify(body);
    fetch(INV_REST + path + (method === 'GET' && body ? '?' + new URLSearchParams(body) : ''), opts)
        .then(function(r){
            if (!r.ok) return r.json().then(function(err){
                cb(null, {success:false, message:err.message||'เกิดข้อผิดพลาด'});
            });
            return r.json().then(function(d){ cb(null, d); });
        })
        .catch(function(e){ cb(e, null); });
}

// ========= LIST VIEW =========
var _invReturnTo = null;   // V.32.0: navigation stack for detail→builder→back
var _invReturnDistId = 0;

function invShow(view) {
    ['inv-list-view','inv-builder-view','inv-dist-detail-view'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) { el.classList.remove('active'); }
    });
    var target = document.getElementById(view);
    if (target) target.classList.add('active');
}

window.invLoadList = function(filter, page) {
    invCurrentFilter = filter || invCurrentFilter;
    invCurrentPage   = page || 1;
    var search = document.getElementById('inv-search').value.trim();
    var params = { status: invCurrentFilter, page: invCurrentPage };
    if (search) params.search = search;

    invApi('GET', '/invoice/list', params, function(err, data) {
        if (err || !data.success) { invToast('error', 'โหลดรายการล้มเหลว'); return; }
        var invoices = data.invoices || [];
        document.getElementById('inv-list-summary').textContent =
            'จำนวน ' + data.total + ' รายการ, มูลค่าทั้งหมด ' + invFmt(data.total_value) + ' บาท';

        var pending  = invoices.filter(function(i){ return i.status === 'awaiting_payment'; }).length;
        var overdue  = invoices.filter(function(i){ return i.status === 'overdue'; }).length;
        var badge = document.getElementById('badge-awaiting');
        if (badge) badge.textContent = pending;
        var badgeOd = document.getElementById('badge-overdue');
        if (badgeOd) { badgeOd.textContent = overdue; badgeOd.style.display = overdue ? '' : 'none'; }

        var tbody = document.getElementById('inv-list-body');
        if (!invoices.length) {
            tbody.innerHTML = '<tr><td colspan="7"><div class="inv-empty"><i class="fa-solid fa-file-invoice"></i>ยังไม่มีใบแจ้งหนี้/วางบิล</div></td></tr>';
            return;
        }
        var rows = invoices.map(function(inv, i) {
            var statusLabel = {draft:'Draft', awaiting_payment:'รอชำระ', paid:'ชำระแล้ว', cancelled:'ยกเลิก', overdue:'เกินกำหนด'}[inv.status] || inv.status;
            var isPaid = inv.paid_amount > 0 && inv.paid_amount < inv.total_amount;
            var statusClass = isPaid ? 'partial' : inv.status;
            var statusText  = isPaid ? 'จ่ายบางส่วน' : statusLabel;
            var date = inv.issue_date ? new Date(inv.issue_date).toLocaleDateString('th-TH', {day:'numeric',month:'short',year:'numeric'}) : '-';
            return '<tr>' +
                '<td>' + ((invCurrentPage-1)*30 + i + 1) + '</td>' +
                '<td>' + date + '</td>' +
                '<td><span class="inv-num" onclick="invViewInvoice(' + inv.id + ')">' + escH(inv.inv_number) + '</span></td>' +
                '<td>' + (inv.dist_id ? '<a class="inv-dist-link" href="javascript:void(0)" onclick="invOpenDistDetail(' + inv.dist_id + ')">' + escH(inv.dist_name) + '</a>' : escH(inv.dist_name)) + '</td>' +
                '<td style="text-align:right">' + invFmt(inv.total_amount) + '</td>' +
                '<td><span class="inv-status ' + statusClass + '">' + statusText + '</span></td>' +
                '<td><div class="inv-actions">' + invRowActions(inv) + '</div></td>' +
                '</tr>';
        });
        tbody.innerHTML = rows.join('');
        invRenderPager(data.pages, data.page);
    });
};

function invRowActions(inv) {
    var s    = inv.status;
    var id   = inv.id;
    var btns = '';
    if (s === 'draft') {
        btns += '<button class="inv-act-btn" onclick="invOpenBuilder(' + id + ')">แก้ไข</button>';
        btns += '<button class="inv-act-btn" style="color:#16a34a;font-weight:600;" onclick="invIssueFromList(' + id + ')">ออกบิล</button>';
        btns += '<button class="inv-act-btn" style="color:#dc2626" onclick="invDeleteFromList(' + id + ')">ลบ</button>';
    } else if (s === 'awaiting_payment' || s === 'overdue') {
        btns += '<button class="inv-act-btn" onclick="invOpenBuilder(' + id + ')">แก้ไข</button>';
        btns += '<button class="inv-act-btn" style="color:#16a34a;font-weight:600;" onclick="invOpenPayment(' + id + ')">รับเงิน</button>';
        btns += '<button class="inv-act-btn" onclick="invResendLine(' + id + ')">ส่ง LINE</button>';
        btns += '<button class="inv-act-btn" onclick="invPrint(' + id + ')">พิมพ์</button>';
        btns += '<button class="inv-act-btn" onclick="invDownloadInvImage(' + id + ')">ดาวน์โหลด</button>';
        // V.33.3 — Audit C2: refund ถ้ามี partial payment
        if ((inv.paid_amount || 0) > 0) {
            btns += '<button class="inv-act-btn" style="color:#f59e0b;font-weight:600;" onclick="invOpenRefund(' + id + ')">คืนเงิน</button>';
        }
        btns += '<button class="inv-act-btn" style="color:#dc2626" onclick="invCancelFromList(' + id + ')">ยกเลิก</button>';
    } else if (s === 'paid') {
        btns += '<button class="inv-act-btn" onclick="invPrint(' + id + ')">พิมพ์</button>';
        btns += '<button class="inv-act-btn" onclick="invResendLine(' + id + ')">ส่ง LINE</button>';
        btns += '<button class="inv-act-btn" onclick="invDownloadInvImage(' + id + ')">ดาวน์โหลด</button>';
        // V.33.3 — Audit C2: refund จาก paid status
        btns += '<button class="inv-act-btn" style="color:#f59e0b;font-weight:600;" onclick="invOpenRefund(' + id + ')">คืนเงิน</button>';
    } else if (s === 'cancelled') {
        btns += '<button class="inv-act-btn" style="color:#dc2626" onclick="invDeleteFromList(' + id + ')">ลบ</button>';
    }
    return btns;
}

function invRenderPager(pages, current) {
    var el = document.getElementById('inv-pagination');
    if (!el || pages <= 1) { el.innerHTML = ''; return; }
    var html = '';
    for (var p = 1; p <= pages; p++) {
        html += '<button class="inv-btn ' + (p === current ? 'inv-btn-primary' : 'inv-btn-secondary') + '" onclick="invLoadList(null,' + p + ')" style="padding:6px 12px;">' + p + '</button>';
    }
    el.innerHTML = html;
}

window.invSetFilter = function(f, btn) {
    document.querySelectorAll('#inv-wrap .inv-tab-btn').forEach(function(b){ b.classList.remove('active'); });
    if (btn) btn.classList.add('active');
    invLoadList(f, 1);
};

window.invDebouncedSearch = function() {
    clearTimeout(invSearchTimer);
    invSearchTimer = setTimeout(function(){ invLoadList(null, 1); }, 350);
};

window.invViewInvoice = function(id) {
    invOpenBuilder(id);
};

// ========= BUILDER VIEW =========
window.invOpenBuilder = function(id) {
    invShow('inv-builder-view');
    invResetBuilder();
    var heading = document.getElementById('inv-builder-heading');

    if (!invDistributors.length) invLoadDistributors();
    if (!invProducts.length) invLoadProducts();

    if (id) {
        document.getElementById('inv-edit-id').value = id;
        if (heading) heading.textContent = 'กำลังโหลด...';
        invApi('GET', '/invoice/get', {id: id}, function(err, data) {
            if (err || !data.success) { invToast('error', 'โหลด invoice ล้มเหลว'); return; }
            var inv = data.invoice;
            if (heading) heading.textContent = (inv.inv_number || ('#' + id)) + (inv.dist_name ? ' — ' + inv.dist_name : '');
            document.getElementById('inv-f-number').value = inv.inv_number || '';
            document.getElementById('inv-f-ref').value = inv.reference || '';
            document.getElementById('inv-f-note').value = inv.admin_note || '';
            document.getElementById('inv-f-due').value = inv.due_date || '';   // already ISO from API
            document.getElementById('inv-f-date').value = inv.issue_date || '';
            // Restore global discount and shipping fee
            var gd = inv.global_disc_pct > 0 ? inv.global_disc_pct + '%' : (inv.global_disc_val > 0 ? String(inv.global_disc_val) : '');
            document.getElementById('inv-f-global-disc').value = gd;
            document.getElementById('inv-f-ship').value = inv.ship_fee || 0;
            // Dist select will be set after distributors load
            setTimeout(function(){
                document.getElementById('inv-f-dist').value = inv.dist_id || '';
                var dist = invDistributors.find(function(d){ return d.id == inv.dist_id; });
                document.getElementById('inv-f-dist-search').value = dist ? (dist.shop_name || dist.name || '') : '';
                invFillDistInfo(inv.dist_id);
            }, 600);
            // Fill product rows + always add an empty row at the bottom
            var items = inv.items || [];
            items.forEach(function(item){ invAddRow(item); });
            invAddCustomRow();
            invRecalc();
            // Show/hide buttons based on status
            var isEditable = inv.status === 'draft';
            var isAwaiting = inv.status === 'awaiting_payment' || inv.status === 'overdue';
            document.getElementById('inv-save-draft-btn').style.display = isEditable ? '' : 'none';
            document.getElementById('inv-issue-btn').style.display     = isEditable ? '' : 'none';
            document.getElementById('inv-resend-btn').style.display    = isAwaiting ? '' : 'none';
            document.getElementById('inv-print-btn').style.display     = (isAwaiting || inv.status === 'paid') ? '' : 'none';
            document.getElementById('inv-dl-btn').style.display       = (isAwaiting || inv.status === 'paid') ? '' : 'none';
            document.getElementById('inv-pay-btn').style.display       = isAwaiting ? '' : 'none';
            document.getElementById('inv-cancel-btn').style.display    = isAwaiting ? '' : 'none';
            document.getElementById('inv-update-btn').style.display    = (isAwaiting || inv.status === 'overdue') ? '' : 'none';
        });
    } else {
        // Create empty draft immediately to reserve invoice number
        if (heading) heading.textContent = 'กำลังสร้าง...';
        invApi('POST', '/invoice/init', {}, function(err, data) {
            if (err || !data || !data.success) {
                invToast('error', 'ไม่สามารถสร้าง draft ได้');
                if (heading) heading.textContent = 'สร้างใบแจ้งหนี้/วางบิล';
                return;
            }
            document.getElementById('inv-edit-id').value = data.id;
            document.getElementById('inv-f-number').value = data.inv_number;
            if (heading) heading.textContent = data.inv_number;
            var today = new Date(new Date().toLocaleString('en-US',{timeZone:'Asia/Bangkok'})).toISOString().slice(0,10);
            document.getElementById('inv-f-date').value = today;
            invAddCustomRow();
        });
    }
};

window.invCloseBuilder = function() {
    // V.32.9: Auto-delete unsaved draft when closing builder
    _invCleanupDraft();

    // V.32.0: Return to detail view if navigated from there
    if (_invReturnTo === 'inv-dist-detail-view' && _invReturnDistId) {
        var distId = _invReturnDistId;
        _invReturnTo = null;
        _invReturnDistId = 0;
        invOpenDistDetail(distId);
        return;
    }
    invShow('inv-list-view');
    invLoadList();
};

// Delete draft if user never saved anything (no distributor, no items)
function _invCleanupDraft() {
    var id = document.getElementById('inv-edit-id').value;
    if (!id) return;
    var dist = document.getElementById('inv-f-dist').value;
    // Check if any real items exist (non-empty rows)
    var hasItems = false;
    document.querySelectorAll('#inv-prod-tbody tr:not(.inv-child-tr)').forEach(function(tr) {
        var sku  = tr.querySelector('[data-field="sku"]').value.trim();
        var desc = tr.querySelector('[data-field="description"]').value.trim();
        if (sku || desc) hasItems = true;
    });
    // If no distributor AND no items → this draft was never used, delete it
    if (!dist && !hasItems) {
        invApi('POST', '/invoice/delete', {id: parseInt(id)}, function() {});
    }
}

function invResetBuilder() {
    document.getElementById('inv-edit-id').value = '';
    document.getElementById('inv-f-number').value = '';
    document.getElementById('inv-f-ref').value = '';
    document.getElementById('inv-f-note').value = '';
    document.getElementById('inv-f-due').value = '';
    document.getElementById('inv-f-date').value = '';
    document.getElementById('inv-f-global-disc').value = '';
    document.getElementById('inv-f-ship').value = '0';
    document.getElementById('inv-grand-total').textContent = '฿0';
    document.getElementById('inv-prod-tbody').innerHTML = '';
    document.getElementById('inv-credit-banner').style.display = 'none';
    document.getElementById('inv-f-dist').value = '';
    document.getElementById('inv-f-dist-search').value = '';
    document.getElementById('inv-f-phone').value = '';
    document.getElementById('inv-f-addr').value = '';
    document.getElementById('inv-save-draft-btn').style.display = '';
    document.getElementById('inv-issue-btn').style.display = '';
    document.getElementById('inv-resend-btn').style.display = 'none';
    document.getElementById('inv-print-btn').style.display = 'none';
    document.getElementById('inv-dl-btn').style.display = 'none';
    document.getElementById('inv-pay-btn').style.display = 'none';
    document.getElementById('inv-cancel-btn').style.display = 'none';
    document.getElementById('inv-update-btn').style.display = 'none';
}

// ========= DISTRIBUTORS =========
// Actions available when viewing a non-draft invoice in builder
window.invResendLineBuilder = function() {
    var id = document.getElementById('inv-edit-id').value;
    if (!id) return;
    invApi('POST', '/invoice/resend-line', {id: parseInt(id)}, function(err, data) {
        if (err || !data || !data.success) { invToast('error', 'ส่ง LINE ล้มเหลว'); return; }
        invToast('success', 'ส่ง LINE ซ้ำแล้ว');
    });
};
window.invPrintFromBuilder = function() {
    var id = document.getElementById('inv-edit-id').value;
    if (id) invPrint(parseInt(id));
};
window.invDlFromBuilder = function() {
    var id = document.getElementById('inv-edit-id').value;
    if (id) invDownloadInvImage(parseInt(id));
};
window.invOpenPayModal = function() {
    var id = document.getElementById('inv-edit-id').value;
    if (id) invOpenPayment(parseInt(id));
};
window.invCancelFromBuilder = function() {
    var id = document.getElementById('inv-edit-id').value;
    if (!id) return;
    if (!confirm('ยืนยันยกเลิกใบแจ้งหนี้นี้?')) return;
    invApi('POST', '/invoice/cancel', {id: id}, function(err, data) {
        if (err || !data || !data.success) { invToast('error', 'ยกเลิกล้มเหลว'); return; }
        invToast('success', 'ยกเลิกแล้ว');
        invCloseBuilder();
    });
};

function invLoadDistributors() {
    invApi('GET', '/distributors', {}, function(err, data) {
        if (err || !data.success) { invToast('error', 'โหลดรายชื่อตัวแทนล้มเหลว'); return; }
        invDistributors = data.distributors || [];
    });
}

window.invOnDistChange = function() {
    var id = parseInt(document.getElementById('inv-f-dist').value);
    if (!id) {
        document.getElementById('inv-f-phone').value = '';
        document.getElementById('inv-f-addr').value = '';
        document.getElementById('inv-credit-banner').style.display = 'none';
        return;
    }
    if (!invDistributors.length) { setTimeout(window.invOnDistChange, 250); return; }
    invFillDistInfo(id);
    var dist = invDistributors.find(function(d){ return d.id == id; });
    if (dist && dist.credit_term_days) {
        var existingDue = document.getElementById('inv-f-due').value;
        if (!existingDue) {
            var invDateVal = document.getElementById('inv-f-date').value;
            var due = invDateVal ? new Date(invDateVal) : new Date();
            due.setDate(due.getDate() + parseInt(dist.credit_term_days));
            document.getElementById('inv-f-due').value = due.toISOString().slice(0,10);
        }
        // Show credit term hint
        var dueRow = document.getElementById('inv-f-due').closest('.inv-field-row');
        if (dueRow) {
            var hint = dueRow.querySelector('.inv-due-hint');
            if (!hint) { hint = document.createElement('span'); hint.className = 'inv-due-hint'; hint.style.cssText = 'font-size:0.75rem;color:#dc2626;margin-left:8px;'; dueRow.appendChild(hint); }
            hint.textContent = '(' + dist.credit_term_days + ' วัน)';
        }
    }
};

window.invDistSearch = function() {
    var q  = (document.getElementById('inv-f-dist-search').value || '').toLowerCase().trim();
    var dd = document.getElementById('inv-dist-dropdown');
    if (!invDistributors.length) { invLoadDistributors(); }
    var filtered = invDistributors.filter(function(d) {
        if (!q) return true;
        return (d.shop_name||d.name||'').toLowerCase().includes(q) ||
               (d.dist_phone||'').includes(q) ||
               (String(d.id)).includes(q);
    });
    if (!filtered.length) {
        dd.innerHTML = '<div style="padding:12px 16px;color:#94a3b8;font-size:0.85rem;">ไม่พบตัวแทน</div>';
    } else {
        dd.innerHTML = filtered.slice(0, 30).map(function(d) {
            var name = escH(d.shop_name || d.name || '');
            var meta = [d.dist_phone, d.rank_system ? 'Rank: ' + d.rank_system : ''].filter(Boolean).map(escH).join(' · ');
            var safeName = (d.shop_name || d.name || '').replace(/\\/g,'\\\\').replace(/'/g,"\\'");
            return '<div class="inv-dist-option" onclick="invSelectDist(' + d.id + ',\'' + safeName + '\')">' +
                '<div class="dopt-name">' + name + '</div>' +
                (meta ? '<div class="dopt-meta">' + meta + '</div>' : '') +
                '</div>';
        }).join('');
    }
    dd.style.display = 'block';
};
window.invSelectDist = function(id, name) {
    document.getElementById('inv-f-dist').value = id;
    document.getElementById('inv-f-dist-search').value = name;
    document.getElementById('inv-dist-dropdown').style.display = 'none';
    invOnDistChange();
};
document.addEventListener('click', function(e) {
    if (!e.target.closest('#inv-wrap .inv-dist-wrap')) {
        var dd = document.getElementById('inv-dist-dropdown');
        if (dd) dd.style.display = 'none';
    }
});

function invFillDistInfo(distId) {
    var dist = invDistributors.find(function(d){ return d.id == distId; });
    if (!dist) return;
    document.getElementById('inv-f-phone').value = dist.dist_phone || '';
    var addr = [dist.dist_address, dist.dist_district, dist.dist_city, dist.dist_province, dist.dist_postcode].filter(Boolean).join(', ');
    document.getElementById('inv-f-addr').value = addr;
    // Credit banner
    var banner = document.getElementById('inv-credit-banner');
    var limit  = parseFloat(dist.credit_limit) || 0;
    var debt   = parseFloat(dist.current_debt) || 0;
    var avail  = limit - debt;
    var cls    = avail > 10000 ? 'inv-credit-ok' : (avail > 0 ? 'inv-credit-warn' : 'inv-credit-danger');
    banner.className = 'inv-credit-banner ' + cls;
    banner.innerHTML = '<i class="fa-solid fa-credit-card"></i> เครดิตคงเหลือ ฿' + invFmt(avail) + ' / ฿' + invFmt(limit) +
        (dist.credit_hold ? ' <strong>⚠️ ระงับเครดิต</strong>' : '');
    banner.style.display = '';
}

// ========= PRODUCTS =========
function invLoadProducts() {
    invApi('GET', '/products', {}, function(err, data) {
        if (err || !data.success) { invToast('error', 'โหลดรายการสินค้าล้มเหลว'); return; }
        invProducts = data.products || [];
    });
}

// Render (or update) tree-style child sub-rows below a SET product row
function _invRenderChildrenRow(parentTr, childSkus) {
    // Remove all existing child rows
    var sib = parentTr.nextElementSibling;
    while (sib && sib.classList.contains('inv-child-tr')) {
        var rem = sib; sib = sib.nextElementSibling; rem.parentNode.removeChild(rem);
    }
    if (!childSkus || !childSkus.length) return;
    var frag = document.createDocumentFragment();
    childSkus.forEach(function(sku) {
        var skuStr = (typeof sku === 'object' && sku.sku) ? sku.sku : sku;
