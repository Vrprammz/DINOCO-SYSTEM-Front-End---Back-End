// --- RESEND LINE FLEX CARD + IMAGE ---
function dinoco_inv_rest_resend_line(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'ไม่พบใบแจ้งหนี้', ['status' => 404]);
    $dist_id  = intval(get_post_meta($id, '_dist_post_id', true));
    $line_gid = $dist_id ? get_field('line_group_id', $dist_id) : '';
    if (!$line_gid) return new WP_Error('no_line', 'ตัวแทนไม่มี LINE Group ID', ['status' => 400]);
    $inv_data = [
        'inv_number'       => get_post_meta($id, '_inv_number', true),
        'dist_name'        => get_field('dist_name', $id),
        'total_amount'     => floatval(get_field('total_amount', $id)),
        'due_date'         => get_field('due_date', $id) ?: '',
        'issue_date'       => get_post_meta($id, '_inv_date', true) ?: get_the_date('Y-m-d', $id),
        'items_json'       => get_post_meta($id, '_inv_items', true) ?: '[]',
        'credit_term_days' => intval(get_field('credit_term_days', $dist_id)),
        'created_by'       => intval(get_post_meta($id, '_inv_created_by', true)),
    ];
    $flex = dinoco_inv_build_flex_card($inv_data, dinoco_inv_get_settings());
    $sent = b2b_line_push_raw($line_gid, $flex);
    if ($sent && function_exists('b2b_send_invoice_image')) {
        b2b_send_invoice_image($line_gid, $id);
    }
    b2b_add_audit_log($id, 'resend_line', 'ส่ง LINE Flex Card ซ้ำ โดย ' . wp_get_current_user()->user_login);
    return rest_ensure_response(['success' => $sent, 'message' => $sent ? 'ส่ง LINE สำเร็จ' : 'ส่ง LINE ล้มเหลว']);
}

// --- PENDING SUMMARY: Preview (GET) ---
function dinoco_inv_rest_pending_summary(WP_REST_Request $req) {
    $dist_id = intval($req->get_param('dist_id'));
    if ($dist_id <= 0) return new WP_Error('missing', 'กรุณาระบุรหัสตัวแทนจำหน่าย', ['status' => 400]);
    $data = _dinoco_inv_get_pending_invoices($dist_id);
    if ($data === null) return new WP_Error('invalid', 'ไม่พบตัวแทนจำหน่าย', ['status' => 404]);
    $line_group = get_field('line_group_id', $dist_id);
    // V.32: include credit info for zero-debt preview
    $debt = function_exists('b2b_recalculate_debt') ? b2b_recalculate_debt($dist_id) : floatval(get_field('current_debt', $dist_id));
    $credit_limit = floatval(get_field('credit_limit', $dist_id));
    $credit_remain = $credit_limit > 0 ? max(0, $credit_limit - $debt) : 0;
    return rest_ensure_response([
        'success'        => true,
        'dist_id'        => $dist_id,
        'dist_name'      => $data['dist_name'],
        'has_line_group'  => !empty($line_group),
        'count'          => $data['count'],
        'total'          => $data['total'],
        'debt'           => $debt,
        'credit_limit'   => $credit_limit,
        'credit_remain'  => $credit_remain,
        'invoices'       => array_map(function($inv) {
            return [
                'inv_number'  => $inv['inv_number'],
                'amount'      => $inv['remaining'],
                'date'        => $inv['due_date'],
                'overdue_days' => $inv['overdue'] ? abs($inv['days_diff']) : -abs($inv['days_diff']),
            ];
        }, $data['invoices']),
    ]);
}

// --- SEND SUMMARY: Send Flex to LINE (POST) ---
function dinoco_inv_rest_send_summary(WP_REST_Request $req) {
    $dist_id = intval($req->get_param('dist_id'));
    if ($dist_id <= 0) return new WP_Error('missing', 'กรุณาระบุรหัสตัวแทนจำหน่าย', ['status' => 400]);

    // Rate limit: 60s per distributor
    $lock = 'inv_summary_lock_' . $dist_id;
    if (get_transient($lock)) return new WP_Error('rate_limited', 'กรุณารอ 60 วินาทีก่อนส่งอีกครั้ง', ['status' => 429]);

    $data = _dinoco_inv_get_pending_invoices($dist_id);
    if ($data === null) return new WP_Error('invalid', 'ไม่พบตัวแทนจำหน่าย', ['status' => 404]);

    $line_group = get_field('line_group_id', $dist_id);
    if (!$line_group) return new WP_Error('no_line', 'ตัวแทนไม่มี LINE group', ['status' => 422]);

    $flex = dinoco_inv_build_flex_summary($data);
    if (empty($flex)) return new WP_Error('build_fail', 'Failed to build Flex card', ['status' => 500]);

    b2b_line_push_raw($line_group, $flex);
    set_transient($lock, 1, 60);

    $admin = wp_get_current_user()->user_login;
    if ($data['count'] > 0) {
        foreach ($data['invoices'] as $inv) {
            b2b_add_audit_log($inv['post_id'], 'summary_sent',
                'รวมในสรุปบิลค้าง ส่งโดย ' . $admin . ' (' . $data['count'] . ' ใบ ฿' . number_format($data['total'], 0) . ')');
        }
    }

    $msg = $data['count'] > 0
        ? 'ส่งสรุป ' . $data['count'] . ' บิล ฿' . number_format($data['total'], 0) . ' แล้ว'
        : 'ส่งอัพเดทยอดบัญชี (ไม่มีค้าง) แล้ว';
    return rest_ensure_response([
        'success'   => true,
        'dist_name' => $data['dist_name'],
        'count'     => $data['count'],
        'total'     => $data['total'],
        'message'   => $msg,
    ]);
}

// --- DISTRIBUTOR DETAIL (V.32.0) ---
function dinoco_inv_rest_distributor_detail(WP_REST_Request $req) {
    $dist_id = intval($req->get_param('dist_id'));
    if (!$dist_id || get_post_type($dist_id) !== 'distributor') {
        return new WP_Error('invalid', 'Distributor not found', ['status' => 404]);
    }
    $page = max(1, intval($req->get_param('page') ?? 1));
    $per  = 20;

    // --- Profile ---
    $profile = [
        'id'               => $dist_id,
        'shop_name'        => get_field('shop_name', $dist_id) ?: get_the_title($dist_id),
        'shop_logo_url'    => get_field('shop_logo_url', $dist_id) ?: '',
        'dist_phone'       => get_field('dist_phone', $dist_id) ?: '',
        'dist_address'     => get_field('dist_address', $dist_id) ?: '',
        'dist_district'    => get_field('dist_district', $dist_id) ?: '',
        'dist_city'        => get_field('dist_city', $dist_id) ?: '',
        'dist_province'    => get_field('dist_province', $dist_id) ?: '',
        'dist_postcode'    => get_field('dist_postcode', $dist_id) ?: '',
        'rank_system'      => get_field('rank_system', $dist_id) ?: 'standard',
        'credit_limit'     => floatval(get_field('credit_limit', $dist_id)),
        'credit_term_days' => intval(get_field('credit_term_days', $dist_id) ?: 30),
        'current_debt'     => function_exists('b2b_recalculate_debt')
            ? floatval(b2b_recalculate_debt($dist_id))
            : floatval(get_field('current_debt', $dist_id)),
    ];

    // --- All non-draft/cancelled invoices for this distributor ---
    $all_ids = get_posts([
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => -1,
        'fields'         => 'ids',
        'meta_query'     => [
            ['key' => '_order_source', 'value' => 'manual_invoice'],
            ['key' => '_dist_post_id', 'value' => $dist_id, 'type' => 'NUMERIC'],
        ],
    ]);

    // Warm meta cache
    if (!empty($all_ids)) update_postmeta_cache($all_ids);

    $tz          = new DateTimeZone('Asia/Bangkok');
    $now         = new DateTime('now', $tz);
    $month_start = $now->format('Y-m-01');
    $year_start  = $now->format('Y-01-01');

    $sales_month = 0;
    $sales_year  = 0;
    $outstanding = 0;
    $product_map = []; // sku => [description, total_qty, total_value]
    $cutoff_12m  = (clone $now)->modify('-12 months')->format('Y-m-d');

    foreach ($all_ids as $pid) {
        $status = get_field('order_status', $pid);
        if (in_array($status, ['draft', 'cancelled'])) continue;

        $total    = floatval(get_field('total_amount', $pid));
        $inv_date = get_post_meta($pid, '_inv_date', true) ?: get_the_date('Y-m-d', $pid);

        // Sales aggregation
        if ($inv_date >= $year_start)  $sales_year  += $total;
        if ($inv_date >= $month_start) $sales_month += $total;

        // Outstanding (awaiting_payment / overdue)
        if (in_array($status, ['awaiting_payment'])) {
            $paid = floatval(get_post_meta($pid, '_inv_paid_amount', true));
            $outstanding += ($total - $paid);
        }

        // Product breakdown (last 12 months)
        if ($inv_date >= $cutoff_12m) {
            $items = json_decode(get_post_meta($pid, '_inv_items', true) ?: '[]', true);
            foreach ($items as $item) {
                $sku = $item['sku'] ?? 'N/A';
                if (!isset($product_map[$sku])) {
                    $product_map[$sku] = ['sku' => $sku, 'description' => $item['description'] ?? $sku, 'total_qty' => 0, 'total_value' => 0];
                }
                $product_map[$sku]['total_qty']   += intval($item['qty'] ?? 1);
                $product_map[$sku]['total_value']  += floatval($item['line_total'] ?? 0);
            }
        }
    }

    // Sort products by value DESC, top 10
    $products = array_values($product_map);
    usort($products, function($a, $b) { return $b['total_value'] <=> $a['total_value']; });
    $products = array_slice($products, 0, 10);

    // --- Paginated invoice history (all statuses) ---
    $inv_query = new WP_Query([
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => $per,
        'paged'          => $page,
        'orderby'        => 'date',
        'order'          => 'DESC',
        'meta_query'     => [
            ['key' => '_order_source', 'value' => 'manual_invoice'],
            ['key' => '_dist_post_id', 'value' => $dist_id, 'type' => 'NUMERIC'],
        ],
    ]);
    $invoices = [];
    foreach ($inv_query->posts as $p) {
        $invoices[] = _dinoco_inv_row($p->ID);
    }

    return rest_ensure_response([
        'success'           => true,
        'profile'           => $profile,
        'sales_this_month'  => round($sales_month, 2),
        'sales_this_year'   => round($sales_year, 2),
        'outstanding_debt'  => round($outstanding, 2),
        'product_breakdown' => $products,
        'invoices'          => $invoices,
        'invoice_count'     => $inv_query->found_posts,
        'invoice_pages'     => $inv_query->max_num_pages,
        'invoice_page'      => $page,
    ]);
}

// --- DELETE ---
function dinoco_inv_rest_delete(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $status = get_field('order_status', $id);
    if (!in_array($status, ['draft', 'cancelled'])) return new WP_Error('invalid', 'ลบได้เฉพาะ Draft หรือ ยกเลิก', ['status' => 400]);
    // Remove the manual_invoice marker so post disappears from invoice list
    // but remains as a b2b_order (visible in B2B Orders tab)
    delete_post_meta($id, '_order_source');
    b2b_add_audit_log($id, 'invoice_removed', 'ลบออกจากรายการใบแจ้งหนี้ (b2b_order ยังคงอยู่)');
    return rest_ensure_response(['success' => true]);
}


