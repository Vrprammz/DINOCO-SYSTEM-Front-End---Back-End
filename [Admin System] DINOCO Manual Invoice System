// Helper: get rank-based price info for a product object
// V.33.2: tier fields now store discount % (0-100), not absolute prices
// V.34.4: returns {base, disc, effective} so callers can split base + discount %
// V.34.5: HIGH-1 fix вҖ” derive implicit disc% for legacy unmigrated tier prices
//         (e.g. price_silver=7040 absolute + b2b_discount_percent=0) so picker emits
//         unit_price=base + disc% instead of unit_price=catalog + disc=0
function invGetRankPriceInfo(p) {
    var dist = invDistributors.find(function(d){ return d.id == document.getElementById('inv-f-dist').value; });
    var rank = dist ? (dist.rank_system || 'standard') : 'standard';
    var basePrice = parseFloat(p.catalog_price || p.base_price || 0);
    var discKey = 'price_' + rank;
    var discPct = parseFloat(p[discKey] || 0);

    // tier values are % discount (0-100). If > 100 = unmigrated price, fallback
    if (!(discPct > 0 && discPct <= 100)) {
        discPct = parseFloat(p.b2b_discount_percent || p.discount || 0);
    }
    if (!(discPct > 0 && discPct <= 100)) discPct = 0;

    var effective;
    if (discPct > 0 && basePrice > 0) {
        effective = Math.round(basePrice * (1 - discPct / 100) * 100) / 100;
    } else {
        // last fallback: dealer_price from API or base
        effective = parseFloat(p.dealer_price || basePrice) || basePrice;
    }

    // HIGH-1: derive implicit disc% for legacy unmigrated tier prices
    // (e.g. price_silver=7040 absolute + b2b_discount_percent=0 вҶ’ effective=7040, base=8800
    //  вҶ’ without this branch, picker emits unit_price=8800, disc='' вҶ’ invoice shows 8800 not 7040)
    if (discPct === 0 && basePrice > 0 && effective > 0 && effective < basePrice) {
        discPct = Math.round((1 - effective / basePrice) * 10000) / 100;
    }

    return { base: basePrice, disc: discPct, effective: effective };
}

function invGetRankPrice(p) {
    return invGetRankPriceInfo(p).effective;
}

// V.34.5: unified pickerвҶ’row value extraction. Returns {unit_price, discount_raw}.
// Priority: info.base (catalog/retail) вҶ’ info.effective (dealer) вҶ’ fallback arg вҶ’ 0.
// Discount only emitted when base is the chosen price (so recalc applies disc once).
function _invPickerVals(p, fallback) {
    var info = invGetRankPriceInfo(p);
    if (info.base > 0) {
        return {
            unit_price: info.base,
            discount_raw: info.disc > 0 ? info.disc + '%' : '',
        };
    }
    return {
        unit_price: info.effective || fallback || 0,
        discount_raw: '', // base unknown вҶ’ can't safely apply disc% on top of dealer price
    };
}

window.invFilterPicker = function() {
    var q = document.getElementById('inv-picker-search').value.toLowerCase();
    var list = document.getElementById('inv-prod-picker-list');
    var filtered = invProducts.filter(function(p){
        if (invPickerTab === 'set' && !(p.children && p.children.length > 0)) return false;
        return !q || (p.product_sku||'').toLowerCase().includes(q) || (p.title||'').toLowerCase().includes(q);
    });
    if (!filtered.length) { list.innerHTML = '<p style="padding:16px;color:#94a3b8;text-align:center;">а№„аёЎа№ҲаёһаёҡаёӘаёҙаёҷаё„а№үаёІ</p>'; return; }
    list.innerHTML = filtered.slice(0,80).map(function(p) {
        var info = invGetRankPriceInfo(p);
        // V.34.6: display catalog (pre-discount) вҖ” matches table row that shows base + disc%
        var price = info.base > 0 ? info.base : info.effective;
        // Tooltip вҖ” admin verify dealer (post-discount) price before pick
        var priceTitle = info.base > 0 && info.disc > 0 && info.effective > 0
            ? 'аё«аёҘаёұаёҮаёӘа№Ҳаё§аёҷаёҘаё” аёҝ' + invFmt(info.effective) + ' (-' + info.disc + '%)'
            : '';
        var isSet = p.children && p.children.length > 0;
        return '<div class="inv-picker-item" onclick="invPickProduct(' + JSON.stringify(p).replace(/"/g,'&quot;') + ',' + (parseFloat(price)||0) + ')">' +
            (p.img ? '<img src="' + escH(p.img) + '" alt="" loading="lazy">' : '<div style="width:52px;height:52px;border-radius:6px;background:#f1f5f9;flex-shrink:0;margin-right:10px;"></div>') +
            '<div style="flex:1;min-width:0;"><span class="pi-name">' + escH(p.title) + '</span>' +
            (isSet ? '<span class="pi-badge">SET</span>' : '') +
            '<br><span class="pi-sku">' + escH(p.product_sku) + '</span></div>' +
            '<span class="pi-price"' + (priceTitle ? ' title="' + escH(priceTitle) + '"' : '') + '>аёҝ' + invFmt(price) + '</span></div>';
    }).join('');
