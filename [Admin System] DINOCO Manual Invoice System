// Remove empty trailing rows (keep only one)
function _invCleanEmptyRows() {
    var tbody = document.getElementById('inv-prod-tbody');
    var rows = Array.from(tbody.querySelectorAll('tr:not(.inv-child-tr)'));
    for (var i = rows.length - 1; i >= 0; i--) {
        var r = rows[i];
        var sku  = r.querySelector('[data-field="sku"]').value.trim();
        var desc = r.querySelector('[data-field="description"]').value.trim();
        if (!sku && !desc) {
            var next = r.nextElementSibling;
            while (next && next.classList.contains('inv-child-tr')) { var rem = next; next = next.nextElementSibling; rem.remove(); }
            r.remove();
        } else {
            break; // stop at first non-empty row from bottom
        }
    }
}

// ========= SAVE =========
function invBuildPayload() {
    var items = [];
    document.querySelectorAll('#inv-prod-tbody tr:not(.inv-child-tr)').forEach(function(tr) {
        var desc = tr.querySelector('[data-field="description"]').value.trim();
        var sku  = tr.querySelector('[data-field="sku"]').value.trim();
        var qty  = parseInt(tr.querySelector('[data-field="qty"]').value) || 0;
        var price = parseFloat(tr.querySelector('[data-field="unit_price"]').value) || 0;
        // Skip empty rows (no description AND no SKU, or qty=0 and price=0)
        if (!desc && !sku) return;
        var discRaw = tr.querySelector('[data-field="discount_raw"]').value.trim();
        var discVal = 0, discPct = 0;
        if (discRaw.endsWith('%')) discPct = parseFloat(discRaw) || 0;
        else discVal = parseFloat(discRaw) || 0;
        var childrenInput = tr.querySelector('[data-field="children"]');
        var childrenVal = [];
        try { childrenVal = JSON.parse(childrenInput ? childrenInput.value : '[]') || []; } catch(e) {}
        var imgInput = tr.querySelector('[data-field="img_url"]');
        items.push({
            type:        tr.querySelector('[data-field="type"]').value,
            sku:         sku,
            description: desc,
            qty:         qty || 1,
            unit_price:  price,
            discount_val: discVal,
            discount_pct: discPct,
            img_url:     imgInput ? imgInput.value.trim() : '',
            children:    childrenVal,
        });
    });
    var gdRaw = document.getElementById('inv-f-global-disc').value.trim();
    return {
        dist_id:             document.getElementById('inv-f-dist').value,
        items:               items,
        admin_note:          document.getElementById('inv-f-note').value,
        reference:           document.getElementById('inv-f-ref').value,
        invoice_date:        document.getElementById('inv-f-date').value,
        due_date:            document.getElementById('inv-f-due').value,
        shipping_fee:        parseFloat(document.getElementById('inv-f-ship').value) || 0,
        global_discount_val: gdRaw.endsWith('%') ? 0 : (parseFloat(gdRaw)||0),
        global_discount_pct: gdRaw.endsWith('%') ? (parseFloat(gdRaw)||0) : 0,
    };
}

window.invSave = function(issue) {
    if (_invBusy.save) return; _invBusy.save = true;
    var payload = invBuildPayload();
    if (!payload.dist_id) { _invBusy.save = false; invToast('error', 'กรุณาเลือกตัวแทนจำหน่าย'); return; }
    if (!payload.items.length || !payload.items.some(function(i){ return i.description; })) {
        _invBusy.save = false; invToast('error', 'กรุณาใส่รายการสินค้าอย่างน้อย 1 รายการ'); return;
    }
    var editId = document.getElementById('inv-edit-id').value;
    if (issue) payload.issue = true;

    if (editId) {
        payload.id = editId;
        invApi('POST', '/invoice/update', payload, function(err, data) {
            _invBusy.save = false;
            if (err || !data.success) { invToast('error', 'บันทึกล้มเหลว: ' + (data&&data.message||'')); return; }
            invToast('success', 'บันทึกเรียบร้อย');
            if (issue) {
                invApi('POST', '/invoice/issue', {id: editId}, function(e2, d2){
                    if (!e2 && d2 && d2.success) invToast('success', 'ออกใบแจ้งหนี้/วางบิลเรียบร้อย — ส่ง LINE แล้ว');
                    else invToast('error', 'ออกบิลล้มเหลว: ' + (d2&&d2.message||''));
                    invCloseBuilder();
                });
            } else {
                invCloseBuilder();
            }
        });
    } else {
        invApi('POST', '/invoice/create', payload, function(err, data) {
            _invBusy.save = false;
            if (err || !data.success) { invToast('error', 'สร้าง invoice ล้มเหลว: ' + (data&&data.message||'')); return; }
            invToast('success', 'สร้าง ' + data.inv_number + ' เรียบร้อย');
            if (issue && !data.issued) invToast('error', 'ออกบิลล้มเหลว: ' + (data.issue_error||''));
            else if (issue) invToast('success', 'ส่ง LINE Flex Card ไปยังตัวแทนแล้ว');
            invCloseBuilder();
        });
    }
};

window.invConfirmIssue = function() {
    var distName = document.getElementById('inv-f-dist-search').value || '?';
    var total = document.getElementById('inv-grand-total').textContent;
    if (!confirm('ยืนยันออกใบแจ้งหนี้/วางบิล ' + total + ' สำหรับ ' + distName + '?\n\nยอดนี้จะถูกเพิ่มเข้าหนี้ของตัวแทน')) return;
