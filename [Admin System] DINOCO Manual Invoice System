// Query helper: all manual invoices awaiting payment
function _dinoco_inv_query_awaiting() {
    return get_posts([
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => -1,
        'meta_query'     => [
            'relation' => 'AND',
            ['key' => '_order_source', 'value' => 'manual_invoice'],
        ],
        'fields' => 'ids',
    ]);
}

// Build dunning LINE push message
function _dinoco_inv_build_dunning_message($inv_number, $total, $due_date_str, $days_overdue = 0) {
    $settings = dinoco_inv_get_settings();
    $due_ts_d = _dinoco_inv_parse_date($due_date_str);
    if ($days_overdue <= 0) {
        $days_left = $due_ts_d ? max(0, (int)ceil(($due_ts_d - time()) / 86400)) : 0;
        $icon = '📋'; $title = 'เตือนชำระเงิน'; $urgency = "ครบกำหนดใน {$days_left} วัน";
    } elseif ($days_overdue <= 7) {
        $icon = '⚠️'; $title = 'แจ้งเตือนเลยกำหนดชำระ'; $urgency = "เลยกำหนด {$days_overdue} วัน";
    } else {
        $icon = '🔴'; $title = 'ค้างชำระเกิน 7 วัน'; $urgency = "เลยกำหนด {$days_overdue} วัน — กรุณาติดต่อเจ้าหน้าที่";
    }
    $due_fmt = $due_ts_d ? b2b_date('d/m/Y', $due_ts_d) : '-';
    $bank = ($settings['bank_name'] ?? '') . ' ' . ($settings['bank_account'] ?? '');
    $pp   = $settings['promptpay_id'] ?? '';
    $payment_line = trim("โอนผ่าน: {$bank}" . ($pp ? " | พร้อมเพย์ {$pp}" : ''));
    return [[
        'type' => 'text',
        'text' => "{$icon} {$title}\nใบแจ้งหนี้/วางบิล: {$inv_number}\nยอด: ฿" . number_format($total, 0) .
                  "\nครบกำหนด: {$due_fmt}\n{$urgency}\n{$payment_line}",
    ]];
}

// CRON: 3-day pre-payment reminder
add_action('b2b_dunning_cron_event', 'dinoco_inv_cron_reminder');
function dinoco_inv_cron_reminder() {
    $now       = time();
    $target_lo = $now + (2 * DAY_IN_SECONDS);          // >2 days away
    $target_hi = $now + (4 * DAY_IN_SECONDS);          // <4 days away
    $ids = _dinoco_inv_query_awaiting();
    foreach ($ids as $id) {
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') continue;
        $due = get_field('due_date', $id);
        if (!$due) continue;
        $due_ts = _dinoco_inv_parse_date($due);
        if (!$due_ts || $due_ts < $target_lo || $due_ts > $target_hi) continue;
        // Avoid duplicate send
        if (get_post_meta($id, '_dunning_reminder_3day_sent', true)) continue;
        $dist_id   = intval(get_post_meta($id, '_dist_post_id', true));
        $group_id  = get_field('line_group_id', $dist_id);
        if ($group_id) {
            $msgs = _dinoco_inv_build_dunning_message(
                get_post_meta($id, '_inv_number', true),
                floatval(get_field('total_amount', $id)),
                $due, 0
            );
            $pushed = b2b_line_push_raw($group_id, $msgs);
            if ($pushed) {
                update_post_meta($id, '_dunning_reminder_3day_sent', b2b_date('Y-m-d H:i:s'));
            }
        }
        b2b_add_audit_log($id, 'dunning_reminder', 'ส่งเตือนล่วงหน้า 3 วัน' . ($group_id ? '' : ' (ไม่มี LINE group)'));
    }
}

// CRON: Overdue alerts (1+ day past due)
add_action('b2b_bo_overdue_check', 'dinoco_inv_cron_overdue');
function dinoco_inv_cron_overdue() {
    $now = time();
    $ids = _dinoco_inv_query_awaiting();
    foreach ($ids as $id) {
        $status = get_field('order_status', $id);
        if ($status !== 'awaiting_payment') continue;
        $due = get_field('due_date', $id);
        $due_ts = _dinoco_inv_parse_date($due);
        if (!$due_ts || $due_ts >= $now) continue;  // Not yet overdue
        $days_overdue = (int)ceil(($now - $due_ts) / DAY_IN_SECONDS);
        // Escalation tiers: day 1, day 7 — avoid resend within same tier
        $tier = $days_overdue >= 7 ? 'escalated' : 'day1';
        $sent_key = '_overdue_notice_sent_' . $tier;
        if (get_post_meta($id, $sent_key, true)) continue;
        $dist_id  = intval(get_post_meta($id, '_dist_post_id', true));
        $group_id = get_field('line_group_id', $dist_id);
        if ($group_id) {
            $msgs = _dinoco_inv_build_dunning_message(
                get_post_meta($id, '_inv_number', true),
                floatval(get_field('total_amount', $id)),
                $due, $days_overdue
            );
            $pushed = b2b_line_push_raw($group_id, $msgs);
            if ($pushed) {
                update_post_meta($id, $sent_key, b2b_date('Y-m-d H:i:s'));
            }
        }
        b2b_add_audit_log($id, 'dunning_overdue', "แจ้งเตือนค้างชำระ {$days_overdue} วัน" . ($group_id ? '' : ' (ไม่มี LINE group)'));
    }
}

// REST: Manual send reminder
function dinoco_inv_rest_send_reminder(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $due     = get_field('due_date', $id);
    $total   = floatval(get_field('total_amount', $id));
    $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
    $group   = get_field('line_group_id', $dist_id);
    if (!$group) return new WP_Error('no_line', 'ตัวแทนไม่มี LINE group', ['status' => 422]);
    $msgs = _dinoco_inv_build_dunning_message(get_post_meta($id, '_inv_number', true), $total, $due ?: '', 0);
    b2b_line_push_raw($group, $msgs);
    // Reset flags so cron can re-send later if still unpaid
    delete_post_meta($id, '_dunning_reminder_3day_sent');
    b2b_add_audit_log($id, 'dunning_manual', 'Admin ส่งเตือนชำระเงินด้วยตนเอง');
    return rest_ensure_response(['success' => true, 'message' => 'ส่งเตือนผ่าน LINE แล้ว']);
}

// REST: Manual send overdue notice
function dinoco_inv_rest_send_overdue_notice(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $due      = get_field('due_date', $id);
    $total    = floatval(get_field('total_amount', $id));
    $dist_id  = intval(get_post_meta($id, '_dist_post_id', true));
    $group    = get_field('line_group_id', $dist_id);
    if (!$group) return new WP_Error('no_line', 'ตัวแทนไม่มี LINE group', ['status' => 422]);
    $due_ts   = _dinoco_inv_parse_date($due);
    $days_ov  = $due_ts ? max(1, (int)ceil((time() - $due_ts) / DAY_IN_SECONDS)) : 1;
    $msgs = _dinoco_inv_build_dunning_message(get_post_meta($id, '_inv_number', true), $total, $due ?: '', $days_ov);
    b2b_line_push_raw($group, $msgs);
    // Reset overdue flags so cron can re-escalate
    delete_post_meta($id, '_overdue_notice_sent_day1');
    delete_post_meta($id, '_overdue_notice_sent_escalated');
    b2b_add_audit_log($id, 'dunning_overdue_manual', "Admin ส่งแจ้งเตือนค้างชำระ {$days_ov} วัน ด้วยตนเอง");
    return rest_ensure_response(['success' => true, 'message' => "ส่งแจ้งเตือนค้างชำระผ่าน LINE แล้ว"]);
}

// --- Helpers for REST ---
function _dinoco_inv_row($post_id) {
    $status   = get_field('order_status', $post_id);
    $due_date = get_field('due_date', $post_id); // ACF may return d/m/Y

    // Normalize due_date to timestamp safely (ใช้ safe parser รองรับทั้ง d/m/Y และ Y-m-d)
    $due_ts = false;
    if (!empty($due_date) && $due_date !== '0000-00-00') {
        $due_ts = _dinoco_inv_parse_date($due_date);
        // Legacy fallback (keep for safety)
        if (!$due_ts || $due_ts < 86400) {
            $parts = explode('/', $due_date);
            if (count($parts) === 3) {
                $due_ts = mktime(0, 0, 0, intval($parts[1]), intval($parts[0]), intval($parts[2]));
            }
        }
        if ($due_ts < 86400) $due_ts = false; // reject epoch-zero result
    }

    // Virtual overdue flag: awaiting_payment + past due_date
    $is_overdue = ($status === 'awaiting_payment' && $due_ts && $due_ts < current_time('timestamp'));
    return [
        'id'           => $post_id,
        'inv_number'   => get_post_meta($post_id, '_inv_number', true),
        'dist_name'    => get_field('dist_name', $post_id),
        'dist_id'      => intval(get_post_meta($post_id, '_dist_post_id', true)),
        'status'       => $is_overdue ? 'overdue' : $status,
        'total_amount' => floatval(get_field('total_amount', $post_id)),
        'paid_amount'  => floatval(get_post_meta($post_id, '_inv_paid_amount', true)),
        'due_date'     => $due_ts ? b2b_date('Y-m-d', $due_ts) : '',   // always ISO for <input type="date">
        'issue_date'   => get_post_meta($post_id, '_inv_date', true) ?: get_the_date('Y-m-d', $post_id),
        'created_by'   => intval(get_post_meta($post_id, '_inv_created_by', true)),
        'is_billed'    => (bool) get_field('is_billed', $post_id),
        'is_overdue'   => $is_overdue,
    ];
}

function _dinoco_inv_check_owner($post_id) {
    if (get_post_type($post_id) !== 'b2b_order') return false;
    if (get_post_meta($post_id, '_order_source', true) !== 'manual_invoice') return false;
    return true;
}

// --- LIST ---
function dinoco_inv_rest_list(WP_REST_Request $req) {
    $status  = sanitize_text_field($req->get_param('status') ?? '');
    $dist_id = intval($req->get_param('dist_id') ?? 0);
    $search  = sanitize_text_field($req->get_param('search') ?? '');
    $page    = max(1, intval($req->get_param('page') ?? 1));
    $per     = 30;

    $meta_query = [['key' => '_order_source', 'value' => 'manual_invoice']];
    if ($dist_id > 0) $meta_query[] = ['key' => '_dist_post_id', 'value' => $dist_id];

    $args = [
        'post_type'      => 'b2b_order',
        'post_status'    => 'publish',
        'posts_per_page' => $per,
        'paged'          => $page,
        'orderby'        => 'date',
        'order'          => 'DESC',
        'meta_query'     => $meta_query,
    ];

    if ($status && $status !== 'all') {
        add_filter('posts_where', function($where) use ($status) {
            global $wpdb;
            return $where . $wpdb->prepare(
                " AND ID IN (SELECT post_id FROM {$wpdb->postmeta} WHERE meta_key='order_status' AND meta_value=%s)",
                $status
            );
        });
    }

    if ($search) {
        $args['s'] = $search;
    }

    $query = new WP_Query($args);
    $rows  = [];
    $total_value = 0;
    foreach ($query->posts as $p) {
        $row = _dinoco_inv_row($p->ID);
        if ($status && $status !== 'all' && $row['status'] !== $status) continue;
        if ($search) {
            $hay = strtolower($row['inv_number'] . ' ' . $row['dist_name']);
            if (strpos($hay, strtolower($search)) === false) continue;
        }
        $rows[] = $row;
        $total_value += $row['total_amount'];
    }

    return rest_ensure_response([
        'success'     => true,
        'invoices'    => $rows,
        'total'       => $query->found_posts,
        'total_value' => $total_value,
        'pages'       => $query->max_num_pages,
        'page'        => $page,
    ]);
}

// --- GET SINGLE ---
function dinoco_inv_rest_get(WP_REST_Request $req) {
    $id = intval($req->get_param('id'));
    if (!$id || !_dinoco_inv_check_owner($id)) return new WP_Error('not_found', 'Invoice not found', ['status' => 404]);
    $row = _dinoco_inv_row($id);
    $row['items']      = json_decode(get_post_meta($id, '_inv_items', true) ?: '[]', true);
    $row['admin_note'] = get_field('admin_note', $id);
    // due_date is already ISO-normalized in _dinoco_inv_row() — do NOT overwrite with raw ACF value here
    $row['global_disc_pct'] = floatval(get_post_meta($id, '_inv_global_disc_pct', true));
    $row['global_disc_val'] = floatval(get_post_meta($id, '_inv_global_disc_val', true));
    $row['ship_fee']        = floatval(get_post_meta($id, '_inv_ship_fee', true));
    $row['dist_phone']    = get_field('dist_phone', $id);
    $row['dist_address']  = get_field('dist_address', $id);
    $row['dist_district'] = get_field('dist_district', $id);
    $row['dist_city']     = get_field('dist_city', $id);
    $row['dist_province'] = get_field('dist_province', $id);
    $row['dist_postcode'] = get_field('dist_postcode', $id);
    $row['partial_payments'] = json_decode(get_post_meta($id, '_inv_partial_payments', true) ?: '[]', true);
    $row['audit_log']  = get_post_meta($id, '_b2b_audit_log', true) ?: [];
    $row['slip_ref']   = get_post_meta($id, '_inv_slip_ref', true);
    $row['reference']  = get_post_meta($id, '_inv_reference', true);
    return rest_ensure_response(['success' => true, 'invoice' => $row]);
}

