function _invDiscRaw(p, price) {
    var discPct = parseFloat(p.discount_pct) || 0;
    var catPrice = parseFloat(p.catalog_price) || 0;
    if (discPct === 0 && catPrice > 0 && price < catPrice) {
        discPct = Math.round((1 - price / catPrice) * 10000) / 100;
    }
    return discPct > 0 ? discPct + '%' : '';
}
