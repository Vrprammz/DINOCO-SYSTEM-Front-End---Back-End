window.invPrint = function(id) {
    invApi('GET', '/invoice/get', {id: id}, function(err, data) {
        if (err || !data.success) { invToast('error', 'โหลดข้อมูลล้มเหลว'); return; }
        var inv = data.invoice;
        var s   = INV_SETTINGS;
        var items = inv.items || [];
        var rows = items.map(function(item, i) {
            var discText = '';
            if (item.discount_pct > 0) discText = '(' + item.discount_pct + '% ส่วนลด)';
            else if (item.discount_val > 0) discText = '(ลด ฿' + invFmt(item.discount_val) + ')';
            var mainRow = '<tr>' +
                '<td>' + (i+1) + '</td>' +
                '<td>' + (item.sku ? '<small style="color:#888">' + escH(item.sku) + '</small><br>' : '') + escH(item.description) + (discText ? '<br><small style="color:#888">' + discText + '</small>' : '') + '</td>' +
                '<td style="text-align:center">' + item.qty + '</td>' +
                '<td style="text-align:right">฿' + invFmt(item.unit_price) + '</td>' +
                '<td style="text-align:right">฿' + invFmt(item.line_total) + '</td>' +
                '</tr>';
            var childRow = '';
            if (item.type === 'set' && item.children && item.children.length) {
                var chips = item.children.map(function(child) {
                    var skuStr = (typeof child === 'object' && child.sku) ? child.sku : child;
                    var childName = (typeof child === 'object' && child.name) ? child.name : '';
                    var cp = invProducts.find(function(p){ return p.product_sku === skuStr; });
                    var imgHtml = (cp && cp.img) ? '<img src="' + escH(cp.img) + '" style="width:26px;height:26px;object-fit:cover;border-radius:4px;vertical-align:middle;margin-right:5px;">' : '';
                    var displayName = cp ? escH(cp.title) : (childName ? escH(childName) : '');
                    return '<span style="display:inline-flex;align-items:center;background:#fff;border:1px solid #e2e8f0;border-radius:6px;padding:3px 8px 3px 4px;margin:2px;font-size:0.75rem;">' +
                        imgHtml + '<span style="color:#888;margin-right:4px;">' + escH(skuStr) + '</span>' +
                        (displayName ? '<span style="font-weight:600;">' + displayName + '</span>' : '') + '</span>';
                }).join('');
                childRow = '<tr style="background:#f8fafc;">' +
                    '<td></td>' +
                    '<td colspan="4" style="padding:4px 10px 10px 16px;">' + chips + '</td>' +
                    '</tr>';
            }
            return mainRow + childRow;
        }).join('');

        var addrLines = [s.reg_address, s.reg_province, s.reg_postcode].filter(Boolean).join(', ');
        var distAddr  = [inv.dist_address, inv.dist_district, inv.dist_city, inv.dist_province, inv.dist_postcode].filter(Boolean).join(', ');
        var dueDisp   = inv.due_date ? new Date(inv.due_date).toLocaleDateString('th-TH') : '-';
        var issuedDisp = inv.issue_date ? new Date(inv.issue_date).toLocaleDateString('th-TH') : '-';

        var html =
            '<div id="inv-print-area">' +
            '<div class="prt-header">' +
                (s.logo_url ? '<img class="prt-logo" src="' + escH(s.logo_url) + '" alt="logo">' : '<div></div>') +
                '<div class="prt-company"><h2>' + escH(s.company_name) + '</h2>' +
                (addrLines ? '<p>' + escH(addrLines) + '</p>' : '') +
                (s.reg_phone ? '<p>โทร: ' + escH(s.reg_phone) + '</p>' : '') + '</div>' +
            '</div>' +
            '<div class="prt-title-row">' +
                '<span class="prt-inv-title">ใบแจ้งหนี้/วางบิล / INVOICE</span>' +
                '<div class="prt-inv-meta">' +
                    '<p><strong>เลขที่:</strong> ' + escH(inv.inv_number) + '</p>' +
                    '<p><strong>วันที่:</strong> ' + issuedDisp + '</p>' +
                    '<p><strong>ครบกำหนด:</strong> ' + dueDisp + '</p>' +
                '</div>' +
            '</div>' +
            '<div class="prt-addr-row">' +
                '<div class="prt-addr-box">' +
                    '<strong>ลูกค้า</strong>' +
                    '<p><strong>' + escH(inv.dist_name) + '</strong></p>' +
                    (distAddr ? '<p>' + escH(distAddr) + '</p>' : '') +
                    (inv.dist_phone ? '<p>โทร: ' + escH(inv.dist_phone) + '</p>' : '') +
                '</div>' +
            '</div>' +
            '<table>' +
                '<thead><tr><th>#</th><th>รายละเอียด</th><th style="text-align:center">จำนวน</th><th style="text-align:right">ราคา/หน่วย</th><th style="text-align:right">รวม</th></tr></thead>' +
                '<tbody>' + rows + '</tbody>' +
            '</table>' +
            (function(){
                var subtotal = items.reduce(function(s,it){ return s + (parseFloat(it.unit_price)||0) * (parseInt(it.qty)||1); }, 0);
                var totalDisc = items.reduce(function(s,it){
                    var up = parseFloat(it.unit_price)||0, qty = parseInt(it.qty)||1, lt = parseFloat(it.line_total)||0;
                    return s + (up * qty - lt);
                }, 0);
                var gDiscPct = parseFloat(inv.global_disc_pct)||0;
                var gDiscVal = parseFloat(inv.global_disc_val)||0;
                var shipFee  = parseFloat(inv.ship_fee)||0;
                var hasBreakdown = totalDisc > 0 || gDiscPct > 0 || gDiscVal > 0 || shipFee > 0;
                var summaryRows = '';
                if (hasBreakdown) {
                    summaryRows += '<tr><td>ราคาจำหน่าย</td><td style="text-align:right">฿' + invFmt(subtotal) + '</td></tr>';
                    if (totalDisc > 0) summaryRows += '<tr style="color:#16a34a"><td>ส่วนลดตัวแทน</td><td style="text-align:right">-฿' + invFmt(totalDisc) + '</td></tr>';
                    var afterItemDisc = subtotal - totalDisc;
                    if (gDiscPct > 0) {
                        var gAmt = Math.round(afterItemDisc * gDiscPct / 100);
                        summaryRows += '<tr style="color:#16a34a"><td>ส่วนลดรวม (' + gDiscPct + '%)</td><td style="text-align:right">-฿' + invFmt(gAmt) + '</td></tr>';
                    } else if (gDiscVal > 0) {
                        summaryRows += '<tr style="color:#16a34a"><td>ส่วนลดรวม</td><td style="text-align:right">-฿' + invFmt(gDiscVal) + '</td></tr>';
                    }
                    if (shipFee > 0) summaryRows += '<tr><td>ค่าจัดส่ง</td><td style="text-align:right">฿' + invFmt(shipFee) + '</td></tr>';
                }
                summaryRows += '<tr><td><strong>มูลค่ารวมสุทธิ</strong></td><td class="prt-grand">฿' + invFmt(inv.total_amount) + '</td></tr>';
                if (inv.paid_amount > 0) summaryRows += '<tr><td>ชำระแล้ว</td><td style="text-align:right">฿' + invFmt(inv.paid_amount) + '</td></tr>';
                return '<table class="prt-summary"><tbody>' + summaryRows + '</tbody></table>';
            })() +
            (s.bank_name || s.promptpay_id ? '<div class="prt-payment"><strong>ชำระผ่าน:</strong>' +
                (s.bank_name ? ' ธนาคาร ' + escH(s.bank_name) + ' เลขที่ ' + escH(s.bank_account) + ' (' + escH(s.bank_holder) + ')' : '') +
                (s.promptpay_id ? '<br>พร้อมเพย์: ' + escH(s.promptpay_id) : '') +
                '</div>' : '') +
            (inv.admin_note ? '<p style="font-size:0.82rem;color:#555;margin-top:12px"><strong>หมายเหตุ:</strong> ' + escH(inv.admin_note) + '</p>' : '') +
            '<div class="prt-footer">สร้างโดยระบบ DINOCO Manual Invoice — ' + escH(s.company_name) + '</div>' +
            '</div>';

        var area = document.getElementById('inv-print-area');
        area.innerHTML = html;
        area.style.display = 'block';
        setTimeout(function(){ window.print(); area.style.display = 'none'; area.innerHTML = ''; }, 200);
    });
};

