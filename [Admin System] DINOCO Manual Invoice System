        '<td class="cell-price"><input type="number" class="inv-input" data-field="unit_price" value="' + (item.unit_price || 0) + '" min="0" step="0.01" oninput="invRecalc()"></td>' +
        '<td class="cell-disc"><input type="text" class="inv-input" data-field="discount_raw" value="' + escH(String(discDisp)) + '" placeholder="฿ หรือ %" oninput="invRecalc()"></td>' +
