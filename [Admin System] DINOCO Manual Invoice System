// ========= SLIP UPLOAD =========
window.invHandleSlipFile = function(input) {
    var file = input.files && input.files[0];
    if (!file) return;

    // Validate file type
    var allowed = ['image/jpeg', 'image/png', 'image/webp'];
    if (allowed.indexOf(file.type) === -1) {
        invToast('error', 'รองรับเฉพาะไฟล์ JPEG, PNG, WebP');
        input.value = '';
        return;
    }
    // Validate file size (max 5MB)
    if (file.size > 5 * 1024 * 1024) {
        invToast('error', 'ไฟล์ใหญ่เกินไป (สูงสุด 5MB)');
        input.value = '';
        return;
    }

    document.getElementById('inv-slip-filename').textContent = file.name;

    // Show preview
    var reader = new FileReader();
    reader.onload = function(e) {
        var base64 = e.target.result;
        document.getElementById('inv-slip-preview-img').src = base64;
        document.getElementById('inv-slip-preview').style.display = 'block';

        // Show loading status
        var statusEl = document.getElementById('inv-slip-status');
        statusEl.style.display = 'block';
        statusEl.style.background = '#f0f9ff';
        statusEl.style.color = '#0369a1';
        statusEl.textContent = '⏳ กำลังตรวจสอบสลิป...';

        // Call upload-slip API
        var invoiceId = document.getElementById('inv-pay-id').value;
        invApi('POST', '/invoice/upload-slip', { id: invoiceId, image: base64 }, function(err, data) {
            if (err || !data) {
                statusEl.style.background = '#fef2f2';
                statusEl.style.color = '#dc2626';
                statusEl.textContent = '❌ เชื่อมต่อ API ล้มเหลว';
                return;
            }
            if (data.verified) {
                var amt = parseFloat(data.amount) || 0;
                statusEl.style.background = '#f0fdf4';
                statusEl.style.color = '#16a34a';
                statusEl.innerHTML = '✅ สลิปถูกต้อง ฿' + invFmt(amt) +
                    (data.sender ? '<br><span style="font-weight:400;font-size:0.8rem;">ผู้โอน: ' + escH(data.sender) + '</span>' : '') +
                    (data.ref ? '<br><span style="font-weight:400;font-size:0.8rem;">Ref: ' + escH(data.ref) + '</span>' : '');
                // Auto-fill payment amount
                document.getElementById('inv-pay-amount').value = amt.toFixed(2);
                // Auto-fill note
                var noteField = document.getElementById('inv-pay-note');
                if (!noteField.value) {
                    noteField.value = 'สลิป ref=' + (data.ref || '') + ' ผู้โอน=' + (data.sender || '');
                }
                // If already fully paid by the API, refresh and close
                if (data.fully_paid) {
                    invToast('success', 'ชำระครบแล้ว (อัพโหลดสลิป)');
                    document.getElementById('inv-payment-modal').classList.remove('open');
                    invLoadList();
                }
            } else {
                statusEl.style.background = '#fef2f2';
                statusEl.style.color = '#dc2626';
                statusEl.innerHTML = '❌ สลิปไม่ถูกต้อง' +
                    (data.reason ? '<br><span style="font-weight:400;font-size:0.8rem;">' + escH(data.reason) + '</span>' : '') +
                    (data.amount ? '<br><span style="font-weight:400;font-size:0.8rem;">ยอด: ฿' + invFmt(data.amount) + '</span>' : '');
            }
        });
    };
    reader.readAsDataURL(file);
};

