        banner.innerHTML = '<i class="fa-solid fa-credit-card"></i> а№Җаё„аёЈаё”аёҙаё•аё„аёҮа№Җаё«аёҘаё·аёӯ аёҝ' + invFmt(avail) + ' / аёҝ' + invFmt(p.credit_limit);
        banner.style.display = '';

