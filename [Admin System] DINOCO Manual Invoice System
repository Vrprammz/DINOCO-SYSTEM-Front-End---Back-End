    $row['global_disc_pct'] = floatval(get_post_meta($id, '_inv_global_disc_pct', true));
    $row['global_disc_val'] = floatval(get_post_meta($id, '_inv_global_disc_val', true));
    $row['ship_fee']        = floatval(get_post_meta($id, '_inv_ship_fee', true));
    $row['dist_phone']    = get_field('dist_phone', $id);
    $row['dist_address']  = get_field('dist_address', $id);
    $row['dist_district'] = get_field('dist_district', $id);
    $row['dist_city']     = get_field('dist_city', $id);
    $row['dist_province'] = get_field('dist_province', $id);
    $row['dist_postcode'] = get_field('dist_postcode', $id);
    $row['partial_payments'] = json_decode(get_post_meta($id, '_inv_partial_payments', true) ?: '[]', true);
    $row['audit_log']  = get_post_meta($id, '_b2b_audit_log', true) ?: [];
    $row['slip_ref']   = get_post_meta($id, '_inv_slip_ref', true);
    $row['reference']  = get_post_meta($id, '_inv_reference', true);
    return rest_ensure_response(['success' => true, 'invoice' => $row]);
}

