// ========= SAVE =========
function invBuildPayload() {
    var items = [];
    document.querySelectorAll('#inv-prod-tbody tr:not(.inv-child-tr)').forEach(function(tr) {
        var discRaw = tr.querySelector('[data-field="discount_raw"]').value.trim();
        var discVal = 0, discPct = 0;
        if (discRaw.endsWith('%')) discPct = parseFloat(discRaw) || 0;
        else discVal = parseFloat(discRaw) || 0;
        var childrenInput = tr.querySelector('[data-field="children"]');
        var childrenVal = [];
        try { childrenVal = JSON.parse(childrenInput ? childrenInput.value : '[]') || []; } catch(e) {}
        items.push({
            type:        tr.querySelector('[data-field="type"]').value,
            sku:         tr.querySelector('[data-field="sku"]').value.trim(),
            description: tr.querySelector('[data-field="description"]').value.trim(),
            qty:         parseInt(tr.querySelector('[data-field="qty"]').value) || 1,
            unit_price:  parseFloat(tr.querySelector('[data-field="unit_price"]').value) || 0,
            discount_val: discVal,
            discount_pct: discPct,
            children:    childrenVal,
        });
    });
    var gdRaw = document.getElementById('inv-f-global-disc').value.trim();
    return {
        dist_id:             document.getElementById('inv-f-dist').value,
        items:               items,
        admin_note:          document.getElementById('inv-f-note').value,
        reference:           document.getElementById('inv-f-ref').value,
        due_date:            document.getElementById('inv-f-due').value,
        shipping_fee:        parseFloat(document.getElementById('inv-f-ship').value) || 0,
        global_discount_val: gdRaw.endsWith('%') ? 0 : (parseFloat(gdRaw)||0),
        global_discount_pct: gdRaw.endsWith('%') ? (parseFloat(gdRaw)||0) : 0,
    };
}

window.invSave = function(issue) {
    var payload = invBuildPayload();
    if (!payload.dist_id) { invToast('error', 'กรุณาเลือกตัวแทนจำหน่าย'); return; }
    if (!payload.items.length || !payload.items.some(function(i){ return i.description; })) {
        invToast('error', 'กรุณาใส่รายการสินค้าอย่างน้อย 1 รายการ'); return;
    }
    var editId = document.getElementById('inv-edit-id').value;
    if (issue) payload.issue = true;

    if (editId) {
        payload.id = editId;
        invApi('POST', '/invoice/update', payload, function(err, data) {
            if (err || !data.success) { invToast('error', 'บันทึกล้มเหลว'); return; }
            invToast('success', 'บันทึกเรียบร้อย');
            if (issue) {
                invApi('POST', '/invoice/issue', {id: editId}, function(e2, d2){
                    if (!e2 && d2 && d2.success) invToast('success', 'ออกใบแจ้งหนี้/วางบิลเรียบร้อย — ส่ง LINE แล้ว');
                    else invToast('error', 'ออกบิลล้มเหลว');
                    invCloseBuilder();
                });
            } else {
                invCloseBuilder();
            }
        });
    } else {
        invApi('POST', '/invoice/create', payload, function(err, data) {
            if (err || !data.success) { invToast('error', 'สร้าง invoice ล้มเหลว'); return; }
            invToast('success', 'สร้าง ' + data.inv_number + ' เรียบร้อย');
            if (issue && !data.issued) invToast('error', 'ออกบิลล้มเหลว: ' + (data.issue_error||''));
            else if (issue) invToast('success', 'ส่ง LINE Flex Card ไปยังตัวแทนแล้ว');
            invCloseBuilder();
        });
    }
};

window.invConfirmIssue = function() {
    var distName = document.getElementById('inv-f-dist-search').value || '?';
