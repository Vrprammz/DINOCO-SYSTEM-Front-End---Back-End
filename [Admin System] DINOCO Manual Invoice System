        invApi('POST', '/invoice/update', payload, function(err, data) {
            _invBusy.save = false;
            if (err || !data.success) { invToast('error', 'аёҡаёұаёҷаё—аё¶аёҒаёҘа№үаёЎа№Җаё«аёҘаё§: ' + (data&&data.message||'')); return; }
