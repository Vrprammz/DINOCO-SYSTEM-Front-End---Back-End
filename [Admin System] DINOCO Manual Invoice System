add_action('rest_api_init', function() {
    $ns   = 'b2b/v1';
    $perm = function(WP_REST_Request $req) {
        return wp_verify_nonce($req->get_header('X-WP-Nonce'), 'wp_rest')
            && current_user_can('manage_options');
    };

    // List invoices
    register_rest_route($ns, '/invoice/list', [
        'methods'             => 'GET',
        'callback'            => 'dinoco_inv_rest_list',
        'permission_callback' => $perm,
    ]);
    // Get single
    register_rest_route($ns, '/invoice/get', [
        'methods'             => 'GET',
        'callback'            => 'dinoco_inv_rest_get',
        'permission_callback' => $perm,
    ]);
    // Create
    register_rest_route($ns, '/invoice/create', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_create',
        'permission_callback' => $perm,
    ]);
    // Update draft
    register_rest_route($ns, '/invoice/update', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_update',
        'permission_callback' => $perm,
    ]);
    // Issue (draft → awaiting_payment)
    register_rest_route($ns, '/invoice/issue', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_issue',
        'permission_callback' => $perm,
    ]);
    // Record payment
    register_rest_route($ns, '/invoice/record-payment', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_record_payment',
        'permission_callback' => $perm,
    ]);
    // Verify slip (Slip2Go)
    register_rest_route($ns, '/invoice/verify-slip', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_verify_slip',
        'permission_callback' => $perm,
    ]);
    // Cancel
    register_rest_route($ns, '/invoice/cancel', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_cancel',
        'permission_callback' => $perm,
    ]);
    // Delete
    register_rest_route($ns, '/invoice/delete', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_delete',
        'permission_callback' => $perm,
    ]);
    // Bot toggle (Snippet 9 extension — safe to register here too)
    register_rest_route($ns, '/distributor/toggle-bot', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_toggle_bot',
        'permission_callback' => $perm,
    ]);
    // Dunning: manual trigger
    register_rest_route($ns, '/invoice/send-reminder', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_send_reminder',
        'permission_callback' => $perm,
    ]);
    register_rest_route($ns, '/invoice/send-overdue-notice', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_send_overdue_notice',
        'permission_callback' => $perm,
    ]);
    // Re-send LINE Flex Card
    register_rest_route($ns, '/invoice/resend-line', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_resend_line',
        'permission_callback' => $perm,
    ]);
});

