if (!function_exists('b2b_log')) {
    function b2b_log($msg) { error_log('[DINOCO-INV] ' . $msg); }
}

// One-time backfill: set source_group_id on existing manual invoices that are missing it
// Required so b2b_recalculate_debt() includes them in debt calculation
add_action('init', function() {
    if (get_option('_dinoco_inv_backfill_source_group_v1')) return;
    $ids = get_posts(['post_type' => 'b2b_order', 'post_status' => 'publish', 'numberposts' => -1,
        'meta_query' => [['key' => '_order_source', 'value' => 'manual_invoice']],
        'fields' => 'ids']);
    foreach ($ids as $id) {
        if (get_field('source_group_id', $id)) continue; // already set
        $dist_id = intval(get_post_meta($id, '_dist_post_id', true));
        if (!$dist_id) continue;
        $gid = get_field('line_group_id', $dist_id);
        if ($gid) update_field('source_group_id', $gid, $id);
    }
    update_option('_dinoco_inv_backfill_source_group_v1', 1);
}, 20);

if (!function_exists('b2b_date')) {
    function b2b_date($format, $timestamp = null) {
        $tz = new DateTimeZone('Asia/Bangkok');
        $dt = $timestamp ? (new DateTime('@' . $timestamp))->setTimezone($tz) : new DateTime('now', $tz);
        return $dt->format($format);
    }
}

