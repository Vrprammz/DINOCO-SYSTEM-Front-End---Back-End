    function tick() {
        var dd = document.getElementById('inv-sku-ac-floating');
        if (!dd || !dd.classList.contains('open') || !_invAcInput) {
            _invAcStopTracking();
            return;
        }
        var rect = _invAcInput.getBoundingClientRect();
        // If input scrolled out of viewport, close dropdown
        if (rect.bottom < 0 || rect.top > window.innerHeight || rect.right < 0 || rect.left > window.innerWidth) {
            dd.classList.remove('open');
            _invAcStopTracking();
            return;
        }
        // Check if there is enough space below; if not, show above
        var ddHeight = dd.offsetHeight || 200;
        var spaceBelow = window.innerHeight - rect.bottom;
        if (spaceBelow < ddHeight && rect.top > ddHeight) {
            dd.style.top = (rect.top - ddHeight - 4) + 'px';
        } else {
            dd.style.top = (rect.bottom + 4) + 'px';
        }
        dd.style.left = rect.left + 'px';
        dd.style.width = Math.max(rect.width, 420) + 'px';
        _invAcRafId = requestAnimationFrame(tick);
    }
    _invAcRafId = requestAnimationFrame(tick);
}

function _invAcStopTracking() {
    if (_invAcRafId) {
        cancelAnimationFrame(_invAcRafId);
        _invAcRafId = null;
    }
}

window.invSkuAcSearch = function(input) {
    clearTimeout(_invAcTimer);
    _invAcInput = input;
    var q = input.value.trim().toLowerCase();
    var dd = document.getElementById('inv-sku-ac-floating');
    if (!dd) return;
    if (q.length < 1) { dd.classList.remove('open'); _invAcStopTracking(); return; }

    _invAcTimer = setTimeout(function() {
        var filtered = invProducts.filter(function(p) {
            return (p.product_sku || '').toLowerCase().includes(q) || (p.title || '').toLowerCase().includes(q);
        });
        if (!filtered.length) { dd.classList.remove('open'); _invAcStopTracking(); return; }

        // Initial position (rAF loop will keep updating)
        var rect = input.getBoundingClientRect();
        dd.style.top  = (rect.bottom + 4) + 'px';
        dd.style.left = rect.left + 'px';
        dd.style.width = Math.max(rect.width, 420) + 'px';

        dd.innerHTML = filtered.slice(0, 15).map(function(p) {
            var price = invGetRankPrice(p);
            var isSet = p.children && p.children.length > 0;
            return '<div class="inv-sku-ac-item" data-sku="' + escH(p.product_sku) + '">' +
                (p.img ? '<img src="' + escH(p.img) + '" alt="" loading="lazy">' : '<div style="width:40px;height:40px;border-radius:6px;background:#f1f5f9;flex-shrink:0;"></div>') +
                '<div style="min-width:0;flex:1;"><span class="ac-sku">' + escH(p.product_sku) + '</span>' +
                (isSet ? ' <span class="ac-badge">SET</span>' : '') +
                '<br><span class="ac-name">' + escH(p.title) + '</span></div>' +
                '<span class="ac-price">аёҝ' + invFmt(price) + '</span></div>';
        }).join('');
        dd.classList.add('open');

        // Start rAF tracking loop so dropdown follows input on scroll
        _invAcStartTracking();

        // Attach click handlers
        dd.querySelectorAll('.inv-sku-ac-item').forEach(function(el) {
            el.addEventListener('mousedown', function(e) {
                e.preventDefault(); // prevent blur before click fires
                var sku = this.dataset.sku;
                var prod = invProducts.find(function(p) { return p.product_sku === sku; });
                if (!prod || !_invAcInput) return;
                var tr = _invAcInput.closest('tr');
                if (!tr) return;
                var price = invGetRankPrice(prod);
                invApplyProductToRow(tr, prod, price);
                dd.classList.remove('open');
                _invAcStopTracking();
            });
        });
    }, 150);
};

// Shared: apply product data to a row (used by both picker and autocomplete).
// V.34.5: `price` arg = last-resort fallback only (when both info.base and info.effective
//         are 0 вҖ” e.g. corrupted product record). Normal path uses info.base + disc%.
function invApplyProductToRow(tr, p, price) {
    var vals = _invPickerVals(p, price);
    tr.querySelector('[data-field="sku"]').value         = p.product_sku || '';
    tr.querySelector('[data-field="description"]').value = p.title || '';
    tr.querySelector('[data-field="unit_price"]').value  = vals.unit_price;
    tr.querySelector('[data-field="type"]').value        = (p.children && p.children.length) ? 'set' : 'product';
    tr.querySelector('[data-field="discount_raw"]').value = vals.discount_raw;
    var childSkus = (p.children && p.children.length) ? p.children : [];
    var childInput = tr.querySelector('[data-field="children"]');
    if (childInput) childInput.value = JSON.stringify(childSkus);
    _invRenderChildrenRow(tr, childSkus);
    var imgInput = tr.querySelector('[data-field="img_url"]');
    var imgCell  = tr.querySelector('.cell-img');
    if (imgInput) imgInput.value = p.img || '';
    if (imgCell) {
        var existing = imgCell.querySelector('img, .inv-prod-thumb-placeholder');
        if (existing) existing.remove();
        if (p.img) {
            var imgEl = document.createElement('img');
            imgEl.className = 'inv-prod-thumb'; imgEl.src = p.img; imgEl.alt = ''; imgEl.loading = 'lazy';
            imgCell.appendChild(imgEl);
        } else {
            var ph = document.createElement('span'); ph.className = 'inv-prod-thumb-placeholder';
            imgCell.appendChild(ph);
        }
    }
    invRecalc();
    // Auto-add empty row if no empty row at bottom
    _invAutoAddEmptyRow();
}

// Auto-add an empty row if no empty row exists at the bottom
function _invAutoAddEmptyRow() {
    var tbody = document.getElementById('inv-prod-tbody');
    var rows = tbody.querySelectorAll('tr:not(.inv-child-tr)');
    if (!rows.length) { invAddCustomRow(); return; }
    var last = rows[rows.length - 1];
    var sku  = last.querySelector('[data-field="sku"]').value.trim();
    var desc = last.querySelector('[data-field="description"]').value.trim();
    // If the last row has data, add a new empty row
    if (sku || desc) {
        invAddCustomRow();
    }
}

