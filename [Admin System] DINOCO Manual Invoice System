function dinoco_inv_reverse_debt($post_id) {
    if (get_post_meta($post_id, '_order_source', true) !== 'manual_invoice') return;
    if (!get_field('is_billed', $post_id)) return;
    $dist_id = intval(get_post_meta($post_id, '_dist_post_id', true));
    if (!$dist_id || get_post_type($dist_id) !== 'distributor') return;
    $total = floatval(get_field('total_amount', $post_id));
    if ($total <= 0) return;
    // V.34.0 HIGH-H5 FIX: removed direct update_field('current_debt') fallback (line 607).
    // Bypassing Snippet 13 = no FOR UPDATE lock + no audit + no credit_hold reset.
    // If atomic helpers missing вҶ’ return WP_Error to caller; admin reconciles manually.
    if (function_exists('b2b_recalculate_debt')) {
        update_field('is_billed', false, $post_id);
        b2b_recalculate_debt($dist_id);
    } elseif (function_exists('b2b_debt_subtract')) {
        update_field('is_billed', false, $post_id);
        b2b_debt_subtract($dist_id, $total, 'manual_invoice_reverse:'.$post_id, $post_id);
    } else {
        b2b_log('[CRITICAL] Manual Invoice V.34.0 reverse_debt: b2b_recalculate_debt + b2b_debt_subtract both missing вҖ” debt NOT reversed for dist=' . $dist_id . ' amount=' . $total . ' (admin must reconcile manually)');
        return new WP_Error('debt_helper_missing',
            'аёЈаё°аёҡаёҡаёҡаёұаёҚаёҠаёөаё«аёҷаёөа№үа№„аёЎа№ҲаёһаёЈа№үаёӯаёЎа№ғаёҠа№үаёҮаёІаёҷ вҖ” аёҒаёЈаёёаё“аёІаё•аёЈаё§аёҲаёӘаёӯаёҡ Snippet 1/13 (admin: аё«аёҷаёөа№үаёўаёұаёҮа№„аёЎа№ҲаёӣаёЈаёұаёҡ)',
            ['status' => 503]);
    }
    b2b_add_audit_log($post_id, 'debt_reversed', 'аёўаёҒа№ҖаёҘаёҙаёҒаёҡаёҙаёҘ аёҝ' . number_format($total, 0) . ' вҖ” аё«аёұаёҒаё«аёҷаёөа№үаё•аёұаё§а№Ғаё—аёҷа№ҒаёҘа№үаё§');
}

