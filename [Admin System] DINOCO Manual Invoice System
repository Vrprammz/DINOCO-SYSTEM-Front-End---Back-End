function invFillDistInfo(distId) {
    var dist = invDistributors.find(function(d){ return d.id == distId; });
    if (!dist) return;
    document.getElementById('inv-f-phone').value = dist.dist_phone || '';
    var addr = [dist.dist_address, dist.dist_district, dist.dist_city, dist.dist_province, dist.dist_postcode].filter(Boolean).join(', ');
    document.getElementById('inv-f-addr').value = addr;
    // Credit banner
    var banner = document.getElementById('inv-credit-banner');
    var limit  = parseFloat(dist.credit_limit) || 0;
    var debt   = parseFloat(dist.current_debt) || 0;
    var avail  = limit - debt;
    var cls    = avail > 10000 ? 'inv-credit-ok' : (avail > 0 ? 'inv-credit-warn' : 'inv-credit-danger');
    banner.className = 'inv-credit-banner ' + cls;
    banner.innerHTML = '<i class="fa-solid fa-credit-card"></i> เครดิตคงเหลือ ฿' + invFmt(avail) + ' / ฿' + invFmt(limit) +
        (dist.credit_hold ? ' <strong>⚠️ ระงับเครดิต</strong>' : '');
    banner.style.display = '';
}

