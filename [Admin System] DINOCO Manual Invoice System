add_action('rest_api_init', function() {
    $ns   = 'b2b/v1';
    $perm = function(WP_REST_Request $req) {
        return wp_verify_nonce($req->get_header('X-WP-Nonce'), 'wp_rest')
            && current_user_can('manage_options');
    };

    // V.33.6: Re-register /products route (removed in Snippet 9 V.35.0 вҖ” frontend invLoadProducts still needs it)
    // Reuses b2b_rest_list_products() which still exists in Snippet 9 as dead code.
    // Guarded with function_exists so the route gracefully degrades if Snippet 9 is disabled.
    register_rest_route($ns, '/products', [
        'methods'             => 'GET',
        'callback'            => function(WP_REST_Request $req) {
            if (!function_exists('b2b_rest_list_products')) {
                return new WP_Error('products_unavailable',
                    'b2b_rest_list_products() not loaded вҖ” check Snippet 9 Admin Control Panel',
                    ['status' => 503]);
            }
            return b2b_rest_list_products($req);
        },
        'permission_callback' => $perm,
    ]);

    // List invoices
    register_rest_route($ns, '/invoice/list', [
        'methods'             => 'GET',
        'callback'            => 'dinoco_inv_rest_list',
        'permission_callback' => $perm,
    ]);
    // Get single
    register_rest_route($ns, '/invoice/get', [
        'methods'             => 'GET',
        'callback'            => 'dinoco_inv_rest_get',
        'permission_callback' => $perm,
    ]);
    // Init вҖ” create empty draft immediately (reserves invoice number)
    register_rest_route($ns, '/invoice/init', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_init',
        'permission_callback' => $perm,
    ]);
    // Create
    register_rest_route($ns, '/invoice/create', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_create',
        'permission_callback' => $perm,
    ]);
    // Update draft
    register_rest_route($ns, '/invoice/update', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_update',
        'permission_callback' => $perm,
    ]);
    // Issue (draft вҶ’ awaiting_payment)
    register_rest_route($ns, '/invoice/issue', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_issue',
        'permission_callback' => $perm,
    ]);
    // Record payment
    register_rest_route($ns, '/invoice/record-payment', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_record_payment',
        'permission_callback' => $perm,
    ]);
    // Verify slip (Slip2Go) вҖ” single invoice
    register_rest_route($ns, '/invoice/verify-slip', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_verify_slip',
        'permission_callback' => $perm,
    ]);
    // V.2.6: Combined slip verify вҖ” auto-match across multiple invoices
    register_rest_route($ns, '/invoice/verify-slip-combined', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_verify_slip_combined',
        'permission_callback' => $perm,
    ]);
    // V.2.7: Upload slip image (base64) from dashboard
    register_rest_route($ns, '/invoice/upload-slip', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_upload_slip',
        'permission_callback' => $perm,
    ]);
    // V.33.3 вҖ” Audit C2: Record refund (reverse payment)
    register_rest_route($ns, '/invoice/record-refund', [
        'methods'             => 'POST',
        'callback'            => 'dinoco_inv_rest_record_refund',
        'permission_callback' => $perm,
