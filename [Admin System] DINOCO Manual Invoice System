// Helper: get rank-based price for a product object
function invGetRankPrice(p) {
    var dist = invDistributors.find(function(d){ return d.id == document.getElementById('inv-f-dist').value; });
    var rank = dist ? (dist.rank_system || 'standard') : 'standard';
    var priceField = 'price_' + rank;
    return parseFloat(p[priceField] || p.catalog_price || p.dealer_price || 0);
}

window.invFilterPicker = function() {
    var q = document.getElementById('inv-picker-search').value.toLowerCase();
    var list = document.getElementById('inv-prod-picker-list');
    var filtered = invProducts.filter(function(p){
        if (invPickerTab === 'set' && !(p.children && p.children.length > 0)) return false;
        return !q || (p.product_sku||'').toLowerCase().includes(q) || (p.title||'').toLowerCase().includes(q);
    });
    if (!filtered.length) { list.innerHTML = '<p style="padding:16px;color:#94a3b8;text-align:center;">ไม่พบสินค้า</p>'; return; }
    list.innerHTML = filtered.slice(0,80).map(function(p) {
