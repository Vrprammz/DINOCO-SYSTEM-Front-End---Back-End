        return '<div class="inv-picker-item" onclick="invPickProduct(' + JSON.stringify(p).replace(/"/g,'&quot;') + ',' + (parseFloat(price)||0) + ')">' +
            (p.img ? '<img src="' + escH(p.img) + '" alt="" loading="lazy">' : '<div style="width:52px;height:52px;border-radius:6px;background:#f1f5f9;flex-shrink:0;margin-right:10px;"></div>') +
            '<div style="flex:1;min-width:0;"><span class="pi-name">' + escH(p.title) + '</span>' +
            (isSet ? '<span class="pi-badge">SET</span>' : '') +
            '<br><span class="pi-sku">' + escH(p.product_sku) + '</span></div>' +
            '<span class="pi-price">฿' + invFmt(price) + '</span></div>';
