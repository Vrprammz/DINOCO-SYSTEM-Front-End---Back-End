    var label = document.getElementById('inv-cs-verify-label');
    btn.disabled = true;
    label.textContent = 'กำลังตรวจ...';

    invApi('POST', '/invoice/verify-slip-combined', { dist_id: distId, slip_url: url }, function(err, data) {
        btn.disabled = false;
        label.textContent = 'ตรวจสลิป';
        if (err || !data) { invToast('error', 'เชื่อมต่อ API ล้มเหลว'); return; }
        if (!data.verified) { invToast('error', data.reason || 'สลิปไม่ผ่าน'); return; }

        var resultDiv = document.getElementById('inv-cs-result');
        var html = '';

        if (data.match_type === 'no_match') {
            // ไม่ match — แสดงบิลให้ admin เลือก allocate
            html += '<div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:16px;margin-bottom:12px;">';
            html += '<div style="font-weight:700;color:#dc2626;margin-bottom:8px;">⚠️ ยอดสลิป ฿' + invFmt(data.slip_amount) + ' ไม่ตรงกับบิลใดๆ</div>';
            html += '<p style="font-size:0.82rem;color:#64748b;margin:0;">เลือกบิลที่ต้องการตัดยอด แล้วกด "บันทึกรับเงิน" ด้านล่าง</p>';
            html += '</div>';
            html += '<div style="max-height:200px;overflow-y:auto;">';
            (data.pending || []).forEach(function(inv) {
                html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:8px;border-bottom:1px solid #f1f5f9;">' +
                    '<span><strong>' + escH(inv.inv_number) + '</strong> <span style="color:#94a3b8;font-size:0.78rem;">' + escH(inv.due_date) + '</span></span>' +
                    '<span style="font-weight:600;">฿' + invFmt(inv.remaining) + '</span>' +
                    '</div>';
            });
            html += '</div>';
            html += '<p style="font-size:0.82rem;color:#f59e0b;margin-top:12px;">💡 กดปิดแล้วเปิดบิลที่ต้องการ → กด "บันทึกรับเงิน" ระบุยอดเอง</p>';
        } else {
            // Match สำเร็จ
            var color = '#16a34a';
            var icon = '✅';
            html += '<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:16px;margin-bottom:12px;">';
            html += '<div style="font-weight:700;color:' + color + ';margin-bottom:8px;">' + icon + ' ' + escH(data.message) + '</div>';
            html += '<div style="font-size:0.85rem;color:#64748b;">สลิป: ฿' + invFmt(data.slip_amount) + ' (ref: ' + escH(data.slip_ref || '-') + ')</div>';
            html += '</div>';
            if (data.matched && data.matched.length) {
                html += '<div style="margin-top:8px;">';
                data.matched.forEach(function(m) {
                    html += '<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f1f5f9;">' +
                        '<span>' + escH(m.inv_number) + '</span><span style="color:#16a34a;font-weight:600;">฿' + invFmt(m.amount) + ' ✓</span></div>';
                });
                html += '</div>';
            }
        }

        document.getElementById('inv-cs-step1').style.display = 'none';
        resultDiv.innerHTML = html;
        resultDiv.style.display = '';
        invLoadList(); // refresh list
    });
};

// ========= SUMMARY SEND (V.2.5) =========
var invSmSelectedDist = null;
var invSmPreviewData  = null;

window.invOpenSummaryModal = function() {
    invSmSelectedDist = null;
    invSmPreviewData  = null;
    document.getElementById('inv-sm-dist-id').value = '';
    document.getElementById('inv-sm-dist-search').value = '';
    document.getElementById('inv-sm-step1').style.display = '';
    document.getElementById('inv-sm-step2').style.display = 'none';
    document.getElementById('inv-sm-loading').style.display = 'none';
    document.getElementById('inv-sm-send-btn').disabled = true;
    document.getElementById('inv-sm-send-label').textContent = 'เลือกตัวแทนก่อน';
    var modal = document.getElementById('inv-summary-modal');
    modal.style.display = 'flex';
    if (!invDistributors.length) invLoadDistributors();
};

window.invCloseSummaryModal = function() {
    document.getElementById('inv-summary-modal').style.display = 'none';
};

document.getElementById('inv-summary-modal').addEventListener('click', function(e) {
    if (e.target === this) invCloseSummaryModal();
});

window.invSmDistSearch = function() {
    var q  = (document.getElementById('inv-sm-dist-search').value || '').toLowerCase().trim();
    var dd = document.getElementById('inv-sm-dist-dd');
    if (!invDistributors.length) { invLoadDistributors(); return; }
    var filtered = invDistributors.filter(function(d) {
        if (!q) return true;
        return (d.shop_name||d.name||'').toLowerCase().indexOf(q) >= 0 ||
               (d.dist_phone||'').indexOf(q) >= 0;
    });
    if (!filtered.length) {
        dd.innerHTML = '<div style="padding:12px 16px;color:#94a3b8;font-size:0.85rem;">ไม่พบตัวแทน</div>';
    } else {
        dd.innerHTML = filtered.slice(0, 20).map(function(d) {
            var name = escH(d.shop_name || d.name || '');
            var noGroup = !d.line_group_id;
            var badge = noGroup ? ' <span style="color:#dc2626;font-size:0.75rem;">(ไม่มี LINE group)</span>' : '';
            return '<div style="padding:10px 14px;cursor:pointer;border-bottom:1px solid #f1f5f9;' + (noGroup ? 'opacity:0.5;' : '') + '" onmouseover="this.style.background=\'#f0f9ff\'" onmouseout="this.style.background=\'\'" onclick="invSmSelectDist(' + d.id + ')">' +
                name + badge + '</div>';
        }).join('');
    }
    dd.style.display = 'block';
};

window.invSmSelectDist = function(id) {
    var dist = invDistributors.find(function(d){ return d.id == id; });
    if (!dist) return;
    if (!dist.line_group_id) {
        invToast('error', (dist.shop_name||dist.name) + ' ไม่มี LINE group');
        return;
    }
    invSmSelectedDist = dist;
    document.getElementById('inv-sm-dist-id').value = id;
    document.getElementById('inv-sm-dist-search').value = dist.shop_name || dist.name || '';
    document.getElementById('inv-sm-dist-dd').style.display = 'none';
    document.getElementById('inv-sm-loading').style.display = '';
    document.getElementById('inv-sm-send-btn').disabled = true;
    document.getElementById('inv-sm-send-label').textContent = 'กำลังโหลด...';

    invApi('GET', '/invoice/pending-summary', { dist_id: id }, function(err, data) {
        document.getElementById('inv-sm-loading').style.display = 'none';
        if (err || !data || !data.success) { invToast('error', 'โหลดข้อมูลล้มเหลว'); return; }
        if (!data.count) { invToast('info', 'ไม่มีบิลค้างชำระสำหรับตัวแทนนี้'); return; }
        invSmPreviewData = data;
        // Render preview
        var html = '<div style="font-weight:700;font-size:0.92rem;margin-bottom:10px;color:#92400e;">' + escH(dist.shop_name || dist.name) + '</div>';
        html += '<div style="display:flex;justify-content:space-between;font-size:0.85rem;padding:3px 0;"><span>บิลค้างชำระ</span><span style="font-weight:600;">' + data.count + ' ใบ</span></div>';
        html += '<div style="border-top:1px dashed #fde68a;margin:8px 0;"></div>';
        html += '<div style="max-height:160px;overflow-y:auto;">';
        (data.invoices || []).forEach(function(inv) {
            var badge = '';
            if (inv.overdue_days > 0) badge = '<span style="color:#dc2626;font-size:0.75rem;font-weight:600;"> เกิน ' + inv.overdue_days + ' วัน</span>';
            else if (inv.overdue_days < 0) badge = '<span style="color:#16a34a;font-size:0.75rem;"> เหลือ ' + Math.abs(inv.overdue_days) + ' วัน</span>';
            html += '<div style="display:flex;justify-content:space-between;align-items:center;font-size:0.82rem;padding:4px 0;border-bottom:1px solid #fef3c7;">' +
                '<span>' + escH(inv.inv_number) + ' <span style="color:#94a3b8;font-size:0.78rem;">' + escH(inv.date) + '</span></span>' +
                '<span>฿' + invFmt(inv.amount) + badge + '</span></div>';
        });
        html += '</div>';
        html += '<div style="border-top:1px dashed #fde68a;margin:8px 0;"></div>';
        html += '<div style="display:flex;justify-content:space-between;font-size:0.85rem;padding:3px 0;"><span>ยอดค้างรวม</span><span style="font-weight:700;font-size:1rem;color:#dc2626;">฿' + invFmt(data.total) + '</span></div>';
        document.getElementById('inv-sm-preview').innerHTML = html;
        document.getElementById('inv-sm-step1').style.display = 'none';
        document.getElementById('inv-sm-step2').style.display = '';
        document.getElementById('inv-sm-send-btn').disabled = false;
        document.getElementById('inv-sm-send-label').textContent = 'ส่งสรุป ' + data.count + ' ใบ (฿' + invFmt(data.total) + ')';
    });
};

window.invSmBackToStep1 = function() {
    document.getElementById('inv-sm-step1').style.display = '';
    document.getElementById('inv-sm-step2').style.display = 'none';
    document.getElementById('inv-sm-send-btn').disabled = true;
    document.getElementById('inv-sm-send-label').textContent = 'เลือกตัวแทนก่อน';
    invSmPreviewData = null;
};

window.invDoSendSummary = function() {
    if (!invSmSelectedDist || !invSmPreviewData) return;
    var btn = document.getElementById('inv-sm-send-btn');
    var label = document.getElementById('inv-sm-send-label');
    btn.disabled = true;
    label.textContent = 'กำลังส่ง...';
    invApi('POST', '/invoice/send-summary', { dist_id: invSmSelectedDist.id }, function(err, data) {
        if (err || !data || !data.success) {
            btn.disabled = false;
            label.textContent = 'ส่งสรุป ' + invSmPreviewData.count + ' ใบ (฿' + invFmt(invSmPreviewData.total) + ')';
            invToast('error', data && data.message ? data.message : 'ส่งไม่สำเร็จ');
            return;
        }
        invCloseSummaryModal();
        invToast('success', 'ส่งสรุป ' + data.count + ' บิล ฿' + invFmt(data.total) + ' ไปยัง ' + escH(data.dist_name) + ' แล้ว');
    });
};

document.addEventListener('click', function(e) {
    if (!e.target.closest('#inv-summary-modal [style*="position:relative"]')) {
        var dd = document.getElementById('inv-sm-dist-dd');
        if (dd) dd.style.display = 'none';
    }
});

// ========= UTILS =========
function invFmt(n) {
    return parseFloat(n||0).toLocaleString('th-TH', {minimumFractionDigits:0, maximumFractionDigits:2});
}
function escH(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Close modals on backdrop click
document.getElementById('inv-prod-picker').addEventListener('click', function(e){ if(e.target===this) invClosePicker(); });
document.getElementById('inv-payment-modal').addEventListener('click', function(e){ if(e.target===this) this.classList.remove('open'); });
document.getElementById('inv-slip-modal').addEventListener('click', function(e){ if(e.target===this) this.classList.remove('open'); });

// Recalculate due date when invoice date changes (uses selected dist credit term)
document.getElementById('inv-f-date').addEventListener('change', function() {
    var distId = document.getElementById('inv-f-dist').value;
    if (!distId) return;
    var existingDue = document.getElementById('inv-f-due').value;
    if (existingDue) return;
    var dist = invDistributors.find(function(d){ return d.id == distId; });
    if (!dist || !dist.credit_term_days) return;
    var due = new Date(this.value);
    if (isNaN(due.getTime())) return;
    due.setDate(due.getDate() + parseInt(dist.credit_term_days));
    document.getElementById('inv-f-due').value = due.toISOString().slice(0,10);
});

// Init
invLoadList('all', 1);
invLoadDistributors();
invLoadProducts();

})();
</script>
