            var $dirtyCount = document.getElementById('dncSnDirtyCount');
            var $search = document.getElementById('dncSnRoleSearch');
            var $filterActive = document.getElementById('dncSnRoleFilterActive');

            function getDirtyChanges() {
                var changes = [];
                $matrix.querySelectorAll('.dnc-sn-role-cb').forEach(function(cb) {
                    var orig = cb.getAttribute('data-original') === '1';
                    if (cb.checked !== orig) {
