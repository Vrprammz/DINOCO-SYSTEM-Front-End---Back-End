                dirty.forEach(function(c) {
                    var tr = c.$cb.closest('tr');
                    if (tr) tr.style.background = '#fef3c7';
                });
            }

            function applyFilter() {
                var q = ($search.value || '').toLowerCase().trim();
                var activeOnly = $filterActive.checked;
