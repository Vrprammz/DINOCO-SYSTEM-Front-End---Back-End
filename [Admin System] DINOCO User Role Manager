                    $matrix.querySelectorAll('.dnc-sn-role-cb').forEach(function(cb) {
                        cb.checked = (cb.getAttribute('data-original') === '1');
                    });
                    updateDirtyUI();
                });
            });

            $saveBtn.addEventListener('click', function() {
                var changes = getDirtyChanges();
                if (changes.length === 0) return;

                var payload = changes.map(function(c) {
                    return { user_id: c.user_id, role: c.role, action: c.action };
                });

                $saveBtn.disabled = true;
                $saveBtn.textContent = '⏳ กำลังบันทึก...';

                fetch(DNC_SN_REST, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': DNC_SN_NONCE,
                    },
                    body: JSON.stringify({ changes: payload }),
                })
                .then(function(r) { return r.json().then(function(d) { return { status: r.status, data: d }; }); })
                .then(function(res) {
                    if (res.status >= 200 && res.status < 300) {
                        var msg = '✅ บันทึก ' + (res.data.applied || 0) + ' รายการ';
                        if (res.data.errors && res.data.errors.length) {
                            msg += ' (มี ' + res.data.errors.length + ' ข้อผิดพลาด — ดู console)';
                            console.warn('[Role Manager] errors:', res.data.errors);
                        }
                        var modalAlert = (window.dinocoModal && window.dinocoModal.alert) || function(opts) { alert(opts.content); return Promise.resolve(); };
                        modalAlert({ title: 'บันทึกสำเร็จ', content: msg }).then(function() {
                            window.location.reload();
                        });
                    } else {
                        throw new Error(res.data.message || 'บันทึกล้มเหลว');
                    }
                })
                .catch(function(err) {
                    console.error('[Role Manager] save failed:', err);
                    var modalAlert = (window.dinocoModal && window.dinocoModal.alert) || function(opts) { alert(opts.content); return Promise.resolve(); };
                    modalAlert({ title: 'ผิดพลาด', content: 'บันทึกไม่สำเร็จ: ' + (err.message || 'unknown') });
                    $saveBtn.disabled = false;
                    $saveBtn.innerHTML = '💾 บันทึกการเปลี่ยนแปลง (<span class="count">' + changes.length + '</span>)';
                });
            });

            $search.addEventListener('input', applyFilter);
            $filterActive.addEventListener('change', applyFilter);

            // Initial filter (default: show only users with SN roles)
            applyFilter();
        })();
        </script>

