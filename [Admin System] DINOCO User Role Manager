add_action( 'rest_api_init', function() {
    register_rest_route( 'dinoco/v1', '/sn-roles/bulk-assign', array(
        'methods'  => 'POST',
        'callback' => 'dinoco_sn_rest_bulk_assign_roles',
        'permission_callback' => function() {
            return current_user_can( 'manage_options' )
                && wp_verify_nonce( $_SERVER['HTTP_X_WP_NONCE'] ?? '', 'wp_rest' );
        },
    ) );
} );

if ( ! function_exists( 'dinoco_sn_rest_bulk_assign_roles' ) ) {
    /**
     * Bulk role assignment from matrix UI.
     * Body: { changes: [ {user_id, role, action: 'add'|'remove'}, ... ] }
     * Returns: { applied: N, errors: [], audit_ids: [] }
     */
    function dinoco_sn_rest_bulk_assign_roles( $request ) {
        $body = $request->get_json_params();
        $changes = isset( $body['changes'] ) && is_array( $body['changes'] ) ? $body['changes'] : array();

        if ( empty( $changes ) ) {
            return new WP_Error( 'no_changes', 'ไม่มีการเปลี่ยนแปลง', array( 'status' => 400 ) );
        }
        if ( count( $changes ) > 200 ) {
            return new WP_Error( 'too_many', 'แก้ทีละไม่เกิน 200 รายการ', array( 'status' => 413 ) );
        }

        $valid_roles = array( 'dinoco_sn_approver', 'dinoco_sn_warehouse', 'dinoco_sn_view_pii', 'dinoco_sn_readonly' );
        $applied = 0;
        $errors = array();
        $actor_id = get_current_user_id();

        foreach ( $changes as $idx => $c ) {
            $user_id = (int) ( $c['user_id'] ?? 0 );
            $role = sanitize_text_field( $c['role'] ?? '' );
            $action = sanitize_text_field( $c['action'] ?? '' );

            if ( ! $user_id || ! in_array( $role, $valid_roles, true ) || ! in_array( $action, array( 'add', 'remove' ), true ) ) {
                $errors[] = array( 'idx' => $idx, 'reason' => 'invalid_payload', 'user_id' => $user_id, 'role' => $role );
                continue;
            }

            $user = get_user_by( 'id', $user_id );
            if ( ! $user ) {
                $errors[] = array( 'idx' => $idx, 'reason' => 'user_not_found', 'user_id' => $user_id );
                continue;
            }

            // Self-protection: cannot remove own administrator/approver role
            if ( $user_id === $actor_id && $action === 'remove' && $role === 'dinoco_sn_approver' ) {
                $errors[] = array( 'idx' => $idx, 'reason' => 'cannot_remove_self_approver' );
                continue;
            }

            $had_role = in_array( $role, (array) $user->roles, true );

            if ( $action === 'add' && ! $had_role ) {
                $user->add_role( $role );
                $applied++;
                dinoco_sn_log_role_change( $user_id, $role, 'add', $actor_id );
            } elseif ( $action === 'remove' && $had_role ) {
                $user->remove_role( $role );
                $applied++;
                dinoco_sn_log_role_change( $user_id, $role, 'remove', $actor_id );
            }
            // No-op (add when already has, remove when doesn't have) — silent skip
        }

        return rest_ensure_response( array(
            'applied'    => $applied,
            'errors'     => $errors,
            'total'      => count( $changes ),
            'no_op'      => count( $changes ) - $applied - count( $errors ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_log_role_change' ) ) {
    /**
     * Audit role change. Best-effort — non-throwing.
     */
    function dinoco_sn_log_role_change( $user_id, $role, $action, $actor_id ) {
        if ( function_exists( 'dinoco_sn_audit_log' ) ) {
            dinoco_sn_audit_log( array(
                'event_type' => 'role_change',
                'sn'         => '',
                'actor_user_id' => $actor_id,
                'reason'     => sprintf( '%s role %s for user_id=%d', $action, $role, $user_id ),
                'context_json' => wp_json_encode( array(
                    'target_user_id' => $user_id,
                    'role'           => $role,
                    'action'         => $action,
                ), JSON_UNESCAPED_UNICODE ),
            ) );
        }
    }
}

