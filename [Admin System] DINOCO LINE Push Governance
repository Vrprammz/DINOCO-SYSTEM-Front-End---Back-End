 * 5. RETENTION CRON (PDPA storage limitation §17)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_line_gov_retention_run' ) ) {
    /**
     * Daily — purge log rows beyond retention window. Idempotent.
     */
    function dinoco_line_gov_retention_run() {
        update_option( 'dinoco_cron_line_gov_retention_last_run', current_time( 'mysql' ) );

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';
        $exists = $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $tbl ) );
        if ( $exists !== $tbl ) return 0;

        $days = (int) get_option( 'dinoco_line_gov_log_retention_days', DINOCO_LINE_GOV_LOG_RETENTION_DAYS );
        if ( $days < 7 ) $days = 7;   // floor — protect cap math
        if ( $days > 365 ) $days = 365;

        $cutoff = gmdate( 'Y-m-d H:i:s', time() - ( $days * 86400 ) );
        $deleted = (int) $wpdb->query( $wpdb->prepare(
            "DELETE FROM {$tbl} WHERE sent_at < %s LIMIT 5000",
            $cutoff
        ) );
        update_option( 'dinoco_line_gov_retention_last_summary', array(
            'at'      => current_time( 'mysql' ),
            'days'    => $days,
            'deleted' => $deleted,
        ), false );
        return $deleted;
    }
}

if ( ! wp_next_scheduled( 'dinoco_line_gov_retention_cron' ) ) {
    wp_schedule_event( time() + 600, 'daily', 'dinoco_line_gov_retention_cron' );
}
add_action( 'dinoco_line_gov_retention_cron', 'dinoco_line_gov_retention_run' );

