if ( ! function_exists( 'dinoco_line_gov_resolve_category' ) ) {
    /**
     * Map free-form category input (or notification_type) → canonical key.
     * Tolerates legacy strings like 'expiry_30d', 'anniversary_2y'.
     */
    function dinoco_line_gov_resolve_category( $cat ) {
        $c = strtolower( trim( (string) $cat ) );
        if ( $c === '' ) return 'marketing';
        // V.1.7 Sprint 5A — exact-match 'claim_status' BEFORE generic claim_*
        // fallback (otherwise dedicated bucket can never be reached).
        if ( $c === 'claim_status' ) return 'claim_status';
        if ( $c === 'transactional' || strpos( $c, 'claim_' ) === 0
            || strpos( $c, 'transfer_' ) === 0 || strpos( $c, 'payment_' ) === 0
            || strpos( $c, 'service_' ) === 0 ) {
            return 'transactional';
        }
        if ( strpos( $c, 'expiry_' ) === 0 || $c === 'expiry' ) return 'expiry';
        if ( strpos( $c, 'anniversary_' ) === 0 || $c === 'anniversary' ) return 'anniversary';
        if ( $c === 'review' || $c === 'review_request' || strpos( $c, 'review_' ) === 0 ) return 'review';
        if ( $c === 'marketing' || $c === 'promo' || strpos( $c, 'promo_' ) === 0 ) return 'marketing';
        // Unknown → safest default = marketing (most restrictive caps + opt-in)
        return 'marketing';
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 1. SCHEMA INSTALL (lazy + idempotent)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_line_gov_schema_install' ) ) {
    /**
     * Lazy install on admin_init. Tracked via wp_option
     * `dinoco_line_gov_schema_version` (string compare).
     */
    function dinoco_line_gov_schema_install() {
        $current = (string) get_option( 'dinoco_line_gov_schema_version', '' );
        if ( $current === DINOCO_LINE_GOV_SCHEMA_VERSION ) return;

        global $wpdb;
        $charset = $wpdb->get_charset_collate();
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';

        // R5 Perf-G4 — added idx_user_cat_date composite (user_id, category, sent_at).
        // Covers the new single conditional-aggregate cap query at perf-B1:
        // it left-prefix matches both WHERE user_id=? + category=? + sent_at>=?
        // (category cap path) AND WHERE user_id=? + sent_at>=? (daily/weekly
        // path, ignoring category). Old idx_user_date is now redundant w.r.t.
        // (user_id, sent_at) but kept to avoid an extra DROP step on schema
        // upgrade — dbDelta is not destructive on left-prefix overlaps.
        $sql = "CREATE TABLE {$tbl} (
            id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
            user_id BIGINT UNSIGNED NOT NULL,
            category VARCHAR(40) NOT NULL,
            template_code VARCHAR(64) NOT NULL DEFAULT '',
            sent_at DATETIME NOT NULL,
            success TINYINT(1) NOT NULL DEFAULT 1,
            reason VARCHAR(64) NOT NULL DEFAULT '',
            PRIMARY KEY  (id),
            KEY idx_user_date (user_id, sent_at),
            KEY idx_user_cat_date (user_id, category, sent_at),
            KEY idx_category_date (category, sent_at),
            KEY idx_sent_at (sent_at)
        ) {$charset};";

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';
        dbDelta( $sql );
        update_option( 'dinoco_line_gov_schema_version', DINOCO_LINE_GOV_SCHEMA_VERSION, false );

        // R5 Perf-G2 — invalidate static memo so next dinoco_line_gov_table_exists()
        // call re-probes (table may have just been created by dbDelta above).
        if ( function_exists( 'dinoco_line_gov_table_exists_reset' ) ) {
            dinoco_line_gov_table_exists_reset();
        }
    }
}

add_action( 'admin_init', 'dinoco_line_gov_schema_install', 5 );

/**
 * V.1.6 (2026-05-09) — One-time migration per boss directive "ส่งได้ตลอด".
 * Flips daily_cap + weekly_cap + all per-category caps from default (1/3/various)
 * to 0 (unlimited). Marks migration flag to prevent re-running. Admin can still
 * manually set non-zero caps via Admin UI; this only applies once.
 *
 * Why one-time + flag: existing installations may have admin-set caps already.
 * Without flag, every page load would force-flip → admin's manual caps would
 * be reverted on every request. Flag ensures we only flip once.
 */
if ( ! function_exists( 'dinoco_line_gov_apply_unlimited_directive_2026_05_09' ) ) {
    function dinoco_line_gov_apply_unlimited_directive_2026_05_09() {
        $flag_key = 'dinoco_line_gov_unlimited_2026_05_09';
        if ( get_option( $flag_key, 0 ) ) {
            return; // already applied
        }
        update_option( 'dinoco_line_gov_daily_cap',  0, false );
        update_option( 'dinoco_line_gov_weekly_cap', 0, false );
        // Per-category caps — iterate all known categories
        if ( function_exists( 'dinoco_line_gov_categories' ) ) {
            $cats = dinoco_line_gov_categories();
            foreach ( array_keys( $cats ) as $cat ) {
                update_option( 'dinoco_line_gov_cat_cap_' . $cat, 0, false );
            }
        }
        update_option( $flag_key, 1, false );
        if ( function_exists( 'dinoco_obs_capture' ) ) {
            dinoco_obs_capture( 'info', '[line-gov] caps flipped to unlimited per boss directive 2026-05-09', array() );
        }
    }
}
add_action( 'admin_init', 'dinoco_line_gov_apply_unlimited_directive_2026_05_09', 6 );

