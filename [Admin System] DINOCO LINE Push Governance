    /**
     * R5 Sec-G7 — `update_user_meta` filter (priority 5). Logs a warning
     * to error_log when a marketing meta key is being written with a
     * truthy value AND the caller is NOT inside dinoco_line_set_user_prefs.
     *
     * Non-blocking: this is a `update_user_meta` (not `pre_update_user_meta`)
     * style listener — we always return $check unchanged. The point is
     * observability: rogue snippets bypassing governance audit get traced
     * to a stack frame so they can be migrated to the canonical helper.
     *
     * Note: WordPress fires `update_user_meta` action AFTER a successful
     * write, so we implement on `update_user_metadata` filter (returning
     * null = "let WP proceed normally"). This way we can detect BEFORE
     * the write completes without altering write semantics.
     *
     * @param mixed  $check       null to allow default save (we always return null)
     * @param int    $object_id   user_id
     * @param string $meta_key
     * @param mixed  $meta_value
     * @return null   always — preserves default WP behavior
     */
    function dinoco_line_gov_seam_detector( $check, $object_id, $meta_key, $meta_value ) {
        // Fast path — exit early if not a governed key
        $marketing_keys = dinoco_line_gov_marketing_meta_keys();
        if ( ! in_array( $meta_key, $marketing_keys, true ) ) return $check;

        // Inside the canonical helper? Skip silently.
        $guard = &dinoco_line_gov_inside_helper();
        if ( $guard['count'] > 0 ) return $check;

        // Truthy check — empty/'0'/false writes are de-opt-in (always allowed
        // without governance friction; PDPA "opt-out" is non-restrictive).
        $is_truthy = filter_var( $meta_value, FILTER_VALIDATE_BOOLEAN );
        if ( ! $is_truthy ) return $check;

        // Capture lightweight stack trace (skip first 2 frames = filter
        // dispatcher) for caller identification. Limited depth keeps log
        // volume manageable.
        $trace = debug_backtrace( DEBUG_BACKTRACE_IGNORE_ARGS, 6 );
        $frames = array();
        foreach ( array_slice( $trace, 2, 4 ) as $f ) {
            $loc  = isset( $f['file'] )     ? basename( (string) $f['file'] ) : '?';
            $line = isset( $f['line'] )     ? (int) $f['line']                : 0;
            $fn   = isset( $f['function'] ) ? (string) $f['function']         : '?';
            $frames[] = "{$loc}:{$line}:{$fn}";
        }

        error_log( sprintf(
            '[LINE-GOV][SEAM] direct write to %s (uid=%d, value=%s) bypasses dinoco_line_set_user_prefs(); trace=%s',
            $meta_key,
            (int) $object_id,
            wp_json_encode( $meta_value ),
            implode( ' <- ', $frames )
        ) );

        return $check;
    }
    add_filter( 'update_user_metadata', 'dinoco_line_gov_seam_detector', 5, 4 );
    // Also catch first-time inserts (some plugins use add_user_meta then
    // expect update semantics on next call; without this hook a rogue
    // ADD slips past the detector entirely).
    add_filter( 'add_user_metadata',    'dinoco_line_gov_seam_detector', 5, 4 );
}

