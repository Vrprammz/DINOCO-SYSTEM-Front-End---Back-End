/* ═══════════════════════════════════════════════════════════════════════════
 * 3. QUIET HOURS
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_line_in_quiet_hours' ) ) {
    /**
     * Returns true if NOW falls outside the user's allowed window.
     *
     * Transactional category bypasses (contract performance — claims
     * land any time of day per boss approval).
     *
     * Default window: 09:00–20:00 Asia/Bangkok inclusive.
     * Per-user override:
     *   wp_usermeta dinoco_sn_quiet_hours_start (HH or HH:MM, 24h)
     *   wp_usermeta dinoco_sn_quiet_hours_end   (HH or HH:MM, 24h)
     *
     * "in quiet hours" = OUTSIDE the allowed window. Naming preserved
     * to match user-supplied spec.
     *
     * @return bool true => caller should NOT push now (reschedule)
     */
    function dinoco_line_in_quiet_hours( $user_id, $category = '' ) {
        $cat = dinoco_line_gov_resolve_category( $category );
        if ( $cat === 'transactional' ) return false; // bypass

        $tz = function_exists( 'wp_timezone' ) ? wp_timezone() : new \DateTimeZone( 'Asia/Bangkok' );
        try {
            $now_local = new \DateTime( 'now', $tz );
        } catch ( \Throwable $e ) {
            return false; // fail-open
        }
        $now_min = ( (int) $now_local->format( 'H' ) * 60 ) + (int) $now_local->format( 'i' );

        // Defaults (admin-tunable)
        $start_default = (string) get_option( 'dinoco_line_gov_quiet_start', '09:00' );
        $end_default   = (string) get_option( 'dinoco_line_gov_quiet_end',   '20:00' );

        $uid = (int) $user_id;
        $start_user = $uid > 0 ? get_user_meta( $uid, 'dinoco_sn_quiet_hours_start', true ) : '';
        $end_user   = $uid > 0 ? get_user_meta( $uid, 'dinoco_sn_quiet_hours_end',   true ) : '';

        $start_str = ! empty( $start_user ) ? (string) $start_user : $start_default;
        $end_str   = ! empty( $end_user )   ? (string) $end_user   : $end_default;

        $start_min = dinoco_line_gov_parse_hhmm( $start_str, 9 * 60 );
        $end_min   = dinoco_line_gov_parse_hhmm( $end_str,   20 * 60 );

        // Allowed window is [start_min, end_min)
        // Returns true ⇔ OUTSIDE that window.
        if ( $start_min <= $end_min ) {
            return ! ( $now_min >= $start_min && $now_min < $end_min );
        }
        // Wrap-around (e.g. 22:00–06:00 — niche but supported)
        return ! ( $now_min >= $start_min || $now_min < $end_min );
    }
}

if ( ! function_exists( 'dinoco_line_gov_parse_hhmm' ) ) {
    /**
     * Parse "HH" or "HH:MM" → minute offset since midnight.
     * Falls back to $default on garbage input.
     */
    function dinoco_line_gov_parse_hhmm( $input, $default_min ) {
        $s = trim( (string) $input );
        if ( $s === '' ) return (int) $default_min;
        if ( preg_match( '/^(\d{1,2}):(\d{2})$/', $s, $m ) ) {
            $h = max( 0, min( 23, (int) $m[1] ) );
            $mi = max( 0, min( 59, (int) $m[2] ) );
            return ( $h * 60 ) + $mi;
        }
        if ( preg_match( '/^(\d{1,2})$/', $s, $m ) ) {
            $h = max( 0, min( 23, (int) $m[1] ) );
            return $h * 60;
        }
        return (int) $default_min;
    }
}

if ( ! function_exists( 'dinoco_line_gov_seconds_until_window_open' ) ) {
    /**
     * If we're currently in quiet hours, how many seconds until the
     * window re-opens? Used by Notifier to schedule wp_schedule_single_event.
     *
     * Returns 0 if window already open.
     */
    function dinoco_line_gov_seconds_until_window_open( $user_id, $category = '' ) {
        if ( ! dinoco_line_in_quiet_hours( $user_id, $category ) ) return 0;

        $tz = function_exists( 'wp_timezone' ) ? wp_timezone() : new \DateTimeZone( 'Asia/Bangkok' );
        try {
            $now_local = new \DateTime( 'now', $tz );
        } catch ( \Throwable $e ) {
            return 3600; // safe default — retry in an hour
        }

        $start_default = (string) get_option( 'dinoco_line_gov_quiet_start', '09:00' );
        $start_min = dinoco_line_gov_parse_hhmm( $start_default, 9 * 60 );

        $uid = (int) $user_id;
        $start_user = $uid > 0 ? get_user_meta( $uid, 'dinoco_sn_quiet_hours_start', true ) : '';
        if ( ! empty( $start_user ) ) {
            $start_min = dinoco_line_gov_parse_hhmm( (string) $start_user, $start_min );
        }

        $now_min = ( (int) $now_local->format( 'H' ) * 60 ) + (int) $now_local->format( 'i' );

        if ( $start_min > $now_min ) {
            // Window opens later today
            return ( $start_min - $now_min ) * 60;
        }
        // Window opens tomorrow at start_min
        return ( ( 24 * 60 - $now_min ) + $start_min ) * 60;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 4. FREQUENCY CAPS (the heart — single SELECT COUNT, no JOINs)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_line_gov_table_exists' ) ) {
    /**
     * R5 Perf-G2 — memoize SHOW TABLES result per request.
     *
     * Original code ran SHOW TABLES LIKE on every count + every log_push,
     * generating 4-6 redundant probe queries per cron-fan-out push site.
     * Static var caches once per PHP process; cache invalidated via the
     * $GLOBALS['__dinoco_line_gov_tex_invalidate'] flag (set by lazy schema
     * install so the freshly-created table is detectable on same request).
     *
     * @return bool
     */
    function dinoco_line_gov_table_exists() {
        static $cached = null;
        if ( ! empty( $GLOBALS['__dinoco_line_gov_tex_invalidate'] ) ) {
            $cached = null;
            unset( $GLOBALS['__dinoco_line_gov_tex_invalidate'] );
        }
        if ( $cached !== null ) return $cached;
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';
        $row = $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $tbl ) );
        $cached = ( $row === $tbl );
        return $cached;
    }
}

if ( ! function_exists( 'dinoco_line_gov_table_exists_reset' ) ) {
    /**
     * R5 Perf-G2 — invalidate the static memo. Set on schema-install so
     * the next dinoco_line_gov_table_exists() call re-probes.
     */
    function dinoco_line_gov_table_exists_reset() {
        $GLOBALS['__dinoco_line_gov_tex_invalidate'] = true;
    }
}

if ( ! function_exists( 'dinoco_line_gov_count_recent_pushes' ) ) {
    /**
     * Cheap COUNT query against wp_dinoco_line_push_log.
     *
     * Retained for backward-compat callers; internal cap math now uses
     * dinoco_line_gov_count_recent_pushes_aggregate() (R5 Perf-B1) which
     * collapses 3 round-trips into 1 conditional-aggregate.
     *
     * @param int    $user_id
     * @param string $category  '' = any
     * @param int    $window_seconds  trailing window
     * @return int  rows where success=1 within window
     */
    function dinoco_line_gov_count_recent_pushes( $user_id, $category = '', $window_seconds = 86400 ) {
        global $wpdb;
        $uid = (int) $user_id;
        if ( $uid <= 0 ) return 0;
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';

        // R5 Perf-G2 — defensive table-exists with static memo
        if ( ! dinoco_line_gov_table_exists() ) return 0;

        $cutoff = gmdate( 'Y-m-d H:i:s', time() - max( 60, (int) $window_seconds ) );
        if ( $category !== '' ) {
            return (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$tbl}
                 WHERE user_id = %d AND category = %s AND success = 1 AND sent_at >= %s",
                $uid, $category, $cutoff
            ) );
        }
        return (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$tbl}
             WHERE user_id = %d AND success = 1 AND sent_at >= %s",
            $uid, $cutoff
        ) );
    }
}

if ( ! function_exists( 'dinoco_line_gov_count_recent_pushes_aggregate' ) ) {
    /**
     * R5 Perf-B1 — single conditional-aggregate replacement for 3 sequential
     * COUNT() round-trips inside dinoco_line_can_push().
     *
     * Old behavior: 3 separate SELECT COUNT(*) ... queries fired sequentially:
     *   (1) category cap     — WHERE user_id + category + sent_at >= 24h
     *   (2) hard daily cap   — WHERE user_id + sent_at >= 24h
     *   (3) weekly soft cap  — WHERE user_id + sent_at >= 7d
     *
     * Each query ≈ 0.5-2ms; 5K users × cron fan-out = 15K queries / 60s burst.
     * New: ONE query with SUM(CASE WHEN ...) over the WIDEST window (7d),
     * which left-prefix-matches idx_user_cat_date AND idx_user_date so MySQL
     * prunes rows on the (user_id, sent_at >= week_cut) range — typically
     * 10-100 rows for high-volume users, < 10 for normal.
     *
     * @param int    $user_id
     * @param string $category  canonical category for the cat_count branch
     * @return array{cat_count:int, day_count:int, week_count:int}
     */
    function dinoco_line_gov_count_recent_pushes_aggregate( $user_id, $category ) {
        global $wpdb;
        $uid = (int) $user_id;
        $zero = array( 'cat_count' => 0, 'day_count' => 0, 'week_count' => 0 );
        if ( $uid <= 0 ) return $zero;
        if ( ! dinoco_line_gov_table_exists() ) return $zero;
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';
        $now = time();
        $day_cut  = gmdate( 'Y-m-d H:i:s', $now - 86400 );
        $week_cut = gmdate( 'Y-m-d H:i:s', $now - 7 * 86400 );
        $cat = (string) $category;

        // Single query — week window (widest) prunes via idx_user_date /
        // idx_user_cat_date left-prefix; SUM(CASE) projects the 3 counters.
        // cat_count: rows in last 24h with matching category
        // day_count: rows in last 24h (any category)
        // week_count: rows in last 7d (any category)
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT
                SUM(CASE WHEN sent_at >= %s AND category = %s THEN 1 ELSE 0 END) AS cat_count,
                SUM(CASE WHEN sent_at >= %s THEN 1 ELSE 0 END) AS day_count,
                SUM(CASE WHEN sent_at >= %s THEN 1 ELSE 0 END) AS week_count
             FROM {$tbl}
             WHERE user_id = %d AND sent_at >= %s AND success = 1",
            $day_cut, $cat, $day_cut, $week_cut, $uid, $week_cut
        ), ARRAY_A );

        if ( ! is_array( $row ) ) return $zero;
        return array(
            'cat_count'  => (int) ( $row['cat_count']  ?? 0 ),
            'day_count'  => (int) ( $row['day_count']  ?? 0 ),
            'week_count' => (int) ( $row['week_count'] ?? 0 ),
        );
    }
}

if ( ! function_exists( 'dinoco_line_can_push' ) ) {
    /**
     * THE GATE. Call this BEFORE every LINE push to a registered user.
     *
     * Decision order (first failure wins):
     *   1. user_id invalid                → reason='invalid_user', allow=false
     *   2. (transactional) bypass all checks → allow=true
     *   3. user opt-out (per-category)     → reason='opt_out_<cat>', allow=false
     *   4. nuclear opt-out                 → reason='opt_out_nuclear', allow=false
     *   5. quiet hours                     → reason='quiet_hours', retry_after_sec
     *   6. category daily cap exceeded     → reason='cap_category_day', retry=86400
     *   7. hard daily cap (any category)   → reason='cap_daily', retry=86400
     *   8. weekly soft cap                 → reason='cap_weekly', retry=86400
     *   9. allowed                         → reason='ok', allow=true
     *
     * @return array{allowed:bool, reason:string, retry_after_sec:int, category:string}
     */
    function dinoco_line_can_push( $user_id, $category, $template_code = '' ) {
        $uid = (int) $user_id;
        $cat = dinoco_line_gov_resolve_category( $category );

        if ( $uid <= 0 ) return dinoco_line_gov_deny_response( $cat, 'invalid_user', 0 );

        $cats = dinoco_line_gov_categories();
        $is_transactional = ! empty( $cats[ $cat ]['transactional'] );

        // 2. Transactional bypass
        if ( $is_transactional ) {
            return dinoco_line_gov_allow_response( $cat );
        }

        // 3. + 4. Pref / nuclear opt-out
        try {
            $prefs = dinoco_line_get_user_prefs( $uid );
        } catch ( \Throwable $e ) {
            $prefs = array();
        }
        $nuclear = get_user_meta( $uid, 'dinoco_line_opt_out_all', true );
        if ( ! empty( $nuclear ) && $nuclear !== '0' ) {
            return dinoco_line_gov_deny_response( $cat, 'opt_out_nuclear', 0 );
        }
        if ( array_key_exists( $cat, $prefs ) && $prefs[ $cat ] === false ) {
            return dinoco_line_gov_deny_response( $cat, 'opt_out_' . $cat, 0 );
        }

        // 5. Quiet hours
        if ( dinoco_line_in_quiet_hours( $uid, $cat ) ) {
            $retry = dinoco_line_gov_seconds_until_window_open( $uid, $cat );
            return dinoco_line_gov_deny_response( $cat, 'quiet_hours', $retry );
        }

        // R5 Perf-B1 — single conditional-aggregate replaces 3 sequential
        // COUNTs. We compute counts only when at least one cap is active;
        // common case (all caps enabled) hits a single round-trip.
        $cat_cap_default = isset( $cats[ $cat ]['daily_cap'] ) ? (int) $cats[ $cat ]['daily_cap'] : 1;
        $cat_cap   = (int) get_option( 'dinoco_line_gov_cat_cap_' . $cat, $cat_cap_default );
        // V.1.6 (2026-05-09) — Boss directive "ส่งได้ตลอด": fresh-install
        // default flips 1/3 → 0/0 (unlimited). Existing installations migrated
        // by one-time admin_init below.
        $daily_cap = (int) get_option( 'dinoco_line_gov_daily_cap', 0 );
        $weekly_cap = (int) get_option( 'dinoco_line_gov_weekly_cap', 0 );

        if ( $cat_cap >= 1 || $daily_cap >= 1 || $weekly_cap >= 1 ) {
            $counts = dinoco_line_gov_count_recent_pushes_aggregate( $uid, $cat );

            // 6. Category daily cap
            if ( $cat_cap >= 1 && $counts['cat_count'] >= $cat_cap ) {
                return dinoco_line_gov_deny_response( $cat, 'cap_category_day', 86400 );
            }
            // 7. Hard daily cap (across all non-transactional categories)
            if ( $daily_cap >= 1 && $counts['day_count'] >= $daily_cap ) {
                return dinoco_line_gov_deny_response( $cat, 'cap_daily', 86400 );
            }
            // 8. Weekly soft cap
            if ( $weekly_cap >= 1 && $counts['week_count'] >= $weekly_cap ) {
                return dinoco_line_gov_deny_response( $cat, 'cap_weekly', 86400 );
            }
        }

        return dinoco_line_gov_allow_response( $cat );
    }
}

if ( ! function_exists( 'dinoco_line_gov_deny_response' ) ) {
    /**
     * R5 Perf-G1 — named helper replacing per-call closure allocation.
     * Cosmetic but eliminates GC pressure under cron fan-out.
     */
    function dinoco_line_gov_deny_response( $category, $reason, $retry_after_sec = 0 ) {
        return array(
            'allowed'         => false,
            'reason'          => (string) $reason,
            'retry_after_sec' => (int) $retry_after_sec,
            'category'        => (string) $category,
        );
    }
}

if ( ! function_exists( 'dinoco_line_gov_allow_response' ) ) {
    /** R5 Perf-G1 — named helper replacing per-call closure allocation. */
    function dinoco_line_gov_allow_response( $category ) {
        return array(
            'allowed'         => true,
            'reason'          => 'ok',
            'retry_after_sec' => 0,
            'category'        => (string) $category,
        );
    }
}

if ( ! function_exists( 'dinoco_line_log_push' ) ) {
    /**
     * Record a push attempt. Call AFTER the push (success or failure)
     * so frequency-cap math reflects reality.
     *
     * @param int    $user_id
     * @param string $category       canonical (resolved by caller is fine)
     * @param string $template_code  free-form template identifier
     * @param bool   $success        only success=1 rows count toward cap
     * @param string $reason         optional — populated with deny-reason
     *                               when caller logs a deferred attempt
     * @return int|false insert_id
     */
    function dinoco_line_log_push( $user_id, $category, $template_code = '', $success = true, $reason = '' ) {
        global $wpdb;
        $uid = (int) $user_id;
        if ( $uid <= 0 ) return false;
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';
        // R5 Perf-G2 — memoed table-exists probe (no SHOW TABLES per call)
        if ( ! dinoco_line_gov_table_exists() ) {
            // Lazy install once if admin_init hasn't fired (e.g. cron context)
            if ( function_exists( 'dinoco_line_gov_schema_install' ) ) {
                dinoco_line_gov_schema_install();
            }
            if ( ! dinoco_line_gov_table_exists() ) return false;
        }
        $cat = dinoco_line_gov_resolve_category( $category );
        $ok = $wpdb->insert( $tbl, array(
            'user_id'       => $uid,
            'category'      => substr( $cat, 0, 40 ),
            'template_code' => substr( (string) $template_code, 0, 64 ),
            'sent_at'       => current_time( 'mysql' ),
            'success'       => $success ? 1 : 0,
            'reason'        => substr( (string) $reason, 0, 64 ),
        ), array( '%d', '%s', '%s', '%s', '%d', '%s' ) );
        return $ok ? (int) $wpdb->insert_id : false;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 5. RETENTION CRON (PDPA storage limitation §17)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_line_gov_retention_run' ) ) {
    /**
     * Daily — purge log rows beyond retention window. Idempotent.
     */
    function dinoco_line_gov_retention_run() {
        update_option( 'dinoco_cron_line_gov_retention_last_run', current_time( 'mysql' ), false );

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_line_push_log';
        // R5 Perf-G2 — memoed table-exists probe
        if ( ! dinoco_line_gov_table_exists() ) return 0;

        $days = (int) get_option( 'dinoco_line_gov_log_retention_days', DINOCO_LINE_GOV_LOG_RETENTION_DAYS );
        if ( $days < 7 ) $days = 7;   // floor — protect cap math
        if ( $days > 365 ) $days = 365;

        $cutoff = gmdate( 'Y-m-d H:i:s', time() - ( $days * 86400 ) );

        // R5 Perf-B2 — chunked delete (port from SN audit retention pattern at
        // [Admin System] DINOCO Production SN Manager:8613-8632). At 65K daily
        // inserts × 30d TTL, daily delete needs ~65K rows. Single LIMIT 5000
        // shot accumulated backlog every day. Now: 20 iterations × 1000 rows
        // = up to 20K/run with 50ms gap between batches to release row locks.
        // Two consecutive cron fires (next-day) drain the steady-state backlog.
        $max_iter = 20;
        $batch    = 1000;
        $deleted_total = 0;
        for ( $i = 0; $i < $max_iter; $i++ ) {
            $deleted = (int) $wpdb->query( $wpdb->prepare(
                "DELETE FROM {$tbl} WHERE sent_at < %s LIMIT %d",
                $cutoff,
                $batch
            ) );
            if ( $deleted <= 0 ) break;
            $deleted_total += $deleted;
            if ( $deleted < $batch ) break;  // tail reached
            usleep( 50000 );  // 50ms gap between batches
        }

        update_option( 'dinoco_line_gov_retention_last_summary', array(
            'at'      => current_time( 'mysql' ),
            'days'    => $days,
            'deleted' => $deleted_total,
            'iters'   => $i + 1,
        ), false );
        update_option( 'dinoco_cron_line_push_retention_deleted_count', $deleted_total, false );
        return $deleted_total;
    }
}

// R9 Pattern 4 — flag-aware cron registration. Push Governance is part of the
// SN system surface (telemetry retention for SN-driven LINE pushes), so it
// inherits the dinoco_sn_system_enabled master flag. When admin flips the SN
// flag OFF, retention cron auto-unschedules within minutes via the listener
// dinoco_sn_reevaluate_flag_aware_crons() registered in SN Manager.
//
// Action hook (add_action below) is registered unconditionally — no harm in
// keeping the listener wired even when scheduler doesn't fire it.
add_action( 'dinoco_line_gov_retention_cron', 'dinoco_line_gov_retention_run' );

if ( function_exists( 'dinoco_register_flag_aware_cron' ) ) {
    dinoco_register_flag_aware_cron( 'dinoco_line_gov_retention_cron', 'daily', 'dinoco_sn_system_enabled' );
} else {
    // Fallback when SN Manager not yet synced — preserve original behaviour
    // (schedule unconditionally, no flag-aware unschedule). Future sync of
    // SN Manager V.0.47+ will retroactively wire flag-awareness.
    if ( ! wp_next_scheduled( 'dinoco_line_gov_retention_cron' ) ) {
        wp_schedule_event( time() + 600, 'daily', 'dinoco_line_gov_retention_cron' );
    }
}

// Heartbeat tracking via Health Monitor when available (Round 28 pattern,
// independent of flag-aware scheduling — heartbeat wraps callback regardless
// of whether cron is currently scheduled)
if ( function_exists( 'dinoco_register_cron' ) ) {
    dinoco_register_cron( 'dinoco_line_gov_retention_cron', 'daily', 'dinoco_line_gov_retention_run' );
}

// R9 Pattern 4 — listener for flag flip on this snippet's behalf (defensive:
// also registered in SN Manager, but if Push Gov is loaded WITHOUT SN Manager
// for any reason, this ensures retention cron still cleans up on flag OFF).
if ( ! function_exists( 'dinoco_line_gov_reevaluate_cron' ) ) {
    function dinoco_line_gov_reevaluate_cron() {
        if ( function_exists( 'dinoco_register_flag_aware_cron' ) ) {
            dinoco_register_flag_aware_cron( 'dinoco_line_gov_retention_cron', 'daily', 'dinoco_sn_system_enabled' );
        }
    }
}
add_action( 'update_option_dinoco_sn_system_enabled', 'dinoco_line_gov_reevaluate_cron', 10, 0 );
add_action( 'add_option_dinoco_sn_system_enabled', 'dinoco_line_gov_reevaluate_cron', 10, 0 );

