if ( ! function_exists( 'dinoco_line_get_user_prefs' ) ) {
    /**
     * Resolve all 5 category prefs for one user. Defaults follow
     * dinoco_line_gov_categories() (marketing default OFF — PDPA §24).
     *
     * Reuses existing wp_usermeta keys `dinoco_sn_notif_*` for backward
     * compat with the Member Dashboard form already shipped in V.31.0.
     *
     * @return array<string, bool>
     */
    function dinoco_line_get_user_prefs( $user_id ) {
        $uid = (int) $user_id;
        if ( $uid <= 0 ) return array();
        $cats = dinoco_line_gov_categories();
        $out = array();
        foreach ( $cats as $key => $meta ) {
            // transactional has no opt-out (contract performance)
            if ( ! empty( $meta['transactional'] ) ) {
                $out[ $key ] = true;
                continue;
            }
            // Map canonical category → wp_usermeta key
            $meta_key = dinoco_line_gov_pref_meta_key( $key );
            $stored = get_user_meta( $uid, $meta_key, true );
            if ( $stored === '' || $stored === false || $stored === null ) {
                $out[ $key ] = (bool) $meta['default_pref'];
            } else {
                $out[ $key ] = ! empty( $stored ) && $stored !== '0';
            }
        }
        // NUCLEAR opt-out — single key disables all non-transactional
        $nuclear = get_user_meta( $uid, 'dinoco_line_opt_out_all', true );
        if ( ! empty( $nuclear ) && $nuclear !== '0' ) {
            foreach ( $out as $k => $v ) {
                if ( $k !== 'transactional' ) $out[ $k ] = false;
            }
        }
        return $out;
    }
}

if ( ! function_exists( 'dinoco_line_gov_pref_meta_key' ) ) {
    function dinoco_line_gov_pref_meta_key( $category ) {
        $map = array(
            'expiry'      => 'dinoco_sn_notif_expiry',
            'anniversary' => 'dinoco_sn_notif_anniversary',
            'review'      => 'dinoco_sn_notif_review',
            'marketing'   => 'dinoco_sn_notif_promo',  // legacy key — V.31.0 used 'promo'
        );
        return $map[ $category ] ?? ( 'dinoco_line_pref_' . $category );
    }
}

if ( ! function_exists( 'dinoco_line_set_user_prefs' ) ) {
    /**
     * Write categorical opt-in flags + audit log entry. Honors
     * "double opt-in" requirement for marketing — caller MUST pass
     * an explicit boolean (no toggling-by-omission).
     *
     * @param int   $user_id
     * @param array $prefs   key=category slug, value=bool
     * @return array{updated:int, errors:array<string,string>}
     */
    function dinoco_line_set_user_prefs( $user_id, $prefs ) {
        $uid = (int) $user_id;
        $out = array( 'updated' => 0, 'errors' => array() );
        if ( $uid <= 0 ) {
            $out['errors']['user_id'] = 'invalid';
            return $out;
        }
        if ( ! is_array( $prefs ) ) {
            $out['errors']['prefs'] = 'not_array';
            return $out;
        }
        $cats = dinoco_line_gov_categories();
        foreach ( $prefs as $cat => $val ) {
            $cat = strtolower( trim( (string) $cat ) );
            if ( ! isset( $cats[ $cat ] ) ) continue;
            if ( ! empty( $cats[ $cat ]['transactional'] ) ) continue; // never store
            $val_bool = filter_var( $val, FILTER_VALIDATE_BOOLEAN );
            $meta_key = dinoco_line_gov_pref_meta_key( $cat );
            $old = get_user_meta( $uid, $meta_key, true );
            $new = $val_bool ? '1' : '0';
            if ( (string) $old !== $new ) {
                update_user_meta( $uid, $meta_key, $new );
                $out['updated']++;
                // Audit (best-effort)
                if ( function_exists( 'dinoco_line_gov_audit_pref_change' ) ) {
                    try {
                        dinoco_line_gov_audit_pref_change( $uid, $cat, (string) $old, $new );
                    } catch ( \Throwable $e ) { /* swallow */ }
                }
            }
        }
        // Nuclear opt-out (single boolean; not a category)
        if ( array_key_exists( 'opt_out_all', $prefs ) ) {
            $nuc_val = filter_var( $prefs['opt_out_all'], FILTER_VALIDATE_BOOLEAN );
            update_user_meta( $uid, 'dinoco_line_opt_out_all', $nuc_val ? '1' : '0' );
            $out['updated']++;
        }
        return $out;
    }
}

if ( ! function_exists( 'dinoco_line_gov_audit_pref_change' ) ) {
    /**
     * Best-effort audit — uses Flag Audit snippet if synced, else
     * dinoco_sn_audit_log if SN namespace available, else error_log.
     */
    function dinoco_line_gov_audit_pref_change( $uid, $cat, $old, $new ) {
        $payload = array(
            'user_id'  => (int) $uid,
            'category' => (string) $cat,
            'old'      => (string) $old,
            'new'      => (string) $new,
            'at'       => current_time( 'mysql' ),
            'ip'       => function_exists( 'dinoco_gdpr_get_client_ip' )
                ? dinoco_gdpr_get_client_ip()
                : ( $_SERVER['REMOTE_ADDR'] ?? '' ),
        );
        if ( function_exists( 'dinoco_flag_audit_log' ) ) {
            dinoco_flag_audit_log(
                'line_pref_' . $cat,
                $old,
                $new,
                'user opt-in/out via Member Dashboard',
                'line_governance'
            );
            return;
        }
        if ( function_exists( 'dinoco_sn_audit_log' ) ) {
            dinoco_sn_audit_log( 'line_pref_change', $payload, $uid );
            return;
        }
        error_log( '[LINE-GOV][PREF] ' . wp_json_encode( $payload ) );
    }
}

