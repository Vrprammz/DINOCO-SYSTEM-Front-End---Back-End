        }
        $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
            array('type'=>'text','text'=>'เครดิต','size'=>'xs','color'=>'#64748b','flex'=>4),
            array('type'=>'text','text'=>$term.' วัน','size'=>'xs','flex'=>6,'align'=>'end')));
