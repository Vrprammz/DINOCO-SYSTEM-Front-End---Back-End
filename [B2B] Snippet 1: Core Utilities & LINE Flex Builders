if ( ! function_exists( 'b2b_slip_compute_image_hash' ) ) {
    /**
     * Normalized SHA-256 hash of slip binary. Used as dedup key for replay cascade.
     * @param string $binary raw image bytes from LINE Content API
     * @return string lowercase hex SHA-256 (64 chars) or '' on empty input
     */
    function b2b_slip_compute_image_hash( $binary ) {
        if ( empty( $binary ) || ! is_string( $binary ) ) return '';
        return hash( 'sha256', $binary );
    }
}

if ( ! function_exists( 'b2b_slip_find_prior_payment' ) ) {
    /**
     * Find a PRIOR successfully-processed slip row by image hash.
     * If hit → caller replies "already paid" + skips Slip2Go + skips debt mutation.
     *
     * @param string $image_hash SHA-256 hex
     * @return array|null row assoc array (id, created_at, amount, trans_ref, dist_id, sender_name, result_status) or null
     */
    function b2b_slip_find_prior_payment( $image_hash ) {
        if ( empty( $image_hash ) ) return null;
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        static $table_exists = null;
        if ( $table_exists === null ) {
            $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        }
        if ( ! $table_exists ) return null;
        // Guard: column may not exist on legacy installs pre-V.8.6
        static $col_exists = null;
        if ( $col_exists === null ) {
            $col_exists = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(1) FROM INFORMATION_SCHEMA.COLUMNS
                 WHERE table_schema = DATABASE() AND table_name = %s AND column_name = 'image_hash'",
                $table
            ) );
        }
        if ( ! $col_exists ) return null;

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, created_at, amount, trans_ref, dist_id, sender_name, result_status
             FROM {$table}
             WHERE image_hash = %s
               AND result_status IN ('paid','paid_overpayment','manual_admin_paid')
             ORDER BY id DESC
             LIMIT 1",
            $image_hash
        ), ARRAY_A );
        return $row ? $row : null;
    }
}

if ( ! function_exists( 'b2b_slip_find_cached_response' ) ) {
    /**
     * Find a PRIOR slip attempt that errored on our side but captured a valid Slip2Go response.
     * If hit → caller can REPLAY the decision branches against that cached JSON without
     * re-hitting Slip2Go API (respects quota + dedupes cache-sticky 200501 deadlock).
     *
     * Failure statuses that indicate "we got data but flow failed downstream":
     *   line_api_error  — LINE content download died
     *   slip2go_error   — API 5xx/0 (response WILL be null in this case, skip)
     *   data_missing    — 200000/200200 but data.amount was missing
     *   unregistered_group — group not mapped yet (cached data valid if admin adds dist later)
     *   fatal_exception — PHP crash mid-processing
     *   unknown_slip_code — Slip2Go returned a code we don't handle
     *
     * NOTE: slip2go_error without response is still excluded via WHERE slip2go_response IS NOT NULL.
     *
     * @param string $image_hash SHA-256 hex
     * @return array|null { id, slip2go_response (decoded array), result_status, created_at } or null
     */
    function b2b_slip_find_cached_response( $image_hash ) {
        if ( empty( $image_hash ) ) return null;
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        static $table_exists = null;
        if ( $table_exists === null ) {
            $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        }
        if ( ! $table_exists ) return null;
        static $col_exists = null;
        if ( $col_exists === null ) {
            $col_exists = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(1) FROM INFORMATION_SCHEMA.COLUMNS
                 WHERE table_schema = DATABASE() AND table_name = %s AND column_name = 'slip2go_response'",
                $table
            ) );
        }
        if ( ! $col_exists ) return null;

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, slip2go_response, result_status, created_at
             FROM {$table}
             WHERE image_hash = %s
               AND slip2go_response IS NOT NULL
               AND result_status IN (
                   'line_api_error','data_missing','unregistered_group',
                   'fatal_exception','unknown_slip_code','no_distributor'
               )
             ORDER BY id DESC
             LIMIT 1",
            $image_hash
        ), ARRAY_A );
        if ( ! $row ) return null;

        $decoded = json_decode( (string) $row['slip2go_response'], true );
        if ( ! is_array( $decoded ) ) return null; // corrupted — treat as miss
        $row['slip2go_response'] = $decoded;
        return $row;
    }
}

