<script>
(function(){
    var API_URL = "' . esc_js($site_url) . '/wp-json/b2b/v1/verify-member";
    var PAGE    = "' . esc_js($page) . '";

    // ดึง sig จาก URL
    var params = new URLSearchParams(window.location.search);
    var gid = params.get("gid") || "' . esc_js($gid) . '";
    var hasSig = params.has("_sig") && params.has("_ts");

    function showContent() {
        var ld = document.getElementById("b2b-guard-loader");
        if (ld && ld.parentNode) ld.parentNode.removeChild(ld);
        var wrap = document.querySelector(".b2b-wrap");
        if (wrap) wrap.classList.add("b2b-verified");
    }

    // ═══════════════════════════════════════════════════
    // V.15.1: Fast path — ถ้ามี _sig → PHP verify แล้ว → แสดง content ทันที
    //   ไม่ต้อง load LIFF SDK, ไม่ต้อง liff.init(), ไม่ต้อง verify-member
    //   ลด 1-3 วินาที + ไม่มีหน้าขาว
    // ═══════════════════════════════════════════════════
    if (hasSig) {
        console.log("[LIFF Guard] Fast path — HMAC verified server-side, skip LIFF SDK");
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", showContent);
        } else {
            showContent();
        }
        return;
    }

    // ═══════════════════════════════════════════════════
    // Slow path — ไม่มี sig → ต้อง load LIFF SDK + verify membership
    //   แสดง dark loading screen ระหว่างรอ
    // ═══════════════════════════════════════════════════
    var loader = document.createElement("div");
    loader.id = "b2b-guard-loader";
    loader.style.cssText = "position:fixed;inset:0;z-index:99999;background:#0a0a0a;display:flex;align-items:center;justify-content:center;";
    loader.innerHTML = \'<div style="text-align:center;padding:80px 20px;font-family:-apple-system,Sarabun,sans-serif;">\' +
        \'<div style="font-size:40px;margin-bottom:16px;">🔐</div>\' +
        \'<div style="font-size:14px;color:#94a3b8;">กำลังตรวจสอบสิทธิ์...</div></div>\';
    document.body.insertBefore(loader, document.body.firstChild);

    function showDenied(msg) {
        loader.style.cssText = "position:fixed;inset:0;z-index:99999;background:#0a0a0a;display:flex;align-items:center;justify-content:center;";
        loader.innerHTML = \'<div style="text-align:center;padding:80px 20px;font-family:-apple-system,Sarabun,sans-serif;">\' +
            \'<div style="font-size:64px;margin-bottom:16px;">🔒</div>\' +
            \'<h2 style="font-size:18px;color:#f1f5f9;margin-bottom:8px;">Access Denied</h2>\' +
            \'<p style="font-size:14px;color:#94a3b8;line-height:1.6;">\' + (msg || "คุณไม่มีสิทธิ์เข้าถึงหน้านี้") + \'</p>\' +
            \'<p style="font-size:12px;color:rgba(255,255,255,0.3);margin-top:24px;">DINOCO B2B Security</p></div>\';
    }

    // Load LIFF SDK dynamically (only when needed)
    var s = document.createElement("script");
    s.src = "https://static.line-scdn.net/liff/edge/2/sdk.js";
    s.onload = function() {
        var LIFF_ID = "' . esc_js($liff_id) . '";
        liff.init({ liffId: LIFF_ID }).then(function() {
            if (!liff.isInClient()) {
                showDenied("กรุณาเปิดผ่าน LINE App เท่านั้น");
                return null;
            }
            if (!liff.isLoggedIn()) { liff.login(); return null; }
            return liff.getProfile();
        }).then(function(profile) {
            if (!profile) return;
            if (!gid) { showDenied("ไม่พบข้อมูลกลุ่ม — กรุณาเปิดผ่าน LINE กลุ่ม"); return; }
            return fetch(API_URL, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ gid: gid, uid: profile.userId, page: PAGE })
            }).then(function(r) {
                return r.json().catch(function() { return { ok: false, error: "api_parse_error" }; });
            });
        }).then(function(data) {
            if (!data) return;
            if (data.ok) { showContent(); }
            else if (data.error === "not_member") { showDenied("คุณไม่ได้เป็นสมาชิกกลุ่มนี้"); }
            else if (data.error === "not_admin") { showDenied("เฉพาะ Admin กลุ่มนี้เท่านั้น"); }
            else { showDenied("ไม่สามารถยืนยันสิทธิ์ได้"); }
        }).catch(function(err) {
            console.error("[LIFF Guard] Error:", err);
            showDenied("เกิดข้อผิดพลาด — กรุณาลองใหม่");
        });
    };
    document.head.appendChild(s);
})();
</script>';
    }
}

