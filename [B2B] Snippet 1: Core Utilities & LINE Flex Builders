if ( ! function_exists( 'b2b_flash_create_all_boxes' ) ) {
    function b2b_flash_create_all_boxes( $ticket_id ) {
        $ticket_id = intval( $ticket_id );

        // V.36: Use box manifest for SKU→box mapping
        $manifest = function_exists( 'b2b_calculate_box_manifest' ) ? b2b_calculate_box_manifest( $ticket_id ) : array();
        $total_boxes = count( $manifest );
        if ( $total_boxes < 1 ) {
            // Fallback: no manifest → use old count method
            $total_boxes = b2b_calculate_total_boxes( $ticket_id );
            if ( $total_boxes < 1 ) $total_boxes = 1;
            $manifest = array();
            for ( $i = 0; $i < $total_boxes; $i++ ) {
                $manifest[] = array( 'sku' => '', 'name' => '', 'children' => array() );
            }
        }

        $results = array(); $pnos = array(); $all_ok = true; $first_err = '';
        $pno_statuses = array();

        for ( $i = 0; $i < $total_boxes; $i++ ) {
            $box_num = $i + 1;
            $r = b2b_flash_create_order( $ticket_id, $box_num, $total_boxes );
            $results[] = $r;
            if ( $r['ok'] ) {
                $pnos[] = $r['pno'];
                // V.36: Build per-PNO status entry with SKU info
                $pno_statuses[ $r['pno'] ] = array(
                    'status'   => 'created',
                    'box'      => $box_num . '/' . $total_boxes,
                    'sku'      => $manifest[ $i ]['sku'],
                    'name'     => $manifest[ $i ]['name'],
                    'children' => $manifest[ $i ]['children'],
                );
            } else {
                $all_ok = false;
                if ( ! $first_err ) $first_err = $r['error'];
            }
        }

        if ( $all_ok && ! empty( $pnos ) ) {
            update_post_meta( $ticket_id, '_flash_tracking_numbers', $pnos );
            update_field( 'tracking_number', implode( ', ', $pnos ), $ticket_id );
            update_field( 'shipping_provider', 'Flash', $ticket_id );
            update_field( 'shipped_date', b2b_date(), $ticket_id );
            update_post_meta( $ticket_id, '_flash_sort_code', $results[0]['sortCode'] );
            if ( ! empty( $results[0]['data']['sortingLineCode'] ) ) {
                update_post_meta( $ticket_id, '_flash_sorting_line_code', $results[0]['data']['sortingLineCode'] );
            }
            if ( ! empty( $results[0]['data']['dstStoreName'] ) ) {
                update_post_meta( $ticket_id, '_flash_dst_store_name', $results[0]['data']['dstStoreName'] );
            }
            update_post_meta( $ticket_id, '_flash_packing_status', 'flash_created' );
            update_post_meta( $ticket_id, '_flash_status', 'created' );
            update_post_meta( $ticket_id, '_flash_create_error', '' );
            // V.36: Store per-PNO statuses
            update_post_meta( $ticket_id, '_flash_pno_statuses', $pno_statuses );
            b2b_log( '[Flash] All ' . $total_boxes . ' boxes created for #' . $ticket_id . ': ' . implode( ', ', $pnos ) );
            return array( 'ok' => true, 'pnos' => $pnos, 'total_boxes' => $total_boxes, 'results' => $results );
        }
        // Partial or full failure
        update_post_meta( $ticket_id, '_flash_packing_status', 'flash_create_error' );
        update_post_meta( $ticket_id, '_flash_create_error', $first_err );
        if ( ! empty( $pnos ) ) {
            update_post_meta( $ticket_id, '_flash_tracking_numbers', $pnos );
            update_field( 'tracking_number', implode( ', ', $pnos ), $ticket_id );
            // V.36: Store partial statuses even on failure
            update_post_meta( $ticket_id, '_flash_pno_statuses', $pno_statuses );
        }
        b2b_log( '[Flash] Create failed #' . $ticket_id . ': ' . $first_err . ' (' . count($pnos) . '/' . $total_boxes . ')' );
        // FIX S-6: ไม่ push Flex จาก helper function — ให้ caller (S2/S5) handle แทน ป้องกันส่งซ้ำ 2 อัน
        return array( 'ok' => false, 'error' => $first_err, 'pnos' => $pnos, 'total_boxes' => $total_boxes, 'results' => $results );
    }
}

