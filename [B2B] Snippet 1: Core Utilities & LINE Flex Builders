// ═══════════════════════════════════════════════════════════════
// THAI QR CODE (EMVCo PromptPay — BOT Standard)
// ═══════════════════════════════════════════════════════════════
if ( ! function_exists( 'b2b_crc16_ccitt' ) ) {
    function b2b_crc16_ccitt( $data ) {
        $crc = 0xFFFF;
        for ($i = 0; $i < strlen($data); $i++) {
            $crc ^= (ord($data[$i]) << 8);
            for ($j = 0; $j < 8; $j++) { $crc = ($crc & 0x8000) ? (($crc << 1) ^ 0x1021) & 0xFFFF : ($crc << 1) & 0xFFFF; }
        }
        return $crc;
    }
}
if ( ! function_exists( 'b2b_thai_qr_payload' ) ) {
    function b2b_thai_qr_payload( $amount = 0, $ref = '' ) {
        $tlv = function($id, $val) { return $id . str_pad(strlen($val), 2, '0', STR_PAD_LEFT) . $val; };
        $promptpay_id = defined('B2B_PROMPTPAY_ID') ? trim(B2B_PROMPTPAY_ID) : '';
        $bank_code = defined('B2B_BANK_CODE') ? trim(B2B_BANK_CODE) : '';
        $bank_account = defined('B2B_BANK_ACCOUNT') ? preg_replace('/[^0-9]/', '', B2B_BANK_ACCOUNT) : '';
        $aid = 'A000000677010111'; $tag29_inner = $tlv('00', $aid);
        if (!empty($promptpay_id)) {
            $clean = preg_replace('/[^0-9]/', '', $promptpay_id);
            if (strlen($clean) === 13) { $tag29_inner .= $tlv('02', $clean); }
            else { $clean = preg_replace('/^0/', '0066', $clean); $tag29_inner .= $tlv('01', $clean); }
        } elseif (!empty($bank_code) && !empty($bank_account)) {
            $acct_id = str_pad($bank_code, 3, '0', STR_PAD_LEFT) . $bank_account; $tag29_inner .= $tlv('04', $acct_id);
        } else { return ''; }
        $payload = '';
        $payload .= $tlv('00', '01'); $payload .= $tlv('01', '12'); $payload .= $tlv('29', $tag29_inner);
        $payload .= $tlv('53', '764');
        if ($amount > 0) $payload .= $tlv('54', number_format(round($amount, 2), 2, '.', ''));
        $payload .= $tlv('58', 'TH');
        $co = defined('B2B_COMPANY_NAME') ? preg_replace('/[^\x20-\x7E]/', '', substr(B2B_COMPANY_NAME, 0, 25)) : 'DINOCO';
        if (empty($co)) $co = 'DINOCO';
        $payload .= $tlv('59', $co); $payload .= $tlv('60', 'BANGKOK');
        $payload .= '6304';
        $crc = b2b_crc16_ccitt($payload);
        $payload = substr($payload, 0, -4) . '6304' . strtoupper(str_pad(dechex($crc), 4, '0', STR_PAD_LEFT));
        return $payload;
    }
}
if ( ! function_exists( 'b2b_thai_qr_image_url' ) ) {
    function b2b_thai_qr_image_url( $amount = 0, $ref = '' ) {
        $payload = b2b_thai_qr_payload($amount, $ref);
        if (empty($payload)) return '';
        return 'https://api.qrserver.com/v1/create-qr-code/?size=300x300&format=png&data=' . urlencode($payload);
    }
}
if ( ! function_exists( 'b2b_parse_date' ) ) {
    function b2b_parse_date( $date_val, $format = 'd/m/Y' ) {
        if ( empty($date_val) ) return '';
        if ( preg_match('/^\d{8}$/', $date_val) ) $date_val = substr($date_val,0,4).'-'.substr($date_val,4,2).'-'.substr($date_val,6,2);
        // Fix: dd/mm/yyyy จาก ACF ต้อง parse เอง (strtotime ตีความเป็น mm/dd/yyyy)
        if ( preg_match('#^(\d{1,2})/(\d{1,2})/(\d{4})$#', $date_val, $m) ) {
            $ts = mktime(0, 0, 0, intval($m[2]), intval($m[1]), intval($m[3]));
        } else {
            $ts = strtotime($date_val);
        }
        if ( $ts && $ts > 86400 ) return b2b_date($format, $ts);
        return $date_val;
    }
}
// V.14.0: Robust due-date parser — handle Ymd, Y-m-d, d/m/Y formats from ACF
if ( ! function_exists( 'b2b_parse_due_date_ts' ) ) {
    function b2b_parse_due_date_ts( $dd ) {
        if ( empty($dd) ) return false;
        if ( preg_match('/^\d{8}$/', $dd) )
            return strtotime(substr($dd,0,4).'-'.substr($dd,4,2).'-'.substr($dd,6,2));
        if ( preg_match('#^(\d{1,2})/(\d{1,2})/(\d{4})$#', $dd, $m) )
            return strtotime($m[3].'-'.$m[2].'-'.$m[1]);
        $ts = strtotime($dd);
        return ($ts && $ts > 86400) ? $ts : false;
    }
}

