if ( ! function_exists( 'b2b_mark_shipment_delivered' ) ) {
    function b2b_mark_shipment_delivered( $order_id, $shipment_id ) {
        $shipments = get_post_meta($order_id, '_b2b_shipments', true) ?: array();
        foreach ($shipments as &$s) {
            if ($s['shipment_id'] === $shipment_id) {
                $s['status'] = 'delivered';
                $s['delivered_at'] = function_exists('b2b_date') ? b2b_date('Y-m-d H:i:s') : current_time('mysql');
                break;
            }
        }
        update_post_meta($order_id, '_b2b_shipments', $shipments);

        // Check if ALL shipments delivered
        $all_delivered = true;
        foreach ($shipments as $s) {
            if ($s['status'] !== 'delivered') { $all_delivered = false; break; }
        }
        if ($all_delivered) {
            update_post_meta($order_id, '_b2b_shipping_status', 'delivered');
        }
        return $all_delivered;
    }
}
