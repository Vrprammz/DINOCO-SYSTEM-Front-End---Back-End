        $color   = '#3b82f6';

        $body = array(
            array( 'type' => 'text', 'text' => 'คูเรียร์: ' . ( $staff ?: '(รอข้อมูล)' ), 'weight' => 'bold', 'size' => 'md' ),
            array( 'type' => 'text', 'text' => 'โทร: ' . ( $phone ?: '-' ), 'size' => 'sm', 'color' => '#333333' ),
            array( 'type' => 'text', 'text' => 'มารับภายใน: ' . ( $timeout ?: '-' ), 'size' => 'sm', 'color' => '#333333' ),
            array( 'type' => 'separator', 'margin' => 'md' ),
