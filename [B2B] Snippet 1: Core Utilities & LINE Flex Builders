// ── 13.1 Flex: ถามลูกค้า "สั่ง 10 มา 5 เอาก่อนไหม?" ──
if ( ! function_exists( 'b2b_build_flex_bo_partial_ask' ) ) {
    function b2b_build_flex_bo_partial_ask( $ticket_id, $items_data, $partial_total = 0 ) {
        // items_data = array of ['sku'=>..., 'name'=>..., 'ordered'=>10, 'available'=>5]
        $rows = array();
        foreach ( $items_data as $item ) {
            $name = mb_substr( $item['name'], 0, 25 );
            $ordered   = intval( $item['ordered'] );
            $available = intval( $item['available'] );
            if ( $available >= $ordered ) {
                $qty_text  = '✅ ' . $available . '/' . $ordered;
                $qty_color = '#16a34a';
            } elseif ( $available > 0 ) {
                $qty_text  = '⚠️ ' . $available . '/' . $ordered;
                $qty_color = '#f59e0b';
            } else {
                $qty_text  = '❌ 0/' . $ordered;
                $qty_color = '#dc2626';
            }
            $rows[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>$name,'size'=>'xs','color'=>'#475569','flex'=>6,'wrap'=>true),
                array('type'=>'text','text'=>$qty_text,'size'=>'xs','weight'=>'bold','color'=>$qty_color,'flex'=>4,'align'=>'end')));
        }
        $body = array();
        $body[] = array('type'=>'text','text'=>'สินค้าบางรายการยังไม่ครบ:','weight'=>'bold','size'=>'sm');
        $body[] = array('type'=>'separator','margin'=>'md');
        $body = array_merge( $body, $rows );
        $body[] = array('type'=>'separator','margin'=>'md');
        if ( $partial_total > 0 ) {
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','contents'=>array(
                array('type'=>'text','text'=>'ยอดเฉพาะที่มี','size'=>'sm','color'=>'#64748b','flex'=>5),
