/**
 * Flash Express SHA256 Signing
 * 1. Filter empty/whitespace values
 * 2. ksort() ASCII ascending
 * 3. Join key1=value1&key2=value2
 * 4. Append &key={secret_key}
 * 5. strtoupper(hash('sha256', ...))
 * Sign RAW values BEFORE urlencode
 */
if ( ! function_exists( 'b2b_flash_sign' ) ) {
    function b2b_flash_sign( $params, $secret_key = '' ) {
        if ( ! $secret_key && defined( 'B2B_FLASH_SECRET_KEY' ) ) $secret_key = B2B_FLASH_SECRET_KEY;
        // FIX S-4: trim secret key — ป้องกัน invisible chars จาก copy-paste (whitespace, newline, BOM)
        $secret_key = trim( $secret_key );
        $filtered = array();
        foreach ( $params as $k => $v ) {
            $v = (string) $v;
            if ( $v !== '' && trim( $v ) !== '' ) $filtered[ $k ] = $v;
        }
        ksort( $filtered, SORT_STRING );
        $pairs = array();
        foreach ( $filtered as $k => $v ) {
            $pairs[] = $k . '=' . $v;
        }
        $str = implode( '&', $pairs ) . '&key=' . $secret_key;
        return strtoupper( hash( 'sha256', $str ) );
    }
}

