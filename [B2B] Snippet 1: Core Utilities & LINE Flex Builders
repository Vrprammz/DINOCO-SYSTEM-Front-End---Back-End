}

/**
 * Flash Express API Request Helper
 * - Builds: mchId + nonceStr + extra_params (all flat)
 * - Signs with SHA256 -> application/x-www-form-urlencoded
 * - Path variables ({pno}, {id}) in URL only, NOT in signature
 * - $expect_pdf: return raw binary instead of JSON
 */
if ( ! function_exists( 'b2b_flash_request' ) ) {
    function b2b_flash_request( $path, $extra_params = array(), $expect_pdf = false ) {
        if ( ! defined( 'B2B_FLASH_MCH_ID' ) || ! defined( 'B2B_FLASH_SECRET_KEY' ) || ! defined( 'B2B_FLASH_API_URL' ) ) {
            b2b_log( '[Flash] Missing constants B2B_FLASH_MCH_ID / SECRET_KEY / API_URL' );
            return array( 'ok' => false, 'error' => 'Missing Flash constants' );
        }
        $params = array_merge( array(
            'mchId'    => trim( B2B_FLASH_MCH_ID ),
            'nonceStr' => b2b_flash_nonce_str(),
        ), $extra_params );
        $params['sign'] = b2b_flash_sign( $params );
        $url = rtrim( B2B_FLASH_API_URL, '/' ) . '/' . ltrim( $path, '/' );
        // Log request (ไม่ log secret key)
        b2b_log( '[Flash] POST ' . $path . ' | URL=' . $url . ' | mchId=' . B2B_FLASH_MCH_ID );
        // FIX A-6: retry 1 ครั้งเมื่อ timeout/connection error
        $req_args = array(
            'body'    => $params,
            'timeout' => 30,
            'headers' => array( 'Content-Type' => 'application/x-www-form-urlencoded', 'Accept-Language' => 'th' ),
        );
        $resp = wp_remote_post( $url, $req_args );
        if ( is_wp_error( $resp ) ) {
            $err = $resp->get_error_message();
            // Retry once for timeout/connection errors (NOT for validation/auth errors)
            if ( strpos($err, 'timed out') !== false || strpos($err, 'connect') !== false || strpos($err, 'resolve') !== false ) {
                b2b_log( '[Flash] Retry 1x after: ' . $err );
                sleep(2);
                $resp = wp_remote_post( $url, $req_args );
            }
            if ( is_wp_error( $resp ) ) {
                $err = $resp->get_error_message();
                b2b_log( '[Flash] WP Error: ' . $err );
                return array( 'ok' => false, 'error' => $err );
            }
        }
        $code = wp_remote_retrieve_response_code( $resp );
        $body = wp_remote_retrieve_body( $resp );
        if ( $expect_pdf ) {
            $ct = wp_remote_retrieve_header( $resp, 'content-type' );
            if ( strpos( $ct, 'application/pdf' ) !== false || strpos( $ct, 'octet-stream' ) !== false ) {
                return array( 'ok' => true, 'pdf' => $body, 'content_type' => $ct );
            }
        }
        $data = json_decode( $body, true );
        if ( ! is_array( $data ) ) {
            b2b_log( '[Flash] Invalid JSON (HTTP ' . $code . '): ' . substr( $body, 0, 500 ) );
            return array( 'ok' => false, 'error' => 'Invalid JSON (HTTP ' . $code . ')' );
        }
        $flash_code = isset( $data['code'] ) ? intval( $data['code'] ) : -1;
        if ( $flash_code === 1 ) {
            b2b_log( '[Flash] OK: ' . $path );
            return array( 'ok' => true, 'data' => isset( $data['data'] ) ? $data['data'] : $data );
        }
        $msg = isset( $data['message'] ) ? $data['message'] : 'Unknown error';
        // FIX S-3: เพิ่ม sign debug เมื่อ signature error — ช่วย diagnose Production vs Training key
        if ( strpos($msg, 'ลายมือชื่อ') !== false || strpos($msg, 'signature') !== false || strpos($msg, 'sign') !== false ) {
            $sign_params = $params; unset($sign_params['sign']);
            $filtered_keys = array(); foreach($sign_params as $sk2=>$sv2) { $sv2s=(string)$sv2; if($sv2s!==''&&trim($sv2s)!=='') $filtered_keys[]=$sk2; }
            sort($filtered_keys, SORT_STRING);
            b2b_log( '[Flash] SIGN DEBUG — keys_in_signature: ' . implode(',', $filtered_keys) . ' | sign_sent=' . ($params['sign'] ?? '?') . ' | param_count=' . count($filtered_keys) );
        }
        b2b_log( '[Flash] Error ' . $flash_code . ': ' . $msg . ' path=' . $path );
        return array( 'ok' => false, 'error' => $msg, 'code' => $flash_code, 'raw' => $data );
    }
}

