if ( ! function_exists( 'b2b_check_oos_memory' ) ) {
    function b2b_check_oos_memory( $sku ) {
        // V.32.4: Read from custom table first
        if ( function_exists( 'b2b_get_product_data' ) ) {
            $pd = b2b_get_product_data( $sku );
            if ( ! $pd ) return false;
            if ( $pd['stock_status'] !== 'out_of_stock' ) return false;
            $ts = $pd['oos_timestamp']; $hrs = $pd['oos_duration_hours'];
            if ( !$ts || !$hrs ) return true;
            return ( time() < $ts + ($hrs * 3600) );
        }
        // Fallback ACF
        $pid = b2b_find_product_by_sku( $sku ); if ( !$pid ) return false;
        $status = get_field('stock_status', $pid); if ( $status !== 'out_of_stock' ) return false;
        $ts = intval( get_field('oos_timestamp', $pid) ); $hrs = intval( get_field('oos_duration_hours', $pid) );
        if ( !$ts || !$hrs ) return true;
        return ( time() < $ts + ($hrs * 3600) );
    }
}
if ( ! function_exists( 'b2b_check_order_oos' ) ) {
    /**
     * V.33.5 Phase 0 Hotfix — hierarchy-aware OOS gate
     *
     * เดิม (≤V.33.4) อ่าน stock_status column ดิบ + ไม่ expand SET → drift false-positive
     * Bug reference: Ticket #6266 (DNCSETNX500IRNB stock=10 ระบบตอบ BO)
     *
     * Flow ใหม่:
     *   1. Parse (SKU)xQTY — capture ทั้ง SKU + qty
     *   2. Feature flag OFF หรือ helpers ไม่ exist → fallback behavior เดิม
     *   3. Leaf SKU → เช็ค b2b_check_oos_memory() แบบเดิม (manual OOS flag ยังใช้งานบน leaf)
     *   4. Non-leaf (SET) → real-time compute:
     *      - delete_transient('b2b_reserved_map_bulk') ก่อน (แก้ 60s TTL stale)
     *      - available = max(0, compute_hierarchy_stock - reserved)
     *      - อ่าน manual_hold ตรงจาก DB (b2b_get_product_data ไม่ return manual_hold_reason)
     *      - OOS ถ้า manual_hold=1 OR available < qty
     *
     * จะถูก supersede โดย FEATURE-SPEC-B2B-BACKORDER-2026-04-16.md (opaque accept + admin split)
     */
    function b2b_check_order_oos( $order_text ) {
        $oos_items = array();
        $use_hierarchy = (bool) get_option( 'dinoco_oos_gate_hierarchy_compute', true );

        if ( preg_match_all( '/\(([A-Z0-9\-]+)\)\s*x(\d+)/i', $order_text, $matches, PREG_SET_ORDER ) ) {
            // V.33.6: ไม่ต้อง global $wpdb แล้ว (M3 FIX ใช้ b2b_get_product_data() helper แทน raw SQL)
            $relations = get_option( 'dinoco_sku_relations', array() );
            $reserved_invalidated = false;

            foreach ( $matches as $m ) {
                $sku = strtoupper( trim( $m[1] ) );
                $qty = max( 1, intval( $m[2] ) );

                // Path A — Hierarchy-aware (V.33.5 default)
                if ( $use_hierarchy
                    && function_exists( 'dinoco_is_leaf_sku' )
                    && function_exists( 'dinoco_compute_hierarchy_stock' )
                    && function_exists( 'dinoco_get_reserved_qty' )
                ) {
                    $is_leaf = dinoco_is_leaf_sku( $sku, $relations );

                    if ( ! $is_leaf ) {
                        // Non-leaf SET — real-time compute
                        // V.33.6 CAVEAT (H1): delete_transient invalidate transient เท่านั้น
                        // `dinoco_get_reserved_qty()` ใช้ static $bulk_map cache ภายใน request — ถ้าในอนาคต
                        // มี caller ก่อนหน้าเรียก helper นี้แล้ว static จะยัง stale (acceptable
                        // สำหรับ Phase 0 เพราะ Snippet 2 webhook path ไม่มี earlier caller). Phase B opaque
                        // accept จะ refactor เลิกใช้ b2b_check_order_oos ทั้งก้อน → issue auto-resolve.
                        if ( ! $reserved_invalidated ) {
                            delete_transient( 'b2b_reserved_map_bulk' );
                            $reserved_invalidated = true;
                        }

                        $computed  = (int) dinoco_compute_hierarchy_stock( $sku, $relations );
                        $reserved  = (int) dinoco_get_reserved_qty( $sku );
                        $available = max( 0, $computed - $reserved );

                        // V.33.6 M3 FIX: ใช้ b2b_get_product_data() helper แทน raw SQL
                        // (helper return manual_hold + oos_eta_date อยู่แล้ว — ไม่จำเป็นต้อง raw SQL)
                        $pd          = b2b_get_product_data( $sku );
                        $manual_hold = $pd ? (int) ( $pd['manual_hold'] ?? 0 ) : 0;
                        $eta_date    = $pd ? ( $pd['oos_eta_date'] ?? '' ) : '';

                        if ( $manual_hold || $available < $qty ) {
                            $oos_items[] = array( 'sku' => $sku, 'eta' => $eta_date );
                            if ( function_exists( 'b2b_log' ) ) {
                                b2b_log( sprintf(
                                    '[OOS_GATE] SET=%s computed=%d reserved=%d available=%d qty=%d manual_hold=%d → OOS',
                                    $sku, $computed, $reserved, $available, $qty, $manual_hold
                                ) );
                            }
                        }
                        continue;
                    }
                    // Leaf → fall through to manual OOS flag check (Path B)
                }

                // Path B — Leaf หรือ fallback (behavior เดิม)
                if ( b2b_check_oos_memory( $sku ) ) {
                    $eta = '';
                    if ( function_exists( 'b2b_get_product_data' ) ) {
                        $pd  = b2b_get_product_data( $sku );
                        $eta = $pd ? $pd['oos_eta_date'] : '';
                    } else {
                        $pid = b2b_find_product_by_sku( $sku );
                        $eta = $pid ? get_field( 'oos_eta_date', $pid ) : '';
                    }
                    $oos_items[] = array( 'sku' => $sku, 'eta' => $eta );
                }
            }
        }
        return $oos_items;
    }
}
if ( ! function_exists( 'b2b_mark_product_oos' ) ) {
    function b2b_mark_product_oos( $sku, $eta_days = 0 ) {
        $sku = strtoupper( trim( $sku ) );
        $now_ts = time();
        $hrs = $eta_days > 0 ? $eta_days * 24 : 0;
        $eta_date = $eta_days > 0 ? b2b_date('Y-m-d', strtotime("+{$eta_days} days")) : '';

        // Dual-write ACF
        $pid = b2b_find_product_by_sku( $sku );
        if ( $pid ) {
            update_field('stock_status', 'out_of_stock', $pid);
            update_field('oos_timestamp', $now_ts, $pid);
            update_field('oos_duration_hours', $hrs, $pid);
            update_field('oos_eta_date', $eta_date, $pid);
        }

        // V.32.4: Write to custom table (source of truth)
        if ( class_exists('DINOCO_Catalog') ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_products';
            $update = array(
                'stock_status'       => 'out_of_stock',
                'oos_timestamp'      => $now_ts,
                'oos_duration_hours' => $hrs,
                'oos_eta_date'       => $eta_date ?: null,
            );
            $wpdb->update( $table, $update, array( 'sku' => $sku ) );
        }

        // ถ้า Inventory initialized → set manual_hold
        if (get_option('dinoco_inv_initialized')) {
            global $wpdb;
            $wpdb->update($wpdb->prefix . 'dinoco_products', array(
                'manual_hold' => 1,
                'manual_hold_reason' => 'Admin manual OOS',
                'manual_hold_by' => get_current_user_id(),
            ), array('sku' => $sku));
        }
        delete_transient('b2b_sku_data_map');
        return $pid ? true : (class_exists('DINOCO_Catalog') ? (bool) DINOCO_Catalog::get_by_sku($sku) : false);
    }
}
if ( ! function_exists( 'b2b_unlock_product_oos' ) ) {
    function b2b_unlock_product_oos( $sku ) {
        $sku = strtoupper( trim( $sku ) );

        // Dual-write ACF
        $pid = b2b_find_product_by_sku( $sku );
        if ( $pid ) {
            update_field('stock_status', 'in_stock', $pid);
            update_field('oos_timestamp', 0, $pid);
            update_field('oos_duration_hours', 0, $pid);
        }

        // V.32.4: Write to custom table (source of truth)
        if ( class_exists('DINOCO_Catalog') ) {
            global $wpdb;
            $table = $wpdb->prefix . 'dinoco_products';
            $wpdb->update( $table, array(
                'stock_status'       => 'in_stock',
                'oos_timestamp'      => null,
                'oos_duration_hours' => null,
                'oos_eta_date'       => null,
            ), array( 'sku' => $sku ) );
        }

        // ถ้า Inventory initialized → ปลด manual_hold
        if (get_option('dinoco_inv_initialized')) {
            global $wpdb;
            $wpdb->update($wpdb->prefix . 'dinoco_products', array(
                'manual_hold' => 0,
                'manual_hold_reason' => null,
                'manual_hold_by' => null,
            ), array('sku' => $sku));
            // ให้ auto_status recalculate
            if (function_exists('dinoco_stock_auto_status')) {
                dinoco_stock_auto_status($sku);
            }
        }
        delete_transient('b2b_sku_data_map');
        return $pid ? true : (class_exists('DINOCO_Catalog') ? (bool) DINOCO_Catalog::get_by_sku($sku) : false);
    }
}

