if ( ! function_exists( 'b2b_build_flex_sla_alert' ) ) {
    function b2b_build_flex_sla_alert( $ticket_id ) {
        $order_text = get_field('order_items', $ticket_id) ?: '';
        $preview = trim(mb_substr(preg_replace('/^.*?ขอยืนยัน[^:]*:\s*/u', '', $order_text), 0, 80));
        $gid = get_field('source_group_id', $ticket_id); $dist = $gid ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? get_the_title($dist->ID) : 'N/A';
        $status = get_field('order_status', $ticket_id) ?: 'checking_stock';
        $nag = intval(get_post_meta($ticket_id, '_sla_nag_count', true));
        $mins = max($nag, 1) * 10;

        // Status label
        $sl = array('checking_stock'=>'รอเช็คสต็อก','awaiting_confirm'=>'รอยืนยันราคา','awaiting_payment'=>'รอชำระเงิน','cancel_requested'=>'ลูกค้าขอยกเลิก',
            'change_requested'=>'ลูกค้าขอแก้ไข','claim_opened'=>'เคลมรอดำเนินการ','paid'=>'ชำระแล้ว');
        $status_text = isset($sl[$status]) ? $sl[$status] : $status;

        // Urgency
        $urgency = $nag >= 6 ? '🚨🚨🚨' : ($nag >= 3 ? '🚨' : '🔔');
        $header_bg = $nag >= 6 ? '#7f1d1d' : ($nag >= 3 ? '#991b1b' : '#dc2626');
        $header_sub = $nag >= 6 ? 'เกิน '.round($mins/60).' ชม.! ด่วนมาก!' : 'ค้างมา '.$mins.' นาทีแล้ว!';

        $body = array(
            array('type'=>'text','text'=>'🏪 '.$shop,'size'=>'sm','weight'=>'bold'),
            array('type'=>'text','text'=>'Ticket #'.$ticket_id.' · '.$status_text,'size'=>'xs','color'=>'#dc2626','margin'=>'md','wrap'=>true));
        if ($preview) $body[] = array('type'=>'text','text'=>$preview,'size'=>'xxs','color'=>'#64748b','margin'=>'sm','wrap'=>true);

        // ── Action buttons ตาม status ──
        $actions = array();
        switch ($status) {
            case 'checking_stock':
                $actions[] = array('type'=>'button','style'=>'primary','color'=>'#16a34a','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'✅ มีสินค้าครบ','data'=>'action=stock_confirm&ticket_id='.$ticket_id));
                $actions[] = array('type'=>'button','style'=>'secondary','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'🚫 สินค้าหมด','data'=>'action=stock_oos&ticket_id='.$ticket_id));
                break;
            case 'cancel_requested':
                $actions[] = array('type'=>'button','style'=>'primary','color'=>'#16a34a','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'✅ อนุมัติยกเลิก','data'=>'action=cancel_approve&ticket_id='.$ticket_id));
                $actions[] = array('type'=>'button','style'=>'secondary','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'❌ ปฏิเสธ','data'=>'action=cancel_reject&ticket_id='.$ticket_id));
                break;
            case 'change_requested':
                $actions[] = array('type'=>'button','style'=>'primary','color'=>'#16a34a','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'✅ อนุมัติแก้ไข','data'=>'action=change_approve&ticket_id='.$ticket_id));
                $actions[] = array('type'=>'button','style'=>'secondary','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'❌ ปฏิเสธ','data'=>'action=change_reject&ticket_id='.$ticket_id));
                break;
            case 'claim_opened':
                $actions[] = array('type'=>'button','style'=>'primary','color'=>'#16a34a','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'🔄 เปลี่ยนสินค้า','data'=>'action=claim_exchange&ticket_id='.$ticket_id));
                $actions[] = array('type'=>'button','style'=>'secondary','height'=>'sm',
                    'action'=>array('type'=>'postback','label'=>'💰 คืนเงิน','data'=>'action=claim_refund&ticket_id='.$ticket_id));
                break;
            case 'paid': case 'shipped':
                $url = function_exists('b2b_liff_url') ? b2b_liff_url('b2b-ticket/', array('ticket_id'=>$ticket_id)) : '';
                $actions[] = array('type'=>'button','style'=>'primary','color'=>'#1e40af','height'=>'sm',
                    'action'=>array('type'=>'uri','label'=>'📋 ดูรายละเอียด','uri'=>$url));
                break;
        }

        // ── Snooze button (ทุก status) ──
        $actions[] = array('type'=>'button','style'=>'secondary','height'=>'sm','margin'=>'lg',
            'action'=>array('type'=>'postback','label'=>'⏸️ ยังไม่ว่าง — เลื่อน 30 นาที','data'=>'action=sla_snooze&ticket_id='.$ticket_id.'&mins=30'));

        return array('type'=>'flex','altText'=>$urgency.' SLA #'.$ticket_id.' ค้าง '.$mins.' นาที',
            'contents'=>array('type'=>'bubble','size'=>'kilo',
                'header'=>b2b_flex_header($urgency.' SLA ALERT',$header_sub,$header_bg),
                'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'14px','contents'=>$body),
                'footer'=>array('type'=>'box','layout'=>'vertical','spacing'=>'sm','paddingAll'=>'10px','contents'=>$actions)));
    }
}

