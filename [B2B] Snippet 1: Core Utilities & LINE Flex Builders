// ──────────────────────────────────────────────────────────────
// V.34.0 REST ENDPOINTS — Flash Override / Cancel / Audit / DLQ
// ──────────────────────────────────────────────────────────────

add_action( 'rest_api_init', function() {

    // Shared permission callback — admin only + X-WP-Nonce
    $admin_perm = function( WP_REST_Request $req ) {
        $nonce = $req->get_header( 'X-WP-Nonce' );
        if ( ! $nonce || ! wp_verify_nonce( $nonce, 'wp_rest' ) ) return false;
        return current_user_can( 'manage_options' );
    };

    // ═════════════════════════════════════════════════════════════
    // POST /b2b/v1/flash-override-vehicle
    // Admin overrides expressCategory on ticket before/after create
    // BLK-5: post-pickup-called → return 409 (require cancel+recreate)
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-override-vehicle', array(
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $req ) {
            $ticket_id = absint( $req->get_param( 'ticket_id' ) );
            $new_ec    = absint( $req->get_param( 'express_category' ) );
            $reason    = sanitize_text_field( $req->get_param( 'reason' ) ) ?: 'admin override';

            if ( ! $ticket_id ) return new WP_Error( 'bad_input', 'ticket_id required', array( 'status' => 400 ) );
            if ( ! in_array( $new_ec, array( 1, 4 ), true ) ) return new WP_Error( 'bad_input', 'express_category must be 1 or 4', array( 'status' => 400 ) );

            $post = get_post( $ticket_id );
            if ( ! $post ) return new WP_Error( 'not_found', 'ticket not found', array( 'status' => 404 ) );

            // BLK-5: if pickup already called → reject (Flash Q5 allows multi-pickup but override
            // on already-called pickup is undefined; admin must cancel + recreate)
            $pickup_called = get_post_meta( $ticket_id, '_flash_pickup_called_at', true );
            if ( $pickup_called ) {
                return new WP_Error( 'pickup_already_called',
                    'Pickup ถูกเรียกแล้ว — ต้อง cancel pickup ก่อน แล้ว recreate ด้วย EC ใหม่ (Flash Q5)',
                    array( 'status' => 409, 'pickup_called_at' => $pickup_called )
                );
            }

            // Update meta + audit log
            $old_ec = (int) get_post_meta( $ticket_id, '_flash_express_category', true );
            update_post_meta( $ticket_id, '_flash_express_category', $new_ec );
            update_post_meta( $ticket_id, '_flash_ec_override_by', get_current_user_id() );
            update_post_meta( $ticket_id, '_flash_ec_override_at', current_time( 'mysql' ) );
            update_post_meta( $ticket_id, '_flash_ec_override_reason', $reason );

            // Insert audit row
            global $wpdb;
            $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
            if ( $wpdb->get_var( "SHOW TABLES LIKE '{$audit_tbl}'" ) ) {
                $wpdb->insert( $audit_tbl, array(
                    'ticket_id'        => $ticket_id,
                    'event_type'       => 'ec_override',
                    'expected_ec'      => $old_ec,
                    'actual_ec'        => $new_ec,
                    'request_summary'  => wp_json_encode( array( 'reason' => $reason ) ),
                    'response_summary' => '',
                    'user_id'          => get_current_user_id(),
                    'created_at'       => current_time( 'mysql' ),
                ) );
            }

            if ( function_exists( 'b2b_log' ) ) b2b_log( "[FlashOverride] ticket={$ticket_id} EC {$old_ec}→{$new_ec} reason={$reason}" );

            return rest_ensure_response( array(
                'ok' => true,
                'ticket_id' => $ticket_id,
                'express_category' => $new_ec,
                'previous' => $old_ec,
            ) );
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // POST /b2b/v1/flash-cancel-pickup
    // Admin cancels scheduled pickup (Flash notify request)
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-cancel-pickup', array(
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $req ) {
            $pickup_tid = sanitize_text_field( $req->get_param( 'pickup_tid' ) );
            $warehouse_no = sanitize_text_field( $req->get_param( 'warehouse_no' ) );
            $reason    = sanitize_text_field( $req->get_param( 'reason' ) ) ?: 'admin cancel';

            if ( ! $pickup_tid && ! $warehouse_no ) {
                return new WP_Error( 'bad_input', 'pickup_tid หรือ warehouse_no อย่างน้อย 1 ตัว', array( 'status' => 400 ) );
            }

            // Clear active_pickup transient (both keys — bike + truck)
            if ( $warehouse_no ) {
                $key = 'b2b_flash_pickup_' . md5( $warehouse_no );
                delete_transient( $key );
            }

            // Try Flash API cancel endpoint (if exists in b2b_flash_request)
            $result = array( 'cancelled_local' => true );
            if ( function_exists( 'b2b_flash_request' ) && $pickup_tid ) {
                // Flash API: POST /open/v1/notify/cancel (hypothetical — actual endpoint per Flash docs)
                $resp = @b2b_flash_request( 'open/v1/notify/cancel', array( 'tid' => $pickup_tid ) );
                $result['flash_response'] = $resp;
            }

            // Audit log
            global $wpdb;
            $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
            if ( $wpdb->get_var( "SHOW TABLES LIKE '{$audit_tbl}'" ) ) {
                $wpdb->insert( $audit_tbl, array(
                    'ticket_id'        => 0,
                    'event_type'       => 'pickup_cancel',
                    'request_summary'  => wp_json_encode( array( 'pickup_tid' => $pickup_tid, 'warehouse_no' => $warehouse_no, 'reason' => $reason ) ),
                    'response_summary' => wp_json_encode( $result ),
                    'user_id'          => get_current_user_id(),
                    'created_at'       => current_time( 'mysql' ),
                ) );
            }

            if ( function_exists( 'b2b_log' ) ) b2b_log( "[FlashCancelPickup] pickup_tid={$pickup_tid} wh={$warehouse_no} reason={$reason}" );

            return rest_ensure_response( array_merge( array( 'ok' => true ), $result ) );
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // GET /b2b/v1/flash-audit?ticket_id={id}
    // Admin view Flash audit trail for a ticket
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-audit', array(
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $req ) {
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_flash_audit';
            if ( ! $wpdb->get_var( "SHOW TABLES LIKE '{$tbl}'" ) ) {
                return rest_ensure_response( array( 'ok' => true, 'items' => array(), 'note' => 'audit table not yet created (run Snippet 15 V.8.0)' ) );
            }
            $ticket_id = absint( $req->get_param( 'ticket_id' ) );
            $limit = min( 100, max( 10, absint( $req->get_param( 'limit' ) ) ?: 50 ) );

            if ( $ticket_id ) {
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT * FROM {$tbl} WHERE ticket_id = %d ORDER BY created_at DESC LIMIT %d",
                    $ticket_id, $limit
                ), ARRAY_A );
            } else {
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT * FROM {$tbl} ORDER BY created_at DESC LIMIT %d",
                    $limit
                ), ARRAY_A );
            }
            return rest_ensure_response( array( 'ok' => true, 'items' => $rows ?: array(), 'total' => count( $rows ?: array() ) ) );
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // GET /b2b/v1/flash-dlq — list pending DLQ entries (F7)
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-dlq', array(
        'methods'  => 'GET',
        'callback' => function( WP_REST_Request $req ) {
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
            if ( ! $wpdb->get_var( "SHOW TABLES LIKE '{$tbl}'" ) ) {
                return rest_ensure_response( array( 'ok' => true, 'items' => array(), 'note' => 'DLQ table not yet created' ) );
            }
            $status = sanitize_text_field( $req->get_param( 'status' ) ) ?: 'pending';
            $limit = min( 100, max( 10, absint( $req->get_param( 'limit' ) ) ?: 50 ) );

            if ( in_array( $status, array( 'pending', 'resolved', 'abandoned' ), true ) ) {
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT * FROM {$tbl} WHERE status = %s ORDER BY created_at DESC LIMIT %d",
                    $status, $limit
                ), ARRAY_A );
            } else {
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT * FROM {$tbl} ORDER BY created_at DESC LIMIT %d", $limit
                ), ARRAY_A );
            }
            $counts = $wpdb->get_results( "SELECT status, COUNT(*) as cnt FROM {$tbl} GROUP BY status", ARRAY_A );
            $summary = array();
            foreach ( (array) $counts as $c ) $summary[ $c['status'] ] = (int) $c['cnt'];
            return rest_ensure_response( array(
                'ok' => true,
                'items' => $rows ?: array(),
                'total' => count( $rows ?: array() ),
                'summary' => $summary,
            ) );
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // POST /b2b/v1/flash-dlq/{id}/retry — manual retry
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-dlq/(?P<id>\d+)/retry', array(
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $req ) {
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
            $id = absint( $req['id'] );

            // H-1 FIX: GET_LOCK prevents 2 admins clicking retry simultaneously
            // → 2 parallel Flash orders + double billing. 5s timeout.
            $lock_name = 'dlq_retry_' . $id;
            $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
            if ( $got_lock !== 1 ) {
                return new WP_Error( 'busy', 'Another admin is retrying this entry', array( 'status' => 423 ) );
            }
            try {
                $row = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM {$tbl} WHERE id = %d", $id ), ARRAY_A );
                if ( ! $row ) return new WP_Error( 'not_found', 'DLQ entry not found', array( 'status' => 404 ) );
                if ( $row['status'] !== 'pending' ) return new WP_Error( 'bad_state', 'status=' . $row['status'], array( 'status' => 400 ) );

                // V.34.8 Round 4 H-1: hard cap retry_count at 10 to prevent
                // runaway panic-click by admin — V.34.6 added GET_LOCK for
                // concurrency but didn't bound the retry growth per entry.
                if ( (int) $row['retry_count'] >= 10 ) {
                    return new WP_Error( 'max_retries', 'retry_count ' . $row['retry_count'] . ' exceeds max 10 — abandon instead', array( 'status' => 429 ) );
                }

                // V.34.10 HIGH-3 (PDPA §37): stored request_body is PII-masked — cannot
                // replay directly to Flash API. Instead rebuild full body from ticket_id
                // via the idempotent dispatcher which reads ticket meta + resolver.
                // Dispatcher short-circuits when ticket already has _flash_tracking_numbers
                // (concurrency-safe via GET_LOCK), so retry attempts never duplicate.
                $ticket_id = intval( $row['ticket_id'] );
                if ( ! $ticket_id ) {
                    return new WP_Error( 'bad_data', 'DLQ row missing ticket_id', array( 'status' => 400 ) );
                }
                if ( ! function_exists( 'b2b_flash_dispatch_create_all' ) ) {
                    return new WP_Error( 'no_dispatcher', 'b2b_flash_dispatch_create_all not available', array( 'status' => 500 ) );
                }

                $result = b2b_flash_dispatch_create_all( $ticket_id );
                $is_ok = is_array( $result ) && ! empty( $result['ok'] );

                if ( $is_ok ) {
                    $wpdb->update( $tbl, array(
                        'status' => 'resolved',
                        'resolved_at' => current_time( 'mysql' ),
                        'resolved_by' => get_current_user_id(),
                    ), array( 'id' => $id ) );
                } else {
                    // V.34.11 LOW-1: read status_code + error_code defensively.
                    // b2b_flash_request() V.34.4+ returns 'status_code' (HTTP)
                    // reliably; 'error_code' (Flash business code) is populated
                    // by the $execute wrapper in create-v42. Prefer non-empty
                    // status_code first (always present on failure), fall back
                    // to error_code, then generic error. Using !empty() skips
                    // empty strings so we never bury a real code behind ''.
                    $err_code = 'unknown';
                    if ( is_array( $result ) ) {
                        if ( ! empty( $result['status_code'] ) ) {
                            $err_code = (string) $result['status_code'];
                        } elseif ( ! empty( $result['error_code'] ) ) {
                            $err_code = (string) $result['error_code'];
                        } elseif ( ! empty( $result['error'] ) ) {
                            $err_code = (string) $result['error'];
                        }
                    }
                    $err_msg = '';
                    if ( is_array( $result ) ) {
                        if ( isset( $result['message'] ) )    $err_msg = (string) $result['message'];
                        elseif ( isset( $result['error'] ) )  $err_msg = (string) $result['error'];
                    }
                    $wpdb->update( $tbl, array(
                        'retry_count' => (int) $row['retry_count'] + 1,
                        'last_error_code' => $err_code,
                        'last_error_message' => $err_msg,
                    ), array( 'id' => $id ) );
                }

                return rest_ensure_response( array(
                    'ok' => $is_ok,
                    'dlq_id' => $id,
                    'ticket_id' => $ticket_id,
                    'result' => $result,
                    'status' => $is_ok ? 'resolved' : 'still_failing',
                ) );
            } finally {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // POST /b2b/v1/flash-dlq/{id}/abandon — admin gives up
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-dlq/(?P<id>\d+)/abandon', array(
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $req ) {
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
            $id = absint( $req['id'] );
            $reason = sanitize_text_field( $req->get_param( 'reason' ) ) ?: 'admin abandon';
            $updated = $wpdb->update( $tbl, array(
                'status' => 'abandoned',
                'resolved_at' => current_time( 'mysql' ),
                'resolved_by' => get_current_user_id(),
                'last_error_message' => $reason,
            ), array( 'id' => $id ) );
            if ( $updated === false ) return new WP_Error( 'db_error', 'update failed', array( 'status' => 500 ) );
            return rest_ensure_response( array( 'ok' => true, 'dlq_id' => $id, 'status' => 'abandoned' ) );
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // POST /b2b/v1/flash-test-payload
    // Admin dry-run helper (M6) — calls resolver without Flash side-effect
    // Mirrors /dinoco-stock/v1/shipping-compute but kept under b2b/v1 for namespace clarity
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/flash-test-payload', array(
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $req ) {
            $items = $req->get_param( 'items' );
            if ( ! is_array( $items ) ) return new WP_Error( 'bad_input', 'items array required', array( 'status' => 400 ) );

            $manifest = array();
            foreach ( $items as $it ) {
                $manifest[] = array(
                    'sku'       => strtoupper( sanitize_text_field( $it['sku'] ?? '' ) ),
                    'total_qty' => absint( $it['qty'] ?? 1 ),
                );
            }

            if ( ! function_exists( 'dinoco_resolve_manifest_shipping' ) ) {
                return new WP_Error( 'no_resolver', 'Snippet 15 V.8.0 helpers not loaded', array( 'status' => 500 ) );
            }
            $per_pno = dinoco_resolve_manifest_shipping( $manifest );

            return rest_ensure_response( array(
                'ok' => true,
                'manifest' => $manifest,
                'per_pno'  => $per_pno,
                'total_weight_g' => array_sum( array_column( $per_pno, 'weight_g' ) ),
                'pno_count' => count( $per_pno ),
            ) );
        },
        'permission_callback' => $admin_perm,
    ) );

    // ═════════════════════════════════════════════════════════════
    // H2 — POST /b2b/v1/shipping/manual-rollback (V.34.4)
    // Admin manual kill-switch for dinoco_shipping_meta_enabled flag
    // Audits into wp_dinoco_flash_audit (event_type=manual_rollback_flag, ticket_id=0)
    // ═════════════════════════════════════════════════════════════
    register_rest_route( 'b2b/v1', '/shipping/manual-rollback', array(
        'methods'  => 'POST',
        'callback' => function( WP_REST_Request $req ) {
            $reason = sanitize_text_field( $req->get_param( 'reason' ) ) ?: 'admin manual rollback';
            $uid = get_current_user_id();

            // V.34.11 MED-3: route through dinoco_set_shipping_flag() — helper
            // handles flipped_at + audit row (source='manual_rollback') in one
            // transaction. Replaces 3 inline calls (update_option x2 + $wpdb->insert).
            // NOTE: audit event_type is now 'flag_flip_off' (vs prior
            // 'manual_rollback_flag') — dashboards reading audit table should
            // filter on source='manual_rollback' inside payload_json.
            $rolled_back_at = current_time( 'mysql' );
            if ( function_exists( 'dinoco_set_shipping_flag' ) ) {
                $flip_result = dinoco_set_shipping_flag( '0', $reason, 'manual_rollback' );
                if ( is_array( $flip_result ) && ! empty( $flip_result['flipped_at'] ) ) {
                    $rolled_back_at = $flip_result['flipped_at'];
                }
            } else {
                // Fallback — preserve legacy behavior if helper unavailable
                update_option( 'dinoco_shipping_meta_enabled', '0' );
                update_option( 'dinoco_shipping_flag_flipped_at', $rolled_back_at );
            }

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[ManualRollback] V.42 flag disabled by user={$uid} reason={$reason}" );
            }

            return rest_ensure_response( array(
                'ok' => true,
                'rolled_back_at' => $rolled_back_at,
            ) );
        },
        'permission_callback' => $admin_perm,
    ) );

} );

