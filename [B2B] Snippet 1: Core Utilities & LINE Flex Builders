// ── V.33.4: Dunning Summary (multi-invoice CI card) ──
// ใช้กับ Manual Invoice reminder/overdue cron — รวมทุกบิลของตัวแทน 1 Flex
// $invoices = array of [
//   'inv_number'      => string (e.g. 'INV-2026-001' or '#123')
//   'total'           => float (INVOICE total full value — ใช้ตอน fallback)
//   'remaining'       => float (ยอดค้างหลังหักที่ชำระ — ถ้าไม่ set จะใช้ total)
//   'due_date_str'    => string (Thai display e.g. '15/04/2026' หรือ dd/mm/yyyy)
//   'days_until_due'  => int (> 0 = ใกล้ครบ, 0 = วันนี้, < 0 = overdue)
//   'days_overdue'    => int (>= 0; ถ้าไม่ส่ง จะคำนวณจาก -days_until_due)
// ]
// $opts = [
//   'show_credit_bar' => bool (default true ถ้าส่ง dist_id)
//   'accent_color'    => string (override header bg — default auto: แดงเข้มถ้ามี overdue)
//   'header_text'     => string (override header title)
// ]
if ( ! function_exists( 'b2b_build_flex_dunning_summary' ) ) {
    function b2b_build_flex_dunning_summary( $dist_id, $invoices, $opts = array() ) {
        $dist_id    = intval($dist_id);
        $invoices   = is_array($invoices) ? $invoices : array();
        $opts       = is_array($opts) ? $opts : array();

        if ( empty($invoices) ) {
            return null;
        }

        // ── Distributor info ──
        $dist_name = $dist_id ? ( get_field('shop_name', $dist_id) ?: get_the_title($dist_id) ) : '';
        if ( empty($dist_name) ) $dist_name = 'ตัวแทนจำหน่าย';

        $debt  = $dist_id ? floatval( get_field('current_debt', $dist_id) ) : 0;
        $limit = $dist_id ? floatval( get_field('credit_limit', $dist_id) ) : 0;

        // ── Normalize invoice rows + totals ──
        $has_overdue = false;
        $grand_total = 0;
        $normalized  = array();
        foreach ($invoices as $inv) {
            $inv_num   = isset($inv['inv_number']) ? (string)$inv['inv_number'] : '-';
            $remaining = isset($inv['remaining']) ? floatval($inv['remaining']) : (isset($inv['total']) ? floatval($inv['total']) : 0);
            if ($remaining <= 0) continue;
            $due_str   = isset($inv['due_date_str']) ? (string)$inv['due_date_str'] : '-';
            $d_until   = isset($inv['days_until_due']) ? intval($inv['days_until_due']) : 0;
            $d_over    = isset($inv['days_overdue']) ? intval($inv['days_overdue']) : max(0, -$d_until);
            if ($d_over > 0) $has_overdue = true;
            $grand_total += $remaining;
            $normalized[] = array(
                'inv_number'     => $inv_num,
                'remaining'      => $remaining,
                'due_date_str'   => $due_str,
                'days_until_due' => $d_until,
                'days_overdue'   => $d_over,
            );
        }

        if ( empty($normalized) ) return null;

        // ── Color tokens ──
        $accent = isset($opts['accent_color']) && !empty($opts['accent_color'])
            ? $opts['accent_color']
            : ( $has_overdue ? '#dc2626' : '#111111' );
        $header_text = isset($opts['header_text']) && !empty($opts['header_text'])
            ? $opts['header_text']
            : '📋 สรุปบิลค้างชำระ';
        $show_credit_bar = isset($opts['show_credit_bar']) ? (bool)$opts['show_credit_bar'] : ($dist_id > 0);

        // ── Build body contents ──
        $body = array();

        // Distributor row
        $body[] = array('type'=>'box','layout'=>'vertical','contents'=>array(
            array('type'=>'text','text'=>$dist_name,'weight'=>'bold','size'=>'md','color'=>B2B_FLEX_COLOR_TEXT_DARK,'wrap'=>true),
            array('type'=>'text','text'=>'ตัวแทนจำหน่าย','size'=>'xxs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT,'margin'=>'xs'),
        ));
        $body[] = array('type'=>'separator','margin'=>'md');

        // Section header: bill list
        $body[] = array('type'=>'text','text'=>count($normalized).' ใบ · ฿'.number_format($grand_total,0),'size'=>'xxs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT,'margin'=>'md');

        // Bill rows
        $first_row = true;
        foreach ($normalized as $inv) {
            if (!$first_row) $body[] = array('type'=>'separator','margin'=>'sm','color'=>'#f1f5f9');
            $first_row = false;

            // Color per urgency
            if ($inv['days_overdue'] > 0) {
                $amount_color = '#dc2626'; // danger
                $urgency_text = 'เลย '.$inv['days_overdue'].' วัน';
                $urgency_color = '#dc2626';
            } elseif ($inv['days_until_due'] == 0) {
                $amount_color = '#dc2626';
                $urgency_text = 'วันนี้';
                $urgency_color = '#dc2626';
            } elseif ($inv['days_until_due'] >= 1 && $inv['days_until_due'] <= 7) {
                $amount_color = '#f59e0b'; // warning
                $urgency_text = 'อีก '.$inv['days_until_due'].' วัน';
                $urgency_color = '#f59e0b';
            } else {
                $amount_color = B2B_FLEX_COLOR_TEXT_DARK;
                $urgency_text = 'อีก '.$inv['days_until_due'].' วัน';
                $urgency_color = '#16a34a';
            }

            // Row 1: inv_number / amount
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>$inv['inv_number'],'size'=>'sm','weight'=>'bold','color'=>B2B_FLEX_COLOR_TEXT_DARK,'flex'=>5,'wrap'=>true),
                array('type'=>'text','text'=>'฿'.number_format($inv['remaining'],0),'size'=>'sm','weight'=>'bold','color'=>$amount_color,'flex'=>4,'align'=>'end'),
            ));
            // Row 2: due_date / urgency
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>array(
                array('type'=>'text','text'=>$inv['due_date_str'],'size'=>'xxs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT,'flex'=>5),
                array('type'=>'text','text'=>$urgency_text,'size'=>'xxs','color'=>$urgency_color,'flex'=>4,'align'=>'end','weight'=>'bold'),
            ));
        }

        // Total row
        $body[] = array('type'=>'separator','margin'=>'md');
        $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','contents'=>array(
            array('type'=>'text','text'=>'ยอดค้างรวม','size'=>'sm','weight'=>'bold','color'=>B2B_FLEX_COLOR_TEXT_DARK,'flex'=>4),
            array('type'=>'text','text'=>'฿'.number_format($grand_total,0),'size'=>'lg','weight'=>'bold','color'=>'#dc2626','flex'=>5,'align'=>'end'),
        ));

        // Credit bar (copy pattern จาก b2b_build_flex_account_info L.3071-3082)
        if ( $show_credit_bar && $limit > 0 ) {
            $remain = max(0, $limit - $debt);
            $pct = min(100, round( ($limit > 0 ? $debt / $limit : 0) * 100 ));
            $bar_color = $pct > 80 ? '#dc2626' : ($pct > 50 ? '#f59e0b' : '#16a34a');
            $body[] = array('type'=>'separator','margin'=>'md');
            $body[] = array('type'=>'text','text'=>'เครดิตคงเหลือ','size'=>'xs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT,'margin'=>'md','weight'=>'bold');
            $body[] = array('type'=>'box','layout'=>'vertical','margin'=>'sm','height'=>'6px','cornerRadius'=>'3px','backgroundColor'=>'#e2e8f0','contents'=>array(
                array('type'=>'box','layout'=>'vertical','height'=>'6px','cornerRadius'=>'3px','backgroundColor'=>$bar_color,'width'=>$pct.'%','contents'=>array(
                    array('type'=>'filler'),
                )),
            ));
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>array(
                array('type'=>'text','text'=>'฿'.number_format($remain,0).' / ฿'.number_format($limit,0),'size'=>'xxs','color'=>B2B_FLEX_COLOR_TEXT_MID,'flex'=>1,'align'=>'end'),
            ));
        }

        // Bank section (copy pattern จาก b2b_build_flex_payment_invoice L.2459-2471)
        $bank      = b2b_get_bank_info();
        $bank_logo = b2b_get_bank_logo_url();
        $bank_card_contents = array();
        if ( !empty($bank_logo) ) {
            $bank_card_contents[] = array('type'=>'box','layout'=>'horizontal','spacing'=>'md','contents'=>array(
                array('type'=>'image','url'=>$bank_logo,'size'=>'xxs','aspectRatio'=>'1:1','aspectMode'=>'cover','flex'=>0),
                array('type'=>'box','layout'=>'vertical','flex'=>4,'contents'=>array(
                    array('type'=>'text','text'=>$bank['name'],'weight'=>'bold','size'=>'sm','color'=>B2B_FLEX_COLOR_TEXT_DARK),
                    array('type'=>'text','text'=>(!empty($bank['name_en']) ? '('.$bank['name_en'].')' : ''),'size'=>'xxs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT),
                )),
            ));
        } else {
            $bank_card_contents[] = array('type'=>'text','text'=>'🏦 '.$bank['name'],'weight'=>'bold','size'=>'sm','color'=>B2B_FLEX_COLOR_TEXT_DARK);
        }
        $bank_card_contents[] = array('type'=>'text','text'=>$bank['account'],'weight'=>'bold','size'=>'xxl','color'=>'#111111','align'=>'center','margin'=>'lg');
        $bank_card_contents[] = array('type'=>'text','text'=>'ชื่อบัญชี: '.$bank['holder'],'size'=>'xs','color'=>B2B_FLEX_COLOR_TEXT_MID,'align'=>'center','margin'=>'xs');

        $body[] = array('type'=>'separator','margin'=>'md');
        $body[] = array('type'=>'text','text'=>'ช่องทางชำระเงิน','size'=>'xs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT,'margin'=>'md','weight'=>'bold');
        $body[] = array('type'=>'box','layout'=>'vertical','margin'=>'sm','backgroundColor'=>'#f0fdf4','cornerRadius'=>'12px','paddingAll'=>'16px','contents'=>$bank_card_contents);

        // Footer — clipboard button
        $footer = array(
            array('type'=>'button','action'=>array('type'=>'clipboard','label'=>'📋 คัดลอกข้อมูลบัญชี','clipboardText'=>b2b_get_bank_copy_text()),'style'=>'primary','color'=>'#16a34a','height'=>'sm'),
            array('type'=>'text','text'=>'โอนแล้วส่งสลิปเข้ากลุ่มนี้ได้เลยครับ','size'=>'xxs','color'=>B2B_FLEX_COLOR_TEXT_LIGHT,'align'=>'center','margin'=>'md','wrap'=>true),
        );

        $alt = mb_substr('📋 สรุปบิลค้างชำระ '.$dist_name.' '.count($normalized).' ใบ ฿'.number_format($grand_total,0), 0, 400);

        return array(
            'type'     => 'flex',
            'altText'  => $alt,
            'contents' => array(
                'type'   => 'bubble',
                'size'   => 'mega',
                'header' => b2b_flex_header($header_text, count($normalized).' ใบ · ฿'.number_format($grand_total,0), $accent),
                'body'   => array('type'=>'box','layout'=>'vertical','paddingAll'=>'16px','spacing'=>'none','contents'=>$body),
                'footer' => array('type'=>'box','layout'=>'vertical','spacing'=>'sm','paddingAll'=>'12px','contents'=>$footer),
            ),
        );
    }
}

