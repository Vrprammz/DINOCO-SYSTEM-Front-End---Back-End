        $urgency = $nag >= 6 ? '🚨🚨🚨' : ($nag >= 3 ? '🚨' : '🔔');
        $header_bg = $nag >= 6 ? '#7f1d1d' : ($nag >= 3 ? '#991b1b' : '#dc2626');
        $header_sub = $nag >= 6 ? 'เกิน '.round($mins/60).' ชม.! ด่วนมาก!' : 'ค้างมา '.$mins.' นาทีแล้ว!';

        $body = array(
            array('type'=>'text','text'=>'🏪 '.$shop,'size'=>'sm','weight'=>'bold'),
            array('type'=>'text','text'=>'Ticket #'.$ticket_id.' · '.$status_text,'size'=>'xs','color'=>'#dc2626','margin'=>'md','wrap'=>true));
        if ($preview) $body[] = array('type'=>'text','text'=>$preview,'size'=>'xxs','color'=>'#64748b','margin'=>'sm','wrap'=>true);

        // ── Action buttons ตาม status ──
        $actions = array();
