// ── 11.2 Flex: เช็คสถานะ #ID (Ticket Detail) ──
if ( ! function_exists( 'b2b_build_flex_ticket_detail' ) ) {
    function b2b_build_flex_ticket_detail( $ticket_id ) {
        $status = get_field('order_status', $ticket_id) ?: 'draft';
        $labels = b2b_get_status_labels(); $sl = isset($labels[$status]) ? $labels[$status] : $status;
        $total = floatval(get_field('total_amount', $ticket_id));
        $due = get_field('due_date', $ticket_id); $tracking = get_field('tracking_number', $ticket_id);
        $items_raw = get_field('order_items', $ticket_id) ?: '';
        $items_preview = trim(mb_substr(preg_replace('/^.*?ขอยืนยัน[^:]*:\s*/u', '', $items_raw), 0, 120));
        if (empty($items_preview)) $items_preview = mb_substr($items_raw, 0, 120);
        $claimed = get_field('claimed_by_admin', $ticket_id) ?: '';
        $date = b2b_date('d/m/Y H:i', get_post_time('U', true, $ticket_id));
        $status_colors = array('draft'=>'#94a3b8','checking_stock'=>'#f59e0b','awaiting_confirm'=>'#3b82f6','awaiting_payment'=>'#ef4444','paid'=>'#16a34a','shipped'=>'#06b6d4','completed'=>'#16a34a','backorder'=>'#f97316');
        $sc = isset($status_colors[$status]) ? $status_colors[$status] : '#64748b';
        $body = array();
        $body[] = array('type'=>'box','layout'=>'horizontal','paddingAll'=>'8px','cornerRadius'=>'8px','backgroundColor'=>$sc.'18','contents'=>array(
            array('type'=>'text','text'=>$sl,'size'=>'sm','weight'=>'bold','color'=>$sc,'align'=>'center')));
        $body[] = array('type'=>'separator','margin'=>'lg');
        if (!empty($items_preview)) $body[] = array('type'=>'text','text'=>$items_preview,'size'=>'xs','color'=>'#475569','wrap'=>true,'margin'=>'lg');
        $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'lg','contents'=>array(
            array('type'=>'text','text'=>'ยอด','size'=>'xs','color'=>'#64748b','flex'=>3),
            array('type'=>'text','text'=>'฿'.number_format($total,0),'size'=>'md','weight'=>'bold','color'=>'#1e293b','flex'=>7,'align'=>'end')));
        $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
            array('type'=>'text','text'=>'วันสั่ง','size'=>'xs','color'=>'#64748b','flex'=>3),
            array('type'=>'text','text'=>$date,'size'=>'xs','flex'=>7,'align'=>'end')));
        if ($due) {
            $due_str = function_exists('b2b_parse_date') ? b2b_parse_date($due) : $due;
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>'กำหนดชำระ','size'=>'xs','color'=>'#64748b','flex'=>3),
                array('type'=>'text','text'=>$due_str,'size'=>'xs','flex'=>7,'align'=>'end')));
        }
        if ($tracking) {
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>'เลขพัสดุ','size'=>'xs','color'=>'#64748b','flex'=>3),
                array('type'=>'text','text'=>$tracking,'size'=>'xs','weight'=>'bold','color'=>'#2563eb','flex'=>7,'align'=>'end')));
        }
        if ($claimed) {
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>'ผู้ดูแล','size'=>'xs','color'=>'#64748b','flex'=>3),
                array('type'=>'text','text'=>$claimed,'size'=>'xs','flex'=>7,'align'=>'end')));
        }
        $ticket_url = b2b_liff_url('b2b-ticket/', array('ticket_id'=>$ticket_id));
        $footer = array(
            array('type'=>'button','style'=>'primary','color'=>'#2563eb','height'=>'sm',
                'action'=>array('type'=>'uri','label'=>'📋 ดูรายละเอียดเต็ม','uri'=>$ticket_url)));
        if ($status === 'awaiting_payment') {
            $footer[] = array('type'=>'button','style'=>'secondary','height'=>'sm',
                'action'=>array('type'=>'uri','label'=>'💳 ดูบัญชี','uri'=>b2b_liff_url('b2b-account/')));
        }
        return array('type'=>'flex','altText'=>'📋 Ticket #'.$ticket_id.' — '.$sl,
            'contents'=>array('type'=>'bubble','size'=>'mega',
                'header'=>b2b_flex_header('📋 Ticket #'.$ticket_id,$sl.' · '.$date,$sc),
                'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'14px','spacing'=>'none','contents'=>$body),
                'footer'=>array('type'=>'box','layout'=>'vertical','spacing'=>'sm','paddingAll'=>'12px','contents'=>$footer)));
    }
}

