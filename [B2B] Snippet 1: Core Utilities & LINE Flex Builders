    //   ไม่ต้อง load LIFF SDK, ไม่ต้อง liff.init(), ไม่ต้อง verify-member
    //   ลด 1-3 วินาที + ไม่มีหน้าขาว
    // ═══════════════════════════════════════════════════
    if (hasSig) {
        console.log("[LIFF Guard] Fast path — HMAC verified server-side, skip LIFF SDK");
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", showContent);
        } else {
            showContent();
