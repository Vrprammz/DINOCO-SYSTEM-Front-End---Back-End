        if ($pending > 0) $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','paddingAll'=>'6px','cornerRadius'=>'6px','backgroundColor'=>'#fef3c7','contents'=>array(
            array('type'=>'text','text'=>'🧾 บิลค้างชำระอีก '.$pending.' รายการ','size'=>'xxs','color'=>'#92400e','wrap'=>true)));
        if ($hold) $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','paddingAll'=>'8px','cornerRadius'=>'8px','backgroundColor'=>'#fee2e2','contents'=>array(
