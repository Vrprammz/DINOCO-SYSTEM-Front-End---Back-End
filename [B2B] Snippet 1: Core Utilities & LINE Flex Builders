        );
        $status_texts = array(
            'created' => 'รอจัดส่ง', 'picked_up' => 'คูเรียร์รับแล้ว', 'in_transit' => 'ระหว่างขนส่ง',
            'delivering' => 'กำลังนำส่ง', 'delivered' => 'ส่งถึงแล้ว', 'detained' => 'คงคลัง',
            'returned' => 'ตีกลับ', 'cancelled' => 'ยกเลิก', 'hold_pending' => 'รอส่งรอบถัดไป',
        );

        $body = array();
        foreach ( $pno_statuses as $pno => $info ) {
            $box_label = is_array( $info ) ? ( $info['box'] ?? '' ) : '';
            $item_name = is_array( $info ) ? ( $info['name'] ?? '' ) : '';
            $pno_status = is_array( $info ) ? ( $info['status'] ?? 'created' ) : 'created';
            $icon = $status_icons[ $pno_status ] ?? '📦';
            $stxt = $status_texts[ $pno_status ] ?? $pno_status;
            $body[] = array( 'type' => 'text', 'text' => $icon . ' กล่อง ' . $box_label . ': ' . $item_name, 'size' => 'sm', 'weight' => 'bold', 'margin' => 'md' );
            $body[] = array( 'type' => 'text', 'text' => '   🚚 ' . $pno . ' — ' . $stxt, 'size' => 'xs', 'color' => '#666666' );
        }

        // Footer
        $footer_contents = array();
        if ( defined( 'B2B_LIFF_ID' ) ) {
            $ticket_url = b2b_liff_url( 'b2b-ticket/', array( 'ticket_id' => (string) $ticket_id ) );
            $footer_contents[] = array( 'type' => 'button', 'style' => 'link', 'height' => 'sm',
                'action' => array( 'type' => 'uri', 'label' => '📋 ดูรายละเอียด', 'uri' => $ticket_url ) );
        }

        $bubble = array( 'type' => 'bubble',
            'header' => b2b_flex_header( '📦 สถานะพัสดุ #' . $ticket_id, $status_label . ' (' . $total_boxes . ' กล่อง)', $color ),
            'body'   => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $body ),
        );
        if ( ! empty( $footer_contents ) ) {
            $bubble['footer'] = array( 'type' => 'box', 'layout' => 'vertical', 'spacing' => 'sm', 'paddingAll' => '12px', 'contents' => $footer_contents );
        }
        return array( 'type' => 'flex', 'altText' => '📦 สถานะพัสดุ #' . $ticket_id . ' — ' . $status_label, 'contents' => $bubble );
    }
}

// ════════════════════════════════════════════════════════════════
// V.36: Flex Card — ยกเลิกบางกล่อง (แจ้งตัวแทน)
// ════════════════════════════════════════════════════════════════
if ( ! function_exists( 'b2b_build_flex_partial_cancel' ) ) {
    function b2b_build_flex_partial_cancel( $ticket_id, $pno_statuses, $cancelled_name = '' ) {
        $dist_name = get_field( 'dist_name', $ticket_id ) ?: '';
        $color     = '#f59e0b';

        $body = array();
        foreach ( $pno_statuses as $pno => $info ) {
            $box_label = is_array( $info ) ? ( $info['box'] ?? '' ) : '';
            $item_name = is_array( $info ) ? ( $info['name'] ?? '' ) : '';
            $status    = is_array( $info ) ? ( $info['status'] ?? 'created' ) : 'created';
            if ( $status === 'cancelled' || $status === 'hold_pending' ) {
                $body[] = array( 'type' => 'text', 'text' => '❌ กล่อง ' . $box_label . ': ' . $item_name . ' — ยกเลิก', 'size' => 'sm', 'color' => '#dc2626', 'margin' => 'sm' );
            } else {
                $body[] = array( 'type' => 'text', 'text' => '✅ กล่อง ' . $box_label . ': ' . $item_name . ' — พร้อมส่ง', 'size' => 'sm', 'color' => '#16a34a', 'margin' => 'sm' );
            }
        }
        if ( $cancelled_name ) {
            $body[] = array( 'type' => 'separator', 'margin' => 'md' );
            $body[] = array( 'type' => 'text', 'text' => $cancelled_name . ' ไม่พร้อมส่ง — จะแจ้งอีกครั้งเมื่อพร้อม', 'size' => 'xs', 'color' => '#92400e', 'wrap' => true, 'margin' => 'sm' );
        }

        $footer_contents = array();
        if ( defined( 'B2B_LIFF_ID' ) ) {
            $ticket_url = b2b_liff_url( 'b2b-ticket/', array( 'ticket_id' => (string) $ticket_id ) );
            $footer_contents[] = array( 'type' => 'button', 'style' => 'link', 'height' => 'sm',
                'action' => array( 'type' => 'uri', 'label' => '📋 ดูรายละเอียด #' . $ticket_id, 'uri' => $ticket_url ) );
        }

        $bubble = array( 'type' => 'bubble',
            'header' => b2b_flex_header( '⚠️ สินค้าบางรายการถูกยกเลิก', '#' . $ticket_id . ' — ' . $dist_name, $color ),
            'body'   => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $body ),
        );
        if ( ! empty( $footer_contents ) ) {
            $bubble['footer'] = array( 'type' => 'box', 'layout' => 'vertical', 'spacing' => 'sm', 'paddingAll' => '12px', 'contents' => $footer_contents );
        }
        return array( 'type' => 'flex', 'altText' => '⚠️ #' . $ticket_id . ' สินค้าบางรายการถูกยกเลิก', 'contents' => $bubble );
    }
}
}
