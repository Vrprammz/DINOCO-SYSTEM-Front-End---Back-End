if ( ! function_exists( 'b2b_get_product_data' ) ) {
    /**
     * อ่านข้อมูลสินค้าจาก custom table (source of truth) → fallback ACF
     * @param string $sku
     * @return array|null  All product fields or null if not found
     */
    function b2b_get_product_data( $sku ) {
        $sku = strtoupper( trim( $sku ) );
        if ( empty( $sku ) ) return null;

        // Source 1: Custom table (source of truth)
        if ( class_exists( 'DINOCO_Catalog' ) ) {
            $ct = DINOCO_Catalog::get_by_sku( $sku );
            if ( $ct ) {
                return array(
                    'sku'                => $ct['sku'],
                    'name'               => $ct['name'],
                    'subtitle'           => $ct['subtitle'],
