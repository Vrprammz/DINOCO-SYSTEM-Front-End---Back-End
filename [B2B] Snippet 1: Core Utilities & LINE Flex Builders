// ═══════════════════════════════════════════════════════════════
// V.34.8: SLIP RESILIENCE HELPERS (Snippet 2 V.34.8 companion)
// ═══════════════════════════════════════════════════════════════
if ( ! function_exists( 'b2b_slip_log_insert' ) ) {
    /**
     * Insert audit row ใน wp_dinoco_slip_log — best-effort (ไม่ throw)
     * เรียกจากทุก decision point ใน b2b_handle_slip_image
     *
     * @param array $row assoc array: group_id, message_id, user_id, dist_id,
     *                   slip_code, amount, trans_ref, sender_name,
     *                   result_status, error_code, error_msg,
     *                   http_code, processing_time_ms, retry_count
     * @return int|false insert id หรือ false ถ้า fail
     */
    function b2b_slip_log_insert( $row ) {
        global $wpdb;
        if ( ! $wpdb ) return false;
        $table = $wpdb->prefix . 'dinoco_slip_log';

        // Defensive: ถ้า table ยังไม่ถูกสร้าง (Snippet 15 init ยังไม่ fire) — ข้าม ไม่ fatal
        static $table_exists = null;
        if ( $table_exists === null ) {
            $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        }
        if ( ! $table_exists ) return false;

        $defaults = array(
            'group_id'           => '',
            'message_id'         => '',
            'user_id'            => '',
            'dist_id'            => null,
            'slip_code'          => '',
            'amount'             => null,
            'trans_ref'          => '',
            'sender_name'        => '',
            'result_status'      => '',
            'error_code'         => '',
            'error_msg'          => '',
            'http_code'          => null,
            'processing_time_ms' => null,
            'retry_count'        => 0,
            // V.34.12: Slip Replay Pool fields (nullable — legacy callers omit = NULL)
            'image_hash'           => null,
            'image_mime'           => null,
            'slip2go_response'     => null,
            'replayed_from_log_id' => null,
            'created_at'         => current_time( 'mysql' ),
        );
        $row = array_merge( $defaults, is_array( $row ) ? $row : array() );

        // Truncate long fields เพื่อกัน error (V.34.9 L-3: add [TRUNC] marker if truncated)
        $row['group_id']    = substr( (string) $row['group_id'], 0, 100 );
        $row['message_id']  = substr( (string) $row['message_id'], 0, 64 );
        $row['user_id']     = substr( (string) $row['user_id'], 0, 64 );
        $row['slip_code']   = substr( (string) $row['slip_code'], 0, 16 );
        $row['trans_ref']   = substr( (string) $row['trans_ref'], 0, 100 );
        $row['sender_name'] = substr( (string) $row['sender_name'], 0, 200 );
        $row['result_status'] = substr( (string) $row['result_status'], 0, 32 );
        $row['error_code']  = substr( (string) $row['error_code'], 0, 32 );
        $_em = (string) $row['error_msg'];
        if ( mb_strlen( $_em ) > 500 ) {
            $row['error_msg'] = mb_substr( $_em, 0, 490 ) . '...[TRUNC]';
        } else {
            $row['error_msg'] = $_em;
        }

        // V.34.12: Slip Replay Pool — normalize new fields
        if ( $row['image_hash'] !== null ) {
            $row['image_hash'] = substr( (string) $row['image_hash'], 0, 64 );
            if ( $row['image_hash'] === '' ) $row['image_hash'] = null;
        }
        if ( $row['image_mime'] !== null ) {
            $row['image_mime'] = substr( (string) $row['image_mime'], 0, 20 );
            if ( $row['image_mime'] === '' ) $row['image_mime'] = null;
        }
        // slip2go_response: accept array/object → json_encode, or pass-through string,
        // or NULL. MEDIUMTEXT cap 16MB — realistic Slip2Go payload is <10KB so no cap needed.
        if ( $row['slip2go_response'] !== null && ! is_string( $row['slip2go_response'] ) ) {
            $row['slip2go_response'] = wp_json_encode( $row['slip2go_response'] );
            if ( $row['slip2go_response'] === false ) $row['slip2go_response'] = null;
        }
        if ( $row['replayed_from_log_id'] !== null ) {
            $row['replayed_from_log_id'] = (int) $row['replayed_from_log_id'];
            if ( $row['replayed_from_log_id'] <= 0 ) $row['replayed_from_log_id'] = null;
        }

        // V.34.9 M-7: explicit $format array matching schema (prevents STRICT-mode write failures
        // + ensures nullable fields serialize correctly)
        // V.34.12: format extended to match 4 new trailing columns before created_at
        // Column order must match $defaults order above
        $format = array(
            '%s', // group_id
            '%s', // message_id
            '%s', // user_id
            '%d', // dist_id (nullable — wpdb passes NULL through untyped)
            '%s', // slip_code
            '%f', // amount (nullable)
            '%s', // trans_ref
            '%s', // sender_name
            '%s', // result_status
            '%s', // error_code
            '%s', // error_msg
            '%d', // http_code (nullable)
            '%d', // processing_time_ms (nullable)
            '%d', // retry_count
            '%s', // image_hash (V.34.12, nullable)
            '%s', // image_mime (V.34.12, nullable)
            '%s', // slip2go_response (V.34.12, nullable — MEDIUMTEXT)
            '%d', // replayed_from_log_id (V.34.12, nullable)
            '%s', // created_at (MySQL datetime)
        );

        $ok = $wpdb->insert( $table, $row, $format );
        if ( $ok === false ) {
            // V.34.9 M-3: dual fallback logging — primary b2b_log + error_log as last resort
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[SlipLog] INSERT fail: ' . $wpdb->last_error );
            }
            // Always emit to PHP error_log as failsafe (e.g. if b2b_log backend is also down)
            @error_log( '[DINOCO SlipLog FATAL] insert failed: ' . $wpdb->last_error
                . ' row=' . wp_json_encode( $row ) );
            return false;
        }
        return (int) $wpdb->insert_id;
    }
}

// V.34.9 M-2: Atomic Slip2Go error counter helper
// Race-safe alternative to get_transient → ++ → set_transient pattern.
// Prefers wp_cache_incr when persistent object cache is available,
// falls back to wp_options atomic increment via MySQL UPDATE (ON DUPLICATE KEY UPDATE pattern).
if ( ! function_exists( 'b2b_slip_incr_err_count' ) ) {
    /**
     * Atomically increment the Slip2Go error counter.
     *
     * @param int $ttl_seconds  Counter reset interval (default 10 minutes)
     * @return int              The new counter value after increment
     */
    function b2b_slip_incr_err_count( $ttl_seconds = 600 ) {
        global $wpdb;
        $cache_key = 'b2b_slip2go_err_count';

        // Path 1: persistent object cache (Redis/Memcached) — true atomic via wp_cache_incr
        if ( wp_using_ext_object_cache() && function_exists( 'wp_cache_incr' ) ) {
            $val = wp_cache_incr( $cache_key, 1, 'transient' );
            if ( $val === false ) {
                // Key not yet set — seed to 1
                wp_cache_set( $cache_key, 1, 'transient', $ttl_seconds );
                $val = 1;
            }
            // Refresh TTL best-effort (wp_cache_incr doesn't touch TTL on all backends)
            // Not critical — transient cleanup cron handles stale entries
            return (int) $val;
        }

        // Path 2: wp_options fallback — atomic via single UPDATE statement
        // Use transient to ride existing WP TTL machinery (timeout row auto-expires)
        $opt_name = '_transient_' . $cache_key;
        $timeout_name = '_transient_timeout_' . $cache_key;

        // Try atomic increment first (works if row exists and has numeric value)
        $affected = $wpdb->query( $wpdb->prepare(
            "UPDATE {$wpdb->options} SET option_value = CAST(option_value AS UNSIGNED) + 1 WHERE option_name = %s",
            $opt_name
        ) );

        if ( $affected && ! is_wp_error( $affected ) ) {
            $new_val = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT option_value FROM {$wpdb->options} WHERE option_name = %s",
                $opt_name
            ) );
            // Ensure timeout row exists (refresh TTL lazily)
            if ( ! get_option( $timeout_name ) ) {
                update_option( $timeout_name, time() + $ttl_seconds, false );
            }
            return $new_val > 0 ? $new_val : 1;
        }

        // Row doesn't exist yet — seed via set_transient (still a narrow race window,
        // but accepted for telemetry counter)
        set_transient( $cache_key, 1, $ttl_seconds );
        return 1;
    }
}

if ( ! function_exists( 'b2b_slip_clear_locks' ) ) {
    /**
     * Force-unlock + drain queue สำหรับ 1 group หรือ all groups
     * เรียกจาก Admin Slip Monitor button / emergency cron recovery
     *
     * @param string $group_id '' = clear all, otherwise specific group
     * @param string $reason  audit trail reason (default 'admin_manual')
     * @return array { cleared_locks: int, cleared_queues: int, groups: array }
     */
    function b2b_slip_clear_locks( $group_id = '', $reason = 'admin_manual' ) {
        global $wpdb;
        $cleared_locks = 0;
        $cleared_queues = 0;
        $groups = array();

        if ( $group_id !== '' ) {
            if ( get_transient( 'b2b_slip_lock_' . $group_id ) ) {
                delete_transient( 'b2b_slip_lock_' . $group_id );
                $cleared_locks++;
            }
            $q = get_option( 'b2b_slip_queue_' . $group_id, array() );
            if ( ! empty( $q ) ) {
                delete_option( 'b2b_slip_queue_' . $group_id );
                $cleared_queues++;
            }
            $groups[] = $group_id;
        } else {
            // Clear all groups — scan wp_options for slip_queue_* + transients
            $prefix = $wpdb->esc_like( 'b2b_slip_queue_' );
            $rows = $wpdb->get_col( $wpdb->prepare(
                "SELECT option_name FROM {$wpdb->options} WHERE option_name LIKE %s",
                $prefix . '%'
            ) );
            foreach ( $rows as $opt_name ) {
                $gid = substr( $opt_name, strlen( 'b2b_slip_queue_' ) );
                if ( $gid === '' ) continue;
                delete_option( $opt_name );
                $cleared_queues++;
                if ( get_transient( 'b2b_slip_lock_' . $gid ) ) {
                    delete_transient( 'b2b_slip_lock_' . $gid );
                    $cleared_locks++;
                }
                $groups[] = $gid;
            }
            // Also scan transients table for orphan locks (queue เคลียร์แล้วแต่ lock ค้าง)
            $lock_prefix = $wpdb->esc_like( '_transient_b2b_slip_lock_' );
            $lock_rows = $wpdb->get_col( $wpdb->prepare(
                "SELECT option_name FROM {$wpdb->options} WHERE option_name LIKE %s",
                $lock_prefix . '%'
            ) );
            foreach ( $lock_rows as $opt_name ) {
                $gid = substr( $opt_name, strlen( '_transient_b2b_slip_lock_' ) );
                if ( $gid === '' ) continue;
                if ( ! in_array( $gid, $groups, true ) ) {
                    delete_transient( 'b2b_slip_lock_' . $gid );
                    $cleared_locks++;
                    $groups[] = $gid;
                }
            }
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( '[Slip] ClearLocks reason=' . $reason . ' locks=' . $cleared_locks . ' queues=' . $cleared_queues . ' groups=' . implode( ',', $groups ) );
        }
        return array( 'cleared_locks' => $cleared_locks, 'cleared_queues' => $cleared_queues, 'groups' => $groups );
    }
}

if ( ! function_exists( 'b2b_slip_is_trans_ref_seen' ) ) {
    /**
     * Forensic dedup check: trans_ref เคยถูก process แล้วหรือยัง
     * ตรวจ 2 sources: wp_dinoco_slip_log + postmeta _slip_trans_ref
     *
     * @param string $trans_ref
     * @return bool
     */
    function b2b_slip_is_trans_ref_seen( $trans_ref ) {
        if ( empty( $trans_ref ) ) return false;
        global $wpdb;
        $trans_ref = (string) $trans_ref;

        // Check slip_log (any successful/paid row within 30 days)
        $log_table = $wpdb->prefix . 'dinoco_slip_log';
        static $log_table_exists = null;
        if ( $log_table_exists === null ) {
            $log_table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $log_table ) );
        }
        if ( $log_table_exists ) {
            // V.34.9 H-3: expand dedup to ALL bank-cleared statuses.
            //   Previously only ('paid','paid_overpayment','duplicate') → agent could resend a slip
            //   that we already rejected for receiver_mismatch / amount_mismatch / amount_no_pending
            //   / no_distributor (bank DID clear the transfer, Slip2Go DID return valid data) —
            //   Slip2Go cache flush after 7 days lets the same trans_ref re-enter the "fresh" path,
            //   risking double debt subtraction if the second attempt matches a pending order.
            //   Bank-cleared = any status where trans_ref comes from a valid Slip2Go response.
            $hit = $wpdb->get_var( $wpdb->prepare(
                "SELECT id FROM {$log_table}
                 WHERE trans_ref = %s
                   AND result_status IN (
                       'paid','paid_overpayment','duplicate',
                       'receiver_mismatch','amount_mismatch','amount_no_pending','no_distributor'
                   )
                 LIMIT 1",
                $trans_ref
            ) );
            if ( $hit ) return true;
        }

        // Check postmeta (orders that stamped trans_ref)
        $hit2 = $wpdb->get_var( $wpdb->prepare(
            "SELECT post_id FROM {$wpdb->postmeta} WHERE meta_key = '_slip_trans_ref' AND meta_value = %s LIMIT 1",
            $trans_ref
        ) );
        return ! empty( $hit2 );
    }
}

