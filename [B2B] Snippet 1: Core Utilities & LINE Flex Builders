// ── 15.1 แสดง label #123-1 จาก sub-ticket ──
if ( ! function_exists( 'b2b_get_sub_ticket_label' ) ) {
    function b2b_get_sub_ticket_label( $ticket_id ) {
        $parent = intval( get_field('parent_ticket_id', $ticket_id) );
        $index  = intval( get_field('sub_ticket_index', $ticket_id) );
        if ( $parent > 0 && $index > 0 ) {
            return '#' . $parent . '-' . $index;
        }
        return '#' . $ticket_id;
    }
}

// ── 15.2 หาเลข sub-ticket ถัดไป (1→2→3...) ──
if ( ! function_exists( 'b2b_get_next_sub_index' ) ) {
    function b2b_get_next_sub_index( $parent_ticket_id ) {
        $existing = get_posts(array(
            'post_type'=>'b2b_order','posts_per_page'=>1,'post_status'=>'publish',
            'meta_query'=>array(array('key'=>'parent_ticket_id','value'=>$parent_ticket_id,'type'=>'NUMERIC')),
            'meta_key'=>'sub_ticket_index','orderby'=>'meta_value_num','order'=>'DESC','fields'=>'ids'));
        if ( !empty($existing) ) {
            return intval( get_field('sub_ticket_index', $existing[0]) ) + 1;
        }
        return 1;
    }
}

