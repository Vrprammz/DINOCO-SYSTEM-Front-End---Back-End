        $src_district = ! empty( $wh['wh_district'] ) ? $wh['wh_district'] : '';
        $src_city     = ! empty( $wh['wh_city'] )     ? $wh['wh_city']     : '';
        $src_province = ! empty( $wh['wh_province'] ) ? $wh['wh_province'] : '';
        $src_postcode = ! empty( $wh['wh_postcode'] ) ? $wh['wh_postcode'] : '';
        $dst_name     = get_field( 'dist_name', $ticket_id )     ?: '';
        $dst_phone    = get_field( 'dist_phone', $ticket_id )    ?: '';
        $dst_address  = get_field( 'dist_address', $ticket_id )  ?: '';
        $dst_district = get_field( 'dist_district', $ticket_id ) ?: '';
        $dst_city     = get_field( 'dist_city', $ticket_id )     ?: '';
        $dst_province = get_field( 'dist_province', $ticket_id ) ?: '';
        $dst_postcode = get_field( 'dist_postcode', $ticket_id ) ?: '';
        // V.22: Backfill from distributor if order missing address (legacy orders)
        if ( empty( $dst_name ) || empty( $dst_phone ) || empty( $dst_address ) ) {
            $gid = get_field( 'source_group_id', $ticket_id );
            if ( $gid && function_exists( 'b2b_get_dist_by_group' ) ) {
                $dist = b2b_get_dist_by_group( $gid );
                if ( $dist ) {
                    if ( empty( $dst_name ) )     { $dst_name     = get_field( 'shop_name', $dist->ID ) ?: get_the_title( $dist->ID ); update_field( 'dist_name', $dst_name, $ticket_id ); }
                    if ( empty( $dst_phone ) )    { $dst_phone    = get_field( 'dist_phone', $dist->ID ) ?: ''; update_field( 'dist_phone', $dst_phone, $ticket_id ); }
                    if ( empty( $dst_address ) )  { $dst_address  = get_field( 'dist_address', $dist->ID ) ?: ''; update_field( 'dist_address', $dst_address, $ticket_id ); }
                    if ( empty( $dst_district ) ) { $dst_district = get_field( 'dist_district', $dist->ID ) ?: ''; update_field( 'dist_district', $dst_district, $ticket_id ); }
                    if ( empty( $dst_city ) )     { $dst_city     = get_field( 'dist_city', $dist->ID ) ?: ''; update_field( 'dist_city', $dst_city, $ticket_id ); }
                    if ( empty( $dst_province ) ) { $dst_province = get_field( 'dist_province', $dist->ID ) ?: ''; update_field( 'dist_province', $dst_province, $ticket_id ); }
                    if ( empty( $dst_postcode ) ) { $dst_postcode = get_field( 'dist_postcode', $dist->ID ) ?: ''; update_field( 'dist_postcode', $dst_postcode, $ticket_id ); }
                    b2b_log( '[Flash] Backfilled address from distributor #' . $dist->ID . ' for ticket #' . $ticket_id );
                }
            }
        }
        // Validate required address fields
        $missing = array();
        if ( empty( $dst_name ) )     $missing[] = 'ชื่อผู้รับ (dist_name)';
        if ( empty( $dst_phone ) )    $missing[] = 'เบอร์โทรผู้รับ (dist_phone)';
        if ( empty( $dst_address ) )  $missing[] = 'ที่อยู่ (dist_address)';
        if ( empty( $dst_province ) ) $missing[] = 'จังหวัด (dist_province)';
        if ( empty( $dst_city ) )     $missing[] = 'เขต/อำเภอ (dist_city)';
        if ( empty( $dst_postcode ) ) $missing[] = 'รหัสไปรษณีย์ (dist_postcode)';
        if ( ! empty( $missing ) ) {
            $err = 'ที่อยู่ปลายทางไม่ครบ: ' . implode( ', ', $missing );
            b2b_log( '[Flash] ' . $err . ' ticket=#' . $ticket_id );
            return array( 'ok' => false, 'error' => $err );
        }

        $items_text = get_field( 'order_items', $ticket_id ) ?: 'DINOCO Products';
        $item_desc  = mb_substr( wp_strip_all_tags( $items_text ), 0, 100 );
        $out_trade_no = $ticket_id . '-' . $box_num;
        $insured_satang = b2b_flash_get_insured_value( $ticket_id );
        $params = array(
            'outTradeNo'       => $out_trade_no,
            'expressCategory'  => intval( get_post_meta( $ticket_id, '_flash_express_category', true ) ) ?: 1,
            'articleCategory'  => b2b_flash_get_article_category( $ticket_id ),
            'srcName'          => $src_name,
            'srcPhone'         => $src_phone,
            'srcDetailAddress' => $src_address,
            'srcDistrictName'  => $src_district,
            'srcCityName'      => $src_city,
            'srcProvinceName'  => $src_province,
            'srcPostalCode'    => $src_postcode,
            'dstName'          => $dst_name,
            'dstPhone'         => $dst_phone,
            'dstDetailAddress' => $dst_address,
            'dstDistrictName'  => $dst_district,
            'dstCityName'      => $dst_city,
            'dstProvinceName'  => $dst_province,
            'dstPostalCode'    => $dst_postcode,
            'weight'           => b2b_flash_get_order_weight( $ticket_id ),
            'insured'             => $insured_satang > 0 ? 1 : 0,
            'insureDeclareValue'  => $insured_satang > 0 ? $insured_satang : '',
            'codEnabled'       => b2b_flash_is_cod( $ticket_id ) ? 1 : 0,
            'remark'           => '#' . $ticket_id . ' Box ' . $box_num . '/' . $total_boxes . ' ' . $item_desc,
        );
        // Add COD amount if COD is enabled (in satang: 1 baht = 100 satang)
        if ( $params['codEnabled'] ) {
            $cod_baht = floatval( get_field( 'total_amount', $ticket_id ) );
            $params['codAmount'] = intval( $cod_baht * 100 );  // Convert baht to satang
        }
        $result = b2b_flash_request( 'open/v3/orders', $params );
        if ( $result['ok'] && ! empty( $result['data']['pno'] ) ) {
            b2b_log( '[Flash] Created ' . $out_trade_no . ' -> pno=' . $result['data']['pno'] );
            return array(
                'ok'       => true,
                'pno'      => $result['data']['pno'],
                'sortCode' => isset( $result['data']['sortCode'] ) ? $result['data']['sortCode'] : '',
                'data'     => $result['data'],
            );
        }
        $err = isset( $result['error'] ) ? $result['error'] : 'No pno returned';
        b2b_log( '[Flash] Create failed ' . $out_trade_no . ': ' . $err );
        return array( 'ok' => false, 'error' => $err, 'raw' => isset( $result['raw'] ) ? $result['raw'] : null );
    }
}

