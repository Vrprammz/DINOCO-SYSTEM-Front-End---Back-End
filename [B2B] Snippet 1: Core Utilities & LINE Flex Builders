    // V.34.11 MED-4: 'timestamp' arg deprecated in WP 5.3+ → use 'U' instead.
    $now = (int) current_time( 'U' );
    $next = strtotime( 'today 03:00', $now );
    if ( $next <= $now ) $next = strtotime( 'tomorrow 03:00', $now );
    wp_schedule_event( $next, 'daily', 'dinoco_flash_dlq_cleanup_cron' );
}
add_action( 'dinoco_flash_dlq_cleanup_cron', function() {
    // V.34.9 NEW: cron heartbeat for Go-Live Tool monitor
    // V.34.10 CRIT-1: drop double 'dinoco_' prefix — Go-Live Monitor reader uses single prefix
    update_option( 'dinoco_cron_flash_dlq_cleanup_last_run', time() );
    global $wpdb;
    $tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
    if ( ! $wpdb->get_var( "SHOW TABLES LIKE '{$tbl}'" ) ) return;
    // V.34.7 H-3: use current_time('mysql') not NOW() — prevents 7hr TZ drift
    // (WP is Asia/Bangkok, MySQL server typically UTC — DELETE was 7hr too early)
    $deleted = $wpdb->query( $wpdb->prepare(
        "DELETE FROM {$tbl} WHERE created_at < DATE_SUB(%s, INTERVAL 30 DAY)",
        current_time( 'mysql' )
    ) );
    if ( $deleted && function_exists( 'b2b_log' ) ) b2b_log( "[DLQCleanup] deleted {$deleted} rows > 30 days old" );

    // Also cleanup old audit rows > 90 days (DR-4 PDPA hygiene)
    $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
    if ( $wpdb->get_var( "SHOW TABLES LIKE '{$audit_tbl}'" ) ) {
        $d2 = $wpdb->query( $wpdb->prepare(
            "DELETE FROM {$audit_tbl} WHERE created_at < DATE_SUB(%s, INTERVAL 90 DAY)",
            current_time( 'mysql' )
        ) );
        if ( $d2 && function_exists( 'b2b_log' ) ) b2b_log( "[AuditCleanup] deleted {$d2} audit rows > 90 days old" );
    }

    // Warn if DLQ pending > 1000
    $pending = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl} WHERE status = 'pending'" );
    if ( $pending > 1000 && function_exists( 'b2b_push_to_admin' ) ) {
        b2b_push_to_admin( "⚠️ DINOCO DLQ: pending rows = {$pending} (>1000) — investigate Flash stability + admin review queue" );
    }
} );

