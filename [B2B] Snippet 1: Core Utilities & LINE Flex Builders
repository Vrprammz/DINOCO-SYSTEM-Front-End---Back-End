// V.33.1 — Audit H8: canonical rate limiter for B2B REST endpoints.
//
// Why: history of rate-limit bugs (N4 → H7 → H8):
//   - N4 (v1): get_transient + set_transient with pre-ownership counter burn
//   - H7 (v2): wp_cache_add primary → broken on non-persistent cache backends
//               (default WP = per-request cache → counter resets every request)
//   - H8 (v3): same broken pattern → rate limit effectively disabled on default WP
//
// Fix: transient-primary (survives across requests on default WP), sliding-window
//      counter keyed by absolute start timestamp. Mirrors proven `b2f_rate_limit()`
//      from [B2F] Snippet 2 so both subsystems use the same semantics.
//
// Usage:
//   $ok = b2b_rate_limit( 'cancel_' . $group_id, 5, 60 );  // 5 req / 60 sec / group
//   if ( is_wp_error( $ok ) ) return $ok;                 // 429 response
//
// Thread-safety note: transients are atomic per key on MySQL backend; two concurrent
// requests may both see count=0 → both write count=1. Net effect: +1 over soft cap
// under concurrency, which is acceptable for spam-protection use cases.
if ( ! function_exists( 'b2b_rate_limit' ) ) {
    /**
     * Transient-based sliding-window rate limiter.
     *
     * @param string $key     Unique key suffix (e.g. 'cancel_<group_id>')
     * @param int    $max     Max requests in window
     * @param int    $window  Window in seconds
     * @return true|WP_Error  true on allow, WP_Error(429) on block
     */
    /**
     * V.33.7 — Atomic rate limiter ป้องกัน race condition (security-pentester C2 fix)
     *
     * เดิม: read transient → check count → write back = race window
     *   (2 concurrent requests เห็น count=0 → increment 1 ทั้งคู่ → bypass limit 2×)
     *
     * ใหม่: wrap critical section ด้วย MySQL GET_LOCK() → atomic serialization
     *   across all PHP workers + request timing
     *
     * Properties:
     *   - No schema change (transient still = storage)
     *   - Lock timeout 2s (fail closed → return 429 on contention)
     *   - try/finally ensure RELEASE_LOCK
     *   - Backward compat signature + return type
     */
    function b2b_rate_limit( $key, $max = 10, $window = 60 ) {
        global $wpdb;
        $tkey      = 'b2b_rl_' . md5( (string) $key );
        $lock_name = 'b2b_rl_' . md5( $tkey ); // 40 chars < 64 MySQL limit

        $got_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 2)", $lock_name ) );
        if ( $got_lock !== '1' ) {
            return new WP_Error(
                'rate_limit_contention',
                'ระบบหนาแน่น กรุณาลองใหม่',
                array( 'status' => 429 )
            );
        }

        try {
            $data = get_transient( $tkey );

            if ( $data === false || ! is_array( $data ) ) {
                set_transient( $tkey, array( 'count' => 1, 'start' => time() ), $window );
                return true;
            }

            $count = intval( $data['count'] ?? 0 );
            $start = intval( $data['start'] ?? 0 );

            if ( ( time() - $start ) >= $window ) {
                set_transient( $tkey, array( 'count' => 1, 'start' => time() ), $window );
                return true;
            }

            if ( $count >= $max ) {
                return new WP_Error(
                    'rate_limited',
                    sprintf( 'คำขอมากเกินไป กรุณารอสักครู่ (สูงสุด %d ครั้ง / %d วินาที)', $max, $window ),
                    array( 'status' => 429 )
                );
            }

            $data['count'] = $count + 1;
            $remaining     = max( 1, $window - ( time() - $start ) );
            set_transient( $tkey, $data, $remaining );
            return true;
        } finally {
            $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
        }
    }
}

