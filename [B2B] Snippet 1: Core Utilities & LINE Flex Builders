if ( ! function_exists( 'b2b_build_flex_draft_confirm' ) ) {
    function b2b_build_flex_draft_confirm( $ticket_id, $items_preview, $total = 0, $dist_name = '' ) {
        $body = array();
        if (!empty($dist_name)) $body[] = array('type'=>'box','layout'=>'horizontal','contents'=>array(
            array('type'=>'text','text'=>'🏪 ร้าน','size'=>'xs','color'=>'#64748b','flex'=>2),
            array('type'=>'text','text'=>$dist_name,'size'=>'xs','weight'=>'bold','flex'=>5,'align'=>'end','wrap'=>true)));

        // Parse items for structured display
        $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
        $relations = get_option('dinoco_sku_relations', array());
        $gid = get_field('source_group_id', $ticket_id) ?: '';
        $dist = $gid ? b2b_get_dist_by_group($gid) : null;
        $dist_rank = $dist ? (get_field('rank_system', $dist->ID) ?: 'standard') : 'standard';
        $rank_price_field = 'price_' . $dist_rank;
        $parsed = array();
        $total_retail = 0;
        preg_match_all('/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)\s*=\s*[฿B]?([\d,.]+)/mu', $items_preview, $matches, PREG_SET_ORDER);
        foreach ($matches as $m) {
            $sku = strtoupper(trim($m[2]));
            $qty = intval($m[3]);
            $line_total = floatval(str_replace(',','',$m[4]));
            $unit_price = $qty > 0 ? $line_total / $qty : $line_total;
            $img_url = isset($catalog[$sku]['img']) ? $catalog[$sku]['img'] : '';
            $retail = 0; $disc_pct = 0;
            if (function_exists('b2b_find_product_by_sku')) {
                $pid = b2b_find_product_by_sku($sku);
                if ($pid) {
                    $retail = floatval(get_field('price_standard', $pid));
                    if ($retail <= 0 && isset($catalog[$sku]['price'])) $retail = floatval(str_replace(',', '', $catalog[$sku]['price']));
                    $rp = floatval(get_field($rank_price_field, $pid));
                    if ($rp > 0 && $retail > 0 && $rp < $retail) $disc_pct = round((1 - $rp / $retail) * 100, 1);
                    elseif ($retail > 0 && $unit_price > 0 && $unit_price < $retail) $disc_pct = round((1 - $unit_price / $retail) * 100, 1);
                }
            }
            if ($retail <= 0 && isset($catalog[$sku]['price'])) $retail = floatval(str_replace(',', '', $catalog[$sku]['price']));
            $total_retail += $retail * $qty;
            $children = isset($relations[$sku]) ? $relations[$sku] : array();
            $parsed[] = array('name'=>trim($m[1]),'sku'=>$sku,'qty'=>$qty,'total'=>$line_total,'img'=>$img_url,'disc_pct'=>$disc_pct,'children'=>$children);
        }
        $total_discount = $total_retail > 0 ? $total_retail - $total : 0;
        if ($total_discount < 0) $total_discount = 0;

        $body[] = array('type'=>'text','text'=>'📦 รายการสินค้า','weight'=>'bold','size'=>'sm','margin'=>'md');
        if (!empty($parsed)) {
            foreach ($parsed as $pi) {
                $row_contents = array();
                if (!empty($pi['img'])) {
                    $row_contents[] = array('type'=>'image','url'=>$pi['img'],'size'=>'xxs','aspectRatio'=>'1:1','aspectMode'=>'cover','flex'=>0);
                }
                $row_contents[] = array('type'=>'text','text'=>$pi['name'],'size'=>'xs','flex'=>3,'wrap'=>true,'color'=>'#1e293b');
                $row_contents[] = array('type'=>'text','text'=>'x'.$pi['qty'],'size'=>'xs','flex'=>1,'align'=>'center','color'=>'#64748b');
                $row_contents[] = array('type'=>'text','text'=>$pi['disc_pct'] > 0 ? $pi['disc_pct'].'%' : '-','size'=>'xs','flex'=>1,'align'=>'center','color'=>'#16a34a');
                $row_contents[] = array('type'=>'text','text'=>'฿'.number_format($pi['total'],0),'size'=>'xs','flex'=>2,'align'=>'end','weight'=>'bold');
                $body[] = array('type'=>'box','layout'=>'horizontal','spacing'=>'sm','margin'=>'md','contents'=>$row_contents);
                // Show SET children
                if (!empty($pi['children'])) {
                    foreach ($pi['children'] as $child_sku) {
                        $cname = isset($catalog[$child_sku]['name']) ? $catalog[$child_sku]['name'] : $child_sku;
                        $body[] = array('type'=>'text','text'=>'  ↳ '.$child_sku.' '.$cname,'size'=>'xxs','color'=>'#0369a1','wrap'=>true,'margin'=>'xs');
                    }
                }
            }
        } else {
            $p = mb_substr($items_preview, 0, 300); if (mb_strlen($items_preview)>300) $p .= '...';
            if (empty(trim($p))) $p = '(ดูรายละเอียดในแชท)';
            $body[] = array('type'=>'text','text'=>$p,'wrap'=>true,'size'=>'sm','color'=>'#475569','margin'=>'sm');
        }

        // Summary section
        $body[] = array('type'=>'separator','margin'=>'md');
        if ($total_retail > 0) {
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','contents'=>array(
                array('type'=>'text','text'=>'ราคาจำหน่าย','size'=>'sm','color'=>'#64748b','flex'=>3),
                array('type'=>'text','text'=>'฿'.number_format($total_retail,0),'size'=>'sm','color'=>'#1e293b','flex'=>3,'align'=>'end')));
            if ($total_discount > 0) {
                $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>array(
                    array('type'=>'text','text'=>'ส่วนลดตัวแทน','size'=>'sm','color'=>'#16a34a','flex'=>3),
                    array('type'=>'text','text'=>'-฿'.number_format($total_discount,0),'size'=>'sm','color'=>'#16a34a','flex'=>3,'align'=>'end')));
            }
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>array(
                array('type'=>'text','text'=>'ราคาตัวแทนรวมส่วนลด','size'=>'sm','color'=>'#64748b','flex'=>3),
                array('type'=>'text','text'=>'฿'.number_format($total,0),'size'=>'sm','color'=>'#1e293b','flex'=>3,'align'=>'end')));
        }
        if ($total > 0) {
            $body[] = array('type'=>'separator','margin'=>'md');
            $body[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','contents'=>array(
                array('type'=>'text','text'=>'มูลค่ารวมสุทธิ','size'=>'md','weight'=>'bold','color'=>'#1e293b','flex'=>3),
                array('type'=>'text','text'=>'฿'.number_format($total,0),'size'=>'lg','weight'=>'bold','color'=>'#1e293b','flex'=>3,'align'=>'end')));
        }

        $body[] = array('type'=>'separator','margin'=>'md');
        $body[] = array('type'=>'text','text'=>'⚠️ รายการนี้ยังไม่ยืนยันสต็อก กดปุ่มด้านล่างเพื่อให้ทีมเช็คสินค้า','wrap'=>true,'size'=>'xs','color'=>'#f59e0b','margin'=>'md');
        return array('type'=>'flex','altText'=>'📋 ตรวจสอบรายการ #'.$ticket_id.($total>0?' ฿'.number_format($total,0):''),
            'contents'=>array('type'=>'bubble',
                'header'=>b2b_flex_header('📋 ตรวจสอบรายการสั่งซื้อ','Ticket #'.$ticket_id,'#1e293b'),
                'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'16px','contents'=>$body),
                'footer'=>array('type'=>'box','layout'=>'vertical','spacing'=>'sm','paddingAll'=>'16px','contents'=>array(
                    array('type'=>'button','style'=>'primary','color'=>'#16a34a',
                        'action'=>array('type'=>'postback','label'=>'✅ ส่งรายการเช็คสต็อก','data'=>'action=confirm_order&ticket_id='.$ticket_id)),
                    array('type'=>'button','style'=>'secondary',
                        'action'=>array('type'=>'postback','label'=>'❌ ยกเลิก / แก้ไข','data'=>'action=cancel_draft&ticket_id='.$ticket_id))))));
    }
}
