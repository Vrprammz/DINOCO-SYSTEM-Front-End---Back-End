// ── V.32: b2b_recalculate_debt — recalculate current_debt from all billed orders ──
// FIX H-4: Single SQL query instead of N+1 get_field loop
if ( ! function_exists( 'b2b_recalculate_debt' ) ) {
    function b2b_recalculate_debt( $dist_id ) {
        if ( ! $dist_id ) return 0;
        global $wpdb;

        $group_id = get_field( 'line_group_id', $dist_id );

        // FIX W-3: Single SQL with per-order subquery to prevent duplicate meta row multiplication
        $sql = "SELECT COALESCE(SUM(sub.remaining), 0) AS total_debt FROM (
                    SELECT p.ID,
                        GREATEST(0,
                            CAST((SELECT pm_t.meta_value FROM {$wpdb->postmeta} pm_t WHERE pm_t.post_id = p.ID AND pm_t.meta_key = 'total_amount' LIMIT 1) AS DECIMAL(12,2))
                            - CAST(COALESCE((SELECT pm_p.meta_value FROM {$wpdb->postmeta} pm_p WHERE pm_p.post_id = p.ID AND pm_p.meta_key = '_inv_paid_amount' LIMIT 1), '0') AS DECIMAL(12,2))
                        ) AS remaining
                    FROM {$wpdb->posts} p
                    WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
                    AND EXISTS (SELECT 1 FROM {$wpdb->postmeta} pm_b WHERE pm_b.post_id = p.ID AND pm_b.meta_key = 'is_billed' AND pm_b.meta_value = '1')
                    AND EXISTS (SELECT 1 FROM {$wpdb->postmeta} pm_s WHERE pm_s.post_id = p.ID AND pm_s.meta_key = 'order_status' AND pm_s.meta_value IN ('awaiting_payment','overdue'))
                    AND (
                        EXISTS (SELECT 1 FROM {$wpdb->postmeta} pm_gid WHERE pm_gid.post_id = p.ID AND pm_gid.meta_key = 'source_group_id' AND pm_gid.meta_value = %s)
                        OR EXISTS (SELECT 1 FROM {$wpdb->postmeta} pm_did WHERE pm_did.post_id = p.ID AND pm_did.meta_key = '_dist_post_id' AND pm_did.meta_value = %s)
                    )
                ) sub";

        $total_debt = round( floatval( $wpdb->get_var( $wpdb->prepare(
            $sql,
            $group_id ? $group_id : '__none__',
            strval( $dist_id )
        ) ) ), 2 );

        update_field( 'current_debt', $total_debt, $dist_id );

        // Auto-clear credit_hold if debt is 0
        if ( $total_debt <= 0 ) {
            update_field( 'credit_hold', false, $dist_id );
        }

        return $total_debt;
    }
}

