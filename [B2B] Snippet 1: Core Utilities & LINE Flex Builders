if ( ! function_exists( 'b2b_liff_url' ) ) {
    function b2b_liff_url( $page = '', $params = array() ) {
        $liff_id = defined('B2B_LIFF_ID') ? B2B_LIFF_ID : '';
        $params['_ts'] = time();
        $params['_sig'] = b2b_generate_sig($page, $params);
        if ( $liff_id ) {
            // LIFF URL — เปิดภายใน LINE App เท่านั้น (liff.isInClient() = true)
            $url = 'https://liff.line.me/' . $liff_id . '/' . ltrim($page, '/');
        } else {
            // Fallback: direct URL ถ้ายังไม่ได้ตั้ง LIFF_ID
            $base = defined('B2B_SITE_URL') ? B2B_SITE_URL : 'https://dinoco.in.th';
            $url  = $base . '/' . ltrim($page, '/');
        }
        $url .= '?' . http_build_query($params);
        return $url;
    }
}
if ( ! function_exists( 'b2b_generate_sig' ) ) {
    function b2b_generate_sig( $page, $params = array() ) {
        if ( !defined('B2B_LINE_CHANNEL_SECRET') || empty(B2B_LINE_CHANNEL_SECRET) ) {
            b2b_log('[SECURITY] Cannot generate sig — B2B_LINE_CHANNEL_SECRET not defined');
            return '';
        }
        $secret = B2B_LINE_CHANNEL_SECRET;
        unset($params['_sig']);
        ksort($params);
        $data = $page . '|' . http_build_query($params);
        return hash_hmac('sha256', $data, $secret);
    }
}
if ( ! function_exists( 'b2b_verify_liff_sig' ) ) {
    function b2b_verify_liff_sig( $page, $max_age = 14400 ) {
        $params = $_GET;
        if ( empty($params['_sig']) || empty($params['_ts']) ) return false;
        $ts = intval($params['_ts']);
        if ( abs(time() - $ts) > $max_age ) return false;
        $expected = b2b_generate_sig($page, $params);
        if ( empty($expected) ) return false;
        return hash_equals($expected, $params['_sig']);
    }
}
// V.11.0: แยกสาเหตุ deny — expired / invalid / missing
if ( ! function_exists( 'b2b_check_sig_status' ) ) {
    function b2b_check_sig_status( $page, $max_age = 14400 ) {
        $params = $_GET;
        if ( empty($params['_sig']) || empty($params['_ts']) ) return 'missing';
        $ts = intval($params['_ts']);
        if ( abs(time() - $ts) > $max_age ) return 'expired';
        $expected = b2b_generate_sig($page, $params);
        if ( empty($expected) ) return 'error';
        return hash_equals($expected, $params['_sig']) ? 'valid' : 'invalid';
    }
}
