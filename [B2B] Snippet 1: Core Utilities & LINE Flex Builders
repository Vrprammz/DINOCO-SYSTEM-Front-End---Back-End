if ( ! function_exists( 'b2b_line_push' ) ) {
    function b2b_line_push( $to, $text ) {
        if ( ! defined('B2B_LINE_ACCESS_TOKEN') || !$to || !$text ) return;
        $r = wp_remote_post( 'https://api.line.me/v2/bot/message/push', array(
            'headers' => array('Content-Type'=>'application/json','Authorization'=>'Bearer '.B2B_LINE_ACCESS_TOKEN),
            'body' => wp_json_encode(array('to'=>$to,'messages'=>array(array('type'=>'text','text'=>$text)))),
            'timeout' => 15,
        ));
        if (is_wp_error($r)) { b2b_log('[Push] WP_Error: '.$r->get_error_message()); return; }
        $code = wp_remote_retrieve_response_code($r);
        if ($code !== 200) b2b_log('[Push] HTTP '.$code.' — '.wp_remote_retrieve_body($r));
    }
}
if ( ! function_exists( 'b2b_line_push_raw' ) ) {
    function b2b_line_push_raw( $to, $messages ) {
        if ( ! defined('B2B_LINE_ACCESS_TOKEN') || !$to ) return false;
        $body = wp_json_encode(array('to'=>$to,'messages'=>$messages));
        $r = wp_remote_post( 'https://api.line.me/v2/bot/message/push', array(
            'headers' => array('Content-Type'=>'application/json','Authorization'=>'Bearer '.B2B_LINE_ACCESS_TOKEN),
            'body' => $body, 'timeout' => 15,
        ));
        if (is_wp_error($r)) { b2b_log('[PushRaw] WP_Error: '.$r->get_error_message()); return array('code'=>0,'body'=>''); }
        $code = wp_remote_retrieve_response_code($r); $resp = wp_remote_retrieve_body($r);
        if ($code !== 200) { b2b_log('[PushRaw] HTTP '.$code.' — '.$resp); b2b_log('[PushRaw] Body sent (first 500): '.mb_substr($body, 0, 500)); }
        return array('code'=>$code,'body'=>$resp);
    }
}
if ( ! function_exists( 'b2b_push_guaranteed' ) ) {
    function b2b_push_guaranteed( $group_id, $messages, $ticket_id = 0, $flex_type = 'generic' ) {
        $result = b2b_line_push_raw($group_id, $messages);
        $success = is_array($result) && isset($result['code']) && $result['code'] === 200;
        if ($success || !$ticket_id) return $success;
        // Failed — queue for retry
        add_post_meta($ticket_id, '_pending_flex', array(
            'flex_type'  => $flex_type,
            'messages'   => $messages,
            'group_id'   => $group_id,
            'attempts'   => 1,
            'created_at' => current_time('mysql'),
        ));
        b2b_log('[PushGuaranteed] Queued retry #' . $ticket_id . ' type=' . $flex_type);
        return false;
    }
}
if ( ! function_exists( 'b2b_create_shipment' ) ) {
    function b2b_create_shipment( $order_id, $args ) {
        $shipments = get_post_meta($order_id, '_b2b_shipments', true) ?: array();
        $shipment = array(
            'shipment_id' => 'SHP-' . date('Ymd') . '-' . substr(md5($order_id . microtime()), 0, 6),
            'method'      => sanitize_text_field($args['method'] ?? 'self_ship'),
            'carrier'     => sanitize_text_field($args['carrier'] ?? ''),
            'tracking_no' => sanitize_text_field($args['tracking_no'] ?? ''),
            'items'       => $args['items'] ?? array(),
            'status'      => 'shipped',
            'note'        => sanitize_text_field($args['note'] ?? ''),
            'created_at'  => function_exists('b2b_date') ? b2b_date('Y-m-d H:i:s') : current_time('mysql'),
            'shipped_at'  => function_exists('b2b_date') ? b2b_date('Y-m-d H:i:s') : current_time('mysql'),
            'delivered_at' => null,
        );
        $shipments[] = $shipment;
        update_post_meta($order_id, '_b2b_shipments', $shipments);
        update_post_meta($order_id, '_b2b_shipping_method', $shipment['method']);

        // Update order status
        $all_shipped = b2b_check_all_items_shipped($order_id);
