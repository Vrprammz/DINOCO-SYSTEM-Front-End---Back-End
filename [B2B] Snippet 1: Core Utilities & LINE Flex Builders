/**
 * S18 Address masking for Flex display (admin-facing).
 * Mask phone/address to prevent insider leak — show first 3 + last 3 + province only.
 */
if ( ! function_exists( 'b2b_flex_mask_phone' ) ) {
    function b2b_flex_mask_phone( $phone ) {
        $p = preg_replace( '/[^0-9]/', '', (string) $phone );
        if ( strlen( $p ) < 7 ) return $phone;
        return substr( $p, 0, 3 ) . '-XXX-' . substr( $p, -3 );
    }
}
if ( ! function_exists( 'b2b_flex_mask_address' ) ) {
    function b2b_flex_mask_address( $address, $province = '' ) {
        $addr = trim( (string) $address );
        if ( $addr === '' ) return '—';
        $first = mb_substr( $addr, 0, 10, 'UTF-8' );
        $suffix = $province ? ' · จ.' . $province : '';
        return $first . '...' . $suffix;
    }
}

/**
 * S26 Telegram Markdown V2 escape — escape special chars for safe rendering.
 */
if ( ! function_exists( 'b2b_tg_escape' ) ) {
    function b2b_tg_escape( $str ) {
        $special = array( '_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!' );
        foreach ( $special as $ch ) {
            $str = str_replace( $ch, '\\' . $ch, (string) $str );
        }
        return $str;
    }
}

/**
 * b2b_push_admin_flex_dedup($key, $ttl, $flex)
 * ────────────────────────────────────────────────────────────────
 * Push Flex to admin group with deduplication + global 20/hr rate cap.
 * - Dedup: same $key within $ttl seconds → silent skip (prevents spam loops)
 * - Rate cap: global 20 Flex/hour across all keys → beyond → coalesce to digest
 *
 * Usage:
 *   b2b_push_admin_flex_dedup(
 *       'flash_dlq_' . $ticket_id,
 *       HOUR_IN_SECONDS,
 *       b2b_build_flex_flash_dlq_alert( $ticket_id, $err_code )
 *   );
 */
if ( ! function_exists( 'b2b_push_admin_flex_dedup' ) ) {
    function b2b_push_admin_flex_dedup( $key, $ttl, $flex, $alt_text = '' ) {
        if ( ! defined( 'B2B_ADMIN_GROUP_ID' ) ) return false;

        $dedup_key = 'b2b_flex_dedup_' . md5( $key );
        if ( get_transient( $dedup_key ) ) {
            // Already pushed within TTL window — skip
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[FlexDedup] skip key={$key}" );
            return 'deduped';
        }

        // Global rate cap: 20 pushes/hour
        $rate_key = 'b2b_flex_admin_rate';
        $count = (int) get_transient( $rate_key );
        if ( $count >= 20 ) {
            // Coalesce: increment overflow counter, push digest only once per hour
            $overflow_key = 'b2b_flex_admin_overflow';
            $overflow = (int) get_transient( $overflow_key );
            set_transient( $overflow_key, $overflow + 1, HOUR_IN_SECONDS );

            // Push digest only if not already sent this hour
            $digest_sent = get_transient( 'b2b_flex_admin_digest_sent' );
            if ( ! $digest_sent ) {
                set_transient( 'b2b_flex_admin_digest_sent', 1, HOUR_IN_SECONDS );
                $digest = "📊 [Rate cap reached] Flex alerts suppressed — " . ( $overflow + 1 ) . " additional alerts this hour. เช็ค Admin Dashboard → Flash Shipping → DLQ / Audit";
                if ( function_exists( 'b2b_push_to_admin' ) ) b2b_push_to_admin( $digest );
            }
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[FlexDedup] rate-capped key={$key} (overflow=" . ( $overflow + 1 ) . ")" );
            return 'rate_capped';
        }

        // Push Flex to admin
        set_transient( $dedup_key, 1, $ttl );
        set_transient( $rate_key, $count + 1, HOUR_IN_SECONDS );

        if ( is_array( $flex ) && function_exists( 'b2b_line_push_flex' ) ) {
            return b2b_line_push_flex( B2B_ADMIN_GROUP_ID, $alt_text ?: ( $flex['altText'] ?? 'Admin Alert' ), $flex );
        } elseif ( is_array( $flex ) && function_exists( 'b2b_line_push' ) ) {
            // Fallback: serialize to text if no flex push helper
            $text = $alt_text ?: ( $flex['altText'] ?? 'Admin Alert' );
            return b2b_line_push( B2B_ADMIN_GROUP_ID, $text );
        } elseif ( is_string( $flex ) && function_exists( 'b2b_push_to_admin' ) ) {
            return b2b_push_to_admin( $flex );
        }
        return false;
    }
}

