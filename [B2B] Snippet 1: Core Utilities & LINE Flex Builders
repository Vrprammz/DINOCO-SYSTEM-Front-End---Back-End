// ══════════════════════════════════════════════════════════════════════════════
// V.34.1 — FLASH SHIPPING METADATA V.42 PHASE 5 (LAUNCH INFRA)
// ──────────────────────────────────────────────────────────────────────────────
// Custom cron intervals + 3 cron jobs + auto-rollback + DLQ cleanup + F2 verify
// ══════════════════════════════════════════════════════════════════════════════

/**
 * FR-4: Custom cron intervals — 10min + 15min
 * Under DISABLE_WP_CRON=true + system cron cadence, 10-min is safer than 5-min
 * (5-min interval sometimes misses triggers when system cron runs every 5-10 min).
 */
add_filter( 'cron_schedules', function( $s ) {
    if ( ! isset( $s['ten_minutes'] ) ) {
        $s['ten_minutes'] = array( 'interval' => 600, 'display' => __( '10 minutes', 'dinoco' ) );
    }
    if ( ! isset( $s['fifteen_minutes'] ) ) {
        $s['fifteen_minutes'] = array( 'interval' => 900, 'display' => __( '15 minutes', 'dinoco' ) );
    }
    return $s;
} );

/**
 * S28 Telegram escape — per-tid replay dedup 1/min
 * Used by webhook handlers to avoid alert spam on Flash replay attacks.
 */
if ( ! function_exists( 'b2b_tg_send_dedup' ) ) {
    function b2b_tg_send_dedup( $tid, $message, $ttl = 60 ) {
        if ( ! $tid ) return false;
        $key = 'b2b_tg_dedup_' . md5( (string) $tid );
        if ( get_transient( $key ) ) return 'deduped';
        set_transient( $key, 1, max( 60, (int) $ttl ) );
        if ( function_exists( 'sendTelegramAlert' ) ) {
            return sendTelegramAlert( 'flash_event', $message );
        }
        return false;
    }
}

// ───────────────────────────────────────────────────────────────────
// CRON 1: flash_category_verify_cron — F2 bump detection (15-min)
// ───────────────────────────────────────────────────────────────────
// Checks recent Flash-created tickets (last 2hr) → fetch Flash Routes API →
// compare expected EC vs actual EC → if bumped (1→4) fire admin Flex alert.
if ( ! wp_next_scheduled( 'flash_category_verify_cron' ) ) {
    wp_schedule_event( time() + 300, 'fifteen_minutes', 'flash_category_verify_cron' );
}
add_action( 'flash_category_verify_cron', function() {
    // V.34.9 NEW: cron heartbeat — Go-Live Tool monitor reads this option
    // to display cron health ("last run" timestamp). Without this write,
    // UI shows "never" perpetually.
    update_option( 'dinoco_cron_flash_category_verify_last_run', time() );
    if ( ! function_exists( 'b2b_flash_request' ) ) return;
    global $wpdb;

    // Only run if V.42 flag is ON — save cycles when feature off
    if ( get_option( 'dinoco_shipping_meta_enabled', '0' ) !== '1' ) return;

    // Find tickets with Flash PNO created in last 2hr + not yet verified.
    // V.34.7 H-3 FIX: use current_time('mysql') instead of NOW() — WP TZ is
    // Asia/Bangkok but MySQL server TZ often UTC → 7-hour drift.
    $recent = $wpdb->get_results( $wpdb->prepare(
        "SELECT p.ID, pm.meta_value AS pno
         FROM {$wpdb->posts} p
         JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = '_flash_tracking_numbers'
         WHERE p.post_type = 'b2b_order'
           AND p.post_date > DATE_SUB(%s, INTERVAL 2 HOUR)
           AND NOT EXISTS (SELECT 1 FROM {$wpdb->postmeta} WHERE post_id = p.ID AND meta_key = '_flash_ec_verified_at')
         LIMIT 20",
        current_time( 'mysql' )
    ), ARRAY_A );

    if ( empty( $recent ) ) return;

    foreach ( $recent as $r ) {
        $ticket_id = (int) $r['ID'];
        // V.34.11 MED-2: defensive JSON fallback — if future migration stores
        // _flash_tracking_numbers as JSON string, maybe_unserialize() returns
        // the string unchanged → is_array() filters it out silently. Try JSON
        // decode as a second chance before giving up.
        $pnos_raw = $r['pno'];
        $pnos = maybe_unserialize( $pnos_raw );
        if ( ! is_array( $pnos ) ) {
            $json_decoded = json_decode( (string) $pnos_raw, true );
            if ( is_array( $json_decoded ) ) {
                $pnos = $json_decoded;
            } else {
                continue; // truly not an array
            }
        }
        if ( empty( $pnos ) ) continue;
        $expected_ec = (int) get_post_meta( $ticket_id, '_flash_express_category', true ) ?: 1;

        // Query Flash Routes API for first PNO
        // V.34.5 CRITICAL FIX C3: was @b2b_flash_request('...', [], 'GET') — 3rd arg is
        // $expect_pdf bool (not HTTP method). 'GET' coerced to true → treated as PDF
        // expected → silently failed. Flash Routes API requires GET. Use wp_remote_get
        // with same HMAC auth pattern as b2b_flash_request.
        $first_pno = reset( $pnos );
        if ( ! $first_pno ) continue;
        $resp = array( 'ok' => false );
        if ( defined( 'B2B_FLASH_MCH_ID' ) && defined( 'B2B_FLASH_SECRET_KEY' ) && defined( 'B2B_FLASH_API_URL' ) ) {
            $params = array(
                'mchId'    => trim( B2B_FLASH_MCH_ID ),
                'nonceStr' => b2b_flash_nonce_str(),
            );
            $params['sign'] = b2b_flash_sign( $params );
            $url = rtrim( B2B_FLASH_API_URL, '/' ) . '/open/v1/routes/' . rawurlencode( $first_pno ) . '?' . http_build_query( $params );
            $wp_resp = wp_remote_get( $url, array( 'timeout' => 15, 'headers' => array( 'Accept-Language' => 'th' ) ) );
            if ( ! is_wp_error( $wp_resp ) ) {
                $code = wp_remote_retrieve_response_code( $wp_resp );
                $body = wp_remote_retrieve_body( $wp_resp );
                $decoded = json_decode( $body, true );
                if ( is_array( $decoded ) ) {
                    $flash_code = isset( $decoded['code'] ) ? intval( $decoded['code'] ) : -1;
                    $resp = array(
                        'ok'          => ( $flash_code === 1 ),
                        'data'        => $decoded['data'] ?? $decoded,
                        'status_code' => $code,
                    );
                }
            }
        }

        // V.34.11 MED-1: Only process if Flash API returned success (code=1).
        // Previously we parsed $resp['data']['expressCategory'] even when
        // flash_code !== 1 — Flash error responses carry 'data' with unrelated
        // fields → actual_ec read stale/wrong → false ec_bumped alerts.
        // $resp['ok'] is TRUE only when code === 1 (see builder above).
        if ( empty( $resp['ok'] ) || empty( $resp['data'] ) ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[F2 verify] Flash API not-ok for pno=' . $first_pno . ' code=' . ( $resp['status_code'] ?? '?' ), 'warn' );
            }
            continue; // skip this ticket — retry next cycle
        }

        // Parse actual EC from response (shape varies per Flash API version)
        $actual_ec = null;
        if ( isset( $resp['data']['expressCategory'] ) ) {
            $actual_ec = (int) $resp['data']['expressCategory'];
        } elseif ( isset( $resp['expressCategory'] ) ) {
            $actual_ec = (int) $resp['expressCategory'];
        }

        update_post_meta( $ticket_id, '_flash_ec_verified_at', current_time( 'mysql' ) );
        update_post_meta( $ticket_id, '_flash_ec_actual', $actual_ec ?: 0 );

        // Audit log
        $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
        if ( $wpdb->get_var( "SHOW TABLES LIKE '{$audit_tbl}'" ) ) {
            $wpdb->insert( $audit_tbl, array(
                'ticket_id'       => $ticket_id,
                'event_type'      => ( $actual_ec && $actual_ec !== $expected_ec ) ? 'ec_bumped' : 'ec_verified',
                'expected_ec'     => $expected_ec,
                'actual_ec'       => $actual_ec ?: 0,
                'request_summary' => wp_json_encode( array( 'pno' => $first_pno ) ),
                'response_summary'=> wp_json_encode( is_array( $resp ) ? array_slice( $resp, 0, 5, true ) : array( 'raw' => substr( (string) $resp, 0, 500 ) ) ),
                'created_at'      => current_time( 'mysql' ),
            ) );
        }

        // If bumped → push Flex alert to admin (dedup per ticket per hour)
        if ( $actual_ec && $actual_ec !== $expected_ec && $actual_ec === 4 && function_exists( 'b2b_build_flex_flash_category_bumped' ) ) {
            $weight_g = (int) get_post_meta( $ticket_id, '_flash_weight_grams', true );
            $flex = b2b_build_flex_flash_category_bumped( $ticket_id, $expected_ec, $actual_ec, $weight_g );
            b2b_push_admin_flex_dedup( 'flash_bumped_' . $ticket_id, HOUR_IN_SECONDS, $flex );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[FlashVerify] ticket={$ticket_id} EC bumped {$expected_ec}→{$actual_ec}" );
        }
    }
} );

// ───────────────────────────────────────────────────────────────────
// V.34.8 Round 4 NEW — dinoco_set_shipping_flag() single-mutation gate
// ───────────────────────────────────────────────────────────────────
// Single source of truth for toggling dinoco_shipping_meta_enabled.
// Auto-writes dinoco_shipping_flag_flipped_at (used by auto-rollback cooldown)
// and inserts a flash_audit row for forensic trace. OPTIONAL wiring — existing
// callers (Go-Live Wizard, manual-rollback endpoint, auto-rollback cron) don't
// need migration. Future callers should prefer this helper.
if ( ! function_exists( 'dinoco_set_shipping_flag' ) ) {
    /**
     * @param string|int|bool $new_val  '1'|'0', 1|0, true|false
     * @param string          $reason   free-text audit reason
     * @param string          $source   'golive_wizard'|'auto_rollback'|'manual_rollback'|'cli'|'other'
     * @return array { ok, old, new, flipped_at?, no_change? }
     */
    function dinoco_set_shipping_flag( $new_val, $reason = '', $source = 'other' ) {
        $new_val = ( $new_val === '1' || $new_val === 1 || $new_val === true ) ? '1' : '0';
        $old_val = (string) get_option( 'dinoco_shipping_meta_enabled', '0' );
        if ( $new_val === $old_val ) {
            return array(
                'ok'        => true,
                'old'       => $old_val,
                'new'       => $new_val,
                'no_change' => true,
            );
        }
        $flipped_at = current_time( 'mysql' );
        update_option( 'dinoco_shipping_meta_enabled', $new_val );
        update_option( 'dinoco_shipping_flag_flipped_at', $flipped_at );
        // Audit row if table exists (defensive — table created by Snippet 15 V.8.0)
        global $wpdb;
        $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
        if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $audit_tbl ) ) ) === $audit_tbl ) {
            $wpdb->insert( $audit_tbl, array(
                'ticket_id'    => 0,
                'event_type'   => 'flag_flip_' . ( $new_val === '1' ? 'on' : 'off' ),
                'payload_json' => wp_json_encode( array(
                    'old'     => $old_val,
                    'new'     => $new_val,
                    'user_id' => get_current_user_id(),
                    'reason'  => $reason,
                    'source'  => $source,
                ) ),
                'created_at'   => $flipped_at,
            ) );
        }
        return array(
            'ok'         => true,
            'old'        => $old_val,
            'new'        => $new_val,
            'flipped_at' => $flipped_at,
        );
    }
}

// ───────────────────────────────────────────────────────────────────
// CRON 2: dinoco_shipping_auto_rollback_cron — 10-min (FR-4 relaxed)
// ───────────────────────────────────────────────────────────────────
// If error rate > 5% AND absolute count > 20/hr → flip flag OFF + alert
if ( ! wp_next_scheduled( 'dinoco_shipping_auto_rollback_cron' ) ) {
    wp_schedule_event( time() + 600, 'ten_minutes', 'dinoco_shipping_auto_rollback_cron' );
}
add_action( 'dinoco_shipping_auto_rollback_cron', function() {
    // V.34.9 NEW: cron heartbeat for Go-Live Tool monitor
    // V.34.10 CRIT-1: drop double 'dinoco_' prefix — Go-Live Monitor reader uses single prefix
    update_option( 'dinoco_cron_shipping_auto_rollback_last_run', time() );
    // Skip if flag already off
    if ( get_option( 'dinoco_shipping_meta_enabled', '0' ) !== '1' ) return;

    // C-Conc-11 / H-C1: 5-minute cooldown after manual flip — avoids
    // race at flip moment where stale audit rows from prior session trigger
    // immediate rollback.
    // V.34.8 Round 4 H-2: stay in Bangkok TZ on both sides — $flipped_at was
    // written via current_time('mysql') (Bangkok literal, no TZ suffix).
    // strtotime() parses as server TZ (often UTC) → 7hr drift on cooldown window.
    // Simpler fix: compare ISO strings lexically, both in local time.
    $flipped_at = (string) get_option( 'dinoco_shipping_flag_flipped_at', '' );
    if ( $flipped_at ) {
        // V.34.11 MED-4: current_time('timestamp') is deprecated since WP 5.3.
        // Use current_time('U') — same semantic (WP local time as Unix epoch)
        // without deprecation warning. Comparison is lexical ISO strings so both
        // sides must remain in Bangkok TZ (H-2 invariant preserved).
        $cooldown_threshold = date( 'Y-m-d H:i:s', (int) current_time( 'U' ) - 300 );
        if ( $flipped_at > $cooldown_threshold ) return; // within 5-min cooldown
    }

    // M4: Prevent concurrent rollback via MySQL GET_LOCK (cross-process, 2s timeout)
    global $wpdb;
    $lock_name = 'dinoco_shipping_rollback_lock';
    $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 2)", $lock_name ) );
    if ( $got_lock !== 1 ) return; // another worker holds it

    try {
        $dlq_tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
        $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
        if ( ! $wpdb->get_var( "SHOW TABLES LIKE '{$dlq_tbl}'" ) ) return;

        // C-Conc-11 / H-C1: Window start = max(flag_flipped_at, now - 1h).
        // Prevents counting pre-flag-flip errors against current flag session.
        // V.34.8 Round 4 H-2: both sides in Bangkok TZ — strtotime on stored
        // Bangkok literal vs strtotime('-1 hour') (which uses server TZ) had
        // 7hr drift. Now uses current_time('U') for the reference.
        // V.34.11 MED-4: 'timestamp' arg deprecated in WP 5.3+ → use 'U' instead.
        $one_hour_ago_local = date( 'Y-m-d H:i:s', (int) current_time( 'U' ) - 3600 );
        $window_start_q = ( $flipped_at && $flipped_at > $one_hour_ago_local )
            ? $flipped_at
            : $one_hour_ago_local;

        // Count Flash create attempts in window (from audit)
        $total_attempts = 0;
        $errors = 0;
        if ( $wpdb->get_var( "SHOW TABLES LIKE '{$audit_tbl}'" ) ) {
            $total_attempts = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$audit_tbl}
                 WHERE event_type IN ('flash_create','flash_create_fail')
                   AND created_at > %s",
                $window_start_q
            ) );
            $errors = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$audit_tbl}
                 WHERE event_type = 'flash_create_fail'
                   AND created_at > %s",
                $window_start_q
            ) );
        }
        // DLQ inserts in window as another signal
        $dlq_recent = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$dlq_tbl}
             WHERE status = 'pending'
               AND created_at > %s",
            $window_start_q
        ) );
        $errors = max( $errors, $dlq_recent );

        // Rollback condition: (error_rate > 5%) AND (absolute_count > 20)
        // V.34.9 M-6: if audit table missing/empty, fall back to absolute DLQ
        // count threshold alone (prevents rollback from failing to fire due to
        // zero denominator — e.g. audit table dropped but DLQ still piling up).
        $rate = 0.0;
        $should_rollback = false;
        if ( $total_attempts === 0 && $errors >= 20 ) {
            // Audit unavailable but DLQ shows real damage — trigger rollback
            if ( function_exists( 'b2b_log' ) ) b2b_log( '[V42 auto-rollback] AUDIT table unavailable; triggering based on absolute DLQ count=' . $errors, 'warn' );
            $should_rollback = true;
        } else {
            $rate = $total_attempts > 0 ? ( 100.0 * $errors / $total_attempts ) : 0.0;
            $should_rollback = ( $rate > 5.0 && $errors > 20 );
        }
        if ( $should_rollback ) {
            // V.34.11 MED-3: route through dinoco_set_shipping_flag() — single
            // source of truth for flag mutation + writes flipped_at + audit row
            // (event_type=flag_flip_off). Removes duplicate inline audit insert
            // below (helper handles it). Helper is defined same-file so always
            // loaded; defensive function_exists just in case of partial loads.
            $reason = sprintf( 'auto-rollback: error rate %.1f%% (%d/%d) in last hour', $rate, $errors, $total_attempts );
            if ( function_exists( 'dinoco_set_shipping_flag' ) ) {
                dinoco_set_shipping_flag( '0', $reason, 'auto_rollback' );
            } else {
                // Fallback — keep legacy path if helper somehow unavailable
                update_option( 'dinoco_shipping_meta_enabled', '0' );
                update_option( 'dinoco_shipping_flag_flipped_at', current_time( 'mysql' ) );
            }
            $msg = sprintf(
                '🚨 AUTO-ROLLBACK: V.42 flag disabled — error rate %.1f%% (%d/%d) in last hour. Check Admin Dashboard → Flash Shipping → DLQ + Audit',
                $rate, $errors, $total_attempts
            );
            if ( function_exists( 'b2b_push_to_admin' ) ) b2b_push_to_admin( $msg );
            if ( function_exists( 'sendTelegramAlert' ) ) {
                $tg_msg = '🚨 *DINOCO V\\.42 auto\\-rollback* — error rate `' . b2b_tg_escape( number_format( $rate, 1 ) ) . '%` \\(' . $errors . '/' . $total_attempts . '\\) last hour';
                sendTelegramAlert( 'flash_rollback', $tg_msg );
            }
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[AutoRollback] V.42 flag disabled: rate={$rate}% errors={$errors} total={$total_attempts}" );
            // Inline audit row removed — dinoco_set_shipping_flag() writes
            // event_type='flag_flip_off' row with reason + source='auto_rollback'
        }
    } finally {
        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
    }
} );

// ───────────────────────────────────────────────────────────────────
// CRON 3: dinoco_flash_dlq_cleanup_cron — daily 03:00 (F7 30d retention)
// ───────────────────────────────────────────────────────────────────
if ( ! wp_next_scheduled( 'dinoco_flash_dlq_cleanup_cron' ) ) {
