// ── 5.11 Payment Invoice (V.10.0: Copy ครบ 3 อย่าง — ชื่อธนาคาร + เลขบัญชี + ชื่อบัญชี) ──
if ( ! function_exists( 'b2b_build_flex_payment_invoice' ) ) {
    function b2b_build_flex_payment_invoice( $ticket_id, $total, $dist_name, $due_date, $credit_days ) {
        $bank = b2b_get_bank_info( $ticket_id );
        $items_raw = get_field('order_items', $ticket_id) ?: '';
        $thai_due = !empty($due_date) ? b2b_parse_date($due_date) : '-';
        $orderer = get_field('orderer_display_name', $ticket_id); if ( empty($orderer) ) $orderer = '-';

        // Parse items for structured display
        $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
        $gid = get_field('source_group_id', $ticket_id) ?: '';
        $dist = $gid ? b2b_get_dist_by_group($gid) : null;
        $dist_rank = $dist ? (get_field('rank_system', $dist->ID) ?: 'standard') : 'standard';
        $rank_price_field = 'price_' . $dist_rank;
        $parsed = array();
        $inv_total_retail = 0;
        $clean_items = preg_replace('/^.*?ขอยืนยัน[^:]*:\s*/u', '', $items_raw);
        preg_match_all('/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)\s*=\s*[฿B]?([\d,.]+)/mu', $clean_items, $matches, PREG_SET_ORDER);
        foreach ($matches as $m) {
            $sku = strtoupper(trim($m[2]));
            $qty = intval($m[3]);
            $line_total = floatval(str_replace(',','',$m[4]));
            $unit_price = $qty > 0 ? $line_total / $qty : $line_total;
            $img_url = isset($catalog[$sku]['img']) ? $catalog[$sku]['img'] : '';
            $retail = 0; $disc_pct = 0;
            if (function_exists('b2b_find_product_by_sku')) {
                $pid = b2b_find_product_by_sku($sku);
                if ($pid) {
                    $retail = floatval(get_field('price_standard', $pid));
                    if ($retail <= 0 && isset($catalog[$sku]['price'])) $retail = floatval(str_replace(',', '', $catalog[$sku]['price']));
                    $rp = floatval(get_field($rank_price_field, $pid));
                    if ($rp > 0 && $retail > 0 && $rp < $retail) $disc_pct = round((1 - $rp / $retail) * 100, 1);
                    elseif ($retail > 0 && $unit_price > 0 && $unit_price < $retail) $disc_pct = round((1 - $unit_price / $retail) * 100, 1);
                }
            }
            if ($retail <= 0 && isset($catalog[$sku]['price'])) $retail = floatval(str_replace(',', '', $catalog[$sku]['price']));
            $inv_total_retail += $retail * $qty;
            $parsed[] = array('name'=>trim($m[1]),'sku'=>$sku,'qty'=>$qty,'total'=>$line_total,'img'=>$img_url,'disc_pct'=>$disc_pct);
        }
        $inv_total_discount = $inv_total_retail > 0 ? $inv_total_retail - $total : 0;
        if ($inv_total_discount < 0) $inv_total_discount = 0;

        // Build item rows
        $item_rows = array();
        $item_rows[] = array('type'=>'text','text'=>'📦 รายการสินค้า','weight'=>'bold','size'=>'sm','margin'=>'md');
        if (!empty($parsed)) {
            foreach ($parsed as $pi) {
                $row_contents = array();
                if (!empty($pi['img'])) {
                    $row_contents[] = array('type'=>'image','url'=>$pi['img'],'size'=>'xxs','aspectRatio'=>'1:1','aspectMode'=>'cover','flex'=>0);
                }
                $row_contents[] = array('type'=>'text','text'=>$pi['name'],'size'=>'xs','flex'=>3,'wrap'=>true,'color'=>'#1e293b');
                $row_contents[] = array('type'=>'text','text'=>'x'.$pi['qty'],'size'=>'xs','flex'=>1,'align'=>'center','color'=>'#64748b');
                $row_contents[] = array('type'=>'text','text'=>$pi['disc_pct'] > 0 ? $pi['disc_pct'].'%' : '-','size'=>'xs','flex'=>1,'align'=>'center','color'=>'#16a34a');
                $row_contents[] = array('type'=>'text','text'=>'฿'.number_format($pi['total'],0),'size'=>'xs','flex'=>2,'align'=>'end','weight'=>'bold');
                $item_rows[] = array('type'=>'box','layout'=>'horizontal','spacing'=>'sm','margin'=>'sm','contents'=>$row_contents);
            }
        } else {
            $items_short = trim( mb_substr( $clean_items, 0, 300 ) );
            if ( empty(trim($items_short)) ) $items_short = '(ดูรายละเอียดในแชท)';
            $item_rows[] = array('type'=>'text','text'=>$items_short,'wrap'=>true,'size'=>'xs','color'=>'#555555','margin'=>'xs');
        }

        // Summary rows
        $summary_rows = array();
        $summary_rows[] = array('type'=>'separator','margin'=>'md');
        if ($inv_total_retail > 0) {
            $summary_rows[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','contents'=>array(array('type'=>'text','text'=>'ราคาจำหน่าย','size'=>'sm','color'=>'#64748b','flex'=>3),array('type'=>'text','text'=>'฿'.number_format($inv_total_retail,0),'size'=>'sm','color'=>'#1e293b','flex'=>3,'align'=>'end')));
            if ($inv_total_discount > 0) {
                $summary_rows[] = array('type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>array(array('type'=>'text','text'=>'ส่วนลดตัวแทน','size'=>'sm','color'=>'#16a34a','flex'=>3),array('type'=>'text','text'=>'-฿'.number_format($inv_total_discount,0),'size'=>'sm','color'=>'#16a34a','flex'=>3,'align'=>'end')));
            }
            $summary_rows[] = array('type'=>'box','layout'=>'horizontal','margin'=>'xs','contents'=>array(array('type'=>'text','text'=>'ราคาตัวแทนรวมส่วนลด','size'=>'sm','color'=>'#64748b','flex'=>3),array('type'=>'text','text'=>'฿'.number_format($total,0),'size'=>'sm','color'=>'#1e293b','flex'=>3,'align'=>'end')));
        }
        $summary_rows[] = array('type'=>'separator','margin'=>'md');
        $summary_rows[] = array('type'=>'box','layout'=>'horizontal','margin'=>'md','contents'=>array(array('type'=>'text','text'=>'มูลค่ารวมสุทธิ','weight'=>'bold','size'=>'md','flex'=>3),array('type'=>'text','text'=>'฿'.number_format($total,2),'weight'=>'bold','size'=>'xl','color'=>'#111111','align'=>'end','flex'=>3)));
        $summary_rows[] = array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(array('type'=>'text','text'=>'📅 กำหนดชำระ','size'=>'xs','color'=>'#dc2626','flex'=>2),array('type'=>'text','text'=>$thai_due.' ('.$credit_days.' วัน)','size'=>'xs','weight'=>'bold','color'=>'#dc2626','align'=>'end','flex'=>3)));

        $bank_logo = b2b_get_bank_logo_url( $ticket_id );
        $bank_card_contents = array();
        if (!empty($bank_logo)) {
            $bank_card_contents[] = array('type'=>'box','layout'=>'horizontal','spacing'=>'md','contents'=>array(
                array('type'=>'image','url'=>$bank_logo,'size'=>'xxs','aspectRatio'=>'1:1','aspectMode'=>'cover','flex'=>0),
                array('type'=>'box','layout'=>'vertical','flex'=>4,'contents'=>array(
                    array('type'=>'text','text'=>$bank['name'],'weight'=>'bold','size'=>'sm','color'=>'#1e293b'),
                    array('type'=>'text','text'=>'('.$bank['name_en'].')','size'=>'xxs','color'=>'#94a3b8')))));
        } else { $bank_card_contents[] = array('type'=>'text','text'=>'🏦 '.$bank['name'],'weight'=>'bold','size'=>'sm','color'=>'#1e293b'); }
        $bank_card_contents[] = array('type'=>'text','text'=>$bank['account'],'weight'=>'bold','size'=>'xxl','color'=>'#111111','align'=>'center','margin'=>'lg');
        $bank_card_contents[] = array('type'=>'text','text'=>'ชื่อบัญชี: '.$bank['holder'],'size'=>'xs','color'=>'#64748b','align'=>'center','margin'=>'xs');
        $bank_card_contents[] = array('type'=>'button','action'=>array('type'=>'clipboard','label'=>'📋 คัดลอกข้อมูลบัญชี','clipboardText'=>b2b_get_bank_copy_text($ticket_id)),'style'=>'primary','color'=>'#16a34a','height'=>'sm','margin'=>'lg');
        $payment_section = array(array('type'=>'box','layout'=>'vertical','margin'=>'md','backgroundColor'=>'#f0fdf4','cornerRadius'=>'12px','paddingAll'=>'16px','contents'=>$bank_card_contents));

        $body_contents = array_merge(array(
                    array('type'=>'box','layout'=>'horizontal','contents'=>array(array('type'=>'text','text'=>'ตัวแทนจำหน่าย','size'=>'xs','color'=>'#999999','flex'=>3),array('type'=>'text','text'=>$dist_name,'size'=>'xs','weight'=>'bold','flex'=>4,'align'=>'end'))),
                    array('type'=>'box','layout'=>'horizontal','contents'=>array(array('type'=>'text','text'=>'ผู้สั่ง','size'=>'xs','color'=>'#999999','flex'=>3),array('type'=>'text','text'=>$orderer,'size'=>'xs','weight'=>'bold','flex'=>4,'align'=>'end'))),
                    array('type'=>'box','layout'=>'horizontal','contents'=>array(array('type'=>'text','text'=>'วันที่','size'=>'xs','color'=>'#999999','flex'=>3),array('type'=>'text','text'=>b2b_date('d/m/Y H:i'),'size'=>'xs','flex'=>4,'align'=>'end'))),
                    array('type'=>'separator','margin'=>'md')),
                    $item_rows, $summary_rows, array(
                    array('type'=>'separator','margin'=>'md'),
                    array('type'=>'text','text'=>'💰 ช่องทางชำระเงิน','weight'=>'bold','size'=>'sm','margin'=>'md')),$payment_section,array(
                    array('type'=>'text','text'=>'📸 โอนแล้วส่งสลิปเข้ากลุ่มนี้ได้เลยครับ','size'=>'xs','color'=>'#999999','margin'=>'md','wrap'=>true)));

        return array('type'=>'flex','altText'=>'🧾 ใบแจ้งหนี้ #'.$ticket_id.' ฿'.number_format($total,0),
            'contents'=>array('type'=>'bubble',
                'header'=>b2b_flex_header('🧾 ใบแจ้งหนี้ / วางบิล','INV-'.$ticket_id,'#111111'),
                'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'16px','spacing'=>'sm','contents'=>$body_contents)));
    }
}

