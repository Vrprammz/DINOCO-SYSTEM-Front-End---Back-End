// REST API: ตรวจว่า LINE userId เป็นสมาชิกกลุ่มนั้นจริงไหม
add_action('rest_api_init', function(){
    register_rest_route('b2b/v1', '/verify-member', array(
        'methods'  => 'POST',
        'callback' => 'b2b_rest_verify_member',
        'permission_callback' => '__return_true',
    ));
});

if ( ! function_exists('b2b_rest_verify_member') ) {
    /**
     * V.10.6-SEC: verify-member API
     * เช็ค membership ผ่าน LINE API: GET /v2/bot/group/{gid}/member/{uid}
     *
     * สำหรับหน้า admin: บังคับเช็คกับ B2B_ADMIN_GROUP_ID เสมอ
     * ไม่ว่า client จะส่ง gid อะไรมา server จะใช้ admin group ID แทน
     */
    function b2b_rest_verify_member( WP_REST_Request $req ) {
        // V.33.2 H10 FIX: rate limit per client IP to prevent group-membership
        // enumeration + LINE Messaging API quota burn. 20 req/min is ~5x typical
        // legit burst (LIFF loads re-verify every ~1 hour; a single page reload
        // triggers at most 1 call). IP is md5-hashed for log-privacy.
        if ( function_exists('b2b_rate_limit') ) {
            $client_ip = isset($_SERVER['REMOTE_ADDR']) ? (string) $_SERVER['REMOTE_ADDR'] : 'unknown';
            $rl_key = 'verify_member_' . md5( $client_ip );
            $rl = b2b_rate_limit( $rl_key, 20, 60 );
            if ( is_wp_error( $rl ) ) {
                b2b_log('[VerifyMember] Rate limited: ip_hash=' . substr( md5($client_ip), 0, 8 ));
                return new WP_REST_Response(
                    array(
                        'ok'      => false,
                        'error'   => 'rate_limited',
                        'message' => 'คำขอมากเกินไป กรุณารอสักครู่แล้วลองอีกครั้ง',
                    ),
                    429
                );
            }
        }

        $gid  = sanitize_text_field($req->get_param('gid'));
        $uid  = sanitize_text_field($req->get_param('uid'));
        $page = sanitize_text_field($req->get_param('page'));

        if ( empty($gid) || empty($uid) ) {
            return new WP_REST_Response(array('ok'=>false,'error'=>'missing_params'), 400);
        }

        // V.10.6-SEC: Admin pages → บังคับ gid = B2B_ADMIN_GROUP_ID
        if ( $page === 'b2b-dashboard' ) {
            $admin_gid = defined('B2B_ADMIN_GROUP_ID') ? B2B_ADMIN_GROUP_ID : '';
            if ( empty($admin_gid) ) {
                return new WP_REST_Response(array('ok'=>false,'error'=>'admin_not_configured'), 500);
            }
            $gid = $admin_gid; // บังคับใช้ admin group ID
        }

        // เรียก LINE API: ตรวจว่า user อยู่ใน group ไหม
        $token = defined('B2B_LINE_ACCESS_TOKEN') ? B2B_LINE_ACCESS_TOKEN : '';
        if ( empty($token) ) {
            return new WP_REST_Response(array('ok'=>false,'error'=>'no_token'), 500);
        }

        $api_url = 'https://api.line.me/v2/bot/group/' . urlencode($gid) . '/member/' . urlencode($uid);
        $resp = wp_remote_get($api_url, array(
            'headers' => array('Authorization' => 'Bearer ' . $token),
            'timeout' => 10,
        ));
        if ( is_wp_error($resp) ) {
            b2b_log('[VerifyMember] WP_Error: ' . $resp->get_error_message());
            return new WP_REST_Response(array('ok'=>false,'error'=>'network_error'), 503);
        }

        $code = wp_remote_retrieve_response_code($resp);

        if ( $code === 200 ) {
            // สมาชิกจริง — สร้าง session token (ใช้ซ้ำ 1 ชม.)
            $session = hash_hmac('sha256', $uid . $gid . b2b_date('YmdH'), $token);
            return new WP_REST_Response(array('ok'=>true,'session'=>$session));
        }

        // ไม่ผ่าน — แยก error message ตาม page (V.13: เพิ่ม stock, tracking)
        $admin_pages = array('b2b-dashboard','b2b-stock','b2b-tracking');
        $error = in_array($page, $admin_pages) ? 'not_admin' : 'not_member';
        return new WP_REST_Response(array('ok'=>false,'error'=>$error,'code'=>$code), 403);
    }
}

