        return '
<style>.b2b-wrap{display:none!important}.b2b-wrap.b2b-verified{display:block!important}</style>
<noscript><div style="text-align:center;padding:60px 20px;font-size:16px;color:#dc2626;">กรุณาเปิด JavaScript เพื่อใช้งาน</div></noscript>
<script>
(function(){
    var API_URL = "' . esc_js($site_url) . '/wp-json/b2b/v1/verify-member";
