// V.15.2: Status change wrapper — log history with timestamps
if ( ! function_exists( 'b2b_set_order_status' ) ) {
    function b2b_set_order_status( $ticket_id, $new_status ) {
        $ticket_id = intval($ticket_id);
        if ( $ticket_id <= 0 ) { b2b_log('[SetStatus] Invalid ticket_id'); return false; }
        // Guard: ป้องกันการเปลี่ยน status ของ order ที่ถูก trash แล้ว
        if ( get_post_status($ticket_id) === 'trash' ) {
            b2b_log('[SetStatus] Blocked — ticket #' . $ticket_id . ' is trashed');
            return false;
        }

        // V.31: Route through FSM if available (validates transitions + logs actor)
        if ( class_exists( 'B2B_Order_FSM' ) ) {
            $result = B2B_Order_FSM::transition( $ticket_id, $new_status, 'system' );
            if ( is_wp_error( $result ) ) {
                // Log warning but still allow (soft migration — don't break existing flows)
                b2b_log('[FSM-WARN] ' . $result->get_error_message() . ' — allowing anyway for #' . $ticket_id);
            } else {
                return true; // FSM handled everything (update + history + hook)
            }
        }

        // Fallback: direct update (if FSM not loaded or FSM warned but we proceed)
        if ( function_exists('b2b_allowed_statuses') && ! in_array( $new_status, b2b_allowed_statuses(), true ) ) {
            b2b_log('[SetStatus] Invalid status: ' . $new_status . ' for #' . $ticket_id);
            return false;
        }
        $old_status = get_field( 'order_status', $ticket_id ) ?: '';
        $now        = current_time( 'mysql' );

        $history = get_post_meta( $ticket_id, '_b2b_status_history', true );
        if ( ! is_array( $history ) ) $history = array();
        $history[] = array( 'from' => $old_status, 'to' => $new_status, 'at' => $now );
        update_post_meta( $ticket_id, '_b2b_status_history', $history );

        update_field( 'order_status', $new_status, $ticket_id );

        // Fire action hook (same as FSM)
        do_action( 'b2b_order_status_changed', $ticket_id, $old_status, $new_status, 'system' );
    }
}

