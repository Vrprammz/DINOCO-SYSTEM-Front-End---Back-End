/**
 * V.32.6: Central helper — คำนวณราคาตัวแทนจาก base_price + tier discount %
 * ใช้ทั้ง GET /catalog, POST /place-order, Flex cards, Invoice
 *
 * @param float  $base_price  ราคาปลีก
 * @param string $rank        standard|silver|gold|platinum|diamond
 * @param array  $sku_data    product data array (must have discount/price_silver/etc + b2b_discount_percent)
 * @return float dealer price (rounded 2 decimal)
 */
if ( ! function_exists( 'b2b_compute_dealer_price' ) ) {
    function b2b_compute_dealer_price( $base_price, $rank, $sku_data ) {
        $base = floatval( $base_price );
        if ( $base <= 0 ) return 0;

        $rank_lower = strtolower( $rank );
        $discount_pct = 0;

        if ( $rank_lower === 'standard' ) {
            // Standard ใช้ b2b_discount_percent (default discount) หรือ discount_standard ถ้ามี
            $discount_pct = floatval( $sku_data['discount_standard'] ?? $sku_data['b2b_discount_percent'] ?? $sku_data['discount'] ?? 0 );
        } else {
            // Tier-specific: price_silver/gold/platinum/diamond ตอนนี้เก็บ % (0-100)
            $tier_key = 'price_' . $rank_lower;
            $tier_val = isset( $sku_data[ $tier_key ] ) ? floatval( $sku_data[ $tier_key ] ) : 0;

            if ( $tier_val > 0 && $tier_val <= 100 ) {
                $discount_pct = $tier_val;
            } else {
                // V.32.7: warn about unmigrated tier values (absolute prices still stored)
                if ( $tier_val > 100 && function_exists( 'b2b_log' ) ) {
                    b2b_log( "[Pricing] WARNING: tier value {$tier_val} > 100% for rank={$rank_lower} — likely unmigrated price, falling back to b2b_discount_percent" );
                }
                // Fallback ไป b2b_discount_percent (default discount)
                $discount_pct = floatval( $sku_data['b2b_discount_percent'] ?? $sku_data['discount'] ?? 0 );
            }
        }

        if ( $discount_pct > 0 && $discount_pct <= 100 ) {
            return round( $base * ( 1 - $discount_pct / 100 ), 2 );
        }
        return $base; // no discount
    }
}

// V.31: Get price for a specific rank from custom table
if ( ! function_exists( 'b2b_get_product_price' ) ) {
    function b2b_get_product_price( $sku, $rank = 'standard' ) {
        if ( class_exists( 'DINOCO_Catalog' ) ) {
            return DINOCO_Catalog::get_price_for_rank( $sku, $rank );
        }
        // Fallback: b2b_product CPT — V.32.6: use b2b_compute_dealer_price
        $pid = b2b_find_product_by_sku( $sku );
        if ( ! $pid ) return 0;
        $base = floatval( get_field( 'price_standard', $pid ) );
        if ( $base <= 0 ) return 0;
        $sku_data = array(
            'b2b_discount_percent' => floatval( get_field( 'b2b_discount_percent', $pid ) ),
            'price_silver'   => floatval( get_field( 'price_silver', $pid ) ),
            'price_gold'     => floatval( get_field( 'price_gold', $pid ) ),
            'price_platinum' => floatval( get_field( 'price_platinum', $pid ) ),
            'price_diamond'  => floatval( get_field( 'price_diamond', $pid ) ),
        );
        return b2b_compute_dealer_price( $base, $rank, $sku_data );
    }
}

