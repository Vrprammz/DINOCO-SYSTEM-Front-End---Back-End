// V.30.0: Receipt AI result Flex card
if ( ! function_exists( 'b2b_build_flex_receipt_result' ) ) {
    function b2b_build_flex_receipt_result( $results ) {
        $matched = 0; $total = count($results);
        $body_items = array();
        foreach ( $results as $r ) {
            if ($r['status'] === 'matched') $matched++;
            $icon = ($r['status'] === 'matched') ? '✅' : (($r['status'] === 'multiple') ? '⚠️' : '❓');
            $line = $icon . ' ' . $r['tracking'];
            if ( isset($r['ticket_id']) ) $line .= ' → #'.$r['ticket_id'];
            if ( isset($r['dist_name']) ) $line .= ' ('.$r['dist_name'].')';

            $body_items[] = array('type'=>'text','text'=>$line,'wrap'=>true,'size'=>'xs','color'=>($r['status']==='matched'?'#059669':'#dc2626'),'margin'=>'sm');

            // Add detail line for non-matched
            if ( $r['status'] === 'no_match' ) {
                $body_items[] = array('type'=>'text','text'=>'   ผู้รับ: '.$r['recipient'].' — ไม่พบ ticket','size'=>'xxs','color'=>'#94a3b8','margin'=>'none');
            }
            if ( $r['status'] === 'multiple' && isset($r['candidates']) ) {
                $body_items[] = array('type'=>'text','text'=>'   พบหลาย ticket: #'.implode(', #', $r['candidates']),'size'=>'xxs','color'=>'#94a3b8','margin'=>'none');
            }
            if ( $r['status'] === 'wrong_status' && isset($r['error']) ) {
                $body_items[] = array('type'=>'text','text'=>'   '.$r['error'],'size'=>'xxs','color'=>'#94a3b8','margin'=>'none');
            }
        }

        // Footer buttons for unmatched trackings
        $footer_buttons = array();
        foreach ( $results as $r ) {
            if ( in_array($r['status'], array('no_match','multiple')) && count($footer_buttons) < 3 ) {
                $label = mb_substr($r['tracking'], 0, 15) . ' → เลือก Ticket';
                $admin_url = home_url('/admin-command-center/?tab=b2b-orders&search=' . urlencode($r['tracking']));
                $footer_buttons[] = array('type'=>'button','style'=>'secondary','height'=>'sm',
                    'action'=>array('type'=>'uri','label'=>$label, 'uri'=>$admin_url));
            }
        }

        $header_text = '📋 อ่านใบเสร็จ — '.$matched.'/'.$total.' matched';
        $bubble = array('type'=>'bubble',
            'header'=>b2b_flex_header($header_text, $matched === $total ? '✅ ครบทุก tracking' : '⚠️ มี tracking ที่ไม่ match', $matched === $total ? '#059669' : '#f59e0b'),
            'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'12px','contents'=>$body_items));
        if ( !empty($footer_buttons) ) {
            $bubble['footer'] = array('type'=>'box','layout'=>'vertical','spacing'=>'sm','paddingAll'=>'12px','contents'=>$footer_buttons);
        }
        return array('type'=>'flex','altText'=>'📋 อ่านใบเสร็จ '.$matched.'/'.$total.' matched','contents'=>$bubble);
    }
}
