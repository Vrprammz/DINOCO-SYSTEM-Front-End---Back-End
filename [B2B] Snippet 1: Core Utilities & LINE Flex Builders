if ( ! function_exists( 'b2b_build_flex_courier_pickup' ) ) {
    function b2b_build_flex_courier_pickup( $pickup_info ) {
        $staff   = $pickup_info['staff_name']   ?? '';
        $phone   = $pickup_info['staff_phone']  ?? '';
        $timeout = $pickup_info['timeout_text'] ?? '';
        $pid     = $pickup_info['pickup_id']    ?? '';
        $count   = intval( $pickup_info['parcel_count'] ?? 0 );
        $tids    = $pickup_info['ticket_ids']   ?? array();
        $color   = '#3b82f6';

        $body = array(
            array( 'type' => 'text', 'text' => 'คูเรียร์: ' . ( $staff ?: '(รอข้อมูล)' ), 'weight' => 'bold', 'size' => 'md' ),
            array( 'type' => 'text', 'text' => 'โทร: ' . ( $phone ?: '-' ), 'size' => 'sm', 'color' => '#333333' ),
            array( 'type' => 'text', 'text' => 'มารับภายใน: ' . ( $timeout ?: '-' ), 'size' => 'sm', 'color' => '#333333' ),
            array( 'type' => 'separator', 'margin' => 'md' ),
            array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'contents' => array(
                array( 'type' => 'text', 'text' => 'Pickup ID', 'size' => 'xs', 'color' => '#888888', 'flex' => 1 ),
                array( 'type' => 'text', 'text' => (string) $pid, 'size' => 'xs', 'flex' => 2, 'align' => 'end' ),
            )),
            array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'sm', 'contents' => array(
                array( 'type' => 'text', 'text' => 'จำนวนพัสดุ', 'size' => 'xs', 'color' => '#888888', 'flex' => 1 ),
                array( 'type' => 'text', 'text' => $count . ' กล่อง', 'size' => 'xs', 'weight' => 'bold', 'flex' => 2, 'align' => 'end' ),
            )),
        );

        // List orders + per-box PNO details
        if ( ! empty( $tids ) ) {
            $body[] = array( 'type' => 'separator', 'margin' => 'md' );
            $body[] = array( 'type' => 'text', 'text' => 'รวมใน Pickup นี้:', 'size' => 'xs', 'color' => '#888888', 'margin' => 'md' );
            foreach ( $tids as $order_tid ) {
                $dist = get_field( 'dist_name', $order_tid ) ?: '';
                $pno_statuses = get_post_meta( $order_tid, '_flash_pno_statuses', true );
                $box_count = is_array( $pno_statuses ) ? count( $pno_statuses ) : 1;
                $body[] = array( 'type' => 'text', 'text' => '#' . $order_tid . ' ' . $dist . ' (' . $box_count . ' กล่อง)', 'size' => 'xs', 'weight' => 'bold', 'color' => '#333333' );
                // Per-box PNO list
                if ( is_array( $pno_statuses ) ) {
                    foreach ( $pno_statuses as $pno => $info ) {
                        $box_label = is_array( $info ) ? ( $info['box'] ?? '' ) : '';
                        $item_name = is_array( $info ) ? ( $info['name'] ?? '' ) : '';
                        $short_pno = strlen( $pno ) > 10 ? '...' . substr( $pno, -6 ) : $pno;
                        $body[] = array( 'type' => 'text', 'text' => '  ' . $short_pno . ' กล่อง ' . $box_label . ' ' . $item_name, 'size' => 'xxs', 'color' => '#666666' );
                    }
                }
            }
            // Total summary
            $order_count = count( $tids );
            if ( $order_count > 1 ) {
                $body[] = array( 'type' => 'separator', 'margin' => 'sm' );
                $body[] = array( 'type' => 'text', 'text' => '📦 รวม ' . $count . ' กล่อง จาก ' . $order_count . ' ออเดอร์', 'size' => 'xs', 'weight' => 'bold', 'color' => '#333333', 'margin' => 'sm' );
            }
        }

        // Footer: Dashboard + จัดการกล่อง buttons
        $footer_contents = array();
        if ( defined( 'B2B_LIFF_ID' ) ) {
            $dash_url = b2b_liff_url( 'b2b-dashboard/', array( 'tab' => 'flash' ) );
            $footer_contents[] = array( 'type' => 'button', 'style' => 'primary', 'height' => 'sm', 'color' => $color,
                'action' => array( 'type' => 'uri', 'label' => '📋 เปิด Dashboard', 'uri' => $dash_url ) );
            $footer_contents[] = array( 'type' => 'button', 'style' => 'link', 'height' => 'sm', 'color' => $color,
                'action' => array( 'type' => 'uri', 'label' => '⚙️ จัดการกล่อง', 'uri' => $dash_url ) );
        }

        $bubble = array( 'type' => 'bubble',
            'header' => b2b_flex_header( '🚛 เรียกรถ Flash สำเร็จ', 'Flash Express', $color ),
            'body'   => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $body ),
        );
        if ( ! empty( $footer_contents ) ) {
            $bubble['footer'] = array( 'type' => 'box', 'layout' => 'vertical', 'spacing' => 'sm', 'paddingAll' => '12px', 'contents' => $footer_contents );
        }
        return array( 'type' => 'flex', 'altText' => '🚛 เรียกรถ Flash สำเร็จ — ' . $staff, 'contents' => $bubble );
    }
}

