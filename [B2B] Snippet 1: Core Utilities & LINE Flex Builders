            array('type'=>'button','style'=>'secondary','height'=>'sm',
                'action'=>array('type'=>'uri','label'=>'🛒 สั่งของ','uri'=>b2b_liff_url('b2b-catalog/'))));
        return array('type'=>'flex','altText'=>'💳 บัญชี '.$name.' — หนี้ ฿'.number_format($debt,0),
