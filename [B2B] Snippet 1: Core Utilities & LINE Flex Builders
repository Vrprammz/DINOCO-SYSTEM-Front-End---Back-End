/**
 * V.32.3: Central helper — อ่าน boxes_per_unit จาก custom table (source of truth) → fallback ACF
 */
if ( ! function_exists( 'b2b_get_boxes_per_unit' ) ) {
    function b2b_get_boxes_per_unit( $sku, $pid = 0 ) {
        // Source 1: Custom table (source of truth)
        if ( class_exists( 'DINOCO_Catalog' ) ) {
            $ct = DINOCO_Catalog::get_by_sku( $sku );
            if ( $ct && intval( $ct['boxes_per_unit'] ?? 0 ) > 0 ) {
                return intval( $ct['boxes_per_unit'] );
            }
        }
        // Source 2: Fallback ACF (สำหรับ product ที่ยังไม่อยู่ใน custom table)
        if ( $pid > 0 ) {
            $bpu = intval( get_field( 'boxes_per_unit', $pid ) ?: 0 );
            if ( $bpu > 0 ) return $bpu;
        }
        return 1; // default
    }
}

/**
 * V.32.9: Central helper — อ่าน units_per_box จาก custom table
 * สำหรับสินค้าเล็กที่แพ็ครวมหลายชิ้นใน 1 กล่อง (เช่น กระเป๋า 6L = 20 ชิ้น/กล่อง)
 */
if ( ! function_exists( 'b2b_get_units_per_box' ) ) {
    function b2b_get_units_per_box( $sku, $pid = 0 ) {
        if ( class_exists( 'DINOCO_Catalog' ) ) {
            $ct = DINOCO_Catalog::get_by_sku( $sku );
            if ( $ct && intval( $ct['units_per_box'] ?? 0 ) > 1 ) {
                return intval( $ct['units_per_box'] );
            }
        }
        return 1; // default
    }
}

/**
 * V.32.9: คำนวณจำนวนกล่องจาก qty + boxes_per_unit + units_per_box
 * - units_per_box > 1: total_boxes = ceil(qty / units_per_box) — แพ็ครวม
 * - boxes_per_unit > 1: total_boxes = qty * boxes_per_unit — ของใหญ่
 * - ทั้งคู่ = 1: total_boxes = qty (เหมือนเดิม)
 */
if ( ! function_exists( 'b2b_compute_boxes_for_qty' ) ) {
    function b2b_compute_boxes_for_qty( $qty, $bpu, $upb ) {
        $qty = max(0, (int) $qty);
        $bpu = max(1, (int) $bpu);
        $upb = max(1, (int) $upb);
        if ( $upb > 1 ) {
            return (int) ceil( $qty / $upb );
        }
        return $qty * $bpu;
    }
}

/**
 * Calculate total boxes for an order based on boxes_per_unit + units_per_box per product.
 * Parses order_items text: "Product Name (SKU) x3 = ฿9,000"
 * V.32.9: รองรับ units_per_box สำหรับสินค้าเล็กแพ็ครวมกล่อง
 */
if ( ! function_exists( 'b2b_calculate_total_boxes' ) ) {
    function b2b_calculate_total_boxes( $ticket_id ) {
        $items = get_field( 'order_items', $ticket_id ) ?: '';
        if ( empty( $items ) ) return 0;

        $total_boxes = 0;
        if ( preg_match_all( '/\(([A-Z0-9\-]+)\)\s*x(\d+)/i', $items, $matches, PREG_SET_ORDER ) ) {
            foreach ( $matches as $m ) {
                $sku = strtoupper( trim( $m[1] ) );
                $qty = intval( $m[2] );
                $pid = function_exists( 'b2b_find_product_by_sku' ) ? b2b_find_product_by_sku( $sku ) : 0;
                $bpu = b2b_get_boxes_per_unit( $sku, $pid );
                $upb = b2b_get_units_per_box( $sku, $pid );
                $total_boxes += b2b_compute_boxes_for_qty( $qty, $bpu, $upb );
            }
        }
        return $total_boxes;
    }
}

/**
 * V.32.9: Calculate box manifest — maps each box to its SKU, name, and leaf children.
 * Returns array of boxes: [ { sku, name, children }, ... ]
 * Uses dinoco_get_leaf_skus() to resolve SET children to leaf nodes (3-level hierarchy).
 * Fallback to 1-level resolution if helper not available.
 * V.32.9: รองรับ units_per_box — สินค้าเล็กหลายชิ้นรวม 1 กล่อง
 */
if ( ! function_exists( 'b2b_calculate_box_manifest' ) ) {
    function b2b_calculate_box_manifest( $ticket_id ) {
        $items = get_field( 'order_items', $ticket_id ) ?: '';
        if ( empty( $items ) ) return array();

        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) ) $relations = array();

        $boxes = array();
        if ( preg_match_all( '/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)/mu', $items, $matches, PREG_SET_ORDER ) ) {
            foreach ( $matches as $m ) {
                $name = trim( $m[1] );
                $sku  = strtoupper( trim( $m[2] ) );
                $qty  = intval( $m[3] );
                $pid = function_exists( 'b2b_find_product_by_sku' ) ? b2b_find_product_by_sku( $sku ) : 0;
                $bpu = b2b_get_boxes_per_unit( $sku, $pid );
                $upb = b2b_get_units_per_box( $sku, $pid );

                // Resolve SET children to leaf nodes (3-level hierarchy)
                if ( function_exists( 'dinoco_get_leaf_skus' ) ) {
                    $leaf_skus = dinoco_get_leaf_skus( $sku, $relations );
                    if ( count( $leaf_skus ) === 1 && strtoupper( trim( $leaf_skus[0] ) ) === $sku ) {
                        $children = array();
                    } else {
                        $children = $leaf_skus;
                    }
                } else {
                    $children = isset( $relations[ $sku ] ) ? $relations[ $sku ] : array();
                }

                // V.32.9: คำนวณจำนวนกล่องตาม units_per_box / boxes_per_unit
                $num_boxes = b2b_compute_boxes_for_qty( $qty, $bpu, $upb );

                for ( $b = 0; $b < $num_boxes; $b++ ) {
                    $boxes[] = array(
                        'sku'      => $sku,
                        'name'     => $name,
                        'children' => $children,
                    );
                }
            }
        }
        return $boxes;
    }
}

/**
 * V.36: Aggregate per-PNO statuses into a single ticket-level status.
 * Filters out cancelled PNOs, then determines the overall status.
 */
if ( ! function_exists( 'b2b_flash_aggregate_status' ) ) {
    function b2b_flash_aggregate_status( $pno_statuses ) {
        if ( ! is_array( $pno_statuses ) || empty( $pno_statuses ) ) return 'created';

        $active = array();
        foreach ( $pno_statuses as $pno => $info ) {
            $s = is_array( $info ) ? ( isset( $info['status'] ) ? $info['status'] : 'created' ) : $info;
            if ( $s !== 'cancelled' ) $active[ $pno ] = $s;
        }
        if ( empty( $active ) ) return 'cancelled';

        $states = array_values( $active );
        $unique = array_unique( $states );

        // ALL same → use that status
        if ( count( $unique ) === 1 ) return $unique[0];

        // Check if ALL delivered
        $all_delivered = true;
        foreach ( $states as $s ) { if ( $s !== 'delivered' ) { $all_delivered = false; break; } }
        if ( $all_delivered ) return 'delivered';

        // Priority: delivering > in_transit > picked_up > created
        // FIX A-5: Priority problem/returned/detained ก่อน — ถ้ามีกล่องที่มีปัญหาต้องแจ้ง
        if ( in_array( 'returned', $states, true ) ) return 'returned';
        if ( in_array( 'problem', $states, true ) ) return 'problem';
        if ( in_array( 'detained', $states, true ) ) return 'detained';

        if ( in_array( 'delivering', $states, true ) ) return 'delivering';
        if ( in_array( 'in_transit', $states, true ) ) return 'in_transit';
        if ( in_array( 'picked_up', $states, true ) ) return 'picked_up';

        return $states[0];
    }
}

/**
 * Enqueue a print job for an order.
 * Sets print_status = 'queued' and calculates total_boxes.
 * RPi will pull this via the print-queue REST endpoint.
 */
if ( ! function_exists( 'b2b_enqueue_print_job' ) ) {
    function b2b_enqueue_print_job( $ticket_id ) {
        $ticket_id = intval( $ticket_id );
        if ( $ticket_id <= 0 || get_post_type( $ticket_id ) !== 'b2b_order' ) return false;

        // Check if auto-print is enabled
        if ( ! get_option( 'b2b_auto_print_enabled', false ) ) {
            b2b_log( '[Print] Auto-print disabled — skip enqueue #' . $ticket_id );
            return false;
        }

        $total_boxes = b2b_calculate_total_boxes( $ticket_id );
        update_field( 'print_status', 'queued', $ticket_id );
        update_field( 'total_boxes', $total_boxes, $ticket_id );
        update_field( 'print_error', '', $ticket_id );
        update_field( 'print_timestamp', '', $ticket_id );
        update_field( 'print_details', '', $ticket_id );

        b2b_log( '[Print] Enqueued #' . $ticket_id . ' — ' . $total_boxes . ' boxes' );
        return true;
    }
}

/**
 * Cancel a print job (remove from queue).
 * If already printed, sends admin notification.
 */
if ( ! function_exists( 'b2b_cancel_print_job' ) ) {
    function b2b_cancel_print_job( $ticket_id ) {
        $ticket_id = intval( $ticket_id );
        $print_status = get_field( 'print_status', $ticket_id ) ?: 'none';

        if ( $print_status === 'queued' ) {
            update_field( 'print_status', 'none', $ticket_id );
            b2b_log( '[Print] Removed from queue #' . $ticket_id );
        } elseif ( $print_status === 'done' ) {
            // Already printed — alert admin
            b2b_push_to_admin( "⚠️ ระงับออเดอร์ #" . $ticket_id . " — ปริ้นไปแล้ว กรุณาดึงใบออก" );
            b2b_log( '[Print] Cancel after printed #' . $ticket_id . ' — admin notified' );
        }
    }
}

