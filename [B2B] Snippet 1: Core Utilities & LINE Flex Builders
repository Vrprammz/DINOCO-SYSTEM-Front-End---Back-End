if ( ! function_exists( 'b2b_log' ) ) {
    function b2b_log( $msg ) {
        $f = defined('WP_CONTENT_DIR') ? WP_CONTENT_DIR . '/b2b-debug.log' : '/tmp/b2b-debug.log';
        // Rotate at 10MB
        if ( file_exists($f) && filesize($f) > 10 * 1024 * 1024 ) {
            @rename($f, $f . '.1');
        }
        $ts = (function_exists('b2b_date')) ? b2b_date('Y-m-d H:i:s') : date('Y-m-d H:i:s');
        $line = '[' . $ts . '] ' . $msg . "\n";
        if ( file_put_contents( $f, $line, FILE_APPEND | LOCK_EX ) === false ) {
            error_log('[B2B] ' . $msg);
        }
    }
}
/** Escape string for safe HTML output */
function b2b_esc( $str ) {
    return htmlspecialchars( (string) $str, ENT_QUOTES, 'UTF-8' );
}
// V.18.0: ICT Timezone helpers — WordPress ตั้ง PHP timezone เป็น UTC เสมอ
// date() จึงแสดงเวลา UTC ทั้งหมด → ต้องใช้ b2b_date() เพื่อให้ได้เวลาไทย (Asia/Bangkok, UTC+7)
if ( ! function_exists( 'b2b_date' ) ) {
    function b2b_date( $format = 'Y-m-d H:i:s', $timestamp = null ) {
        static $tz = null;
        if ( $tz === null ) $tz = new DateTimeZone('Asia/Bangkok');
        $dt = new DateTime('now', $tz);
        if ( $timestamp !== null ) $dt->setTimestamp( (int) $timestamp );
        return $dt->format( $format );
    }
}
if ( ! function_exists( 'b2b_today' ) ) {
    function b2b_today( $format = 'Y-m-d' ) {
        return b2b_date( $format );
    }
}

// V.33.0 — Audit I4: unified debt reader across B2B distributor + B2F maker.
// B2B stores 'current_debt' on `distributor` CPT; B2F stores 'maker_current_debt' on `maker` CPT.
// Returns [ 'debt' => float, 'limit' => float, 'hold' => bool, 'reason' => string, 'field' => 'current_debt'|'maker_current_debt' ]
// or NULL if post_type is neither.
if ( ! function_exists( 'dinoco_get_debt' ) ) {
    function dinoco_get_debt( $post_id ) {
        $post_id = intval( $post_id );
        if ( ! $post_id ) return null;
        $pt = get_post_type( $post_id );
        if ( $pt === 'distributor' ) {
            return array(
                'debt'   => floatval( get_field( 'current_debt', $post_id ) ),
                'limit'  => floatval( get_field( 'credit_limit', $post_id ) ),
                'hold'   => (bool) get_field( 'credit_hold', $post_id ),
                'reason' => (string) get_field( 'credit_hold_reason', $post_id ),
                'field'  => 'current_debt',
            );
        }
        if ( $pt === 'maker' ) {
            return array(
                'debt'   => floatval( get_field( 'maker_current_debt', $post_id ) ),
                'limit'  => floatval( get_field( 'maker_credit_limit', $post_id ) ),
                'hold'   => (bool) get_field( 'maker_credit_hold', $post_id ),
                'reason' => (string) get_field( 'maker_credit_hold_reason', $post_id ),
                'field'  => 'maker_current_debt',
            );
        }
        return null;
    }
}

