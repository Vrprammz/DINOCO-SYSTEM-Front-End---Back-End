/**
 * V.36: Flex card for multi-box status notification (ส่งลูกค้า)
 * ใช้เมื่อ ALL active PNOs ถึงสถานะเดียวกัน หรือมีปัญหาบาง PNO
 */
if ( ! function_exists( 'b2b_build_flex_multi_box_status' ) ) {
    function b2b_build_flex_multi_box_status( $ticket_id, $state, $pno_statuses, $message = '' ) {
        $emoji = b2b_flash_state_emoji( $state );
        $label = b2b_flash_state_label( $state );
        $color = b2b_flash_state_color( $state );
        $active_count = 0;
        foreach ( $pno_statuses as $info ) {
            if ( is_array( $info ) && ( $info['status'] ?? '' ) !== 'cancelled' ) $active_count++;
        }
        $header_text = $emoji . ' ' . $label . ' (' . $active_count . ' กล่อง)';
        $body = array(
            array( 'type' => 'text', 'text' => $header_text, 'weight' => 'bold', 'size' => 'lg', 'color' => $color ),
            array( 'type' => 'separator', 'margin' => 'md' ),
        );
        foreach ( $pno_statuses as $pno => $info ) {
            if ( ! is_array( $info ) ) continue;
            $s = $info['status'] ?? 'created';
            $box = $info['box'] ?? '';
            $name = $info['name'] ?? '';
            if ( $s === 'cancelled' ) continue;
            $s_emoji = b2b_flash_state_emoji( $s === 'created' ? 0 : $s );
            $body[] = array( 'type' => 'box', 'layout' => 'vertical', 'margin' => 'md', 'contents' => array(
                array( 'type' => 'text', 'text' => '📦 กล่อง ' . $box . ': ' . $name, 'size' => 'sm', 'weight' => 'bold', 'color' => '#333333' ),
                array( 'type' => 'text', 'text' => '🚚 ' . $pno, 'size' => 'xs', 'color' => '#666666' ),
            ));
        }
        if ( $message ) {
            $body[] = array( 'type' => 'text', 'text' => $message, 'size' => 'sm', 'color' => '#555555', 'margin' => 'md', 'wrap' => true );
        }
        $footer_contents = array();
        if ( defined( 'B2B_LIFF_ID' ) ) {
