// -- Webhook Verification --------------------------------------------

if ( ! function_exists( 'b2b_flash_verify_webhook' ) ) {
    /**
     * V.33.8 [API-H3]: Flash signs only mchId + nonceStr — webhook body fields
     * are NOT covered by the signature. An attacker with a captured legitimate
     * webhook can replay it with arbitrary body (state forward/backward). We add
     * nonceStr dedup via transient (1hr TTL) to close the replay window.
     *
     * Behavior:
     * - Missing/empty nonceStr → log warning, accept (backward compat with any
     *   Flash callers that omit it — currently all webhooks include nonceStr)
     * - Fresh nonceStr → cache + accept
     * - Repeated nonceStr within 1hr → reject (replay)
     */
    function b2b_flash_verify_webhook( $mch_id, $nonce_str, $sign ) {
        if ( ! defined( 'B2B_FLASH_SECRET_KEY' ) ) return false;
        $params = array( 'mchId' => $mch_id, 'nonceStr' => $nonce_str );
        $expected = b2b_flash_sign( $params );
        if ( ! hash_equals( $expected, strtoupper( (string) $sign ) ) ) {
            return false;
        }

        // [API-H3] Nonce replay defense — 1hr window covers legitimate Flash retries (≤ few min)
        // while blocking replays captured and reused later.
        $nonce_clean = is_string( $nonce_str ) ? trim( $nonce_str ) : '';
        if ( $nonce_clean === '' ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[Flash WH] nonce missing — cannot dedup (accepting for backward compat)' );
            }
            return true;
        }
        $transient_key = 'b2b_flash_nonce_' . md5( $nonce_clean );
        if ( get_transient( $transient_key ) ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[Flash WH] 🔴 REPLAY DETECTED nonce=' . substr( $nonce_clean, 0, 16 ) );
            }
            return false;
        }
        set_transient( $transient_key, 1, HOUR_IN_SECONDS );
        return true;
    }
}

