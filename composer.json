{
    "name": "dinoco/system",
    "description": "DINOCO motorcycle warranty management platform — WordPress + ACF + LINE + PDPA compliance.",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "DinocoTests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "test:verbose": "phpunit --testdox"
    }
}
