{
    "name": "dinoco/system",
    "description": "DINOCO motorcycle warranty management platform — WordPress + ACF + LINE + PDPA compliance.",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "phpunit/phpunit": "^10.0",
        "yoast/phpunit-polyfills": "^2.0",
        "yoast/wp-test-utils": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "DinocoTests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "test:verbose": "phpunit -c phpunit.xml.dist --testdox",
        "test:unit": "phpunit -c phpunit.xml.dist",
        "test:integration": "phpunit -c phpunit.integration.xml",
        "test:all": [
            "@test:unit",
            "@test:integration"
        ]
    }
}
