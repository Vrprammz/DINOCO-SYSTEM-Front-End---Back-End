if ( ! function_exists( 'b2f_rate_limit' ) ) {
    /**
     * Transient-based rate limiter
     * @param string $key     Unique key (e.g. 'create_po_<user_id>')
     * @param int    $max     Max requests
     * @param int    $window  Window in seconds (default 60)
     * @return true|WP_Error
     */
    function b2f_rate_limit( $key, $max = 10, $window = 60 ) {
        global $wpdb;
        $tkey = '_transient_b2f_rl_' . md5( $key );

        // FIX HIGH-02: Atomic increment ด้วย MySQL ON DUPLICATE KEY UPDATE (ป้องกัน TOCTOU)
        $wpdb->query( $wpdb->prepare(
            "INSERT INTO {$wpdb->options} (option_name, option_value, autoload)
             VALUES (%s, '1', 'no')
             ON DUPLICATE KEY UPDATE option_value = option_value + 1",
            $tkey
        ) );

        $count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT option_value FROM {$wpdb->options} WHERE option_name = %s", $tkey
        ) );

        // Set expiry transient (separate key for TTL tracking)
        if ( ! get_transient( 'b2f_rl_exp_' . md5( $key ) ) ) {
            set_transient( 'b2f_rl_exp_' . md5( $key ), 1, $window );
            // Reset counter after window expires (via wp_options cleanup)
            wp_schedule_single_event( time() + $window, 'b2f_rl_cleanup', array( $tkey ) );
        }

        if ( $count > $max ) {
            return new WP_Error( 'rate_limit', 'คำขอมากเกินไป กรุณารอสักครู่', array( 'status' => 429 ) );
        }
        return true;
    }

    // Cleanup handler for rate limit keys
    add_action( 'b2f_rl_cleanup', function( $tkey ) {
        global $wpdb;
        $wpdb->delete( $wpdb->options, array( 'option_name' => $tkey ) );
    } );
}

