// 2. HELPER: RATE LIMITER
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rate_limit' ) ) {
    /**
     * Transient-based rate limiter (CRIT-07 fix: ใช้ transient + timestamp ไม่พึ่ง cron)
     * @param string $key     Unique key (e.g. 'create_po_<user_id>')
     * @param int    $max     Max requests
     * @param int    $window  Window in seconds (default 60)
     * @return true|WP_Error
     */
    function b2f_rate_limit( $key, $max = 10, $window = 60 ) {
        $tkey  = 'b2f_rl_' . md5( $key );
        $data  = get_transient( $tkey );

        if ( $data === false ) {
            // First request — start new window
            set_transient( $tkey, array( 'count' => 1, 'start' => time() ), $window );
            return true;
        }

        $count = intval( $data['count'] ?? 0 );
        $start = intval( $data['start'] ?? 0 );

        // Window expired (transient should auto-expire but double check)
        if ( ( time() - $start ) >= $window ) {
            set_transient( $tkey, array( 'count' => 1, 'start' => time() ), $window );
            return true;
        }

        if ( $count >= $max ) {
            return new WP_Error( 'rate_limit', 'คำขอมากเกินไป กรุณารอสักครู่', array( 'status' => 429 ) );
        }

        // Increment count
        $data['count'] = $count + 1;
        set_transient( $tkey, $data, $window - ( time() - $start ) );
        return true;
    }
}

// ════════════════════════════════════════════
// 2B. ADMIN LIFF AUTH (V.3.0)
// ════════════════════════════════════════════

/**
 * POST /b2f/v1/auth-admin
 * LIFF จาก LINE browser → verify HMAC sig + LINE ID Token → issue session token
 * Pattern เหมือน B2B /auth-group แต่ verify เฉพาะ admin
 *
 * V.11.5 S2 FIX (Phase 2 audit): four-part hardening paired with Snippet 1 V.7.4
 *   `b2f_liff_url()` uid-binding emitter:
 *   (a) When `b2f_flag_sig_bind_uid` ON (default) + `_uid` param present → expected sig
 *       = hash_hmac('sha256', path|_ts=TS|_uid=UID, secret) full 64-char. `hash_equals`
 *       compares full hex → timing-safe + 2^256 collision space (was 2^64).
 *   (b) id_token verify REQUIRED (not silent-fallback). Empty or LINE-API reject →
 *       authorized=false. Previously id_token optional → trivial impersonation via
 *       client-supplied line_user_id.
 *   (c) Post-verify UID check: `$verified_uid` (LINE `verify.sub`) must equal
 *       `$uid_param` from query. Mismatch = URL was forwarded to a different user →
 *       reject. Defeats "screenshot URL → auth as original admin" attack.
 *   (d) `b2f_is_admin_line_uid($verified_uid)` allowlist check BEFORE JWT issuance.
 *       Only LINE UIDs linked to administrator WP users (user_meta.line_user_id + role)
 *       can obtain admin JWT. Previously: any LINE user whose URL passed HMAC became
 *       admin.
 *   (e) Max-age tightened 4hr → 30 min. URL is consumed on LIFF open in typical flow;
 *       30 min margin more than adequate and shrinks stolen-URL reuse window.
 *   Rollback: flip `b2f_flag_sig_bind_uid=false` → falls back to 16-char sig +
 *   skips uid cross-check + keeps id_token optional. Lets older Flex cards authenticate
 *   while new cards roll out. Admin allowlist (d) + 30-min TTL (e) remain unconditional
 *   (no legacy behavior — they are strict-upgrade).
 */
if ( ! function_exists( 'b2f_rest_auth_admin' ) ) {
    function b2f_rest_auth_admin( WP_REST_Request $request ) {
        // Rate limit: 20 per 5 min per IP
        $ip = isset( $_SERVER['REMOTE_ADDR'] ) ? $_SERVER['REMOTE_ADDR'] : 'unknown';
        $rate_key = 'b2f_auth_admin_' . md5( $ip );
        $attempts = intval( get_transient( $rate_key ) );
        if ( $attempts > 20 ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'Too many attempts' ), 429 );
        }
        set_transient( $rate_key, $attempts + 1, 300 );

        // Verify HMAC signature (from b2f_liff_url)
        $sig = sanitize_text_field( $request->get_param( '_sig' ) );
        $ts  = intval( $request->get_param( '_ts' ) );
        if ( empty( $sig ) || $ts <= 0 ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'ลิงก์ไม่ถูกต้อง' ), 200 );
        }

        // V.11.5 S2(e): Max age tightened 4hr → 30 min (LIFF URLs are one-shot in practice).
        if ( abs( time() - $ts ) > 1800 ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'ลิงก์หมดอายุ กรุณากดลิงก์ใหม่' ), 200 );
        }

        // V.11.5 S2(a): Reconstruct HMAC — uid-bound (V.7.4) or legacy (V.7.3).
        $path = 'b2f-catalog/';
        $secret = defined( 'B2B_LINE_CHANNEL_SECRET' ) ? B2B_LINE_CHANNEL_SECRET : wp_salt( 'auth' );
        $uid_param = sanitize_text_field( $request->get_param( '_uid' ) ?: '' );
        $bind_uid_flag = function_exists( 'b2f_is_flag_enabled' )
            ? b2f_is_flag_enabled( 'b2f_flag_sig_bind_uid' )
            : true; // default ON if helper unavailable

        $sig_ok = false;
        if ( $bind_uid_flag && ! empty( $uid_param ) ) {
            // V.7.4 secure path: full 64-char sig + uid bound
            $sig_data = $path . '|_ts=' . $ts . '|_uid=' . $uid_param;
            $expected = hash_hmac( 'sha256', $sig_data, $secret );
            $sig_ok = ( strlen( $sig ) === 64 && hash_equals( $expected, $sig ) );
        }
        if ( ! $sig_ok ) {
            // Legacy path (V.7.3 — 16-char sig over path+_ts) for backward compat during rollout
            $legacy_sig_data = $path . '|_ts=' . $ts;
            $legacy_expected = substr( hash_hmac( 'sha256', $legacy_sig_data, $secret ), 0, 16 );
            if ( strlen( $sig ) === 16 && hash_equals( $legacy_expected, $sig ) ) {
                // Accept legacy sig only when flag is OFF (transition window).
                // When flag ON, reject legacy sigs — forces re-generation of admin Flex URLs.
                if ( ! $bind_uid_flag ) {
                    $sig_ok = true;
                }
            }
        }
        if ( ! $sig_ok ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'ลิงก์ไม่ถูกต้อง (sig)' ), 200 );
        }

        // V.11.5 S2(b): id_token verify REQUIRED. Previously optional (silent fallback to
        // client-supplied line_user_id = trivial impersonation). Now missing/invalid → reject.
        $line_uid_param = sanitize_text_field( $request->get_param( 'line_user_id' ) );
        $id_token       = sanitize_text_field( $request->get_param( 'id_token' ) );
        if ( empty( $line_uid_param ) ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'ต้องเปิดผ่าน LINE เท่านั้น' ), 200 );
        }
        if ( empty( $id_token ) ) {
            return new WP_REST_Response( array(
                'authorized' => false,
                'code'       => 'missing_id_token',
                'message'    => 'ต้องแนบ id_token จาก LIFF',
            ), 400 );
        }

        // Verify LINE ID Token against LINE API. Non-blocking network issues (wp_remote_post
        // WP_Error) are treated as verify-fail (reject) — prior behavior silently accepted.
        $liff_channel_id = defined( 'B2B_LIFF_ID' ) ? preg_replace( '/-.*$/', '', B2B_LIFF_ID ) : '';
        if ( empty( $liff_channel_id ) ) {
            return new WP_REST_Response( array( 'authorized' => false, 'code' => 'liff_not_configured', 'message' => 'LIFF ไม่ได้ตั้งค่า' ), 500 );
        }
        $verify_resp = wp_remote_post( 'https://api.line.me/oauth2/v2.1/verify', array(
            'body'    => array( 'id_token' => $id_token, 'client_id' => $liff_channel_id ),
            'timeout' => 10,
        ) );
        if ( is_wp_error( $verify_resp ) ) {
            return new WP_REST_Response( array( 'authorized' => false, 'code' => 'id_token_verify_fail', 'message' => 'ไม่สามารถยืนยัน LINE ID Token' ), 401 );
        }
        $verify_body = json_decode( wp_remote_retrieve_body( $verify_resp ), true );
        if ( empty( $verify_body['sub'] ) ) {
            return new WP_REST_Response( array( 'authorized' => false, 'code' => 'id_token_invalid', 'message' => 'LINE ID Token ไม่ถูกต้อง' ), 401 );
        }
        $verified_uid = sanitize_text_field( $verify_body['sub'] );

        // V.11.5 S2(c): URL hijack defense — if sig bound to `_uid`, the id_token's `sub`
        // (verified) must equal that `_uid`. If a different user opened the URL, their
        // id_token.sub won't match. Only applies when bind flag ON + uid was bound.
        if ( $bind_uid_flag && ! empty( $uid_param ) && $verified_uid !== $uid_param ) {
            if ( function_exists( 'b2f_log' ) ) {
                b2f_log( sprintf( '[Auth-Admin] S2(c) URL-hijack reject: bound_uid=%s verified_uid=%s', $uid_param, $verified_uid ) );
            }
            return new WP_REST_Response( array( 'authorized' => false, 'code' => 'uid_mismatch', 'message' => 'ลิงก์นี้ไม่ได้สร้างสำหรับคุณ' ), 403 );
        }

        // V.11.5 S2(d): Admin allowlist check. b2f_is_admin_line_uid() looks up WP users
        // with user_meta.line_user_id = $verified_uid + role=administrator. No match → reject.
        // Previously: HMAC sig pass = admin (sig-only trust). Now: sig + id_token +
        // allowlist triple-gate.
        if ( function_exists( 'b2f_is_admin_line_uid' ) ) {
            if ( ! b2f_is_admin_line_uid( $verified_uid ) ) {
                if ( function_exists( 'b2f_log' ) ) {
                    b2f_log( sprintf( '[Auth-Admin] S2(d) allowlist reject: uid=%s', $verified_uid ) );
                }
                return new WP_REST_Response( array( 'authorized' => false, 'code' => 'not_admin', 'message' => 'ผู้ใช้ไม่ได้รับสิทธิ์แอดมิน' ), 403 );
            }
        } else {
            // Helper unavailable — fail closed (safer than permissive fallback).
            return new WP_REST_Response( array( 'authorized' => false, 'code' => 'allowlist_helper_missing', 'message' => 'ระบบตรวจสิทธิ์ไม่พร้อม' ), 500 );
        }

        // Issue session token (reuse B2B JWT if available)
        $token = '';
        if ( class_exists( 'DINOCO_JWT' ) ) {
            $token = DINOCO_JWT::create( array( 'role' => 'b2f_admin', 'uid' => $verified_uid, 'is_admin' => true ), 7200 );
        } else {
            // Fallback: transient
            $token = bin2hex( random_bytes( 32 ) );
            set_transient( 'b2f_admin_sess_' . $token, array( 'uid' => $verified_uid, 'is_admin' => true, 'created' => time() ), 7200 );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( '[Auth-Admin] OK uid=%s (bound=%s)', $verified_uid, ( $bind_uid_flag && ! empty( $uid_param ) ) ? 'yes' : 'no' ) );
        }

        return new WP_REST_Response( array(
            'authorized' => true,
            'token'      => $token,
            'line_uid'   => $verified_uid,
        ), 200 );
    }
}

/**
 * Check if LINE UID belongs to a WP admin user
 * ตรวจจาก user meta 'line_user_id' ที่ link ตอน LINE Login
 */
if ( ! function_exists( 'b2f_is_admin_line_uid' ) ) {
    function b2f_is_admin_line_uid( $line_uid ) {
        if ( empty( $line_uid ) ) return false;

        // ตรวจจาก WordPress users ที่มี line_user_id = $line_uid + เป็น admin
        $users = get_users( array(
            'meta_key'   => 'line_user_id',
            'meta_value' => $line_uid,
            'role'       => 'administrator',
            'number'     => 1,
        ) );
        if ( ! empty( $users ) ) return true;

        // Fallback: ตรวจจาก LINE group membership (Admin group)
        // ถ้า user อยู่ใน Admin group → ถือว่าเป็น admin
        // (ไม่สามารถ query LINE API ได้โดยตรง จึงใช้ user meta เป็นหลัก)
        return false;
    }
}

/**
 * Verify B2F Admin token จาก X-B2F-Token header
 * @return array|false  { uid, is_admin } or false
 */
if ( ! function_exists( 'b2f_verify_admin_token' ) ) {
    function b2f_verify_admin_token( WP_REST_Request $request ) {
        $token = $request->get_header( 'X-B2F-Token' );
        if ( empty( $token ) ) {
            $token = sanitize_text_field( $request->get_param( '_b2f_token' ) );
        }
        if ( empty( $token ) ) return false;

        // JWT verify
        if ( class_exists( 'DINOCO_JWT' ) && strpos( $token, '.' ) !== false ) {
            $payload = DINOCO_JWT::verify( $token );
            if ( $payload && ! empty( $payload['is_admin'] ) && ( $payload['role'] ?? '' ) === 'b2f_admin' ) {
                return array( 'uid' => $payload['uid'] ?? '', 'is_admin' => true );
            }
            return false;
        }

        // Fallback: transient
        $token = preg_replace( '/[^a-f0-9]/i', '', $token );
        if ( empty( $token ) ) return false;
        $data = get_transient( 'b2f_admin_sess_' . $token );
        if ( ! $data || empty( $data['is_admin'] ) ) return false;
        return $data;
    }
}

// ════════════════════════════════════════════
// 3. HELPER: JWT AUTH FOR MAKER ENDPOINTS
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_verify_maker_jwt' ) ) {
    /**
     * Verify JWT token from Maker LIFF
     * @param WP_REST_Request $req
     * @return array|WP_Error  { po_id, maker_id, action } or WP_Error
     */
    function b2f_verify_maker_jwt( WP_REST_Request $req ) {
        $token = sanitize_text_field( $req->get_param( 'token' ) ?: '' );
        if ( empty( $token ) ) {
            // Try Authorization header
            $auth = $req->get_header( 'Authorization' );
            if ( $auth && stripos( $auth, 'Bearer ' ) === 0 ) {
                $token = sanitize_text_field( substr( $auth, 7 ) );
            }
        }

        if ( empty( $token ) ) {
            return new WP_Error( 'no_token', 'ไม่พบ token สำหรับยืนยันตัวตน', array( 'status' => 401 ) );
        }

        if ( ! class_exists( 'DINOCO_JWT' ) ) {
            return new WP_Error( 'jwt_unavailable', 'ระบบ JWT ไม่พร้อมใช้งาน', array( 'status' => 500 ) );
        }

        $payload = DINOCO_JWT::verify( $token );
        if ( ! $payload ) {
            return new WP_Error( 'invalid_token', 'Token ไม่ถูกต้องหรือหมดอายุ', array( 'status' => 401 ) );
        }

        // Required: maker_id (po_id optional สำหรับ maker-level access เช่น list/deliver)
        if ( empty( $payload['maker_id'] ) ) {
            return new WP_Error( 'invalid_payload', 'Token ไม่มีข้อมูลที่จำเป็น', array( 'status' => 401 ) );
        }

        return array(
            'po_id'    => intval( $payload['po_id'] ?? 0 ),
            'maker_id' => intval( $payload['maker_id'] ),
            'action'   => sanitize_text_field( $payload['action'] ?? '' ),
        );
    }
}

