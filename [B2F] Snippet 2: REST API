if ( ! function_exists( 'b2f_rest_po_detail' ) ) {
    /**
     * GET /po-detail/{po_id} — PO detail (admin or maker JWT)
     */
    function b2f_rest_po_detail( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );

        // Auth: admin session OR maker JWT
        $is_admin = current_user_can( 'manage_options' );
        if ( ! $is_admin ) {
            $jwt = b2f_verify_maker_jwt( $req );
            if ( is_wp_error( $jwt ) ) {
                $status = 401;
                $data = $jwt->get_error_data();
                if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
                return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
            }
            // Verify PO belongs to maker
            if ( $jwt['po_id'] !== $po_id ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีสิทธิ์เข้าถึง PO นี้', 'code' => 'FORBIDDEN' ), 403 );
            }
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'po'      => b2f_format_po_detail( $po_id, $is_admin ),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_format_po_detail' ) ) {
    /**
     * Format PO data for API response
     * @param int  $po_id
     * @param bool $include_sensitive  Include admin-only fields (payment, cancel info)
     * @return array
     */
    function b2f_format_po_detail( $po_id, $include_sensitive = false ) {
        $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $items    = get_field( 'po_items', $po_id ) ?: array();

        $formatted_items = array();
        foreach ( $items as $item ) {
            $fi = array(
                'sku'          => esc_html( $item['poi_sku'] ?? '' ),
                'product_name' => esc_html( $item['poi_product_name'] ?? '' ),
                'qty_ordered'  => intval( $item['poi_qty_ordered'] ?? 0 ),
                'unit_cost'    => floatval( $item['poi_unit_cost'] ?? 0 ),
                'qty_received' => intval( $item['poi_qty_received'] ?? 0 ),
                'qty_rejected' => intval( $item['poi_qty_rejected'] ?? 0 ),
            );
            $fi['subtotal'] = round( $fi['unit_cost'] * $fi['qty_ordered'], 2 );
            $formatted_items[] = $fi;
        }

        $data = array(
            'id'              => $po_id,
            'po_number'       => esc_html( get_field( 'po_number', $po_id ) ?: '' ),
            'maker_id'        => $maker_id,
            'maker_name'      => esc_html( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ),
            'status'          => esc_html( get_field( 'po_status', $po_id ) ?: 'draft' ),
            'items'           => $formatted_items,
            'total_amount'    => floatval( get_field( 'po_total_amount', $po_id ) ?: 0 ),
            'item_count'      => intval( get_field( 'po_item_count', $po_id ) ?: 0 ),
            'requested_date'  => esc_html( get_field( 'po_requested_date', $po_id ) ?: '' ),
            'expected_date'   => esc_html( get_field( 'po_expected_date', $po_id ) ?: '' ),
            'actual_date'     => esc_html( get_field( 'po_actual_date', $po_id ) ?: '' ),
            'maker_note'      => esc_html( get_field( 'po_maker_note', $po_id ) ?: '' ),
            'version'         => intval( get_field( 'po_version', $po_id ) ?: 1 ),
            'amendment_count' => intval( get_field( 'po_amendment_count', $po_id ) ?: 0 ),
            'created_date'    => get_the_date( 'Y-m-d H:i:s', $po_id ),
        );

        if ( $include_sensitive ) {
            $data['admin_note']       = esc_html( get_field( 'po_admin_note', $po_id ) ?: '' );
            $data['created_by']       = esc_html( get_field( 'po_created_by', $po_id ) ?: '' );
            $data['paid_amount']      = floatval( get_field( 'po_paid_amount', $po_id ) ?: 0 );
            $data['payment_status']   = esc_html( get_field( 'po_payment_status', $po_id ) ?: 'unpaid' );
            $data['cancelled_reason'] = esc_html( get_field( 'po_cancelled_reason', $po_id ) ?: '' );
            $data['cancelled_by']     = esc_html( get_field( 'po_cancelled_by', $po_id ) ?: '' );
            $data['cancelled_date']   = esc_html( get_field( 'po_cancelled_date', $po_id ) ?: '' );
            $data['rejected_reason']  = esc_html( get_field( 'po_rejected_reason', $po_id ) ?: '' );
        }

        return $data;
    }
}

if ( ! function_exists( 'b2f_rest_po_update' ) ) {
    /**
     * POST /po-update — แก้ไข PO (admin, ก่อน Maker confirm only)
     * Body: { po_id, items: [{ sku, qty }], note?, requested_date? }
     */
    function b2f_rest_po_update( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );

        // Only allow amend in these statuses
        $amendable = array( 'submitted', 'confirmed', 'rejected' );
        if ( ! in_array( $current_status, $amendable, true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่สามารถแก้ไข PO ในสถานะนี้', 'code' => 'NOT_AMENDABLE' ), 400 );
        }

        $items = $req->get_param( 'items' );
        if ( empty( $items ) || ! is_array( $items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุรายการสินค้า', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Rebuild items with fresh cost snapshot
        $po_items = array();
        $total    = 0;

        foreach ( $items as $item ) {
            $sku = sanitize_text_field( $item['sku'] ?? '' );
            $qty = intval( $item['qty'] ?? 0 );
            if ( empty( $sku ) || $qty <= 0 ) continue;

            $mp = new WP_Query( array(
                'post_type'      => 'b2f_maker_product',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array(
                    'relation' => 'AND',
                    array( 'key' => 'mp_maker_id', 'value' => $maker_id, 'type' => 'NUMERIC' ),
                    array( 'key' => 'mp_product_sku', 'value' => $sku ),
                ),
            ) );

            if ( ! $mp->have_posts() ) {
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'ไม่พบ SKU "%s" สำหรับโรงงานนี้', esc_html( $sku ) ),
                    'code'    => 'INVALID_SKU',
                ), 400 );
            }

            $mp_post      = $mp->posts[0];
            $unit_cost    = floatval( get_field( 'mp_unit_cost', $mp_post->ID ) ?: 0 );
            $product_name = get_field( 'mp_product_name', $mp_post->ID ) ?: $sku;
            $subtotal     = round( $unit_cost * $qty, 2 );

            $po_items[] = array(
                'poi_sku'          => $sku,
                'poi_product_name' => $product_name,
                'poi_qty_ordered'  => $qty,
                'poi_unit_cost'    => $unit_cost,
                'poi_qty_received' => 0,
                'poi_qty_rejected' => 0,
            );
            $total += $subtotal;
        }

        if ( empty( $po_items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีรายการสินค้าที่ถูกต้อง', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        // Update fields
        update_field( 'po_items', $po_items, $po_id );
        update_field( 'po_total_amount', round( $total, 2 ), $po_id );
        update_field( 'po_item_count', count( $po_items ), $po_id );

        $amend_count = intval( get_field( 'po_amendment_count', $po_id ) ?: 0 ) + 1;
        $version     = intval( get_field( 'po_version', $po_id ) ?: 1 ) + 1;
        update_field( 'po_amendment_count', $amend_count, $po_id );
        update_field( 'po_version', $version, $po_id );

        $note = $req->get_param( 'note' );
        if ( $note !== null ) {
            update_field( 'po_admin_note', sanitize_textarea_field( $note ), $po_id );
        }
        $req_date = $req->get_param( 'requested_date' );
        if ( $req_date !== null ) {
            update_field( 'po_requested_date', sanitize_text_field( $req_date ), $po_id );
        }

        // Transition: current -> amended -> auto-resubmit
        if ( function_exists( 'b2f_transition_order' ) ) {
            b2f_transition_order( $po_id, 'amended', 'admin', 'PO amended (version ' . $version . ')' );
            b2f_transition_order( $po_id, 'submitted', 'system', 'auto-resubmit after amend' );
        } else {
            update_field( 'po_status', 'submitted', $po_id );
        }

        // Push Flex to Maker
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        if ( function_exists( 'b2f_build_flex_po_amended' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_po_amended( $po_id, $amend_count );
            if ( $flex ) b2f_line_push( $maker_group, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'PO amended: %s (#%d) version=%d total=%.2f', $po_number, $po_id, $version, $total ) );
        }

        return new WP_REST_Response( array(
            'success'      => true,
            'po_id'        => $po_id,
            'version'      => $version,
            'total_amount' => round( $total, 2 ),
            'status'       => 'submitted',
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_po_cancel' ) ) {
    /**
     * POST /po-cancel — ยกเลิก PO (admin) + rollback ถ้า partial received
     * Body: { po_id, reason }
     */
    function b2f_rest_po_cancel( WP_REST_Request $req ) {
        $po_id  = intval( $req->get_param( 'po_id' ) ?: 0 );
        $reason = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );
        $maker_id       = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Check if partial_received -> need rollback
        $need_rollback = ( $current_status === 'partial_received' );

        // Transition
        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'cancelled', 'admin', $reason );
            if ( is_wp_error( $trans ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
            }
        } else {
            update_field( 'po_status', 'cancelled', $po_id );
        }

        // Save cancel metadata
        update_field( 'po_cancelled_reason', $reason, $po_id );
        update_field( 'po_cancelled_by', strval( get_current_user_id() ), $po_id );
        update_field( 'po_cancelled_date', wp_date( 'Y-m-d' ), $po_id );

        // Rollback if partial received
        $rollback_info = array();
        if ( $need_rollback ) {
            $rcv_q = new WP_Query( array(
                'post_type'      => 'b2f_receiving',
                'posts_per_page' => -1,
                'post_status'    => 'publish',
                'meta_query'     => array( array(
                    'key'   => 'rcv_po_id',
                    'value' => $po_id,
                    'type'  => 'NUMERIC',
                ) ),
            ) );

            // TODO: reverse inventory entries (source='b2f_cancel') when Inventory integration is built
            $rollback_info['receiving_records'] = $rcv_q->found_posts;

            // Rollback debt
            $po_total    = floatval( get_field( 'po_total_amount', $po_id ) ?: 0 );
            $paid        = floatval( get_field( 'po_paid_amount', $po_id ) ?: 0 );
            $outstanding = round( $po_total - $paid, 2 );

            if ( $outstanding > 0 && function_exists( 'b2f_payable_subtract' ) ) {
                b2f_payable_subtract( $maker_id, $outstanding, 'PO cancelled - rollback debt', $po_id );
                $rollback_info['debt_reversed'] = $outstanding;
            }
        }

        // Push Flex to Maker
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        if ( function_exists( 'b2f_build_flex_po_cancelled' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_po_cancelled( $po_id, $reason );
            if ( $flex ) b2f_line_push( $maker_group, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'PO cancelled: %s (#%d) reason=%s rollback=%s',
                $po_number, $po_id, $reason, wp_json_encode( $rollback_info )
            ) );
        }

        $resp = array( 'success' => true, 'po_id' => $po_id, 'status' => 'cancelled' );
        if ( ! empty( $rollback_info ) ) {
            $resp['rollback'] = $rollback_info;
        }

        return new WP_REST_Response( $resp, 200 );
    }
}

