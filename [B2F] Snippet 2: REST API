// 13. DASHBOARD ENDPOINTS
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_dashboard_stats' ) ) {
    /**
     * GET /dashboard-stats — KPI stats (ตาม spec section 12)
     *
     * Response: {
     *   pending_confirm, confirmed, overdue,
     *   total_payable, overdue_payable,
     *   po_this_month, po_last_month,
     *   status_breakdown
     * }
     */
    function b2f_rest_dashboard_stats( WP_REST_Request $req ) {
        global $wpdb;

        // PO counts by status
        $status_counts = array();
        $statuses = array(
            'draft', 'submitted', 'confirmed', 'amended', 'rejected',
            'delivering', 'partial_received', 'received',
            'partial_paid', 'paid', 'completed', 'cancelled',
        );

        foreach ( $statuses as $s ) {
            $status_counts[ $s ] = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->posts} p
                 INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'po_status'
                 WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish' AND pm.meta_value = %s",
                $s
            ) );
        }

        // Overdue: confirmed/delivering with expected_date < today
        $today = wp_date( 'Y-m-d' );
        $overdue = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} ps ON p.ID = ps.post_id AND ps.meta_key = 'po_status'
             INNER JOIN {$wpdb->postmeta} pe ON p.ID = pe.post_id AND pe.meta_key = 'po_expected_date'
             WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
             AND ps.meta_value IN ('confirmed','delivering')
             AND pe.meta_value < %s AND pe.meta_value != ''",
            $today
        ) );

        // Total payable (sum of all makers' current_debt)
        $total_payable = (float) $wpdb->get_var(
            "SELECT COALESCE(SUM(CAST(pm.meta_value AS DECIMAL(12,2))), 0)
             FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'maker_current_debt'
             WHERE p.post_type = 'b2f_maker' AND p.post_status = 'publish'"
        );

        // PO this month
        $month_start = wp_date( 'Y-m-01' );
        $po_this_month = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts}
             WHERE post_type = 'b2f_order' AND post_status = 'publish' AND post_date >= %s",
            $month_start . ' 00:00:00'
        ) );

        // PO last month
        $last_month_start = wp_date( 'Y-m-01', strtotime( '-1 month' ) );
        $last_month_end   = wp_date( 'Y-m-t', strtotime( '-1 month' ) );
        $po_last_month = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts}
             WHERE post_type = 'b2f_order' AND post_status = 'publish'
             AND post_date >= %s AND post_date <= %s",
            $last_month_start . ' 00:00:00',
            $last_month_end . ' 23:59:59'
        ) );

        // Overdue payable: makers with debt past credit term
        $overdue_payable = 0;
        $makers_q = new WP_Query( array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => -1,
            'post_status'    => 'publish',
            'fields'         => 'ids',
        ) );
        foreach ( $makers_q->posts as $mid ) {
            $debt = floatval( get_field( 'maker_current_debt', $mid ) ?: 0 );
            if ( $debt <= 0 ) continue;

            $term = intval( get_field( 'maker_credit_term_days', $mid ) ?: 30 );

            // Find oldest unpaid received PO for this maker
            $oldest = $wpdb->get_var( $wpdb->prepare(
                "SELECT MIN(pe.meta_value) FROM {$wpdb->posts} p
                 INNER JOIN {$wpdb->postmeta} ps ON p.ID = ps.post_id AND ps.meta_key = 'po_status'
                 INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'po_maker_id'
                 INNER JOIN {$wpdb->postmeta} pe ON p.ID = pe.post_id AND pe.meta_key = 'po_actual_date'
                 INNER JOIN {$wpdb->postmeta} pp ON p.ID = pp.post_id AND pp.meta_key = 'po_payment_status'
                 WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
                 AND pm.meta_value = %s
                 AND ps.meta_value IN ('received','partial_paid')
                 AND pp.meta_value != 'paid'
                 AND pe.meta_value != ''",
                strval( $mid )
            ) );

            if ( $oldest && strtotime( $oldest ) < strtotime( "-{$term} days" ) ) {
                $overdue_payable += $debt;
            }
        }

        return new WP_REST_Response( array(
            'success'          => true,
            'pending_confirm'  => $status_counts['submitted'] ?? 0,
            'confirmed'        => ( $status_counts['confirmed'] ?? 0 ) + ( $status_counts['delivering'] ?? 0 ),
            'overdue'          => $overdue,
            'total_payable'    => round( $total_payable, 2 ),
            'overdue_payable'  => round( $overdue_payable, 2 ),
            'po_this_month'    => $po_this_month,
            'po_last_month'    => $po_last_month,
            'status_breakdown' => $status_counts,
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_po_history' ) ) {
    /**
     * GET /po-history — PO list with filters and pagination
     * Params: ?maker_id, ?status, ?date_from, ?date_to, ?page, ?per_page, ?search
     *
     * Response: { success, total, page, per_page, total_pages, orders }
     */
    function b2f_rest_po_history( WP_REST_Request $req ) {
        $maker_id  = intval( $req->get_param( 'maker_id' ) ?: 0 );
        $status    = sanitize_text_field( $req->get_param( 'status' ) ?: '' );
        $date_from = sanitize_text_field( $req->get_param( 'date_from' ) ?: '' );
        $date_to   = sanitize_text_field( $req->get_param( 'date_to' ) ?: '' );
        $page      = max( 1, intval( $req->get_param( 'page' ) ?: 1 ) );
        $per_page  = min( 100, max( 1, intval( $req->get_param( 'per_page' ) ?: 20 ) ) );
        $search    = sanitize_text_field( $req->get_param( 'search' ) ?: '' );

        $args = array(
            'post_type'      => 'b2f_order',
            'posts_per_page' => $per_page,
            'paged'          => $page,
            'post_status'    => 'publish',
            'orderby'        => 'date',
            'order'          => 'DESC',
            'meta_query'     => array(),
        );

        if ( $maker_id ) {
            $args['meta_query'][] = array(
                'key'   => 'po_maker_id',
                'value' => $maker_id,
                'type'  => 'NUMERIC',
            );
        }

        if ( ! empty( $status ) ) {
            $args['meta_query'][] = array(
                'key'   => 'po_status',
                'value' => $status,
            );
        }

        if ( ! empty( $date_from ) ) {
            $args['date_query'][] = array(
                'after'     => $date_from,
                'inclusive' => true,
            );
        }

        if ( ! empty( $date_to ) ) {
            $args['date_query'][] = array(
                'before'    => $date_to,
                'inclusive' => true,
            );
        }

        if ( ! empty( $search ) ) {
            $args['meta_query'][] = array(
                'key'     => 'po_number',
                'value'   => $search,
                'compare' => 'LIKE',
            );
        }

        $q      = new WP_Query( $args );
        $orders = array();

        foreach ( $q->posts as $p ) {
            $orders[] = b2f_format_po_detail( $p->ID, true );
        }

        return new WP_REST_Response( array(
            'success'     => true,
            'total'       => $q->found_posts,
            'page'        => $page,
            'per_page'    => $per_page,
            'total_pages' => $q->max_num_pages,
            'orders'      => $orders,
        ), 200 );
    }
}
