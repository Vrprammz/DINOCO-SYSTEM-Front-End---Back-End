if ( ! function_exists( 'b2f_rest_receive_goods' ) ) {
    /**
     * POST /receive-goods — ตรวจรับสินค้า (FormData with photo upload)
     *
     * FormData fields:
     *   po_id           (int)
     *   items           (JSON string) [{ sku, qty_received, qc_status, reject_qty?, reject_reason? }]
     *   photos_<SKU>[]  (files, max 5 per SKU)
     *   inspected_by    (string)
     *   note            (string)
     *
     * Response: { success, rcv_id, rcv_number, po_status, inventory_updated, debt_added }
     */
    function b2f_rest_receive_goods( WP_REST_Request $req ) {
        // Rate limit: 5 req/min per admin
        $rl = b2f_rate_limit( 'receive_' . get_current_user_id(), 5, 60 );
        if ( is_wp_error( $rl ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $rl->get_error_message(), 'code' => 'RATE_LIMIT' ), 429 );
        }

        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        // FIX HIGH-03: MySQL GET_LOCK แทน transient (atomic, ป้องกัน TOCTOU double receiving)
        $lock_key = 'b2f_recv_' . intval( $po_id );
        global $wpdb;
        $got_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 0)", $lock_key ) );
        if ( ! $got_lock ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'มีคนอื่นกำลังตรวจรับ PO นี้อยู่ กรุณารอสักครู่', 'code' => 'LOCKED' ), 423 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );
        // ISSUE-3 fix: เอา confirmed ออก — Admin ตรวจรับได้เฉพาะเมื่อ Maker แจ้งส่งแล้ว (delivering/partial_received)
        $receivable = array( 'delivering', 'partial_received' );
        if ( ! in_array( $current_status, $receivable, true ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่สามารถตรวจรับ PO ในสถานะนี้', 'code' => 'NOT_RECEIVABLE' ), 400 );
        }

        // Parse items (JSON string from FormData)
        $items_raw = $req->get_param( 'items' );
        if ( is_string( $items_raw ) ) {
            $items = json_decode( $items_raw, true );
        } else {
            $items = $items_raw;
        }

        if ( empty( $items ) || ! is_array( $items ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุรายการที่รับ', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        $inspected_by = sanitize_text_field( $req->get_param( 'inspected_by' ) ?: '' );
        $note         = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );
        $maker_id     = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Build PO items lookup map
        $po_items = get_field( 'po_items', $po_id ) ?: array();
        $po_items_map = array();
        foreach ( $po_items as $idx => $pi ) {
            $sku = $pi['poi_sku'] ?? '';
            $po_items_map[ $sku ] = array(
                'index'    => $idx,
                'ordered'  => intval( $pi['poi_qty_ordered'] ?? 0 ),
                'shipped'  => intval( $pi['poi_qty_shipped'] ?? 0 ),
                'received' => intval( $pi['poi_qty_received'] ?? 0 ),
                'rejected' => intval( $pi['poi_qty_rejected'] ?? 0 ),
            );
        }

        // Process receiving items
        $rcv_items       = array();
        $total_rcv_value = 0;
        $all_complete    = true;
        $files           = $req->get_file_params();

        foreach ( $items as $item ) {
            $sku           = sanitize_text_field( $item['sku'] ?? '' );
            $qty_rcv       = intval( $item['qty_received'] ?? 0 );
            $qc_status     = sanitize_text_field( $item['qc_status'] ?? 'passed' );
            $reject_qty    = intval( $item['reject_qty'] ?? 0 );
            $reject_reason = sanitize_textarea_field( $item['reject_reason'] ?? '' );

            if ( empty( $sku ) || $qty_rcv <= 0 ) continue;

            if ( ! isset( $po_items_map[ $sku ] ) ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'SKU "%s" ไม่อยู่ใน PO นี้', esc_html( $sku ) ),
                    'code'    => 'INVALID_SKU',
                ), 400 );
            }

            $pi_data   = $po_items_map[ $sku ];
            // V.6.5 FIX: remaining = shipped - received (received = ทุกชิ้นที่ผ่าน QC แล้ว ทั้งผ่าน+reject)
            // ของที่ reject ไม่กลับมาให้รับซ้ำ — Maker ส่งใหม่เป็นของชิ้นใหม่
            $remaining = max( 0, $pi_data['shipped'] - $pi_data['received'] );

            if ( $qty_rcv > $remaining ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'จำนวนรับ SKU "%s" (%d) เกินจำนวนที่เหลือ (%d)', esc_html( $sku ), $qty_rcv, $remaining ),
                    'code'    => 'OVER_RECEIVE',
                ), 400 );
            }

            // Handle photo uploads for rejected items
            $reject_photo_ids = array();
            if ( ( $qc_status === 'failed' || $reject_qty > 0 ) ) {
                $file_key = 'photos_' . $sku;
                if ( ! empty( $files[ $file_key ] ) ) {
                    require_once ABSPATH . 'wp-admin/includes/image.php';
                    require_once ABSPATH . 'wp-admin/includes/file.php';
                    require_once ABSPATH . 'wp-admin/includes/media.php';

                    // FIX HIGH-01: MIME type + file size validation ก่อน upload
                    $b2f_allowed_mimes = array( 'image/jpeg', 'image/png', 'image/webp' );
                    $b2f_max_file_size = 5 * 1024 * 1024; // 5MB

                    // Restrict upload types ผ่าน WP filter
                    $b2f_mime_filter = function( $mimes ) {
                        return array( 'jpg|jpeg' => 'image/jpeg', 'png' => 'image/png', 'webp' => 'image/webp' );
                    };
                    add_filter( 'upload_mimes', $b2f_mime_filter, 999 );

                    $uploaded = $files[ $file_key ];
                    if ( is_array( $uploaded['name'] ) ) {
                        $count = min( count( $uploaded['name'] ), 5 );
                        for ( $i = 0; $i < $count; $i++ ) {
                            // Validate MIME + size
                            if ( ! in_array( $uploaded['type'][ $i ], $b2f_allowed_mimes ) ) continue;
                            if ( $uploaded['size'][ $i ] > $b2f_max_file_size ) continue;
                            $file_arr = array(
                                'name'     => $uploaded['name'][ $i ],
                                'type'     => $uploaded['type'][ $i ],
                                'tmp_name' => $uploaded['tmp_name'][ $i ],
                                'error'    => $uploaded['error'][ $i ],
                                'size'     => $uploaded['size'][ $i ],
                            );
                            $_FILES['b2f_upload'] = $file_arr;
                            $att_id = media_handle_upload( 'b2f_upload', 0 );
                            if ( ! is_wp_error( $att_id ) ) {
                                $reject_photo_ids[] = $att_id;
                            }
                        }
                    } else {
                        // Validate MIME + size (single file)
                        if ( in_array( $uploaded['type'], $b2f_allowed_mimes ) && $uploaded['size'] <= $b2f_max_file_size ) {
                            $_FILES['b2f_upload'] = $uploaded;
                            $att_id = media_handle_upload( 'b2f_upload', 0 );
                            if ( ! is_wp_error( $att_id ) ) {
                                $reject_photo_ids[] = $att_id;
                            }
                        }
                    }
                    // Remove MIME filter after upload
                    remove_filter( 'upload_mimes', $b2f_mime_filter, 999 );
                }
            }

            $rcv_items[] = array(
                'rcvi_sku'           => $sku,
                'rcvi_qty_received'  => $qty_rcv,
                'rcvi_qty_rejected'  => $reject_qty,
                'rcvi_qc_status'     => $qc_status,
                'rcvi_reject_reason' => $reject_reason,
                'rcvi_reject_photos' => $reject_photo_ids,
            );

            // Update PO item cumulative totals
            $new_received = $pi_data['received'] + $qty_rcv;
            $new_rejected = $pi_data['rejected'] + $reject_qty;
            $po_items[ $pi_data['index'] ]['poi_qty_received'] = $new_received;
            $po_items[ $pi_data['index'] ]['poi_qty_rejected'] = $new_rejected;

            // Calculate value for debt (only count accepted items) — always THB
            $unit_cost     = floatval( $po_items[ $pi_data['index'] ]['poi_unit_cost'] ?? 0 );
            $accepted      = $qty_rcv - $reject_qty;
            $po_ex_rate    = floatval( get_field( 'po_exchange_rate', $po_id ) ?: 1 );
            if ( $accepted > 0 ) {
                $total_rcv_value += round( $unit_cost * $accepted * $po_ex_rate, 2 );
            }
        }

        if ( empty( $rcv_items ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีรายการที่รับ', 'code' => 'NO_ITEMS' ), 400 );
        }

        // Check if ALL SKUs fully received — accepted (received - rejected) >= ordered
        foreach ( $po_items_map as $sku => $pi_data ) {
            $cur_received = intval( $po_items[ $pi_data['index'] ]['poi_qty_received'] ?? 0 );
            $cur_rejected = intval( $po_items[ $pi_data['index'] ]['poi_qty_rejected'] ?? 0 );
            $cur_accepted = $cur_received - $cur_rejected;
            if ( $cur_accepted < $pi_data['ordered'] ) {
                $all_complete = false;
                break;
            }
        }

        // V.6.4 FIX: เขียน sub-fields ตรง wp_postmeta bypass ACF repeater
        // ACF update_field สำหรับ repeater อาจไม่ persist sub-fields ที่แก้ไข
        // ดังนั้นใช้ update_post_meta ตรงๆ ซึ่งเชื่อถือได้ 100%
        update_field( 'po_items', $po_items, $po_id );
        foreach ( $po_items as $idx => $pi_save ) {
            update_post_meta( $po_id, 'po_items_' . $idx . '_poi_qty_received', intval( $pi_save['poi_qty_received'] ?? 0 ) );
            update_post_meta( $po_id, 'po_items_' . $idx . '_poi_qty_rejected', intval( $pi_save['poi_qty_rejected'] ?? 0 ) );
        }
        wp_cache_delete( $po_id, 'post_meta' );
        clean_post_cache( $po_id );

        // Debug log
        if ( function_exists( 'b2f_log' ) ) {
            $dbg = array();
            foreach ( $po_items as $pi_dbg ) {
                $dbg[] = ( $pi_dbg['poi_sku'] ?? '?' ) . ':rcv=' . ( $pi_dbg['poi_qty_received'] ?? '?' ) . '/rej=' . ( $pi_dbg['poi_qty_rejected'] ?? '?' );
            }
            b2f_log( '[RCV] Saved po_items PO#' . $po_id . ': ' . implode( ' | ', $dbg ) );
        }

        // Create receiving record
        $rcv_number = function_exists( 'b2f_generate_rcv_number' )
            ? b2f_generate_rcv_number()
            : 'RCV-' . wp_date( 'ymd' ) . '-000';

        $rcv_id = wp_insert_post( array(
            'post_type'   => 'b2f_receiving',
            'post_title'  => $rcv_number,
            'post_status' => 'publish',
        ) );

        if ( is_wp_error( $rcv_id ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'สร้างใบรับของไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
        }

        update_field( 'rcv_po_id', $po_id, $rcv_id );
        update_field( 'rcv_number', $rcv_number, $rcv_id );
        update_field( 'rcv_date', wp_date( 'Y-m-d' ), $rcv_id );
        update_field( 'rcv_items', $rcv_items, $rcv_id );
        update_field( 'rcv_total_value', $total_rcv_value, $rcv_id );
        update_field( 'rcv_admin_note', $note, $rcv_id );
        update_field( 'rcv_inspected_by', $inspected_by, $rcv_id );

        // V.5.5: Set rcv_has_reject flag
        $has_any_reject = false;
        foreach ( $rcv_items as $ri ) {
            if ( intval( $ri['rcvi_qty_rejected'] ?? 0 ) > 0 ) { $has_any_reject = true; break; }
        }
        if ( $has_any_reject ) {
            update_field( 'rcv_has_reject', 1, $rcv_id );
            update_field( 'rcv_reject_resolved', 0, $rcv_id );
        }

        // V.8.6 — Audit C4 v2: DO NOT transition PO yet. Stock write first; transition after success.
        // Why: FSM `received → delivering` is illegal (Snippet 6 FSM table) → rollback transition
        //      would silently fail, leaving PO in `received` with no stock rows.
        // ดึง unit_cost จาก PO items + exchange_rate สำหรับ Valuation
        // V.11.7 DB-H1 FIX: SKU key case-insensitive — build + lookup ทั้งคู่ใช้ strtoupper(trim())
        //   ทั้ง rcv_items ($sku) และ po_items ($poi_sku) เก็บมาจากหลาย source (LIFF, admin form,
        //   legacy PO) → case อาจต่างกัน → isset($po_cost_map[$sku]) miss → unit_cost_thb NULL →
        //   dinoco_stock_add() skip valuation write → WAC silent drift เมื่อ PO ต่าง case ชนกัน.
        //   Both maps/keys now uppercase-normalized (matches utf8mb4_bin + DINOCO_Catalog convention).
        $po_items_raw = get_field( 'po_items', $po_id ) ?: [];
        $po_exchange  = floatval( get_field( 'po_exchange_rate', $po_id ) ?: 1 );
        $po_cost_map  = [];
        if ( is_array( $po_items_raw ) ) {
            foreach ( $po_items_raw as $poi ) {
                $poi_sku  = $poi['poi_sku'] ?? ($poi['sku'] ?? '');
                $poi_cost = floatval( $poi['poi_unit_cost'] ?? ($poi['unit_cost'] ?? 0) );
                if ( $poi_sku && $poi_cost > 0 ) {
                    $po_cost_map[ strtoupper( trim( $poi_sku ) ) ] = $poi_cost * $po_exchange; // THB
                }
            }
        }

        // === Stage 1: Stock dual-write with early-abort on first failure ===
        $inventory_updated = false;
        $stock_errors      = array();
        $stock_succeeded   = array(); // [ [sku,qty], ... ] สำหรับ rollback

        foreach ( $rcv_items as $ri ) {
            $sku = $ri['rcvi_sku'] ?? '';
            $qty = intval( $ri['rcvi_qty_received'] ?? 0 );
            if ( ! $sku || $qty <= 0 ) continue;

            // V.11.7 DB-H1: lookup also uppercase-normalized (paired with build above)
            $sku_cost_key  = strtoupper( trim( $sku ) );
            $unit_cost_thb = isset( $po_cost_map[ $sku_cost_key ] ) ? $po_cost_map[ $sku_cost_key ] : null;

            if ( function_exists( 'dinoco_stock_add' ) ) {
                $stock_result = dinoco_stock_add( $sku, $qty, 'b2f_receive', 'b2f_receiving', $rcv_id, 'B2F receive PO ' . ( get_field( 'po_number', $po_id ) ?: $po_id ), '', null, $unit_cost_thb );
                if ( is_wp_error( $stock_result ) ) {
                    $stock_errors[] = sprintf( '%s(%d): %s', $sku, $qty, $stock_result->get_error_message() );
                    if ( function_exists( 'b2f_log' ) ) {
                        b2f_log( sprintf( '[C4 CRITICAL] dinoco_stock_add failed on receive-goods po=%d sku=%s qty=%d err=%s', $po_id, $sku, $qty, $stock_result->get_error_message() ) );
                    }
                    break;
                }
                $stock_succeeded[] = array( 'sku' => $sku, 'qty' => $qty );
                $inventory_updated = true;
            }
            elseif ( class_exists( 'DINOCO_Catalog' ) ) {
                $product = DINOCO_Catalog::get_by_sku( $sku );
                if ( $product && $product['stock_status'] === 'out_of_stock' ) {
                    DINOCO_Catalog::set_stock_status( $sku, 'in_stock' );
                }
                $inventory_updated = true;
            }
        }

        // === Stage 1 failure: rollback stock only, delete rcv_id, leave PO unchanged ===
        if ( ! empty( $stock_errors ) ) {
            foreach ( array_reverse( $stock_succeeded ) as $ok ) {
                if ( function_exists( 'dinoco_stock_subtract' ) ) {
                    dinoco_stock_subtract( $ok['sku'], $ok['qty'], 'b2f_receive_rollback', 'b2f_receiving', $rcv_id, 'Rollback receive PO ' . $po_id . ' (C4 dual-write fail)' );
                }
            }
            // Log BEFORE delete so audit refers to a real post id
            if ( function_exists( 'b2f_log' ) ) {
                b2f_log( sprintf( '[C4 ROLLBACK] deleting rcv_id=%d for po=%d (errors=%s)', $rcv_id, $po_id, implode( '; ', $stock_errors ) ) );
            }
            wp_delete_post( $rcv_id, true );
            // PO status untouched → still `delivering`/`partial_received` (legal upstream states)
            return new WP_Error( 'stock_dual_write_failed', 'บันทึกสต็อกไม่สำเร็จ ยกเลิกการรับของแล้ว: ' . implode( '; ', $stock_errors ), array( 'status' => 500 ) );
        }

        // === Stage 2: Stock succeeded → transition PO + add payable ===
        $new_status = $all_complete ? 'received' : 'partial_received';
        if ( function_exists( 'b2f_transition_order' ) ) {
            b2f_transition_order( $po_id, $new_status, 'admin', sprintf( 'Receiving %s', $rcv_number ) );
        } else {
            update_field( 'po_status', $new_status, $po_id );
        }

        if ( $all_complete ) {
            if ( empty( get_field( 'po_actual_date', $po_id ) ) ) update_field( 'po_actual_date', wp_date( 'Y-m-d' ), $po_id );
        }

        // Add debt (payable) — stock already committed; this is the last write and is idempotent via b2f_payable_add audit log
        $debt_added = false;
        if ( $total_rcv_value > 0 && function_exists( 'b2f_payable_add' ) ) {
            b2f_payable_add( $maker_id, $total_rcv_value, sprintf( 'รับของ %s', $rcv_number ), $po_id );
            $debt_added = true;
        }

        // V.5.1: Guaranteed push — Maker + Admin with text fallback + debug log
        $maker_group = get_field( 'maker_line_group_id', $maker_id ) ?: '';
        $po_number   = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( '[Receive Push] maker_id=%d maker_group=%s po=%s status=%s', $maker_id, $maker_group ?: 'EMPTY', $po_number, $new_status ) );
        }
        // V.5.3: Inline Flex push — สร้าง Flex ตรงนี้เลย (ไม่พึ่ง builder function)
        $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
        $rcv_status_th = $all_complete ? 'รับครบแล้ว' : 'รับบางส่วน';
        $rcv_badge_color = $all_complete ? '#16a34a' : '#f59e0b';
        $rcv_badge_emoji = $all_complete ? '✅' : '⏳';
        $detail_url = function_exists( 'b2f_liff_url' ) ? b2f_liff_url( '/b2f-po-ticket/', array( 'po_id' => $po_id ) ) : '#';
        $logo = 'https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png';

        // V.7.2: ENG labels for Maker Flex
        $po_currency = get_field( 'po_currency', $po_id ) ?: 'THB';
        $cur = $po_currency ?: 'THB';
        $is_eng = $cur !== 'THB';

        // V.5.9: Flex ตรวจรับแบบตาราง (เหมือน Flex ส่งของ)
        // สร้าง rcv_items sku map สำหรับ "รอบนี้" lookup
        $rcv_sku_map = array();
        $total_this_rcv = 0;
        $total_this_rej = 0;
        foreach ( $rcv_items as $ri ) {
            $rs = $ri['rcvi_sku'] ?? '';
            $rq = intval( $ri['rcvi_qty_received'] ?? 0 );
            $rj = intval( $ri['rcvi_qty_rejected'] ?? 0 );
            $rcv_sku_map[ $rs ] = array( 'rcv' => $rq, 'rej' => $rj );
            $total_this_rcv += $rq;
            $total_this_rej += $rj;
        }

        // Per-item rows (shared between Maker + Admin) — refresh po_items
        $refreshed_items = get_field( 'po_items', $po_id ) ?: $po_items;
        $total_remaining = 0;
        $pending_inspect_count = 0; // V.6.5
        $rcv_item_rows = array(); // shared data rows
        foreach ( $refreshed_items as $pi ) {
            $pi_sku      = $pi['poi_sku'] ?? '';
            $pi_name     = $pi['poi_product_name'] ?? $pi_sku;
            $pi_ordered  = intval( $pi['poi_qty_ordered'] ?? 0 );
            $pi_received = intval( $pi['poi_qty_received'] ?? 0 );
            $pi_rejected = intval( $pi['poi_qty_rejected'] ?? 0 );
            $pi_shipped  = intval( $pi['poi_qty_shipped'] ?? 0 );
            $pi_accepted = $pi_received - $pi_rejected;
            $pi_left     = max( 0, $pi_ordered - $pi_accepted );
            $total_remaining += $pi_left;
            if ( $pi_shipped > $pi_received ) $pending_inspect_count++;

            $this_ri = isset( $rcv_sku_map[ $pi_sku ] ) ? $rcv_sku_map[ $pi_sku ] : null;
            $round_rcv = $this_ri ? $this_ri['rcv'] : 0;
            $round_rej = $this_ri ? $this_ri['rej'] : 0;
            $round_text = $round_rcv > 0 ? '+' . $round_rcv : '-';
            if ( $round_rej > 0 ) $round_text = '+' . $round_rcv . '/' . $round_rej;
            $round_color = $round_rej > 0 ? '#dc2626' : ( $round_rcv > 0 ? '#16a34a' : '#94a3b8' );
            $row_bg = $round_rcv > 0 ? '#f0fdf4' : '#ffffff';
            $left_color = $pi_left > 0 ? '#dc2626' : '#16a34a';

            $row = array();
            $pi_img = '';
            if ( $pi_sku && class_exists( 'DINOCO_Catalog' ) ) {
                $pi_prod = DINOCO_Catalog::get_by_sku( $pi_sku );
                if ( $pi_prod && ! empty( $pi_prod['image_url'] ) ) $pi_img = $pi_prod['image_url'];
            }
            if ( $pi_img ) $row[] = array( 'type' => 'image', 'url' => $pi_img, 'size' => 'xxs', 'aspectMode' => 'cover', 'aspectRatio' => '1:1', 'flex' => 0 );
            $row[] = array( 'type' => 'text', 'text' => $pi_name, 'size' => 'xxs', 'flex' => 3, 'wrap' => true, 'color' => '#1e293b' );
            $row[] = array( 'type' => 'text', 'text' => (string) $pi_ordered, 'size' => 'xs', 'flex' => 1, 'align' => 'center', 'color' => '#64748b' );
            $row[] = array( 'type' => 'text', 'text' => (string) $pi_accepted, 'size' => 'xs', 'flex' => 1, 'align' => 'center', 'color' => '#1e293b' );
            $row[] = array( 'type' => 'text', 'text' => (string) $pi_left, 'size' => 'xs', 'weight' => 'bold', 'flex' => 1, 'align' => 'center', 'color' => $left_color );
            $row[] = array( 'type' => 'text', 'text' => $round_text, 'size' => 'xs', 'weight' => 'bold', 'flex' => 1, 'align' => 'center', 'color' => $round_color );
            $rcv_item_rows[] = array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'sm', 'margin' => 'sm', 'backgroundColor' => $row_bg, 'paddingAll' => '4px', 'cornerRadius' => '4px', 'contents' => $row );
        }

        // V.8.0: Helper — build rcv Flex body with currency param (3-lang)
        $rcv_build_body = function ( $c ) use ( $maker_id, $total_this_rcv, $total_this_rej, $rcv_item_rows, $all_complete, $rcv_status_th, $total_remaining, $rcv_badge_color, $pending_inspect_count, $total_rcv_value ) {
            $body = array();
            $body[] = array( 'type' => 'box', 'layout' => 'horizontal', 'contents' => array(
                array( 'type' => 'text', 'text' => b2f_t('🏭 โรงงาน', '🏭 Factory', '🏭 供应商', $c), 'size' => 'xs', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => get_field( 'maker_name', $maker_id ) ?: '-', 'size' => 'xs', 'weight' => 'bold', 'flex' => 5, 'align' => 'end', 'wrap' => true ),
            ) );
            $body[] = array( 'type' => 'text', 'text' => '📅 ' . wp_date( 'd/m/Y H:i' ), 'size' => 'xxs', 'color' => '#64748b', 'margin' => 'sm' );

            $summary = b2f_t('รับรอบนี้ ' . $total_this_rcv . ' ชิ้น', 'Received this lot: ' . $total_this_rcv . ' pcs', '本次验收: ' . $total_this_rcv . '件', $c);
            if ( $total_this_rej > 0 ) $summary .= ' (reject ' . $total_this_rej . ')';
            $body[] = array( 'type' => 'text', 'text' => $summary, 'size' => 'xs', 'weight' => 'bold', 'color' => '#7c3aed', 'margin' => 'sm' );

            $body[] = array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'paddingBottom' => '4px', 'contents' => array(
                array( 'type' => 'text', 'text' => b2f_t('สินค้า', 'Product', '产品', $c), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 3 ),
                array( 'type' => 'text', 'text' => b2f_t('สั่ง', 'Ord', '订购', $c), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 1, 'align' => 'center' ),
                array( 'type' => 'text', 'text' => b2f_t('รับ', 'Rcv', '已收', $c), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 1, 'align' => 'center' ),
                array( 'type' => 'text', 'text' => b2f_t('เหลือ', 'Left', '剩余', $c), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 1, 'align' => 'center' ),
                array( 'type' => 'text', 'text' => b2f_t('รอบนี้', 'Now', '本次', $c), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#7c3aed', 'flex' => 1, 'align' => 'center' ),
            ) );
            $body[] = array( 'type' => 'separator' );

            foreach ( $rcv_item_rows as $ir ) { $body[] = $ir; }

            $body[] = array( 'type' => 'separator', 'margin' => 'md' );
            if ( $pending_inspect_count > 0 && ! $all_complete ) {
                $inspect_text = b2f_t(
                    "\xf0\x9f\x94\x8d " . $pending_inspect_count . ' รายการ ส่งมาแล้ว รอ DINOCO ตรวจรับ',
                    "\xf0\x9f\x94\x8d " . $pending_inspect_count . ' items shipped, pending DINOCO inspection',
                    "\xf0\x9f\x94\x8d " . $pending_inspect_count . '件已发货，等待DINOCO验收', $c);
                $body[] = array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'backgroundColor' => '#eff6ff', 'cornerRadius' => '6px', 'paddingAll' => '8px', 'contents' => array(
                    array( 'type' => 'text', 'text' => $inspect_text, 'size' => 'xs', 'color' => '#1e40af', 'wrap' => true ),
                ) );
            }
            if ( $all_complete ) {
                $body[] = array( 'type' => 'text', 'text' => b2f_t('✅ รับครบทุกรายการ', '✅ All items received', '✅ 全部已收', $c), 'size' => 'sm', 'weight' => 'bold', 'color' => '#16a34a', 'margin' => 'md' );
            } else {
                $remaining_text = b2f_t(
                    '📦 ' . $rcv_status_th . ' — ค้างอีก ' . $total_remaining . ' ชิ้น',
                    '📦 Partial — ' . $total_remaining . ' pcs remaining',
                    '📦 部分 — 剩余' . $total_remaining . '件', $c);
                $body[] = array( 'type' => 'text', 'text' => $remaining_text, 'size' => 'sm', 'weight' => 'bold', 'color' => $rcv_badge_color, 'margin' => 'md' );
                if ( $total_this_rej > 0 ) {
                    $rej_text = b2f_t(
                        '⚠️ reject ' . $total_this_rej . ' ชิ้น — Maker ต้องส่งทดแทน',
                        '⚠️ ' . $total_this_rej . ' pcs rejected — Maker must reship',
                        '⚠️ 拒收' . $total_this_rej . '件 — 供应商需补发', $c);
                    $body[] = array( 'type' => 'text', 'text' => $rej_text, 'size' => 'xs', 'color' => '#dc2626', 'margin' => 'sm' );
                } else {
                    $body[] = array( 'type' => 'text', 'text' => b2f_t('DINOCO รับทราบแล้ว รอตรวจรับสินค้าที่เหลือ', 'DINOCO acknowledged. Awaiting remaining goods.', 'DINOCO已确认，等待剩余货物。', $c), 'size' => 'xs', 'color' => '#64748b', 'margin' => 'sm' );
                }
            }
            if ( $total_rcv_value > 0 ) {
                $debt_text = b2f_t('💰 ยอดค้างจ่าย: ฿' . number_format( $total_rcv_value, 2 ), '💰 Outstanding (THB): ฿' . number_format( $total_rcv_value, 2 ), '💰 应付 (THB): ฿' . number_format( $total_rcv_value, 2 ), $c);
                $body[] = array( 'type' => 'text', 'text' => $debt_text, 'size' => 'xs', 'color' => '#d97706', 'margin' => 'sm' );
            }
            return $body;
        };

        // Build Maker Flex (ENG if != THB)
        $rcv_body_maker = $rcv_build_body( $cur );
        $rcv_title_maker = $all_complete
            ? b2f_t('✅ ตรวจรับสินค้า — รับครบ', '✅ Goods Received — Complete', '✅ 验收 — 全部', $cur)
            : b2f_t('📦 ตรวจรับสินค้า — รับบางส่วน', '📦 Goods Received — Partial', '📦 验收 — 部分', $cur);
        $rcv_alt_maker = b2f_t(
            '📦 ตรวจรับ ' . $po_number . ' — ' . $rcv_status_th,
            '📦 Received ' . $po_number . ' — ' . ( $all_complete ? 'Complete' : 'Partial' ),
            '📦 验收 ' . $po_number . ' — ' . ( $all_complete ? '全部' : '部分' ), $cur);
        $rcv_btn_maker = b2f_t('📋 ดูรายละเอียด PO', '📋 View PO Detail', '📋 查看详情', $cur);

        $rcv_header_color = $all_complete ? '#16a34a' : '#7c3aed';
        $rcv_header_maker = array( 'type' => 'box', 'layout' => 'horizontal', 'backgroundColor' => $rcv_header_color, 'paddingAll' => '14px', 'contents' => array(
            array( 'type' => 'image', 'url' => $logo, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
            array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                array( 'type' => 'text', 'text' => $rcv_title_maker, 'color' => '#ffffff', 'size' => 'sm', 'weight' => 'bold' ),
                array( 'type' => 'text', 'text' => $po_number . ' — ' . $rcv_number, 'color' => '#ddd6fe', 'size' => 'xxs' ),
            ) ),
        ) );
        $rcv_footer_maker = array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '12px', 'contents' => array(
            array( 'type' => 'button', 'style' => 'primary', 'height' => 'sm', 'color' => '#7c3aed',
                'action' => array( 'type' => 'uri', 'label' => $rcv_btn_maker, 'uri' => $detail_url ) ),
        ) );
        $rcv_flex_maker = array( 'type' => 'flex', 'altText' => $rcv_alt_maker,
            'contents' => array( 'type' => 'bubble', 'size' => 'mega', 'header' => $rcv_header_maker,
                'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'contents' => $rcv_body_maker ),
                'footer' => $rcv_footer_maker ) );

        // Build Admin Flex (always Thai)
        $rcv_body_admin = $rcv_build_body( 'th' );
        $rcv_title_admin = $all_complete ? '✅ ตรวจรับสินค้า — รับครบ' : '📦 ตรวจรับสินค้า — รับบางส่วน';
        $rcv_header_admin = array( 'type' => 'box', 'layout' => 'horizontal', 'backgroundColor' => $rcv_header_color, 'paddingAll' => '14px', 'contents' => array(
            array( 'type' => 'image', 'url' => $logo, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
            array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                array( 'type' => 'text', 'text' => $rcv_title_admin, 'color' => '#ffffff', 'size' => 'sm', 'weight' => 'bold' ),
                array( 'type' => 'text', 'text' => $po_number . ' — ' . $rcv_number, 'color' => '#ddd6fe', 'size' => 'xxs' ),
            ) ),
        ) );
        $rcv_footer_admin = array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '12px', 'contents' => array(
            array( 'type' => 'button', 'style' => 'primary', 'height' => 'sm', 'color' => '#7c3aed',
                'action' => array( 'type' => 'uri', 'label' => '📋 ดูรายละเอียด PO', 'uri' => $detail_url ) ),
        ) );
        $rcv_flex_admin = array( 'type' => 'flex', 'altText' => '📦 ตรวจรับ ' . $po_number . ' — ' . $rcv_status_th,
            'contents' => array( 'type' => 'bubble', 'size' => 'mega', 'header' => $rcv_header_admin,
                'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'contents' => $rcv_body_admin ),
                'footer' => $rcv_footer_admin ) );

        // Maker push (guaranteed) + log result
        $push_maker = false;
        $push_admin = false;
        if ( ! empty( $maker_group ) && function_exists( 'b2f_line_push' ) ) {
            if ( function_exists( 'b2f_push_guaranteed' ) ) {
                $push_maker = b2f_push_guaranteed( $maker_group, $rcv_flex_maker, $po_id, 'receive_maker' );
            } else {
                $push_maker = b2f_line_push( $maker_group, $rcv_flex_maker );
            }
            error_log( '[B2F RCV] Maker push to ' . $maker_group . ' = ' . ( $push_maker ? 'OK' : 'FAIL/QUEUED' ) );
        } else {
            error_log( '[B2F RCV] Maker push SKIP: group=' . var_export( $maker_group, true ) . ' fn=' . ( function_exists('b2f_line_push') ? 'yes' : 'no' ) );
        }
        // Admin push (guaranteed)
        if ( ! empty( $admin_group ) && function_exists( 'b2f_line_push' ) ) {
            if ( function_exists( 'b2f_push_guaranteed' ) ) {
                $push_admin = b2f_push_guaranteed( $admin_group, $rcv_flex_admin, $po_id, 'receive_admin' );
            } else {
                $push_admin = b2f_line_push( $admin_group, $rcv_flex_admin );
            }
            error_log( '[B2F RCV] Admin push to ' . $admin_group . ' = ' . ( $push_admin ? 'OK' : 'FAIL/QUEUED' ) );
        } else {
            error_log( '[B2F RCV] Admin push SKIP: group=' . var_export( $admin_group, true ) );
        }

        // V.5.5: QC Reject Flex push — ส่งแจ้ง Maker + Admin ถ้ามี reject items
        if ( $has_any_reject && function_exists( 'b2f_build_flex_qc_reject' ) ) {
            $qc_reject_items = array();
            foreach ( $rcv_items as $ri ) {
                $ri_rej = intval( $ri['rcvi_qty_rejected'] ?? 0 );
                if ( $ri_rej <= 0 ) continue;
                $ri_photo_ids  = $ri['rcvi_reject_photos'] ?? array();
                $ri_photo_urls = array();
                if ( is_array( $ri_photo_ids ) ) {
                    foreach ( $ri_photo_ids as $att_id ) {
                        $url = wp_get_attachment_url( $att_id );
                        if ( $url ) $ri_photo_urls[] = $url;
                    }
                }
                // Lookup product name from PO items
                $ri_name = $ri['rcvi_sku'] ?? '';
                foreach ( $po_items as $pi ) {
                    if ( ( $pi['poi_sku'] ?? '' ) === $ri_name ) { $ri_name = $pi['poi_product_name'] ?? $ri_name; break; }
                }
                $qc_reject_items[] = array(
                    'sku'        => $ri['rcvi_sku'] ?? '',
                    'name'       => $ri_name,
                    'reject_qty' => $ri_rej,
                    'reason'     => $ri['rcvi_reject_reason'] ?? '',
                    'photo_urls' => $ri_photo_urls,
                );
            }
            $qc_flex = b2f_build_flex_qc_reject( $po_id, $rcv_id, $qc_reject_items );
            if ( $qc_flex ) {
                if ( ! empty( $maker_group ) && function_exists( 'b2f_push_guaranteed' ) ) {
                    b2f_push_guaranteed( $maker_group, $qc_flex, $po_id, 'qc_reject_maker' );
                }
                if ( ! empty( $admin_group ) && function_exists( 'b2f_push_guaranteed' ) ) {
                    b2f_push_guaranteed( $admin_group, $qc_flex, $po_id, 'qc_reject_admin' );
                }
                error_log( '[B2F RCV] QC Reject Flex pushed: ' . count( $qc_reject_items ) . ' items' );
            }
        }

        // C3 FIX: ลบ dead code delete_transient — ใช้ MySQL GET_LOCK/RELEASE_LOCK แล้ว

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'Goods received: %s (#%d) rcv=%s status=%s debt=%.2f',
                $po_number, $po_id, $rcv_number, $new_status, $total_rcv_value
            ) );
        }

        // Release MySQL lock ก่อน return (CRIT-05 fix — dead code)
        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", 'b2f_recv_' . intval( $po_id ) ) );

        return new WP_REST_Response( array(
            'success'           => true,
            'rcv_id'            => $rcv_id,
            'rcv_number'        => esc_html( $rcv_number ),
            'po_status'         => $new_status,
            'inventory_updated' => ! empty( $inventory_updated ),
            'debt_added'        => $debt_added ? $total_rcv_value : 0,
            'has_reject'        => ! empty( $has_any_reject ),
            '_debug_push'       => array(
                'maker_group' => $maker_group ?: 'EMPTY',
                'admin_group' => $admin_group ?: 'EMPTY',
                'maker_push'  => $push_maker ? 'OK' : 'FAIL',
                'admin_push'  => $push_admin ? 'OK' : 'FAIL',
                'maker_id'    => $maker_id,
            ),
        ), 200 );
    }
}

