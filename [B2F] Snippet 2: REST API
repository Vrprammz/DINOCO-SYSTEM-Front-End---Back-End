if ( ! function_exists( 'b2f_rest_po_detail' ) ) {
    /**
     * GET /po-detail/{po_id} — PO detail (admin or maker JWT)
     */
    function b2f_rest_po_detail( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );

        // Auth: admin session OR maker JWT
        $is_admin = current_user_can( 'manage_options' );
        if ( ! $is_admin ) {
            $jwt = b2f_verify_maker_jwt( $req );
            if ( is_wp_error( $jwt ) ) {
                $status = 401;
                $data = $jwt->get_error_data();
                if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
                return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
            }
            // Verify PO belongs to maker
            if ( $jwt['po_id'] !== $po_id ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีสิทธิ์เข้าถึง PO นี้', 'code' => 'FORBIDDEN' ), 403 );
            }
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => b2f_format_po_detail( $po_id, $is_admin ),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_po_detail_jwt' ) ) {
    /**
     * GET /po-detail/jwt — PO detail by JWT token (Maker LIFF)
     * token มี po_id + maker_id → verify แล้วดึง PO detail
     */
    function b2f_rest_po_detail_jwt( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message() ), $status );
        }

        // B-07 fix: รับ po_id จาก JWT หรือ request param (Delivery Form ส่ง po_id แยก)
        $po_id = ! empty( $jwt['po_id'] ) ? intval( $jwt['po_id'] ) : intval( $req->get_param( 'po_id' ) ?: 0 );
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO' ), 404 );
        }

        // Verify PO belongs to maker
        $po_maker = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        if ( $po_maker !== intval( $jwt['maker_id'] ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'PO นี้ไม่ใช่ของโรงงานคุณ' ), 403 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => b2f_format_po_detail( $po_id, false ),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_format_po_detail' ) ) {
    /**
     * Format PO data for API response
     * @param int  $po_id
     * @param bool $include_sensitive  Include admin-only fields (payment, cancel info)
     * @return array
     */
    function b2f_format_po_detail( $po_id, $include_sensitive = false ) {
        $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $items    = get_field( 'po_items', $po_id ) ?: array();

        $formatted_items = array();
        foreach ( $items as $item ) {
            $sku  = esc_html( $item['poi_sku'] ?? '' );
            $name = esc_html( $item['poi_product_name'] ?? '' );
            $qo   = intval( $item['poi_qty_ordered'] ?? 0 );
            $uc   = floatval( $item['poi_unit_cost'] ?? 0 );
            $qs   = intval( $item['poi_qty_shipped'] ?? 0 );
            $qr   = intval( $item['poi_qty_received'] ?? 0 );
            $qj   = intval( $item['poi_qty_rejected'] ?? 0 );
            // V.4.9: ดึง image_url จาก DINOCO_Catalog
            $img  = '';
            if ( $sku && class_exists( 'DINOCO_Catalog' ) ) {
                $catalog_product = DINOCO_Catalog::get_by_sku( $item['poi_sku'] ?? '' );
                if ( $catalog_product && ! empty( $catalog_product['image_url'] ) ) {
                    $img = esc_url( $catalog_product['image_url'] );
                }
            }
            $formatted_items[] = array(
                // V.4.7: ส่งทั้ง short name + poi_ prefix เพื่อ compat กับ Maker LIFF + Admin
                'image_url' => $img, 'poi_image_url' => $img,
                'sku' => $sku, 'poi_sku' => $sku,
                'product_name' => $name, 'poi_product_name' => $name,
                'qty_ordered' => $qo, 'poi_qty_ordered' => $qo,
                'unit_cost' => $uc, 'poi_unit_cost' => $uc,
                'qty_shipped' => $qs, 'poi_qty_shipped' => $qs,
                'qty_received' => $qr, 'poi_qty_received' => $qr,
                'qty_rejected' => $qj, 'poi_qty_rejected' => $qj,
                'subtotal' => round( $uc * $qo, 2 ),
            );
        }

        $status_val = esc_html( get_field( 'po_status', $po_id ) ?: 'draft' );
        $total_val  = floatval( get_field( 'po_total_amount', $po_id ) ?: 0 );

        $data = array(
            'id'              => $po_id,
            'po_number'       => esc_html( get_field( 'po_number', $po_id ) ?: '' ),
            'maker_id'        => $maker_id,
            'maker_name'      => esc_html( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ),
            'status'          => $status_val,
            'po_status'       => $status_val,       // BUG-1 fix: alias สำหรับ Maker LIFF ที่ใช้ po_status
            'items'           => $formatted_items,
            'po_items'        => $formatted_items,   // BUG-2 fix: alias สำหรับ Maker LIFF ที่ใช้ po_items
            'total_amount'    => $total_val,
            'po_total_amount' => $total_val,         // alias
            'item_count'      => intval( get_field( 'po_item_count', $po_id ) ?: 0 ),
            'po_item_count'   => intval( get_field( 'po_item_count', $po_id ) ?: 0 ),
            'requested_date'     => esc_html( get_field( 'po_requested_date', $po_id ) ?: '' ),
            'po_requested_date'  => esc_html( get_field( 'po_requested_date', $po_id ) ?: '' ),
            'expected_date'      => esc_html( get_field( 'po_expected_date', $po_id ) ?: '' ),
            'po_expected_date'   => esc_html( get_field( 'po_expected_date', $po_id ) ?: '' ),
            'actual_date'        => esc_html( get_field( 'po_actual_date', $po_id ) ?: '' ),
            'po_actual_date'     => esc_html( get_field( 'po_actual_date', $po_id ) ?: '' ),
            'maker_note'         => esc_html( get_field( 'po_maker_note', $po_id ) ?: '' ),
            'po_maker_note'      => esc_html( get_field( 'po_maker_note', $po_id ) ?: '' ),
            'admin_note'         => esc_html( get_field( 'po_admin_note', $po_id ) ?: '' ),
            'po_admin_note'      => esc_html( get_field( 'po_admin_note', $po_id ) ?: '' ),
            'version'         => intval( get_field( 'po_version', $po_id ) ?: 1 ),
            'amendment_count' => intval( get_field( 'po_amendment_count', $po_id ) ?: 0 ),
            'created_date'    => get_the_date( 'Y-m-d H:i:s', $po_id ),
        );

        // Delivery records (ทุก role เห็นได้)
        $deliveries_raw = get_field( 'po_deliveries', $po_id ) ?: array();
        $data['deliveries'] = array();
        foreach ( $deliveries_raw as $dlv ) {
            $data['deliveries'][] = array(
                'number'      => esc_html( $dlv['dlv_number'] ?? '' ),
                'date'        => esc_html( $dlv['dlv_date'] ?? '' ),
                'items'       => json_decode( $dlv['dlv_items'] ?? '[]', true ) ?: array(),
                'note'        => esc_html( $dlv['dlv_note'] ?? '' ),
                'is_complete' => ! empty( $dlv['dlv_is_complete'] ),
            );
        }

        if ( $include_sensitive ) {
            $data['admin_note']       = esc_html( get_field( 'po_admin_note', $po_id ) ?: '' );
            $data['created_by']       = esc_html( get_field( 'po_created_by', $po_id ) ?: '' );
            $data['paid_amount']      = floatval( get_field( 'po_paid_amount', $po_id ) ?: 0 );
            $data['payment_status']   = esc_html( get_field( 'po_payment_status', $po_id ) ?: 'unpaid' );
            $data['cancelled_reason'] = esc_html( get_field( 'po_cancelled_reason', $po_id ) ?: '' );
            $data['cancelled_by']     = esc_html( get_field( 'po_cancelled_by', $po_id ) ?: '' );
            $data['cancelled_date']   = esc_html( get_field( 'po_cancelled_date', $po_id ) ?: '' );
            $data['rejected_reason']  = esc_html( get_field( 'po_rejected_reason', $po_id ) ?: '' );
        }

        return $data;
    }
}

if ( ! function_exists( 'b2f_rest_po_update' ) ) {
    /**
     * POST /po-update — แก้ไข PO (admin, ก่อน Maker confirm only)
     * Body: { po_id, items: [{ sku, qty }], note?, requested_date? }
     */
    function b2f_rest_po_update( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status  = get_field( 'po_status', $po_id );
        $resubmit_only   = ! empty( $req->get_param( 'resubmit_only' ) );

        // B-02 fix: Resubmit — ส่ง PO เดิมกลับ Maker โดยไม่แก้ไข items
        if ( $resubmit_only ) {
            if ( $current_status !== 'rejected' ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'ส่งใหม่ได้เฉพาะ PO ที่ถูกปฏิเสธ', 'code' => 'NOT_REJECTED' ), 400 );
            }
            if ( function_exists( 'b2f_transition_order' ) ) {
                $trans = b2f_transition_order( $po_id, 'submitted', 'admin', 'Resubmit without changes' );
                if ( is_wp_error( $trans ) ) {
                    return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
                }
            } else {
                update_field( 'po_status', 'submitted', $po_id );
            }

            // Push Flex resubmitted ไป Maker
            $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
            $maker_group = $maker_id ? get_field( 'maker_line_group_id', $maker_id ) : '';
            if ( function_exists( 'b2f_build_flex_po_resubmitted' ) && ! empty( $maker_group ) ) {
                $flex = b2f_build_flex_po_resubmitted( $po_id );
                if ( $flex ) b2f_line_push( $maker_group, array( $flex ) );
            }

            $po_number = get_field( 'po_number', $po_id ) ?: '';
            if ( function_exists( 'b2f_log' ) ) b2f_log( "PO resubmitted: {$po_number} (#{$po_id})" );

            return new WP_REST_Response( array( 'success' => true, 'po_id' => $po_id, 'status' => 'submitted', 'po_number' => $po_number ), 200 );
        }

        // Only allow amend in these statuses
        $amendable = array( 'submitted', 'confirmed', 'rejected' );
        if ( ! in_array( $current_status, $amendable, true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่สามารถแก้ไข PO ในสถานะนี้', 'code' => 'NOT_AMENDABLE' ), 400 );
        }

        $items = $req->get_param( 'items' );
        if ( empty( $items ) || ! is_array( $items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุรายการสินค้า', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Rebuild items with fresh cost snapshot
        $po_items = array();
        $total    = 0;

        foreach ( $items as $item ) {
            $sku = sanitize_text_field( $item['sku'] ?? '' );
            $qty = intval( $item['qty'] ?? 0 );
            if ( empty( $sku ) || $qty <= 0 ) continue;

            $mp = new WP_Query( array(
                'post_type'      => 'b2f_maker_product',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array(
                    'relation' => 'AND',
                    array( 'key' => 'mp_maker_id', 'value' => $maker_id, 'type' => 'NUMERIC' ),
                    array( 'key' => 'mp_product_sku', 'value' => $sku ),
                ),
            ) );

            if ( ! $mp->have_posts() ) {
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'ไม่พบ SKU "%s" สำหรับโรงงานนี้', esc_html( $sku ) ),
                    'code'    => 'INVALID_SKU',
                ), 400 );
            }

            $mp_post      = $mp->posts[0];
            $unit_cost    = floatval( get_field( 'mp_unit_cost', $mp_post->ID ) ?: 0 );
            $product_name = get_field( 'mp_product_name', $mp_post->ID ) ?: $sku;
            $subtotal     = round( $unit_cost * $qty, 2 );

            $po_items[] = array(
                'poi_sku'          => $sku,
                'poi_product_name' => $product_name,
                'poi_qty_ordered'  => $qty,
                'poi_unit_cost'    => $unit_cost,
                'poi_qty_received' => 0,
                'poi_qty_rejected' => 0,
            );
            $total += $subtotal;
        }

        if ( empty( $po_items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีรายการสินค้าที่ถูกต้อง', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        // Update fields
        update_field( 'po_items', $po_items, $po_id );
        update_field( 'po_total_amount', round( $total, 2 ), $po_id );
        update_field( 'po_item_count', count( $po_items ), $po_id );

        $amend_count = intval( get_field( 'po_amendment_count', $po_id ) ?: 0 ) + 1;
        $version     = intval( get_field( 'po_version', $po_id ) ?: 1 ) + 1;
        update_field( 'po_amendment_count', $amend_count, $po_id );
        update_field( 'po_version', $version, $po_id );

        $note = $req->get_param( 'note' );
        if ( $note !== null ) {
            update_field( 'po_admin_note', sanitize_textarea_field( $note ), $po_id );
        }
        $req_date = $req->get_param( 'requested_date' );
        if ( $req_date !== null ) {
            update_field( 'po_requested_date', sanitize_text_field( $req_date ), $po_id );
        }

        // Transition: current -> amended -> auto-resubmit
        if ( function_exists( 'b2f_transition_order' ) ) {
            b2f_transition_order( $po_id, 'amended', 'admin', 'PO amended (version ' . $version . ')' );
            b2f_transition_order( $po_id, 'submitted', 'system', 'auto-resubmit after amend' );
        } else {
            update_field( 'po_status', 'submitted', $po_id );
        }

        // Push Flex to Maker
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        if ( function_exists( 'b2f_build_flex_po_amended' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_po_amended( $po_id, $amend_count );
            if ( $flex ) b2f_line_push( $maker_group, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'PO amended: %s (#%d) version=%d total=%.2f', $po_number, $po_id, $version, $total ) );
        }

        return new WP_REST_Response( array(
            'success'      => true,
            'po_id'        => $po_id,
            'version'      => $version,
            'total_amount' => round( $total, 2 ),
            'status'       => 'submitted',
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_po_cancel' ) ) {
    /**
     * POST /po-cancel — ยกเลิก PO (admin) + rollback ถ้า partial received
     * Body: { po_id, reason }
     */
    function b2f_rest_po_cancel( WP_REST_Request $req ) {
        $po_id  = intval( $req->get_param( 'po_id' ) ?: 0 );
        $reason = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );
        $maker_id       = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Transition
        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'cancelled', 'admin', $reason );
            if ( is_wp_error( $trans ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
            }
        } else {
            update_field( 'po_status', 'cancelled', $po_id );
        }

        // Save cancel metadata
        update_field( 'po_cancelled_reason', $reason, $po_id );
        update_field( 'po_cancelled_by', strval( get_current_user_id() ), $po_id );
        update_field( 'po_cancelled_date', wp_date( 'Y-m-d' ), $po_id );

        // Rollback credit — recalculate จาก data จริง (CRIT-02 fix)
        // ใช้ recalculate แทน manual subtract — ถูกต้องทุก status ไม่ว่า cancel จาก submitted/confirmed/partial_received
        $rollback_info = array();
        $old_debt = floatval( get_field( 'maker_current_debt', $maker_id ) ?: 0 );
        if ( function_exists( 'b2f_recalculate_payable' ) && $maker_id > 0 ) {
            $new_debt = b2f_recalculate_payable( $maker_id );
            $reversed = round( $old_debt - $new_debt, 2 );
            if ( $reversed > 0 ) {
                $rollback_info['debt_reversed'] = $reversed;
                $rollback_info['old_debt']      = $old_debt;
                $rollback_info['new_debt']      = $new_debt;
            }
        }

        // Push cancel notification ทั้ง Maker + Admin group (พร้อม fallback text)
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        $po_number   = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;
        $cancelled_by = 'Admin';
        $uid = get_current_user_id();
        if ( $uid ) { $u = get_user_by( 'id', $uid ); if ( $u ) $cancelled_by = $u->display_name; }

        // → สร้าง Flex cancel inline (ไม่พึ่ง Snippet 1 function_exists)
        $maker_name_str = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: '' ) : '';
        $total_str      = number_format( floatval( get_field( 'po_total_amount', $po_id ) ?: 0 ), 0 );
        $item_count_str = intval( get_field( 'po_item_count', $po_id ) ?: 0 ) . ' SKU';

        $cancel_body = array(
            array( 'type' => 'box', 'layout' => 'horizontal', 'contents' => array(
                array( 'type' => 'text', 'text' => 'เลขที่ PO', 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => $po_number, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end' ) ) ),
            array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'sm', 'contents' => array(
                array( 'type' => 'text', 'text' => 'โรงงาน', 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => $maker_name_str, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end', 'wrap' => true ) ) ),
            array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'sm', 'contents' => array(
                array( 'type' => 'text', 'text' => 'ยอดรวม', 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => '฿' . $total_str, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end' ) ) ),
            array( 'type' => 'separator', 'margin' => 'md' ),
        );
        if ( ! empty( $reason ) ) {
            $cancel_body[] = array( 'type' => 'text', 'text' => 'เหตุผล: ' . mb_substr( $reason, 0, 80 ), 'size' => 'sm', 'color' => '#dc2626', 'wrap' => true, 'margin' => 'md' );
        }

        $logo_url = 'https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png';

        // Flex Maker
        $flex_maker = array( 'type' => 'flex', 'altText' => '❌ ยกเลิก PO ' . $po_number,
            'contents' => array( 'type' => 'bubble', 'size' => 'mega',
                'header' => array( 'type' => 'box', 'layout' => 'vertical', 'backgroundColor' => '#0a0a0a', 'paddingAll' => '16px',
                    'contents' => array( array( 'type' => 'box', 'layout' => 'horizontal', 'alignItems' => 'center', 'contents' => array(
                        array( 'type' => 'image', 'url' => $logo_url, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                        array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                            array( 'type' => 'text', 'text' => '❌ DINOCO ยกเลิก PO', 'weight' => 'bold', 'color' => '#ffffff', 'size' => 'md' ),
                            array( 'type' => 'text', 'text' => $po_number, 'color' => '#f87171', 'size' => 'xs', 'margin' => 'xs' ) ) ) ) ) ) ),
                'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $cancel_body ) ) );

        // Flex Admin (เพิ่ม "โดย")
        $admin_body = $cancel_body;
        $admin_body[] = array( 'type' => 'text', 'text' => 'ยกเลิกโดย: ' . $cancelled_by, 'size' => 'xs', 'color' => '#94a3b8', 'margin' => 'sm' );
        $flex_admin = array( 'type' => 'flex', 'altText' => '❌ ยกเลิก PO ' . $po_number,
            'contents' => array( 'type' => 'bubble', 'size' => 'mega',
                'header' => array( 'type' => 'box', 'layout' => 'vertical', 'backgroundColor' => '#0a0a0a', 'paddingAll' => '16px',
                    'contents' => array( array( 'type' => 'box', 'layout' => 'horizontal', 'alignItems' => 'center', 'contents' => array(
                        array( 'type' => 'image', 'url' => $logo_url, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                        array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                            array( 'type' => 'text', 'text' => '❌ ยกเลิก PO', 'weight' => 'bold', 'color' => '#ffffff', 'size' => 'md' ),
                            array( 'type' => 'text', 'text' => $po_number, 'color' => '#f87171', 'size' => 'xs', 'margin' => 'xs' ) ) ) ) ) ) ),
                'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $admin_body ) ) );

        // → Push
        $push_maker = false;
        $push_admin = false;
        if ( ! empty( $maker_group ) && function_exists( 'b2f_line_push' ) ) {
            $push_maker = b2f_line_push( $maker_group, array( $flex_maker ) );
        }
        if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
            $push_admin = b2f_line_push( B2B_ADMIN_GROUP_ID, array( $flex_admin ) );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'PO cancelled: %s (#%d) reason=%s rollback=%s',
                $po_number, $po_id, $reason, wp_json_encode( $rollback_info )
            ) );
        }

        $resp = array(
            'success' => true, 'po_id' => $po_id, 'status' => 'cancelled',
            'push_maker' => $push_maker ? 'sent' : ( empty( $maker_group ) ? 'no_group' : 'failed' ),
            'push_admin' => $push_admin ? 'sent' : ( ! defined( 'B2B_ADMIN_GROUP_ID' ) ? 'no_config' : 'failed' ),
            'line_push_available' => function_exists( 'b2f_line_push' ) ? 'yes' : 'NO — Snippet 1 not loaded!',
        );
        if ( ! empty( $rollback_info ) ) {
            $resp['rollback'] = $rollback_info;
        }

        return new WP_REST_Response( $resp, 200 );
    }
}

