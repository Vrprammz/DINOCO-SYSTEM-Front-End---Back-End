if ( ! function_exists( 'b2f_rest_create_po' ) ) {
    /**
     * POST /create-po
     * Body: { maker_id, items: [{ sku, qty }], requested_date?, note?, force? }
     *
     * Response: { success, po_id, po_number, total_amount, items, warnings? }
     * Error codes: CREDIT_HOLD, DUPLICATE_PO, INVALID_MAKER, INVALID_SKU, MISSING_ITEMS
     */
    function b2f_rest_create_po( WP_REST_Request $req ) {
        // Rate limit: 10 req/min per admin
        $user_id = get_current_user_id();
        $rl = b2f_rate_limit( 'create_po_' . $user_id, 10, 60 );
        if ( is_wp_error( $rl ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $rl->get_error_message(), 'code' => 'RATE_LIMIT' ), 429 );
        }

        $maker_id = intval( $req->get_param( 'maker_id' ) ?: 0 );
        $items    = $req->get_param( 'items' );
        $note     = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );
        $req_date = sanitize_text_field( $req->get_param( 'requested_date' ) ?: '' );

        // ── Validate maker ──
        if ( ! $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาเลือกโรงงาน', 'code' => 'INVALID_MAKER' ), 400 );
        }
        $maker = get_post( $maker_id );
        if ( ! $maker || $maker->post_type !== 'b2f_maker' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบโรงงาน', 'code' => 'INVALID_MAKER' ), 404 );
        }
        $maker_status = get_field( 'maker_status', $maker_id );
        if ( $maker_status === 'inactive' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'โรงงานนี้ถูกปิดใช้งาน', 'code' => 'INVALID_MAKER' ), 400 );
        }

        // ── Check credit ──
        if ( function_exists( 'b2f_check_credit' ) ) {
            $credit = b2f_check_credit( $maker_id );
            if ( is_wp_error( $credit ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $credit->get_error_message(), 'code' => 'CREDIT_HOLD' ), 400 );
            }
        }

        // ── Multi-Currency: read maker currency + validate exchange_rate + shipping_method ──
        $currency      = get_field( 'maker_currency', $maker_id ) ?: 'THB';
        $exchange_rate  = floatval( $req->get_param( 'exchange_rate' ) ?: 1 );
        $shipping_method = sanitize_text_field( $req->get_param( 'shipping_method' ) ?: '' );

        // THB ต้อง = 1 เสมอ
        if ( $currency === 'THB' ) $exchange_rate = 1.0;

        // Validate range
        if ( $exchange_rate <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'อัตราแลกเปลี่ยนต้องมากกว่า 0', 'code' => 'INVALID_RATE' ), 400 );
        }
        $rate_ranges = array( 'THB' => array( 1, 1 ), 'CNY' => array( 2, 10 ), 'USD' => array( 25, 50 ) );
        if ( isset( $rate_ranges[ $currency ] ) ) {
            if ( $exchange_rate < $rate_ranges[ $currency ][0] || $exchange_rate > $rate_ranges[ $currency ][1] ) {
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'RATE_OUT_OF_RANGE: %s rate must be %s-%s', $currency, $rate_ranges[ $currency ][0], $rate_ranges[ $currency ][1] ),
                    'code'    => 'RATE_OUT_OF_RANGE',
                ), 400 );
            }
        }

        // ≠ THB ต้องเลือกวิธีส่ง
        if ( $currency !== 'THB' && ! in_array( $shipping_method, array( 'land', 'sea' ), true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'โรงงานต่างประเทศต้องเลือกวิธีส่ง (land/sea)', 'code' => 'SHIPPING_METHOD_REQUIRED' ), 400 );
        }

        // ── Validate items ──
        if ( empty( $items ) || ! is_array( $items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาเลือกสินค้าอย่างน้อย 1 รายการ', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        // V.11.0 — order_mode validator (7 rules, flag-gated by `b2f_flag_order_intent`)
        //   Flag OFF → ignore `order_mode` param (V.10.5 behavior). Flag ON → strict validation.
        //   Rule order matters: enum (fail fast) → production_mode match → source_sku check.
        $flag_order_intent = function_exists( 'b2f_is_flag_enabled' )
            && b2f_is_flag_enabled( 'b2f_flag_order_intent' );

        // Enum registry for order_mode (match Snippet 1 V.7.0 helper `b2f_order_mode_label`)
        $enum_order_mode = array( 'full_set', 'sub_unit', 'single_leaf' );
        // Production mode → order_mode compatibility matrix
        $mode_compat = array(
            'full_set'    => array( 'set_assembled', 'cross_factory_assembly' ),
            'sub_unit'    => array( 'sub_unit' ),
            'single_leaf' => array( 'single' ),
        );

        // Merge duplicate SKUs (V.10.5: key=$sku / V.11.0: key=$sku|$order_mode|$source_sku)
        // DD-3: same SKU with different modes should NOT merge (preserves admin intent per item).
        $merged = array();
        foreach ( $items as $item ) {
            if ( ! is_array( $item ) ) continue;
            $sku = sanitize_text_field( $item['sku'] ?? '' );
            $qty = intval( $item['qty'] ?? 0 );
            if ( empty( $sku ) || $qty <= 0 ) continue;

            // V.11.0 — order_mode extraction + validation (flag-gated)
            $order_mode = '';
            $source_sku = '';
            $intent_notes = '';
            $prod_mode_snapshot = '';

            if ( $flag_order_intent ) {
                $raw_order_mode = sanitize_text_field( $item['order_mode'] ?? '' );
                $source_sku = sanitize_text_field( $item['source_sku'] ?? $sku );

                // V.11.6 BUG-H7: normalize cross-axis input. Callers may send either
                // order_mode (full_set|sub_unit|single_leaf) OR production_mode
                // (set_assembled|sub_unit|single|cross_factory_assembly). Snippet 1 V.7.5
                // `b2f_normalize_order_mode()` collapses both to order_mode axis
                // (set_assembled/cross_factory_assembly → full_set; single → single_leaf).
                // Unknown string → null → rule 1 reject.
                $order_mode = function_exists( 'b2f_normalize_order_mode' )
                    ? b2f_normalize_order_mode( $raw_order_mode )
                    : ( in_array( $raw_order_mode, $enum_order_mode, true ) ? $raw_order_mode : null );

                // Rule 1: strict enum match (in_array with type-check)
                if ( $order_mode === null || $order_mode === '' || ! in_array( $order_mode, $enum_order_mode, true ) ) {
                    return new WP_REST_Response( array(
                        'success' => false,
                        'error'   => sprintf( 'order_mode ไม่ถูกต้อง "%s" (ต้องเป็น full_set|sub_unit|single_leaf)', esc_html( $raw_order_mode ) ),
                        'code'    => defined( 'B2F_ERR_INVALID_ORDER_MODE' ) ? B2F_ERR_INVALID_ORDER_MODE : 'invalid_order_mode',
                        'sku'     => $sku,
                    ), 400 );
                }

                // Rules 2/3/4: order_mode compatibility with production_mode
                //   Lookup production_mode from junction (v11 flag check inside helper).
                //   NULL = junction row missing or v11 flag off → fallback to sku_relations inference.
                $prod_mode_snapshot = '';
                if ( function_exists( 'b2f_get_production_mode' ) ) {
                    $prod_mode_snapshot = (string) b2f_get_production_mode( $sku, $maker_id );
                }
                if ( $prod_mode_snapshot === '' || $prod_mode_snapshot === null ) {
                    // Fallback: infer from sku_relations (mirror Phase 4 logic)
                    if ( function_exists( 'b2f_infer_production_mode_from_relations' ) ) {
                        $prod_mode_snapshot = b2f_infer_production_mode_from_relations( $sku, $maker_id );
                    } else {
                        $prod_mode_snapshot = 'single';
                    }
                }

                $allowed_pmodes = isset( $mode_compat[ $order_mode ] ) ? $mode_compat[ $order_mode ] : array();
                if ( ! in_array( $prod_mode_snapshot, $allowed_pmodes, true ) ) {
                    return new WP_REST_Response( array(
                        'success' => false,
                        'error'   => sprintf(
                            'order_mode "%s" ใช้กับ SKU ที่ production_mode="%s" ไม่ได้ (ต้องเป็น %s)',
                            esc_html( $order_mode ),
                            esc_html( $prod_mode_snapshot ),
                            esc_html( implode( '|', $allowed_pmodes ) )
                        ),
                        'code'             => defined( 'B2F_ERR_INVALID_ORDER_MODE' ) ? B2F_ERR_INVALID_ORDER_MODE : 'invalid_order_mode',
                        'sku'              => $sku,
                        'production_mode'  => $prod_mode_snapshot,
                        'requested_mode'   => $order_mode,
                    ), 400 );
                }

                // Rule 5: source_sku must be in ancestor chain of $sku
                //   For full_set click → source_sku = SET SKU itself (ancestor via short-circuit in helper)
                //   For single_leaf click → source_sku = leaf SKU == $sku (short-circuit)
                //   For sub_unit click → source_sku = intermediate SET == $sku OR its parent
                if ( $source_sku !== '' && function_exists( 'b2f_validate_source_sku_in_ancestors' ) ) {
                    $ancestor_check = b2f_validate_source_sku_in_ancestors( $sku, $source_sku );
                    if ( is_wp_error( $ancestor_check ) ) {
                        return new WP_REST_Response( array(
                            'success'    => false,
                            'error'      => $ancestor_check->get_error_message(),
                            'code'       => $ancestor_check->get_error_code(),
                            'sku'        => $sku,
                            'source_sku' => $source_sku,
                        ), 400 );
                    }
                }

                // Rule 6: sanitize intent_notes + 200-char cap (MED-4 XSS handled via
                // sanitize_textarea_field here + frontend textContent render)
                $raw_notes = (string) ( $item['intent_notes'] ?? '' );
                if ( $raw_notes !== '' ) {
                    $intent_notes = sanitize_textarea_field( $raw_notes );
                    $intent_notes = function_exists( 'mb_substr' )
                        ? mb_substr( $intent_notes, 0, 200 )
                        : substr( $intent_notes, 0, 200 );
                }
            }

            // V.11.0 — composite merge key: sku|order_mode|source_sku
            //   Same SKU with different modes remain separate items (preserves intent per spec).
            //   Legacy path (flag OFF) → key = sku only (V.10.5 behavior).
            $merge_key = $flag_order_intent
                ? ( $sku . '|' . $order_mode . '|' . $source_sku )
                : $sku;

            if ( isset( $merged[ $merge_key ] ) ) {
                $merged[ $merge_key ]['qty'] += $qty;
                // Preserve first non-empty intent_notes; don't overwrite
                if ( empty( $merged[ $merge_key ]['intent_notes'] ) && ! empty( $intent_notes ) ) {
                    $merged[ $merge_key ]['intent_notes'] = $intent_notes;
                }
            } else {
                $merged[ $merge_key ] = array(
                    'sku'                       => $sku,
                    'qty'                       => $qty,
                    'order_mode'                => $order_mode,
                    'source_sku'                => $source_sku,
                    'intent_notes'              => $intent_notes,
                    'production_mode_snapshot'  => $prod_mode_snapshot,
                );
            }
        }

        if ( empty( $merged ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาเลือกสินค้าอย่างน้อย 1 รายการ (จำนวนต้องมากกว่า 0)', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        // ── DD-7: Auto-expand SET/non-leaf SKUs → leaf items + track SET origin (V.8.7 Hierarchy) ──
        // V.10.3 Issue #1: also track intermediate parent chain via `parent_path` per breakdown
        //   parent_path = "TOP_SKU/MID_SKU" (3-level) หรือ "TOP_SKU" (2-level) หรือ "" (standalone leaf)
        //   stored per breakdown entry (DD-3 safe: shared leaf can have different paths per occurrence)
        //   top-level repeater field poi_parent_path = first breakdown path (matches poi_parent_sku convention)
        if ( function_exists( 'dinoco_get_leaf_skus' ) && function_exists( 'dinoco_is_leaf_sku' ) ) {
            $expanded = array();
            foreach ( $merged as $merge_k => $item ) {
                $sku = $item['sku'];
                $qty = $item['qty'];
                // V.11.0 — propagate per-item intent fields to breakdown + repeater snapshot
                $it_order_mode   = isset( $item['order_mode'] ) ? (string) $item['order_mode'] : '';
                $it_source_sku   = isset( $item['source_sku'] ) ? (string) $item['source_sku'] : '';
                $it_intent_notes = isset( $item['intent_notes'] ) ? (string) $item['intent_notes'] : '';
                $it_prod_snap    = isset( $item['production_mode_snapshot'] ) ? (string) $item['production_mode_snapshot'] : '';

                if ( dinoco_is_leaf_sku( $sku ) ) {
                    // Leaf SKU → keep as-is (ordered standalone, no SET parent)
                    // V.11.0: composite key preserves mode/source — use $merge_k instead of $sku
                    $exp_key = $merge_k;
                    if ( isset( $expanded[ $exp_key ] ) ) {
                        $expanded[ $exp_key ]['qty'] += $qty;
                        // V.9.9 DD-3 + V.11.0: breakdown entry with order_mode for standalone
                        $expanded[ $exp_key ]['breakdown'][] = array(
                            'parent_sku'  => '__standalone__',
                            'parent_name' => '',
                            'parent_path' => '',
                            'order_mode'  => $it_order_mode, // V.11.0
                            'qty'         => $qty,
                        );
                    } else {
                        $expanded[ $exp_key ] = array(
                            'sku'                        => $sku,
                            'qty'                        => $qty,
                            'parent_sku'                 => '',
                            'parent_name'                => '',
                            'parent_path'                => '',
                            'order_mode'                 => $it_order_mode,          // V.11.0
                            'source_sku'                 => $it_source_sku,          // V.11.0
                            'intent_notes'               => $it_intent_notes,        // V.11.0
                            'production_mode_snapshot'   => $it_prod_snap,           // V.11.0
                            'breakdown'                  => array( array(
                                'parent_sku'  => '__standalone__',
                                'parent_name' => '',
                                'parent_path' => '',
                                'order_mode'  => $it_order_mode,
                                'qty'         => $qty,
                            ) ),
                        );
                    }
                } else {
                    // SET/non-leaf → expand to leaf SKUs
                    $leaves = dinoco_get_leaf_skus( $sku );
                    if ( empty( $leaves ) ) {
                        return new WP_REST_Response( array(
                            'success' => false,
                            'error'   => sprintf( 'SET SKU "%s" ไม่มี leaf items', esc_html( $sku ) ),
                            'code'    => 'EMPTY_SET',
                        ), 400 );
                    }

                    // V.8.7: Resolve SET parent name for hierarchy display
                    $set_parent_name = $sku; // fallback = SKU
                    if ( class_exists( 'DINOCO_Catalog' ) ) {
                        $set_cat = DINOCO_Catalog::get_by_sku( $sku );
                        if ( $set_cat && ! empty( $set_cat['product_name'] ) ) {
                            $set_parent_name = $set_cat['product_name'];
                        }
                    }

                    // V.10.3 Issue #1: for each leaf, compute intermediate parent chain within THIS SET
                    //   walk ancestors from leaf upward → include only ancestors that are descendants of (or equal to) the ordered SET
                    //   if leaf is direct child of ordered SET → path = "SET"
                    //   if leaf has intermediate parent(s) under SET → path = "SET/MID1/MID2..."
                    $ordered_sku_u = strtoupper( $sku );
                    $leaf_path_map = array(); // leaf_sku_upper => path string
                    if ( function_exists( 'dinoco_get_ancestor_skus' ) ) {
                        foreach ( $leaves as $leaf_sku ) {
                            $leaf_u = strtoupper( $leaf_sku );
                            $ancestors = dinoco_get_ancestor_skus( $leaf_sku ); // [direct_parent, grandparent, ...]
                            // Build path from top → bottom (top = ordered SET, then intermediates down to immediate parent)
                            // Filter ancestors: keep only those between leaf and ordered SET (inclusive of SET at top)
                            $chain = array();
                            foreach ( $ancestors as $anc_u ) {
                                $chain[] = $anc_u;
                                if ( $anc_u === $ordered_sku_u ) break;
                            }
                            // Reverse: top → direct parent
                            $chain = array_reverse( $chain );
                            // Safety: if ordered SET not found in ancestors → fallback to just ordered SET (defensive)
                            if ( empty( $chain ) || $chain[0] !== $ordered_sku_u ) {
                                $chain = array( $ordered_sku_u );
                            }
                            // For path string, drop immediate-parent-only 2-level SETs → keep full chain joined
                            $leaf_path_map[ $leaf_u ] = implode( '/', $chain );
                        }
                    } else {
                        // Fallback: no ancestor helper → path = just ordered SET
                        foreach ( $leaves as $leaf_sku ) {
                            $leaf_path_map[ strtoupper( $leaf_sku ) ] = $ordered_sku_u;
                        }
                    }

                    foreach ( $leaves as $leaf_sku ) {
                        // V.10.0: Validate via flag-gated helper (junction when flag ON, CPT otherwise)
                        $leaf_mp = b2f_read_maker_product( $leaf_sku, $maker_id );

                        if ( empty( $leaf_mp ) ) {
                            return new WP_REST_Response( array(
                                'success' => false,
                                'error'   => sprintf( 'สินค้า %s (จาก SET %s) ยังไม่ได้ลงทะเบียนกับโรงงาน', esc_html( $leaf_sku ), esc_html( $sku ) ),
                                'code'    => 'INVALID_LEAF_SKU',
                            ), 400 );
                        }

                        $leaf_u = strtoupper( $leaf_sku );
                        $parent_path = isset( $leaf_path_map[ $leaf_u ] ) ? $leaf_path_map[ $leaf_u ] : $ordered_sku_u;

                        // V.11.0 — composite key prevents merge when same leaf expanded from
                        //   different SETs OR same SET ordered with different modes (DD-3 + intent).
                        //   Legacy key = $leaf_sku (V.10.5 behavior preserved when flag OFF).
                        $exp_key = $flag_order_intent
                            ? ( $leaf_sku . '|' . $it_order_mode . '|' . $sku )
                            : $leaf_sku;

                        // V.9.9 DD-3: ทุก leaf ได้ qty เท่ากับ SET qty ต้นทาง + collect breakdown
                        // V.10.3: include parent_path per breakdown entry
                        // V.11.0: include order_mode per breakdown entry (shared leaf intent tracking)
                        if ( isset( $expanded[ $exp_key ] ) ) {
                            $expanded[ $exp_key ]['qty'] += $qty;
                            $expanded[ $exp_key ]['breakdown'][] = array(
                                'parent_sku'  => $sku,
                                'parent_name' => $set_parent_name,
                                'parent_path' => $parent_path,
                                'order_mode'  => $it_order_mode, // V.11.0
                                'qty'         => $qty,
                            );
                        } else {
                            $expanded[ $exp_key ] = array(
                                'sku'                        => $leaf_sku,
                                'qty'                        => $qty,
                                'parent_sku'                 => $sku,
                                'parent_name'                => $set_parent_name,
                                'parent_path'                => $parent_path,
                                'order_mode'                 => $it_order_mode,    // V.11.0
                                'source_sku'                 => $it_source_sku,    // V.11.0
                                'intent_notes'               => $it_intent_notes,  // V.11.0
                                'production_mode_snapshot'   => $it_prod_snap,     // V.11.0
                                'breakdown'                  => array( array(
                                    'parent_sku'  => $sku,
                                    'parent_name' => $set_parent_name,
                                    'parent_path' => $parent_path,
                                    'order_mode'  => $it_order_mode,
                                    'qty'         => $qty,
                                ) ),
                            );
                        }
                    }

                    if ( function_exists( 'b2f_log' ) ) {
                        b2f_log( sprintf( 'DD-7: SET %s (%s) expanded → %s (qty=%d)', $sku, $set_parent_name, implode( ', ', $leaves ), $qty ) );
                    }
                }
            }
            $merged = $expanded;
        }

        // ── Snapshot ราคาทุนจาก maker-product (V.10.0: junction OR CPT via helper) ──
        $po_items = array();
        $total    = 0;

        foreach ( $merged as $item ) {
            $sku = $item['sku'];
            $qty = $item['qty'];

            // V.10.0: Flag-gated read (junction when ON, CPT fallback otherwise)
            $mp_data = b2f_read_maker_product( $sku, $maker_id );

            if ( empty( $mp_data ) ) {
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'ไม่พบ SKU "%s" สำหรับโรงงานนี้', esc_html( $sku ) ),
                    'code'    => 'INVALID_SKU',
                ), 400 );
            }

            $mp_post_id   = intval( $mp_data['legacy_cpt_id'] ?? 0 );
            $unit_cost    = floatval( $mp_data['unit_cost'] ?? 0 );
            // Prefer CPT mp_product_name (ACF-only field — junction ไม่มี column)
            $product_name = '';
            if ( $mp_post_id ) {
                $product_name = (string) ( get_field( 'mp_product_name', $mp_post_id ) ?: '' );
            }
            if ( $product_name === '' ) {
                // Fallback: catalog name → raw SKU
                if ( class_exists( 'DINOCO_Catalog' ) ) {
                    $cat_row = DINOCO_Catalog::get_by_sku( $sku );
                    if ( $cat_row && ! empty( $cat_row['name'] ) ) $product_name = (string) $cat_row['name'];
                }
                if ( $product_name === '' ) $product_name = $sku;
            }
            $subtotal = round( $unit_cost * $qty, 2 );

            $po_items[] = array(
                'sku'          => $sku,
                'product_name' => $product_name,
                'qty'          => $qty,
                'unit_cost'    => $unit_cost,
                'subtotal'     => $subtotal,
                'mp_post_id'   => $mp_post_id,
                // V.10.0: snapshot shipping from helper (junction/CPT unified)
                'shipping_land' => floatval( $mp_data['shipping_land'] ?? 0 ),
                'shipping_sea'  => floatval( $mp_data['shipping_sea'] ?? 0 ),
                // V.8.7 Hierarchy: SET origin tracking
                'parent_sku'   => $item['parent_sku'] ?? '',
                // V.9.9 DD-3: breakdown[] for shared child tracking
                'breakdown'    => $item['breakdown'] ?? array(),
                'parent_name'  => $item['parent_name'] ?? '',
                // V.10.3 Issue #1: intermediate parent chain (top/mid — empty for standalone)
                'parent_path'  => $item['parent_path'] ?? '',
                // V.11.0 Order Intent fields (admin-only PII for intent_notes)
                'order_mode'                => $item['order_mode'] ?? '',
                'source_sku'                => $item['source_sku'] ?? '',
                'intent_notes'              => $item['intent_notes'] ?? '',
                'production_mode_snapshot'  => $item['production_mode_snapshot'] ?? '',
            );
            $total += $subtotal;

            // Update last order date on maker product (CPT-only field, ACF)
            if ( $mp_post_id ) {
                update_field( 'mp_last_order_date', wp_date( 'Y-m-d' ), $mp_post_id );
            }
        }

        // ── Duplicate check (same maker + SKUs + qty ภายใน 5 นาที) ──
        $dup_key = 'b2f_dup_' . $maker_id . '_' . md5( wp_json_encode( $merged ) );
        $dup_existing = get_transient( $dup_key );
        if ( $dup_existing ) {
            $force = $req->get_param( 'force' );
            if ( ! $force ) {
                return new WP_REST_Response( array(
                    'success'     => false,
                    'error'       => 'มี PO ที่เหมือนกันภายใน 5 นาที ยืนยันสร้างใหม่?',
                    'code'        => 'DUPLICATE_PO',
                    'existing_po' => $dup_existing,
                ), 409 );
            }
        }

        // ── Create PO CPT ──
        // PO-DNC-XXXXXX (6 หลัก random)
        $po_number = function_exists( 'b2f_generate_po_number_v2' )
            ? b2f_generate_po_number_v2()
            : ( function_exists( 'b2f_generate_po_number' ) ? b2f_generate_po_number() : 'PO-DNC-' . str_pad( mt_rand( 0, 999999 ), 6, '0', STR_PAD_LEFT ) );

        $po_id = wp_insert_post( array(
            'post_type'   => 'b2f_order',
            'post_title'  => $po_number,
            'post_status' => 'publish',
        ) );

        if ( is_wp_error( $po_id ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'สร้าง PO ไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
        }

        // Save ACF fields
        update_field( 'po_number', $po_number, $po_id );
        update_field( 'po_maker_id', $maker_id, $po_id );
        update_field( 'po_status', 'draft', $po_id );
        update_field( 'po_total_amount', round( $total, 2 ), $po_id );
        update_field( 'po_admin_note', $note, $po_id );
        update_field( 'po_created_by', strval( $user_id ), $po_id );
        update_field( 'po_item_count', count( $po_items ), $po_id );
        update_field( 'po_version', 1, $po_id );
        update_field( 'po_amendment_count', 0, $po_id );
        update_field( 'po_paid_amount', 0, $po_id );
        update_field( 'po_payment_status', 'unpaid', $po_id );

        // ── Multi-Currency: save currency fields ──
        update_field( 'po_currency', $currency, $po_id );
        update_field( 'po_exchange_rate', round( $exchange_rate, 4 ), $po_id );
        if ( $shipping_method ) {
            update_field( 'po_shipping_method', $shipping_method, $po_id );
        }

        if ( ! empty( $req_date ) ) {
            update_field( 'po_requested_date', $req_date, $po_id );
        }

        // Save po_items repeater (with shipping per unit snapshot)
        $repeater       = array();
        $shipping_total = 0;
        foreach ( $po_items as $pi ) {
            // V.10.0: Snapshot shipping per unit — prefer pre-snapshotted value from b2f_read_maker_product(),
            // fallback to ACF read if legacy caller didn't populate (defensive).
            $ship_per = 0;
            if ( $shipping_method ) {
                if ( isset( $pi['shipping_land'] ) || isset( $pi['shipping_sea'] ) ) {
                    $ship_per = ( $shipping_method === 'sea' )
                        ? floatval( $pi['shipping_sea'] ?? 0 )
                        : floatval( $pi['shipping_land'] ?? 0 );
                } elseif ( ! empty( $pi['mp_post_id'] ) ) {
                    $ship_key = ( $shipping_method === 'sea' ) ? 'mp_shipping_sea' : 'mp_shipping_land';
                    $ship_per = floatval( get_field( $ship_key, $pi['mp_post_id'] ) ?: 0 );
                }
            }
            $shipping_total += round( $ship_per * $pi['qty'], 2 );

            // V.9.9 DD-3: Build breakdown JSON + invariant check
            $breakdown = $pi['breakdown'] ?? array();
            $breakdown_json = function_exists( 'b2f_build_item_breakdown_json' )
                ? b2f_build_item_breakdown_json( $breakdown )
                : '';
            // Invariant validation: sum(breakdown.qty) === qty
            $sum_qty = 0;
            foreach ( $breakdown as $b ) { $sum_qty += intval( $b['qty'] ?? 0 ); }
            if ( $sum_qty !== intval( $pi['qty'] ) && function_exists( 'b2f_log' ) ) {
                b2f_log( sprintf( 'DD-3 invariant broken at create-po: sku=%s sum=%d qty=%d', $pi['sku'], $sum_qty, $pi['qty'] ) );
            }

            $repeater[] = array(
                'poi_sku'                => $pi['sku'],
                'poi_product_name'       => $pi['product_name'],
                'poi_qty_ordered'        => $pi['qty'],
                'poi_unit_cost'          => $pi['unit_cost'],
                'poi_qty_shipped'        => 0,
                'poi_qty_received'       => 0,
                'poi_qty_rejected'       => 0,
                'poi_shipping_per_unit'  => $ship_per,
                // V.8.7 Hierarchy: SET origin (legacy single parent for backward compat)
                'poi_parent_sku'         => $pi['parent_sku'] ?? '',
                'poi_parent_name'        => $pi['parent_name'] ?? '',
                // V.9.9 DD-3: breakdown JSON (multi-parent tracking)
                'poi_parent_breakdown'   => $breakdown_json,
                // V.10.3 Issue #1: intermediate parent chain ("TOP/MID" or "TOP" or empty)
                // V.10.5 (M-3): top-level poi_parent_path = probe-only (first breakdown entry path).
                // DD-3 shared leaf: authoritative path per occurrence lives in $breakdown[i]['parent_path'].
                // Renderer logic: b2f_group_items_by_path() checks $has_any_path (probe) then iterates
                // breakdown (authoritative). Do NOT rely on top-level poi_parent_path for DD-3 cases —
                // use breakdown[] instead. Mirrors poi_parent_sku convention (V.9.10).
                'poi_parent_path'        => $pi['parent_path'] ?? '',
                // V.11.0 — Order Intent ACF sub-fields (Snippet 0 V.3.5 registered them)
                //   poi_intent_notes gated via PII filter in b2f_format_po_detail (non-admin → stripped)
                //   poi_production_mode_snapshot = audit trail (what system saw ณ order time)
                'poi_order_mode'                => $pi['order_mode'] ?? '',
                'poi_source_sku'                => $pi['source_sku'] ?? '',
                'poi_intent_notes'              => $pi['intent_notes'] ?? '',
                'poi_production_mode_snapshot'  => $pi['production_mode_snapshot'] ?? '',
            );
        }
        update_field( 'po_items', $repeater, $po_id );

        // V.11.0 — Compute + save `_b2f_order_intent_summary` aggregate postmeta
        //   Frontend Flex builder (b2f_flex_intent_summary) reads this for PO-level breakdown.
        //   Also populated on create-po so LIFF Submit Gate (Screen 5) can show 3-bucket summary.
        if ( $flag_order_intent ) {
            $summary = array(
                'full_set_count'     => 0,
                'sub_unit_count'     => 0,
                'single_leaf_count'  => 0,
                'total_items'        => 0,
            );
            foreach ( $po_items as $pi_sum ) {
                $om = (string) ( $pi_sum['order_mode'] ?? '' );
                $oq = (int) ( $pi_sum['qty'] ?? 0 );
                $summary['total_items'] += $oq;
                if ( $om === 'full_set' )          $summary['full_set_count']    += $oq;
                elseif ( $om === 'sub_unit' )      $summary['sub_unit_count']    += $oq;
                elseif ( $om === 'single_leaf' )   $summary['single_leaf_count'] += $oq;
            }
            update_post_meta( $po_id, '_b2f_order_intent_summary', wp_json_encode( $summary ) );
        }

        // ── Multi-Currency: calculate THB totals ──
        $total_amount_thb = round( $total * $exchange_rate, 2 );
        $grand_total_thb  = $total_amount_thb + $shipping_total;
        update_field( 'po_total_amount_thb', $total_amount_thb, $po_id );
        update_field( 'po_shipping_total', $shipping_total, $po_id );
        update_field( 'po_grand_total_thb', $grand_total_thb, $po_id );

        // ── Transition to 'submitted' via FSM (CRIT-04 fix: ห้าม bypass FSM) ──
        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'submitted', 'admin', 'PO created' );
            if ( is_wp_error( $trans ) ) {
                b2f_log( '[CRITICAL] FSM transition draft→submitted failed for PO #' . $po_id . ': ' . $trans->get_error_message() );
            }
        } else {
            update_field( 'po_status', 'submitted', $po_id );
            b2f_log( '[WARN] FSM not loaded — fallback update_field for PO #' . $po_id );
        }

        // Set duplicate prevention transient (5 minutes)
        set_transient( $dup_key, $po_number, 5 * MINUTE_IN_SECONDS );

        // ── Push Flex to Maker group ──
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        $push_maker  = false;
        $push_admin  = false;

        // ── Generate PO Image (A4 PNG) ──
        $po_image_ok = false;
        if ( function_exists( 'b2f_generate_po_pages' ) ) {
            $po_images = b2f_generate_po_pages( $po_id );
            $po_image_ok = ! empty( $po_images );
        }

        // ── Push Flex + PO Image to Maker group ──
        if ( function_exists( 'b2f_build_flex_new_po_for_maker' ) ) {
            $flex_maker = b2f_build_flex_new_po_for_maker( $po_id );
        } elseif ( function_exists( 'b2f_build_flex_new_po' ) ) {
            $flex_maker = b2f_build_flex_new_po( $po_id );
        }
        if ( ! empty( $flex_maker ) && ! empty( $maker_group ) && function_exists( 'b2f_line_push' ) ) {
            $push_maker = b2f_line_push( $maker_group, array( $flex_maker ) );
            // ส่งรูป PO Image ตามหลัง Flex
            if ( $po_image_ok && function_exists( 'b2f_send_po_image' ) ) {
                b2f_send_po_image( $maker_group, $po_id );
            }
        }

        // ── Push Flex to Admin group ──
        $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
        if ( ! empty( $admin_group ) && function_exists( 'b2f_line_push' ) ) {
            $flex_admin = null;
            if ( function_exists( 'b2f_build_flex_po_created' ) ) {
                $flex_admin = b2f_build_flex_po_created( $po_id );
            }
            if ( ! empty( $flex_admin ) ) {
                $push_admin = b2f_line_push( $admin_group, array( $flex_admin ) );
            } else {
                // Fallback: plain text ถ้า Flex builder ไม่พร้อม
                $push_admin = b2f_line_push( $admin_group, array( array(
                    'type' => 'text',
                    'text' => "\xF0\x9F\x93\x8B \xE0\xB8\xAA\xE0\xB8\xA3\xE0\xB9\x89\xE0\xB8\xB2\xE0\xB8\x87 PO \xE0\xB9\x83\xE0\xB8\xAB\xE0\xB8\xA1\xE0\xB9\x88\n{$po_number}\n\xE0\xB9\x82\xE0\xB8\xA3\xE0\xB8\x87\xE0\xB8\x87\xE0\xB8\xB2\xE0\xB8\x99: " . esc_html( get_field( 'maker_name', $maker_id ) ?: '' ) . "\n\xE0\xB8\xA2\xE0\xB8\xAD\xE0\xB8\x94: \xE0\xB8\xBF" . number_format( $total, 2 ),
                ) ) );
            }
        }

        // ── Credit: ไม่หักตอนสร้าง PO — หักตอน receive-goods เท่านั้น (CRIT-01 fix) ──
        // b2f_payable_add ถูกเรียกใน b2f_rest_receive_goods() เมื่อรับของจริง
        // b2f_recalculate_payable() เป็น source of truth คำนวณจาก receiving records

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'PO created: %s (#%d) Maker=#%d Total=%.2f Push:maker=%s,admin=%s',
                $po_number, $po_id, $maker_id, $total,
                $push_maker ? 'ok' : 'fail',
                $push_admin ? 'ok' : 'fail'
            ) );
        }

        // ── Response (ตาม spec section 12) ──
        $response_items = array();
        foreach ( $po_items as $pi ) {
            $response_items[] = array(
                'sku'       => esc_html( $pi['sku'] ),
                'qty'       => $pi['qty'],
                'unit_cost' => $pi['unit_cost'],
                'subtotal'  => $pi['subtotal'],
            );
        }

        $resp = array(
            'success'      => true,
            'po_id'        => $po_id,
            'po_number'    => esc_html( $po_number ),
            'total_amount' => round( $total, 2 ),
            'items'        => $response_items,
        );

        // Warnings (non-fatal)
        $warnings = array();
        if ( ! $push_maker && ! empty( $maker_group ) ) {
            $warnings[] = 'ส่งแจ้งเตือนไปโรงงานไม่สำเร็จ';
        }
        if ( empty( $maker_group ) ) {
            $warnings[] = 'โรงงานนี้ยังไม่มี LINE Group — ไม่ได้ส่งแจ้งเตือน';
        }
        if ( ! empty( $warnings ) ) {
            $resp['warnings'] = $warnings;
        }

        return new WP_REST_Response( $resp, 200 );
    }
}

// ════════════════════════════════════════════
// 8. PO DETAIL / UPDATE / CANCEL
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_po_detail' ) ) {
    /**
     * GET /po-detail/{po_id} — PO detail (admin or maker JWT)
     */
    function b2f_rest_po_detail( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );

        // Auth: admin session OR maker JWT
        $is_admin = current_user_can( 'manage_options' );
        if ( ! $is_admin ) {
            $jwt = b2f_verify_maker_jwt( $req );
            if ( is_wp_error( $jwt ) ) {
                $status = 401;
                $data = $jwt->get_error_data();
                if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
                return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
            }
            // Verify PO belongs to maker
            if ( $jwt['po_id'] !== $po_id ) {
                $mc = get_field( 'maker_currency', $jwt['maker_id'] ) ?: 'THB';
                $eng = $mc !== 'THB';
                return new WP_REST_Response( array( 'success' => false, 'error' => $eng ? 'You do not have access to this PO' : 'ไม่มีสิทธิ์เข้าถึง PO นี้', 'code' => 'FORBIDDEN' ), 403 );
            }
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            $pc = get_field( 'po_currency', $po_id ) ?: 'THB';
            $eng = $pc !== 'THB';
            return new WP_REST_Response( array( 'success' => false, 'error' => $eng ? 'PO not found' : 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => b2f_format_po_detail( $po_id, $is_admin ),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_po_detail_jwt' ) ) {
    /**
     * GET /po-detail/jwt — PO detail by JWT token (Maker LIFF)
     * token มี po_id + maker_id → verify แล้วดึง PO detail
     */
    function b2f_rest_po_detail_jwt( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message() ), $status );
        }

        // B-07 fix: รับ po_id จาก JWT หรือ request param (Delivery Form ส่ง po_id แยก)
        $po_id = ! empty( $jwt['po_id'] ) ? intval( $jwt['po_id'] ) : intval( $req->get_param( 'po_id' ) ?: 0 );
        // V.7.3: i18n error messages — detect currency from maker_id (JWT always has it)
        $mc = get_field( 'maker_currency', $jwt['maker_id'] ) ?: 'THB';
        $eng = $mc !== 'THB';
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $eng ? 'Missing PO ID' : 'ไม่ระบุ PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $eng ? 'PO not found' : 'ไม่พบ PO' ), 404 );
        }

        // Verify PO belongs to maker
        $po_maker = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        if ( $po_maker !== intval( $jwt['maker_id'] ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $eng ? 'This PO does not belong to your factory' : 'PO นี้ไม่ใช่ของโรงงานคุณ' ), 403 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => b2f_format_po_detail( $po_id, false ),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_format_po_detail' ) ) {
    /**
     * Format PO data for API response
     * @param int  $po_id
     * @param bool $include_sensitive  Include admin-only fields (payment, cancel info)
     *                                 V.11.0: also gates PII (intent_notes, production_mode_snapshot,
     *                                 _b2f_order_intent_summary aggregate). Callers MUST pass
     *                                 `$is_admin` accurately — Maker JWT path always passes false.
     * @return array
     */
    function b2f_format_po_detail( $po_id, $include_sensitive = false ) {
        $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $items    = get_field( 'po_items', $po_id ) ?: array();

        // V.11.4 — BUG-C4 FIX (Phase 1 audit): restored PII defense-in-depth by removing the
        //   self-reverting block that auto-re-enabled the gate whenever caller claimed admin
        //   without cap. That defeated the whole point of the double-check (see audit §S/BUG-C4).
        //   Now the gate is authoritative: $include_sensitive=true AND current_user_can must
        //   both be true. Admin LIFF contexts (X-B2F-Token without WP user session) will see
        //   PII stripped — proper token→user binding is tracked as Phase 2 auth fix (S1/S2).
        //   Until then, LEAK-PROOF is the correct default for intent_notes + production_mode
        //   snapshot + order_intent_summary.
        $is_admin_gate = (bool) $include_sensitive && current_user_can( 'manage_options' );

        $formatted_items = array();
        foreach ( $items as $item ) {
            $sku  = esc_html( $item['poi_sku'] ?? '' );
            $name = esc_html( $item['poi_product_name'] ?? '' );
            $qo   = intval( $item['poi_qty_ordered'] ?? 0 );
            $uc   = floatval( $item['poi_unit_cost'] ?? 0 );
            $qs   = intval( $item['poi_qty_shipped'] ?? 0 );
            $qr   = intval( $item['poi_qty_received'] ?? 0 );
            $qj   = intval( $item['poi_qty_rejected'] ?? 0 );
            // V.4.9: ดึง image_url จาก DINOCO_Catalog
            $img  = '';
            if ( $sku && class_exists( 'DINOCO_Catalog' ) ) {
                $catalog_product = DINOCO_Catalog::get_by_sku( $item['poi_sku'] ?? '' );
                if ( $catalog_product && ! empty( $catalog_product['image_url'] ) ) {
                    $img = esc_url( $catalog_product['image_url'] );
                }
            }
            // V.8.7 Hierarchy: parent info for UI grouping (empty = standalone item)
            // V.8.8: ไม่ esc_html() ใน REST response — escape ที่ output point (Flex/LIFF/Ticket ทำเอง)
            $psku = $item['poi_parent_sku'] ?? '';
            $pnam = $item['poi_parent_name'] ?? '';
            // V.10.3 Issue #1: intermediate parent chain (slash-separated) — empty for PO เก่า
            $ppath = $item['poi_parent_path'] ?? '';

            // V.9.9 DD-3: parent_breakdown (JSON or fallback single entry)
            $breakdown = function_exists( 'b2f_get_item_breakdown' )
                ? b2f_get_item_breakdown( $item )
                : array( array( 'parent_sku' => $psku ?: '__standalone__', 'parent_name' => $pnam, 'qty' => $qo ) );

            // V.11.0 — Order Intent fields (all 4 sub-fields Snippet 0 V.3.5 registered)
            $poi_order_mode   = (string) ( $item['poi_order_mode'] ?? '' );
            $poi_source_sku   = (string) ( $item['poi_source_sku'] ?? '' );
            $poi_intent_notes = (string) ( $item['poi_intent_notes'] ?? '' );
            $poi_prod_snap    = (string) ( $item['poi_production_mode_snapshot'] ?? '' );

            // V.11.0 — Legacy PO fallback: infer order_mode display-only (Decision #9 per plan
            //   says "display — for legacy PO Mode column shows '—'"). But for NEW UI that
            //   wants richer fallback, provide `poi_order_mode_inferred` separately so renderer
            //   can choose. poi_order_mode remains empty string for pure legacy UI switch.
            $poi_order_mode_inferred = '';
            if ( $poi_order_mode === '' && function_exists( 'b2f_infer_legacy_order_mode' ) ) {
                $poi_order_mode_inferred = (string) b2f_infer_legacy_order_mode( $item );
            }

            $item_out = array(
                // V.4.7: ส่งทั้ง short name + poi_ prefix เพื่อ compat กับ Maker LIFF + Admin
                'image_url' => $img, 'poi_image_url' => $img,
                'sku' => $sku, 'poi_sku' => $sku,
                'product_name' => $name, 'poi_product_name' => $name,
                'qty_ordered' => $qo, 'poi_qty_ordered' => $qo,
                'unit_cost' => $uc, 'poi_unit_cost' => $uc,
                'qty_shipped' => $qs, 'poi_qty_shipped' => $qs,
                'qty_received' => $qr, 'poi_qty_received' => $qr,
                'qty_rejected' => $qj, 'poi_qty_rejected' => $qj,
                'subtotal' => round( $uc * $qo, 2 ),
                // V.8.7 Hierarchy (legacy single parent)
                'parent_sku' => $psku, 'poi_parent_sku' => $psku,
                'parent_name' => $pnam, 'poi_parent_name' => $pnam,
                // V.10.3 Issue #1: intermediate parent chain ("TOP/MID" or "TOP" or "")
                'parent_path' => $ppath, 'poi_parent_path' => $ppath,
                // V.9.9 DD-3 Shared Child breakdown
                'parent_breakdown' => $breakdown,
                // V.11.0 — Order Intent (non-PII fields always exposed)
                'order_mode'                 => $poi_order_mode, 'poi_order_mode' => $poi_order_mode,
                'source_sku'                 => $poi_source_sku, 'poi_source_sku' => $poi_source_sku,
                'order_mode_inferred'        => $poi_order_mode_inferred,
                'poi_order_mode_inferred'    => $poi_order_mode_inferred,
            );

            // V.11.0 — PII fields (intent_notes + production_mode_snapshot) admin-only.
            //   Non-admin → strip both. Never leak to Maker LIFF or LINE group payloads.
            if ( $is_admin_gate ) {
                $item_out['intent_notes']                  = $poi_intent_notes;
                $item_out['poi_intent_notes']              = $poi_intent_notes;
                $item_out['production_mode_snapshot']      = $poi_prod_snap;
                $item_out['poi_production_mode_snapshot']  = $poi_prod_snap;
            }

            $formatted_items[] = $item_out;
        }

        $status_val   = esc_html( get_field( 'po_status', $po_id ) ?: 'draft' );
        $total_val    = floatval( get_field( 'po_total_amount', $po_id ) ?: 0 );
        $po_currency  = get_field( 'po_currency', $po_id ) ?: 'THB';
        $po_ex_rate   = floatval( get_field( 'po_exchange_rate', $po_id ) ?: 1 );
        $po_ship_meth = get_field( 'po_shipping_method', $po_id ) ?: '';

        $data = array(
            'id'              => $po_id,
            'po_number'       => esc_html( get_field( 'po_number', $po_id ) ?: '' ),
            'maker_id'        => $maker_id,
            'maker_name'      => esc_html( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ),
            'status'          => $status_val,
            'po_status'       => $status_val,       // BUG-1 fix: alias สำหรับ Maker LIFF ที่ใช้ po_status
            'items'           => $formatted_items,
            'po_items'        => $formatted_items,   // BUG-2 fix: alias สำหรับ Maker LIFF ที่ใช้ po_items
            'total_amount'    => $total_val,
            'po_total_amount' => $total_val,         // alias
            // Multi-Currency fields
            'currency'           => $po_currency,
            'po_currency'        => $po_currency,
            'exchange_rate'      => $po_ex_rate,
            'po_exchange_rate'   => $po_ex_rate,
            'shipping_method'    => $po_ship_meth,
            'po_shipping_method' => $po_ship_meth,
            'total_amount_thb'   => floatval( get_field( 'po_total_amount_thb', $po_id ) ?: 0 ),
            'shipping_total'     => floatval( get_field( 'po_shipping_total', $po_id ) ?: 0 ),
            'grand_total_thb'    => floatval( get_field( 'po_grand_total_thb', $po_id ) ?: 0 ),
            'currency_symbol'    => function_exists( 'b2f_currency_symbol' ) ? b2f_currency_symbol( $po_currency ) : '฿',
            'item_count'      => intval( get_field( 'po_item_count', $po_id ) ?: 0 ),
            'po_item_count'   => intval( get_field( 'po_item_count', $po_id ) ?: 0 ),
            'requested_date'     => esc_html( get_field( 'po_requested_date', $po_id ) ?: '' ),
            'po_requested_date'  => esc_html( get_field( 'po_requested_date', $po_id ) ?: '' ),
            'expected_date'      => esc_html( get_field( 'po_expected_date', $po_id ) ?: '' ),
            'po_expected_date'   => esc_html( get_field( 'po_expected_date', $po_id ) ?: '' ),
            'actual_date'        => esc_html( get_field( 'po_actual_date', $po_id ) ?: '' ),
            'po_actual_date'     => esc_html( get_field( 'po_actual_date', $po_id ) ?: '' ),
            'maker_note'         => esc_html( get_field( 'po_maker_note', $po_id ) ?: '' ),
            'po_maker_note'      => esc_html( get_field( 'po_maker_note', $po_id ) ?: '' ),
            'admin_note'         => esc_html( get_field( 'po_admin_note', $po_id ) ?: '' ),
            'po_admin_note'      => esc_html( get_field( 'po_admin_note', $po_id ) ?: '' ),
            'version'         => intval( get_field( 'po_version', $po_id ) ?: 1 ),
            'amendment_count' => intval( get_field( 'po_amendment_count', $po_id ) ?: 0 ),
            'created_date'    => get_the_date( 'Y-m-d H:i:s', $po_id ),
        );

        // V.6.8: เพิ่ม credit timeline fields สำหรับ progress bars
        $credit_term = intval( get_field( 'maker_credit_term_days', $maker_id ) ?: 30 );
        $data['credit_term_days'] = $credit_term;
        $actual = get_field( 'po_actual_date', $po_id );
        if ( ! empty( $actual ) ) {
            $due = date( 'Y-m-d', strtotime( $actual . ' + ' . $credit_term . ' days' ) );
            $data['payment_due_date'] = $due;
        }

        // Delivery records (ทุก role เห็นได้)
        $deliveries_raw = get_field( 'po_deliveries', $po_id ) ?: array();
        $data['deliveries'] = array();
        foreach ( $deliveries_raw as $dlv ) {
            $data['deliveries'][] = array(
                'number'      => esc_html( $dlv['dlv_number'] ?? '' ),
                'date'        => esc_html( $dlv['dlv_date'] ?? '' ),
                'items'       => json_decode( $dlv['dlv_items'] ?? '[]', true ) ?: array(),
                'note'        => esc_html( $dlv['dlv_note'] ?? '' ),
                'is_complete' => ! empty( $dlv['dlv_is_complete'] ),
            );
        }

        if ( $include_sensitive ) {
            $data['admin_note']       = esc_html( get_field( 'po_admin_note', $po_id ) ?: '' );
            $data['created_by']       = esc_html( get_field( 'po_created_by', $po_id ) ?: '' );
            $data['paid_amount']      = floatval( get_field( 'po_paid_amount', $po_id ) ?: 0 );
            $data['payment_status']   = esc_html( get_field( 'po_payment_status', $po_id ) ?: 'unpaid' );
            $data['cancelled_reason'] = esc_html( get_field( 'po_cancelled_reason', $po_id ) ?: '' );
            $data['cancelled_by']     = esc_html( get_field( 'po_cancelled_by', $po_id ) ?: '' );
            $data['cancelled_date']   = esc_html( get_field( 'po_cancelled_date', $po_id ) ?: '' );
            $data['rejected_reason']  = esc_html( get_field( 'po_rejected_reason', $po_id ) ?: '' );
        }

        // V.11.0 — order_intent_summary aggregate (admin-only PII — see HIGH-1 in plan)
        //   Reads _b2f_order_intent_summary postmeta (saved on create-po). Falls back to
        //   on-the-fly computation if missing (legacy PO OR flag OFF at create time).
        if ( $is_admin_gate ) {
            $summary_raw = get_post_meta( $po_id, '_b2f_order_intent_summary', true );
            $summary_out = null;
            if ( is_string( $summary_raw ) && $summary_raw !== '' ) {
                $decoded = json_decode( $summary_raw, true );
                if ( is_array( $decoded ) ) $summary_out = $decoded;
            }
            // Fallback: compute on-the-fly from items
            if ( ! is_array( $summary_out ) ) {
                $summary_out = array(
                    'full_set_count'     => 0,
                    'sub_unit_count'     => 0,
                    'single_leaf_count'  => 0,
                    'total_items'        => 0,
                );
                foreach ( $items as $it ) {
                    $om = (string) ( $it['poi_order_mode'] ?? '' );
                    $oq = (int) ( $it['poi_qty_ordered'] ?? 0 );
                    $summary_out['total_items'] += $oq;
                    if ( $om === 'full_set' )        $summary_out['full_set_count']    += $oq;
                    elseif ( $om === 'sub_unit' )    $summary_out['sub_unit_count']    += $oq;
                    elseif ( $om === 'single_leaf' ) $summary_out['single_leaf_count'] += $oq;
                }
            }
            $data['order_intent_summary'] = $summary_out;
        }

        return $data;
    }
}

if ( ! function_exists( 'b2f_rest_po_update' ) ) {
    /**
     * POST /po-update — แก้ไข PO (admin, ก่อน Maker confirm only)
     * Body: { po_id, items: [{ sku, qty }], note?, requested_date? }
     */
    function b2f_rest_po_update( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status  = get_field( 'po_status', $po_id );
        $resubmit_only   = ! empty( $req->get_param( 'resubmit_only' ) );

        // B-02 fix: Resubmit — ส่ง PO เดิมกลับ Maker โดยไม่แก้ไข items
        if ( $resubmit_only ) {
            if ( $current_status !== 'rejected' ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'ส่งใหม่ได้เฉพาะ PO ที่ถูกปฏิเสธ', 'code' => 'NOT_REJECTED' ), 400 );
            }
            if ( function_exists( 'b2f_transition_order' ) ) {
                $trans = b2f_transition_order( $po_id, 'submitted', 'admin', 'Resubmit without changes' );
                if ( is_wp_error( $trans ) ) {
                    return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
                }
            } else {
                update_field( 'po_status', 'submitted', $po_id );
            }

            // Push Flex resubmitted ไป Maker
            $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
            $maker_group = $maker_id ? get_field( 'maker_line_group_id', $maker_id ) : '';
            if ( function_exists( 'b2f_build_flex_po_resubmitted' ) && ! empty( $maker_group ) ) {
                $flex = b2f_build_flex_po_resubmitted( $po_id );
                if ( $flex ) b2f_line_push( $maker_group, array( $flex ) );
            }

            $po_number = get_field( 'po_number', $po_id ) ?: '';
            if ( function_exists( 'b2f_log' ) ) b2f_log( "PO resubmitted: {$po_number} (#{$po_id})" );

            return new WP_REST_Response( array( 'success' => true, 'po_id' => $po_id, 'status' => 'submitted', 'po_number' => $po_number ), 200 );
        }

        // Only allow amend in these statuses
        $amendable = array( 'submitted', 'confirmed', 'rejected' );
        if ( ! in_array( $current_status, $amendable, true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่สามารถแก้ไข PO ในสถานะนี้', 'code' => 'NOT_AMENDABLE' ), 400 );
        }

        $items = $req->get_param( 'items' );
        if ( empty( $items ) || ! is_array( $items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุรายการสินค้า', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Rebuild items with fresh cost snapshot
        $po_items = array();
        $total    = 0;

        foreach ( $items as $item ) {
            $sku = sanitize_text_field( $item['sku'] ?? '' );
            $qty = intval( $item['qty'] ?? 0 );
            if ( empty( $sku ) || $qty <= 0 ) continue;

            $mp = new WP_Query( array(
                'post_type'      => 'b2f_maker_product',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array(
                    'relation' => 'AND',
                    array( 'key' => 'mp_maker_id', 'value' => $maker_id, 'type' => 'NUMERIC' ),
                    array( 'key' => 'mp_product_sku', 'value' => $sku ),
                ),
            ) );

            if ( ! $mp->have_posts() ) {
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'ไม่พบ SKU "%s" สำหรับโรงงานนี้', esc_html( $sku ) ),
                    'code'    => 'INVALID_SKU',
                ), 400 );
            }

            $mp_post      = $mp->posts[0];
            $unit_cost    = floatval( get_field( 'mp_unit_cost', $mp_post->ID ) ?: 0 );
            $product_name = get_field( 'mp_product_name', $mp_post->ID ) ?: $sku;
            $subtotal     = round( $unit_cost * $qty, 2 );

            $po_items[] = array(
                'poi_sku'          => $sku,
                'poi_product_name' => $product_name,
                'poi_qty_ordered'  => $qty,
                'poi_unit_cost'    => $unit_cost,
                'poi_qty_received' => 0,
                'poi_qty_rejected' => 0,
            );
            $total += $subtotal;
        }

        if ( empty( $po_items ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีรายการสินค้าที่ถูกต้อง', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        // Update fields
        update_field( 'po_items', $po_items, $po_id );
        update_field( 'po_total_amount', round( $total, 2 ), $po_id );
        update_field( 'po_item_count', count( $po_items ), $po_id );

        $amend_count = intval( get_field( 'po_amendment_count', $po_id ) ?: 0 ) + 1;
        $version     = intval( get_field( 'po_version', $po_id ) ?: 1 ) + 1;
        update_field( 'po_amendment_count', $amend_count, $po_id );
        update_field( 'po_version', $version, $po_id );

        $note = $req->get_param( 'note' );
        if ( $note !== null ) {
            update_field( 'po_admin_note', sanitize_textarea_field( $note ), $po_id );
        }
        $req_date = $req->get_param( 'requested_date' );
        if ( $req_date !== null ) {
            update_field( 'po_requested_date', sanitize_text_field( $req_date ), $po_id );
        }

        // Transition: current -> amended -> auto-resubmit
        if ( function_exists( 'b2f_transition_order' ) ) {
            b2f_transition_order( $po_id, 'amended', 'admin', 'PO amended (version ' . $version . ')' );
            b2f_transition_order( $po_id, 'submitted', 'system', 'auto-resubmit after amend' );
        } else {
            update_field( 'po_status', 'submitted', $po_id );
        }

        // Push Flex to Maker
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        if ( function_exists( 'b2f_build_flex_po_amended' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_po_amended( $po_id, $amend_count );
            if ( $flex ) b2f_line_push( $maker_group, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'PO amended: %s (#%d) version=%d total=%.2f', $po_number, $po_id, $version, $total ) );
        }

        return new WP_REST_Response( array(
            'success'      => true,
            'po_id'        => $po_id,
            'version'      => $version,
            'total_amount' => round( $total, 2 ),
            'status'       => 'submitted',
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_po_cancel' ) ) {
    /**
     * POST /po-cancel — ยกเลิก PO (admin) + reverse stock + rollback credit + แจ้งโรงงาน
     * Body: { po_id, reason }
     * V.8.2: ใช้ FSM transition แทน wp_delete_post — เก็บ PO + receiving + payment เป็น audit trail
     */
    function b2f_rest_po_cancel( WP_REST_Request $req ) {
        $po_id  = intval( $req->get_param( 'po_id' ) ?: 0 );
        $reason = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุใบสั่งซื้อ', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบใบสั่งซื้อ', 'code' => 'NOT_FOUND' ), 404 );
        }

        // W1 FIX: Lock ป้องกัน concurrent cancel + receive/payment
        global $wpdb;
        $cancel_lock = 'b2f_recv_' . intval( $po_id );
        $got_cancel_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 3)", $cancel_lock ) );
        if ( ! $got_cancel_lock ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'มีคนอื่นกำลังดำเนินการอยู่', 'code' => 'LOCKED' ), 423 );
        }

        $current_status = get_field( 'po_status', $po_id );
        $maker_id       = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // ห้ามยกเลิกซ้ำ
        if ( $current_status === 'cancelled' ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $cancel_lock ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ใบสั่งซื้อนี้ถูกยกเลิกไปแล้ว', 'code' => 'ALREADY_CANCELLED' ), 400 );
        }

        // V.8.2: FSM transition แทน wp_delete_post
        if ( function_exists( 'b2f_transition_order' ) ) {
            $fsm_result = b2f_transition_order( $po_id, 'cancelled', 'admin', $reason );
            if ( is_wp_error( $fsm_result ) ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $cancel_lock ) );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => $fsm_result->get_error_message(),
                    'code'    => 'FSM_REJECTED',
                ), 400 );
            }
        } else {
            // Fallback: direct status update ถ้า FSM ไม่ load
            update_field( 'po_status', 'cancelled', $po_id );
        }

        // V.8.2: บันทึก cancellation metadata (audit trail)
        $cancelled_by = 'Admin';
        $uid = get_current_user_id();
        if ( $uid ) { $u = get_user_by( 'id', $uid ); if ( $u ) $cancelled_by = $u->display_name; }

        update_field( 'po_cancelled_reason', $reason, $po_id );
        update_field( 'po_cancelled_by', $cancelled_by, $po_id );
        $tz = new DateTimeZone( 'Asia/Bangkok' );
        update_field( 'po_cancelled_date', ( new DateTime( 'now', $tz ) )->format( 'Y-m-d' ), $po_id );

        // เก็บข้อมูลสำหรับ Flex notification
        $po_number      = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;
        $maker_name_str = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: '' ) : '';
        $total_str      = number_format( floatval( get_field( 'po_total_amount', $po_id ) ?: 0 ), 0 );
        $maker_group    = $maker_id ? ( get_field( 'maker_line_group_id', $maker_id ) ?: '' ) : '';
        $po_currency    = get_field( 'po_currency', $po_id ) ?: 'THB';
        $cur_sym        = function_exists( 'b2f_currency_symbol' ) ? b2f_currency_symbol( $po_currency ) : '฿';

        // V.8.2: Reverse stock — คืนสต็อกที่เคย add ผ่าน receive-goods
        $stock_reversed = 0;
        $receivings = get_posts( array(
            'post_type'      => 'b2f_receiving',
            'meta_query'     => array( array( 'key' => 'rcv_po_id', 'value' => $po_id ) ),
            'posts_per_page' => -1,
            'post_status'    => 'any',
        ) );
        foreach ( $receivings as $rcv ) {
            $rcv_items = get_field( 'rcv_items', $rcv->ID );
            if ( ! $rcv_items || ! is_array( $rcv_items ) ) continue;
            if ( function_exists( 'dinoco_stock_subtract' ) ) {
                foreach ( $rcv_items as $item ) {
                    $sku = $item['rcvi_sku'] ?? '';
                    // receive-goods เพิ่มเฉพาะ rcvi_qty_received (rejected ไม่เคยถูก add)
                    $qty = intval( $item['rcvi_qty_received'] ?? 0 );
                    if ( $sku && $qty > 0 ) {
                        dinoco_stock_subtract( $sku, $qty, 'b2f_cancel', 'b2f_order', $po_id, 'B2F Cancel ' . $po_number );
                        $stock_reversed += $qty;
                    }
                }
            }
        }

        // V.8.2: Recalculate payable (receiving + payment records ยังอยู่ แต่ FSM status=cancelled
        // ทำให้ b2f_recalculate_payable ไม่นับ cancelled PO)
        $rollback_info = array();
        $old_debt = floatval( get_field( 'maker_current_debt', $maker_id ) ?: 0 );
        if ( function_exists( 'b2f_recalculate_payable' ) && $maker_id > 0 ) {
            $new_debt = b2f_recalculate_payable( $maker_id );
            $reversed = round( $old_debt - $new_debt, 2 );
            if ( $reversed > 0 ) {
                $rollback_info['debt_reversed'] = $reversed;
                $rollback_info['old_debt']      = $old_debt;
                $rollback_info['new_debt']      = $new_debt;
            }
        }

        // V.8.0: 3-lang labels for Maker Flex (THB/USD/CNY)
        $cur = $po_currency ?: 'THB';
        $is_eng = $cur !== 'THB';

        $cancel_body_maker = array(
            array( 'type' => 'box', 'layout' => 'horizontal', 'contents' => array(
                array( 'type' => 'text', 'text' => b2f_t('เลขที่ PO', 'PO Number', '订单号', $cur), 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => $po_number, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end' ) ) ),
            array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'sm', 'contents' => array(
                array( 'type' => 'text', 'text' => b2f_t('โรงงาน', 'Factory', '供应商', $cur), 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => $maker_name_str, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end', 'wrap' => true ) ) ),
            array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'sm', 'contents' => array(
                array( 'type' => 'text', 'text' => b2f_t('ยอดรวม', 'Total', '合计', $cur), 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => $cur_sym . $total_str, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end' ) ) ),
            array( 'type' => 'separator', 'margin' => 'md' ),
        );
        if ( ! empty( $reason ) ) {
            $cancel_body_maker[] = array( 'type' => 'text', 'text' => b2f_t('เหตุผล: ', 'Reason: ', '原因: ', $cur) . mb_substr( $reason, 0, 80 ), 'size' => 'sm', 'color' => '#dc2626', 'wrap' => true, 'margin' => 'md' );
