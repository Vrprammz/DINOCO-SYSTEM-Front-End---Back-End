if ( ! function_exists( 'b2f_rest_reject_lot' ) ) {
    /**
     * POST /reject-lot — Admin reject ทั้ง lot ให้ Maker ส่งใหม่
     */
    function b2f_rest_reject_lot( WP_REST_Request $req ) {
        $po_id  = intval( $req->get_param( 'po_id' ) ?: 0 );
        $reason = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );
        if ( $current_status !== 'delivering' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'PO ไม่อยู่ในสถานะ delivering', 'code' => 'INVALID_STATUS' ), 400 );
        }

        // Transition delivering → confirmed (FSM allows this)
        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'confirmed', 'admin', 'Reject lot: ' . $reason );
            if ( is_wp_error( $trans ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
            }
        } else {
            update_field( 'po_status', 'confirmed', $po_id );
        }

        update_field( 'po_admin_note', $reason, $po_id );

        // Push Flex to Maker
        $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $maker_group = $maker_id ? get_field( 'maker_line_group_id', $maker_id ) : '';
        if ( function_exists( 'b2f_build_flex_lot_rejected' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_lot_rejected( $po_id, $reason );
            if ( $flex ) b2f_line_push( $maker_group, array( $flex ) );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Reject lot: PO #%d reason=%s', $po_id, $reason ) );
        }

        return new WP_REST_Response( array( 'success' => true, 'po_id' => $po_id, 'status' => 'confirmed' ), 200 );
    }
}

// ════════════════════════════════════════════
// V.5.5: QC REJECT RESOLVE — Admin ดำเนินการ reject items
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_reject_resolve' ) ) {
    /**
     * POST /reject-resolve — Admin เลือกวิธีจัดการ reject items
     *
     * Body: { rcv_id, action: 'replacement'|'reship'|'write_off', note? }
     *
     * - replacement: สร้าง PO draft ใหม่เฉพาะ reject SKUs
     * - reship:      transition PO เดิม → confirmed ให้ Maker ส่งใหม่
     * - write_off:   ลด qty_ordered = accepted qty + recalculate total
     */
    function b2f_rest_reject_resolve( WP_REST_Request $req ) {
        $rcv_id = intval( $req->get_param( 'rcv_id' ) ?: 0 );
        $action = sanitize_text_field( $req->get_param( 'action' ) ?: '' );
        $note   = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );

        if ( ! $rcv_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุใบรับ', 'code' => 'MISSING_RCV' ), 400 );
        }
        if ( ! in_array( $action, array( 'replacement', 'reship', 'write_off' ), true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'action ไม่ถูกต้อง (replacement/reship/write_off)', 'code' => 'INVALID_ACTION' ), 400 );
        }

        // C-2: MySQL GET_LOCK ป้องกัน concurrent resolve
        global $wpdb;
        $lock_key = 'b2f_reject_resolve_' . $rcv_id;
        $got_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 0)", $lock_key ) );
        if ( ! $got_lock ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กำลังดำเนินการอยู่', 'code' => 'LOCKED' ), 423 );
        }

        $rcv_post = get_post( $rcv_id );
        if ( ! $rcv_post || $rcv_post->post_type !== 'b2f_receiving' ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบใบรับ', 'code' => 'NOT_FOUND' ), 404 );
        }

        // ตรวจว่ายัง unresolved
        if ( get_field( 'rcv_reject_resolved', $rcv_id ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ดำเนินการแล้ว ไม่สามารถทำซ้ำ', 'code' => 'ALREADY_RESOLVED' ), 400 );
        }

        $po_id    = intval( get_field( 'rcv_po_id', $rcv_id ) ?: 0 );
        $po_post  = get_post( $po_id );
        if ( ! $po_post || $po_post->post_type !== 'b2f_order' ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'PO_NOT_FOUND' ), 404 );
        }

        $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $maker_group = $maker_id ? get_field( 'maker_line_group_id', $maker_id ) : '';
        $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
        $po_number   = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;
        $rcv_items   = get_field( 'rcv_items', $rcv_id ) ?: array();
        $po_items    = get_field( 'po_items', $po_id ) ?: array();

        // Collect reject SKUs
        $reject_skus = array();
        foreach ( $rcv_items as $ri ) {
            $rej = intval( $ri['rcvi_qty_rejected'] ?? 0 );
            if ( $rej > 0 ) {
                $reject_skus[ $ri['rcvi_sku'] ?? '' ] = $rej;
            }
        }

        if ( empty( $reject_skus ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ reject items', 'code' => 'NO_REJECT' ), 400 );
        }

        $result_data = array( 'action' => $action );
        $action_labels = array( 'replacement' => 'สร้างใบสั่งซื้อใหม่', 'reship' => 'ให้ส่งใหม่', 'write_off' => 'ตัดยอด' );

        // ── Action: replacement — สร้าง PO draft ใหม่เฉพาะ reject SKUs ──
        if ( $action === 'replacement' ) {
            $new_items = array();
            $new_total = 0;
            foreach ( $po_items as $pi ) {
                $sku = $pi['poi_sku'] ?? '';
                if ( isset( $reject_skus[ $sku ] ) ) {
                    $unit_cost = floatval( $pi['poi_unit_cost'] ?? 0 );
                    $qty       = $reject_skus[ $sku ];
                    $new_items[] = array(
                        'poi_sku'           => $sku,
                        'poi_product_name'  => $pi['poi_product_name'] ?? $sku,
                        'poi_unit_cost'     => $unit_cost,
                        'poi_qty_ordered'   => $qty,
                        'poi_qty_received'  => 0,
                        'poi_subtotal'      => $unit_cost * $qty,
                    );
                    $new_total += $unit_cost * $qty;
                }
            }

            $new_po_number = function_exists( 'b2f_generate_po_number' ) ? b2f_generate_po_number() : 'PO-RPL-' . wp_date( 'ymdHi' );
            $new_po_id = wp_insert_post( array(
                'post_type'   => 'b2f_order',
                'post_title'  => $new_po_number,
                'post_status' => 'publish',
            ) );

            if ( is_wp_error( $new_po_id ) ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                return new WP_REST_Response( array( 'success' => false, 'error' => 'สร้าง PO ใหม่ไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
            }

            update_field( 'po_number', $new_po_number, $new_po_id );
            update_field( 'po_maker_id', $maker_id, $new_po_id );
            update_field( 'po_status', 'draft', $new_po_id );
            update_field( 'po_items', $new_items, $new_po_id );
            update_field( 'po_total_amount', $new_total, $new_po_id );
            update_field( 'po_item_count', count( $new_items ), $new_po_id );
            update_field( 'po_is_replacement', 1, $new_po_id );
            update_field( 'po_payment_status', 'unpaid', $new_po_id );
            update_field( 'po_parent_po_id', $po_id, $new_po_id );
            update_field( 'po_admin_note', 'Replacement PO จาก ' . $po_number . ' (QC reject)', $new_po_id );

            // Link replacement PO to receiving
            update_field( 'rcv_replacement_po_id', $new_po_id, $rcv_id );

            $result_data['new_po_id']     = $new_po_id;
            $result_data['new_po_number'] = $new_po_number;

            if ( function_exists( 'b2f_log' ) ) {
                b2f_log( sprintf( 'Reject resolve: replacement PO %s (#%d) from PO %s (#%d)', $new_po_number, $new_po_id, $po_number, $po_id ) );
            }
        }

        // ── Action: reship — transition PO เดิม → confirmed ──
        if ( $action === 'reship' ) {
            $current_status = get_field( 'po_status', $po_id );
            if ( in_array( $current_status, array( 'partial_received', 'received' ), true ) ) {
                if ( function_exists( 'b2f_transition_order' ) ) {
                    $trans = b2f_transition_order( $po_id, 'confirmed', 'admin', 'QC reject reship: ' . $note );
                    if ( is_wp_error( $trans ) ) {
                        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                        return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
                    }
                } else {
                    update_field( 'po_status', 'confirmed', $po_id );
                }
            }

            // Push Flex แจ้ง Maker ให้ส่งใหม่ (ใช้ b2f_build_flex_lot_rejected ที่มีอยู่)
            if ( function_exists( 'b2f_build_flex_lot_rejected' ) && ! empty( $maker_group ) ) {
                $flex = b2f_build_flex_lot_rejected( $po_id, 'QC reject — กรุณาส่งของใหม่: ' . $note );
                if ( $flex && function_exists( 'b2f_push_guaranteed' ) ) {
                    b2f_push_guaranteed( $maker_group, $flex, $po_id, 'reject_reship_maker' );
                }
            }

            $result_data['po_status'] = 'confirmed';
        }

        // ── Action: write_off — ลด qty_ordered = accepted (received-rejected) ──
        if ( $action === 'write_off' ) {
            $updated_items = array();
            $new_total     = 0;
            foreach ( $po_items as $pi ) {
                $sku = $pi['poi_sku'] ?? '';
                if ( isset( $reject_skus[ $sku ] ) ) {
                    $ordered  = intval( $pi['poi_qty_ordered'] ?? 0 );
                    $accepted = $ordered - $reject_skus[ $sku ];
                    if ( $accepted < 0 ) $accepted = 0;
                    $pi['poi_qty_ordered'] = $accepted;
                    $pi['poi_subtotal']    = floatval( $pi['poi_unit_cost'] ?? 0 ) * $accepted;
                }
                $new_total    += floatval( $pi['poi_subtotal'] ?? 0 );
                $updated_items[] = $pi;
            }
            update_field( 'po_items', $updated_items, $po_id );
            update_field( 'po_total_amount', $new_total, $po_id );

            // Check if all items complete now
            $all_done = true;
            foreach ( $updated_items as $pi ) {
                $ord = intval( $pi['poi_qty_ordered'] ?? 0 );
                $rcvd = intval( $pi['poi_qty_received'] ?? 0 );
                if ( $rcvd < $ord ) { $all_done = false; break; }
            }
            if ( $all_done ) {
                $current_status = get_field( 'po_status', $po_id );
                if ( $current_status === 'partial_received' && function_exists( 'b2f_transition_order' ) ) {
                    b2f_transition_order( $po_id, 'received', 'admin', 'Write-off reject → all complete' );
                }
            }

            $result_data['new_total'] = $new_total;
            $result_data['all_complete'] = $all_done;
        }

        // Mark resolved
        update_field( 'rcv_reject_action', $action, $rcv_id );
        update_field( 'rcv_reject_resolved', 1, $rcv_id );
        if ( $note ) update_field( 'rcv_reject_note', $note, $rcv_id );

        // Push แจ้ง Maker ทุก action (text message สรุป)
        $action_label = $action_labels[ $action ] ?? $action;
        $text_msg = array( 'type' => 'text', 'text' => '📋 ' . $po_number . "\nQC Reject: " . $action_label . ( $note ? "\nหมายเหตุ: " . mb_substr( $note, 0, 100 ) : '' ) );
        if ( ! empty( $maker_group ) && function_exists( 'b2f_push_guaranteed' ) ) {
            b2f_push_guaranteed( $maker_group, $text_msg, $po_id, 'reject_resolve_maker' );
        }
        if ( ! empty( $admin_group ) && function_exists( 'b2f_push_guaranteed' ) ) {
            b2f_push_guaranteed( $admin_group, $text_msg, $po_id, 'reject_resolve_admin' );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Reject resolve: rcv=#%d action=%s po=%s note=%s', $rcv_id, $action, $po_number, $note ) );
        }

        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
        return new WP_REST_Response( array_merge( array( 'success' => true, 'rcv_id' => $rcv_id ), $result_data ), 200 );
    }
}

// ════════════════════════════════════════════
// GAP-05: PO COMPLETE (received → completed, ของฟรี/sample)
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_po_complete' ) ) {
    /**
     * POST /po-complete — Admin ปิด PO โดยไม่ต้องจ่ายเงิน (sample, ของฟรี)
     */
    function b2f_rest_po_complete( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );
        $note  = sanitize_textarea_field( $req->get_param( 'note' ) ?: 'ปิด PO — ไม่ต้องชำระ' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );
        if ( ! in_array( $current_status, array( 'received', 'paid', 'partial_paid' ), true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'PO ไม่อยู่ในสถานะที่ปิดได้', 'code' => 'INVALID_STATUS' ), 400 );
        }

        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'completed', 'admin', $note );
            if ( is_wp_error( $trans ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
            }
        } else {
            update_field( 'po_status', 'completed', $po_id );
        }

        update_field( 'po_admin_note', $note, $po_id );

        // Push Flex completed to both Admin and Maker
        $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $maker_group = $maker_id ? get_field( 'maker_line_group_id', $maker_id ) : '';
        if ( function_exists( 'b2f_build_flex_po_completed' ) ) {
            $flex = b2f_build_flex_po_completed( $po_id );
            if ( $flex ) {
                if ( ! empty( $maker_group ) ) b2f_line_push( $maker_group, array( $flex ) );
                if ( defined( 'B2B_ADMIN_GROUP_ID' ) ) b2f_line_push( B2B_ADMIN_GROUP_ID, array( $flex ) );
            }
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'PO completed (manual): #%d note=%s', $po_id, $note ) );
        }

        return new WP_REST_Response( array( 'success' => true, 'po_id' => $po_id, 'status' => 'completed' ), 200 );
    }
}



if ( ! function_exists( "b2f_rest_debug_models_v918" ) ) {
    function b2f_rest_debug_models_v918( WP_REST_Request $req ) {
        $key = $req->get_param( "key" );
        if ( $key !== "debug918htp" ) {
            return new WP_REST_Response( array( "error" => "forbidden" ), 403 );
        }
        $maker_id = intval( $req["maker_id"] );
        $q = new WP_Query( array(
            "post_type" => "b2f_maker_product",
            "posts_per_page" => -1,
            "post_status" => "publish",
            "meta_query" => array( array( "key" => "mp_maker_id", "value" => $maker_id, "type" => "NUMERIC" ) ),
        ) );
        $sku_relations = get_option( "dinoco_sku_relations", array() );
        $rel_upper = array();
        foreach ( $sku_relations as $p => $ch ) {
            $rel_upper[ strtoupper( $p ) ] = array_map( "strtoupper", (array) $ch );
        }
        $out = array();
        foreach ( $q->posts as $p ) {
            $sku = get_field( "mp_product_sku", $p->ID ) ?: "";
            $sku_u = strtoupper( $sku );
            $cat = class_exists( "DINOCO_Catalog" ) ? DINOCO_Catalog::get_by_sku( $sku ) : null;
            $cm_raw = $cat["compatible_models"] ?? null;
            $parsed = array();
            if ( is_string( $cm_raw ) ) {
                $dec = json_decode( $cm_raw, true );
                if ( is_array( $dec ) ) {
                    foreach ( $dec as $item ) {
                        if ( is_string( $item ) ) $parsed[] = $item;
                        elseif ( is_array( $item ) ) $parsed[] = ( $item["name"] ?? $item["model_name"] ?? $item["slug"] ?? "?" );
                    }
                }
            }
            $children = $rel_upper[ $sku_u ] ?? array();
            $out[] = array(
                "sku" => $sku,
                "name" => substr( $cat["name"] ?? $sku, 0, 80 ),
                "ui_role_override" => $cat["ui_role_override"] ?? "auto",
                "compatible_models_raw" => $cm_raw,
                "compatible_models_parsed" => $parsed,
                "children_count" => count( $children ),
                "children" => array_slice( $children, 0, 10 ),
            );
        }
        return new WP_REST_Response( array(
            "maker_id" => $maker_id,
            "total" => count( $out ),
            "products" => $out,
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_inject_virtual_all_sets_v920' ) ) {
    /**
     * V.10.2: Inject virtual SET entries (top-level AND intermediate) เข้า products[]
     *
     * Rationale (Issue #3):
     *   V.9.19 walked up จาก registered leaves ไปหา top-level SET (parent ที่ไม่มี parent อีก) เท่านั้น
     *   → intermediate sub-SETs (parent + has grandparent) ไม่ถูก inject
     *   → LIFF SET Detail `renderSetDetailItems()` ใช้ `productBySku[childSku]` lookup → miss → UI แสดงแค่
     *     "1 child + 2 grandchildren" แทน "2 children + 4 grandchildren" สำหรับ 3-level hierarchy
     *
     *   Example: DNCSETNX500E002 → [DNCNX500001B, DNCNX500E002B] → each → [-L, -R]
     *     HTP registered: DNCNX500001B + all L/R leaves (ไม่ register DNCNX500E002B intermediate)
     *     V.9.19 inject: DNCSETNX500E002 เท่านั้น (top-level)
     *     V.10.2 inject: DNCSETNX500E002 + DNCNX500E002B (ทุก non-registered parent ที่มี leaf descendant registered)
     *
     * Algorithm:
     *   1. สร้าง registered set จาก products[] (uppercase)
     *   2. สร้าง child→parents map (DD-3 shared child safe)
     *   3. collect candidate parents = ทุก key ใน rel_upper ที่ไม่ได้ registered
     *   4. For each candidate: walk descendants → ถ้ามี ≥1 leaf registered → inject virtual entry
     *   5. Preserve guards: auto_type='set', is_virtual=true, unit_cost=sum(registered leaf costs)
     *
     * Backward compat:
     *   - Called เฉพาะเมื่อ ?include_virtual=1 (LIFF only — Admin Makers ไม่ส่ง param)
     *   - Phase 3 junction path skip virtual inject (unchanged)
     *
     * @param array $products Registered maker products
     * @param array $rel_upper sku_relations ใน uppercase format
     * @return array $products + injected virtual SETs (top-level + intermediate)
     */
    function b2f_inject_virtual_all_sets_v920( $products, $rel_upper ) {
        if ( ! class_exists( 'DINOCO_Catalog' ) || empty( $rel_upper ) ) return $products;

        // Build registered SKU set (uppercase) + lookup index
        $registered = array();
        $product_idx = array();
        foreach ( $products as $p ) {
            $sku_u = strtoupper( $p['sku'] ?? '' );
            if ( $sku_u === '' ) continue;
            $registered[ $sku_u ] = true;
            $product_idx[ $sku_u ] = $p;
        }

        // Build reverse: child → parents (DD-3 shared child supported — ทุก parent ที่ pointer ไปหา child)
        $child_to_parents = array();
        foreach ( $rel_upper as $parent_u => $children ) {
            foreach ( $children as $ch_u ) {
                if ( ! isset( $child_to_parents[ $ch_u ] ) ) $child_to_parents[ $ch_u ] = array();
                $child_to_parents[ $ch_u ][] = $parent_u;
            }
        }

        // Helper: collect leaf descendants (value-copy visited per branch — DD-3 shared child safe)
        $collect_leaves = function( $sku_u, $visited ) use ( &$collect_leaves, $rel_upper ) {
            if ( isset( $visited[ $sku_u ] ) ) return array();
            $visited[ $sku_u ] = true;
            $children = isset( $rel_upper[ $sku_u ] ) ? $rel_upper[ $sku_u ] : array();
            if ( empty( $children ) ) return array( $sku_u );
            $leaves = array();
            foreach ( $children as $ch ) {
                $leaves = array_merge( $leaves, $collect_leaves( $ch, $visited ) );
            }
            return $leaves;
        };

        // V.10.2 change: walk ALL parent keys (both top-level AND intermediate)
        // - top-level: parent ที่ไม่มี key ใน $child_to_parents
        // - intermediate: parent ที่มี entry ใน $child_to_parents (is child of another parent) AND มี entry ใน rel_upper (is parent of children)
        // inject ถ้า parent NOT registered + มี ≥1 registered leaf descendant
        $candidate_parents = array();
        foreach ( array_keys( $rel_upper ) as $parent_u ) {
            if ( empty( $rel_upper[ $parent_u ] ) ) continue; // no children → not a SET
            if ( isset( $registered[ $parent_u ] ) ) continue; // already registered
            $candidate_parents[ $parent_u ] = true;
        }

        $added = array();
        foreach ( array_keys( $candidate_parents ) as $parent_u ) {
            // Collect all leaf descendants
            $leaves = array_unique( $collect_leaves( $parent_u, array() ) );

            $has_registered_leaf = false;
            $sum_cost = 0.0;
            $sum_land = 0.0;
            $sum_sea = 0.0;
            $registered_leaves = 0;
            $missing_leaves = array();

            foreach ( $leaves as $leaf_u ) {
                if ( isset( $product_idx[ $leaf_u ] ) ) {
                    $p = $product_idx[ $leaf_u ];
                    $lc = floatval( $p['unit_cost'] ?? 0 );
                    $ll = floatval( $p['shipping_land'] ?? 0 );
                    $ls = floatval( $p['shipping_sea'] ?? 0 );
                    if ( $lc > 0 ) {
                        $sum_cost += $lc;
                        $sum_land += $ll;
                        $sum_sea += $ls;
                        $registered_leaves++;
                        $has_registered_leaf = true;
                    }
                } else {
                    $missing_leaves[] = $leaf_u;
                }
            }

            if ( ! $has_registered_leaf ) continue;

            // Fetch parent data จาก Product Catalog
            $cat = DINOCO_Catalog::get_by_sku( $parent_u );
            if ( ! $cat ) continue;

            // Determine top-level parent (walk up for hierarchy metadata)
            // Support DD-3 shared child — ใช้ parent ตัวแรก (deterministic)
            $top_sku = $parent_u;
            $visited = array();
            $walk_top = function( $sku_u ) use ( &$walk_top, $child_to_parents, &$visited, &$top_sku ) {
                if ( isset( $visited[ $sku_u ] ) ) return;
                $visited[ $sku_u ] = true;
                $parents = isset( $child_to_parents[ $sku_u ] ) ? $child_to_parents[ $sku_u ] : array();
                if ( empty( $parents ) ) {
                    $top_sku = $sku_u;
                    return;
                }
                $walk_top( $parents[0] );
            };
            $walk_top( $parent_u );
            $top_cat = ( $top_sku !== $parent_u && class_exists( 'DINOCO_Catalog' ) )
                ? DINOCO_Catalog::get_by_sku( $top_sku )
                : $cat;

            // parent_skus for intermediate = all immediate parents (DD-3 safe)
            $my_parents = isset( $child_to_parents[ $parent_u ] ) ? $child_to_parents[ $parent_u ] : array();
            $immediate_parent_sku = ! empty( $my_parents ) ? $my_parents[0] : '';
            $immediate_parent_name = '';
            if ( $immediate_parent_sku !== '' && class_exists( 'DINOCO_Catalog' ) ) {
                $pcat = DINOCO_Catalog::get_by_sku( $immediate_parent_sku );
                if ( $pcat && ! empty( $pcat['name'] ) ) $immediate_parent_name = $pcat['name'];
            }

            $added[] = array(
                'id'               => 0,
                'maker_id'         => $products[0]['maker_id'] ?? 0,
                'sku'              => $cat['sku'] ?? $parent_u,
                'name'             => $cat['name'] ?? $parent_u,
                'product_name'     => $cat['name'] ?? $parent_u,
                'image_url'        => $cat['image_url'] ?? '',
                'unit_cost'        => $sum_cost,
                'unit_cost_computed' => true,
                'unit_cost_complete' => empty( $missing_leaves ),
                'unit_cost_leaf_count' => $registered_leaves,
                'unit_cost_missing' => $missing_leaves,
                'moq'              => 1,
                'lead_time_days'   => 7,
                'shipping_land'    => $sum_land,
                'shipping_sea'     => $sum_sea,
                'status'           => 'active',
                'currency'         => $products[0]['currency'] ?? 'THB',
                'currency_symbol'  => $products[0]['currency_symbol'] ?? '฿',
                'is_set'           => true,
                'is_leaf'          => false,
                // V.10.2: classification — intermediate = 'child' (has parent), top-level = 'set' (no parent)
                'product_type'     => empty( $my_parents ) ? 'set' : 'child',
                'auto_type'        => empty( $my_parents ) ? 'set' : 'child',
                'children_count'   => count( $rel_upper[ $parent_u ] ?? array() ),
                'direct_children_count' => count( $rel_upper[ $parent_u ] ?? array() ),
                'grandchildren_total' => 0,
                'parent_sku'       => $immediate_parent_sku,
                'parent_skus'      => $my_parents,
                'parent_name'      => $immediate_parent_name,
                'grandparent_sku'  => '',
                'top_parent_sku'   => $top_cat ? ( $top_cat['sku'] ?? $top_sku ) : $top_sku,
                'top_parent_name'  => $top_cat ? ( $top_cat['name'] ?? '' ) : '',
                'compatible_models' => $cat['compatible_models'] ?? '[]',
                'category'         => $cat['category'] ?? '',
                'is_virtual'       => true, // V.9.19/V.10.2 marker
                // V.10.4: virtual_reason — frontend ใช้ filter toggle
                //   - shared_parts_assembled: top-level SET (ไม่มี parent) — ประกอบจากชิ้นส่วนที่ shared ข้าม SETs → default hide
                //   - intermediate_sub_set: sub-SET ที่มี grandparent — จำเป็นสำหรับ SET Detail hierarchy display → always show
                'virtual_reason'   => empty( $my_parents ) ? 'shared_parts_assembled' : 'intermediate_sub_set',
            );
        }

        return array_merge( $products, $added );
    }
}

if ( ! function_exists( 'b2f_inject_virtual_sets_v919' ) ) {
    /**
     * V.9.19 legacy wrapper — delegates to V.10.2 `b2f_inject_virtual_all_sets_v920()`.
     * Preserved for any external caller that may reference the old name.
     */
    function b2f_inject_virtual_sets_v919( $products, $rel_upper ) {
        return b2f_inject_virtual_all_sets_v920( $products, $rel_upper );
    }
