if ( ! function_exists( 'b2f_rest_maker_reschedule' ) ) {
    /**
     * POST /maker-reschedule — Maker ขอเลื่อนวันส่ง
     * Body: { token, new_date, reason }
     */
    function b2f_rest_maker_reschedule( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
        }

        $po_id    = $jwt['po_id'];
        $maker_id = $jwt['maker_id'];
        $new_date = sanitize_text_field( $req->get_param( 'new_date' ) ?: '' );
        $reason   = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        if ( empty( $new_date ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณากรอกวันที่ใหม่', 'code' => 'MISSING_DATE' ), 400 );
        }

        $date_ts  = strtotime( $new_date );
        $today_ts = strtotime( wp_date( 'Y-m-d' ) );
        if ( $date_ts === false || $date_ts <= $today_ts ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'วันที่ใหม่ต้องเป็นวันในอนาคต', 'code' => 'INVALID_DATE' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $po_maker = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        if ( $po_maker !== $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีสิทธิ์เข้าถึง PO นี้', 'code' => 'FORBIDDEN' ), 403 );
        }

        // Save reschedule request as post meta (pending approval)
        $reschedule_data = array(
            'new_date'     => $new_date,
            'reason'       => $reason,
            'requested_at' => wp_date( 'Y-m-d H:i:s' ),
            'status'       => 'pending',
            'old_date'     => get_field( 'po_expected_date', $po_id ) ?: '',
        );

        // Append to reschedule history
        $history = get_post_meta( $po_id, '_b2f_reschedule_history', true ) ?: array();
        $history[] = $reschedule_data;
        update_post_meta( $po_id, '_b2f_reschedule_history', $history );
        update_post_meta( $po_id, '_b2f_pending_reschedule', $reschedule_data );

        // Push Flex to Admin for approval
        if ( function_exists( 'b2f_build_flex_reschedule_request' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
            $flex = b2f_build_flex_reschedule_request( $po_id, $new_date, $reason );
