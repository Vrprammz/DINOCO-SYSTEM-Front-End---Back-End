        // Flex Admin (เพิ่ม "โดย") — always Thai
        $admin_body = $cancel_body_admin;
        $admin_body[] = array( 'type' => 'text', 'text' => 'ยกเลิกโดย: ' . $cancelled_by, 'size' => 'xs', 'color' => '#94a3b8', 'margin' => 'sm' );
        if ( $stock_reversed > 0 ) {
            $admin_body[] = array( 'type' => 'text', 'text' => 'คืนสต็อก: ' . $stock_reversed . ' ชิ้น', 'size' => 'xs', 'color' => '#f59e0b', 'margin' => 'xs' );
        }
        $flex_admin = array( 'type' => 'flex', 'altText' => '❌ ยกเลิกใบสั่งซื้อ ' . $po_number,
            'contents' => array( 'type' => 'bubble', 'size' => 'mega',
                'header' => array( 'type' => 'box', 'layout' => 'vertical', 'backgroundColor' => '#0a0a0a', 'paddingAll' => '16px',
                    'contents' => array( array( 'type' => 'box', 'layout' => 'horizontal', 'alignItems' => 'center', 'contents' => array(
                        array( 'type' => 'image', 'url' => $logo_url, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                        array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                            array( 'type' => 'text', 'text' => '❌ ยกเลิกใบสั่งซื้อ', 'weight' => 'bold', 'color' => '#ffffff', 'size' => 'md' ),
                            array( 'type' => 'text', 'text' => $po_number, 'color' => '#f87171', 'size' => 'xs', 'margin' => 'xs' ) ) ) ) ) ) ),
                'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $admin_body ) ) );

        // → Push
        $push_maker = false;
        $push_admin = false;
        if ( ! empty( $maker_group ) && function_exists( 'b2f_line_push' ) ) {
            $push_maker = b2f_line_push( $maker_group, array( $flex_maker ) );
        }
        if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2f_line_push' ) ) {
            $push_admin = b2f_line_push( B2B_ADMIN_GROUP_ID, array( $flex_admin ) );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'PO CANCELLED: %s (#%d) reason=%s stock_reversed=%d rollback=%s by=%s',
                $po_number, $po_id, $reason, $stock_reversed, wp_json_encode( $rollback_info ), $cancelled_by
            ) );
        }

        $resp = array(
            'success'        => true,
            'po_id'          => $po_id,
            'action'         => 'cancelled',
            'po_number'      => $po_number,
            'stock_reversed' => $stock_reversed,
            'push_maker'     => $push_maker ? 'sent' : ( empty( $maker_group ) ? 'no_group' : 'failed' ),
            'push_admin'     => $push_admin ? 'sent' : ( ! defined( 'B2B_ADMIN_GROUP_ID' ) ? 'no_config' : 'failed' ),
        );
        if ( ! empty( $rollback_info ) ) {
            $resp['rollback'] = $rollback_info;
        }

        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $cancel_lock ) );

        return new WP_REST_Response( $resp, 200 );
    }
}

// ════════════════════════════════════════════
// 8B. V.11.0 — PO UNDO SUBMIT (HIGH-3)
// 30-second undo window using DB clock + FOR UPDATE lock + FSM transition.
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_po_undo_submit' ) ) {
    /**
     * POST /b2f/v1/po-undo-submit
     * Body: { po_id, confirm?:true }
     * Auth: dual (WP admin session OR X-B2F-Token admin JWT) — enforced by $admin_perm callback
     * Atomicity: START TRANSACTION + FOR UPDATE on PO row
     * Time window: post_date > NOW() - INTERVAL 30 SECOND (DB clock — prevents PHP time drift)
     *
     * Response 200: { success, data: { fsm_transition: {from,to}, refunded_credit, stock_restored[] } }
     * Error codes:
     *   - 410 undo_window_expired (past 30 sec)
     *   - 409 already_cancelled (idempotent-safe — return current state + already_cancelled:true)
     *   - 404 not_found
     *   - 500 undo_failed (internal)
     *
     * Integration: reuses po-cancel path for stock restore + credit refund (single transition
     * point for cancel semantics). Difference is ONLY the caller-facing affordance + 30sec gate.
     */
    function b2f_rest_po_undo_submit( WP_REST_Request $req ) {
        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );

        if ( ! $po_id ) {
            return new WP_REST_Response( array(
                'success' => false,
                'error'   => 'ไม่ระบุ PO',
                'code'    => 'MISSING_PO',
            ), 400 );
        }

        // Rate limit: 10 undo attempts per user per minute (prevent spam)
        $user_id = get_current_user_id();
        $rl = b2f_rate_limit( 'po_undo_submit_' . $user_id, 10, 60 );
        if ( is_wp_error( $rl ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'error'   => $rl->get_error_message(),
                'code'    => 'RATE_LIMIT',
            ), 429 );
        }

        global $wpdb;

        // W1 — MySQL named lock (same pattern as po-cancel) prevents concurrent undo+cancel+receive
        $undo_lock = 'b2f_recv_' . intval( $po_id );
        $got_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 3)", $undo_lock ) );
        if ( ! $got_lock ) {
            return new WP_REST_Response( array(
                'success' => false,
                'error'   => 'มีคนอื่นกำลังดำเนินการอยู่',
                'code'    => 'LOCKED',
            ), 423 );
        }

        // Begin transaction — START TRANSACTION + FOR UPDATE lock on PO row
        $wpdb->query( 'START TRANSACTION' );

        try {
            // FOR UPDATE lock on posts row + fetch post_date_gmt for DB clock window check
            // Single SQL reads: post_type validation + DB-clock age check + row lock
            // V.11.7 BUG-H5: SELECT post_date_gmt (UTC) instead of post_date (non-GMT)
            //   post_date = WP server-local TZ (may be Asia/Bangkok or whatever admin set) →
            //   exposing it in error response caused TZ confusion ("30-second window" feels wrong
            //   when client-side JS compares against UTC clock). post_date_gmt is ISO-8601 UTC,
            //   pairs cleanly with the DB-clock check (UTC_TIMESTAMP()) + `_tz_hint: 'UTC'` flag.
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT ID, post_type, post_date_gmt,
                        ( post_date_gmt > ( UTC_TIMESTAMP() - INTERVAL 30 SECOND ) ) AS within_window
                   FROM {$wpdb->posts}
                  WHERE ID = %d
                  FOR UPDATE",
                $po_id
            ) );

            if ( ! $row ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => 'ไม่พบ PO',
                    'code'    => 'NOT_FOUND',
                ), 404 );
            }
            if ( $row->post_type !== 'b2f_order' ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => 'ไม่พบ PO',
                    'code'    => 'NOT_FOUND',
                ), 404 );
            }

            // Idempotent: if already cancelled → return success + flag (not an error)
            $current_status = get_field( 'po_status', $po_id );
            if ( $current_status === 'cancelled' ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );
                return new WP_REST_Response( array(
                    'success' => true,
                    'data'    => array(
                        'already_cancelled' => true,
                        'current_status'    => 'cancelled',
                    ),
                ), 200 );
            }

            // Time window check (DB clock — server time authoritative)
            // V.11.7 BUG-H5: expose post_date_gmt (UTC ISO-8601) + _tz_hint instead of non-GMT post_date.
            //   post_date_gmt is guaranteed populated by wp_insert_post() for b2f_order CPT
            //   (WP core inserts GMT timestamp when post_status in [publish, private, future]).
            //   Fallback: if somehow NULL (shouldn't happen for b2f_order), emit current_time UTC
            //   to keep client parser happy rather than exposing null.
            if ( ! (int) $row->within_window ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );
                $post_date_gmt = ! empty( $row->post_date_gmt ) && $row->post_date_gmt !== '0000-00-00 00:00:00'
                    ? $row->post_date_gmt
                    : current_time( 'mysql', true );
                return new WP_REST_Response( array(
                    'success'       => false,
                    'error'         => 'เลยเวลายกเลิกแล้ว (ภายใน 30 วินาทีเท่านั้น)',
                    'code'          => defined( 'B2F_ERR_UNDO_WINDOW_EXPIRED' ) ? B2F_ERR_UNDO_WINDOW_EXPIRED : 'undo_window_expired',
                    'post_date_gmt' => $post_date_gmt,
                    '_tz_hint'      => 'UTC',
                ), 410 );
            }

            // FSM transition → cancelled (source = 'user_undo_within_30s' for audit)
            $from_status = $current_status ?: 'draft';
            if ( function_exists( 'b2f_transition_order' ) ) {
                $fsm_result = b2f_transition_order( $po_id, 'cancelled', 'admin', 'user_undo_within_30s' );
                if ( is_wp_error( $fsm_result ) ) {
                    $wpdb->query( 'ROLLBACK' );
                    $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );
                    return new WP_REST_Response( array(
                        'success' => false,
                        'error'   => $fsm_result->get_error_message(),
                        'code'    => 'FSM_REJECTED',
                    ), 400 );
                }
            } else {
                update_field( 'po_status', 'cancelled', $po_id );
            }

            // Audit metadata
            $cancelled_by = 'Admin (Undo)';
            $uid = get_current_user_id();
            if ( $uid ) { $u = get_user_by( 'id', $uid ); if ( $u ) $cancelled_by = $u->display_name . ' (Undo)'; }
            update_field( 'po_cancelled_reason', 'user_undo_within_30s', $po_id );
            update_field( 'po_cancelled_by', $cancelled_by, $po_id );
            $tz = new DateTimeZone( 'Asia/Bangkok' );
            update_field( 'po_cancelled_date', ( new DateTime( 'now', $tz ) )->format( 'Y-m-d' ), $po_id );

            // Stock restore — undo-within-30s should never have receivings yet, but reuse po-cancel
            // pattern defensively in case admin managed to click receive within 30sec window.
            $stock_restored = array();
            if ( function_exists( 'dinoco_stock_subtract' ) ) {
                $receivings = get_posts( array(
                    'post_type'      => 'b2f_receiving',
                    'meta_query'     => array( array( 'key' => 'rcv_po_id', 'value' => $po_id ) ),
                    'posts_per_page' => -1,
                    'post_status'    => 'any',
                ) );
                foreach ( $receivings as $rcv ) {
                    $rcv_items = get_field( 'rcv_items', $rcv->ID );
                    if ( ! $rcv_items || ! is_array( $rcv_items ) ) continue;
                    foreach ( $rcv_items as $ri ) {
                        $r_sku = $ri['rcvi_sku'] ?? '';
                        $r_qty = intval( $ri['rcvi_qty_received'] ?? 0 );
                        if ( $r_sku && $r_qty > 0 ) {
                            $po_number_for_log = get_field( 'po_number', $po_id ) ?: ( 'PO-' . $po_id );
                            dinoco_stock_subtract( $r_sku, $r_qty, 'b2f_undo_submit', 'b2f_order', $po_id, 'B2F Undo ' . $po_number_for_log );
                            $stock_restored[] = array( 'sku' => $r_sku, 'qty' => $r_qty );
                        }
                    }
                }
            }

            // Credit refund — recalculate payable (same pattern as po-cancel)
            $maker_id = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
            $refunded_credit = 0;
            if ( function_exists( 'b2f_recalculate_payable' ) && $maker_id > 0 ) {
                $old_debt = floatval( get_field( 'maker_current_debt', $maker_id ) ?: 0 );
                $new_debt = b2f_recalculate_payable( $maker_id );
                $refunded_credit = round( max( 0, $old_debt - $new_debt ), 2 );
            }

            $wpdb->query( 'COMMIT' );

            if ( function_exists( 'b2f_log' ) ) {
                $po_number = get_field( 'po_number', $po_id ) ?: ( 'PO-' . $po_id );
                b2f_log( sprintf(
                    '[V.11.0] PO undo-submit: %s (#%d) from=%s → cancelled by=%s (within 30s window, stock_restored=%d items)',
                    $po_number, $po_id, $from_status, $cancelled_by, count( $stock_restored )
                ) );
            }

            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );

            return new WP_REST_Response( array(
                'success' => true,
                'data'    => array(
                    'po_id'            => $po_id,
                    'fsm_transition'   => array( 'from' => $from_status, 'to' => 'cancelled' ),
                    'refunded_credit'  => $refunded_credit,
                    'stock_restored'   => $stock_restored,
                    'cancelled_reason' => 'user_undo_within_30s',
                ),
            ), 200 );
        } catch ( Exception $e ) {
            $wpdb->query( 'ROLLBACK' );
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $undo_lock ) );
            if ( function_exists( 'b2f_log' ) ) {
                b2f_log( '[V.11.0] undo-submit failed for PO #' . $po_id . ': ' . $e->getMessage() );
            }
            return new WP_REST_Response( array(
                'success' => false,
                'error'   => 'ยกเลิกไม่สำเร็จ: ' . $e->getMessage(),
                'code'    => 'undo_failed',
            ), 500 );
        }
    }
}

// ════════════════════════════════════════════
// 9. MAKER ACTION ENDPOINTS (JWT AUTH)
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_maker_confirm' ) ) {
    /**
     * POST /maker-confirm — Maker ยืนยัน PO + ETA
     * Body: { token, expected_date, note? }
     * Response: { success, po_id, status: "confirmed" }
     */
    function b2f_rest_maker_confirm( WP_REST_Request $req ) {
        // Rate limit: 5 req/min per token
        $token_hash = md5( $req->get_param( 'token' ) ?: '' );
        $rl = b2f_rate_limit( 'maker_confirm_' . $token_hash, 5, 60 );
        if ( is_wp_error( $rl ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $rl->get_error_message(), 'code' => 'RATE_LIMIT' ), 429 );
        }

        // Verify JWT
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
        }

        $po_id    = $jwt['po_id'];
        $maker_id = $jwt['maker_id'];

        // V.7.3: i18n error messages
        $po_currency = get_field( 'po_currency', $po_id ) ?: ( get_field( 'maker_currency', $maker_id ) ?: 'THB' );
        $cur = $po_currency ?: 'THB';
        $is_eng = $cur !== 'THB';

        // Verify PO exists and belongs to maker
        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่พบ PO', 'PO not found', '未找到订单', $cur), 'code' => 'NOT_FOUND' ), 404 );
        }

        $po_maker = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        if ( $po_maker !== $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่มีสิทธิ์เข้าถึง PO นี้', 'You do not have access to this PO', '您无权访问此订单', $cur), 'code' => 'FORBIDDEN' ), 403 );
        }

        $current_status = get_field( 'po_status', $po_id );
        if ( $current_status === 'cancelled' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ใบสั่งซื้อนี้ถูกยกเลิกแล้ว', 'This PO has been cancelled', '此订单已取消', $cur), 'code' => 'PO_CANCELLED' ), 400 );
        }

        // Validate expected_date
        $expected_date = sanitize_text_field( $req->get_param( 'expected_date' ) ?: '' );
        if ( empty( $expected_date ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('กรุณากรอกวันที่คาดว่าจะส่ง', 'Please specify delivery date', '请指定交货日期', $cur), 'code' => 'MISSING_DATE' ), 400 );
        }

        $date_ts  = strtotime( $expected_date );
        $today_ts = strtotime( wp_date( 'Y-m-d' ) );
        if ( $date_ts === false || $date_ts <= $today_ts ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('วันส่งต้องเป็นวันในอนาคต', 'Delivery date must be in the future', '交货日期必须是未来日期', $cur), 'code' => 'INVALID_DATE' ), 400 );
        }

        // Transition
        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'confirmed', 'maker', 'Maker confirmed with ETA' );
            if ( is_wp_error( $trans ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
            }
        } else {
            update_field( 'po_status', 'confirmed', $po_id );
        }

        update_field( 'po_expected_date', $expected_date, $po_id );

        $note = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );
        if ( ! empty( $note ) ) {
            update_field( 'po_maker_note', $note, $po_id );
        }

        // Push Flex to Admin
        if ( function_exists( 'b2f_build_flex_maker_confirmed' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
            $flex = b2f_build_flex_maker_confirmed( $po_id, $expected_date );
            if ( $flex ) b2f_line_push( B2B_ADMIN_GROUP_ID, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'Maker confirmed: %s (#%d) ETA=%s', $po_number, $po_id, $expected_date ) );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'po_id'   => $po_id,
            'status'  => 'confirmed',
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_maker_reject' ) ) {
    /**
     * POST /maker-reject — Maker ปฏิเสธ PO
     * Body: { token, reason }
     * Response: { success, po_id, status: "rejected" }
     */
    function b2f_rest_maker_reject( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
        }

        $po_id    = $jwt['po_id'];
        $maker_id = $jwt['maker_id'];
        $reason   = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        // V.7.3: i18n error messages
        $po_currency = get_field( 'po_currency', $po_id ) ?: ( get_field( 'maker_currency', $maker_id ) ?: 'THB' );
        $cur = $po_currency ?: 'THB';
        $is_eng = $cur !== 'THB';

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่พบ PO', 'PO not found', '未找到订单', $cur), 'code' => 'NOT_FOUND' ), 404 );
        }

        $po_maker = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        if ( $po_maker !== $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่มีสิทธิ์เข้าถึง PO นี้', 'You do not have access to this PO', '您无权访问此订单', $cur), 'code' => 'FORBIDDEN' ), 403 );
        }

        $current_status = get_field( 'po_status', $po_id );
        if ( $current_status === 'cancelled' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ใบสั่งซื้อนี้ถูกยกเลิกแล้ว', 'This PO has been cancelled', '此订单已取消', $cur), 'code' => 'PO_CANCELLED' ), 400 );
        }

        // Transition
        if ( function_exists( 'b2f_transition_order' ) ) {
            $trans = b2f_transition_order( $po_id, 'rejected', 'maker', $reason );
            if ( is_wp_error( $trans ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $trans->get_error_message(), 'code' => 'TRANSITION_FAILED' ), 400 );
            }
        } else {
            update_field( 'po_status', 'rejected', $po_id );
        }

        update_field( 'po_rejected_reason', $reason, $po_id );

        // Push Flex to Admin
        if ( function_exists( 'b2f_build_flex_maker_rejected' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
            $flex = b2f_build_flex_maker_rejected( $po_id, $reason );
            if ( $flex ) b2f_line_push( B2B_ADMIN_GROUP_ID, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'Maker rejected: %s (#%d) reason=%s', $po_number, $po_id, $reason ) );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'po_id'   => $po_id,
            'status'  => 'rejected',
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_maker_reschedule' ) ) {
    /**
     * POST /maker-reschedule — Maker ขอเลื่อนวันส่ง
     * Body: { token, new_date, reason }
     */
    function b2f_rest_maker_reschedule( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
        }

        // V.4.6: fallback po_id from request param (LIFF list → JWT ไม่มี po_id)
        $po_id    = ! empty( $jwt['po_id'] ) ? intval( $jwt['po_id'] ) : intval( $req->get_param( 'po_id' ) ?: 0 );
        $maker_id = $jwt['maker_id'];
        $new_date = sanitize_text_field( $req->get_param( 'new_date' ) ?: '' );
        $reason   = sanitize_textarea_field( $req->get_param( 'reason' ) ?: '' );

        // V.7.3: i18n error messages — detect from maker_currency first (po_id may be 0)
        $mc = get_field( 'maker_currency', $maker_id ) ?: 'THB';
        $cur = $mc ?: 'THB';
        $is_eng = $cur !== 'THB';

        if ( empty( $new_date ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('กรุณากรอกวันที่ใหม่', 'Please specify new date', '请指定新日期', $cur), 'code' => 'MISSING_DATE' ), 400 );
        }

        $date_ts  = strtotime( $new_date );
        $today_ts = strtotime( wp_date( 'Y-m-d' ) );
        if ( $date_ts === false || $date_ts <= $today_ts ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('วันที่ใหม่ต้องเป็นวันในอนาคต', 'New date must be in the future', '新日期必须是未来日期', $cur), 'code' => 'INVALID_DATE' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่พบ PO', 'PO not found', '未找到订单', $cur), 'code' => 'NOT_FOUND' ), 404 );
        }

        $po_maker = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        if ( $po_maker !== $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่มีสิทธิ์เข้าถึง PO นี้', 'You do not have access to this PO', '您无权访问此订单', $cur), 'code' => 'FORBIDDEN' ), 403 );
        }

        // Save reschedule request as post meta (pending approval)
        $reschedule_data = array(
            'new_date'     => $new_date,
            'reason'       => $reason,
            'requested_at' => wp_date( 'Y-m-d H:i:s' ),
            'status'       => 'pending',
            'old_date'     => get_field( 'po_expected_date', $po_id ) ?: '',
        );

        // Append to reschedule history
        $history = get_post_meta( $po_id, '_b2f_reschedule_history', true ) ?: array();
        $history[] = $reschedule_data;
        update_post_meta( $po_id, '_b2f_reschedule_history', $history );
        update_post_meta( $po_id, '_b2f_pending_reschedule', $reschedule_data );

        // Push Flex to Admin for approval
        if ( function_exists( 'b2f_build_flex_reschedule_request' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
            $flex = b2f_build_flex_reschedule_request( $po_id, $new_date, $reason );
            if ( $flex ) b2f_line_push( B2B_ADMIN_GROUP_ID, $flex );
        }

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'Maker reschedule request: %s (#%d) new_date=%s reason=%s', $po_number, $po_id, $new_date, $reason ) );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'po_id'   => $po_id,
            'message' => b2f_t('ส่งคำขอเลื่อนวันส่งแล้ว รอ Admin อนุมัติ', 'Reschedule request submitted. Pending admin approval.', '延期申请已提交，等待管理员批准。', $cur),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_maker_po_list' ) ) {
    /**
     * GET /maker-po-list — Maker ดู PO ของตัวเอง (JWT auth)
     * Params: ?token=<JWT>&status=all|submitted|confirmed|...
     */
    function b2f_rest_maker_po_list( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message(), 'code' => $jwt->get_error_code() ), $status );
        }

        $maker_id      = $jwt['maker_id'];
        $status_filter = sanitize_text_field( $req->get_param( 'status' ) ?: 'all' );

        $args = array(
            'post_type'      => 'b2f_order',
            'posts_per_page' => 50,
            'post_status'    => 'publish',
            'orderby'        => 'date',
            'order'          => 'DESC',
            'meta_query'     => array( array(
                'key'   => 'po_maker_id',
                'value' => $maker_id,
                'type'  => 'NUMERIC',
            ) ),
        );

        if ( $status_filter !== 'all' ) {
            // Support comma-separated statuses (e.g. "confirmed,partial_received")
            if ( strpos( $status_filter, ',' ) !== false ) {
                $statuses = array_map( 'trim', explode( ',', $status_filter ) );
                $args['meta_query'][] = array(
                    'key'     => 'po_status',
                    'value'   => $statuses,
                    'compare' => 'IN',
                );
            } else {
                $args['meta_query'][] = array(
                    'key'   => 'po_status',
                    'value' => $status_filter,
                );
            }
        }

        $q       = new WP_Query( $args );
        $po_list = array();

        foreach ( $q->posts as $p ) {
            $po_list[] = b2f_format_po_detail( $p->ID, false );
        }

        // V.7.4: เพิ่ม maker_currency ใน response สำหรับ LIFF LANG detection
        $maker_currency = get_field( 'maker_currency', $maker_id ) ?: 'THB';

        return new WP_REST_Response( array(
            'success'        => true,
            'total'          => $q->found_posts,
            'maker_currency' => $maker_currency,
            'data'           => $po_list,
            'orders'         => $po_list, // backward compat
        ), 200 );
    }
}

// ════════════════════════════════════════════
