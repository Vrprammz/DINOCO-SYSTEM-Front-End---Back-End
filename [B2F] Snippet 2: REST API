add_action( 'rest_api_init', function () {

    $ns = 'b2f/v1';

    // ── Admin permission check (WP session OR B2F admin token) ──
    $admin_perm = function ( WP_REST_Request $req ) {
        // Layer 1: WP admin session (PC browser / Admin Dashboard)
        if ( wp_verify_nonce( $req->get_header( 'X-WP-Nonce' ), 'wp_rest' ) && current_user_can( 'manage_options' ) ) {
            return true;
        }
        // Layer 2: B2F Admin token (LIFF context — no WP session)
        if ( function_exists( 'b2f_verify_admin_token' ) ) {
            $session = b2f_verify_admin_token( $req );
            if ( $session && ! empty( $session['is_admin'] ) ) return true;
        }
        return false;
    };

    // ── Maker JWT permission (CRIT-06 fix: verify JWT ใน permission_callback) ──
    $maker_perm = function ( WP_REST_Request $req ) {
        // Admin session ก็เข้าได้ (เช่น po-detail)
        if ( wp_verify_nonce( $req->get_header( 'X-WP-Nonce' ), 'wp_rest' ) && current_user_can( 'manage_options' ) ) {
            return true;
        }
        // B2F Admin token (LIFF)
        if ( function_exists( 'b2f_verify_admin_token' ) ) {
            $session = b2f_verify_admin_token( $req );
            if ( $session && ! empty( $session['is_admin'] ) ) return true;
        }
        // Maker JWT
        if ( function_exists( 'b2f_verify_maker_jwt' ) ) {
            $jwt = b2f_verify_maker_jwt( $req );
            if ( ! is_wp_error( $jwt ) ) return true;
        }
        return new WP_Error( 'rest_forbidden', 'Unauthorized', array( 'status' => 401 ) );
    };

    // ── Maker CRUD (admin only) ──
    register_rest_route( $ns, '/makers', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_list_makers',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_save_maker',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker/delete', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_delete_maker',
        'permission_callback' => $admin_perm,
    ) );

    // ── Maker Product CRUD (admin only) ──
    register_rest_route( $ns, '/maker-products/(?P<maker_id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_list_maker_products',
        'permission_callback' => $admin_perm,
    ) );

    register_rest_route( $ns, '/maker-product', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_save_maker_product',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker-product/delete', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_delete_maker_product',
        'permission_callback' => $admin_perm,
    ) );

    // ── Maker Bot Toggle ──
    register_rest_route( $ns, '/maker/toggle-bot', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_toggle_maker_bot',
        'permission_callback' => $admin_perm,
    ) );

    // ── PO Management (admin only) ──
    register_rest_route( $ns, '/create-po', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_create_po',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/po-detail/(?P<po_id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_po_detail',
        'permission_callback' => $maker_perm, // admin OR maker JWT — verified inside callback
    ) );
    // Maker LIFF: po-detail by JWT token (ไม่ต้องรู้ po_id ล่วงหน้า)
    register_rest_route( $ns, '/po-detail/jwt', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_po_detail_jwt',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/po-update', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_po_update',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/po-cancel', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_po_cancel',
        'permission_callback' => $admin_perm,
    ) );

    // ── V.11.0 HIGH-3: Undo submit within 30 seconds ──
    //   dual-auth (WP nonce OR X-B2F-Token admin JWT) + DB clock check + FOR UPDATE lock
    register_rest_route( $ns, '/po-undo-submit', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_po_undo_submit',
        'permission_callback' => $admin_perm,
    ) );

    // ── Maker Actions (JWT auth) ──
    register_rest_route( $ns, '/maker-confirm', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_confirm',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-reject', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_reject',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-reschedule', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_reschedule',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-po-list', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_maker_po_list',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-deliver', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_deliver',
        'permission_callback' => $maker_perm,
    ) );

    // ── Admin Actions ──
    register_rest_route( $ns, '/approve-reschedule', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_approve_reschedule',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/receive-goods', array(
