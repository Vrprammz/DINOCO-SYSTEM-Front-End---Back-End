if ( ! function_exists( 'b2f_rest_record_payment' ) ) {
    /**
     * POST /record-payment — บันทึกจ่ายเงิน Maker (FormData with slip)
     *
     * FormData fields:
     *   po_id       (int)
     *   amount      (float, > 0)
     *   date        (Y-m-d)
     *   method      (transfer|cheque|cash)
     *   reference   (string)
     *   slip_image  (file, optional)
     *   note        (string)
     *
     * Response: { success, pmt_id, payment_status, remaining, po_status }
     * Error codes: OVERPAYMENT, NOT_PAYABLE, INVALID_AMOUNT, INVALID_METHOD
     */
    function b2f_rest_record_payment( WP_REST_Request $req ) {
        $po_id  = intval( $req->get_param( 'po_id' ) ?: 0 );
        $amount = floatval( $req->get_param( 'amount' ) ?: 0 );
        $date   = sanitize_text_field( $req->get_param( 'date' ) ?: wp_date( 'Y-m-d' ) );
        $method = sanitize_text_field( $req->get_param( 'method' ) ?: 'transfer' );
        $ref    = sanitize_text_field( $req->get_param( 'reference' ) ?: '' );
        $note   = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }
        if ( $amount <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'จำนวนเงินต้องมากกว่า 0', 'code' => 'INVALID_AMOUNT' ), 400 );
        }
        if ( ! in_array( $method, array( 'transfer', 'cheque', 'cash' ), true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'วิธีจ่ายไม่ถูกต้อง', 'code' => 'INVALID_METHOD' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        // FIX-2a: MySQL GET_LOCK ป้องกัน concurrent payment (เหมือน receive-goods)
        $pmt_lock_key = 'b2f_pmt_' . intval( $po_id );
        global $wpdb;
        $got_pmt_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 0)", $pmt_lock_key ) );
        if ( ! $got_pmt_lock ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'มีคนอื่นกำลังบันทึกจ่ายเงิน PO นี้อยู่ กรุณารอสักครู่', 'code' => 'LOCKED' ), 423 );
        }

        // FIX-2b: Idempotency — ป้องกันกดซ้ำภายใน 10 วินาที
        $idem_key = 'b2f_pmt_idem_' . $po_id . '_' . md5( $amount . $method . $date );
        if ( get_transient( $idem_key ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $pmt_lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'คำขอซ้ำ กรุณารอสักครู่', 'code' => 'DUPLICATE' ), 409 );
        }
        set_transient( $idem_key, 1, 10 );

        $current_status = get_field( 'po_status', $po_id );
        // BUG-3 fix: ลบ partial_received — FSM ไม่มี transition partial_received→paid
        // Admin ต้องรอรับครบก่อนจ่ายเงิน (received/partial_paid)
        $payable_statuses = array( 'received', 'partial_paid' );
        if ( ! in_array( $current_status, $payable_statuses, true ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $pmt_lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่สามารถบันทึกการจ่ายเงินในสถานะนี้', 'code' => 'NOT_PAYABLE' ), 400 );
        }

        // G-08 fix: ใช้ received value จริง (SUM rcv_total_value) แทน po_total_amount
        // เพราะ partial receive → ค้างจ่ายจริง = มูลค่าที่รับ ไม่ใช่มูลค่าที่สั่ง
        $received_total = (float) $wpdb->get_var( $wpdb->prepare(
            "SELECT COALESCE(SUM(pm.meta_value), 0)
             FROM {$wpdb->posts} rcv
             JOIN {$wpdb->postmeta} pm_po ON pm_po.post_id = rcv.ID AND pm_po.meta_key = 'rcv_po_id'
             JOIN {$wpdb->postmeta} pm ON pm.post_id = rcv.ID AND pm.meta_key = 'rcv_total_value'
             WHERE rcv.post_type = 'b2f_receiving' AND rcv.post_status = 'publish'
             AND pm_po.meta_value = %s",
            $po_id
        ) );
        // C5 FIX: fallback ใช้ po_total_amount_thb (THB) ไม่ใช่ po_total_amount (สกุลโรงงาน)
        $po_total    = $received_total > 0 ? $received_total : floatval( get_field( 'po_total_amount_thb', $po_id ) ?: get_field( 'po_total_amount', $po_id ) ?: 0 );
        $paid_so_far = floatval( get_field( 'po_paid_amount', $po_id ) ?: 0 );
        $remaining   = round( $po_total - $paid_so_far, 2 );

        if ( $amount > $remaining + 0.01 ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $pmt_lock_key ) );
            return new WP_REST_Response( array(
                'success'   => false,
                'error'     => sprintf( 'จำนวนเงิน (%.2f) เกินยอดค้างจ่าย (%.2f)', $amount, $remaining ),
                'code'      => 'OVERPAYMENT',
                'remaining' => $remaining,
            ), 400 );
        }

        $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $po_currency = get_field( 'po_currency', $po_id ) ?: 'THB';

        // Handle slip upload + verify
        $slip_id     = 0;
        $slip_status = '';
        $slip_result = array();
        $files       = $req->get_file_params();
        if ( ! empty( $files['slip_image'] ) ) {
            require_once ABSPATH . 'wp-admin/includes/image.php';
            require_once ABSPATH . 'wp-admin/includes/file.php';
            require_once ABSPATH . 'wp-admin/includes/media.php';

            $_FILES['b2f_slip'] = $files['slip_image'];
            $att_id = media_handle_upload( 'b2f_slip', 0 );
            if ( ! is_wp_error( $att_id ) ) {
                $slip_id = $att_id;
            }

            // Multi-Currency: ≠ THB → ข้าม slip verify, admin approve เอง
            if ( $po_currency !== 'THB' ) {
                $slip_status = 'admin_approved';
            } elseif ( $slip_id && function_exists( 'b2f_verify_slip_image' ) ) {
                // Slip2Go verify (THB only)
                $file_path  = get_attached_file( $slip_id );
                $image_data = @file_get_contents( $file_path );
                if ( $image_data ) {
                    $mime   = wp_check_filetype( $file_path )['type'] ?: 'image/jpeg';
                    $base64 = 'data:' . $mime . ';base64,' . base64_encode( $image_data );

                    $slip_result = b2f_verify_slip_image( $base64, $maker_id );

                    if ( ! empty( $slip_result['success'] ) ) {
                        $slip_status = 'verified';
                        // Duplicate check: trans_ref ซ้ำ?
                        if ( ! empty( $slip_result['trans_ref'] ) ) {
                            global $wpdb;
                            $dup = $wpdb->get_var( $wpdb->prepare(
                                "SELECT COUNT(*) FROM {$wpdb->postmeta} WHERE meta_key = 'pmt_slip_trans_ref' AND meta_value = %s",
                                $slip_result['trans_ref']
                            ) );
                            if ( $dup > 0 ) {
                                $slip_status = 'rejected';
                                $slip_result['error'] = 'สลิปนี้เคยใช้แล้วในระบบ (local duplicate)';
                                $slip_result['success'] = false;
                            }
                        }
                    } elseif ( isset( $slip_result['code'] ) && $slip_result['code'] === 'NO_BANK_INFO' ) {
                        $slip_status = 'pending'; // ไม่มี bank_code — skip verify แต่ยังบันทึกได้
                    } else {
                        $slip_status = 'rejected';
                    }
                } else {
                    $slip_status = 'error';
                    $slip_result = array( 'error' => 'อ่านไฟล์สลิปไม่ได้' );
                }
            } elseif ( $slip_id ) {
                $slip_status = 'pending'; // ไม่มี b2f_verify_slip_image — skip verify
            }
        } elseif ( $po_currency !== 'THB' ) {
            // ≠ THB + ไม่มีสลิป → admin_approved (จ่ายต่างประเทศไม่ต้องแนบสลิป)
            $slip_status = 'admin_approved';
        }

        // Create payment record
        $po_number = get_field( 'po_number', $po_id ) ?: '';
        $pmt_id = wp_insert_post( array(
            'post_type'   => 'b2f_payment',
            'post_title'  => sprintf( 'Payment %s - %s', $po_number, $date ),
            'post_status' => 'publish',
        ) );

        if ( is_wp_error( $pmt_id ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $pmt_lock_key ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'บันทึกการจ่ายเงินไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
        }

        update_field( 'pmt_po_id', $po_id, $pmt_id );
        update_field( 'pmt_maker_id', $maker_id, $pmt_id );
        update_field( 'pmt_amount', $amount, $pmt_id );
        update_field( 'pmt_date', $date, $pmt_id );
        update_field( 'pmt_method', $method, $pmt_id );
        update_field( 'pmt_reference', $ref, $pmt_id );
        update_field( 'pmt_note', $note, $pmt_id );
        if ( $slip_id ) {
            update_field( 'pmt_slip_image', $slip_id, $pmt_id );
        }
        if ( ! empty( $slip_status ) ) {
            update_field( 'pmt_slip_status', $slip_status, $pmt_id );
        }
        if ( ! empty( $slip_result ) ) {
            update_field( 'pmt_slip_verify_result', wp_json_encode( $slip_result ), $pmt_id );
        }
        if ( ! empty( $slip_result['trans_ref'] ) ) {
            update_field( 'pmt_slip_trans_ref', $slip_result['trans_ref'], $pmt_id );
        }

        // Update PO paid amount
        $new_paid = round( $paid_so_far + $amount, 2 );
        update_field( 'po_paid_amount', $new_paid, $po_id );

        // Determine payment status
        $is_fully_paid  = ( abs( $new_paid - $po_total ) < 0.01 );
        $payment_status = $is_fully_paid ? 'paid' : 'partial_paid';
        update_field( 'po_payment_status', $payment_status, $po_id );

        // Transition PO status
        if ( $is_fully_paid ) {
            if ( function_exists( 'b2f_transition_order' ) ) {
                b2f_transition_order( $po_id, 'paid', 'admin', sprintf( 'Full payment: %.2f', $amount ) );
                b2f_transition_order( $po_id, 'completed', 'system', 'Payment completed' );
            } else {
                update_field( 'po_status', 'completed', $po_id );
            }
        } else {
            if ( function_exists( 'b2f_transition_order' ) ) {
                b2f_transition_order( $po_id, 'partial_paid', 'admin', sprintf( 'Partial payment: %.2f', $amount ) );
            } else {
                update_field( 'po_status', 'partial_paid', $po_id );
            }
        }

        // Subtract debt (payable)
        if ( function_exists( 'b2f_payable_subtract' ) ) {
            b2f_payable_subtract( $maker_id, $amount, sprintf( 'จ่ายเงิน PO %s', $po_number ), $po_id );
        }

        // Push Flex to Maker
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        if ( function_exists( 'b2f_build_flex_payment' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_payment( $po_id, $pmt_id );
            if ( $flex ) b2f_line_push( $maker_group, array( $flex ) );
        }

        // GAP-01: Push Flex completed เมื่อจ่ายครบ → ทั้ง Admin + Maker รู้
        if ( $is_fully_paid && function_exists( 'b2f_build_flex_po_completed' ) ) {
            $flex_done = b2f_build_flex_po_completed( $po_id );
            if ( $flex_done ) {
                if ( ! empty( $maker_group ) ) b2f_line_push( $maker_group, array( $flex_done ) );
                if ( defined( 'B2B_ADMIN_GROUP_ID' ) ) b2f_line_push( B2B_ADMIN_GROUP_ID, array( $flex_done ) );
            }
        }

        // Push Flex slip verify result ไป Admin group
        if ( ! empty( $slip_status ) && $slip_status !== 'pending' && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
            if ( $slip_status === 'verified' && function_exists( 'b2f_build_flex_slip_verified' ) ) {
                $flex_v = b2f_build_flex_slip_verified( $po_id, $slip_result );
                if ( $flex_v ) b2f_line_push( B2B_ADMIN_GROUP_ID, array( $flex_v ) );
            } elseif ( $slip_status === 'rejected' && function_exists( 'b2f_build_flex_slip_rejected' ) ) {
                $reason = isset( $slip_result['error'] ) ? $slip_result['error'] : 'สลิปไม่ผ่านการตรวจ';
                $flex_r = b2f_build_flex_slip_rejected( $po_id, $reason, $slip_result );
                if ( $flex_r ) b2f_line_push( B2B_ADMIN_GROUP_ID, array( $flex_r ) );
            }
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Payment recorded: %s (#%d) amount=%.2f method=%s status=%s slip=%s',
                $po_number, $po_id, $amount, $method, $payment_status, $slip_status ?: 'none'
            ) );
        }

        $new_remaining = round( $po_total - $new_paid, 2 );

        // FIX-2a: Release payment lock
        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $pmt_lock_key ) );

        return new WP_REST_Response( array(
            'success'        => true,
            'pmt_id'         => $pmt_id,
            'payment_status' => $payment_status,
            'remaining'      => $new_remaining,
            'po_status'      => esc_html( get_field( 'po_status', $po_id ) ),
            'slip_status'    => $slip_status ?: null,
            'slip_error'     => ( $slip_status === 'rejected' && isset( $slip_result['error'] ) ) ? $slip_result['error'] : null,
        ), 200 );
    }
}

// ════════════════════════════════════════════
// 13. DASHBOARD ENDPOINTS
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_dashboard_stats' ) ) {
    /**
     * GET /dashboard-stats — KPI stats (ตาม spec section 12)
     *
     * V.11.6 PERF-H2: cached 120s via transient `b2f_dashboard_stats_cache`.
     * Status breakdown + overdue + total_payable collapsed into 2 GROUP BY queries.
     * Invalidation: `b2f_order_status_changed` + `save_post_b2f_maker` + `save_post_b2f_order`
     * (hooks registered near bottom of this snippet).
     *
     * Response: {
     *   pending_confirm, confirmed, overdue,
     *   total_payable, overdue_payable,
     *   po_this_month, po_last_month,
     *   status_breakdown, cached_at
     * }
     */
    function b2f_rest_dashboard_stats( WP_REST_Request $req ) {
        global $wpdb;

        // PERF-H2: try cache first. Skip cache if ?no_cache=1 (admin debug).
        $no_cache = (bool) $req->get_param( 'no_cache' );
        $cache_key = 'b2f_dashboard_stats_cache';
        if ( ! $no_cache ) {
            $cached = get_transient( $cache_key );
            if ( is_array( $cached ) && ! empty( $cached['data'] ) ) {
                return new WP_REST_Response( array(
                    'success'   => true,
                    'data'      => $cached['data'],
                    'cached'    => true,
                    'cached_at' => $cached['cached_at'] ?? null,
                ), 200 );
            }
        }

        // ── Single GROUP BY: all status counts at once ─────────────────────
        $statuses = array(
            'draft', 'submitted', 'confirmed', 'amended', 'rejected',
            'delivering', 'partial_received', 'received',
            'partial_paid', 'paid', 'completed', 'cancelled',
        );
        $status_counts = array_fill_keys( $statuses, 0 );

        $rows = $wpdb->get_results(
            "SELECT pm.meta_value AS status, COUNT(*) AS cnt
             FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'po_status'
             WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
             GROUP BY pm.meta_value",
            ARRAY_A
        );
        if ( is_array( $rows ) ) {
            foreach ( $rows as $r ) {
                $s = (string) ( $r['status'] ?? '' );
                if ( isset( $status_counts[ $s ] ) ) {
                    $status_counts[ $s ] = (int) $r['cnt'];
                }
            }
        }

        // ── Overdue: confirmed/delivering with expected_date < today ──
        $today = wp_date( 'Y-m-d' );
        $overdue = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} ps ON p.ID = ps.post_id AND ps.meta_key = 'po_status'
             INNER JOIN {$wpdb->postmeta} pe ON p.ID = pe.post_id AND pe.meta_key = 'po_expected_date'
             WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
             AND ps.meta_value IN ('confirmed','delivering')
             AND pe.meta_value < %s AND pe.meta_value != ''",
            $today
        ) );

        // ── Total payable (sum of all makers' current_debt) ──
        $total_payable = (float) $wpdb->get_var(
            "SELECT COALESCE(SUM(CAST(pm.meta_value AS DECIMAL(12,2))), 0)
             FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'maker_current_debt'
             WHERE p.post_type = 'b2f_maker' AND p.post_status = 'publish'"
        );

        // ── PO this month + last month ──
        $month_start = wp_date( 'Y-m-01' );
        $po_this_month = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts}
             WHERE post_type = 'b2f_order' AND post_status = 'publish' AND post_date >= %s",
            $month_start . ' 00:00:00'
        ) );

        $last_month_start = wp_date( 'Y-m-01', strtotime( '-1 month' ) );
        $last_month_end   = wp_date( 'Y-m-t', strtotime( '-1 month' ) );
        $po_last_month = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts}
             WHERE post_type = 'b2f_order' AND post_status = 'publish'
             AND post_date >= %s AND post_date <= %s",
            $last_month_start . ' 00:00:00',
            $last_month_end . ' 23:59:59'
        ) );

        // ── Overdue payable: makers with debt past credit term ──
        // PERF-H2: Prime meta cache in a single query + bulk-load all oldest dates in one
        // GROUP BY instead of per-maker SELECT. Loop becomes in-memory only.
        $overdue_payable = 0.0;
        $makers_q = new WP_Query( array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => -1,
            'post_status'    => 'publish',
            'fields'         => 'ids',
            'no_found_rows'  => true,
        ) );
        $maker_ids = $makers_q->posts ?: array();
        if ( ! empty( $maker_ids ) ) {
            update_meta_cache( 'post', $maker_ids );

            // Bulk-load: oldest po_actual_date per maker for unpaid received/partial_paid POs.
            // Single GROUP BY scoped to the makers we care about.
            $placeholders = implode( ',', array_fill( 0, count( $maker_ids ), '%d' ) );
            $oldest_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT pm.meta_value AS maker_id, MIN(pe.meta_value) AS oldest_date
                 FROM {$wpdb->posts} p
                 INNER JOIN {$wpdb->postmeta} ps ON p.ID = ps.post_id AND ps.meta_key = 'po_status'
                 INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'po_maker_id'
                 INNER JOIN {$wpdb->postmeta} pe ON p.ID = pe.post_id AND pe.meta_key = 'po_actual_date'
                 INNER JOIN {$wpdb->postmeta} pp ON p.ID = pp.post_id AND pp.meta_key = 'po_payment_status'
                 WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
                 AND ps.meta_value IN ('received','partial_paid')
                 AND pp.meta_value != 'paid'
                 AND pe.meta_value != ''
                 AND CAST(pm.meta_value AS UNSIGNED) IN ($placeholders)
                 GROUP BY pm.meta_value",
                $maker_ids
            ), ARRAY_A );
            $oldest_map = array();
            if ( is_array( $oldest_rows ) ) {
                foreach ( $oldest_rows as $r ) {
                    $oldest_map[ (int) $r['maker_id'] ] = (string) $r['oldest_date'];
                }
            }

            foreach ( $maker_ids as $mid ) {
                $debt = floatval( get_field( 'maker_current_debt', $mid ) ?: 0 );
                if ( $debt <= 0 ) continue;
                $term = intval( get_field( 'maker_credit_term_days', $mid ) ?: 30 );
                $oldest = $oldest_map[ (int) $mid ] ?? '';
                if ( $oldest && strtotime( $oldest ) < strtotime( "-{$term} days" ) ) {
                    $overdue_payable += $debt;
                }
            }
        }

        $data = array(
            'pending_confirm'  => $status_counts['submitted'] ?? 0,
            'confirmed'        => ( $status_counts['confirmed'] ?? 0 ) + ( $status_counts['delivering'] ?? 0 ),
            'overdue'          => $overdue,
            'total_payable'    => round( $total_payable, 2 ),
            'overdue_payable'  => round( $overdue_payable, 2 ),
            'po_this_month'    => $po_this_month,
            'po_last_month'    => $po_last_month,
            'status_breakdown' => $status_counts,
        );

        // PERF-H2: store in transient (120s). Cache key is static — all admins share.
        if ( ! $no_cache ) {
            set_transient( $cache_key, array(
                'data'      => $data,
                'cached_at' => current_time( 'mysql' ),
            ), 120 );
        }

        return new WP_REST_Response( array(
            'success'   => true,
            'data'      => $data,
            'cached'    => false,
            'cached_at' => current_time( 'mysql' ),
        ), 200 );
    }
}

