        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'Maker reschedule request: %s (#%d) new_date=%s reason=%s', $po_number, $po_id, $new_date, $reason ) );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'po_id'   => $po_id,
            'message' => 'ส่งคำขอเลื่อนวันส่งแล้ว รอ Admin อนุมัติ',
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_maker_po_list' ) ) {
