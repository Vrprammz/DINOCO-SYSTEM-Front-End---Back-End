                array( 'type' => 'text', 'text' => 'ยอดรวม', 'size' => 'sm', 'color' => '#64748b', 'flex' => 2 ),
                array( 'type' => 'text', 'text' => $cur_sym . $total_str, 'size' => 'sm', 'weight' => 'bold', 'flex' => 3, 'align' => 'end' ) ) ),
            array( 'type' => 'separator', 'margin' => 'md' ),
        );
        if ( ! empty( $reason ) ) {
            $cancel_body_admin[] = array( 'type' => 'text', 'text' => 'เหตุผล: ' . mb_substr( $reason, 0, 80 ), 'size' => 'sm', 'color' => '#dc2626', 'wrap' => true, 'margin' => 'md' );
