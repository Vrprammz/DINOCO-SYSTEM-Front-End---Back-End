if ( ! function_exists( 'b2f_rest_maker_deliver' ) ) {
    function b2f_rest_maker_deliver( WP_REST_Request $req ) {
        $jwt = b2f_verify_maker_jwt( $req );
        if ( is_wp_error( $jwt ) ) {
            $status = 401;
            $data = $jwt->get_error_data();
            if ( is_array( $data ) && isset( $data['status'] ) ) $status = $data['status'];
            return new WP_REST_Response( array( 'success' => false, 'error' => $jwt->get_error_message() ), $status );
        }

        $maker_id       = $jwt['maker_id'];
        $params         = $req->get_json_params();
        $po_id          = intval( $params['po_id'] ?? 0 );
        $delivery_items = $params['delivery_items'] ?? array(); // [{sku, qty}]
        $maker_note     = sanitize_textarea_field( $params['note'] ?? '' );

        // V.7.3: i18n error messages
        $mc = get_field( 'maker_currency', $maker_id ) ?: 'THB';
        $cur = $mc ?: 'THB';
        $is_eng = $cur !== 'THB';

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ไม่พบ PO', 'Missing PO ID', '缺少订单号', $cur) ), 400 );
        }

        // Verify ownership
        $po_maker = get_field( 'po_maker_id', $po_id );
        if ( intval( $po_maker ) !== $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('PO นี้ไม่ใช่ของโรงงานคุณ', 'This PO does not belong to your factory', '此订单不属于您的工厂', $cur) ), 403 );
        }

        if ( ! function_exists( 'b2f_transition_order' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('ระบบไม่พร้อม', 'System not ready', '系统未就绪', $cur) ), 500 );
        }

        // W7 FIX: Lock ป้องกัน concurrent deliver
        global $wpdb;
        $dlv_lock = 'b2f_dlv_' . intval( $po_id );
        $got_dlv_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 0)", $dlv_lock ) );
        if ( ! $got_dlv_lock ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('กำลังประมวลผล กรุณารอสักครู่', 'Processing, please wait', '处理中，请稍候', $cur), 'code' => 'LOCKED' ), 423 );
        }

        $current_status = get_field( 'po_status', $po_id );
        $is_additional  = ( $current_status === 'partial_received' );
        $po_items       = get_field( 'po_items', $po_id ) ?: array();
        $po_number      = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;

        // ── Delivery Items Processing (Delivery Form feature) ──
        $dlv_summary    = array();
        $is_complete    = true;
        $has_items      = ! empty( $delivery_items ) && is_array( $delivery_items );

        if ( $has_items ) {
            // Build SKU → index map
            $sku_map = array();
            foreach ( $po_items as $idx => $item ) {
                $sku_map[ $item['poi_sku'] ] = $idx;
            }

            // Validate + update qty_shipped
            $any_qty = false;
            foreach ( $delivery_items as $di ) {
                $sku = sanitize_text_field( $di['sku'] ?? '' );
                $qty = intval( $di['qty'] ?? 0 );
                if ( ! isset( $sku_map[ $sku ] ) ) continue;
                if ( $qty <= 0 ) continue;

                $idx          = $sku_map[ $sku ];
                $ordered      = intval( $po_items[ $idx ]['poi_qty_ordered'] ?? 0 );
                $old_shipped  = intval( $po_items[ $idx ]['poi_qty_shipped'] ?? 0 );
                $rejected     = intval( $po_items[ $idx ]['poi_qty_rejected'] ?? 0 );
                $remaining    = $ordered - $old_shipped + $rejected;

                // Cap qty at remaining
                if ( $qty > $remaining ) $qty = $remaining;
                if ( $qty <= 0 ) continue;

                $any_qty = true;
                $po_items[ $idx ]['poi_qty_shipped'] = $old_shipped + $qty;

                $dlv_summary[] = array( 'sku' => $sku, 'qty' => $qty, 'name' => $po_items[ $idx ]['poi_product_name'] ?? $sku );

                // ตรวจว่าส่งครบไหม (shipped >= remaining)
                $new_shipped = $old_shipped + $qty;
                if ( $new_shipped < $remaining ) $is_complete = false;
            }

            if ( ! $any_qty ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $dlv_lock ) );
                return new WP_REST_Response( array( 'success' => false, 'error' => b2f_t('กรุณาระบุจำนวนอย่างน้อย 1 รายการ', 'Please specify at least 1 item', '请至少指定1件产品', $cur) ), 400 );
            }

            // ตรวจ is_complete จาก ALL items (ไม่ใช่แค่ items ที่ส่งรอบนี้)
            // C2 FIX: shipped ที่ส่งมาจริง (หัก rejected) ต้อง >= ordered
            $is_complete = true;
            foreach ( $po_items as $pi_chk ) {
                $chk_ordered  = intval( $pi_chk['poi_qty_ordered'] ?? 0 );
                $chk_shipped  = intval( $pi_chk['poi_qty_shipped'] ?? 0 );
                $chk_rejected = intval( $pi_chk['poi_qty_rejected'] ?? 0 );
                if ( ( $chk_shipped - $chk_rejected ) < $chk_ordered ) { $is_complete = false; break; }
            }

            // Save updated po_items with qty_shipped
            update_field( 'po_items', $po_items, $po_id );

            // Save delivery record
            $deliveries    = get_field( 'po_deliveries', $po_id ) ?: array();
            $dlv_number    = 'DLV-' . str_pad( count( $deliveries ) + 1, 3, '0', STR_PAD_LEFT );
            $deliveries[]  = array(
                'dlv_number'      => $dlv_number,
                'dlv_date'        => wp_date( 'Y-m-d H:i:s' ),
                'dlv_items'       => wp_json_encode( $dlv_summary, JSON_UNESCAPED_UNICODE ),
                'dlv_note'        => $maker_note,
                'dlv_is_complete' => $is_complete,
            );
            update_field( 'po_deliveries', $deliveries, $po_id );
        }

        // Transition to delivering
        $note   = $is_additional ? 'Maker ส่งของเพิ่ม (LIFF)' : 'Maker แจ้งส่งของ (LIFF)';
        $result = b2f_transition_order( $po_id, 'delivering', 'maker', $note );
        if ( is_wp_error( $result ) ) {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $dlv_lock ) );
            return new WP_REST_Response( array( 'success' => false, 'error' => $result->get_error_message() ), 400 );
        }

        if ( empty( get_field( 'po_actual_date', $po_id ) ) ) update_field( 'po_actual_date', wp_date( 'Y-m-d' ), $po_id );

        // ── LINE Push Admin ──
        $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
        $maker_name  = get_the_title( $maker_id ) ?: 'โรงงาน';

        // V.5.4: direct call แทน $gpush variable function — ป้องกัน fail เงียบ
        if ( $admin_group && function_exists( 'b2f_line_push' ) ) {
            $admin_msgs = array();
            if ( $has_items && function_exists( 'b2f_build_flex_delivered_detail' ) ) {
                $admin_msgs = array( b2f_build_flex_delivered_detail( $po_id, $dlv_summary, $is_complete, $is_additional ) );
            } elseif ( $is_additional && function_exists( 'b2f_build_flex_additional_delivery' ) ) {
                $admin_msgs = array( b2f_build_flex_additional_delivery( $po_id ) );
            } elseif ( function_exists( 'b2f_build_flex_delivered' ) ) {
                $admin_msgs = array( b2f_build_flex_delivered( $po_id ) );
            } else {
                $admin_msgs = array( array(
                    'type' => 'text',
                    'text' => "🚚 โรงงาน {$maker_name} แจ้งส่งของ\nPO: {$po_number}\n\nกรุณาตรวจรับสินค้า",
                ) );
            }
            if ( function_exists( 'b2f_push_guaranteed' ) ) {
                b2f_push_guaranteed( $admin_group, $admin_msgs, $po_id, 'deliver_admin' );
            } else {
                b2f_line_push( $admin_group, $admin_msgs );
            }
        }

        // Maker Flex — ตาราง สั่ง/ส่ง/เหลือ เหมือน Admin
        $maker_group = get_field( 'maker_line_group_id', $maker_id ) ?: '';
        if ( $maker_group && function_exists( 'b2f_line_push' ) ) {
            // V.7.2: ENG labels for Maker Flex
            $po_currency = get_field( 'po_currency', $po_id ) ?: 'THB';
            $cur = $po_currency ?: 'THB';
        $is_eng = $cur !== 'THB';

            $badge_color = $is_complete ? '#16a34a' : '#ca8a04';
            if ( $is_complete ) {
                $header_title = b2f_t('✅ แจ้งส่งของสำเร็จ', '✅ Delivery Confirmed', '✅ 发货确认', $cur);
                if ( $is_additional ) $header_title = b2f_t('✅ ส่งของเพิ่ม — ครบแล้ว', '✅ Additional Delivery — Complete', '✅ 补发 — 全部', $cur);
            } else {
                $header_title = b2f_t('📦 แจ้งส่งของ — ส่งบางส่วน', '📦 Partial Delivery', '📦 发货 — 部分', $cur);
                if ( $is_additional ) $header_title = b2f_t('📦 ส่งของเพิ่ม — ยังไม่ครบ', '📦 Additional Delivery — Partial', '📦 补发 — 部分', $cur);
            }
            $header_bg = $is_complete ? '#16a34a' : '#ca8a04';

            // Build dlv map
            $mk_dlv_map = array();
            $mk_total_round = 0;
            foreach ( $dlv_summary as $di ) { $mk_dlv_map[ $di['sku'] ?? '' ] = intval( $di['qty'] ?? 0 ); $mk_total_round += intval( $di['qty'] ?? 0 ); }

            $body = array();
            $body[] = array( 'type' => 'text', 'text' => wp_date( 'd/m/Y H:i' ), 'size' => 'xxs', 'color' => '#64748b' );
            $body[] = array( 'type' => 'text', 'text' => b2f_t('ส่งรอบนี้ ', 'This shipment: ', '本次: ', $cur) . $mk_total_round . b2f_t(' ชิ้น', ' pcs', '件', $cur), 'size' => 'xs', 'weight' => 'bold', 'color' => '#1e40af', 'margin' => 'sm' );

            // ตาราง header + รอบนี้
            $body[] = array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'contents' => array(
                array( 'type' => 'text', 'text' => b2f_t('สินค้า', 'Product', '产品', $cur), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 3 ),
                array( 'type' => 'text', 'text' => b2f_t('สั่ง', 'Ord', '订购', $cur), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 1, 'align' => 'center' ),
                array( 'type' => 'text', 'text' => b2f_t('ส่ง', 'Ship', '已发', $cur), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 1, 'align' => 'center' ),
                array( 'type' => 'text', 'text' => b2f_t('เหลือ', 'Left', '剩余', $cur), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#475569', 'flex' => 1, 'align' => 'center' ),
                array( 'type' => 'text', 'text' => b2f_t('รอบนี้', 'Now', '本次', $cur), 'size' => 'xxs', 'weight' => 'bold', 'color' => '#1e40af', 'flex' => 1, 'align' => 'center' ),
            ) );
            $body[] = array( 'type' => 'separator' );

            $total_left = 0;
            foreach ( $po_items as $pi ) {
                $sku     = $pi['poi_sku'] ?? '';
                $name    = $pi['poi_product_name'] ?? $sku;
                $ordered = intval( $pi['poi_qty_ordered'] ?? 0 );
                $shipped = intval( $pi['poi_qty_shipped'] ?? 0 );
                // V.5.7 FIX: poi_qty_shipped ถูก update ก่อนตรงนี้แล้ว (บรรทัด 1957) — ห้ามบวก this_round ซ้ำ
                $this_round = isset( $mk_dlv_map[ $sku ] ) ? $mk_dlv_map[ $sku ] : 0;
                $left = max( 0, $ordered - $shipped );
                $total_left += $left;
                $left_color = $left > 0 ? '#dc2626' : '#16a34a';
                $round_text = $this_round > 0 ? '+' . $this_round : '-';
                $round_color = $this_round > 0 ? '#16a34a' : '#94a3b8';
                $row_bg = $this_round > 0 ? '#f0fdf4' : '#ffffff';

                $row = array();
                $di_img = '';
                if ( $sku && class_exists( 'DINOCO_Catalog' ) ) {
                    $di_prod = DINOCO_Catalog::get_by_sku( $sku );
                    if ( $di_prod && ! empty( $di_prod['image_url'] ) ) $di_img = $di_prod['image_url'];
                }
                if ( $di_img ) $row[] = array( 'type' => 'image', 'url' => $di_img, 'size' => 'xxs', 'aspectMode' => 'cover', 'aspectRatio' => '1:1', 'flex' => 0 );
                $row[] = array( 'type' => 'text', 'text' => $name, 'size' => 'xxs', 'flex' => 3, 'wrap' => true, 'color' => '#1e293b' );
                $row[] = array( 'type' => 'text', 'text' => (string) $ordered, 'size' => 'xs', 'flex' => 1, 'align' => 'center', 'color' => '#64748b' );
                $row[] = array( 'type' => 'text', 'text' => (string) $shipped, 'size' => 'xs', 'flex' => 1, 'align' => 'center', 'color' => '#1e293b' );
                $row[] = array( 'type' => 'text', 'text' => (string) $left, 'size' => 'xs', 'weight' => 'bold', 'flex' => 1, 'align' => 'center', 'color' => $left_color );
                $row[] = array( 'type' => 'text', 'text' => $round_text, 'size' => 'xs', 'weight' => 'bold', 'flex' => 1, 'align' => 'center', 'color' => $round_color );
                $body[] = array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'sm', 'margin' => 'sm', 'backgroundColor' => $row_bg, 'paddingAll' => '4px', 'cornerRadius' => '4px', 'contents' => $row );
            }

            $body[] = array( 'type' => 'separator', 'margin' => 'md' );
            if ( $is_complete ) {
                $body[] = array( 'type' => 'text', 'text' => b2f_t('✅ ส่งครบทุกรายการ', '✅ All items shipped', '✅ 全部已发', $cur), 'size' => 'sm', 'weight' => 'bold', 'color' => '#16a34a', 'margin' => 'md' );
            } else {
                $body[] = array( 'type' => 'text', 'text' => b2f_t('📦 ค้างส่งอีก ', '📦 Remaining: ', '📦 剩余', $cur) . $total_left . b2f_t(' ชิ้น', ' pcs', '件', $cur), 'size' => 'sm', 'weight' => 'bold', 'color' => '#ca8a04', 'margin' => 'md' );
            }
            $body[] = array( 'type' => 'text', 'text' => b2f_t('DINOCO รับทราบแล้ว รอตรวจรับสินค้า', 'DINOCO acknowledged. Pending inspection.', '已确认 — 等待验收', $cur), 'size' => 'xs', 'color' => '#64748b', 'margin' => 'sm', 'wrap' => true );
            // V.8.0: Ship to address — dynamic from get_option()
            if ( $cur !== 'THB' ) {
                $shipping_method = get_field( 'po_shipping_method', $po_id ) ?: '';
                $dest_key  = $shipping_method === 'sea' ? 'b2f_shipping_dest_sea' : 'b2f_shipping_dest_land';
                $dest_addr = get_option( $dest_key, '' );
                $ship_label = $shipping_method === 'sea' ? b2f_t('ทางเรือ (M)', 'By Sea (M)', '海运 (M)', $cur) : b2f_t('ทางรถ (K)', 'By Truck (K)', '陆运 (K)', $cur);
                if ( $dest_addr ) {
                    $body[] = array( 'type' => 'text', 'text' => b2f_t('📍 ส่งถึง: ', '📍 Ship to: ', '📍 送达: ', $cur) . $dest_addr, 'size' => 'xs', 'color' => '#1e40af', 'wrap' => true, 'margin' => 'md' );
                }
                $body[] = array( 'type' => 'text', 'text' => b2f_t('วิธีส่ง: ', 'Shipping: ', '运输: ', $cur) . $ship_label, 'size' => 'xs', 'color' => '#94a3b8', 'margin' => 'sm' );
            }

            $logo = 'https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png';
            $header = array( 'type' => 'box', 'layout' => 'horizontal', 'backgroundColor' => $header_bg, 'paddingAll' => '14px', 'contents' => array(
                array( 'type' => 'image', 'url' => $logo, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                    array( 'type' => 'text', 'text' => $header_title, 'color' => '#ffffff', 'size' => 'sm', 'weight' => 'bold' ),
                    array( 'type' => 'text', 'text' => $po_number, 'color' => '#ffffff80', 'size' => 'xxs' ),
                ) ),
            ) );

            $detail_url = function_exists( 'b2f_liff_url' ) ? b2f_liff_url( '/b2f-po-ticket/', array( 'po_id' => $po_id ) ) : '#';
            $btn_label = b2f_t("\xf0\x9f\x93\x8b \xe0\xb8\x94\xe0\xb8\xb9\xe0\xb8\xa3\xe0\xb8\xb2\xe0\xb8\xa2\xe0\xb8\xa5\xe0\xb8\xb0\xe0\xb9\x80\xe0\xb8\xad\xe0\xb8\xb5\xe0\xb8\xa2\xe0\xb8\x94", '📋 View PO Detail', '📋 查看详情', $cur);
            $footer = array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '12px', 'contents' => array(
                array( 'type' => 'button', 'style' => 'primary', 'height' => 'sm', 'color' => '#1a3a5c',
                    'action' => array( 'type' => 'uri', 'label' => $btn_label, 'uri' => $detail_url ) ),
            ) );

            $mk_alt = ( $is_complete ? '✅' : '📦' ) . ' ' . $po_number . ' ' . $header_title;
            $maker_flex = array( 'type' => 'flex',
                'altText' => $mk_alt,
                'contents' => array( 'type' => 'bubble', 'size' => 'mega', 'header' => $header,
                    'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'contents' => $body ),
                    'footer' => $footer ) );
            if ( function_exists( 'b2f_push_guaranteed' ) ) {
                b2f_push_guaranteed( $maker_group, array( $maker_flex ), $po_id, 'deliver_maker' );
            } else {
                b2f_line_push( $maker_group, array( $maker_flex ) );
            }
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Maker deliver: %s (#%d) items=%d complete=%s additional=%s',
                $po_number, $po_id, count( $dlv_summary ), $is_complete ? 'yes' : 'no', $is_additional ? 'yes' : 'no'
            ) );
        }

        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $dlv_lock ) );

        return new WP_REST_Response( array(
            'success'         => true,
            'message'         => "แจ้งส่งของ {$po_number} เรียบร้อย",
            'delivery_number' => $has_items ? ( $dlv_number ?? '' ) : '',
            'is_complete'     => $is_complete,
            'items_count'     => count( $dlv_summary ),
        ), 200 );
    }
}

