if ( ! function_exists( 'b2f_line_push' ) ) {
    /**
     * Push Flex message to LINE group
     * @param string $group_id  LINE group ID
     * @param array  $flex      Flex message payload
     * @return bool
     */
    function b2f_line_push( $group_id, $flex ) {
        if ( empty( $group_id ) || empty( $flex ) ) return false;

        $token = defined( 'B2B_LINE_ACCESS_TOKEN' ) ? B2B_LINE_ACCESS_TOKEN : '';
        if ( empty( $token ) ) {
            if ( function_exists( 'b2f_log' ) ) b2f_log( 'LINE push failed: no access token' );
            return false;
        }

        $body = array(
            'to'       => $group_id,
            'messages' => array( $flex ),
        );

        $resp = wp_remote_post( 'https://api.line.me/v2/bot/message/push', array(
            'headers' => array(
                'Content-Type'  => 'application/json',
                'Authorization' => 'Bearer ' . $token,
            ),
            'body'    => wp_json_encode( $body ),
            'timeout' => 10,
        ) );

        if ( is_wp_error( $resp ) ) {
            if ( function_exists( 'b2f_log' ) ) b2f_log( 'LINE push error: ' . $resp->get_error_message() );
            return false;
        }

        $code = wp_remote_retrieve_response_code( $resp );
        if ( $code !== 200 ) {
            if ( function_exists( 'b2f_log' ) ) b2f_log( 'LINE push HTTP ' . $code . ': ' . wp_remote_retrieve_body( $resp ) );
            return false;
        }

        return true;
    }
}

