if ( ! function_exists( 'b2f_verify_maker_jwt' ) ) {
    /**
     * Verify JWT token from Maker LIFF
     * @param WP_REST_Request $req
     * @return array|WP_Error  { po_id, maker_id, action } or WP_Error
     */
    function b2f_verify_maker_jwt( WP_REST_Request $req ) {
        $token = sanitize_text_field( $req->get_param( 'token' ) ?: '' );
        if ( empty( $token ) ) {
            // Try Authorization header
            $auth = $req->get_header( 'Authorization' );
            if ( $auth && stripos( $auth, 'Bearer ' ) === 0 ) {
                $token = sanitize_text_field( substr( $auth, 7 ) );
            }
        }

        if ( empty( $token ) ) {
            return new WP_Error( 'no_token', 'ไม่พบ token สำหรับยืนยันตัวตน', array( 'status' => 401 ) );
        }

        if ( ! class_exists( 'DINOCO_JWT' ) ) {
            return new WP_Error( 'jwt_unavailable', 'ระบบ JWT ไม่พร้อมใช้งาน', array( 'status' => 500 ) );
        }

        $payload = DINOCO_JWT::verify( $token );
        if ( ! $payload ) {
            return new WP_Error( 'invalid_token', 'Token ไม่ถูกต้องหรือหมดอายุ', array( 'status' => 401 ) );
        }

        // Required fields in payload: po_id, maker_id
        if ( empty( $payload['po_id'] ) || empty( $payload['maker_id'] ) ) {
            return new WP_Error( 'invalid_payload', 'Token ไม่มีข้อมูลที่จำเป็น', array( 'status' => 401 ) );
        }

        return array(
            'po_id'    => intval( $payload['po_id'] ),
            'maker_id' => intval( $payload['maker_id'] ),
            'action'   => sanitize_text_field( $payload['action'] ?? '' ),
        );
    }
}

