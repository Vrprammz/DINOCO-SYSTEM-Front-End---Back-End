if ( ! function_exists( 'b2f_rest_list_maker_products' ) ) {
    /**
     * GET /maker-products/{maker_id} — list SKUs for a maker
     */
    function b2f_rest_list_maker_products( WP_REST_Request $req ) {
        $maker_id = intval( $req->get_param( 'maker_id' ) ?: 0 );
        if ( ! $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ maker_id', 'code' => 'MISSING_MAKER_ID' ), 400 );
        }

        $q = new WP_Query( array(
            'post_type'      => 'b2f_maker_product',
            'posts_per_page' => -1,
            'post_status'    => 'publish',
            'meta_query'     => array( array(
                'key'   => 'mp_maker_id',
                'value' => $maker_id,
                'type'  => 'NUMERIC',
            ) ),
            'orderby'        => 'title',
            'order'          => 'ASC',
        ) );

        $products = array();
        foreach ( $q->posts as $p ) {
            $products[] = b2f_format_maker_product( $p->ID );
        }

        return new WP_REST_Response( array( 'success' => true, 'products' => $products ), 200 );
    }
}

