if ( ! function_exists( 'b2f_rest_list_makers' ) ) {
    /**
     * GET /makers — list all makers
     * Params: ?status=active|inactive|all (default: all)
     */
    function b2f_rest_list_makers( WP_REST_Request $req ) {
        $status_filter = sanitize_text_field( $req->get_param( 'status' ) ?: 'all' );

        $args = array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => -1,
            'post_status'    => 'publish',
            'orderby'        => 'title',
            'order'          => 'ASC',
        );

        if ( $status_filter !== 'all' ) {
            $args['meta_query'] = array( array(
                'key'   => 'maker_status',
                'value' => $status_filter,
            ) );
        }

        $q      = new WP_Query( $args );
        $makers = array();

        foreach ( $q->posts as $p ) {
            $makers[] = b2f_format_maker( $p->ID );
        }

        return new WP_REST_Response( array( 'success' => true, 'data' => $makers ), 200 );
    }
}

if ( ! function_exists( 'b2f_format_maker' ) ) {
    function b2f_format_maker( $maker_id ) {
        global $wpdb;
        // WARN-01 fix: ใช้ COUNT(*) ตรงๆ แทน WP_Query -1 (ลด N+1)
        $product_count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'mp_maker_id'
             WHERE p.post_type = 'b2f_maker_product' AND p.post_status = 'publish' AND pm.meta_value = %s",
            $maker_id
        ) );
        $po_count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'po_maker_id'
             WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish' AND pm.meta_value = %s",
            $maker_id
        ) );

        return array(
            'id'               => $maker_id,
            'name'             => esc_html( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ),
            'contact'          => esc_html( get_field( 'maker_contact', $maker_id ) ?: '' ),
            'phone'            => esc_html( get_field( 'maker_phone', $maker_id ) ?: '' ),
            'email'            => sanitize_email( get_field( 'maker_email', $maker_id ) ?: '' ),
            'address'          => esc_html( get_field( 'maker_address', $maker_id ) ?: '' ),
            'line_group_id'    => esc_html( get_field( 'maker_line_group_id', $maker_id ) ?: '' ),
            'tax_id'           => esc_html( get_field( 'maker_tax_id', $maker_id ) ?: '' ),
            'bank_name'        => esc_html( get_field( 'maker_bank_name', $maker_id ) ?: '' ),
            'bank_account'     => esc_html( get_field( 'maker_bank_account', $maker_id ) ?: '' ),
            'bank_holder'      => esc_html( get_field( 'maker_bank_holder', $maker_id ) ?: '' ),
            'status'           => esc_html( get_field( 'maker_status', $maker_id ) ?: 'active' ),
            'notes'            => esc_html( get_field( 'maker_notes', $maker_id ) ?: '' ),
            'credit_limit'     => floatval( get_field( 'maker_credit_limit', $maker_id ) ?: 0 ),
            'current_debt'     => floatval( get_field( 'maker_current_debt', $maker_id ) ?: 0 ),
            'credit_term_days' => intval( get_field( 'maker_credit_term_days', $maker_id ) ?: 30 ),
            'credit_hold'      => (bool) get_field( 'maker_credit_hold', $maker_id ),
            'product_count'    => $product_count,
            'po_count'         => $po_count,
            'bot_enabled'      => get_post_meta( $maker_id, 'maker_bot_enabled', true ) !== '0',
        );
    }
}

if ( ! function_exists( 'b2f_rest_save_maker' ) ) {
    /**
     * POST /maker — create or update maker
     * Body: { id?, maker_name, maker_contact, maker_phone, maker_email,
     *         maker_address, maker_line_group_id, maker_tax_id,
     *         maker_bank_name, maker_bank_account, maker_bank_holder,
     *         maker_status, maker_notes, maker_credit_limit, maker_credit_term_days }
     */
    function b2f_rest_save_maker( WP_REST_Request $req ) {
        $id   = intval( $req->get_param( 'id' ) ?: 0 );
        $name = sanitize_text_field( $req->get_param( 'maker_name' ) ?: '' );

        if ( empty( $name ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณากรอกชื่อโรงงาน', 'code' => 'MISSING_NAME' ), 400 );
        }

        // Validate group_id uniqueness
        $group_id = sanitize_text_field( $req->get_param( 'maker_line_group_id' ) ?: '' );
        if ( ! empty( $group_id ) && function_exists( 'b2f_validate_group_id' ) ) {
            $valid = b2f_validate_group_id( $group_id, $id );
            if ( is_wp_error( $valid ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => $valid->get_error_message(), 'code' => 'DUPLICATE_GROUP_ID' ), 400 );
            }
        }

        // Check name uniqueness
        $name_check = new WP_Query( array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'post_status'    => 'publish',
            'post__not_in'   => $id ? array( $id ) : array(),
            'meta_query'     => array( array(
                'key'   => 'maker_name',
                'value' => $name,
            ) ),
        ) );
        if ( $name_check->found_posts > 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ชื่อโรงงานนี้มีอยู่แล้ว', 'code' => 'DUPLICATE_NAME' ), 400 );
        }

        // Create or update
        if ( $id > 0 ) {
            $post = get_post( $id );
            if ( ! $post || $post->post_type !== 'b2f_maker' ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบโรงงาน', 'code' => 'NOT_FOUND' ), 404 );
            }
            wp_update_post( array( 'ID' => $id, 'post_title' => $name ) );
        } else {
            $id = wp_insert_post( array(
                'post_type'   => 'b2f_maker',
                'post_title'  => $name,
                'post_status' => 'publish',
            ) );
            if ( is_wp_error( $id ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'สร้างโรงงานไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
            }
        }

        // Save ACF fields
        $fields = array(
            'maker_name', 'maker_contact', 'maker_phone', 'maker_email',
            'maker_address', 'maker_line_group_id', 'maker_tax_id',
            'maker_bank_name', 'maker_bank_account', 'maker_bank_holder',
            'maker_status', 'maker_notes',
        );
        foreach ( $fields as $f ) {
            $val = $req->get_param( $f );
            if ( $val !== null ) {
                update_field( $f, sanitize_text_field( $val ), $id );
            }
        }

        // Numeric fields
        $credit_limit = $req->get_param( 'maker_credit_limit' );
        if ( $credit_limit !== null ) {
            update_field( 'maker_credit_limit', floatval( $credit_limit ), $id );
        }
        $credit_term = $req->get_param( 'maker_credit_term_days' );
        if ( $credit_term !== null ) {
            update_field( 'maker_credit_term_days', intval( $credit_term ), $id );
        }

        // Clear group_id cache
        if ( ! empty( $group_id ) ) {
            delete_transient( 'b2f_maker_gid_' . md5( $group_id ) );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Maker saved: #%d %s', $id, $name ) );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'maker'   => b2f_format_maker( $id ),
        ), 200 );
    }
}

