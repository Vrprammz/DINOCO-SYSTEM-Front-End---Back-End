if ( ! function_exists( 'b2f_rest_approve_reschedule' ) ) {
    /**
     * POST /approve-reschedule — Admin approve/reject ETA reschedule
     * Body: { po_id, approved: true|false, note? }
     * Response: { success, new_eta?, po_status } or { success, message }
     */
    function b2f_rest_approve_reschedule( WP_REST_Request $req ) {
        $po_id    = intval( $req->get_param( 'po_id' ) ?: 0 );
        $approved = (bool) $req->get_param( 'approved' );
        $note     = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );

        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $pending = get_post_meta( $po_id, '_b2f_pending_reschedule', true );
        if ( empty( $pending ) || ( $pending['status'] ?? '' ) !== 'pending' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีคำขอเลื่อนวันส่งที่รอดำเนินการ', 'code' => 'NO_PENDING' ), 400 );
        }

        $maker_id    = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );
        $maker_group = get_field( 'maker_line_group_id', $maker_id );

        if ( $approved ) {
            $new_date = sanitize_text_field( $pending['new_date'] );
            update_field( 'po_expected_date', $new_date, $po_id );

            $pending['status']      = 'approved';
            $pending['approved_at'] = wp_date( 'Y-m-d H:i:s' );
            $pending['admin_note']  = $note;
            update_post_meta( $po_id, '_b2f_pending_reschedule', $pending );

            // Update history
            $history = get_post_meta( $po_id, '_b2f_reschedule_history', true ) ?: array();
            if ( ! empty( $history ) ) {
                $history[ count( $history ) - 1 ]['status'] = 'approved';
                update_post_meta( $po_id, '_b2f_reschedule_history', $history );
            }

            // Notify Maker
            if ( function_exists( 'b2f_build_flex_reschedule_approved' ) && ! empty( $maker_group ) ) {
                $flex = b2f_build_flex_reschedule_approved( $po_id, $new_date );
                if ( $flex ) b2f_line_push( $maker_group, $flex );
            }

            if ( function_exists( 'b2f_log' ) ) {
                $po_number = get_field( 'po_number', $po_id );
                b2f_log( sprintf( 'Reschedule approved: %s (#%d) new_eta=%s', $po_number, $po_id, $new_date ) );
            }

            return new WP_REST_Response( array(
                'success'   => true,
                'new_eta'   => esc_html( $new_date ),
                'po_status' => esc_html( get_field( 'po_status', $po_id ) ),
            ), 200 );

        } else {
            $pending['status']      = 'rejected';
            $pending['rejected_at'] = wp_date( 'Y-m-d H:i:s' );
            $pending['admin_note']  = $note;
            update_post_meta( $po_id, '_b2f_pending_reschedule', $pending );

            $history = get_post_meta( $po_id, '_b2f_reschedule_history', true ) ?: array();
            if ( ! empty( $history ) ) {
                $history[ count( $history ) - 1 ]['status'] = 'rejected';
                update_post_meta( $po_id, '_b2f_reschedule_history', $history );
            }

            // Notify Maker
            if ( function_exists( 'b2f_build_flex_reschedule_rejected' ) && ! empty( $maker_group ) ) {
                $flex = b2f_build_flex_reschedule_rejected( $po_id );
                if ( $flex ) b2f_line_push( $maker_group, $flex );
            }

            if ( function_exists( 'b2f_log' ) ) {
                $po_number = get_field( 'po_number', $po_id );
                b2f_log( sprintf( 'Reschedule rejected: %s (#%d)', $po_number, $po_id ) );
            }

            return new WP_REST_Response( array(
                'success' => true,
                'message' => 'ปฏิเสธคำขอเลื่อนวันส่ง',
            ), 200 );
        }
    }
}

// ════════════════════════════════════════════
// 11. RECEIVE GOODS ENDPOINT
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_rest_receive_goods' ) ) {
    /**
     * POST /receive-goods — ตรวจรับสินค้า (FormData with photo upload)
     *
     * FormData fields:
     *   po_id           (int)
     *   items           (JSON string) [{ sku, qty_received, qc_status, reject_qty?, reject_reason? }]
     *   photos_<SKU>[]  (files, max 5 per SKU)
     *   inspected_by    (string)
     *   note            (string)
     *
     * Response: { success, rcv_id, rcv_number, po_status, inventory_updated, debt_added }
     */
    function b2f_rest_receive_goods( WP_REST_Request $req ) {
        // Rate limit: 5 req/min per admin
        $rl = b2f_rate_limit( 'receive_' . get_current_user_id(), 5, 60 );
        if ( is_wp_error( $rl ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => $rl->get_error_message(), 'code' => 'RATE_LIMIT' ), 429 );
        }

        $po_id = intval( $req->get_param( 'po_id' ) ?: 0 );
        if ( ! $po_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ PO', 'code' => 'MISSING_PO' ), 400 );
        }

        // FIX HIGH-03: MySQL GET_LOCK แทน transient (atomic, ป้องกัน TOCTOU double receiving)
        $lock_key = 'b2f_recv_' . intval( $po_id );
        global $wpdb;
        $got_lock = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 0)", $lock_key ) );
        if ( ! $got_lock ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'มีคนอื่นกำลังตรวจรับ PO นี้อยู่ กรุณารอสักครู่', 'code' => 'LOCKED' ), 423 );
        }

        $post = get_post( $po_id );
        if ( ! $post || $post->post_type !== 'b2f_order' ) {
            delete_transient( $lock_key );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบ PO', 'code' => 'NOT_FOUND' ), 404 );
        }

        $current_status = get_field( 'po_status', $po_id );
        $receivable = array( 'confirmed', 'delivering', 'partial_received' );
        if ( ! in_array( $current_status, $receivable, true ) ) {
            delete_transient( $lock_key );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่สามารถตรวจรับ PO ในสถานะนี้', 'code' => 'NOT_RECEIVABLE' ), 400 );
        }

        // Parse items (JSON string from FormData)
        $items_raw = $req->get_param( 'items' );
        if ( is_string( $items_raw ) ) {
            $items = json_decode( $items_raw, true );
        } else {
            $items = $items_raw;
        }

        if ( empty( $items ) || ! is_array( $items ) ) {
            delete_transient( $lock_key );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุรายการที่รับ', 'code' => 'MISSING_ITEMS' ), 400 );
        }

        $inspected_by = sanitize_text_field( $req->get_param( 'inspected_by' ) ?: '' );
        $note         = sanitize_textarea_field( $req->get_param( 'note' ) ?: '' );
        $maker_id     = intval( get_field( 'po_maker_id', $po_id ) ?: 0 );

        // Build PO items lookup map
        $po_items = get_field( 'po_items', $po_id ) ?: array();
        $po_items_map = array();
        foreach ( $po_items as $idx => $pi ) {
            $sku = $pi['poi_sku'] ?? '';
            $po_items_map[ $sku ] = array(
                'index'    => $idx,
                'ordered'  => intval( $pi['poi_qty_ordered'] ?? 0 ),
                'received' => intval( $pi['poi_qty_received'] ?? 0 ),
                'rejected' => intval( $pi['poi_qty_rejected'] ?? 0 ),
            );
        }

        // Process receiving items
        $rcv_items       = array();
        $total_rcv_value = 0;
        $all_complete    = true;
        $files           = $req->get_file_params();

        foreach ( $items as $item ) {
            $sku           = sanitize_text_field( $item['sku'] ?? '' );
            $qty_rcv       = intval( $item['qty_received'] ?? 0 );
            $qc_status     = sanitize_text_field( $item['qc_status'] ?? 'passed' );
            $reject_qty    = intval( $item['reject_qty'] ?? 0 );
            $reject_reason = sanitize_textarea_field( $item['reject_reason'] ?? '' );

            if ( empty( $sku ) || $qty_rcv <= 0 ) continue;

            if ( ! isset( $po_items_map[ $sku ] ) ) {
                delete_transient( $lock_key );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'SKU "%s" ไม่อยู่ใน PO นี้', esc_html( $sku ) ),
                    'code'    => 'INVALID_SKU',
                ), 400 );
            }

            $pi_data   = $po_items_map[ $sku ];
            $remaining = $pi_data['ordered'] - $pi_data['received'];

            if ( $qty_rcv > $remaining ) {
                delete_transient( $lock_key );
                return new WP_REST_Response( array(
                    'success' => false,
                    'error'   => sprintf( 'จำนวนรับ SKU "%s" (%d) เกินจำนวนที่เหลือ (%d)', esc_html( $sku ), $qty_rcv, $remaining ),
                    'code'    => 'OVER_RECEIVE',
                ), 400 );
            }

            // Handle photo uploads for rejected items
            $reject_photo_ids = array();
            if ( ( $qc_status === 'failed' || $reject_qty > 0 ) ) {
                $file_key = 'photos_' . $sku;
                if ( ! empty( $files[ $file_key ] ) ) {
                    require_once ABSPATH . 'wp-admin/includes/image.php';
                    require_once ABSPATH . 'wp-admin/includes/file.php';
                    require_once ABSPATH . 'wp-admin/includes/media.php';

                    // FIX HIGH-01: MIME type + file size validation ก่อน upload
                    $b2f_allowed_mimes = array( 'image/jpeg', 'image/png', 'image/webp' );
                    $b2f_max_file_size = 5 * 1024 * 1024; // 5MB

                    // Restrict upload types ผ่าน WP filter
                    $b2f_mime_filter = function( $mimes ) {
                        return array( 'jpg|jpeg' => 'image/jpeg', 'png' => 'image/png', 'webp' => 'image/webp' );
                    };
                    add_filter( 'upload_mimes', $b2f_mime_filter, 999 );

                    $uploaded = $files[ $file_key ];
                    if ( is_array( $uploaded['name'] ) ) {
                        $count = min( count( $uploaded['name'] ), 5 );
                        for ( $i = 0; $i < $count; $i++ ) {
                            // Validate MIME + size
                            if ( ! in_array( $uploaded['type'][ $i ], $b2f_allowed_mimes ) ) continue;
                            if ( $uploaded['size'][ $i ] > $b2f_max_file_size ) continue;
                            $file_arr = array(
                                'name'     => $uploaded['name'][ $i ],
                                'type'     => $uploaded['type'][ $i ],
                                'tmp_name' => $uploaded['tmp_name'][ $i ],
                                'error'    => $uploaded['error'][ $i ],
                                'size'     => $uploaded['size'][ $i ],
                            );
                            $_FILES['b2f_upload'] = $file_arr;
                            $att_id = media_handle_upload( 'b2f_upload', 0 );
                            if ( ! is_wp_error( $att_id ) ) {
                                $reject_photo_ids[] = $att_id;
                            }
                        }
                    } else {
                        // Validate MIME + size (single file)
                        if ( in_array( $uploaded['type'], $b2f_allowed_mimes ) && $uploaded['size'] <= $b2f_max_file_size ) {
                            $_FILES['b2f_upload'] = $uploaded;
                            $att_id = media_handle_upload( 'b2f_upload', 0 );
                            if ( ! is_wp_error( $att_id ) ) {
                                $reject_photo_ids[] = $att_id;
                            }
                        }
                    }
                    // Remove MIME filter after upload
                    remove_filter( 'upload_mimes', $b2f_mime_filter, 999 );
                }
            }

            $rcv_items[] = array(
                'rcvi_sku'           => $sku,
                'rcvi_qty_received'  => $qty_rcv,
                'rcvi_qty_rejected'  => $reject_qty,
                'rcvi_qc_status'     => $qc_status,
                'rcvi_reject_reason' => $reject_reason,
                'rcvi_reject_photos' => $reject_photo_ids,
            );

            // Update PO item cumulative totals
            $new_received = $pi_data['received'] + $qty_rcv;
            $new_rejected = $pi_data['rejected'] + $reject_qty;
            $po_items[ $pi_data['index'] ]['poi_qty_received'] = $new_received;
            $po_items[ $pi_data['index'] ]['poi_qty_rejected'] = $new_rejected;

            // Calculate value for debt (only count accepted items)
            $unit_cost = floatval( $po_items[ $pi_data['index'] ]['poi_unit_cost'] ?? 0 );
            $accepted  = $qty_rcv - $reject_qty;
            if ( $accepted > 0 ) {
                $total_rcv_value += round( $unit_cost * $accepted, 2 );
            }
        }

        if ( empty( $rcv_items ) ) {
            delete_transient( $lock_key );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่มีรายการที่รับ', 'code' => 'NO_ITEMS' ), 400 );
        }

        // Check if ALL SKUs in PO are fully received
        foreach ( $po_items_map as $sku => $pi_data ) {
            $cur_received = intval( $po_items[ $pi_data['index'] ]['poi_qty_received'] ?? 0 );
            if ( $cur_received < $pi_data['ordered'] ) {
                $all_complete = false;
                break;
            }
        }

        // Update PO items
        update_field( 'po_items', $po_items, $po_id );

        // Create receiving record
        $rcv_number = function_exists( 'b2f_generate_rcv_number' )
            ? b2f_generate_rcv_number()
            : 'RCV-' . wp_date( 'ymd' ) . '-000';

        $rcv_id = wp_insert_post( array(
            'post_type'   => 'b2f_receiving',
            'post_title'  => $rcv_number,
            'post_status' => 'publish',
        ) );

        if ( is_wp_error( $rcv_id ) ) {
            delete_transient( $lock_key );
            return new WP_REST_Response( array( 'success' => false, 'error' => 'สร้างใบรับของไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
        }

        update_field( 'rcv_po_id', $po_id, $rcv_id );
        update_field( 'rcv_number', $rcv_number, $rcv_id );
        update_field( 'rcv_date', wp_date( 'Y-m-d' ), $rcv_id );
        update_field( 'rcv_items', $rcv_items, $rcv_id );
        update_field( 'rcv_admin_note', $note, $rcv_id );
        update_field( 'rcv_inspected_by', $inspected_by, $rcv_id );

        // Transition PO status
        $new_status = $all_complete ? 'received' : 'partial_received';
        if ( function_exists( 'b2f_transition_order' ) ) {
            b2f_transition_order( $po_id, $new_status, 'admin', sprintf( 'Receiving %s', $rcv_number ) );
        } else {
            update_field( 'po_status', $new_status, $po_id );
        }

        if ( $all_complete ) {
            update_field( 'po_actual_date', wp_date( 'Y-m-d' ), $po_id );
        }

        // Add debt (payable)
        $debt_added = false;
        if ( $total_rcv_value > 0 && function_exists( 'b2f_payable_add' ) ) {
            b2f_payable_add( $maker_id, $total_rcv_value, sprintf( 'รับของ %s', $rcv_number ), $po_id );
            $debt_added = true;
        }

        // TODO: Update global inventory (source='b2f') when Inventory integration is built

        // Push Flex to Maker
        $maker_group = get_field( 'maker_line_group_id', $maker_id );
        if ( function_exists( 'b2f_build_flex_receiving' ) && ! empty( $maker_group ) ) {
            $flex = b2f_build_flex_receiving( $po_id, $rcv_id );
            if ( $flex ) b2f_line_push( $maker_group, $flex );
        }

        // Push summary to Admin
        if ( function_exists( 'b2f_build_flex_receiving_summary' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
            $flex = b2f_build_flex_receiving_summary( $po_id, $rcv_id );
            if ( $flex ) b2f_line_push( B2B_ADMIN_GROUP_ID, $flex );
        }

        delete_transient( $lock_key );

        if ( function_exists( 'b2f_log' ) ) {
            $po_number = get_field( 'po_number', $po_id );
            b2f_log( sprintf( 'Goods received: %s (#%d) rcv=%s status=%s debt=%.2f',
                $po_number, $po_id, $rcv_number, $new_status, $total_rcv_value
            ) );
        }

        return new WP_REST_Response( array(
            'success'           => true,
            'rcv_id'            => $rcv_id,
            'rcv_number'        => esc_html( $rcv_number ),
            'po_status'         => $new_status,
            'inventory_updated' => false, // TODO: set true when inventory integration is built
            'debt_added'        => $debt_added ? $total_rcv_value : 0,
        ), 200 );

        // FIX HIGH-03: Release MySQL lock
        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", 'b2f_recv_' . intval( $po_id ) ) );
        return $response;
    }
}

