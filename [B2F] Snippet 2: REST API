add_action( 'rest_api_init', function () {

    $ns = 'b2f/v1';

    // ── Admin permission check ──
    $admin_perm = function ( WP_REST_Request $req ) {
        return wp_verify_nonce( $req->get_header( 'X-WP-Nonce' ), 'wp_rest' )
            && current_user_can( 'manage_options' );
    };

    // ── Maker JWT permission (public route, token validated inside callback) ──
    $maker_perm = function () { return true; };

    // ── Maker CRUD (admin only) ──
    register_rest_route( $ns, '/makers', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_list_makers',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_save_maker',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker/delete', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_delete_maker',
        'permission_callback' => $admin_perm,
    ) );

    // ── Maker Product CRUD (admin only) ──
    register_rest_route( $ns, '/maker-products/(?P<maker_id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_list_maker_products',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker-product', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_save_maker_product',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/maker-product/delete', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_delete_maker_product',
        'permission_callback' => $admin_perm,
    ) );

    // ── PO Management (admin only) ──
    register_rest_route( $ns, '/create-po', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_create_po',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/po-detail/(?P<po_id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_po_detail',
        'permission_callback' => $maker_perm, // admin OR maker JWT — verified inside callback
    ) );
    register_rest_route( $ns, '/po-update', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_po_update',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/po-cancel', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_po_cancel',
        'permission_callback' => $admin_perm,
    ) );

    // ── Maker Actions (JWT auth) ──
    register_rest_route( $ns, '/maker-confirm', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_confirm',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-reject', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_reject',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-reschedule', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_maker_reschedule',
        'permission_callback' => $maker_perm,
    ) );
    register_rest_route( $ns, '/maker-po-list', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_maker_po_list',
        'permission_callback' => $maker_perm,
    ) );

    // ── Admin Actions ──
    register_rest_route( $ns, '/approve-reschedule', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_approve_reschedule',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/receive-goods', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_receive_goods',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/record-payment', array(
        'methods'             => 'POST',
        'callback'            => 'b2f_rest_record_payment',
        'permission_callback' => $admin_perm,
    ) );

    // ── Dashboard ──
    register_rest_route( $ns, '/dashboard-stats', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_dashboard_stats',
        'permission_callback' => $admin_perm,
    ) );
    register_rest_route( $ns, '/po-history', array(
        'methods'             => 'GET',
        'callback'            => 'b2f_rest_po_history',
        'permission_callback' => $admin_perm,
    ) );
} );

