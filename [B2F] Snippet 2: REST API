if ( ! function_exists( 'b2f_read_maker_product' ) ) {
    /**
     * V.10.0: Read single maker-product record with flag-gated source switch.
     *
     * @param string $sku
     * @param int    $maker_id
     * @return array|null Shape: {
     *     product_sku, maker_id, unit_cost, moq, lead_time_days,
     *     shipping_land, shipping_sea, status, notes, legacy_cpt_id,
     *     mp_post_id (alias of legacy_cpt_id for CPT-centric callers)
     * } OR null if not found.
     *
     * Reads from junction table when `b2f_flag_read_from_junction` is ON
     * (and row exists). Falls back to CPT (ACF) otherwise.
     */
    function b2f_read_maker_product( $sku, $maker_id ) {
        global $wpdb;
        $sku = strtoupper( trim( (string) $sku ) );
        $maker_id = intval( $maker_id );
        if ( ! $sku || ! $maker_id ) return null;

        $flag_on = function_exists( 'b2f_is_flag_enabled' )
            && b2f_is_flag_enabled( 'b2f_flag_read_from_junction' );

        if ( $flag_on ) {
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            // V.11.5 DB-C2 FIX: drop non-SARGable `UPPER(product_sku)` wrap — blocks
            // uq_sku_maker composite unique + idx_sku (utf8mb4_bin column) from being
            // used → seq scan on a hot path (create-po leaf validation N times).
            // Column is stored uppercase by all writers (Snippet 0.5 strtoupper() at
            // INSERT, Audit backfill uppercase on transfer, junction_upsert uppercase),
            // and $sku is normalized to uppercase at function entry (line above — `$sku
            // = strtoupper(trim($sku))`). Direct compare on utf8mb4_bin is exact +
            // index-eligible. Callers that bypass the normalization still safe because
            // we self-uppercase at entry.
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl} WHERE product_sku = %s AND maker_id = %d AND deleted_at IS NULL LIMIT 1",
                $sku, $maker_id
            ), ARRAY_A );
            if ( $row ) {
                return array(
                    'product_sku'    => (string) ( $row['product_sku'] ?? $sku ),
                    'maker_id'       => intval( $row['maker_id'] ?? $maker_id ),
                    'unit_cost'      => floatval( $row['unit_cost'] ?? 0 ),
                    'moq'            => intval( $row['moq'] ?? 1 ),
                    'lead_time_days' => intval( $row['lead_time_days'] ?? 7 ),
                    'shipping_land'  => floatval( $row['shipping_land'] ?? 0 ),
                    'shipping_sea'   => floatval( $row['shipping_sea'] ?? 0 ),
                    'status'         => (string) ( $row['status'] ?? 'active' ),
                    'notes'          => (string) ( $row['notes'] ?? '' ),
                    'legacy_cpt_id'  => intval( $row['legacy_cpt_id'] ?? 0 ),
                    'mp_post_id'     => intval( $row['legacy_cpt_id'] ?? 0 ),
                    '_source'        => 'junction',
                );
            }
            // Fall through to CPT (edge case: junction row missing during transition)
        }

        // CPT fallback (V.9.x behavior)
        $mp = get_posts( array(
            'post_type'      => 'b2f_maker_product',
            'posts_per_page' => 1,
            'post_status'    => 'publish',
            'meta_query'     => array(
                'relation' => 'AND',
                array( 'key' => 'mp_maker_id', 'value' => $maker_id, 'type' => 'NUMERIC' ),
                array( 'key' => 'mp_product_sku', 'value' => $sku ),
            ),
        ) );
        if ( empty( $mp ) ) {
            // V.10.1: Removed lowercase retry block. SKU is normalized to uppercase
            // at function entry (b2f_read_maker_product line 1: $sku = strtoupper(trim($sku))),
            // so legacy data with mixed-case `mp_product_sku` postmeta indicates a
            // data-integrity issue that must be fixed via migration (UPDATE postmeta
            // SET meta_value = UPPER(meta_value) WHERE meta_key = 'mp_product_sku'),
            // not papered over with runtime fallback that masked the bug.
            return null;
        }
        $mp_id = $mp[0]->ID;
        return array(
            'product_sku'    => (string) ( get_field( 'mp_product_sku', $mp_id ) ?: $sku ),
            'maker_id'       => $maker_id,
            'unit_cost'      => floatval( get_field( 'mp_unit_cost', $mp_id ) ?: 0 ),
            'moq'            => intval( get_field( 'mp_moq', $mp_id ) ?: 1 ),
            'lead_time_days' => intval( get_field( 'mp_lead_time_days', $mp_id ) ?: 7 ),
            'shipping_land'  => floatval( get_field( 'mp_shipping_land', $mp_id ) ?: 0 ),
            'shipping_sea'   => floatval( get_field( 'mp_shipping_sea', $mp_id ) ?: 0 ),
            'status'         => (string) ( get_field( 'mp_status', $mp_id ) ?: 'active' ),
            'notes'          => (string) ( get_field( 'mp_notes', $mp_id ) ?: '' ),
            'legacy_cpt_id'  => $mp_id,
            'mp_post_id'     => $mp_id,
            '_source'        => 'cpt',
        );
    }
}

if ( ! function_exists( 'b2f_list_maker_products_junction' ) ) {
    /**
     * V.10.0: List maker products from junction table.
     * V.10.1: Match CPT path behavior — show all non-deleted (active + pending +
     *         discontinued). CPT path doesn't filter by mp_status, so admin uses
     *         pending/discontinued as soft states (still visible in product list,
     *         just labeled). Filtering to status='active' here was a silent
     *         behavior change between Phase 2 (CPT) and Phase 3 (junction).
     *         Order: active first, then pending, then discontinued (admin sees
     *         active SKUs at top of list).
     *
     * @param int $maker_id
     * @return array rows from wp_dinoco_product_makers
     */
    function b2f_list_maker_products_junction( $maker_id ) {
        global $wpdb;
        $maker_id = intval( $maker_id );
        if ( ! $maker_id ) return array();
        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM {$tbl}
             WHERE maker_id = %d
               AND deleted_at IS NULL
             ORDER BY FIELD(status, 'active', 'pending', 'discontinued'), product_sku ASC",
            $maker_id
        ), ARRAY_A );
        return is_array( $rows ) ? $rows : array();
    }
}

if ( ! function_exists( 'b2f_rest_list_maker_products' ) ) {
    /**
     * GET /maker-products/{maker_id} — list SKUs for a maker
     * V.9.2: Pre-compute hierarchy maps once (not per product) + return hierarchy_meta
     */
    function b2f_rest_list_maker_products( WP_REST_Request $req ) {
        $maker_id = intval( $req->get_param( 'maker_id' ) ?: 0 );
        if ( ! $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ maker_id', 'code' => 'MISSING_MAKER_ID' ), 400 );
        }

        // V.11.0 — Transient cache (10min TTL). Invalidated via central action hook
        // `b2f_junction_updated` → listener `b2f_on_junction_updated_invalidate` in Snippet 1 V.7.0.
        // Skip cache for virtual inject (audit tool) — audit reads bypass cache path intentionally.
        $include_virtual = ( '1' === (string) $req->get_param( 'include_virtual' ) );
        $flag_v11_cache = function_exists( 'b2f_is_flag_enabled' )
            && b2f_is_flag_enabled( 'b2f_flag_v11_explicit_mode' );
        $cache_key = $flag_v11_cache
            ? "b2f_maker_products_v11_{$maker_id}"
            : "b2f_maker_products_{$maker_id}";
        if ( ! $include_virtual ) {
            $cached = get_transient( $cache_key );
            if ( is_array( $cached ) && ! empty( $cached ) ) {
                return new WP_REST_Response( $cached, 200 );
            }
        }

        // V.9.2: Pre-compute hierarchy maps ONCE (not N times per product)
        $sku_relations = get_option( 'dinoco_sku_relations', array() );
        $hierarchy_ctx = b2f_build_hierarchy_context( $sku_relations );

        // V.10.0: Flag-gated source switch — junction table (Phase 3) vs CPT (legacy)
        $flag_junction = function_exists( 'b2f_is_flag_enabled' )
            && b2f_is_flag_enabled( 'b2f_flag_read_from_junction' );

        // V.11.7 DB-M1: prime maker_currency ONCE outside product loop.
        //   Legacy per-product get_field('maker_currency', $maker_id) = N× ACF cache hits for
        //   identical data. Fetch once, pass as param (new 4th arg on b2f_format_maker_product).
        $primed_currency = (string) ( get_field( 'maker_currency', $maker_id ) ?: 'THB' );

        // V.11.8 PERF-M5: accumulate stats during format loop (single pass instead of two).
        //   Only accumulate when the V11 flag is on (matches existing condition below).
        //   `b2f_compute_set_costs_v918()` + virtual-SET injection do NOT change the fields
        //   we count (production_mode / confirmation_status / admin_display_mode / is_virtual)
        //   — virtuals are injected AFTER format loop and were already skipped in the old
        //   stats pass, so keeping count in-loop preserves behavior.
        $stats_accum = array(
            'set_count'                => 0,
            'sub_unit_count'           => 0,
            'single_count'             => 0,
            'cross_factory_count'      => 0,
            'unconfirmed_count'        => 0,
            'unconfirmed_items_count'  => 0,
            'hidden_as_parts_count'    => 0,
            'total'                    => 0,
        );
        $stats_collect = function( $p ) use ( &$stats_accum ) {
            // Skip virtual synthesized entries (parity with pre-V.11.8 stats pass)
            if ( ! empty( $p['is_virtual'] ) ) return;
            $stats_accum['total']++;
            $pm = isset( $p['production_mode'] ) ? (string) $p['production_mode'] : '';
            $cs = isset( $p['confirmation_status'] ) ? (string) $p['confirmation_status'] : 'auto_synced';
            $ad = isset( $p['admin_display_mode'] ) ? (string) $p['admin_display_mode'] : 'auto';
            if ( $pm === 'set_assembled' )              $stats_accum['set_count']++;
            elseif ( $pm === 'sub_unit' )               $stats_accum['sub_unit_count']++;
            elseif ( $pm === 'single' )                 $stats_accum['single_count']++;
            elseif ( $pm === 'cross_factory_assembly' ) $stats_accum['cross_factory_count']++;
            if ( $cs === 'auto_synced' ) {
                $stats_accum['unconfirmed_items_count']++;
                if ( $pm === 'set_assembled' || $pm === 'cross_factory_assembly' ) {
                    $stats_accum['unconfirmed_count']++;
                }
            }
            if ( $ad === 'as_parts' ) $stats_accum['hidden_as_parts_count']++;
        };

        $products = array();

        if ( $flag_junction ) {
            // ═══ Phase 3: read from junction table ═══
            $rows = b2f_list_maker_products_junction( $maker_id );
            foreach ( $rows as $row ) {
                $fp = b2f_format_maker_product( 0, $hierarchy_ctx, $row, $primed_currency );
                if ( $flag_v11_cache ) $stats_collect( $fp );
                $products[] = $fp;
            }
        } else {
            // ═══ Legacy: read from CPT (V.9.x behavior) ═══
            $q = new WP_Query( array(
                'post_type'      => 'b2f_maker_product',
                'posts_per_page' => -1,
                'post_status'    => 'publish',
                'meta_query'     => array( array(
                    'key'   => 'mp_maker_id',
                    'value' => $maker_id,
                    'type'  => 'NUMERIC',
                ) ),
                'orderby'        => 'title',
                'order'          => 'ASC',
            ) );
            // V.11.8 PERF-M5 bonus: prime postmeta cache for the CPT batch so per-product
            //   ACF reads inside `b2f_format_maker_product` hit warm cache.
            if ( ! empty( $q->posts ) ) {
                update_meta_cache( 'post', wp_list_pluck( $q->posts, 'ID' ) );
            }
            foreach ( $q->posts as $p ) {
                $fp = b2f_format_maker_product( $p->ID, $hierarchy_ctx, null, $primed_currency );
                if ( $flag_v11_cache ) $stats_collect( $fp );
                $products[] = $fp;
            }
        }

        // V.10.3: Opt-in virtual SET injection — applies to BOTH paths
        // Phase 3 junction has **top-level orphan SETs** (13 rows จาก backfill) แต่ไม่มี
        // **intermediate sub-SETs** (เช่น DNCNX500E002B ที่เป็น child ของ DNCSETNX500E002
        // แต่ HTP ไม่ได้ register). SET Detail UI ต้องเห็นทุกชั้น → virtual inject ทั้ง path
        // V.11.0: reuse $include_virtual computed above (avoid duplicate $req->get_param call)
        if ( $include_virtual ) {
            $products = b2f_inject_virtual_all_sets_v920( $products, $hierarchy_ctx['rel_upper'] );
        }

        // V.9.2: Compute hierarchy_meta — which SET parents are referenced + missing children
        $hierarchy_meta = b2f_compute_hierarchy_meta( $products, $hierarchy_ctx );

        // V.9.4: moto_catalog สำหรับ model filter (เหมือน B2B)
        $moto_catalog = array();
        if ( class_exists( 'DINOCO_MotoDB' ) && method_exists( 'DINOCO_MotoDB', 'get_full_catalog_json' ) ) {
            $moto_catalog = DINOCO_MotoDB::get_full_catalog_json();
        }

        // V.9.9: Send sku_relations (rel_upper) to frontend for forward-lookup grouping
        // แก้ DD-3 shared child ที่ reverse lookup (top_parent_sku) แสดงใต้ SET เดียว
        $sku_relations_response = array();
        foreach ( $hierarchy_ctx['rel_upper'] as $p_sku => $ch_arr ) {
            $sku_relations_response[ $p_sku ] = $ch_arr;
        }

        // V.9.11: Build catalog_map สำหรับ ALL SKUs ใน hierarchy tree ของ maker's products
        // เหตุผล: LIFF ต้อง filter ด้วย compatible_models ที่อยู่ที่ leaf level — แต่ maker อาจ
        // register เฉพาะ SET (แม่) → leaf ไม่อยู่ใน $products → frontend walk descendants ไม่เจอ
        // Fix: ส่ง catalog data (wp_dinoco_products source of truth) ให้ frontend lookup ได้
        $catalog_map = array();
        if ( class_exists( 'DINOCO_Catalog' ) ) {
            // Collect SKUs: (1) maker's own products, (2) all descendants ของ SET ที่ maker register
            $tree_skus = array();
            foreach ( $products as $p ) {
                $su = strtoupper( $p['sku'] ?? '' );
                if ( ! empty( $su ) ) $tree_skus[ $su ] = true;
            }
            // Walk descendants ผ่าน rel_upper → เก็บ leaf + intermediate children
            $rel_u = $hierarchy_ctx['rel_upper'];
            $walk_descendants = function( $sku ) use ( &$walk_descendants, &$tree_skus, $rel_u ) {
                $children = isset( $rel_u[ $sku ] ) ? $rel_u[ $sku ] : array();
                foreach ( $children as $ch ) {
                    if ( ! isset( $tree_skus[ $ch ] ) ) {
                        $tree_skus[ $ch ] = true;
                        $walk_descendants( $ch );
                    }
                }
            };
            foreach ( array_keys( $tree_skus ) as $seed_sku ) {
                $walk_descendants( $seed_sku );
            }
            // Also include top_parent_sku (หา leaf ของ SET ที่ maker register เป็น leaf เท่านั้น)
            foreach ( $products as $p ) {
                $tp = strtoupper( $p['top_parent_sku'] ?? '' );
                if ( ! empty( $tp ) && ! isset( $tree_skus[ $tp ] ) ) {
                    $tree_skus[ $tp ] = true;
                    $walk_descendants( $tp );
                }
            }

            // V.9.12: Batch fetch catalog rows — single SQL (WHERE UPPER(sku) IN ...) แทน N+1 loop เดิม
            // DINOCO_Catalog::get_by_skus() return map { UPPERCASE_SKU => row } case-insensitive
            // V.9.17: helper — normalize ui_role_override with whitelist
            $norm_role = function( $cat ) {
                $raw = strtolower( (string) ( $cat['ui_role_override'] ?? 'auto' ) );
                $allowed = array( 'auto', 'set', 'child', 'grandchild', 'single' );
                return in_array( $raw, $allowed, true ) ? $raw : 'auto';
            };

            if ( method_exists( 'DINOCO_Catalog', 'get_by_skus' ) ) {
                $batch_rows = DINOCO_Catalog::get_by_skus( array_keys( $tree_skus ) );
                foreach ( $batch_rows as $sku_u => $cat ) {
                    $catalog_map[ $sku_u ] = array(
                        'sku'               => $cat['sku'] ?? $sku_u,
                        'name'              => $cat['name'] ?? $sku_u,
                        'image_url'         => $cat['image_url'] ?? '',
                        'compatible_models' => $cat['compatible_models'] ?? '[]',
                        'category'          => $cat['category'] ?? '',
                        // V.9.17: ui_role_override (badge-only, from Product Catalog source of truth)
                        'ui_role_override'  => $norm_role( $cat ),
                    );
                }
            } else {
                // Fallback V.9.11 (DINOCO_Catalog from Snippet 15 < V.7.3)
                foreach ( array_keys( $tree_skus ) as $sku_u ) {
                    $cat = DINOCO_Catalog::get_by_sku( $sku_u );
                    if ( ! $cat ) $cat = DINOCO_Catalog::get_by_sku( strtolower( $sku_u ) );
                    if ( ! $cat ) continue;
                    $catalog_map[ $sku_u ] = array(
                        'sku'               => $cat['sku'] ?? $sku_u,
                        'name'              => $cat['name'] ?? $sku_u,
                        'image_url'         => $cat['image_url'] ?? '',
                        'compatible_models' => $cat['compatible_models'] ?? '[]',
                        'category'          => $cat['category'] ?? '',
                        'ui_role_override'  => $norm_role( $cat ),
                    );
                }
            }
        }

        // V.11.3 — SET cost ALWAYS auto-computed from sum(leaves.unit_cost).
        //
        // Design decision (per user, 2026-04-17): SET has no manual price input — price
        // is derived from its parts. The original V.9.18 helper was gated behind
        // `flag_junction=OFF` on the assumption that junction.unit_cost would hold a real
        // admin-entered SET cost. Reality: no UI allows entering SET cost directly, so
        // junction rows end up with stale/bug values (e.g. 666) that admin can't fix.
        //
        // Fix: run b2f_compute_set_costs_v918() unconditionally. SET cost = sum of leaf
        // costs (DNCSETNX500X001 = 1750+1750+750+750 = 5000). When all leaves are
        // registered, SET's `unit_cost` is the computed total + `unit_cost_computed=true`
        // + `unit_cost_complete` flag. If leaves are missing, computed sum + missing list
        // so UI can warn.
        $data_products = b2f_compute_set_costs_v918( $products, $hierarchy_ctx['rel_upper'] );

        // V.11.0 — maker_profile.stats aggregate (only when v11 flag ON)
        //   Counts per production_mode + confirmation_status + admin_display_mode.
        //   Frontend uses for Maker banner ("91 CPT · 9 orphan · ⚠️ 9 SET รอยืนยัน").
        $maker_profile = array(
            'id'    => $maker_id,
            'name'  => (string) ( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ),
        );
        if ( $flag_v11_cache ) {
            // V.11.8 PERF-M5: stats accumulated during format loop above (single-pass).
            //   Counters skip virtual synthesized entries (parity with V.11.1 behavior —
            //   virtuals are injected AFTER format loop, so they were never in the tally).
            //   `b2f_compute_set_costs_v918()` does NOT mutate the counted fields, so the
            //   pre-computed counts remain valid at this point.
            //
            // V.11.1 semantics preserved:
            //   - `unconfirmed_count` = SETs only (set_assembled + cross_factory_assembly)
            //     matching LIFF banner text "N SET รอยืนยัน"
            //   - `unconfirmed_items_count` = all product types (for future "รีวิว" flow)
            //   - virtual products excluded from all counts
            $maker_profile['stats'] = $stats_accum;
        }

        $response_body = array(
            'success'        => true,
            'data'           => $data_products,
            'hierarchy_meta' => $hierarchy_meta,
            'sku_relations'  => $sku_relations_response,
            'moto_catalog'   => $moto_catalog,
            'catalog_map'    => $catalog_map, // V.9.12 (batch lookup)
            '_source'        => $flag_junction ? 'junction' : 'cpt', // V.10.0 debug hint
            'maker_profile'  => $maker_profile, // V.11.0
        );

        // V.11.0 — cache write (10min TTL). Skip when include_virtual=1 (audit path).
        if ( ! $include_virtual ) {
            set_transient( $cache_key, $response_body, 10 * MINUTE_IN_SECONDS );
        }

        return new WP_REST_Response( $response_body, 200 );
    }
}

if ( ! function_exists( 'b2f_compute_set_costs_v918' ) ) {
    /**
     * V.9.18: Auto-compute SET unit_cost = sum(leaves.mp_unit_cost) when registered children exist
     *
     * Rationale: Admin UI (Snippet 5 V.6.1) accordion ไม่มี input สำหรับ SET price →
     * Admin ไม่ได้กรอก mp_unit_cost ของ SET ตรงๆ → ถ้า ACF ค้าง stale value (เช่น 666)
     * LIFF read มาจะผิด. Design intent: SET cost = sum ของ leaves (ราคาชิ้นส่วนบวกกันมาเป็นแม่)
     *
     * Logic:
     * - สำหรับแต่ละ product ที่ product_type='set' AND มี children ใน sku_relations
     * - Walk descendants recursive → collect leaves → sum mp_unit_cost จาก registered leaves เท่านั้น
     * - ถ้า computed > 0 → override unit_cost + flag unit_cost_computed=true + preserve unit_cost_stored
     * - ถ้า computed = 0 (leaves ไม่ได้ register) → คง unit_cost เดิม (fallback)
     */
    function b2f_compute_set_costs_v918( $products, $rel_upper ) {
        if ( empty( $products ) || empty( $rel_upper ) ) return $products;

        // Build sku → product index (uppercase key)
        $by_sku = array();
        foreach ( $products as $idx => $p ) {
            $sku_u = strtoupper( $p['sku'] ?? '' );
            if ( $sku_u !== '' ) $by_sku[ $sku_u ] = $idx;
        }

        // Recursive leaf collector
        $collect_leaves = function( $sku_u, &$visited ) use ( $rel_upper, &$collect_leaves ) {
            if ( isset( $visited[ $sku_u ] ) ) return array();
            $visited[ $sku_u ] = true;
            $children = isset( $rel_upper[ $sku_u ] ) ? $rel_upper[ $sku_u ] : array();
            if ( empty( $children ) ) return array( $sku_u ); // leaf
            $leaves = array();
            foreach ( $children as $ch ) {
                $leaves = array_merge( $leaves, $collect_leaves( $ch, $visited ) );
            }
            return $leaves;
        };

        foreach ( $products as $idx => $p ) {
            $is_set = ( ( $p['product_type'] ?? 'single' ) === 'set' );
            if ( ! $is_set ) continue;

            $sku_u = strtoupper( $p['sku'] ?? '' );
            if ( $sku_u === '' || empty( $rel_upper[ $sku_u ] ) ) continue; // ไม่มี children

            $visited = array();
            $leaves = $collect_leaves( $sku_u, $visited );

            $computed_cost  = 0.0;
            $computed_land  = 0.0;
            $computed_sea   = 0.0;
            $registered_cnt = 0;
            $missing_leaves = array();

            foreach ( $leaves as $leaf_u ) {
                if ( $leaf_u === $sku_u ) continue; // self-loop guard
                if ( isset( $by_sku[ $leaf_u ] ) ) {
                    $leaf_p = $products[ $by_sku[ $leaf_u ] ];
                    $lc = floatval( $leaf_p['unit_cost'] ?? 0 );
                    $ll = floatval( $leaf_p['shipping_land'] ?? 0 );
                    $ls = floatval( $leaf_p['shipping_sea'] ?? 0 );
                    if ( $lc > 0 ) {
                        $computed_cost  += $lc;
                        $computed_land  += $ll;
                        $computed_sea   += $ls;
                        $registered_cnt++;
                    } else {
                        $missing_leaves[] = $leaf_u;
                    }
                } else {
                    $missing_leaves[] = $leaf_u;
                }
            }

            if ( $registered_cnt > 0 && $computed_cost > 0 ) {
                $products[ $idx ]['unit_cost_stored']    = floatval( $p['unit_cost'] ?? 0 );
                $products[ $idx ]['unit_cost']           = $computed_cost;
                $products[ $idx ]['unit_cost_computed']  = true;
                $products[ $idx ]['unit_cost_complete']  = empty( $missing_leaves );
                $products[ $idx ]['unit_cost_leaf_count'] = $registered_cnt;
                $products[ $idx ]['unit_cost_missing']   = $missing_leaves;
                // Override shipping ด้วย sum (ถ้า SET เดิมไม่ได้กำหนดค่าส่งแยก)
                if ( $computed_land > 0 && empty( $p['shipping_land'] ) ) {
                    $products[ $idx ]['shipping_land'] = $computed_land;
                }
                if ( $computed_sea > 0 && empty( $p['shipping_sea'] ) ) {
                    $products[ $idx ]['shipping_sea'] = $computed_sea;
                }
            }
        }

        return $products;
    }
}

if ( ! function_exists( 'b2f_build_hierarchy_context' ) ) {
    /**
     * V.9.2: Build hierarchy lookup maps from dinoco_sku_relations (called ONCE per request)
     */
    function b2f_build_hierarchy_context( $sku_relations ) {
        $parent_skus_arr = array();
        $child_to_parent = array();
        $child_to_parents = array(); // DD-3: ทุก parent (array)
        $rel_upper = array();

        if ( is_array( $sku_relations ) ) {
            foreach ( $sku_relations as $p => $ch_arr ) {
                if ( ! is_array( $ch_arr ) ) continue;
                $p_upper = strtoupper( $p );
                $parent_skus_arr[] = $p_upper;
                $ch_upper = array_map( 'strtoupper', $ch_arr );
                $rel_upper[ $p_upper ] = $ch_upper;
                foreach ( $ch_upper as $ch ) {
                    if ( ! isset( $child_to_parent[ $ch ] ) ) $child_to_parent[ $ch ] = $p_upper;
                    if ( ! isset( $child_to_parents[ $ch ] ) ) $child_to_parents[ $ch ] = array();
                    if ( ! in_array( $p_upper, $child_to_parents[ $ch ] ) ) $child_to_parents[ $ch ][] = $p_upper;
                }
            }
        }

        return array(
            'parent_skus_arr'  => $parent_skus_arr,
            'child_to_parent'  => $child_to_parent,
            'child_to_parents' => $child_to_parents,
            'rel_upper'        => $rel_upper,
        );
    }
}

if ( ! function_exists( 'b2f_compute_hierarchy_meta' ) ) {
    /**
     * V.9.2: Compute which SET parents are referenced by maker products + missing leaf SKUs
     * ช่วย frontend แสดง warning เมื่อ Maker ลงทะเบียนลูก/หลานไม่ครบ
     */
    function b2f_compute_hierarchy_meta( $products, $ctx ) {
        $rel_upper = $ctx['rel_upper'];
        $child_to_parent = $ctx['child_to_parent'];

        // Collect all registered SKUs (uppercase)
        $registered = array();
        foreach ( $products as $p ) {
            $registered[ strtoupper( $p['sku'] ) ] = true;
        }

        // Find all SET parents referenced (from top_parent_sku or set products)
        $set_parents = array();
        foreach ( $products as $p ) {
            $tp = strtoupper( $p['top_parent_sku'] ?? '' );
            if ( ! empty( $tp ) ) $set_parents[ $tp ] = true;
            if ( ( $p['auto_type'] ?? $p['product_type'] ) === 'set' ) {
                $set_parents[ strtoupper( $p['sku'] ) ] = true;
            }
        }

        $meta = array();
        foreach ( array_keys( $set_parents ) as $set_sku ) {
            // Resolve ALL leaf SKUs for this SET
            $all_leaves = array();
            b2f_collect_leaves_recursive( $set_sku, $rel_upper, $all_leaves );
            if ( empty( $all_leaves ) ) continue;

            $registered_leaves = array();
            $missing_leaves = array();
            foreach ( $all_leaves as $leaf ) {
                if ( isset( $registered[ $leaf ] ) ) {
                    $registered_leaves[] = $leaf;
                } else {
                    $missing_leaves[] = $leaf;
                }
            }

            // Resolve SET name from catalog
            $set_name = $set_sku;
            if ( class_exists( 'DINOCO_Catalog' ) ) {
                $cat = DINOCO_Catalog::get_by_sku( $set_sku );
                if ( $cat && ! empty( $cat['name'] ) ) $set_name = $cat['name'];
            }

            // V.9.3: Resolve missing leaf details (name + img) for frontend quick-add
            $missing_details = array();
            foreach ( $missing_leaves as $msku ) {
                $mname = $msku;
                $mimg  = '';
                if ( class_exists( 'DINOCO_Catalog' ) ) {
                    $mc = DINOCO_Catalog::get_by_sku( $msku );
                    if ( ! $mc ) $mc = DINOCO_Catalog::get_by_sku( strtolower( $msku ) );
                    if ( $mc ) {
                        $mname = ! empty( $mc['name'] ) ? $mc['name'] : $msku;
                        $mimg  = ! empty( $mc['image_url'] ) ? $mc['image_url'] : '';
                    }
                }
                $missing_details[] = array( 'sku' => $msku, 'name' => $mname, 'image_url' => $mimg );
            }

            $meta[ $set_sku ] = array(
                'set_name'          => $set_name,
                'total_leaves'      => count( $all_leaves ),
                'registered_leaves' => count( $registered_leaves ),
                'missing_leaves'    => $missing_leaves,
                'missing_details'   => $missing_details,
                'all_leaves'        => $all_leaves,
            );
        }

        return $meta;
    }
}

if ( ! function_exists( 'b2f_collect_leaves_recursive' ) ) {
    /**
     * V.9.2: Recursively collect leaf SKUs for a given parent
     */
    function b2f_collect_leaves_recursive( $parent_sku, $rel_upper, &$result ) {
        $children = isset( $rel_upper[ $parent_sku ] ) ? $rel_upper[ $parent_sku ] : array();
        if ( empty( $children ) ) {
            // parent_sku itself is a leaf
            $result[] = $parent_sku;
            return;
        }
        foreach ( $children as $ch ) {
            b2f_collect_leaves_recursive( $ch, $rel_upper, $result );
        }
    }
}

if ( ! function_exists( 'b2f_format_maker_product' ) ) {
    /**
     * V.9.2: Accept pre-computed $hierarchy_ctx (optional, fallback builds own)
     * V.10.0: Accept optional $junction_row (array) — when provided, read fields from
     *         junction row instead of ACF/CPT. $mp_id may be 0 in that case
     *         (falls back to legacy_cpt_id for ACF-only fields: mp_product_name,
     *         mp_lead_land, mp_lead_sea, mp_last_order_date).
     * V.11.7 DB-M1: Accept optional $maker_currency (string) — when caller primes once
     *         outside the product loop, avoids N× get_field('maker_currency', $maker_id)
     *         per product. Falls back to per-product get_field() if null (backward compat).
     * Fix: ui_role_override ใช้สำหรับ display badge เท่านั้น — ห้ามเปลี่ยน grouping fields
     * Fix: is_leaf ใช้ !$is_parent_node (accurate) แทน !$is_set
     */
    function b2f_format_maker_product( $mp_id, $hierarchy_ctx = null, $junction_row = null, $maker_currency = null ) {
        // V.10.0: resolve data source — junction row > ACF/CPT
        $has_junction = is_array( $junction_row ) && ! empty( $junction_row );
        if ( $has_junction ) {
            $sku     = (string) ( $junction_row['product_sku'] ?? '' );
            $eff_mp_id = intval( $junction_row['legacy_cpt_id'] ?? $mp_id );
            $maker_id_src = intval( $junction_row['maker_id'] ?? 0 );
        } else {
            $sku = get_field( 'mp_product_sku', $mp_id ) ?: '';
            $eff_mp_id = intval( $mp_id );
            $maker_id_src = intval( get_field( 'mp_maker_id', $mp_id ) ?: 0 );
        }
        // ดึงรูปจาก product catalog (DINOCO_Catalog) ถ้ามี
        $image_url = '';
        $product = null;
        if ( ! empty( $sku ) && class_exists( 'DINOCO_Catalog' ) ) {
            $product = DINOCO_Catalog::get_by_sku( $sku );
            if ( $product && ! empty( $product['image_url'] ) ) {
                $image_url = $product['image_url'];
            }
        }

        // V.9.2 Hierarchy: reuse stock/list classification
        $is_set = false;
        $is_parent_node = false;
        $children_count = 0;
        $parent_sku_val = '';
        $top_parent_sku = '';
        $top_parent_name = '';
        $product_type = 'single';

        if ( ! empty( $sku ) ) {
            // V.9.2: Use pre-computed context if provided, else build (backward compat)
            if ( ! $hierarchy_ctx ) {
                $sku_relations = get_option( 'dinoco_sku_relations', array() );
                $hierarchy_ctx = b2f_build_hierarchy_context( $sku_relations );
            }

            $sku_upper        = strtoupper( $sku );
            $parent_skus_arr  = $hierarchy_ctx['parent_skus_arr'];
            $child_to_parent  = $hierarchy_ctx['child_to_parent'];
            $child_to_parents = $hierarchy_ctx['child_to_parents'] ?? array();
            $rel_upper        = $hierarchy_ctx['rel_upper'];

            $is_parent_node = in_array( $sku_upper, $parent_skus_arr );
            $my_parent = isset( $child_to_parent[ $sku_upper ] ) ? $child_to_parent[ $sku_upper ] : null;

            // V.9.7: Leaf-based classification ตรงกับ JS computeProductTypes() (source of truth)
            // เดิม depth-based: ดู parent มี grandparent ไหม → ผิดเมื่อ leaf อยู่ depth 2
            // ใหม่ leaf-based: ดู isLeaf (ไม่มี children) + myParent → classification เดียวกับ JS
            $is_leaf_node = ! $is_parent_node;

            if ( $my_parent && $is_leaf_node ) {
                // มี parent + ไม่มี children ของตัวเอง = leaf (grandchild)
                $product_type = 'grandchild';
                $parent_sku_val = $my_parent;
                // top_parent = parent ของ parent (ถ้ามี) หรือ parent เอง
                $top_parent_sku = isset( $child_to_parent[ $my_parent ] ) ? $child_to_parent[ $my_parent ] : $my_parent;
            } elseif ( $my_parent && $is_parent_node ) {
                // มี parent + มี children = intermediate/sub-SET (child)
                $product_type = 'child';
                $parent_sku_val = $my_parent;
                $top_parent_sku = $my_parent;
            } elseif ( $is_parent_node ) {
                // ไม่มี parent + มี children = top-level SET
                $product_type = 'set';
                $is_set = true;
                $children_count = isset( $rel_upper[ $sku_upper ] ) ? count( $rel_upper[ $sku_upper ] ) : 0;
            }

            // Resolve names จาก catalog
            if ( ! empty( $parent_sku_val ) && class_exists( 'DINOCO_Catalog' ) ) {
                $p_cat = DINOCO_Catalog::get_by_sku( $parent_sku_val );
                if ( ! $p_cat ) $p_cat = DINOCO_Catalog::get_by_sku( strtolower( $parent_sku_val ) );
            }
            if ( ! empty( $top_parent_sku ) && class_exists( 'DINOCO_Catalog' ) ) {
                $tp_cat = DINOCO_Catalog::get_by_sku( $top_parent_sku );
                if ( ! $tp_cat ) $tp_cat = DINOCO_Catalog::get_by_sku( strtolower( $top_parent_sku ) );
                $top_parent_name = ( $tp_cat && ! empty( $tp_cat['name'] ) ) ? $tp_cat['name'] : $top_parent_sku;
            }
            $parent_name_val = '';
            if ( isset( $p_cat ) && $p_cat && ! empty( $p_cat['name'] ) ) {
                $parent_name_val = $p_cat['name'];
            } elseif ( ! empty( $parent_sku_val ) ) {
                $parent_name_val = $parent_sku_val;
            }

            // V.42.14: ui_role_override — display only, ห้ามเปลี่ยน grouping fields
            // V.9.2 FIX: เก็บ auto_type สำหรับ grouping, override เฉพาะ product_type สำหรับ badge
            // ไม่ reset parent_sku / top_parent_sku / is_set เพราะ frontend ใช้ grouping fields

            // V.9.7: Compute grandchildren_total (เหมือน JS computeProductTypes line 5118-5124)
            if ( $is_parent_node ) {
                $my_children = isset( $rel_upper[ $sku_upper ] ) ? $rel_upper[ $sku_upper ] : array();
                $grand_total = 0;
                foreach ( $my_children as $c_upper ) {
                    $gc_arr = isset( $rel_upper[ $c_upper ] ) ? $rel_upper[ $c_upper ] : array();
                    $grand_total += count( $gc_arr );
                }
            }
        }

        // V.9.17: auto_type = hierarchy จริงจาก dinoco_sku_relations (ไม่ override)
        // ui_role_override จาก wp_dinoco_products ใช้สำหรับ BADGE เท่านั้น (ตรงกับ Inventory V.42.14 pattern)
        // Grouping/DD-7/cart/PO ใช้ auto_type (hierarchy จริง) — ห้ามใช้ override สำหรับ grouping
        // เช่น DNCGNDPROT500: relations = leaf under parent → auto_type='grandchild', ui_role_override='single' → badge "เดี่ยว" แต่ grouping ยัง under parent SET
        $auto_type = $product_type;

        // V.9.17: ดึง ui_role_override จาก catalog (source of truth = wp_dinoco_products)
        $ui_role = 'auto';
        if ( $product && isset( $product['ui_role_override'] ) ) {
            $raw = strtolower( (string) $product['ui_role_override'] );
            $allowed = array( 'auto', 'set', 'child', 'grandchild', 'single' );
            if ( in_array( $raw, $allowed, true ) ) $ui_role = $raw;
        }

        // V.10.0: source-aware field resolution (junction vs CPT/ACF)
        if ( $has_junction ) {
            $f_product_name    = ( $eff_mp_id ? (string) ( get_field( 'mp_product_name', $eff_mp_id ) ?: '' ) : '' );
            if ( $f_product_name === '' && $product && ! empty( $product['name'] ) ) $f_product_name = (string) $product['name'];
            $f_unit_cost       = floatval( $junction_row['unit_cost'] ?? 0 );
            $f_moq             = intval( $junction_row['moq'] ?? 1 );
            $f_lead_time_days  = intval( $junction_row['lead_time_days'] ?? 7 );
            $f_lead_land       = ( $eff_mp_id ? intval( get_field( 'mp_lead_land', $eff_mp_id ) ?: 7 ) : 7 );
            $f_lead_sea        = ( $eff_mp_id ? intval( get_field( 'mp_lead_sea', $eff_mp_id ) ?: 14 ) : 14 );
            $f_last_order_date = ( $eff_mp_id ? (string) ( get_field( 'mp_last_order_date', $eff_mp_id ) ?: '' ) : '' );
            $f_notes           = (string) ( $junction_row['notes'] ?? '' );
            $f_status          = (string) ( $junction_row['status'] ?? 'active' );
            $f_ship_land       = floatval( $junction_row['shipping_land'] ?? 0 );
            $f_ship_sea        = floatval( $junction_row['shipping_sea'] ?? 0 );
            $maker_id_out      = $maker_id_src;
            $out_id            = $eff_mp_id; // keep CPT id for backward compat
        } else {
            $f_product_name    = (string) ( get_field( 'mp_product_name', $mp_id ) ?: '' );
            $f_unit_cost       = floatval( get_field( 'mp_unit_cost', $mp_id ) ?: 0 );
            $f_moq             = intval( get_field( 'mp_moq', $mp_id ) ?: 1 );
            $f_lead_time_days  = intval( get_field( 'mp_lead_time_days', $mp_id ) ?: 7 );
            $f_lead_land       = intval( get_field( 'mp_lead_land', $mp_id ) ?: 7 );
            $f_lead_sea        = intval( get_field( 'mp_lead_sea', $mp_id ) ?: 14 );
            $f_last_order_date = (string) ( get_field( 'mp_last_order_date', $mp_id ) ?: '' );
            $f_notes           = (string) ( get_field( 'mp_notes', $mp_id ) ?: '' );
            $f_status          = (string) ( get_field( 'mp_status', $mp_id ) ?: 'active' );
            $f_ship_land       = floatval( get_field( 'mp_shipping_land', $mp_id ) ?: 0 );
            $f_ship_sea        = floatval( get_field( 'mp_shipping_sea', $mp_id ) ?: 0 );
            $maker_id_out      = intval( get_field( 'mp_maker_id', $mp_id ) ?: 0 );
            $out_id            = $mp_id;
        }
        // V.11.7 DB-M1: use primed currency if caller provided (avoid per-product get_field).
        //   Null → fallback to per-call lookup (backward compat for legacy callers).
        if ( $maker_currency === null || $maker_currency === '' ) {
            $maker_currency = get_field( 'maker_currency', $maker_id_out ) ?: 'THB';
        }

        $out = array(
            'id'              => $out_id,
            'maker_id'        => $maker_id_out,
            'sku'             => esc_html( $sku ),
            'product_name'    => esc_html( $f_product_name ),
            'unit_cost'       => $f_unit_cost,
            'moq'             => $f_moq,
            'lead_time_days'  => $f_lead_time_days,
            'lead_land'       => $f_lead_land,
            'lead_sea'        => $f_lead_sea,
            'last_order_date' => esc_html( $f_last_order_date ),
            'notes'           => esc_html( $f_notes ),
            'status'          => esc_html( $f_status ),
            'image_url'       => esc_url( $image_url ),
            'shipping_land'   => $f_ship_land,
            'shipping_sea'    => $f_ship_sea,
            'currency_symbol' => function_exists( 'b2f_currency_symbol' ) ? b2f_currency_symbol( $maker_currency ) : '฿',
            // V.9.7 Hierarchy — leaf-based classification ตรงกับ JS computeProductTypes()
            'is_set'           => $is_set,
            'is_leaf'          => ! $is_parent_node,
            'product_type'     => $product_type,
            'auto_type'        => $auto_type,
            // V.9.17: ui_role_override (badge-only, mirror Inventory V.42.14) — frontend ใช้สำหรับ display badge
            'ui_role_override' => $ui_role,
            'children_count'   => $children_count,
            'direct_children_count' => $children_count,
            'grandchildren_total'   => isset( $grand_total ) ? $grand_total : 0,
            'parent_sku'       => $parent_sku_val,
            'parent_skus'      => isset( $child_to_parents[ $sku_upper ] ) ? $child_to_parents[ $sku_upper ] : array(),
            'parent_name'      => $parent_name_val ?? '',
            'grandparent_sku'  => ( $auto_type === 'grandchild' ) ? $top_parent_sku : '',
            'top_parent_sku'   => $top_parent_sku,
            'top_parent_name'  => $top_parent_name,
            // V.9.4: compatible_models + category จาก catalog สำหรับ filter
            'compatible_models' => ( $product && ! empty( $product['compatible_models'] ) ) ? $product['compatible_models'] : '[]',
            'category'          => ( $product && ! empty( $product['category'] ) ) ? $product['category'] : '',
        );

        // V.11.0 — Enriched fields (flag-gated by `b2f_flag_v11_explicit_mode`)
        //   Flag OFF → V.10.5-compat shape (no new fields). Flag ON → add classification +
        //   confirmation + admin_display + missing_leaves. Reads from junction row when provided
        //   (has_junction) else null → default safe values via b2f_infer_production_mode_from_relations.
        $flag_v11 = function_exists( 'b2f_is_flag_enabled' )
            && b2f_is_flag_enabled( 'b2f_flag_v11_explicit_mode' );

        if ( $flag_v11 ) {
            $v11_production_mode     = null;
            $v11_confirmation_status = 'auto_synced';
            $v11_admin_display_mode  = 'auto';
            $v11_missing_leaves_cnt  = 0;

            if ( $has_junction ) {
                // Read directly from junction row (source of truth)
                $v11_production_mode     = isset( $junction_row['production_mode'] ) ? (string) $junction_row['production_mode'] : null;
                $v11_confirmation_status = isset( $junction_row['confirmation_status'] ) ? (string) $junction_row['confirmation_status'] : 'auto_synced';
                $v11_admin_display_mode  = isset( $junction_row['admin_display_mode'] ) ? (string) $junction_row['admin_display_mode'] : 'auto';
                $v11_missing_leaves_cnt  = isset( $junction_row['missing_leaves_count'] ) ? (int) $junction_row['missing_leaves_count'] : 0;
            }

            // Fallback: if junction row missing the column (pre-schema-activation) OR CPT path →
            // infer from sku_relations (mirror Phase 4 migration logic)
            if ( $v11_production_mode === null || $v11_production_mode === '' ) {
                if ( function_exists( 'b2f_infer_production_mode_from_relations' ) && ! empty( $sku ) ) {
                    $v11_production_mode = b2f_infer_production_mode_from_relations( $sku, $maker_id_out );
                } else {
                    $v11_production_mode = 'single'; // safest default
                }
            }

            // Enum safety check (defensive — never leak invalid value to frontend)
            $enum_pmode = array( 'set_assembled', 'sub_unit', 'single', 'cross_factory_assembly' );
            if ( ! in_array( $v11_production_mode, $enum_pmode, true ) ) $v11_production_mode = 'single';

            $enum_conf = array( 'confirmed', 'auto_synced' );
            if ( ! in_array( $v11_confirmation_status, $enum_conf, true ) ) $v11_confirmation_status = 'auto_synced';

            $enum_disp = array( 'auto', 'as_set', 'as_parts' );
            if ( ! in_array( $v11_admin_display_mode, $enum_disp, true ) ) $v11_admin_display_mode = 'auto';

            // missing_leaves[] — compute only for parent nodes with children
            // (denormalized count stored on junction; frontend may want SKU list for UI)
            $missing_leaves_list = array();
            if ( $is_parent_node && function_exists( 'dinoco_get_leaf_skus' ) && ! empty( $sku ) ) {
                $leaves = dinoco_get_leaf_skus( $sku );
                if ( is_array( $leaves ) && ! empty( $leaves ) ) {
                    // Probe junction for which leaves are registered to THIS maker
                    global $wpdb;
                    $tbl = $wpdb->prefix . 'dinoco_product_makers';
                    $leaves_u = array_map( 'strtoupper', $leaves );
                    $placeholders = implode( ',', array_fill( 0, count( $leaves_u ), '%s' ) );
                    $params = array_merge( array( $maker_id_out ), $leaves_u );
                    $sql = "SELECT UPPER(product_sku) AS s FROM {$tbl}
                            WHERE maker_id = %d AND deleted_at IS NULL
                              AND BINARY UPPER(product_sku) IN ({$placeholders})";
                    $registered_rows = $wpdb->get_col( $wpdb->prepare( $sql, $params ) );
                    $registered_set = is_array( $registered_rows ) ? array_flip( $registered_rows ) : array();
                    foreach ( $leaves_u as $lu ) {
                        if ( ! isset( $registered_set[ $lu ] ) ) $missing_leaves_list[] = $lu;
                    }
                    // Keep denormalized count in sync when junction value is stale/zero
                    if ( $v11_missing_leaves_cnt === 0 && ! empty( $missing_leaves_list ) ) {
                        $v11_missing_leaves_cnt = count( $missing_leaves_list );
                    }
                }
            }

            $out['production_mode']      = $v11_production_mode;
            $out['confirmation_status']  = $v11_confirmation_status;
            $out['admin_display_mode']   = $v11_admin_display_mode;
            $out['missing_leaves']       = $missing_leaves_list;
            $out['missing_leaves_count'] = $v11_missing_leaves_cnt;
        }

        return $out;
    }
}

if ( ! function_exists( 'b2f_rest_save_maker_product' ) ) {
    /**
     * POST /maker-product — create or update maker-SKU mapping
     * Body: { id?, mp_maker_id, mp_product_sku, mp_product_name, mp_unit_cost,
     *         mp_moq, mp_lead_time_days, mp_notes, mp_status }
     */
    function b2f_rest_save_maker_product( WP_REST_Request $req ) {
        $id       = intval( $req->get_param( 'id' ) ?: 0 );
        $maker_id = intval( $req->get_param( 'mp_maker_id' ) ?: 0 );
        $sku      = sanitize_text_field( $req->get_param( 'mp_product_sku' ) ?: '' );
        $cost     = floatval( $req->get_param( 'mp_unit_cost' ) ?: 0 );

        if ( ! $maker_id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุโรงงาน', 'code' => 'MISSING_MAKER' ), 400 );
        }
        if ( empty( $sku ) ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'กรุณาระบุ SKU', 'code' => 'MISSING_SKU' ), 400 );
        }
        if ( $cost <= 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ราคาทุนต้องมากกว่า 0', 'code' => 'INVALID_COST' ), 400 );
        }

        // Check maker exists
        $maker = get_post( $maker_id );
        if ( ! $maker || $maker->post_type !== 'b2f_maker' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบโรงงาน', 'code' => 'INVALID_MAKER' ), 404 );
        }

        // Check duplicate SKU for same maker (exclude current)
        $dup = new WP_Query( array(
            'post_type'      => 'b2f_maker_product',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'post_status'    => 'publish',
            'post__not_in'   => $id ? array( $id ) : array(),
            'meta_query'     => array(
                'relation' => 'AND',
                array( 'key' => 'mp_maker_id', 'value' => $maker_id, 'type' => 'NUMERIC' ),
                array( 'key' => 'mp_product_sku', 'value' => $sku ),
            ),
        ) );
        if ( $dup->found_posts > 0 ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'SKU นี้มีอยู่แล้วสำหรับโรงงานนี้', 'code' => 'DUPLICATE_SKU' ), 400 );
        }

        $product_name = sanitize_text_field( $req->get_param( 'mp_product_name' ) ?: $sku );

        // Create or update
        if ( $id > 0 ) {
            $post = get_post( $id );
            if ( ! $post || $post->post_type !== 'b2f_maker_product' ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบรายการ', 'code' => 'NOT_FOUND' ), 404 );
            }
            wp_update_post( array( 'ID' => $id, 'post_title' => $sku . ' - ' . $product_name ) );
        } else {
            $id = wp_insert_post( array(
                'post_type'   => 'b2f_maker_product',
                'post_title'  => $sku . ' - ' . $product_name,
                'post_status' => 'publish',
            ) );
            if ( is_wp_error( $id ) ) {
                return new WP_REST_Response( array( 'success' => false, 'error' => 'สร้างรายการไม่สำเร็จ', 'code' => 'CREATE_FAILED' ), 500 );
            }
        }

        // Save fields
        update_field( 'mp_maker_id', $maker_id, $id );
        update_field( 'mp_product_sku', $sku, $id );
        update_field( 'mp_product_name', $product_name, $id );
        update_field( 'mp_unit_cost', $cost, $id );
        update_field( 'mp_moq', intval( $req->get_param( 'mp_moq' ) ?: 1 ), $id );
        update_field( 'mp_lead_time_days', intval( $req->get_param( 'mp_lead_time_days' ) ?: 7 ), $id );
        update_field( 'mp_lead_land', intval( $req->get_param( 'mp_lead_land' ) ?: 7 ), $id );
        update_field( 'mp_lead_sea', intval( $req->get_param( 'mp_lead_sea' ) ?: 14 ), $id );

        // Shipping cost
        $ship_land = $req->get_param( 'mp_shipping_land' );
        if ( $ship_land !== null ) update_field( 'mp_shipping_land', floatval( $ship_land ), $id );
        $ship_sea = $req->get_param( 'mp_shipping_sea' );
        if ( $ship_sea !== null ) update_field( 'mp_shipping_sea', floatval( $ship_sea ), $id );

        $notes = $req->get_param( 'mp_notes' );
        if ( $notes !== null ) {
            update_field( 'mp_notes', sanitize_textarea_field( $notes ), $id );
        }
        $mp_status = $req->get_param( 'mp_status' );
        if ( $mp_status !== null ) {
            update_field( 'mp_status', sanitize_text_field( $mp_status ), $id );
        }

        // V.11.2 FIX — BUG: Save from REST endpoint left junction stale (user report: SET price
        // edited + saved but value stayed at 666).
        //
        // Root cause: V.10.1 gate (OFF when shadow_write=ON) relied on Snippet 0.5 save_post hook
        // to propagate values to junction. BUT the hook fires during wp_update_post() (line above)
        // BEFORE the subsequent update_field() calls finish. So the hook reads STALE ACF values
        // and UPSERTs junction with old data. Later update_field() calls don't re-fire save_post,
        // so junction stays stuck.
        //
        // Fix: ALWAYS call b2f_dual_write_to_junction() explicitly at the end of this endpoint,
        // AFTER every update_field() has written to postmeta. This makes the junction reflect
        // the fresh values that the hook missed. Accepts a small double-write cost (hook already
        // ran with stale values — UPSERT re-runs with fresh values) for correctness guarantee.
        //
        // Updated truth table — when does junction get written?
        //   shadow_write | read_from_junction | who writes?
        //   -------------|--------------------|-------------------
        //        OFF     |        OFF         | nobody (Phase 1, observe-only)
        //        ON      |        OFF         | save_post hook (Phase 2 shadow) — stale bug
        //        OFF     |        ON          | THIS BLOCK only (Phase 3 no-shadow)
        //        ON      |        ON          | hook (stale) + THIS BLOCK (fresh) — fresh wins
        //
        // Gate removed — always call. V.11.2 prioritizes correctness over minor UPSERT dedup.
        if ( function_exists( 'b2f_dual_write_to_junction' ) ) {
            $dw = b2f_dual_write_to_junction( $id );
            if ( is_wp_error( $dw ) && function_exists( 'b2f_log' ) ) {
                b2f_log( '[V.11.2] save_maker_product explicit dual-write failed mp_id=' . $id . ': ' . $dw->get_error_message() );
            }
        }

        // V.11.0 HIGH-4 — Defensive cache invalidation hook fire.
        //   Snippet 0.5 dual-write already fires this hook, but that's only when shadow_write OR
        //   junction-read flag is ON. When BOTH flags are OFF (Phase 1 observe-only) the hook
        //   doesn't fire. Fire defensively here so v11 cache stays fresh regardless of flag state.
        do_action( 'b2f_junction_updated', $maker_id );

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Maker product saved: #%d SKU=%s Maker=#%d Cost=%.2f', $id, $sku, $maker_id, $cost ) );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'product' => b2f_format_maker_product( $id ),
        ), 200 );
    }
}

if ( ! function_exists( 'b2f_rest_delete_maker_product' ) ) {
    /**
     * POST /maker-product/delete — delete mapping
     * Body: { id }
     * V.10.0: Soft-delete junction row (UPDATE deleted_at + status=discontinued)
     *         in addition to CPT hard delete. Phase 3 read path will skip
     *         soft-deleted rows (WHERE deleted_at IS NULL).
     */
    function b2f_rest_delete_maker_product( WP_REST_Request $req ) {
        $id = intval( $req->get_param( 'id' ) ?: 0 );
        if ( ! $id ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่ระบุ ID', 'code' => 'MISSING_ID' ), 400 );
        }

        $post = get_post( $id );
        if ( ! $post || $post->post_type !== 'b2f_maker_product' ) {
            return new WP_REST_Response( array( 'success' => false, 'error' => 'ไม่พบรายการ', 'code' => 'NOT_FOUND' ), 404 );
        }

        // V.11.0: Capture maker_id BEFORE delete (for central hook fire below)
        $maker_id_for_hook = intval( get_field( 'mp_maker_id', $id ) ?: 0 );

        // V.10.0: Soft-delete junction first (before CPT delete removes legacy_cpt_id linkage)
        if ( function_exists( 'b2f_dual_soft_delete_junction' ) ) {
            $soft_ok = b2f_dual_soft_delete_junction( $id );
            if ( ! $soft_ok && function_exists( 'b2f_log' ) ) {
                b2f_log( '[V.10.0] delete_maker_product soft-delete junction failed mp_id=' . $id );
            }
        }

        wp_delete_post( $id, true ); // permanent delete (CPT)

        // V.11.0 HIGH-4 — fire central invalidation hook (defensive — soft-delete also fires but
        // only under Phase 2+ flags). Ensures v11 cache invalidated regardless of flag state.
        if ( $maker_id_for_hook > 0 ) {
            do_action( 'b2f_junction_updated', $maker_id_for_hook );
        }

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Maker product deleted: #%d', $id ) );
        }

        return new WP_REST_Response( array( 'success' => true ), 200 );
    }
}

