    function b2f_invalidate_makers_list_cache() {
        // Transient keys hashed by status|page|per_page — can't selectively invalidate.
        // Use a scanning delete via $wpdb since there are very few cache entries
        // (per status × pagination pages = bounded). Safer than flushing all transients.
        global $wpdb;
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '\_transient\_b2f\_makers\_list\_%' OR option_name LIKE '\_transient\_timeout\_b2f\_makers\_list\_%'" );
    }
    add_action( 'save_post_b2f_maker', 'b2f_invalidate_makers_list_cache', 20, 0 );
    add_action( 'save_post_b2f_maker_product', 'b2f_invalidate_makers_list_cache', 20, 0 );
