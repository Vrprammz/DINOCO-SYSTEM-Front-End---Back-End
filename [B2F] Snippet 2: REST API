if ( ! function_exists( 'b2f_rest_list_makers' ) ) {
    /**
     * GET /makers — list makers (paginated).
     * Params: ?status=active|inactive|all (default: all)
     *         ?page=1
     *         ?per_page=100 (max 200)
     *         ?no_cache=1
     *
     * V.11.6 PERF-H3: was `posts_per_page=-1` + 18 queries per maker (16 get_field + 2 COUNT)
     *   → 30 makers = 570 queries. Now:
     *     - pagination default 100/page (param override up to 200)
     *     - `update_meta_cache()` primes ACF reads in 1 query
     *     - product + PO counts bulk-loaded in 2 GROUP BY queries (not 2N)
     *     - response cached 300s via transient, invalidated on maker/junction change
     */
    function b2f_rest_list_makers( WP_REST_Request $req ) {
        global $wpdb;

        $status_filter = sanitize_text_field( $req->get_param( 'status' ) ?: 'all' );
        $page     = max( 1, intval( $req->get_param( 'page' ) ?: 1 ) );
        $per_page = min( 200, max( 1, intval( $req->get_param( 'per_page' ) ?: 100 ) ) );
        $no_cache = (bool) $req->get_param( 'no_cache' );

        // Transient cache — status + pagination in key.
        $cache_key = 'b2f_makers_list_' . md5( $status_filter . '|' . $page . '|' . $per_page );
        if ( ! $no_cache ) {
            $cached = get_transient( $cache_key );
            if ( is_array( $cached ) && isset( $cached['data'] ) ) {
                $cached['cached'] = true;
                return new WP_REST_Response( $cached, 200 );
            }
        }

        $args = array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => $per_page,
            'paged'          => $page,
            'post_status'    => 'publish',
            'orderby'        => 'title',
            'order'          => 'ASC',
        );

        if ( $status_filter !== 'all' ) {
            $args['meta_query'] = array( array(
                'key'   => 'maker_status',
                'value' => $status_filter,
            ) );
        }

        $q = new WP_Query( $args );
        $maker_ids = wp_list_pluck( $q->posts, 'ID' );
        $makers = array();

        if ( ! empty( $maker_ids ) ) {
            // Prime ACF/get_field cache in a single query — avoids per-field DB hit.
            update_meta_cache( 'post', $maker_ids );

            // Bulk load counts via 2 GROUP BY queries instead of 2N.
            $placeholders = implode( ',', array_fill( 0, count( $maker_ids ), '%d' ) );

            $product_counts = array();
            $prod_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT pm.meta_value AS maker_id, COUNT(*) AS cnt
                 FROM {$wpdb->posts} p
                 INNER JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'mp_maker_id'
                 WHERE p.post_type = 'b2f_maker_product' AND p.post_status = 'publish'
                 AND CAST(pm.meta_value AS UNSIGNED) IN ($placeholders)
                 GROUP BY pm.meta_value",
                $maker_ids
            ), ARRAY_A );
            if ( is_array( $prod_rows ) ) {
                foreach ( $prod_rows as $r ) {
                    $product_counts[ (int) $r['maker_id'] ] = (int) $r['cnt'];
                }
            }

            $po_counts = array();
            $po_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT pm.meta_value AS maker_id, COUNT(*) AS cnt
                 FROM {$wpdb->posts} p
                 INNER JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'po_maker_id'
                 WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
                 AND CAST(pm.meta_value AS UNSIGNED) IN ($placeholders)
                 GROUP BY pm.meta_value",
                $maker_ids
            ), ARRAY_A );
            if ( is_array( $po_rows ) ) {
                foreach ( $po_rows as $r ) {
                    $po_counts[ (int) $r['maker_id'] ] = (int) $r['cnt'];
                }
            }

            foreach ( $q->posts as $p ) {
                $mid = (int) $p->ID;
                $makers[] = b2f_format_maker(
                    $mid,
                    $product_counts[ $mid ] ?? 0,
                    $po_counts[ $mid ] ?? 0
                );
            }
        }

        $payload = array(
            'success'     => true,
            'data'        => $makers,
            'total'       => (int) $q->found_posts,
            'page'        => $page,
            'per_page'    => $per_page,
            'total_pages' => (int) $q->max_num_pages,
            'cached'      => false,
            'cached_at'   => current_time( 'mysql' ),
        );

        if ( ! $no_cache ) {
            set_transient( $cache_key, $payload, 300 );
        }

        return new WP_REST_Response( $payload, 200 );
    }
}

if ( ! function_exists( 'b2f_format_maker' ) ) {
    /**
     * @param int      $maker_id
     * @param int|null $product_count_override PERF-H3: pre-loaded count, skip per-maker COUNT query
     * @param int|null $po_count_override      PERF-H3: pre-loaded count, skip per-maker COUNT query
     */
    function b2f_format_maker( $maker_id, $product_count_override = null, $po_count_override = null ) {
        global $wpdb;

        if ( $product_count_override !== null ) {
            $product_count = (int) $product_count_override;
        } else {
            $product_count = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->posts} p
                 JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'mp_maker_id'
                 WHERE p.post_type = 'b2f_maker_product' AND p.post_status = 'publish' AND pm.meta_value = %s",
                $maker_id
            ) );
        }

        if ( $po_count_override !== null ) {
            $po_count = (int) $po_count_override;
        } else {
            $po_count = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->posts} p
                 JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'po_maker_id'
                 WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish' AND pm.meta_value = %s",
                $maker_id
            ) );
        }

        return array(
            'id'               => $maker_id,
            'name'             => esc_html( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ),
            'contact'          => esc_html( get_field( 'maker_contact', $maker_id ) ?: '' ),
