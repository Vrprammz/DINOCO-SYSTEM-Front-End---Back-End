// ── POST /maker-confirm ──
if ( ! function_exists( 'b2f_api_maker_confirm' ) ) {
    function b2f_api_maker_confirm( WP_REST_Request $request ) {
        $params  = $request->get_json_params();
        $token   = sanitize_text_field( $params['token'] ?? '' );
        $payload = b2f_verify_maker_token( $token );
        if ( is_wp_error( $payload ) ) return $payload;

        $po_id    = intval( $payload['po_id'] );
        $maker_id = intval( $payload['maker_id'] );

        // Rate limit: 5 req/min per maker
        $rate_key = 'b2f_rate_confirm_' . $maker_id;
        $rate     = intval( get_transient( $rate_key ) );
        if ( $rate >= 5 ) {
            return new WP_Error( 'rate_limit', 'คำขอมากเกินไป กรุณารอสักครู่', array( 'status' => 429 ) );
        }
        set_transient( $rate_key, $rate + 1, 60 );

        $expected_date = sanitize_text_field( $params['expected_date'] ?? '' );
        if ( empty( $expected_date ) ) {
            return new WP_Error( 'missing_date', 'กรุณาระบุวันที่คาดว่าจะส่ง', array( 'status' => 400 ) );
        }

        $date_obj = DateTime::createFromFormat( 'Y-m-d', $expected_date );
        $now = new DateTime( 'now', new DateTimeZone( 'Asia/Bangkok' ) );
        if ( ! $date_obj || $date_obj <= $now ) {
            return new WP_Error( 'invalid_date', 'วันส่งต้องเป็นวันในอนาคต', array( 'status' => 400 ) );
        }

        $current_status = get_field( 'po_status', $po_id );
        if ( ! in_array( $current_status, array( 'submitted', 'amended' ), true ) ) {
            return new WP_Error( 'invalid_status', 'สถานะ PO ปัจจุบัน (' . $current_status . ') ไม่สามารถยืนยันได้', array( 'status' => 400 ) );
        }

        if ( function_exists( 'b2f_transition_order' ) ) {
            $result = b2f_transition_order( $po_id, 'confirmed', 'maker' );
            if ( is_wp_error( $result ) ) return $result;
        } else {
            update_field( 'po_status', 'confirmed', $po_id );
        }

        update_field( 'po_expected_date', $expected_date, $po_id );
        $maker_note = sanitize_textarea_field( $params['maker_note'] ?? '' );
        if ( ! empty( $maker_note ) ) {
            update_field( 'po_maker_note', $maker_note, $po_id );
        }

        if ( function_exists( 'b2f_notify_admin_maker_confirmed' ) ) {
            b2f_notify_admin_maker_confirmed( $po_id, $expected_date );
        }

        return rest_ensure_response( array( 'success' => true, 'message' => 'ยืนยัน PO เรียบร้อย' ) );
    }
}

