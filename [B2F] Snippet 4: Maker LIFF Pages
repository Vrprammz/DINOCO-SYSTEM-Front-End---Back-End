        // ถ้ามี po_id ใน URL → โหลด PO detail ตรง, ถ้าไม่มี → แสดง list PO ที่เลื่อนได้
        var poId = new URLSearchParams(window.location.search).get("po_id");
        if (!poId) {
            var res = await apiCall("GET", "maker-po-list", { token: TOKEN, status: "confirmed" });
            var poList = res.data || res.orders || [];
            renderRescheduleList(Array.isArray(poList) ? poList : []);
            return;
        }
        // V.3.5: ส่ง po_id จาก URL params เป็น fallback
        var rscParams = { token: TOKEN };
        if (poId) rscParams.po_id = poId;
        var res = await apiCall("GET", "po-detail/jwt", rscParams);
        PO_DATA = res.data || res;
        if (PO_DATA.currency) _isEng = PO_DATA.currency !== "THB";
        if (PO_DATA.po_status !== "confirmed" && PO_DATA.po_status !== "delivering") {
            showError(L("\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e02\u0e2d\u0e40\u0e25\u0e37\u0e48\u0e2d\u0e19\u0e44\u0e14\u0e49", "Cannot reschedule"),
