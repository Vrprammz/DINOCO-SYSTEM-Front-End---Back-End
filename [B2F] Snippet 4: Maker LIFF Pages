if ( ! function_exists( 'b2f_liff_page_js' ) ) {
    function b2f_liff_page_js( $liff_id, $rest_url ) {
        $js_liff_id  = esc_js( $liff_id );
        $js_rest_url = esc_js( $rest_url );

        return '<script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
<script>
(function(){
"use strict";

var LIFF_ID  = "' . $js_liff_id . '";
var REST_URL = "' . $js_rest_url . '";
var TOKEN    = null;
var LINE_UID = null;
var PO_DATA  = null;
var LOCKED   = false;

// ══════════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════════

async function init() {
    try {
        var params = new URLSearchParams(window.location.search);
        TOKEN = params.get("token") || "";
        var page = params.get("page") || "confirm";

        if (!TOKEN) {
            showError("\u0e25\u0e34\u0e07\u0e01\u0e4c\u0e44\u0e21\u0e48\u0e16\u0e39\u0e01\u0e15\u0e49\u0e2d\u0e07",
                "\u0e44\u0e21\u0e48\u0e1e\u0e1a token \u0e43\u0e19\u0e25\u0e34\u0e07\u0e01\u0e4c \u0e01\u0e23\u0e38\u0e13\u0e32\u0e43\u0e0a\u0e49\u0e25\u0e34\u0e07\u0e01\u0e4c\u0e08\u0e32\u0e01\u0e02\u0e49\u0e2d\u0e04\u0e27\u0e32\u0e21 LINE");
            return;
        }

        await liff.init({ liffId: LIFF_ID });

        if (!liff.isInClient() && !liff.isLoggedIn()) {
            liff.login({ redirectUri: window.location.href });
            return;
        }

        var profile = await liff.getProfile();
        LINE_UID = profile.userId;

        setupOfflineDetection();

        switch (page) {
            case "confirm":    await loadConfirmPage();    break;
            case "detail":     await loadDetailPage();     break;
            case "reschedule": await loadReschedulePage();  break;
            case "list":       await loadListPage();       break;
            case "deliver":    await loadDeliverPage();    break;
            default:           await loadListPage();       break;
        }
    } catch (err) {
        console.error("LIFF init error:", err);
        showError("\u0e40\u0e01\u0e34\u0e14\u0e02\u0e49\u0e2d\u0e1c\u0e34\u0e14\u0e1e\u0e25\u0e32\u0e14",
            "\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e40\u0e1b\u0e34\u0e14\u0e2b\u0e19\u0e49\u0e32\u0e19\u0e35\u0e49\u0e44\u0e14\u0e49 \u0e01\u0e23\u0e38\u0e13\u0e32\u0e25\u0e2d\u0e07\u0e43\u0e2b\u0e21\u0e48\u0e2d\u0e35\u0e01\u0e04\u0e23\u0e31\u0e49\u0e07");
    }
}

// ══════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════

function $(sel) { return document.querySelector(sel); }
function $$(sel) { return document.querySelectorAll(sel); }

function formatNumber(n) {
    return Number(n || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function formatDate(dateStr) {
    if (!dateStr) return "-";
    var d = new Date(dateStr);
    return d.toLocaleDateString("th-TH", { day: "2-digit", month: "2-digit", year: "numeric" });
}

function getMinDate() {
    var d = new Date();
    d.setDate(d.getDate() + 1);
    return d.toISOString().split("T")[0];
}

function statusLabel(status) {
    var labels = {
        draft: "\u0e23\u0e48\u0e32\u0e07", submitted: "\u0e23\u0e2d\u0e22\u0e37\u0e19\u0e22\u0e31\u0e19",
        confirmed: "\u0e22\u0e37\u0e19\u0e22\u0e31\u0e19\u0e41\u0e25\u0e49\u0e27",
        delivering: "\u0e01\u0e33\u0e25\u0e31\u0e07\u0e08\u0e31\u0e14\u0e2a\u0e48\u0e07",
        received: "\u0e23\u0e31\u0e1a\u0e02\u0e2d\u0e07\u0e41\u0e25\u0e49\u0e27",
        partial_received: "\u0e23\u0e31\u0e1a\u0e1a\u0e32\u0e07\u0e2a\u0e48\u0e27\u0e19",
        rejected: "\u0e1b\u0e0f\u0e34\u0e40\u0e2a\u0e18",
        cancelled: "\u0e22\u0e01\u0e40\u0e25\u0e34\u0e01",
        amended: "\u0e41\u0e01\u0e49\u0e44\u0e02",
        paid: "\u0e08\u0e48\u0e32\u0e22\u0e41\u0e25\u0e49\u0e27",
        partial_paid: "\u0e08\u0e48\u0e32\u0e22\u0e1a\u0e32\u0e07\u0e2a\u0e48\u0e27\u0e19",
        completed: "\u0e40\u0e2a\u0e23\u0e47\u0e08\u0e2a\u0e34\u0e49\u0e19"
    };
    return labels[status] || status;
}

function showToast(msg, type) {
    var toast = $(".b2f-toast");
    if (!toast) {
        toast = document.createElement("div");
        toast.className = "b2f-toast";
        document.body.appendChild(toast);
    }
    toast.textContent = msg;
    toast.className = "b2f-toast " + (type || "");
    requestAnimationFrame(function() { toast.classList.add("show"); });
    setTimeout(function() { toast.classList.remove("show"); }, 3000);
}

function showError(title, msg) {
    var app = $("#b2f-app");
    app.innerHTML = "<div class=\"b2f-error\">" +
        "<div class=\"icon\">&#9888;&#65039;</div>" +
        "<h2>" + escHtml(title) + "</h2>" +
        "<p>" + escHtml(msg) + "</p></div>";
}

function showLoading() {
    var app = $("#b2f-app");
    app.innerHTML = "<div class=\"b2f-loading\">" +
        "<div class=\"b2f-spinner b2f-spinner-lg\"></div>" +
        "<p>\u0e01\u0e33\u0e25\u0e31\u0e07\u0e42\u0e2b\u0e25\u0e14...</p></div>";
}

function escHtml(s) {
    var d = document.createElement("div");
    d.textContent = s || "";
    return d.innerHTML;
}

function lockBtn(btn) {
    if (LOCKED) return false;
    LOCKED = true;
    btn.disabled = true;
    btn.dataset.origText = btn.innerHTML;
    btn.innerHTML = "<span class=\"b2f-spinner\"></span> \u0e01\u0e33\u0e25\u0e31\u0e07\u0e14\u0e33\u0e40\u0e19\u0e34\u0e19\u0e01\u0e32\u0e23...";
    return true;
}

function unlockBtn(btn) {
    LOCKED = false;
    btn.disabled = false;
    if (btn.dataset.origText) btn.innerHTML = btn.dataset.origText;
}

function setupOfflineDetection() {
    var banner = document.createElement("div");
    banner.className = "b2f-offline-banner";
    banner.textContent = "\u0e44\u0e21\u0e48\u0e21\u0e35\u0e2d\u0e34\u0e19\u0e40\u0e17\u0e2d\u0e23\u0e4c\u0e40\u0e19\u0e47\u0e15 \u0e01\u0e23\u0e38\u0e13\u0e32\u0e15\u0e23\u0e27\u0e08\u0e2a\u0e2d\u0e1a\u0e01\u0e32\u0e23\u0e40\u0e0a\u0e37\u0e48\u0e2d\u0e21\u0e15\u0e48\u0e2d";
    document.body.prepend(banner);
    window.addEventListener("offline", function() { banner.classList.add("show"); });
    window.addEventListener("online", function() { banner.classList.remove("show"); });
}

async function apiCall(method, endpoint, body) {
    var opts = {
        method: method,
        headers: {
            "Content-Type": "application/json",
            "X-B2F-Token": TOKEN,
            "X-B2F-Line-Uid": LINE_UID || ""
        }
    };
    if (body && method !== "GET") opts.body = JSON.stringify(body);

    var url = REST_URL + endpoint;
    if (method === "GET" && body) {
        url += "?" + new URLSearchParams(body).toString();
    }

    var res = await fetch(url, opts);
    var json = await res.json();

    if (!res.ok) {
        throw new Error(json.message || (json.data && json.data.message) || "\u0e40\u0e01\u0e34\u0e14\u0e02\u0e49\u0e2d\u0e1c\u0e34\u0e14\u0e1e\u0e25\u0e32\u0e14");
    }
    return json;
}

