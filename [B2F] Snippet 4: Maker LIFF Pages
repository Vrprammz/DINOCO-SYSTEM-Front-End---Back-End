function $(sel) { return document.querySelector(sel); }
function $$(sel) { return document.querySelectorAll(sel); }

function formatNumber(n) {
    return Number(n || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function curSym(po) {
    return (po && po.currency_symbol) ? po.currency_symbol : "\u0e3f";
}

function formatDate(dateStr) {
    if (!dateStr) return "-";
    var d = new Date(dateStr);
    return d.toLocaleDateString(_isEng ? "en-GB" : "th-TH", { day: "2-digit", month: "2-digit", year: "numeric" });
}

function fmtDateShort(d) {
    if (!d) return "-";
    var dt = new Date(d);
    var dd = String(dt.getDate()).padStart(2, "0");
    var mm = String(dt.getMonth() + 1).padStart(2, "0");
    if (_isEng) {
        var yy = String(dt.getFullYear()).slice(-2);
        return dd + "/" + mm + "/" + yy;
    }
    var yy = String(dt.getFullYear() + 543).slice(-2);
    return dd + "/" + mm + "/" + yy;
}

function buildTimelineBars(po) {
    var html = "";
    var today = new Date();
    today.setHours(0,0,0,0);

    // Bar 1: กำหนดส่ง
    var eta = po.expected_date || po.po_expected_date;
    var created = po.created_date || po.post_date;
    var status = po.status || po.po_status || "";
    var showDeliveryBar = eta && ["submitted","confirmed","amended","delivering","partial_received"].indexOf(status) !== -1;

    if (showDeliveryBar) {
        var etaDate = new Date(eta);
        var createdDate = new Date(created);
        etaDate.setHours(0,0,0,0);
        createdDate.setHours(0,0,0,0);
        var totalDays = Math.max(1, Math.round((etaDate - createdDate) / 86400000));
        var elapsed = Math.round((today - createdDate) / 86400000);
        var remaining = Math.round((etaDate - today) / 86400000);
        var pct = Math.min(100, Math.max(0, Math.round(elapsed / totalDays * 100)));
        var overdue = remaining < 0;
        var color = overdue ? "#dc2626" : (pct > 80 ? "#f59e0b" : (pct > 50 ? "#eab308" : "#16a34a"));
        var daysText = overdue ? "<span style=\"color:#dc2626\">" + L("\u0e40\u0e25\u0e22 " + Math.abs(remaining) + " \u0e27\u0e31\u0e19", Math.abs(remaining) + " days overdue") + "</span>" : L("\u0e40\u0e2b\u0e25\u0e37\u0e2d " + remaining + " \u0e27\u0e31\u0e19", remaining + " days left");

        html += "<div class=\"b2f-timeline-bar\">";
        html += "<div class=\"b2f-timeline-label\"><span class=\"title\">&#128230; " + L("\u0e01\u0e33\u0e2b\u0e19\u0e14\u0e2a\u0e48\u0e07", "Delivery ETA") + "</span><span class=\"days\" style=\"color:" + color + "\">" + daysText + "</span></div>";
        html += "<div class=\"b2f-timeline-track\"><div class=\"b2f-timeline-fill\" style=\"width:" + (overdue ? 100 : pct) + "%;background:" + color + "\"></div></div>";
        html += "<div class=\"b2f-timeline-dates\"><span>" + fmtDateShort(created) + "</span><span>" + fmtDateShort(eta) + "</span></div>";
        html += "</div>";
    }

    // Bar 2: ครบกำหนดจ่าย (เฉพาะ THB — โรงงานต่างประเทศจ่ายก่อน ไม่มีเครดิต)
    var actualDate = po.actual_date || po.po_actual_date;
    var creditDays = po.credit_term_days || 30;
    var dueDate = po.payment_due_date;
    var poCurrency = po.currency || po.po_currency || "THB";
    // เครดิตนับจากวันรับครบเท่านั้น (ไม่นับ partial_received)
    var showCreditBar = poCurrency === "THB" && actualDate && ["received","partial_paid"].indexOf(status) !== -1;

    if (showCreditBar) {
        var rcvDate = new Date(actualDate);
        rcvDate.setHours(0,0,0,0);
        var payDue = dueDate ? new Date(dueDate) : new Date(rcvDate.getTime() + creditDays * 86400000);
        payDue.setHours(0,0,0,0);
        var creditTotal = Math.max(1, Math.round((payDue - rcvDate) / 86400000));
        var creditElapsed = Math.round((today - rcvDate) / 86400000);
        var creditRemaining = Math.round((payDue - today) / 86400000);
        var creditPct = Math.min(100, Math.max(0, Math.round(creditElapsed / creditTotal * 100)));
        var creditOverdue = creditRemaining < 0;
        var creditColor = creditOverdue ? "#dc2626" : (creditPct > 85 ? "#f59e0b" : (creditPct > 60 ? "#eab308" : "#16a34a"));
        var creditText = creditOverdue ? "<span style=\"color:#dc2626\">" + L("\u0e40\u0e25\u0e22 " + Math.abs(creditRemaining) + " \u0e27\u0e31\u0e19", Math.abs(creditRemaining) + " days overdue") + "</span>" : L("\u0e40\u0e2b\u0e25\u0e37\u0e2d " + creditRemaining + " \u0e27\u0e31\u0e19", creditRemaining + " days left");

        html += "<div class=\"b2f-timeline-bar\">";
        html += "<div class=\"b2f-timeline-label\"><span class=\"title\">&#128176; " + L("\u0e04\u0e23\u0e1a\u0e01\u0e33\u0e2b\u0e19\u0e14\u0e08\u0e48\u0e32\u0e22", "Payment Due") + "</span><span class=\"days\" style=\"color:" + creditColor + "\">" + creditText + "</span></div>";
        html += "<div class=\"b2f-timeline-track\"><div class=\"b2f-timeline-fill\" style=\"width:" + (creditOverdue ? 100 : creditPct) + "%;background:" + creditColor + "\"></div></div>";
        html += "<div class=\"b2f-timeline-dates\"><span>" + fmtDateShort(actualDate) + " (" + L("\u0e23\u0e31\u0e1a\u0e02\u0e2d\u0e07", "Received") + ")</span><span>" + fmtDateShort(dueDate || payDue.toISOString().split("T")[0]) + " (" + creditDays + " " + L("\u0e27\u0e31\u0e19", "days") + ")</span></div>";
        html += "</div>";
    }

    return html;
}

function getMinDate() {
    var d = new Date();
    d.setDate(d.getDate() + 1);
    return d.toISOString().split("T")[0];
