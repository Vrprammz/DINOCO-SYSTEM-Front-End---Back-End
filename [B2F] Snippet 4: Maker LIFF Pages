        }
        set_transient( $rate_key, $rate + 1, 60 );

        $new_date = sanitize_text_field( $params['new_date'] ?? '' );
        if ( empty( $new_date ) ) {
            return new WP_Error( 'missing_date', 'กรุณาระบุวันส่งใหม่', array( 'status' => 400 ) );
        }

        $date_obj = DateTime::createFromFormat( 'Y-m-d', $new_date );
