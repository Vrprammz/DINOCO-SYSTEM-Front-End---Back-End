        if (res.maker_currency) _isEng = res.maker_currency !== "THB";
        else if (Array.isArray(poList) && poList.length > 0 && poList[0].currency) _isEng = poList[0].currency !== "THB";
        renderListPage(Array.isArray(poList) ? poList : []);
    } catch (err) {
        showError(L("\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e42\u0e2b\u0e25\u0e14\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25\u0e44\u0e14\u0e49", "Failed to load"), err.message);
