// V.3.16: Build status info badges from PO data
function buildStatusInfoBadges(po) {
    var items = po.items || po.po_items || [];
    var status = po.po_status || "";
    var html = "";

    // คำนวณ aggregate
    var totalPendingInspect = 0; // shipped แต่ยังไม่ received
    var totalRejected = 0;
    items.forEach(function(it) {
        var shipped  = Number(it.poi_qty_shipped  || it.qty_shipped  || 0);
        var received = Number(it.poi_qty_received || it.qty_received || 0);
        var rejected = Number(it.poi_qty_rejected || it.qty_rejected || 0);
        var pending = shipped - received;
        if (pending > 0) totalPendingInspect += pending;
        if (rejected > 0) totalRejected += rejected;
    });

    if (status === "delivering") {
        if (totalPendingInspect > 0) {
            html += "<div class=\"b2f-status-info info-waiting\">&#128269; " + L("รอ DINOCO ตรวจรับสินค้า " + totalPendingInspect + " ชิ้น", "Pending inspection: " + totalPendingInspect + " items") + "</div>";
        } else if (items.length === 0) {
            html += "<div class=\"b2f-status-info info-waiting\">&#128269; " + L("รอ DINOCO ตรวจรับสินค้า", "Pending inspection") + "</div>";
        }
    } else if (status === "partial_received") {
        if (totalRejected > 0) {
            html += "<div class=\"b2f-status-info info-reject\">&#9888;&#65039; " + L("ถูก reject " + totalRejected + " ชิ้น กรุณาส่งทดแทน", totalRejected + " items rejected — replacement required") + "</div>";
        }
        if (totalPendingInspect > 0) {
            html += "<div class=\"b2f-status-info info-waiting\">&#128269; " + L("รอตรวจรับ " + totalPendingInspect + " ชิ้น", "Pending inspection: " + totalPendingInspect + " items") + "</div>";
        }
        if (totalRejected === 0 && totalPendingInspect === 0 && items.length === 0) {
            html += "<div class=\"b2f-status-info info-reject\">&#9888;&#65039; " + L("รับบางส่วน — ดูรายละเอียดใน PO", "Partial received — see PO details") + "</div>";
        }
    } else if (status === "received") {
        html += "<div class=\"b2f-status-info info-success\">&#9989; " + L("DINOCO รับของครบแล้ว รอชำระเงิน", "Received — pending payment") + "</div>";
    } else if (status === "partial_paid") {
        html += "<div class=\"b2f-status-info info-payment\">&#128176; " + L("จ่ายแล้วบางส่วน", "Partial paid") + "</div>";
    } else if (status === "paid" || status === "completed") {
        html += "<div class=\"b2f-status-info info-success\">&#9989; " + L("จ่ายครบ — PO สำเร็จ", "Paid — PO completed") + "</div>";
    }

    return html;
}

function showToast(msg, type) {
