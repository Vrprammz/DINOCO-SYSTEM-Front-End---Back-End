                });
                remainInfo += "</div>";
                if (hasRemaining) {
                    remainInfo += "<div style=\"margin-top:6px;font-size:11px;color:#1e40af;\">&#128230; กดปุ่มด้านล่างเพื่อส่งสินค้าเพิ่ม</div>";
