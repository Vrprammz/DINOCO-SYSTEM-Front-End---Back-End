// V.3.6: อ่าน JWT payload โดยไม่ verify (ใช้ดึง page fallback เท่านั้น)
function jwtPayload(token) {
    try {
        var parts = token.split(".");
        if (parts.length < 2) return {};
        var b64 = parts[1].replace(/-/g, "+").replace(/_/g, "/");
        return JSON.parse(atob(b64));
    } catch(e) { return {}; }
}

async function init() {
    try {
        var params = new URLSearchParams(window.location.search);
        TOKEN = params.get("token") || "";
        // V.3.7: use view param instead of page (WP reserved query var)
        // fallback: read page from JWT payload → default list
        var page = params.get("view") || params.get("page") || "";
        if (!page && TOKEN) {
            var payload = jwtPayload(TOKEN);
            page = payload.page || "list";
        }
        if (!page) page = "list";

        if (!TOKEN) {
            showError(L("\u0e25\u0e34\u0e07\u0e01\u0e4c\u0e44\u0e21\u0e48\u0e16\u0e39\u0e01\u0e15\u0e49\u0e2d\u0e07", "Invalid link"),
                L("\u0e44\u0e21\u0e48\u0e1e\u0e1a token \u0e43\u0e19\u0e25\u0e34\u0e07\u0e01\u0e4c \u0e01\u0e23\u0e38\u0e13\u0e32\u0e43\u0e0a\u0e49\u0e25\u0e34\u0e07\u0e01\u0e4c\u0e08\u0e32\u0e01\u0e02\u0e49\u0e2d\u0e04\u0e27\u0e32\u0e21 LINE", "No token found. Please use the link from LINE message."));
            return;
        }

        await liff.init({ liffId: LIFF_ID });

        if (!liff.isInClient() && !liff.isLoggedIn()) {
            liff.login({ redirectUri: window.location.href });
            return;
        }

        var profile = await liff.getProfile();
        LINE_UID = profile.userId;

        // V.4.1: ตั้ง _isEng จาก JWT payload (maker_currency) ตั้งแต่ init
        if (TOKEN) {
            var jwt = jwtPayload(TOKEN);
            if (jwt.maker_currency) _isEng = jwt.maker_currency !== "THB";
            else if (jwt.maker_id) {
                // fallback: ดึงจาก maker data ถ้า JWT ไม่มี currency
                try {
                    var mRes = await apiCall("GET", "maker/" + jwt.maker_id, { token: TOKEN });
                    if (mRes && mRes.currency) _isEng = mRes.currency !== "THB";
                } catch(e) {}
            }
        }

        setupOfflineDetection();

        switch (page) {
            case "confirm":    await loadConfirmPage();    break;
            case "detail":     await loadDetailPage();     break;
            case "reschedule": await loadReschedulePage();  break;
            case "list":       await loadListPage();       break;
            case "deliver":    await loadDeliverPage();    break;
            default:           await loadListPage();       break;
        }
    } catch (err) {
        console.error("LIFF init error:", err);
        showError(L("\u0e40\u0e01\u0e34\u0e14\u0e02\u0e49\u0e2d\u0e1c\u0e34\u0e14\u0e1e\u0e25\u0e32\u0e14", "Error"),
            L("\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e40\u0e1b\u0e34\u0e14\u0e2b\u0e19\u0e49\u0e32\u0e19\u0e35\u0e49\u0e44\u0e14\u0e49 \u0e01\u0e23\u0e38\u0e13\u0e32\u0e25\u0e2d\u0e07\u0e43\u0e2b\u0e21\u0e48\u0e2d\u0e35\u0e01\u0e04\u0e23\u0e31\u0e49\u0e07", "Unable to open this page. Please try again."));
    }
}

