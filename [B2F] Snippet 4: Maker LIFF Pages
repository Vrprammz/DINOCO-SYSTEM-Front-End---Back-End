function buildTimeline(po) {
    var allStates = [
        { key: "submitted", label: L("\u0e2a\u0e23\u0e49\u0e32\u0e07 PO", "PO Created") },
        { key: "confirmed", label: L("Maker \u0e22\u0e37\u0e19\u0e22\u0e31\u0e19", "Maker Confirmed") },
        { key: "delivering", label: L("\u0e01\u0e33\u0e25\u0e31\u0e07\u0e08\u0e31\u0e14\u0e2a\u0e48\u0e07", "Shipping") },
        { key: "received", label: L("\u0e23\u0e31\u0e1a\u0e02\u0e2d\u0e07\u0e41\u0e25\u0e49\u0e27", "Received") },
        { key: "paid", label: L("\u0e08\u0e48\u0e32\u0e22\u0e40\u0e07\u0e34\u0e19\u0e41\u0e25\u0e49\u0e27", "Paid") },
        { key: "completed", label: L("\u0e40\u0e2a\u0e23\u0e47\u0e08\u0e2a\u0e34\u0e49\u0e19", "Completed") }
    ];

    var stateOrder = allStates.map(function(s) { return s.key; });
    var currentIdx = stateOrder.indexOf(po.po_status);

    if (po.po_status === "rejected" || po.po_status === "cancelled") {
        return "<div class=\"b2f-timeline-item active\">" +
            "<div class=\"tl-title\">\u0e2a\u0e23\u0e49\u0e32\u0e07 PO</div>" +
            "<div class=\"tl-date\">" + formatDate(po.post_date || po.created_date) + "</div></div>" +
            "<div class=\"b2f-timeline-item current\">" +
            "<div class=\"tl-title\" style=\"color:var(--b2f-danger);\">" + statusLabel(po.po_status) + "</div>" +
            "<div class=\"tl-note\">" + escHtml(po.po_rejected_reason || po.po_cancelled_reason || "") + "</div></div>";
    }

    var html = "";
    allStates.forEach(function(state, idx) {
        var cls = "";
        if (idx < currentIdx) cls = "active";
        else if (idx === currentIdx) cls = "current";

        var dateStr = "";
        if (state.key === "submitted") dateStr = formatDate(po.post_date || po.created_date);
        else if (state.key === "confirmed" && po.po_expected_date) dateStr = "ETA: " + formatDate(po.po_expected_date);
        else if (state.key === "received" && po.po_actual_date) dateStr = formatDate(po.po_actual_date);

        html += "<div class=\"b2f-timeline-item " + cls + "\">" +
            "<div class=\"tl-title\">" + state.label + "</div>" +
            (dateStr ? "<div class=\"tl-date\">" + dateStr + "</div>" : "") + "</div>";
    });
    return html;
}

