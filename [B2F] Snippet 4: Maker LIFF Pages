                "<textarea id=\"b2f-reschedule-reason\" placeholder=\"" + L("\u0e40\u0e0a\u0e48\u0e19 \u0e27\u0e31\u0e15\u0e16\u0e38\u0e14\u0e34\u0e1a\u0e25\u0e48\u0e32\u0e0a\u0e49\u0e32, \u0e40\u0e04\u0e23\u0e37\u0e48\u0e2d\u0e07\u0e08\u0e31\u0e01\u0e23\u0e40\u0e2a\u0e35\u0e22", "e.g. Material delay, machine breakdown") + "\" rows=\"3\"></textarea>" +
