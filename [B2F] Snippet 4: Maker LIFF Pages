        return '<script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
<script>
(function(){
"use strict";

var LIFF_ID  = "' . $js_liff_id . '";
var REST_URL = "' . $js_rest_url . '";
var TOKEN    = null;
var LINE_UID = null;
var PO_DATA  = null;
var LOCKED   = false;

// ── LANG system: ENG for non-THB currency makers ──
var _isEng = false;
function L(th, en) { return _isEng ? en : th; }

// ══════════════════════════════════════════════════════════════
// INIT
