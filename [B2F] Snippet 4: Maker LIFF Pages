async function loadDeliverPage() {
    showLoading();
    try {
        // V.3.13: รวม delivering ด้วย — แสดงสถานะ "รอตรวจรับ" แทนที่จะหายไป
        var res = await apiCall("GET", "maker-po-list", { token: TOKEN, status: "confirmed,partial_received,delivering" });
        var poList = res.data || res.orders || [];
        if (Array.isArray(poList) && poList.length > 0 && poList[0].currency) _isEng = poList[0].currency !== "THB";
        renderDeliverPage(Array.isArray(poList) ? poList : []);
    } catch (err) {
        showError(L("\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e42\u0e2b\u0e25\u0e14\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25\u0e44\u0e14\u0e49", "Failed to load"), err.message);
    }
}

function renderDeliverPage(poList) {
    var app = $("#b2f-app");
    var cardsHtml = "";
    if (poList.length === 0) {
        cardsHtml = "<div class=\"b2f-empty\"><div class=\"icon\">&#128230;</div><p>" + L("\u0e44\u0e21\u0e48\u0e21\u0e35 PO \u0e17\u0e35\u0e48\u0e23\u0e2d\u0e2a\u0e48\u0e07\u0e02\u0e2d\u0e07\u0e15\u0e2d\u0e19\u0e19\u0e35\u0e49", "No POs pending shipment") + "</p></div>";
    } else {
        poList.forEach(function(po) {
            var isPartial    = (po.po_status === "partial_received");
            var isDelivering = (po.po_status === "delivering");
            var statusCls = isDelivering ? "b2f-status-delivering" : (isPartial ? "b2f-status-partial_received" : "b2f-status-confirmed");
            var hasRemaining = false;
            (po.items || po.po_items || []).forEach(function(it) {
                var ord = Number(it.poi_qty_ordered || it.qty_ordered || 0);
                var shp = Number(it.poi_qty_shipped || it.qty_shipped || 0);
                var rej = Number(it.poi_qty_rejected || it.qty_rejected || 0);
                if (ord - shp + rej > 0) hasRemaining = true;
            });
            var btnLabel = (isDelivering || isPartial) ? "&#128230; " + L("\u0e2a\u0e48\u0e07\u0e2a\u0e34\u0e19\u0e04\u0e49\u0e32\u0e40\u0e1e\u0e34\u0e48\u0e21", "Ship more items") : "&#128666; " + L("\u0e41\u0e08\u0e49\u0e07\u0e2a\u0e48\u0e07\u0e02\u0e2d\u0e07", "Ship items");
            var btnColor = (isDelivering || isPartial) ? "background:#ca8a04;border-color:#ca8a04;" : "";
            var btnDisabled = !hasRemaining;

            // แสดงสรุป shipped/remaining ทั้ง partial_received + delivering
            var remainInfo = "";
            var poItems = po.items || po.po_items || [];
            if ((isPartial || isDelivering) && poItems.length) {
                var totalOrdered = 0, totalShipped = 0;
                poItems.forEach(function(it) {
                    totalOrdered  += Number(it.poi_qty_ordered || it.qty_ordered || 0);
                    totalShipped  += Number(it.poi_qty_shipped || it.qty_shipped || 0);
                });
                var totalRemaining = totalOrdered - totalShipped;
                var bgColor = isDelivering ? "#eff6ff" : "#fef9c3";
                var txColor = isDelivering ? "#1e40af" : "#854d0e";
                remainInfo = "<div style=\"margin-top:6px;padding:8px 10px;background:" + bgColor + ";border-radius:8px;font-size:12px;color:" + txColor + ";\">";
                remainInfo += "<div style=\"font-weight:600;margin-bottom:4px;\">" +
                    (isDelivering ? "&#128230; " + L("ส่งแล้วบางส่วน", "Partially shipped") : "&#128230; " + L("รับแล้วบางส่วน", "Partially received")) + "</div>";
                // ตาราง header + rows
                remainInfo += "<div style=\"margin-top:6px;font-size:11px;\">";
                remainInfo += "<div style=\"display:flex;gap:4px;padding:2px 0;font-weight:700;color:#475569;border-bottom:1px solid " + (isDelivering ? "#bfdbfe" : "#fde68a") + ";\">" +
                    "<span style=\"flex:3;\">" + L("สินค้า", "Product") + "</span>" +
                    "<span style=\"flex:1;text-align:center;\">" + L("สั่ง", "Ord") + "</span>" +
                    "<span style=\"flex:1;text-align:center;\">" + L("ส่ง", "Ship") + "</span>" +
                    "<span style=\"flex:1;text-align:center;\">" + L("เหลือ", "Left") + "</span>" +
                "</div>";
                poItems.forEach(function(it) {
                    var ord = Number(it.poi_qty_ordered || it.qty_ordered || 0);
                    var shp = Number(it.poi_qty_shipped || it.qty_shipped || 0);
                    var left = Math.max(0, ord - shp);
                    var name = escHtml(it.poi_product_name || it.product_name || it.poi_sku || it.sku || "");
                    var sku = escHtml(it.poi_sku || it.sku || "");
                    var leftColor = left > 0 ? "color:#dc2626;font-weight:700;" : "color:#16a34a;";
                    remainInfo += "<div style=\"display:flex;gap:4px;padding:4px 0;border-bottom:1px solid #f1f5f9;align-items:center;\">" +
                        "<div style=\"flex:3;overflow:hidden;min-width:0;\">" +
                            "<div style=\"overflow:hidden;text-overflow:ellipsis;white-space:nowrap;\">" + name + "</div>" +
                            "<div style=\"font-size:10px;color:#94a3b8;\">" + sku + "</div>" +
                        "</div>" +
                        "<span style=\"flex:1;text-align:center;\">" + ord + "</span>" +
                        "<span style=\"flex:1;text-align:center;\">" + shp + "</span>" +
                        "<span style=\"flex:1;text-align:center;" + leftColor + "\">" + left + "</span>" +
                    "</div>";
                });
                remainInfo += "</div>";
                // V.3.16: สรุป pending inspect + reject
                var dlvPendingInspect = 0, dlvTotalRejected = 0;
                poItems.forEach(function(it) {
                    var shp2 = Number(it.poi_qty_shipped || it.qty_shipped || 0);
                    var rcv2 = Number(it.poi_qty_received || it.qty_received || 0);
                    var rej2 = Number(it.poi_qty_rejected || it.qty_rejected || 0);
                    if (shp2 - rcv2 > 0) dlvPendingInspect += (shp2 - rcv2);
                    if (rej2 > 0) dlvTotalRejected += rej2;
                });
                if (dlvPendingInspect > 0) {
                    remainInfo += "<div style=\"margin-top:6px;font-size:11px;color:#1e40af;font-weight:600;\">&#128269; " + L("รอตรวจรับ " + dlvPendingInspect + " ชิ้น", "Pending inspection: " + dlvPendingInspect + " items") + "</div>";
                }
                if (dlvTotalRejected > 0) {
                    remainInfo += "<div style=\"margin-top:4px;font-size:11px;color:#991b1b;font-weight:600;\">&#9888;&#65039; " + L("reject " + dlvTotalRejected + " ชิ้น ส่งทดแทนได้", dlvTotalRejected + " items rejected — replacement available") + "</div>";
                }
                if (hasRemaining) {
                    remainInfo += "<div style=\"margin-top:6px;font-size:11px;color:#1e40af;\">&#128230; " + L("กดปุ่มด้านล่างเพื่อส่งสินค้าเพิ่ม", "Tap button below to ship more") + "</div>";
                } else {
                    remainInfo += "<div style=\"margin-top:4px;font-size:11px;color:#16a34a;\">&#9989; " + L("ส่งครบแล้ว รอ DINOCO ตรวจรับ", "Fully shipped — pending inspection") + "</div>";
                }
                remainInfo += "</div>";
            }

            cardsHtml +=
                "<div class=\"b2f-po-card\" style=\"cursor:pointer\" data-po-id=\"" + escHtml(String(po.ID || po.id)) + "\">" +
                    "<div class=\"po-header\">" +
                        "<span class=\"po-number\">" + escHtml(po.po_number) + "</span>" +
                        "<span class=\"b2f-status " + statusCls + "\">" + statusLabel(po.po_status) + "</span>" +
                    "</div>" +
                    "<div class=\"po-meta\">" +
                        Number(po.po_item_count || (po.po_items || []).length) + " " + L("รายการ", "items") +
                        (po.po_expected_date ? " &middot; ETA: " + formatDate(po.po_expected_date) : "") +
                    "</div>" +
                    "<div class=\"po-total\">" + curSym(po) + formatNumber(po.po_total_amount) + "</div>" +
                    remainInfo +
                    "<div style=\"margin-top:10px\">" +
                        "<button class=\"b2f-btn b2f-btn-primary\" style=\"width:100%;font-size:13px;padding:10px;" + (btnDisabled ? "background:#94a3b8;border-color:#94a3b8;" : btnColor) + "\"" +
                            (btnDisabled ? " disabled" : " onclick=\"event.stopPropagation();b2fOpenDeliverForm(" + (po.ID || po.id) + ")\"") +
                        ">" +
                            (btnDisabled ? "&#9989; " + L("ส่งครบแล้ว", "Fully shipped") : btnLabel) +
                        "</button>" +
                    "</div>" +
                "</div>";
        });
    }

    app.innerHTML =
        "<div class=\"b2f-liff-header\">" +
            "<div class=\"b2f-header-content\">" +
            "<h1>&#128666; " + L("แจ้งจัดส่งสินค้า", "Shipment") + "</h1>" +
            "<div class=\"b2f-sub\">" + L("PO ที่รอจัดส่ง " + poList.length + " รายการ", poList.length + " POs pending shipment") + "</div>" +
            "</div>" +
            "<img src=\"https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png\" class=\"b2f-logo\" alt=\"DINOCO\">" +
        "</div>" +
        "<div style=\"padding:0\">" + cardsHtml + "</div>" +
        "<div style=\"padding:12px;text-align:center;\">" +
            "<button class=\"b2f-btn b2f-btn-outline\" onclick=\"goToPage(&apos;list&apos;)\">\u2190 " + L("\u0e01\u0e25\u0e31\u0e1a\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23", "Back to list") + "</button>" +
        "</div>";
}

// ── Delivery Form: กรอกจำนวนต่อ SKU ──
var _deliverPoData = null;

window.b2fOpenDeliverForm = async function(poId) {
    showLoading();
    try {
        var res = await apiCall("GET", "po-detail/jwt", { token: TOKEN, po_id: poId });
        _deliverPoData = res.data || res;
        if (_deliverPoData.currency) _isEng = _deliverPoData.currency !== "THB";
        renderDeliverForm();
    } catch (err) {
        showError(L("โหลดข้อมูล PO ไม่สำเร็จ", "Failed to load PO"), err.message);
    }
};

function renderDeliverForm() {
    var po = _deliverPoData;
    if (!po) return;
    var app = $("#b2f-app");
    var items = po.items || po.po_items || [];

    var rows = "";
    items.forEach(function(it, idx) {
        var ordered  = Number(it.qty_ordered || it.poi_qty_ordered || 0);
        var shipped  = Number(it.qty_shipped || it.poi_qty_shipped || 0);
        var rejected = Number(it.qty_rejected || it.poi_qty_rejected || 0);
        var remaining = Math.max(0, ordered - shipped + rejected);
        var name = it.product_name || it.poi_product_name || it.sku || it.poi_sku || "";
        var sku  = it.sku || it.poi_sku || "";
        var isDone = (remaining <= 0);

        rows += "<div class=\"b2f-po-card\" style=\"padding:12px;margin-bottom:8px;" + (isDone ? "opacity:0.5;" : "") + "\">" +
            "<div style=\"font-weight:600;font-size:13px;\">" + escHtml(name) + "</div>" +
            "<div style=\"font-size:11px;color:#64748b;\">SKU: " + escHtml(sku) + "</div>" +
            "<div style=\"display:flex;gap:12px;margin-top:6px;font-size:12px;color:#475569;\">" +
                "<span>" + L("สั่ง", "Ordered") + ": <b>" + ordered + "</b></span>" +
                "<span>" + L("ส่งแล้ว", "Shipped") + ": <b>" + shipped + "</b></span>" +
                "<span>" + L("ค้างส่ง", "Remaining") + ": <b style=\"color:" + (remaining > 0 ? "#d97706" : "#16a34a") + "\">" + remaining + "</b></span>" +
            "</div>";

        // V.3.16: per-item pending inspect + reject badges
        var received = Number(it.qty_received || it.poi_qty_received || 0);
        var pendingInspect = shipped - received;
        if (pendingInspect > 0) {
            rows += "<div class=\"b2f-status-info info-waiting\" style=\"margin-top:6px;padding:6px 10px;font-size:11px;\">&#128269; " + L("รอตรวจรับ " + pendingInspect + " ชิ้น", "Pending inspection: " + pendingInspect) + "</div>";
        }
        if (rejected > 0) {
            rows += "<div class=\"b2f-status-info info-reject\" style=\"margin-top:4px;padding:6px 10px;font-size:11px;\">&#9888;&#65039; " + L("reject " + rejected + " ชิ้น ส่งทดแทนได้", rejected + " rejected — replacement available") + "</div>";
        }

        if (isDone) {
            rows += "<div style=\"margin-top:6px;font-size:12px;color:#16a34a;font-weight:600;\">" + L("✅ ส่งครบแล้ว", "✅ Fully shipped") + "</div>";
        } else {
            rows += "<div style=\"margin-top:10px;\">" +
                "<div style=\"font-size:12px;color:#374151;margin-bottom:6px;font-weight:600;\">" + L("ส่งรอบนี้:", "This shipment:") + "</div>" +
                "<div style=\"display:flex;align-items:center;gap:6px;\">" +
                    "<button type=\"button\" onclick=\"b2fStepQty(this,-1)\" style=\"width:48px;height:48px;border:1px solid #d1d5db;border-radius:10px;background:#f8fafc;font-size:22px;font-weight:700;cursor:pointer;color:#374151;\">-</button>" +
                    "<input type=\"number\" inputmode=\"numeric\" pattern=\"[0-9]*\" class=\"b2f-dlv-qty\" data-idx=\"" + idx + "\" data-sku=\"" + escHtml(sku) + "\" " +
                        "min=\"0\" max=\"" + remaining + "\" value=\"0\" " +
                        "style=\"flex:1;padding:12px;border:2px solid #d1d5db;border-radius:12px;font-size:28px;font-weight:700;text-align:center;max-width:120px;\">" +
                    "<button type=\"button\" onclick=\"b2fStepQty(this,1)\" style=\"width:48px;height:48px;border:1px solid #d1d5db;border-radius:10px;background:#f8fafc;font-size:22px;font-weight:700;cursor:pointer;color:#374151;\">+</button>" +
                    "<span style=\"font-size:13px;color:#94a3b8;font-weight:600;\">/ " + remaining + "</span>" +
                "</div>" +
            "</div>";
        }
        rows += "</div>";
    });

    app.innerHTML =
        "<div class=\"b2f-liff-header\">" +
            "<div class=\"b2f-header-content\">" +
            "<div style=\"display:flex;align-items:center;gap:10px;\">" +
                "<button onclick=\"loadDeliverPage()\" style=\"background:none;border:none;font-size:20px;cursor:pointer;padding:4px;color:#fff;\">←</button>" +
                "<div><h1 style=\"margin:0;\">" + L("🚛 กรอกรายการจัดส่ง", "🚛 Shipment Form") + "</h1>" +
                "<div class=\"b2f-sub\">" + escHtml(po.po_number) + "</div></div>" +
            "</div></div>" +
            "<img src=\"https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png\" class=\"b2f-logo\" alt=\"DINOCO\">" +
        "</div>" +
        "<div style=\"padding:0 12px;\">" +
            "<button class=\"b2f-btn b2f-btn-secondary\" style=\"width:100%;margin-bottom:12px;font-size:13px;padding:10px;\" onclick=\"b2fFillAllRemaining()\">" +
                L("📋 ส่งครบทุกรายการ (auto-fill)", "📋 Fill all (auto)") +
            "</button>" +
            rows +
            "<div style=\"padding:12px 0;\">" +
                "<textarea id=\"b2f-dlv-note\" placeholder=\"" + L("หมายเหตุ (ถ้ามี)", "Notes (optional)") + "\" rows=\"2\" " +
                    "style=\"width:100%;padding:10px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;box-sizing:border-box;\"></textarea>" +
            "</div>" +
            "<div style=\"display:flex;gap:8px;padding-bottom:20px;\">" +
                "<button class=\"b2f-btn b2f-btn-secondary\" style=\"flex:1;padding:12px;\" onclick=\"loadDeliverPage()\">" + L("← กลับ", "← Back") + "</button>" +
                "<button class=\"b2f-btn b2f-btn-primary\" style=\"flex:2;padding:12px;font-size:14px;\" onclick=\"b2fSubmitDeliver()\">" + L("🚛 ยืนยันส่งของ", "🚛 Confirm Shipment") + "</button>" +
            "</div>" +
        "</div>";
}

window.b2fFillAllRemaining = function() {
    document.querySelectorAll(".b2f-dlv-qty").forEach(function(inp) {
        inp.value = inp.max;
    });
    showToast(L("เติมจำนวนครบทุกรายการแล้ว", "All quantities filled"));
};

window.b2fSubmitDeliver = async function() {
    if (LOCKED) return;
    var po = _deliverPoData;
    if (!po) return;

    // Collect delivery items
    var deliveryItems = [];
    document.querySelectorAll(".b2f-dlv-qty").forEach(function(inp) {
        var qty = parseInt(inp.value) || 0;
        if (qty > 0) {
            deliveryItems.push({ sku: inp.dataset.sku, qty: qty });
        }
    });

    if (deliveryItems.length === 0) {
        showToast(L("กรุณากรอกจำนวนอย่างน้อย 1 รายการ", "Please enter at least 1 item"), "error");
        return;
    }

    // Validate max
    var invalid = false;
    document.querySelectorAll(".b2f-dlv-qty").forEach(function(inp) {
        var qty = parseInt(inp.value) || 0;
        var max = parseInt(inp.max) || 0;
        if (qty > max) {
            inp.style.borderColor = "#dc2626";
            invalid = true;
        } else {
            inp.style.borderColor = "#d1d5db";
        }
    });
    if (invalid) {
        showToast(L("จำนวนเกินที่คงเหลือ", "Quantity exceeds remaining"), "error");
        return;
    }

    LOCKED = true;
    showToast(L("กำลังดำเนินการ...", "Processing..."));
    try {
        var note = (document.getElementById("b2f-dlv-note") || {}).value || "";
        var res = await apiCall("POST", "maker-deliver", {
            token: TOKEN,
            po_id: po.id || po.ID,
            delivery_items: deliveryItems,
            note: note
        });
        var msg = res.is_complete ? L("✅ แจ้งส่งของครบเรียบร้อย", "✅ Shipment completed") : L("📦 แจ้งส่งของบางส่วนเรียบร้อย", "📦 Partial shipment recorded");
        showToast(msg, "success");
        setTimeout(function() { loadDeliverPage(); }, 1500);
    } catch (err) {
        showToast("❌ " + err.message, "error");
    }
    LOCKED = false;
};

// V.3.12: Stepper [-][+] for number inputs
window.b2fStepQty = function(btn, delta) {
    var row = btn.parentElement;
    var inp = row.querySelector("input[type=number]");
    if (!inp) return;
    var val = parseInt(inp.value) || 0;
    var min = parseInt(inp.min) || 0;
    var max = parseInt(inp.max) || 9999;
    inp.value = Math.max(min, Math.min(max, val + delta));
};

