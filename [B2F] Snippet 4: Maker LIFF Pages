// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'b2f_generate_maker_liff_url' ) ) {

    function b2f_generate_maker_liff_url( $po_id, $maker_id, $action = 'confirm', $ttl = 259200 ) {
        if ( ! class_exists( 'DINOCO_JWT' ) ) {
            error_log( '[B2F] DINOCO_JWT class not found' );
            return false;
        }

        $payload = array(
            'po_id'    => intval( $po_id ),
            'maker_id' => intval( $maker_id ),
            'action'   => sanitize_text_field( $action ),
            'iat'      => time(),
            'exp'      => time() + intval( $ttl ),
        );

        $token = DINOCO_JWT::sign( $payload );
        if ( ! $token ) return false;

        $base_url = home_url( '/b2f-maker/' );
        return add_query_arg( array(
            'page'  => $action,
            'token' => $token,
            '_ts'   => time(),
        ), $base_url );
    }
}

if ( ! function_exists( 'b2f_verify_maker_token' ) ) {

    function b2f_verify_maker_token( $token ) {
        if ( ! class_exists( 'DINOCO_JWT' ) ) {
            return new WP_Error( 'jwt_missing', 'DINOCO_JWT class not available', array( 'status' => 500 ) );
        }

        if ( empty( $token ) ) {
            return new WP_Error( 'token_empty', 'ไม่พบ token', array( 'status' => 401 ) );
        }

        $payload = DINOCO_JWT::verify( $token );
        if ( ! $payload || is_wp_error( $payload ) ) {
            return new WP_Error( 'token_invalid', 'token ไม่ถูกต้องหรือหมดอายุ', array( 'status' => 401 ) );
        }

        if ( isset( $payload['exp'] ) && $payload['exp'] < time() ) {
            return new WP_Error( 'token_expired', 'ลิงก์หมดอายุแล้ว กรุณาขอลิงก์ใหม่จาก LINE', array( 'status' => 401 ) );
        }

        if ( empty( $payload['po_id'] ) || empty( $payload['maker_id'] ) ) {
            return new WP_Error( 'token_incomplete', 'token ไม่สมบูรณ์', array( 'status' => 400 ) );
        }

        $po_id    = intval( $payload['po_id'] );
        $maker_id = intval( $payload['maker_id'] );

        $po_maker = get_field( 'po_maker_id', $po_id );
        $po_maker_id = is_object( $po_maker ) ? $po_maker->ID : intval( $po_maker );

        if ( $po_maker_id !== $maker_id ) {
            return new WP_Error( 'token_mismatch', 'ไม่มีสิทธิ์เข้าถึง PO นี้', array( 'status' => 403 ) );
        }

        return $payload;
    }
}

