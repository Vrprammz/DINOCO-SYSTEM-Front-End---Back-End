if ( ! function_exists( 'b2f_api_maker_po_list' ) ) {
    function b2f_api_maker_po_list( WP_REST_Request $request ) {
        $token   = sanitize_text_field( $request->get_param( 'token' ) );
        $payload = b2f_verify_maker_token( $token );
        if ( is_wp_error( $payload ) ) return $payload;

        $maker_id = intval( $payload['maker_id'] );

        $args = array(
            'post_type'      => 'b2f_order',
            'posts_per_page' => 100,
            'post_status'    => 'publish',
            'meta_query'     => array(
                array(
                    'key'     => 'po_maker_id',
                    'value'   => $maker_id,
                    'compare' => '=',
                ),
            ),
            'orderby' => 'date',
            'order'   => 'DESC',
        );

        $query = new WP_Query( $args );
        $list  = array();

        if ( $query->have_posts() ) {
            while ( $query->have_posts() ) {
                $query->the_post();
                $pid = get_the_ID();
                $list[] = array(
                    'ID'               => $pid,
                    'po_number'        => get_field( 'po_number', $pid ) ?: ( 'PO-' . $pid ),
                    'po_status'        => get_field( 'po_status', $pid ) ?: 'draft',
                    'po_total_amount'  => floatval( get_field( 'po_total_amount', $pid ) ),
                    'po_item_count'    => intval( get_field( 'po_item_count', $pid ) ),
                    'po_expected_date' => get_field( 'po_expected_date', $pid ) ?: '',
                    'po_requested_date'=> get_field( 'po_requested_date', $pid ) ?: '',
                    'post_date'        => get_the_date( 'Y-m-d' ),
                );
            }
            wp_reset_postdata();
        }

        return rest_ensure_response( array( 'success' => true, 'data' => $list ) );
    }
}

