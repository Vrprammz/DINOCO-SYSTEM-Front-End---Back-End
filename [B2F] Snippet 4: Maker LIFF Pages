                    var shp = Number(it.poi_qty_shipped || it.qty_shipped || 0);
                    var left = Math.max(0, ord - shp);
                    var name = escHtml(it.poi_product_name || it.product_name || it.poi_sku || it.sku || "");
                    var sku = escHtml(it.poi_sku || it.sku || "");
                    var leftColor = left > 0 ? "color:#dc2626;font-weight:700;" : "color:#16a34a;";
                    remainInfo += "<div style=\"display:flex;gap:4px;padding:4px 0;border-bottom:1px solid #f1f5f9;align-items:center;\">" +
