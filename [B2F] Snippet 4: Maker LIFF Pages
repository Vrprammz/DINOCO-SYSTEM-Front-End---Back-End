            ? "<div class=\"b2f-liff-actions\">" +
                "<button class=\"b2f-btn b2f-btn-outline\" id=\"b2f-reject-btn\">&#10060; " + L("\u0e1b\u0e0f\u0e34\u0e40\u0e2a\u0e18", "Reject") + "</button>" +
                "<button class=\"b2f-btn b2f-btn-accent\" id=\"b2f-confirm-btn\">&#9989; " + L("\u0e22\u0e37\u0e19\u0e22\u0e31\u0e19\u0e27\u0e31\u0e19\u0e2a\u0e48\u0e07", "Confirm ETA") + "</button>" +
              "</div>"
            : "");

    if (canConfirm) {
        $("#b2f-confirm-btn").addEventListener("click", handleConfirm);
        $("#b2f-reject-btn").addEventListener("click", function() {
            var box = $("#b2f-reject-box");
            box.classList.toggle("show");
            if (box.classList.contains("show")) {
                box.scrollIntoView({ behavior: "smooth", block: "center" });
            }
        });
        $("#b2f-confirm-reject").addEventListener("click", handleReject);
    }
}

async function handleConfirm() {
    var btn = $("#b2f-confirm-btn");
    var eta = $("#b2f-eta").value;
    var note = ($("#b2f-note") && $("#b2f-note").value) || "";

    if (!eta) { showToast(L("\u0e01\u0e23\u0e38\u0e13\u0e32\u0e40\u0e25\u0e37\u0e2d\u0e01\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48\u0e04\u0e32\u0e14\u0e27\u0e48\u0e32\u0e08\u0e30\u0e2a\u0e48\u0e07", "Please select delivery date"), "error"); return; }
    if (eta <= new Date().toISOString().split("T")[0]) { showToast(L("\u0e27\u0e31\u0e19\u0e2a\u0e48\u0e07\u0e15\u0e49\u0e2d\u0e07\u0e40\u0e1b\u0e47\u0e19\u0e27\u0e31\u0e19\u0e43\u0e19\u0e2d\u0e19\u0e32\u0e04\u0e15", "Date must be in the future"), "error"); return; }
    if (!lockBtn(btn)) return;

    try {
        await apiCall("POST", "maker-confirm", {
            token: TOKEN, expected_date: eta, maker_note: note, line_uid: LINE_UID
        });
        showToast(L("\u0e22\u0e37\u0e19\u0e22\u0e31\u0e19\u0e27\u0e31\u0e19\u0e2a\u0e48\u0e07\u0e40\u0e23\u0e35\u0e22\u0e1a\u0e23\u0e49\u0e2d\u0e22", "Confirmed successfully"), "success");
        setTimeout(function() {
            var p = new URLSearchParams(window.location.search);
            p.set("view", "detail");
            p.delete("page");
            window.location.search = p.toString();
        }, 1500);
    } catch (err) { showToast(err.message, "error"); unlockBtn(btn); }
}

async function handleReject() {
    var btn = $("#b2f-confirm-reject");
    var reason = ($("#b2f-reject-reason") && $("#b2f-reject-reason").value.trim()) || "";

    if (!reason) { showToast(L("\u0e01\u0e23\u0e38\u0e13\u0e32\u0e23\u0e30\u0e1a\u0e38\u0e40\u0e2b\u0e15\u0e38\u0e1c\u0e25\u0e17\u0e35\u0e48\u0e1b\u0e0f\u0e34\u0e40\u0e2a\u0e18", "Please specify rejection reason"), "error"); return; }
    if (!lockBtn(btn)) return;

    try {
        await apiCall("POST", "maker-reject", {
            token: TOKEN, reject_reason: reason, line_uid: LINE_UID
        });
        showToast(L("\u0e1b\u0e0f\u0e34\u0e40\u0e2a\u0e18 PO \u0e40\u0e23\u0e35\u0e22\u0e1a\u0e23\u0e49\u0e2d\u0e22", "PO rejected successfully"), "success");
        setTimeout(function() {
            var p = new URLSearchParams(window.location.search);
            p.set("view", "detail");
            p.delete("page");
            window.location.search = p.toString();
        }, 1500);
    } catch (err) { showToast(err.message, "error"); unlockBtn(btn); }
}

