        }

        $reschedule_data = array(
            'po_id'        => $po_id,
            'maker_id'     => $maker_id,
            'old_date'     => get_field( 'po_expected_date', $po_id ),
            'new_date'     => $new_date,
            'reason'       => $reason,
            'requested_at' => current_time( 'mysql' ),
            'status'       => 'pending',
        );

        $history = get_post_meta( $po_id, '_b2f_reschedule_requests', true );
        if ( ! is_array( $history ) ) $history = array();
        $history[] = $reschedule_data;
        update_post_meta( $po_id, '_b2f_reschedule_requests', $history );

        if ( function_exists( 'b2f_notify_admin_reschedule_request' ) ) {
            b2f_notify_admin_reschedule_request( $po_id, $new_date, $reason );
        }

        return rest_ensure_response( array( 'success' => true, 'message' => 'ส่งคำขอเลื่อนเรียบร้อย รอ Admin อนุมัติ' ) );
    }
