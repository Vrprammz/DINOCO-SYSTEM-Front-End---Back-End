async function handleReschedule() {
    var btn = $("#b2f-reschedule-btn");
    var newDate = $("#b2f-new-date").value;
    var reason = ($("#b2f-reschedule-reason") && $("#b2f-reschedule-reason").value.trim()) || "";

    if (!newDate) { showToast("\u0e01\u0e23\u0e38\u0e13\u0e32\u0e40\u0e25\u0e37\u0e2d\u0e01\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48\u0e2a\u0e48\u0e07\u0e43\u0e2b\u0e21\u0e48", "error"); return; }
    if (newDate <= new Date().toISOString().split("T")[0]) { showToast("\u0e27\u0e31\u0e19\u0e2a\u0e48\u0e07\u0e15\u0e49\u0e2d\u0e07\u0e40\u0e1b\u0e47\u0e19\u0e27\u0e31\u0e19\u0e43\u0e19\u0e2d\u0e19\u0e32\u0e04\u0e15", "error"); return; }
    if (!reason) { showToast("\u0e01\u0e23\u0e38\u0e13\u0e32\u0e23\u0e30\u0e1a\u0e38\u0e40\u0e2b\u0e15\u0e38\u0e1c\u0e25\u0e17\u0e35\u0e48\u0e15\u0e49\u0e2d\u0e07\u0e40\u0e25\u0e37\u0e48\u0e2d\u0e19", "error"); return; }
    if (!lockBtn(btn)) return;

    try {
        var poId = (PO_DATA && (PO_DATA.id || PO_DATA.ID)) || new URLSearchParams(window.location.search).get("po_id") || "";
        await apiCall("POST", "maker-reschedule", {
            token: TOKEN, po_id: poId, new_date: newDate, reason: reason, line_uid: LINE_UID
        });
        showToast("\u0e2a\u0e48\u0e07\u0e04\u0e33\u0e02\u0e2d\u0e40\u0e25\u0e37\u0e48\u0e2d\u0e19\u0e40\u0e23\u0e35\u0e22\u0e1a\u0e23\u0e49\u0e2d\u0e22 \u0e23\u0e2d Admin \u0e2d\u0e19\u0e38\u0e21\u0e31\u0e15\u0e34", "success");
        setTimeout(function() { goToPage("detail"); }, 1500);
    } catch (err) { showToast(err.message, "error"); unlockBtn(btn); }
}

