async function loadConfirmPage() {
    showLoading();
    try {
        // V.3.5: ส่ง po_id จาก URL params เป็น fallback
        var poId = new URLSearchParams(window.location.search).get("po_id");
        var params = { token: TOKEN };
        if (poId) params.po_id = poId;
        var res = await apiCall("GET", "po-detail/jwt", params);
        PO_DATA = res.data || res;
        if (PO_DATA.currency) _isEng = PO_DATA.currency !== "THB";

        if (PO_DATA.po_status === "cancelled") {
            showError(L("ใบสั่งซื้อถูกยกเลิก", "PO Cancelled"), L("ใบสั่งซื้อนี้ถูกยกเลิกแล้ว ไม่สามารถดำเนินการได้", "This PO has been cancelled."));
            return;
        }
        // W-07 fix: guard สำหรับ PO ที่ confirm/reject ไปแล้ว
        if (["confirmed","delivering","received","partial_received","paid","completed"].indexOf(PO_DATA.po_status) !== -1) {
            showError(L("✅ ยืนยันไปแล้ว", "✅ Already confirmed"), L("PO นี้ได้รับการยืนยันเรียบร้อยแล้ว\nสถานะ: ", "This PO has already been confirmed.\nStatus: ") + statusLabel(PO_DATA.po_status));
            return;
        }
        if (PO_DATA.po_status === "rejected") {
            showError(L("❌ ปฏิเสธไปแล้ว", "❌ Already rejected"), L("PO นี้ถูกปฏิเสธไปแล้ว รอ Admin ส่งใหม่", "This PO has been rejected. Waiting for Admin to resubmit."));
            return;
        }

        renderConfirmPage(PO_DATA);
    } catch (err) {
        showError(L("\u0e44\u0e21\u0e48\u0e2a\u0e32\u0e21\u0e32\u0e23\u0e16\u0e42\u0e2b\u0e25\u0e14\u0e02\u0e49\u0e2d\u0e21\u0e39\u0e25\u0e44\u0e14\u0e49", "Failed to load"), err.message);
    }
}

