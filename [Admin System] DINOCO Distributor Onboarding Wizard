        <script>
        (function() {
            const NONCE = <?php echo wp_json_encode( $nonce ); ?>;
            const REST  = '<?php echo esc_js( rest_url( 'dinoco/v1/onboard' ) ); ?>';

            // State
            const state = {
                step: 1,
                groupChecked: false,
                groupAvailable: false,
                inFlight: false,
                form: {},
            };

            // Per-tier discount hints (informational only)
            const TIER_DISCOUNT_DEFAULTS = {
                standard: '0% (ราคา retail)',
                silver:   '5% off retail',
                gold:     '10% off retail',
                platinum: '15% off retail',
                diamond:  '20% off retail',
            };

            function esc(s) {
                return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
            }
            function fmtBaht(n) { if (n == null || n === '') return '-'; return '฿' + Number(n).toLocaleString('en-US', {minimumFractionDigits:2,maximumFractionDigits:2}); }

            async function apiPost(path, body) {
                const r = await fetch(REST + path, {
                    method: 'POST',
                    headers: { 'X-WP-Nonce': NONCE, 'Content-Type': 'application/json' },
                    body: JSON.stringify(body || {}),
                });
                return r.json();
            }

            function safeAlert(opts) {
                try {
                    if (window.dinocoModal && typeof window.dinocoModal.alert === 'function') {
                        return window.dinocoModal.alert(opts);
                    }
                } catch (e) { /* fall through */ }
                window.alert(opts.message || '');
                return Promise.resolve();
            }
            function safeConfirm(opts) {
                try {
                    if (window.dinocoModal && typeof window.dinocoModal.confirm === 'function') {
                        return window.dinocoModal.confirm(opts);
                    }
                } catch (e) { /* fall through */ }
                return Promise.resolve(window.confirm(opts.message || 'ยืนยัน?'));
            }

            // Update tier hint when select changes
            document.getElementById('dncOnbTier').addEventListener('change', function(e) {
                const t = e.target.value;
                const h = TIER_DISCOUNT_DEFAULTS[t] || '';
                document.getElementById('dncOnbTierHint').textContent = 'ส่วนลด default: ' + h + ' — ปรับเองทีหลังได้';
            });

            // Step navigation
            function showPane(n) {
                document.querySelectorAll('.dnc-onboard-step-pane').forEach(p => p.style.display = 'none');
                const tgt = document.querySelector('.dnc-onboard-step-pane[data-pane="' + n + '"]');
                if (tgt) tgt.style.display = 'block';
                document.querySelectorAll('.dnc-onboard-step').forEach(s => {
                    const num = parseInt(s.dataset.step, 10);
                    s.classList.remove('active', 'done');
                    if (num < n) s.classList.add('done');
                    else if (num === n) s.classList.add('active');
                });
                state.step = n;
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            // Validation per step
            function validateStep1() {
                const shop = document.getElementById('dncOnbShopName').value.trim();
                if (shop === '') {
                    safeAlert({ title: 'ข้อมูลไม่ครบ', message: 'กรุณากรอกชื่อร้าน', type: 'warning' });
                    document.getElementById('dncOnbShopName').focus();
                    return false;
                }
                if (shop.length > 200) {
                    safeAlert({ title: 'ชื่อยาวเกิน', message: 'ชื่อร้านยาวเกิน 200 ตัวอักษร', type: 'warning' });
                    return false;
                }
                state.form.shop_name = shop;
                state.form.rank_system = document.getElementById('dncOnbTier').value;
                state.form.credit_limit = parseFloat(document.getElementById('dncOnbCreditLimit').value) || 0;
                state.form.credit_term_days = parseInt(document.getElementById('dncOnbCreditTerm').value, 10) || 30;
                const dc = document.getElementById('dncOnbDiscountPct').value;
                state.form.b2b_discount_percent = (dc === '' ? null : parseFloat(dc));
                state.form.is_walkin = document.getElementById('dncOnbWalkin').checked;
                return true;
            }

            async function validateStep2() {
                const gid = document.getElementById('dncOnbGroupId').value.trim();
                const checkEl = document.getElementById('dncOnbGroupCheck');
                if (!/^[A-Za-z0-9]{20,}$/.test(gid)) {
                    checkEl.innerHTML = '<div class="err">รูปแบบไม่ถูกต้อง — ต้องเป็นตัวอักษร/ตัวเลข ≥20 ตัว</div>';
                    return false;
                }
                checkEl.innerHTML = '<div class="hint">กำลังตรวจสอบ...</div>';

                try {
                    const r = await apiPost('/check-group-id', { group_id: gid });
                    if (!r.success) {
                        checkEl.innerHTML = '<div class="err">❌ ' + esc(r.message || r.code || 'ตรวจสอบไม่สำเร็จ') + '</div>';
                        return false;
                    }
                    if (!r.available) {
                        const conflict = r.conflict_dist || {};
                        checkEl.innerHTML = '<div class="err">❌ group_id นี้ถูกใช้แล้วโดย <strong>' + esc(conflict.title || 'ตัวแทนอื่น') + '</strong> (id #' + (conflict.id || '?') + ') — ใช้ group_id อื่น</div>';
                        state.groupAvailable = false;
                        return false;
                    }
                    checkEl.innerHTML = '<div class="ok">✓ group_id นี้ยังว่าง — พร้อมใช้งาน</div>';
                    state.form.line_group_id = gid;
                    state.groupChecked = true;
                    state.groupAvailable = true;
                    return true;
                } catch (e) {
                    checkEl.innerHTML = '<div class="err">Network error: ' + esc(e.message || 'unknown') + '</div>';
                    return false;
                }
            }

            function validateStep3() {
                state.form.bot_enabled = document.getElementById('dncOnbBotEnabled').checked;
                return true;
            }

            // Public navigation
            window.dncOnboardNext = async function(fromStep) {
                if (state.inFlight) return;
                if (fromStep === 1) {
                    if (!validateStep1()) return;
                    showPane(2);
                } else if (fromStep === 2) {
                    state.inFlight = true;
                    const btn = document.getElementById('dncOnbStep2Next');
                    if (btn) { btn.disabled = true; btn.textContent = 'กำลังตรวจสอบ...'; }
                    const ok = await validateStep2();
                    if (btn) { btn.disabled = false; btn.textContent = 'ตรวจสอบ + ถัดไป →'; }
                    state.inFlight = false;
                    if (ok) showPane(3);
                } else if (fromStep === 3) {
                    if (!validateStep3()) return;
                    showPane(4);
                } else if (fromStep === 4) {
                    renderReview();
                    showPane(5);
                }
            };

            window.dncOnboardBack = function(fromStep) {
                if (state.inFlight) return;
                if (fromStep > 1) showPane(fromStep - 1);
            };

            // Test bot
            window.dncOnboardTestBot = async function() {
                if (state.inFlight) return;
                if (!state.form.line_group_id) {
                    safeAlert({ title: 'ไม่มี group_id', message: 'ยังไม่ได้ตรวจ group_id ในขั้นที่ 2', type: 'warning' });
                    return;
                }
                const btn = document.getElementById('dncOnbTestBtn');
                const resultEl = document.getElementById('dncOnbTestResult');
                state.inFlight = true;
                btn.disabled = true; btn.textContent = '⏳ กำลังส่ง...';
                resultEl.innerHTML = '';
                try {
                    const r = await apiPost('/test-bot', {
                        group_id: state.form.line_group_id,
                        shop_name: state.form.shop_name || '',
                    });
                    if (r.success && r.sent) {
                        resultEl.innerHTML = '<span style="color:#16a34a;">✅ ' + esc(r.message || 'ส่งสำเร็จ — เช็คใน LINE') + '</span>';
                    } else {
                        resultEl.innerHTML = '<span style="color:#dc2626;">❌ ' + esc(r.message || r.code || 'ส่งไม่สำเร็จ') + '</span>';
                    }
                } catch (e) {
                    resultEl.innerHTML = '<span style="color:#dc2626;">❌ Network error: ' + esc(e.message || 'unknown') + '</span>';
                } finally {
                    btn.disabled = false; btn.textContent = '📨 ส่ง Test Message';
                    state.inFlight = false;
                }
            };

            // Review
            function renderReview() {
                const f = state.form;
                const tier = (f.rank_system || 'standard').toLowerCase();
                const tierBadge = '<span class="dnc-onboard-tier-preview ' + esc(tier) + '">' + esc(tier.toUpperCase()) + '</span>';
                const html = ''
                    + '<div class="dnc-onboard-review-row"><span class="lbl">ชื่อร้าน</span><span class="val">' + esc(f.shop_name) + '</span></div>'
                    + '<div class="dnc-onboard-review-row"><span class="lbl">Tier</span><span class="val">' + tierBadge + '</span></div>'
                    + '<div class="dnc-onboard-review-row"><span class="lbl">วงเงินเครดิต</span><span class="val">' + fmtBaht(f.credit_limit || 0) + '</span></div>'
                    + '<div class="dnc-onboard-review-row"><span class="lbl">เครดิตเทอม</span><span class="val">' + (f.credit_term_days || 30) + ' วัน</span></div>'
                    + (f.b2b_discount_percent != null ? '<div class="dnc-onboard-review-row"><span class="lbl">ส่วนลด default</span><span class="val">' + Number(f.b2b_discount_percent).toFixed(2) + '%</span></div>' : '')
                    + '<div class="dnc-onboard-review-row"><span class="lbl">Walk-in</span><span class="val">' + (f.is_walkin ? '✓ เปิด' : '— ปิด') + '</span></div>'
                    + '<div class="dnc-onboard-review-row"><span class="lbl">LINE Group ID</span><span class="val" style="font-family:ui-monospace,monospace;font-size:11px;">' + esc(f.line_group_id || '-') + '</span></div>'
                    + '<div class="dnc-onboard-review-row"><span class="lbl">Bot</span><span class="val">' + (f.bot_enabled ? '✓ เปิด' : '— ปิด') + '</span></div>';
                document.getElementById('dncOnbReview').innerHTML = html;
            }

            // Final save
            window.dncOnboardSave = async function() {
                if (state.inFlight) return;

                const ok = await safeConfirm({
                    title: '✅ ยืนยันสร้างตัวแทนใหม่',
                    message: 'สร้างตัวแทน "' + state.form.shop_name + '" + เชื่อม LINE Group?\n\nหลังบันทึกแล้วสามารถแก้ไขรายละเอียดเพิ่มเติมได้ใน B2B Admin Control Panel',
                    confirmText: 'บันทึกเลย',
                    cancelText: 'ยกเลิก',
                });
                if (!ok) return;

                const btn = document.getElementById('dncOnbSaveBtn');
                const resultEl = document.getElementById('dncOnbSaveResult');
                state.inFlight = true;
                btn.disabled = true; btn.textContent = 'กำลังบันทึก...';
                resultEl.innerHTML = '<div class="dnc-onboard-banner info">กำลังบันทึก...</div>';

                try {
                    const r = await apiPost('/save', state.form);
                    if (r.success) {
                        resultEl.innerHTML = '<div class="dnc-onboard-banner ok">'
                            + '<strong>✅ ' + esc(r.message || 'สร้างสำเร็จ') + '</strong><br>'
                            + 'distributor #' + (r.dist_id || '?') + ' — '
                            + (r.edit_url ? '<a href="' + esc(r.edit_url) + '" target="_blank">เปิดหน้าแก้ไข</a>' : '')
                            + '</div>';
                        btn.textContent = '✓ บันทึกแล้ว';
                        // Optional: redirect / reset form after delay
                        setTimeout(function() {
                            if (window.confirm('สร้างตัวแทนเพิ่มอีกคนมั้ย?')) {
                                window.location.reload();
                            }
                        }, 2000);
                    } else {
                        resultEl.innerHTML = '<div class="dnc-onboard-banner bad">❌ ' + esc(r.message || r.code || 'บันทึกไม่สำเร็จ') + '</div>';
                        btn.disabled = false; btn.textContent = '💾 บันทึกตัวแทนใหม่';
                    }
                } catch (e) {
                    resultEl.innerHTML = '<div class="dnc-onboard-banner bad">❌ Network error: ' + esc(e.message || 'unknown') + '</div>';
                    btn.disabled = false; btn.textContent = '💾 บันทึกตัวแทนใหม่';
                } finally {
                    state.inFlight = false;
                }
            };

            // Initialize
            showPane(1);
        })();
        </script>
        <?php
        return ob_get_clean();
    }
