if ( ! defined( 'ABSPATH' ) ) exit;

/* ============================================================
 * 1. SHORTCODE + MODULE REGISTRY
 * ============================================================ */

add_shortcode( 'dinoco_admin_onboard_distributor', 'dinoco_onboard_distributor_render' );

add_action( 'init', function() {
    if ( ! function_exists( 'dinoco_register_admin_module' ) ) return;
    dinoco_register_admin_module( array(
        'key'        => 'onboard_distributor',
        'shortcode'  => 'dinoco_admin_onboard_distributor',
        'label'      => 'เพิ่มตัวแทนใหม่',
        'section'    => 'b2b',
        'icon'       => 'fa-user-plus',
        'color'      => '#10b981',
        'cache_ttl'  => 60,
        'capability' => 'manage_options',
        'order'      => 10,
        'source'     => '[Admin System] DINOCO Distributor Onboarding Wizard V.1.0',
    ) );
}, 30 );

/* ============================================================
 * 2. REST API ENDPOINTS
 * ============================================================ */

add_action( 'rest_api_init', function() {
    $perm_admin_post = function( WP_REST_Request $req ) {
        return current_user_can( 'manage_options' )
            && wp_verify_nonce( $req->get_header( 'X-WP-Nonce' ), 'wp_rest' );
    };

    register_rest_route( 'dinoco/v1', '/onboard/check-group-id', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_onboard_rest_check_group_id',
        'permission_callback' => $perm_admin_post,
    ) );

    register_rest_route( 'dinoco/v1', '/onboard/test-bot', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_onboard_rest_test_bot',
        'permission_callback' => $perm_admin_post,
    ) );

    register_rest_route( 'dinoco/v1', '/onboard/save', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_onboard_rest_save',
        'permission_callback' => $perm_admin_post,
    ) );
} );

// ────────────────────────────────────────────────────────────────
// POST /onboard/check-group-id — uniqueness check
// Body: { group_id }
// Returns: { ok, available, conflict_dist?:{id,title,line_group_id} }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_onboard_rest_check_group_id' ) ) {
    function dinoco_onboard_rest_check_group_id( WP_REST_Request $req ) {
        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) $body = array();

        $group_id = sanitize_text_field( (string) ( isset( $body['group_id'] ) ? $body['group_id'] : $req->get_param( 'group_id' ) ) );
        $exclude_id = (int) ( isset( $body['exclude_id'] ) ? $body['exclude_id'] : $req->get_param( 'exclude_id' ) );

        if ( $group_id === '' ) {
            return new WP_Error( 'bad_group_id', 'group_id ว่าง', array( 'status' => 400 ) );
        }
        // LINE group_id is typically 33 chars starting with 'C' or 'R'. Allow letters/digits.
        if ( ! preg_match( '/^[A-Za-z0-9]{20,}$/', $group_id ) ) {
            return new WP_Error( 'invalid_format',
                'รูปแบบไม่ถูกต้อง (group_id ต้องเป็นตัวอักษร/ตัวเลข ≥20 ตัว เช่น Cxxxxxxxxx...)',
                array( 'status' => 400 ) );
        }

        // Search distributor CPT by line_group_id meta
        $existing = get_posts( array(
            'post_type'      => 'distributor',
            'post_status'    => array( 'publish', 'draft', 'pending', 'private' ),
            'posts_per_page' => 5,
            'fields'         => 'ids',
            'meta_query'     => array(
                array(
                    'key'     => 'line_group_id',
                    'value'   => $group_id,
                    'compare' => '=',
                ),
            ),
        ) );

        if ( $exclude_id > 0 && ! empty( $existing ) ) {
            $existing = array_values( array_diff( $existing, array( $exclude_id ) ) );
        }

        if ( empty( $existing ) ) {
            return rest_ensure_response( array(
                'success'   => true,
                'available' => true,
                'group_id'  => $group_id,
            ) );
        }

        $conflict_id = (int) $existing[0];
        return rest_ensure_response( array(
            'success'   => true,
            'available' => false,
            'group_id'  => $group_id,
            'conflict_dist' => array(
                'id'           => $conflict_id,
                'title'        => get_the_title( $conflict_id ),
                'line_group_id' => $group_id,
            ),
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// POST /onboard/test-bot — send welcome Flex to group
// Body: { group_id, shop_name? }
// Returns: { ok, sent:bool, message }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_onboard_rest_test_bot' ) ) {
    function dinoco_onboard_rest_test_bot( WP_REST_Request $req ) {
        $uid = get_current_user_id();
        // Rate limit 5/min/user (network call)
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'onboard_test_bot_u' . $uid, 5, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 5/min)', array( 'status' => 429 ) );
            }
        }

        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) $body = array();

        $group_id  = sanitize_text_field( (string) ( isset( $body['group_id'] ) ? $body['group_id'] : '' ) );
        $shop_name = sanitize_text_field( (string) ( isset( $body['shop_name'] ) ? $body['shop_name'] : '' ) );

        if ( $group_id === '' ) {
            return new WP_Error( 'bad_group_id', 'group_id ว่าง', array( 'status' => 400 ) );
        }

        if ( ! function_exists( 'b2b_line_push' ) ) {
            return new WP_Error( 'no_line_helper', 'b2b_line_push ไม่พร้อม', array( 'status' => 501 ) );
        }

        $shop_label = $shop_name !== '' ? $shop_name : '(ร้านใหม่)';
        $msg = "🎉 ยินดีต้อนรับเข้าสู่ระบบ DINOCO B2B\n\n"
             . "ร้าน: " . $shop_label . "\n"
             . "สถานะ: เชื่อมต่อสำเร็จ ✓\n\n"
             . "ทีมงานจะส่งคู่มือใช้งาน + ราคาสินค้าให้ในกลุ่มนี้เร็วๆนี้ครับ\n"
             . "พิมพ์ \"ขอราคา\" เพื่อดูสินค้า — ขอบคุณที่ร่วมเป็นตัวแทนนะครับ 🙏";

        $sent = false;
        $err_msg = '';
        try {
            $resp = b2b_line_push( $group_id, $msg );
            $sent = ! empty( $resp ) || $resp === true;
        } catch ( \Throwable $e ) {
            $err_msg = $e->getMessage();
        }

        // Audit (best-effort)
        if ( function_exists( 'dinoco_audit_log' ) ) {
            try {
                dinoco_audit_log( array(
                    'event_type'  => 'onboard_test_bot',
                    'actor_type'  => 'admin',
                    'actor_id'    => (string) $uid,
                    'target_type' => 'line_group',
                    'target_id'   => $group_id,
                    'context'     => array(
                        'shop_name' => $shop_name,
                        'sent'      => $sent,
                        'error'     => $err_msg,
                    ),
                    'success'     => $sent ? 1 : 0,
                ) );
            } catch ( \Throwable $e ) { /* silent */ }
        }

        if ( ! $sent ) {
            return rest_ensure_response( array(
                'success' => true,
                'sent'    => false,
                'message' => 'ส่งไม่สำเร็จ — ' . ( $err_msg !== '' ? $err_msg : 'อาจเป็นเพราะบอทยังไม่ได้ join group หรือ group_id ผิด' ),
            ) );
        }

        return rest_ensure_response( array(
            'success' => true,
            'sent'    => true,
            'message' => 'ส่ง welcome message ไปยังกลุ่มเรียบร้อย — เช็คใน LINE',
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// POST /onboard/save — final save (create distributor CPT + meta)
// Body: { shop_name, line_group_id, rank_system, credit_limit,
//         credit_term_days, is_walkin, bot_enabled, dist_phone?,
//         dist_address?, dist_district?, dist_province?, dist_postcode?,
//         dist_city?, b2b_discount_percent? }
// Returns: { ok, dist_id, edit_url, distributor:{...} }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_onboard_rest_save' ) ) {
    function dinoco_onboard_rest_save( WP_REST_Request $req ) {
        $uid = get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'onboard_save_u' . $uid, 10, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 10/min)', array( 'status' => 429 ) );
            }
        }

        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) $body = array();

        // Pull + sanitize
        $shop_name        = sanitize_text_field( (string) ( $body['shop_name'] ?? '' ) );
        $line_group_id    = sanitize_text_field( (string) ( $body['line_group_id'] ?? '' ) );
        $rank_system      = sanitize_text_field( (string) ( $body['rank_system'] ?? 'standard' ) );
        $credit_limit     = floatval( $body['credit_limit'] ?? 0 );
        $credit_term_days = intval( $body['credit_term_days'] ?? 30 );
        $is_walkin        = ! empty( $body['is_walkin'] );
        $bot_enabled      = isset( $body['bot_enabled'] ) ? (bool) $body['bot_enabled'] : true;
        $dist_phone       = sanitize_text_field( (string) ( $body['dist_phone'] ?? '' ) );
        $dist_address     = sanitize_text_field( (string) ( $body['dist_address'] ?? '' ) );
        $dist_district    = sanitize_text_field( (string) ( $body['dist_district'] ?? '' ) );
        $dist_province    = sanitize_text_field( (string) ( $body['dist_province'] ?? '' ) );
        $dist_postcode    = sanitize_text_field( (string) ( $body['dist_postcode'] ?? '' ) );
        $dist_city        = sanitize_text_field( (string) ( $body['dist_city'] ?? '' ) );
        $b2b_discount_pct = $body['b2b_discount_percent'] ?? null;

        // ─── Validation
        $allowed_ranks = array( 'standard', 'silver', 'gold', 'platinum', 'diamond' );
        if ( ! in_array( $rank_system, $allowed_ranks, true ) ) {
            $rank_system = 'standard';
        }
        if ( $shop_name === '' ) {
            return new WP_Error( 'bad_shop', 'กรุณาระบุชื่อร้าน', array( 'status' => 400 ) );
        }
        if ( mb_strlen( $shop_name ) > 200 ) {
            return new WP_Error( 'shop_too_long', 'ชื่อร้านยาวเกิน 200 ตัวอักษร', array( 'status' => 400 ) );
        }
        if ( $line_group_id === '' ) {
            return new WP_Error( 'bad_group_id', 'กรุณาระบุ line_group_id', array( 'status' => 400 ) );
        }
        if ( ! preg_match( '/^[A-Za-z0-9]{20,}$/', $line_group_id ) ) {
            return new WP_Error( 'invalid_group_id_format',
                'รูปแบบ group_id ไม่ถูกต้อง',
                array( 'status' => 400 ) );
        }
        if ( $credit_limit < 0 || $credit_limit > 10000000 ) {
            return new WP_Error( 'bad_credit', 'credit_limit อยู่ในช่วง 0 ถึง 10,000,000', array( 'status' => 400 ) );
        }
        if ( $credit_term_days < 1 || $credit_term_days > 365 ) {
            return new WP_Error( 'bad_term', 'credit_term_days อยู่ในช่วง 1 ถึง 365', array( 'status' => 400 ) );
        }

        // Uniqueness re-check (defense-in-depth — frontend already checked)
        $dup = get_posts( array(
            'post_type'      => 'distributor',
            'post_status'    => array( 'publish', 'draft', 'pending', 'private' ),
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'meta_query'     => array(
                array( 'key' => 'line_group_id', 'value' => $line_group_id, 'compare' => '=' ),
            ),
        ) );
        if ( ! empty( $dup ) ) {
            return new WP_Error( 'group_id_taken',
                'group_id นี้ถูกใช้แล้วโดย distributor #' . (int) $dup[0],
                array( 'status' => 409 ) );
        }

        // ─── Wrap save in transaction wrapper if available
        $context = array(
            'audit_event_type' => 'onboard_distributor',
            'actor_type'       => 'admin',
            'target_type'      => 'distributor',
            'audit_context'    => array(
                'shop_name'    => $shop_name,
                'rank_system'  => $rank_system,
                'credit_limit' => $credit_limit,
                'is_walkin'    => $is_walkin,
                'bot_enabled'  => $bot_enabled,
            ),
        );

        $do_mutate = function() use (
            $shop_name, $line_group_id, $rank_system, $credit_limit, $credit_term_days,
            $is_walkin, $bot_enabled, $dist_phone, $dist_address, $dist_district,
            $dist_province, $dist_postcode, $dist_city, $b2b_discount_pct
        ) {
            $dist_id = wp_insert_post( array(
                'post_type'   => 'distributor',
                'post_title'  => $shop_name,
                'post_status' => 'publish',
            ) );
            if ( is_wp_error( $dist_id ) || ! $dist_id ) {
                return new WP_Error( 'insert_failed',
                    'สร้าง distributor CPT ไม่สำเร็จ',
                    array( 'status' => 500 ) );
            }

            // ACF + meta writes
            if ( function_exists( 'update_field' ) ) {
                update_field( 'shop_name', $shop_name, $dist_id );
                update_field( 'line_group_id', $line_group_id, $dist_id );
                update_field( 'rank_system', $rank_system, $dist_id );
                update_field( 'credit_limit', $credit_limit, $dist_id );
                update_field( 'credit_term_days', $credit_term_days, $dist_id );
                update_field( 'credit_hold', false, $dist_id );
                update_field( 'is_walkin', $is_walkin, $dist_id );
                update_field( 'current_debt', 0, $dist_id );
                update_field( 'monthly_sales_mtd', 0, $dist_id );

                if ( $dist_phone !== '' )    update_field( 'dist_phone', $dist_phone, $dist_id );
                if ( $dist_address !== '' )  update_field( 'dist_address', $dist_address, $dist_id );
                if ( $dist_district !== '' ) update_field( 'dist_district', $dist_district, $dist_id );
                if ( $dist_province !== '' ) update_field( 'dist_province', $dist_province, $dist_id );
                if ( $dist_postcode !== '' ) update_field( 'dist_postcode', $dist_postcode, $dist_id );
                if ( $dist_city !== '' )     update_field( 'dist_city', $dist_city, $dist_id );

                if ( $b2b_discount_pct !== null && $b2b_discount_pct !== '' ) {
                    $pct = max( 0, min( 100, floatval( $b2b_discount_pct ) ) );
                    update_field( 'b2b_discount_percent', $pct, $dist_id );
                }
            } else {
                // Fallback: raw post meta if ACF inactive (rare)
                update_post_meta( $dist_id, 'line_group_id', $line_group_id );
                update_post_meta( $dist_id, 'rank_system', $rank_system );
                update_post_meta( $dist_id, 'credit_limit', $credit_limit );
                update_post_meta( $dist_id, 'credit_term_days', $credit_term_days );
                update_post_meta( $dist_id, 'is_walkin', $is_walkin ? 1 : 0 );
                update_post_meta( $dist_id, 'current_debt', 0 );
            }

            // bot_enabled is plain post meta (Snippet 9 pattern)
            update_post_meta( $dist_id, 'bot_enabled', $bot_enabled ? 1 : 0 );
            update_post_meta( $dist_id, '_b2b_onboarded_via', 'wizard_v1' );
            update_post_meta( $dist_id, '_b2b_onboarded_at', current_time( 'mysql' ) );

            return array( 'dist_id' => (int) $dist_id );
        };

        $result = null;
        if ( function_exists( 'dinoco_transaction' ) ) {
            $result = dinoco_transaction( 'onboard_distributor', array(
                'mutate' => $do_mutate,
            ), $context );
        } else {
            $result = call_user_func( $do_mutate );
            // Manual audit fallback if transaction wrapper unavailable
            if ( ! is_wp_error( $result ) && function_exists( 'dinoco_audit_log' ) ) {
                try {
                    dinoco_audit_log( array(
                        'event_type'  => 'onboard_distributor',
                        'actor_type'  => 'admin',
                        'actor_id'    => (string) $uid,
                        'target_type' => 'distributor',
                        'target_id'   => (string) $result['dist_id'],
                        'context'     => $context['audit_context'],
                    ) );
                } catch ( \Throwable $e ) { /* silent */ }
            }
        }

        if ( is_wp_error( $result ) ) {
            return $result;
        }

        $dist_id = (int) ( is_array( $result ) && isset( $result['dist_id'] ) ? $result['dist_id'] : 0 );

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( '[OnboardWizard] Created distributor #' . $dist_id
                . ' shop="' . $shop_name . '" group=' . $line_group_id
                . ' tier=' . $rank_system . ' admin=' . $uid );
        }

        return rest_ensure_response( array(
            'success'  => true,
            'dist_id'  => $dist_id,
            'edit_url' => admin_url( 'post.php?post=' . $dist_id . '&action=edit' ),
            'distributor' => array(
                'id'             => $dist_id,
                'shop_name'      => $shop_name,
                'line_group_id'  => $line_group_id,
                'rank_system'    => $rank_system,
                'credit_limit'   => $credit_limit,
                'credit_term_days' => $credit_term_days,
                'is_walkin'      => $is_walkin,
                'bot_enabled'    => $bot_enabled,
            ),
            'message' => 'สร้างตัวแทน "' . $shop_name . '" สำเร็จ',
        ) );
    }
}

