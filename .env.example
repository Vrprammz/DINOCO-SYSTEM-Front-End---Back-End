# DINOCO System — WordPress constants reference
# These values are defined in wp-config.php (or via environment on managed hosts).
# This file is a documentation template, not loaded by WordPress.
# See: CLAUDE.md §"Required WordPress Constants"

# ─── LINE Login OAuth2 (Member-facing) ───
DINOCO_LINE_CHANNEL_ID=
DINOCO_LINE_CHANNEL_SECRET=
DINOCO_LINE_REDIRECT_URI=

# ─── LINE Bot (shared B2B/B2F channel) ───
B2B_LINE_ACCESS_TOKEN=
B2B_LINE_CHANNEL_SECRET=
B2B_ADMIN_GROUP_ID=
B2B_LIFF_ID=
B2F_LIFF_ID=

# ─── GitHub Webhook Sync ───
DINOCO_GITHUB_TOKEN=
DINOCO_GITHUB_REPO=Vrprammz/DINOCO-SYSTEM-Front-End---Back-End
DINOCO_GITHUB_WEBHOOK_SECRET=

# ─── LIFF AI (dealer CRM) ───
LIFF_AI_SECRET_KEY=
LIFF_AI_JWT_SECRET=
LIFF_AI_AGENT_URL=http://agent:3000
LIFF_AI_AGENT_KEY=

# ─── God Mode Margin (JWT) ───
DINOCO_JWT=

# ─── Flash Express ───
B2B_FLASH_SECRET_KEY=
B2B_FLASH_API_KEY=

# ─── Slip2Go (bank slip verify — PULL only, no webhook) ───
B2B_SLIP2GO_SECRET_KEY=

# ─── Walk-in bank (optional override; falls back to B2B_BANK_*) ───
B2B_WALKIN_BANK_NAME=
B2B_WALKIN_BANK_NAME_EN=
B2B_WALKIN_BANK_ACCOUNT=
B2B_WALKIN_BANK_HOLDER=
B2B_WALKIN_BANK_CODE=
B2B_WALKIN_BANK_LOGO_URL=
B2B_WALKIN_PROMPTPAY_ID=

# ─── Kill switches ───
# B2F_DISABLED=true

# ─── Observability (optional — all disabled by default) ───
# Requires `composer require sentry/sentry` on server + wp_option flags:
#   dinoco_obs_sentry_enabled=1
#   dinoco_obs_correlation_enabled=1
#   dinoco_obs_structured_log=1
# DINOCO_SENTRY_DSN=https://...@sentry.io/PROJECT_ID
# DINOCO_SENTRY_ENV=production
# DINOCO_SENTRY_SAMPLE_RATE=0.1
