    // POST /smoke-test-quote — call compute_quote with test data
    register_rest_route( 'dinoco-marketplace-tools/v1', '/smoke-test-quote', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mp_tools_rest_smoke_test_quote',
