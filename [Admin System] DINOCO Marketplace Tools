                    var src = v.constant ? '<span class="dnc-mp-status-on">constant</span>' : (v.option ? '<span class="dnc-mp-status-warn">option</span>' : '<span class="dnc-mp-status-off">(empty)</span>');
                    var eff = v.effective || '';
                    var truncEff = eff.length > 60 ? eff.substring(0, 60) + '…' : eff;
                    html += '<tr>'
                        + '<td><strong>' + esc(v.label) + '</strong>' + (v.required ? ' <span style="color:#dc2626;">*</span>' : '') + '<br><code style="font-size:10px;color:#6b7280;">' + esc(key) + '</code></td>'
                        + '<td>' + src + '</td>'
                        + '<td title="' + esc(eff) + '">' + esc(truncEff) + '</td>'
                        + '<td><input type="text" class="dnc-mp-input" style="min-width:auto;width:200px;font-size:12px;padding:4px 8px;" data-vat-input="' + esc(key) + '" value="' + esc(v.option) + '" placeholder="' + (v.constant ? 'constant ทับ — แก้ที่ wp-config' : 'กรอกค่า') + '" ' + (v.constant ? 'disabled' : '') + '> <button class="dnc-mp-btn dnc-mp-btn-primary" style="padding:4px 10px;font-size:11px;" data-action="vat-save" data-key="' + esc(key) + '" ' + (v.constant ? 'disabled' : '') + '>💾</button></td>'
                        + '</tr>';
                });
                html += '</tbody></table>';
                html += '<div style="margin-top:10px;padding:8px;background:#fef3c7;border-radius:6px;font-size:11px;color:#78350f;">💡 ถ้าเซลล์ Source = <strong>constant</strong> = ค่าถูก lock โดย wp-config.php — แก้ไม่ได้ผ่าน UI (ต้องแก้ใน wp-config). ถ้า Source = <strong>option</strong> = ค่าเก็บใน wp_options — แก้ได้ที่นี่ทันที</div>';
                document.getElementById('dnc-mp-vat-content').innerHTML = html;
            }

            function renderStats(stats, summary) {
                var html = '<div class="dnc-mp-grid" style="grid-template-columns:repeat(3,1fr);">';
                html += '<div class="dnc-mp-summary-card"><div class="dnc-mp-summary-num">' + summary.plate_bearing_total + '</div><div class="dnc-mp-summary-label">SKU มีเพลท (สิทธิ์ต่อประกันได้)</div></div>';
                html += '<div class="dnc-mp-summary-card"><div class="dnc-mp-summary-num" style="color:#16a34a;">' + summary.plate_bearing_priced + '</div><div class="dnc-mp-summary-label">SKU ที่กรอกราคาแล้ว</div></div>';
                html += '<div class="dnc-mp-summary-card"><div class="dnc-mp-summary-num" style="color:' + (summary.plate_bearing_pct < 80 ? '#dc2626' : '#16a34a') + ';">' + summary.plate_bearing_pct + '%</div><div class="dnc-mp-summary-label">Coverage (' + summary.plate_bearing_priced + '/' + summary.plate_bearing_total + ')</div></div>';
                html += '</div>';
                html += '<table class="dnc-mp-table" style="margin-top:12px;"><thead><tr><th>Attach level</th><th>Total</th><th>Has pricing</th><th>Missing</th><th>1y</th><th>2y</th><th>3y</th></tr></thead><tbody>';
                ['none','set','child','leaf'].forEach(function(lvl){
                    var s = stats[lvl] || { total: 0, has_pricing: 0, missing: 0, has_1y: 0, has_2y: 0, has_3y: 0 };
                    html += '<tr><td><strong>' + esc(lvl) + '</strong></td><td>' + s.total + '</td><td style="color:#16a34a;font-weight:600;">' + s.has_pricing + '</td><td style="color:#dc2626;font-weight:600;">' + s.missing + '</td><td>' + s.has_1y + '</td><td>' + s.has_2y + '</td><td>' + s.has_3y + '</td></tr>';
                });
                html += '</tbody></table>';
                document.getElementById('dnc-mp-stats-content').innerHTML = html;
            }

            function renderBrowseRows(rows) {
                if (!rows.length) {
                    document.getElementById('dnc-mp-browse-content').innerHTML = '<p style="color:#9ca3af;">ไม่พบผล</p>';
                    return;
                }
                var html = '<table class="dnc-mp-table"><thead><tr><th>SKU</th><th>ชื่อ</th><th>Level</th><th>1y</th><th>2y</th><th>3y</th><th></th></tr></thead><tbody>';
                rows.forEach(function(r){
                    var fmt = function(p) { return p === null ? '<span style="color:#9ca3af;">—</span>' : '฿' + Number(p).toLocaleString(); };
                    html += '<tr>'
                        + '<td><code>' + esc(r.sku) + '</code></td>'
                        + '<td>' + esc(r.name) + '</td>'
                        + '<td>' + esc(r.sn_attach_level) + '</td>'
                        + '<td>' + fmt(r.sn_ext_price_1y) + '</td>'
                        + '<td>' + fmt(r.sn_ext_price_2y) + '</td>'
                        + '<td>' + fmt(r.sn_ext_price_3y) + '</td>'
                        + '<td><a href="/admin-command-center/#inventory.catalog" target="_blank" class="dnc-mp-btn" style="padding:4px 8px;font-size:11px;text-decoration:none;display:inline-block;">📝 แก้ที่ Inventory</a></td>'
                        + '</tr>';
                });
                html += '</tbody></table>';
                html += '<p style="margin-top:6px;color:#6b7280;font-size:11px;">' + rows.length + ' แถว (max 100)</p>';
                document.getElementById('dnc-mp-browse-content').innerHTML = html;
            }

            // V.1.2 — VAT Master Switch banner
            function renderVatMaster(state) {
                state = state || {};
                var box = document.getElementById('dnc-mp-vat-master-banner');
                if (!box) return;
                var lock = state.constant_lock;
                var enabled = !!state.master_enabled;
                var ready = !!state.is_ready;
                var active = !!state.is_active;
                // V.1.4 L-1: scoped class variants instead of inline styles
                var variant, badge, msg, btnHtml = '';
                if (active) {
                    variant = 'is-active'; badge = '✅ ACTIVE';
                    msg = '<strong>VAT 7% เปิดใช้งานอยู่</strong> — ลูกค้าจ่ายเงินจบ → ใบกำกับภาษีถูกส่งทาง LINE Flex อัตโนมัติ';
                    btnHtml = lock
                        ? '<button class="dnc-mp-btn dnc-mp-btn-secondary" disabled title="WP_DINOCO_VAT_ENABLED constant locked">🔒 ปิดผ่าน constant</button>'
                        : '<button class="dnc-mp-btn dnc-mp-btn-secondary" data-action="vat-master-toggle" data-target="0">⏸️ ปิด VAT</button>';
                } else if (!ready) {
                    variant = 'is-warn'; badge = '⚠️ NOT READY';
                    msg = '<strong>กรอกข้อมูล VAT ให้ครบก่อนเปิด</strong> — จำเป็นต้องมี <code>tax_id</code> + <code>company_name</code> + <code>address</code> (ดูใน Section 2 ด้านล่าง)';
                    // V.1.3 H2: warn if constant forces master ON — completing data
                    // will activate VAT instantly without admin clicking Enable
                    if (lock && enabled) {
                        msg += '<br><strong class="dnc-mp-vat-warn-strong">🔒 WP_DINOCO_VAT_ENABLED constant = true</strong> — กรอกข้อมูลครบ → VAT เปิดทันทีโดยไม่ต้องกด Enable';
                    }
                    btnHtml = '<button class="dnc-mp-btn" disabled title="ข้อมูล VAT ยังไม่ครบ">▶️ เปิด VAT (รอกรอกข้อมูล)</button>';
                } else if (enabled && !active) {
                    variant = 'is-warn'; badge = '⚠️ ENABLED แต่ NOT READY';
                    msg = 'Master flag เปิดอยู่ แต่ข้อมูล VAT ขาดหาย — ตรวจ Section 2';
                    btnHtml = '<button class="dnc-mp-btn dnc-mp-btn-secondary" data-action="vat-master-toggle" data-target="0">⏸️ ปิด VAT</button>';
                } else {
                    variant = 'is-off'; badge = '⏸️ OFF';
                    msg = 'VAT ยังไม่เปิด — ลูกค้า marketplace จะไม่ได้รับใบกำกับภาษีจนกว่าจะกดเปิด';
                    btnHtml = lock
                        ? '<button class="dnc-mp-btn" disabled title="WP_DINOCO_VAT_ENABLED constant locked">🔒 ล็อคผ่าน constant</button>'
                        : '<button class="dnc-mp-btn" data-action="vat-master-toggle" data-target="1">▶️ เปิด VAT</button>';
                }
                // V.1.4 L-1: replace class list each render (no leftover variant class)
                box.className = 'dnc-mp-vat-banner ' + variant;
                box.innerHTML =
                    '<div class="dnc-mp-vat-banner-row">' +
                        '<div>' +
                            '<span class="dnc-mp-vat-badge ' + variant + '">' + badge + '</span>' +
                            '<div class="dnc-mp-vat-msg">' + msg + '</div>' +
                            '<div class="dnc-mp-vat-meta">' +
                                'Master: <code>' + (enabled ? 'ON' : 'OFF') + '</code> · ' +
                                'Data ready: <code>' + (ready ? 'YES' : 'NO') + '</code>' +
                                (lock ? ' · <strong>locked via WP_DINOCO_VAT_ENABLED constant</strong>' : '') +
                            '</div>' +
                        '</div>' +
                        '<div>' + btnHtml + '</div>' +
                    '</div>';
            }

            function loadDiagnose() {
                api('GET', '/diagnose').then(function(res){
                    if (res.status !== 200) {
                        toast('โหลด diagnose ไม่สำเร็จ (' + res.status + ')', 'error');
                        return;
                    }
                    renderFlags(res.data.flags);
                    renderVatMaster(res.data.vat_state);
                    renderVat(res.data.vat, res.data.ready);
                }).catch(function(e){
                    toast('Network error: ' + e.message, 'error');
                });
                api('GET', '/pricing-stats').then(function(res){
                    if (res.status !== 200) {
                        document.getElementById('dnc-mp-stats-content').innerHTML = '<p style="color:#dc2626;">โหลด stats ไม่สำเร็จ — ' + esc(res.data.message || 'unknown') + '</p>';
                        return;
                    }
                    renderStats(res.data.by_level, res.data.summary);
                });
            }

            function handleClick(e) {
                var t = e.target.closest('[data-action]');
                if (!t) return;
                var action = t.dataset.action;

                if (action === 'reload-diagnose') {
                    loadDiagnose();
                    toast('🔄 รีโหลด', 'success');
                    return;
                }
                if (action === 'toggle-flag') {
                    var flag = t.dataset.flag, value = t.dataset.value;
                    if (!confirm('Confirm: ' + (value === '1' ? 'เปิด' : 'ปิด') + ' flag "' + flag + '"?')) return;
                    t.disabled = true;
                    api('POST', '/toggle-flag', { flag: flag, value: value }).then(function(res){
                        if (res.status === 200 && res.data.success) {
                            toast('✅ ' + res.data.message, 'success');
                            loadDiagnose();
                        } else {
                            toast('❌ ' + (res.data.message || 'Toggle failed'), 'error');
                        }
                        t.disabled = false;
                    });
                    return;
                }
                if (action === 'vat-master-toggle') {
                    var target = t.dataset.target === '1';
                    var promptMsg = target
                        ? 'เปิด VAT 7% สำหรับ B2C Marketplace?\n\nลูกค้าใหม่ที่จ่ายค่าต่อประกัน → ระบบจะออกใบกำกับภาษี + ส่ง LINE Flex อัตโนมัติ'
                        : 'ปิด VAT?\n\nลูกค้าใหม่ที่จ่ายเงินระหว่าง flag OFF → ไม่ได้รับใบกำกับภาษี (admin ใช้ /resend/{id} ได้ภายหลัง)';
                    // V.1.3 M2: prefer Modal Helpers with native fallback (Phase 6 bulk migration pattern)
                    var doToggle = function(){
                        t.disabled = true;
                        api('POST', '/vat-toggle', { enabled: target ? '1' : '0' }).then(function(res){
                            if (res.status === 200 && res.data.ok) {
                                toast('✅ ' + (res.data.message || 'VAT toggled'), 'success');
                                loadDiagnose();
                            } else {
                                toast('❌ ' + (res.data.message || res.data.error || 'Toggle failed'), 'error');
                            }
                            t.disabled = false;
                        });
                    };
                    try {
                        if (window.dinocoModal && typeof window.dinocoModal.confirm === 'function') {
                            Promise.resolve(window.dinocoModal.confirm({
                                message: promptMsg,
                                confirmLabel: target ? 'เปิด VAT' : 'ปิด VAT',
                                cancelLabel: 'ยกเลิก',
                            })).then(function(ok){ if (ok) doToggle(); });
                        } else if (confirm(promptMsg)) {
                            doToggle();
                        }
                    } catch (e) {
                        if (confirm(promptMsg)) doToggle();
                    }
                    return;
                }
                if (action === 'vat-save') {
                    var key = t.dataset.key;
                    var input = document.querySelector('[data-vat-input="' + key + '"]');
                    var value = input ? input.value : '';
                    t.disabled = true;
                    api('POST', '/vat-set', { key: key, value: value }).then(function(res){
                        if (res.status === 200 && res.data.success) {
                            toast('✅ บันทึก ' + key + ' = ' + res.data.value, 'success');
                            loadDiagnose();
                        } else {
                            toast('❌ ' + (res.data.message || 'Save failed'), 'error');
                        }
                        t.disabled = false;
                    });
                    return;
                }
                if (action === 'browse-search') {
                    var q = document.getElementById('dnc-mp-browse-q').value.trim();
                    var filter = document.getElementById('dnc-mp-browse-filter').value;
                    var level = document.getElementById('dnc-mp-browse-level').value;
                    var qs = new URLSearchParams({ q: q, filter: filter, level: level, limit: '100' }).toString();
                    document.getElementById('dnc-mp-browse-content').innerHTML = '<p style="color:#6b7280;">กำลังโหลด...</p>';
                    fetch(REST_BASE + '/pricing-browse?' + qs + '&_=' + Date.now(), { headers: { 'X-WP-Nonce': NONCE } })
                        .then(function(r){ return r.json(); })
                        .then(function(d){
                            if (d && d.rows) renderBrowseRows(d.rows);
                            else document.getElementById('dnc-mp-browse-content').innerHTML = '<p style="color:#dc2626;">Error: ' + esc(d.message || 'unknown') + '</p>';
                        });
                    return;
                }
                if (action === 'smoke-test') {
                    var sku = document.getElementById('dnc-mp-test-sku').value.trim();
                    var years = parseInt(document.getElementById('dnc-mp-test-years').value, 10);
                    if (!sku) { toast('กรอก SKU ก่อน', 'error'); return; }
                    t.disabled = true;
                    document.getElementById('dnc-mp-test-result').innerHTML = '<p style="color:#6b7280;">กำลังทดสอบ...</p>';
                    api('POST', '/smoke-test-quote', { sku: sku, years: years }).then(function(res){
                        if (res.status === 200) {
                            var d = res.data;
                            var html = '<div class="dnc-mp-pre">' + esc(JSON.stringify(d, null, 2)) + '</div>';
                            if (d.success) {
                                var q = d.quote;
                                html = '<div style="background:#dcfce7;padding:12px;border-radius:8px;margin-bottom:10px;">'
                                    + '<strong>✅ ทดสอบสำเร็จ</strong><br>'
                                    + 'Base price: ฿' + Number(q.base_price).toLocaleString() + ' × ' + q.years + ' ปี<br>'
                                    + 'VAT (' + (q.vat_rate * 100).toFixed(0) + '%): ฿' + Number(q.vat).toLocaleString() + '<br>'
                                    + '<strong>Total: ฿' + Number(q.total).toLocaleString() + '</strong>'
                                    + '</div>' + html;
                            }
                            document.getElementById('dnc-mp-test-result').innerHTML = html;
                        } else {
                            document.getElementById('dnc-mp-test-result').innerHTML = '<p style="color:#dc2626;">❌ ' + esc(res.data.message || 'failed') + '</p>';
                        }
                        t.disabled = false;
                    });
                    return;
                }
            }

            root.addEventListener('click', handleClick);
            loadDiagnose();
        })(jQuery);
        </script>
        <?php
        return ob_get_clean();
    }
}

