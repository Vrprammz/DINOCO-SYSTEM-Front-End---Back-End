    // GET /pricing-stats — count enabled/disabled SKUs by attach_level
    register_rest_route( 'dinoco-marketplace-tools/v1', '/pricing-stats', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_mp_tools_rest_pricing_stats',
        'permission_callback' => $perm,
    ) );

    // GET /pricing-browse — search SKU + view pricing
    register_rest_route( 'dinoco-marketplace-tools/v1', '/pricing-browse', array(
        'methods'             => 'GET',
