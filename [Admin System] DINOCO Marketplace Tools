add_action( 'rest_api_init', function() {

    $perm = function() {
        return current_user_can( 'manage_options' ) && wp_verify_nonce(
            isset( $_SERVER['HTTP_X_WP_NONCE'] ) ? $_SERVER['HTTP_X_WP_NONCE'] : '',
            'wp_rest'
        );
    };

    // GET /diagnose — full system state
    register_rest_route( 'dinoco-marketplace-tools/v1', '/diagnose', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_mp_tools_rest_diagnose',
        'permission_callback' => $perm,
    ) );

    // POST /toggle-flag — flip system flag
    register_rest_route( 'dinoco-marketplace-tools/v1', '/toggle-flag', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mp_tools_rest_toggle_flag',
        'permission_callback' => $perm,
        'args'                => array(
            'flag' => array( 'required' => true, 'type' => 'string' ),
            'value' => array( 'required' => true, 'type' => 'string' ),
        ),
    ) );

    // POST /vat-set — set VAT field (wp_option)
    register_rest_route( 'dinoco-marketplace-tools/v1', '/vat-set', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mp_tools_rest_vat_set',
        'permission_callback' => $perm,
        'args'                => array(
            'key' => array( 'required' => true, 'type' => 'string' ),
            'value' => array( 'required' => true, 'type' => 'string' ),
        ),
    ) );

    // POST /vat-set-bulk — set all VAT fields at once
    register_rest_route( 'dinoco-marketplace-tools/v1', '/vat-set-bulk', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mp_tools_rest_vat_set_bulk',
        'permission_callback' => $perm,
    ) );

    // V.1.2 — POST /vat-toggle — master enable flag
    // V.1.3 L2: type=string declared (callback handles bool/int/string normalization)
    register_rest_route( 'dinoco-marketplace-tools/v1', '/vat-toggle', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mp_tools_rest_vat_toggle',
        'permission_callback' => $perm,
        'args'                => array(
            'enabled' => array(
