if ( ! defined( 'ABSPATH' ) ) return;

/* ============================================================
 * 1. VAT HELPER — Constant override, wp_options fallback
 * ============================================================
 *
 * Resolution order:
 *   1. If WP_DINOCO_VAT_<KEY> constant defined → use it (highest priority)
 *   2. If wp_options['dinoco_vat_<key>'] set → use it
 *   3. Default value
 *
 * This lets boss set values via THIS tool's UI (option update)
 * without needing Code Snippets paste / SSH access.
 */

if ( ! function_exists( 'dinoco_vat_get' ) ) {
    function dinoco_vat_get( $key, $default = '' ) {
        $allowed = array(
            'tax_id', 'company_name', 'company_name_en', 'address',
            'branch_code', 'branch_name', 'phone', 'email', 'rate', 'logo_url',
        );
        if ( ! in_array( $key, $allowed, true ) ) return $default;

        // V.1.1 (2026-05-18) — Hard defaults for non-required fields ที่มี
        // standard value. ใช้เมื่อ caller ไม่ส่ง $default เอง (default='').
        // Boss workflow ไม่ต้องกรอก branch_code='00000' (สำนักงานใหญ่ มาตรฐาน).
        if ( $default === '' ) {
            $hard_defaults = array(
                'branch_code' => '00000',           // สำนักงานใหญ่ (Thai standard)
                'branch_name' => 'สำนักงานใหญ่',
                'rate'        => '0.07',            // 7% Thai standard
            );
            if ( isset( $hard_defaults[ $key ] ) ) {
                $default = $hard_defaults[ $key ];
            }
        }

        // Constant has highest priority
        $const_name = 'WP_DINOCO_VAT_' . strtoupper( $key );
        if ( defined( $const_name ) ) {
            return constant( $const_name );
        }
        // Fallback to wp_options (set via UI). Note: option_value '0' / '00000'
        // is intentional + must NOT collapse to $default — use '' sentinel only.
        $opt = get_option( 'dinoco_vat_' . $key, '__NOT_SET__' );
        if ( $opt === '__NOT_SET__' || $opt === false || $opt === '' ) {
            return $default;
        }
        return $opt;
    }
}

if ( ! function_exists( 'dinoco_vat_is_ready' ) ) {
    /**
     * Returns true ถ้า constants/options ครบทุก field ที่ต้องใช้ใน receipt.
     */
    function dinoco_vat_is_ready() {
        $required = array( 'tax_id', 'company_name', 'address' );
        foreach ( $required as $k ) {
            if ( dinoco_vat_get( $k, '' ) === '' ) return false;
        }
        return true;
    }
}

/* ============================================================
 * V.1.2 — VAT Master Enable Flag
 *
 * Boss feedback 2026-05-18: "ไม่มีปุ่มเปิด VAT" — มี data ready check
 * แต่ไม่มี explicit master switch. เพิ่ม wp_option flag
 * `dinoco_vat_master_enabled` (default '0' = OFF) + helper
 * `dinoco_vat_is_active()` = master ON AND data ready.
 *
 * Defense-in-depth: ทุก VAT-emitting module (Receipt, LINE Push,
 * Monthly Export) ต้อง gate ด้วย dinoco_vat_is_active() ก่อน fire.
 *
 * Rollback: instant via flag flip OFF (ลูกค้าใหม่ที่ paid ระหว่าง
 * flag OFF → ไม่ได้รับ receipt; admin ใช้ /resend/{id} ปลด)
 * ============================================================ */

if ( ! function_exists( 'dinoco_vat_is_master_enabled' ) ) {
    /**
     * Master VAT switch (separate from data-readiness check).
     * Defaults OFF — boss must explicitly enable via UI.
     */
    function dinoco_vat_is_master_enabled() {
        // Constant override has highest priority (allow boss to lock via wp-config)
        if ( defined( 'WP_DINOCO_VAT_ENABLED' ) ) {
            return (bool) WP_DINOCO_VAT_ENABLED;
        }
        return (bool) get_option( 'dinoco_vat_master_enabled', '0' );
    }
}

if ( ! function_exists( 'dinoco_vat_is_active' ) ) {
    /**
     * Authoritative "should VAT module fire?" check.
     * MUST be: master flag ON AND all required settings populated.
     *
     * Callers: VAT Receipt eligibility, LINE Push handler, Monthly
     * Export — all gate downstream behavior on this.
     */
    function dinoco_vat_is_active() {
        if ( ! dinoco_vat_is_master_enabled() ) return false;
        if ( ! dinoco_vat_is_ready() ) return false;
        return true;
    }
}

if ( ! function_exists( 'dinoco_vat_set_master_enabled' ) ) {
    /**
     * Toggle master flag (admin only). Returns the new state actually set.
     * Refuses to enable if data not ready (preserves invariant: active
     * implies ready).
     *
     * @param bool $enabled
     * @return array { ok: bool, enabled: bool, error?: string }
     */
    function dinoco_vat_set_master_enabled( $enabled ) {
        $enabled = (bool) $enabled;
        // V.1.3 H1 fix: Refuse to write when constant overrides (state would
        // diverge silently — option changes but runtime ignores it).
        if ( defined( 'WP_DINOCO_VAT_ENABLED' ) ) {
            return array(
                'ok'      => false,
                'enabled' => (bool) WP_DINOCO_VAT_ENABLED,
                'error'   => 'constant_locked',
                'message' => 'WP_DINOCO_VAT_ENABLED constant ล็อคไว้ใน wp-config.php — แก้ที่ constant',
            );
        }
        if ( $enabled && ! dinoco_vat_is_ready() ) {
            return array(
                'ok'      => false,
                'enabled' => false,
                'error'   => 'data_not_ready',
                'message' => 'กรอก tax_id + company_name + address ให้ครบก่อนเปิด VAT',
            );
        }
        // V.1.3 C2 fix: read actual prior state from DB BEFORE update
        // (previous V.1.2 fabricated $old = inverse of $new which produced
        // phantom audit log rows when admin toggled to same state twice).
        // Also: dedup — skip audit log row if no actual state change.
        $old_raw = (string) get_option( 'dinoco_vat_master_enabled', '0' );
        $new_raw = $enabled ? '1' : '0';
        if ( $old_raw === $new_raw ) {
            // No-op — return success but don't write/log
            return array(
                'ok'      => true,
                'enabled' => $enabled,
                'no_change' => true,
            );
        }
        update_option( 'dinoco_vat_master_enabled', $new_raw );

        // V.1.3 L3: obs_capture for sensitive op telemetry (Round 11 pattern)
        if ( function_exists( 'dinoco_obs_capture' ) ) {
            dinoco_obs_capture( 'info', 'vat_master_toggled', array(
                'old'     => $old_raw,
                'new'     => $new_raw,
                'user_id' => get_current_user_id(),
                'source'  => 'marketplace_tools_set_helper',
            ) );
        }
        // Log via flag audit (function_exists guard — snippet may not be synced).
        // V.1.3 C2: $old is now ACTUAL prior state from get_option, not inverse-of-new.
        // Note: also fires via passive listener on `updated_option` if flag in
        // Flag Audit whitelist — this explicit call may produce duplicate row
        // (acceptable: both will record same delta, OR boss can remove this
        // explicit call once whitelist confirmed includes dinoco_vat_master_enabled).
        if ( function_exists( 'dinoco_flag_audit_log' ) ) {
            dinoco_flag_audit_log(
                'dinoco_vat_master_enabled',
                $old_raw,
                $new_raw,
                'admin_ui_toggle',
                'marketplace_tools'
            );
        }
        return array( 'ok' => true, 'enabled' => $enabled );
    }
}

