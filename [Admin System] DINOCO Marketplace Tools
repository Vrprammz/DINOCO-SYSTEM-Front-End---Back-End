            return new WP_Error( 'mp_compute_missing', 'compute_quote helper ไม่มี', array( 'status' => 503 ) );
        }

        $quote = dinoco_sn_marketplace_compute_quote( $base_price, $years );

        return rest_ensure_response( array(
            'success'    => true,
            'sku'        => $sku,
            'years'      => $years,
            'base_price' => $base_price,
            'quote'      => $quote,
