if ( ! function_exists( 'dinoco_mp_tools_rest_diagnose' ) ) {
    function dinoco_mp_tools_rest_diagnose( $req ) {
        global $wpdb;

        // System flags
        $flags = array(
            'dinoco_sn_system_enabled' => array(
                'value' => get_option( 'dinoco_sn_system_enabled', '0' ),
                'label' => 'SN System Master',
                'helper' => function_exists( 'dinoco_sn_is_enabled' )
                    ? dinoco_sn_is_enabled() : null,
            ),
            'dinoco_sn_marketplace_enabled' => array(
                'value' => get_option( 'dinoco_sn_marketplace_enabled', '0' ),
                'label' => 'Marketplace (F#8)',
                'helper' => function_exists( 'dinoco_sn_marketplace_is_enabled' )
                    ? dinoco_sn_marketplace_is_enabled() : null,
            ),
            'dinoco_sn_notification_send_enabled' => array(
                'value' => get_option( 'dinoco_sn_notification_send_enabled', '0' ),
                'label' => 'Notification Send Gate',
                'helper' => null,
            ),
        );

        // VAT constants/options
        $vat_keys = array(
            'tax_id'           => array( 'label' => 'Tax ID (13 หลัก)', 'required' => true ),
            'company_name'     => array( 'label' => 'ชื่อบริษัท', 'required' => true ),
            'company_name_en'  => array( 'label' => 'Company name (EN)', 'required' => false ),
            'address'          => array( 'label' => 'ที่อยู่จดทะเบียน', 'required' => true ),
            'branch_code'      => array( 'label' => 'รหัสสาขา', 'required' => false ),
            'branch_name'      => array( 'label' => 'ชื่อสาขา', 'required' => false ),
            'phone'            => array( 'label' => 'เบอร์ติดต่อ', 'required' => false ),
            'email'            => array( 'label' => 'อีเมล', 'required' => false ),
            'rate'             => array( 'label' => 'VAT rate (%)', 'required' => false ),
            'logo_url'         => array( 'label' => 'Logo URL', 'required' => false ),
        );
        $vat = array();
        foreach ( $vat_keys as $k => $meta ) {
            $const_name = 'WP_DINOCO_VAT_' . strtoupper( $k );
            $vat[ $k ] = array(
                'label'        => $meta['label'],
                'required'     => $meta['required'],
                'constant'     => defined( $const_name ),
                'constant_val' => defined( $const_name ) ? constant( $const_name ) : null,
                'option'       => get_option( 'dinoco_vat_' . $k, '' ),
                'effective'    => dinoco_vat_get( $k, '' ),
            );
        }

        // Pricing stats
        $ct_table = $wpdb->prefix . 'dinoco_products';
        $stats = array(
            'total_products' => 0,
            'plate_bearing'  => 0,
            'has_pricing'    => 0,
            'missing'        => 0,
        );
        $has_ext_cols = (bool) $wpdb->get_var( "SHOW COLUMNS FROM {$ct_table} LIKE 'sn_ext_price_1y'" );
        if ( $has_ext_cols ) {
            $stats['total_products'] = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$ct_table} WHERE is_active = 1" );
            $stats['plate_bearing'] = (int) $wpdb->get_var(
                "SELECT COUNT(*) FROM {$ct_table} WHERE is_active = 1 AND sn_attach_level != 'none'"
            );
            $stats['has_pricing'] = (int) $wpdb->get_var(
                "SELECT COUNT(*) FROM {$ct_table}
                 WHERE is_active = 1 AND sn_attach_level != 'none'
                   AND (sn_ext_price_1y IS NOT NULL OR sn_ext_price_2y IS NOT NULL OR sn_ext_price_3y IS NOT NULL)"
            );
            $stats['missing'] = max( 0, $stats['plate_bearing'] - $stats['has_pricing'] );
        }

        // Marketplace ready summary
        $ready = array(
            'system_on'        => function_exists( 'dinoco_sn_is_enabled' ) && dinoco_sn_is_enabled(),
            'marketplace_on'   => function_exists( 'dinoco_sn_marketplace_is_enabled' ) && dinoco_sn_marketplace_is_enabled(),
            'vat_ready'        => dinoco_vat_is_ready(),
            'has_priced_skus'  => $stats['has_pricing'] > 0,
            'helper_functions' => array(
                'dinoco_sn_is_enabled' => function_exists( 'dinoco_sn_is_enabled' ),
                'dinoco_sn_marketplace_is_enabled' => function_exists( 'dinoco_sn_marketplace_is_enabled' ),
                'dinoco_sn_marketplace_compute_quote' => function_exists( 'dinoco_sn_marketplace_compute_quote' ),
            ),
        );

        return rest_ensure_response( array(
            'flags'  => $flags,
            'vat'    => $vat,
            'stats'  => $stats,
            'ready'  => $ready,
            // V.1.2 — VAT master state for UI banner
            'vat_state' => array(
                'master_enabled' => dinoco_vat_is_master_enabled(),
                'is_ready'       => dinoco_vat_is_ready(),
                'is_active'      => dinoco_vat_is_active(),
                'constant_lock'  => defined( 'WP_DINOCO_VAT_ENABLED' ),
            ),
            'now'    => current_time( 'mysql' ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_toggle_flag' ) ) {
    function dinoco_mp_tools_rest_toggle_flag( $req ) {
        $flag = sanitize_text_field( $req->get_param( 'flag' ) );
        $value = sanitize_text_field( $req->get_param( 'value' ) );

        $allowed = array(
            'dinoco_sn_system_enabled',
            'dinoco_sn_marketplace_enabled',
            'dinoco_sn_notification_send_enabled',
        );
        if ( ! in_array( $flag, $allowed, true ) ) {
            return new WP_Error( 'mp_invalid_flag', 'Flag ไม่อยู่ใน whitelist', array( 'status' => 400 ) );
        }
        if ( ! in_array( $value, array( '0', '1' ), true ) ) {
            return new WP_Error( 'mp_invalid_value', 'Value ต้องเป็น "0" หรือ "1"', array( 'status' => 400 ) );
        }

        $old = get_option( $flag, '0' );
        update_option( $flag, $value, false );

        // Bust H7 alloptions cache (per 2026-05-16 fix)
        if ( function_exists( 'wp_cache_delete' ) ) {
            wp_cache_delete( 'alloptions', 'options' );
        }

        return rest_ensure_response( array(
            'success' => true,
            'flag'    => $flag,
            'old'     => $old,
            'new'     => $value,
            'message' => "Flag '{$flag}' set to '{$value}' (เดิม '{$old}')",
        ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_vat_set' ) ) {
    function dinoco_mp_tools_rest_vat_set( $req ) {
        $key   = sanitize_key( $req->get_param( 'key' ) );
        $value = $req->get_param( 'value' ); // sanitize per-field below

        $allowed = array(
            'tax_id', 'company_name', 'company_name_en', 'address',
            'branch_code', 'branch_name', 'phone', 'email', 'rate', 'logo_url',
        );
        if ( ! in_array( $key, $allowed, true ) ) {
            return new WP_Error( 'mp_invalid_key', 'Key ไม่อยู่ใน whitelist', array( 'status' => 400 ) );
        }

        // Per-field sanitize
        switch ( $key ) {
            case 'email':
                $value = sanitize_email( $value );
                break;
            case 'logo_url':
                $value = esc_url_raw( $value );
                break;
            case 'rate':
                $value = (string) max( 0, min( 1, (float) $value ) );
                break;
            case 'tax_id':
                $value = preg_replace( '/[^0-9]/', '', $value );
                if ( strlen( $value ) !== 13 ) {
                    return new WP_Error( 'mp_invalid_tax_id', 'Tax ID ต้องเป็น 13 หลัก', array( 'status' => 400 ) );
                }
                break;
            default:
                $value = sanitize_text_field( $value );
        }

        update_option( 'dinoco_vat_' . $key, $value, false );
        if ( function_exists( 'wp_cache_delete' ) ) {
            wp_cache_delete( 'alloptions', 'options' );
        }

        return rest_ensure_response( array(
            'success' => true,
            'key'     => $key,
            'value'   => $value,
            'message' => "VAT field '{$key}' updated",
        ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_vat_set_bulk' ) ) {
    function dinoco_mp_tools_rest_vat_set_bulk( $req ) {
        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) {
            return new WP_Error( 'mp_invalid_body', 'Body ต้องเป็น JSON object', array( 'status' => 400 ) );
        }

        $updated = array();
        $errors  = array();
        foreach ( $body as $key => $value ) {
            // Reuse single-set handler for each field
            $fake_req = new WP_REST_Request( 'POST', '/dinoco-marketplace-tools/v1/vat-set' );
            $fake_req->set_param( 'key', $key );
            $fake_req->set_param( 'value', (string) $value );
            $result = dinoco_mp_tools_rest_vat_set( $fake_req );
            if ( is_wp_error( $result ) ) {
                $errors[ $key ] = $result->get_error_message();
            } else {
                $data = $result->get_data();
                $updated[ $key ] = $data['value'];
            }
        }

        return rest_ensure_response( array(
            'success' => empty( $errors ),
            'updated' => $updated,
            'errors'  => $errors,
        ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_vat_toggle' ) ) {
    /**
     * V.1.2 — POST /vat-toggle — flip master VAT enable flag.
     * Accepts `enabled` as bool/int/string ('1','0','true','false').
     *
     * V.1.3 L4: rate-limited 5 toggles per 10 min per user (defense-in-depth
     * against flapping; admin-only endpoint so low risk, but matches R5 GAP
     * fix pattern for 7 mutation endpoints).
     */
    function dinoco_mp_tools_rest_vat_toggle( $req ) {
        $uid = get_current_user_id();
        if ( $uid > 0 && function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( "vat_master_toggle_{$uid}", 5, 10 * MINUTE_IN_SECONDS );
            if ( is_wp_error( $rl ) ) return $rl;
        }
        $raw = $req->get_param( 'enabled' );
        // Normalize various truthy/falsey shapes
        if ( is_bool( $raw ) ) {
            $enabled = $raw;
        } elseif ( is_string( $raw ) ) {
            $low = strtolower( trim( $raw ) );
            $enabled = in_array( $low, array( '1', 'true', 'on', 'yes' ), true );
        } else {
            $enabled = (bool) intval( $raw );
        }

        $result = dinoco_vat_set_master_enabled( $enabled );

        // Compose response with current readiness + new active state
        return rest_ensure_response( array(
            'ok'           => $result['ok'],
            'enabled'      => $result['enabled'],
            'error'        => $result['error'] ?? null,
            'message'      => $result['message'] ?? ( $result['enabled'] ? 'VAT เปิดใช้งานแล้ว' : 'VAT ปิดใช้งานแล้ว' ),
            'is_ready'     => dinoco_vat_is_ready(),
            'is_active'    => dinoco_vat_is_active(),
        ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_pricing_stats' ) ) {
    function dinoco_mp_tools_rest_pricing_stats( $req ) {
        global $wpdb;
        $ct_table = $wpdb->prefix . 'dinoco_products';
        $has_ext_cols = (bool) $wpdb->get_var( "SHOW COLUMNS FROM {$ct_table} LIKE 'sn_ext_price_1y'" );
        if ( ! $has_ext_cols ) {
            return new WP_Error( 'mp_no_schema', 'sn_ext_price columns ไม่มี — ต้อง sync Inventory V.47.0', array( 'status' => 503 ) );
        }

        $rows = $wpdb->get_results(
            "SELECT sn_attach_level,
                    COUNT(*) AS total,
                    SUM(CASE WHEN sn_ext_price_1y IS NOT NULL OR sn_ext_price_2y IS NOT NULL OR sn_ext_price_3y IS NOT NULL THEN 1 ELSE 0 END) AS has_pricing,
                    SUM(CASE WHEN sn_ext_price_1y IS NOT NULL THEN 1 ELSE 0 END) AS has_1y,
                    SUM(CASE WHEN sn_ext_price_2y IS NOT NULL THEN 1 ELSE 0 END) AS has_2y,
                    SUM(CASE WHEN sn_ext_price_3y IS NOT NULL THEN 1 ELSE 0 END) AS has_3y
             FROM {$ct_table}
             WHERE is_active = 1
             GROUP BY sn_attach_level",
            ARRAY_A
        );

        $by_level = array();
        foreach ( $rows as $r ) {
            $by_level[ $r['sn_attach_level'] ] = array(
                'total'        => (int) $r['total'],
                'has_pricing'  => (int) $r['has_pricing'],
                'missing'      => (int) $r['total'] - (int) $r['has_pricing'],
                'has_1y'       => (int) $r['has_1y'],
                'has_2y'       => (int) $r['has_2y'],
                'has_3y'       => (int) $r['has_3y'],
            );
        }

        // Plate-bearing only (most actionable subset)
        $plate_bearing_total = 0;
        $plate_bearing_priced = 0;
        foreach ( array( 'set', 'child', 'leaf' ) as $lvl ) {
            if ( ! isset( $by_level[ $lvl ] ) ) continue;
            $plate_bearing_total += $by_level[ $lvl ]['total'];
            $plate_bearing_priced += $by_level[ $lvl ]['has_pricing'];
        }

        return rest_ensure_response( array(
            'by_level' => $by_level,
            'summary'  => array(
                'plate_bearing_total'  => $plate_bearing_total,
                'plate_bearing_priced' => $plate_bearing_priced,
                'plate_bearing_pct'    => $plate_bearing_total > 0 ? round( 100 * $plate_bearing_priced / $plate_bearing_total, 1 ) : 0,
            ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_pricing_browse' ) ) {
    function dinoco_mp_tools_rest_pricing_browse( $req ) {
        global $wpdb;
        $ct_table = $wpdb->prefix . 'dinoco_products';
        $has_ext_cols = (bool) $wpdb->get_var( "SHOW COLUMNS FROM {$ct_table} LIKE 'sn_ext_price_1y'" );
        if ( ! $has_ext_cols ) {
            return new WP_Error( 'mp_no_schema', 'sn_ext_price columns ไม่มี', array( 'status' => 503 ) );
        }

        $q       = $req->get_param( 'q' );
        $filter  = $req->get_param( 'filter' ); // 'all' | 'priced' | 'missing'
        $level   = $req->get_param( 'level' );  // 'all' | 'none' | 'set' | 'child' | 'leaf'
        $limit   = min( 100, max( 1, (int) $req->get_param( 'limit' ) ?: 50 ) );

        $where = array( 'is_active = 1' );
        $args  = array();
        if ( $q ) {
            $where[] = '(sku LIKE %s OR name LIKE %s)';
            $like    = '%' . $wpdb->esc_like( $q ) . '%';
            $args[]  = $like;
            $args[]  = $like;
        }
        if ( in_array( $level, array( 'none', 'set', 'child', 'leaf' ), true ) ) {
            $where[] = 'sn_attach_level = %s';
            $args[]  = $level;
        }
        if ( $filter === 'priced' ) {
            $where[] = '(sn_ext_price_1y IS NOT NULL OR sn_ext_price_2y IS NOT NULL OR sn_ext_price_3y IS NOT NULL)';
        } elseif ( $filter === 'missing' ) {
            $where[] = "sn_attach_level != 'none' AND sn_ext_price_1y IS NULL AND sn_ext_price_2y IS NULL AND sn_ext_price_3y IS NULL";
        }

        $sql = "SELECT sku, name, sn_attach_level, sn_ext_price_1y, sn_ext_price_2y, sn_ext_price_3y
                FROM {$ct_table}
                WHERE " . implode( ' AND ', $where ) . "
                ORDER BY sku ASC
                LIMIT %d";
        $args[] = $limit;

        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $args ), ARRAY_A );
        if ( null === $rows ) $rows = array();

        return rest_ensure_response( array( 'rows' => $rows, 'count' => count( $rows ) ) );
    }
}

if ( ! function_exists( 'dinoco_mp_tools_rest_smoke_test_quote' ) ) {
    function dinoco_mp_tools_rest_smoke_test_quote( $req ) {
        $sku   = sanitize_text_field( $req->get_param( 'sku' ) );
        $years = (int) $req->get_param( 'years' );
        if ( ! in_array( $years, array( 1, 2, 3 ), true ) ) {
            return new WP_Error( 'mp_invalid_years', 'years ต้องเป็น 1, 2, หรือ 3', array( 'status' => 400 ) );
        }

        if ( ! function_exists( 'dinoco_sn_get_extension_price' ) ) {
            return new WP_Error( 'mp_helper_missing', 'dinoco_sn_get_extension_price() ไม่มี — SN REST API snippet ไม่ active', array( 'status' => 503 ) );
        }

        $base_price = dinoco_sn_get_extension_price( $sku, $years );
        if ( null === $base_price ) {
            return rest_ensure_response( array(
                'success' => false,
                'message' => 'SKU นี้ไม่มีราคา ' . $years . 'y ที่ตั้งไว้',
                'sku' => $sku,
                'years' => $years,
            ) );
