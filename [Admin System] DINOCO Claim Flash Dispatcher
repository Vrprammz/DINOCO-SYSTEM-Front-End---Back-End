// REG-029 kill switch — when OFF the snippet is byte-identical no-op.
if ( ! get_option( 'dinoco_claim_flash_enabled', false ) ) {
    return;
}

if ( ! defined( 'DINOCO_CLAIM_FLASH_DISPATCHER_ACTIVE' ) ) {
    define( 'DINOCO_CLAIM_FLASH_DISPATCHER_ACTIVE', true );
}

// ──────────────────────────────────────────────────────────────────
// Constants — direction whitelist + FSM mapping
// ──────────────────────────────────────────────────────────────────

if ( ! defined( 'DINOCO_CLAIM_FLASH_DIRECTIONS' ) ) {
    define( 'DINOCO_CLAIM_FLASH_DIRECTIONS', 'replacement|repaired_return|inbound_pickup' );
}

if ( ! function_exists( 'dinoco_claim_flash_direction_to_status' ) ) {
    /**
     * Map dispatch direction → claim_ticket target status.
     * Pure function — used by both helper + REST endpoint + tests.
     *
     * @param string $direction one of replacement/repaired_return/inbound_pickup
     * @return string target ticket_status (empty if unknown)
     */
    function dinoco_claim_flash_direction_to_status( $direction ) {
        $map = array(
            'replacement'     => 'Replacement Shipped',
            'repaired_return' => 'Repaired Item Dispatched',
            'inbound_pickup'  => 'In Transit to Company',
        );
        $direction = is_string( $direction ) ? strtolower( trim( $direction ) ) : '';
        return isset( $map[ $direction ] ) ? $map[ $direction ] : '';
    }
}

if ( ! function_exists( 'dinoco_claim_flash_direction_required_state' ) ) {
    /**
     * Map direction → required current claim_ticket state (pre-transition guard).
     * @return string required source state (empty = no guard)
     */
    function dinoco_claim_flash_direction_required_state( $direction ) {
        $map = array(
            'replacement'     => 'Approved',
            'repaired_return' => 'Repairing',
            'inbound_pickup'  => 'Pending Pickup',
        );
        $direction = is_string( $direction ) ? strtolower( trim( $direction ) ) : '';
        return isset( $map[ $direction ] ) ? $map[ $direction ] : '';
    }
}

if ( ! function_exists( 'dinoco_claim_flash_state_to_terminal_status' ) ) {
    /**
     * Map Flash state code → terminal claim_ticket status, given direction context.
     * State 5 = delivered. Terminal map varies per direction.
     * Returns '' for non-terminal / unmapped state.
     *
     * @param int    $flash_state Flash state code (1-9)
     * @param string $direction   stored direction on PNO record
     * @return string target ticket_status (empty = no transition)
     */
    function dinoco_claim_flash_state_to_terminal_status( $flash_state, $direction ) {
        $flash_state = intval( $flash_state );
        $direction   = is_string( $direction ) ? strtolower( trim( $direction ) ) : '';
        if ( $flash_state !== 5 ) return '';
        $delivered_map = array(
            'replacement'     => 'Replacement Shipped',
            'repaired_return' => 'Maintenance Completed',
            'inbound_pickup'  => 'In Repair Queue',
        );
        return isset( $delivered_map[ $direction ] ) ? $delivered_map[ $direction ] : '';
    }
}

