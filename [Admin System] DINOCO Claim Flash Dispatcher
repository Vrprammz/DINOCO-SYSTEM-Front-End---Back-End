add_action( 'dinoco/claim/shipment_status_changed', 'dinoco_claim_flash_on_webhook', 10, 4 );

if ( ! function_exists( 'dinoco_claim_flash_on_webhook' ) ) {
    /**
     * @param int    $claim_id
     * @param string $pno
     * @param int    $flash_state  Flash state code (1-9)
     * @param array  $context      raw webhook data
     */
    function dinoco_claim_flash_on_webhook( $claim_id, $pno, $flash_state, $context = array() ) {
        $claim_id = intval( $claim_id );
        $pno = (string) $pno;
        $flash_state = intval( $flash_state );
        if ( $claim_id <= 0 || $pno === '' ) return;

        // Read PNO entry for direction context
        $pnos = get_post_meta( $claim_id, '_claim_flash_pnos', true );
        $direction = '';
        $entry_status = '';
        if ( is_array( $pnos ) ) {
            foreach ( $pnos as $entry ) {
                if ( is_array( $entry ) && isset( $entry['pno'] ) && $entry['pno'] === $pno ) {
                    $direction = isset( $entry['direction'] ) ? (string) $entry['direction'] : '';
                    $entry_status = isset( $entry['status'] ) ? (string) $entry['status'] : '';
                    break;
                }
            }
        }

        // Always update PNO entry with latest state
        $state_label_map = array(
            1 => 'picked_up', 2 => 'in_transit', 3 => 'delivering', 4 => 'detained',
            5 => 'delivered', 6 => 'problem', 7 => 'returned', 8 => 'closed', 9 => 'cancelled',
        );
        $new_status = $state_label_map[ $flash_state ] ?? $entry_status;
        dinoco_claim_flash_update_pno_entry( $claim_id, $pno, array(
            'status'      => $new_status,
            'flash_state' => $flash_state,
            'updated_at'  => current_time( 'mysql' ),
        ) );

        // Map state → target claim status
        $target = dinoco_claim_flash_state_to_terminal_status( $flash_state, $direction );

        if ( $flash_state === 7 || $flash_state === 9 ) {
            // returned / cancelled — log + admin alert (no auto-transition)
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'claim_flash_shipment_problem', array(
                    'claim_id'    => $claim_id,
                    'pno'         => $pno,
                    'flash_state' => $flash_state,
                    'direction'   => $direction,
                ) );
            }
            return;
        }

        if ( $target === '' ) return;
        if ( ! function_exists( 'dinoco_set_claim_status' ) ) return;

        // HR4 silent skip — terminal_state guard already inside dinoco_set_claim_status.
        $tr = dinoco_set_claim_status( $claim_id, $target, array(
            'actor'  => 'system',
            'source' => 'claim_flash_webhook',
            'note'   => 'PNO=' . $pno . ' state=' . $flash_state,
        ) );
        if ( is_wp_error( $tr ) ) {
            $err_code = $tr->get_error_code();
            // 'terminal_state' is expected HR4 silent skip; log others
            if ( $err_code !== 'terminal_state' && function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'claim_flash_fsm_skip', array(
                    'claim_id'   => $claim_id,
                    'pno'        => $pno,
                    'target'     => $target,
                    'error_code' => $err_code,
                ) );
            }
        }
    }
}

// ──────────────────────────────────────────────────────────────────
// V.0.5 Sprint 28 Phase 3.6 — Print queue enqueue listener
// ──────────────────────────────────────────────────────────────────
//
// Listens to `dinoco/claim/flash_created` fired from
// `dinoco_claim_create_flash_shipment` success branch (V.0.5).
// Enqueues a print job for the Flash label via the same /b2b/v1/print-queue
// pattern used by B2B order labels — but writes claim-side post meta
// (`_claim_flash_print_jobs[]`) rather than the b2b_order print_status ACF
// field, because RPi `b2b_rest_print_queue` only handles b2b_order CPT.
//
// SKIPS direction === 'inbound_pickup' because the Flash courier brings
// their own AWB to the customer pickup — no DINOCO-side label to print.
//
// Priority 20 — runs AFTER any future security/audit listeners hooked at
// the default priority 10. Safe: NEVER throws to the do_action() caller.

add_action( 'dinoco/claim/flash_created', 'dinoco_claim_flash_enqueue_print_job', 20, 1 );

if ( ! function_exists( 'b2b_enqueue_claim_print_job' ) ) {
    /**
     * V.0.5 Sprint 28 Phase 3.6 — thin helper that records claim Flash
     * print intent on the claim post + fires a downstream action. Mirrors
     * `b2b_enqueue_print_job($ticket_id)` from [B2B] Snippet 1 V.34.x but
     * scoped to claim_ticket CPT (the canonical helper rejects non-b2b_order
     * post types). Reuses /b2b/v1/print-queue insert pattern conceptually
     * by writing print_status meta that RPi can poll via a future endpoint.
     *
     * @param int   $claim_id  claim_ticket post ID
     * @param array $payload   { pno, label_url, direction, sort_code?, out_trade_no?, sender_key? }
     * @return bool true on success, false on guard miss
     */
    function b2b_enqueue_claim_print_job( $claim_id, array $payload ) {
        $claim_id = intval( $claim_id );
        if ( $claim_id <= 0 || get_post_type( $claim_id ) !== 'claim_ticket' ) return false;

        $pno = isset( $payload['pno'] ) ? (string) $payload['pno'] : '';
        if ( $pno === '' ) return false;

        $jobs = get_post_meta( $claim_id, '_claim_flash_print_jobs', true );
        if ( ! is_array( $jobs ) ) $jobs = array();

        // Dedup — skip if this PNO already enqueued
        foreach ( $jobs as $existing ) {
            if ( is_array( $existing ) && isset( $existing['pno'] ) && $existing['pno'] === $pno ) {
                return false;
            }
        }

        $jobs[] = array(
            'pno'          => $pno,
            'label_url'    => isset( $payload['label_url'] ) ? (string) $payload['label_url'] : '',
            'direction'    => isset( $payload['direction'] ) ? (string) $payload['direction'] : '',
            'sort_code'    => isset( $payload['sort_code'] ) ? (string) $payload['sort_code'] : '',
            'out_trade_no' => isset( $payload['out_trade_no'] ) ? (string) $payload['out_trade_no'] : '',
            'sender_key'   => isset( $payload['sender_key'] ) ? (string) $payload['sender_key'] : 'dinoco',
            'status'       => 'queued',
            'source'       => 'claim_flash',
            'created_at'   => current_time( 'mysql' ),
        );
        update_post_meta( $claim_id, '_claim_flash_print_jobs', $jobs );

        if ( function_exists( 'dinoco_obs_capture' ) ) {
            dinoco_obs_capture( 'info', 'claim_flash_print_enqueued', array(
                'claim_id' => $claim_id,
                'pno'      => $pno,
                'direction' => isset( $payload['direction'] ) ? $payload['direction'] : '',
            ) );
        }
        return true;
    }
}

if ( ! function_exists( 'dinoco_claim_flash_enqueue_print_job' ) ) {
    /**
     * V.0.5 Sprint 28 Phase 3.6 — listener.
     *
     * @param array $payload { claim_id, pno, direction, label_url, sort_code, out_trade_no, sender_key }
     */
    function dinoco_claim_flash_enqueue_print_job( $payload ) {
        try {
            if ( ! is_array( $payload ) ) return;
            $direction = isset( $payload['direction'] ) ? (string) $payload['direction'] : '';
            $claim_id  = isset( $payload['claim_id'] ) ? intval( $payload['claim_id'] ) : 0;
            $pno       = isset( $payload['pno'] ) ? (string) $payload['pno'] : '';
            if ( $claim_id <= 0 || $pno === '' ) return;

            // SKIP inbound_pickup — Flash courier brings own AWB to customer
            // pickup. No DINOCO-side label to print at warehouse. Spec line
            // 1062 — only replacement + repaired_return enqueue print.
            if ( $direction === 'inbound_pickup' ) {
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( 'info', 'claim_flash_print_skip_inbound', array(
                        'claim_id' => $claim_id,
                        'pno'      => $pno,
                    ) );
                }
                return;
            }

            $enqueued = b2b_enqueue_claim_print_job( $claim_id, $payload );

            // Fire downstream action for Health Monitor + future RPi heartbeat
            if ( $enqueued ) {
                try {
                    do_action( 'dinoco/claim/flash_print_enqueued', array(
                        'claim_id'  => $claim_id,
                        'pno'       => $pno,
                        'direction' => $direction,
                        'label_url' => isset( $payload['label_url'] ) ? (string) $payload['label_url'] : '',
                    ) );
                } catch ( \Throwable $hook_e ) {
                    // Swallow — print job already enqueued.
                }
            }
        } catch ( \Throwable $e ) {
            // NEVER let listener exception block Flash response chain.
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_flash_print_enqueue_exception', array(
                    'msg' => $e->getMessage(),
                ) );
            }
        }
    }
}
