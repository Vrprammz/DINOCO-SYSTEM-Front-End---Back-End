if ( ! function_exists( 'dinoco_claim_flash_find_claim_by_pno' ) ) {
    function dinoco_claim_flash_find_claim_by_pno( $pno ) {
        global $wpdb;
        if ( ! is_string( $pno ) || $pno === '' ) return 0;
        $rows = $wpdb->get_col( $wpdb->prepare(
            "SELECT post_id FROM {$wpdb->postmeta}
             WHERE meta_key = '_claim_flash_pnos'
             AND meta_value LIKE %s LIMIT 1",
            '%"' . $wpdb->esc_like( $pno ) . '"%'
        ) );
        return ! empty( $rows ) ? intval( $rows[0] ) : 0;
    }
}

if ( ! function_exists( 'dinoco_claim_flash_update_pno_entry' ) ) {
    /**
     * Mutate one entry in _claim_flash_pnos[] by pno.
     * @return bool true on found+updated, false on miss
     */
    function dinoco_claim_flash_update_pno_entry( $claim_id, $pno, array $patch ) {
        $claim_id = intval( $claim_id );
        if ( $claim_id <= 0 || ! is_string( $pno ) || $pno === '' ) return false;
        $pnos = get_post_meta( $claim_id, '_claim_flash_pnos', true );
        if ( ! is_array( $pnos ) ) return false;
        $changed = false;
        foreach ( $pnos as $i => $entry ) {
            if ( is_array( $entry ) && isset( $entry['pno'] ) && $entry['pno'] === $pno ) {
                $pnos[ $i ] = array_merge( $entry, $patch );
                $changed = true;
            }
        }
        if ( $changed ) {
            update_post_meta( $claim_id, '_claim_flash_pnos', $pnos );
        }
        return $changed;
    }
}

