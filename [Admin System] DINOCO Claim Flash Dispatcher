add_action( 'rest_api_init', 'dinoco_claim_flash_register_routes' );

if ( ! function_exists( 'dinoco_claim_flash_register_routes' ) ) {
    function dinoco_claim_flash_register_routes() {
        register_rest_route( 'dinoco-claim/v1', '/flash-create', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_flash_rest_create',
            'permission_callback' => 'dinoco_claim_flash_admin_perm',
        ) );
        register_rest_route( 'dinoco-claim/v1', '/flash-cancel/(?P<pno>[A-Za-z0-9_-]+)', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_flash_rest_cancel',
            'permission_callback' => 'dinoco_claim_flash_admin_perm',
            'args'                => array(
                'pno' => array( 'type' => 'string', 'required' => true ),
            ),
        ) );
        register_rest_route( 'dinoco-claim/v1', '/flash-status/(?P<pno>[A-Za-z0-9_-]+)', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_flash_rest_status',
            'permission_callback' => 'dinoco_claim_flash_read_perm',
            'args'                => array(
                'pno' => array( 'type' => 'string', 'required' => true ),
            ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_claim_flash_admin_perm' ) ) {
    function dinoco_claim_flash_admin_perm( $req ) {
        if ( ! current_user_can( 'manage_options' ) ) return false;
        $nonce = $req->get_header( 'x_wp_nonce' );
        if ( $nonce && wp_verify_nonce( $nonce, 'wp_rest' ) ) return true;
        // Also accept cookie-based nonce
        return (bool) wp_verify_nonce( (string) $req->get_param( '_wpnonce' ), 'wp_rest' );
    }
}

if ( ! function_exists( 'dinoco_claim_flash_read_perm' ) ) {
    function dinoco_claim_flash_read_perm( $req ) {
        if ( current_user_can( 'manage_options' ) ) return true;
        // Customer owners may read their own claim PNOs via LINE session.
        // For Sprint 23 Phase 3.1 keep strict admin — Phase 3.3 will extend.
        return false;
    }
}

if ( ! function_exists( 'dinoco_claim_flash_rest_create' ) ) {
    function dinoco_claim_flash_rest_create( WP_REST_Request $req ) {
        try {
            $claim_id  = intval( $req->get_param( 'claim_id' ) );
            $direction = strtolower( trim( (string) $req->get_param( 'direction' ) ) );
            $uid       = get_current_user_id();

            if ( $claim_id <= 0 ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'claim_id is required', 'code' => 'bad_claim_id' ), 422 );
            }
            if ( ! in_array( $direction, explode( '|', DINOCO_CLAIM_FLASH_DIRECTIONS ), true ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'invalid_direction', 'code' => 'invalid_direction' ), 422 );
            }

            // Rate limit
            if ( function_exists( 'b2b_rate_limit' ) ) {
                $rl = b2b_rate_limit( 'claim_flash_create', $uid, 20, 3600 );
                if ( is_wp_error( $rl ) ) {
                    return new WP_REST_Response( array( 'success' => false, 'message' => 'rate_limited', 'code' => 'rate_limited' ), 429 );
                }
            }

            $weight_grams = intval( $req->get_param( 'weight_grams' ) );
            $dims = $req->get_param( 'dimensions' );
            $notes = sanitize_text_field( (string) $req->get_param( 'notes' ) );

            // Idempotency — body hash includes actor_user_id + direction
            $idem_key = function_exists( 'dinoco_idempotency_extract_key' )
                ? dinoco_idempotency_extract_key( $req ) : '';
            $idem_namespace = 'dinoco-claim/v1::flash-create';
            $idem_body = array(
                'claim_id'        => $claim_id,
                'direction'       => $direction,
                'weight_grams'    => $weight_grams,
                'actor_user_id'   => $uid,
            );
            if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
                $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
                if ( is_wp_error( $cached ) ) {
                    $err_data = $cached->get_error_data();
                    $status_code = ( is_array( $err_data ) && isset( $err_data['status'] ) ) ? (int) $err_data['status'] : 409;
                    return new WP_REST_Response( array(
                        'success' => false,
                        'message' => 'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                        'code'    => 'idempotency_conflict',
                    ), $status_code );
                }
                if ( is_array( $cached ) ) {
                    $cached_code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 201;
                    unset( $cached['_idem_code'] );
                    return new WP_REST_Response( $cached, $cached_code );
                }
            }

            // GET_LOCK per claim_id
            global $wpdb;
            $lock_name = 'claim_flash_create_' . $claim_id;
            $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
            if ( $got_lock !== 1 ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'locked_by_other_worker', 'code' => 'concurrent_dispatch' ), 423 );
            }

            try {
                // Pre-transition state guard
                $required_state = dinoco_claim_flash_direction_required_state( $direction );
                $current_state = function_exists( 'get_field' ) ? (string) get_field( 'ticket_status', $claim_id ) : '';
                if ( $required_state !== '' && $current_state !== $required_state ) {
                    return new WP_REST_Response( array(
                        'success'        => false,
                        'message'        => 'claim_state_mismatch',
                        'code'           => 'claim_state_mismatch',
                        'expected'       => $required_state,
                        'current'        => $current_state,
                    ), 409 );
                }

                $result = dinoco_claim_create_flash_shipment( $claim_id, array(
                    'direction'    => $direction,
                    'weight_grams' => $weight_grams,
                    'dimensions'   => is_array( $dims ) ? $dims : array(),
                    'notes'        => $notes,
                ) );

                if ( is_wp_error( $result ) ) {
                    $code = $result->get_error_code();
                    $status = ( $code === 'flash_api_failed' ) ? 503 : 422;
                    return new WP_REST_Response( array(
                        'success' => false,
                        'message' => $result->get_error_message(),
                        'code'    => $code,
                        'data'    => $result->get_error_data(),
                    ), $status );
                }

                // Auto FSM transition post-COMMIT
                $target = dinoco_claim_flash_direction_to_status( $direction );
                $claim_status_new = $current_state;
                if ( $target !== '' && function_exists( 'dinoco_set_claim_status' ) ) {
                    $tr = dinoco_set_claim_status( $claim_id, $target, array(
                        'actor'  => 'admin',
                        'source' => 'claim_flash_dispatcher',
                        'note'   => 'PNO=' . $result['pno'] . ' direction=' . $direction,
                    ) );
                    if ( ! is_wp_error( $tr ) ) $claim_status_new = $target;
                }

                $resp = array(
                    'success'           => true,
                    'pno'               => $result['pno'],
                    'sort_code'         => $result['sort_code'],
                    'label_url'         => $result['label_url'],
                    'out_trade_no'      => $result['out_trade_no'],
                    'direction'         => $direction,
                    'claim_status_new'  => $claim_status_new,
                );

                if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_store' ) ) {
                    dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body,
                        array_merge( $resp, array( '_idem_code' => 201 ) ), 201 );
                }

                return new WP_REST_Response( $resp, 201 );
            } finally {
                $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_flash_rest_create_exception', array(
                    'msg' => $e->getMessage(),
                ) );
            }
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error', 'code' => 'internal_error' ), 500 );
        }
    }
}

if ( ! function_exists( 'dinoco_claim_flash_rest_cancel' ) ) {
    function dinoco_claim_flash_rest_cancel( WP_REST_Request $req ) {
        try {
            $pno = sanitize_text_field( (string) $req->get_param( 'pno' ) );
            if ( $pno === '' ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'pno required', 'code' => 'bad_pno' ), 422 );
            }
            $uid = get_current_user_id();

            if ( function_exists( 'b2b_rate_limit' ) ) {
                $rl = b2b_rate_limit( 'claim_flash_cancel', $uid, 10, 3600 );
                if ( is_wp_error( $rl ) ) {
                    return new WP_REST_Response( array( 'success' => false, 'message' => 'rate_limited', 'code' => 'rate_limited' ), 429 );
                }
            }

            // Idempotency
            $idem_key = function_exists( 'dinoco_idempotency_extract_key' )
                ? dinoco_idempotency_extract_key( $req ) : '';
            $idem_namespace = 'dinoco-claim/v1::flash-cancel';
            $idem_body = array(
                'pno'           => $pno,
                'actor_user_id' => $uid,
            );
            if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
                $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
                if ( is_wp_error( $cached ) ) {
                    return new WP_REST_Response( array( 'success' => false, 'message' => 'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน', 'code' => 'idempotency_conflict' ), 409 );
                }
                if ( is_array( $cached ) ) {
                    $cached_code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 200;
                    unset( $cached['_idem_code'] );
                    return new WP_REST_Response( $cached, $cached_code );
                }
            }

            if ( ! function_exists( 'b2b_flash_request' ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'flash_helper_missing', 'code' => 'no_helper' ), 503 );
            }
            $r = b2b_flash_request( 'open/v3/orders/cancel', array( 'pno' => $pno ) );
            $ok = is_array( $r ) && ! empty( $r['ok'] );

            // Update _claim_flash_pnos[] entry
            $claim_id = dinoco_claim_flash_find_claim_by_pno( $pno );
            if ( $claim_id ) {
                dinoco_claim_flash_update_pno_entry( $claim_id, $pno, array(
                    'status'     => $ok ? 'cancelled' : 'cancel_failed',
                    'updated_at' => current_time( 'mysql' ),
                ) );
            }

            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $ok ? 'info' : 'error', 'claim_flash_cancel', array(
                    'pno'      => $pno,
                    'claim_id' => $claim_id,
                    'ok'       => $ok,
                ) );
            }

            $resp = array(
                'success'  => $ok,
                'pno'      => $pno,
                'claim_id' => $claim_id,
                'message'  => $ok ? 'cancelled' : ( $r['error'] ?? 'cancel_failed' ),
            );

            if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_store' ) ) {
                dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body,
                    array_merge( $resp, array( '_idem_code' => $ok ? 200 : 503 ) ), $ok ? 200 : 503 );
            }

            return new WP_REST_Response( $resp, $ok ? 200 : 503 );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_flash_rest_cancel_exception', array( 'msg' => $e->getMessage() ) );
            }
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error', 'code' => 'internal_error' ), 500 );
        }
    }
}

if ( ! function_exists( 'dinoco_claim_flash_rest_status' ) ) {
    function dinoco_claim_flash_rest_status( WP_REST_Request $req ) {
        try {
            $pno = sanitize_text_field( (string) $req->get_param( 'pno' ) );
            if ( $pno === '' ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'pno required', 'code' => 'bad_pno' ), 422 );
            }
            $tier = current_user_can( 'manage_options' ) ? 'admin' : 'owner';
            $cache_key = 'dinoco_claim_flash_status_' . md5( $pno . '|' . $tier );
            $cached = get_transient( $cache_key );
            if ( $cached !== false ) {
                return new WP_REST_Response( $cached, 200 );
            }

            if ( ! function_exists( 'b2b_flash_get_routes' ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'flash_helper_missing', 'code' => 'no_helper' ), 503 );
            }
            $r = b2b_flash_get_routes( $pno );
            if ( empty( $r['ok'] ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => $r['error'] ?? 'lookup_failed', 'code' => 'flash_api_error' ), 503 );
            }
            $data = $r['data'] ?? array();
            $state = isset( $data['state'] ) ? intval( $data['state'] ) : -1;

            $state_label_map = array(
                1 => 'รับพัสดุแล้ว',
                2 => 'ระหว่างการขนส่ง',
                3 => 'ระหว่างการจัดส่ง',
                4 => 'พัสดุคงคลัง',
                5 => 'เซ็นรับแล้ว',
                6 => 'ระหว่างจัดการพัสดุมีปัญหา',
                7 => 'พัสดุตีกลับแล้ว',
                8 => 'ปิดงานมีปัญหา',
                9 => 'เรียกคืนพัสดุแล้ว',
            );
            $resp = array(
                'success'      => true,
                'pno'          => $pno,
                'state'        => $state,
                'state_label'  => $state_label_map[ $state ] ?? '-',
            );
            if ( $tier === 'admin' ) {
                $resp['data'] = $data;
            }
            set_transient( $cache_key, $resp, 60 );
            return new WP_REST_Response( $resp, 200 );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_flash_rest_status_exception', array( 'msg' => $e->getMessage() ) );
            }
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error', 'code' => 'internal_error' ), 500 );
        }
    }
}

