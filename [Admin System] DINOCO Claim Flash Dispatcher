add_action( 'rest_api_init', 'dinoco_claim_flash_register_routes' );

if ( ! function_exists( 'dinoco_claim_flash_register_routes' ) ) {
    function dinoco_claim_flash_register_routes() {
        register_rest_route( 'dinoco-claim/v1', '/flash-create', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_flash_rest_create',
            'permission_callback' => 'dinoco_claim_flash_admin_perm',
        ) );
        register_rest_route( 'dinoco-claim/v1', '/flash-cancel/(?P<pno>[A-Za-z0-9_-]+)', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_flash_rest_cancel',
            'permission_callback' => 'dinoco_claim_flash_admin_perm',
            'args'                => array(
                'pno' => array( 'type' => 'string', 'required' => true ),
            ),
        ) );
        register_rest_route( 'dinoco-claim/v1', '/flash-status/(?P<pno>[A-Za-z0-9_-]+)', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_flash_rest_status',
            'permission_callback' => 'dinoco_claim_flash_read_perm',
            'args'                => array(
                'pno' => array( 'type' => 'string', 'required' => true ),
            ),
        ) );
        // V.0.5 Sprint 28 Phase 3.3 — list shipments for a claim_id.
        // Powers Service Center "Flash Shipments" section list panel.
        // Admin-only (manage_options + wp_rest nonce).
        register_rest_route( 'dinoco-claim/v1', '/flash/list', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_flash_rest_list',
            'permission_callback' => 'dinoco_claim_flash_admin_perm',
            'args'                => array(
                'claim_id' => array( 'type' => 'integer', 'required' => true ),
                'limit'    => array( 'type' => 'integer', 'required' => false, 'default' => 50 ),
            ),
        ) );
        // V.0.6 Sprint 29 Phase 4 Batch B Item 7 — pickup-at-warehouse opt-in
        // path. Skips Flash dispatch entirely; writes postmeta + fires action
        // for Notifier listener to push customer Flex with warehouse address.
        register_rest_route( 'dinoco-claim/v1', '/pickup-at-warehouse', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_flash_rest_pickup_at_warehouse',
            'permission_callback' => 'dinoco_claim_flash_admin_perm',
            'args'                => array(
                'claim_id' => array( 'type' => 'integer', 'required' => true ),
            ),
        ) );

        // V.0.7 Sprint 30 Phase 4 Batch C Item 5 — owner-scoped Flash list for
        // customer LIFF "ประวัติเคลม". Mirror of /flash/list but:
        //   - Permission = is_user_logged_in (handler walks ownership chain).
        //   - Excludes `inbound_pickup` direction (admin-only).
        //   - Strips PII (no recipient_/sender_ fields in response).
        //   - Includes `tracking_url` built from PNO (Flash portal).
        //   - Rate limit 30/min/user.
        register_rest_route( 'dinoco-claim/v1', '/my-flash', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_flash_rest_my_flash',
            'permission_callback' => function() { return is_user_logged_in(); },
            'args'                => array(
                'claim_id' => array( 'type' => 'integer', 'required' => true, 'minimum' => 1 ),
                'limit'    => array( 'type' => 'integer', 'required' => false, 'default' => 50, 'minimum' => 1, 'maximum' => 200 ),
            ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_claim_flash_get_warehouse_info' ) ) {
    /**
     * V.0.6 — read warehouse address from `b2b_warehouse_address` option
     * (set in B2B Admin → Print Settings). Returns canonical shape used
     * by both pickup response + Notifier Flex builder.
     *
     * @return array{name:string,phone:string,address:string,district:string,city:string,province:string,postcode:string}
     */
    function dinoco_claim_flash_get_warehouse_info() {
        $wh = get_option( 'b2b_warehouse_address', array() );
        if ( ! is_array( $wh ) ) $wh = array();
        return array(
            'name'     => isset( $wh['wh_name'] )     ? (string) $wh['wh_name']     : '',
            'phone'    => isset( $wh['wh_phone'] )    ? (string) $wh['wh_phone']    : '',
            'address'  => isset( $wh['wh_address'] )  ? (string) $wh['wh_address']  : '',
            'district' => isset( $wh['wh_district'] ) ? (string) $wh['wh_district'] : '',
            'city'     => isset( $wh['wh_city'] )     ? (string) $wh['wh_city']     : '',
            'province' => isset( $wh['wh_province'] ) ? (string) $wh['wh_province'] : '',
            'postcode' => isset( $wh['wh_postcode'] ) ? (string) $wh['wh_postcode'] : '',
        );
    }
}

if ( ! function_exists( 'dinoco_claim_persist_pickup_at_warehouse' ) ) {
    /**
     * V.0.6 — atomic 3-key postmeta write for pickup-at-warehouse mode.
     * Single function so SC modal + future automation share the same
     * mutation point.
     *
     * @param int $claim_id
     * @param int $actor_user_id
     * @return int pickup_id (mysql timestamp seconds — monotonic, sortable)
     */
    function dinoco_claim_persist_pickup_at_warehouse( $claim_id, $actor_user_id ) {
        $now = current_time( 'mysql' );
        update_post_meta( $claim_id, '_claim_pickup_at_warehouse', 1 );
        update_post_meta( $claim_id, '_claim_pickup_status', 'ready_for_pickup' );
        update_post_meta( $claim_id, '_claim_pickup_created_at', $now );
        if ( $actor_user_id > 0 ) {
            update_post_meta( $claim_id, '_claim_pickup_created_by', (int) $actor_user_id );
        }
        return strtotime( $now );
    }
}

if ( ! function_exists( 'dinoco_claim_flash_rest_pickup_at_warehouse' ) ) {
    /**
     * POST /dinoco-claim/v1/pickup-at-warehouse
     *
     * Body params:
     *   - claim_id (int, required)
     *
     * Returns:
     *   201 + { success:true, pickup_id, warehouse:{...}, claim_id, created_at }
     *   422 on bad claim_id / wrong post type
     *   409 on idempotency conflict
     *
     * @param WP_REST_Request $req
     * @return WP_REST_Response
     */
    function dinoco_claim_flash_rest_pickup_at_warehouse( WP_REST_Request $req ) {
        try {
            $claim_id = (int) $req->get_param( 'claim_id' );
            $uid      = (int) get_current_user_id();

            if ( $claim_id <= 0 || get_post_type( $claim_id ) !== 'claim_ticket' ) {
                return new WP_REST_Response( array(
                    'success' => false,
                    'message' => 'claim_id ไม่ถูกต้อง',
                    'code'    => 'bad_claim_id',
                ), 422 );
            }

            // ─── Idempotency (Round 30+ pattern) ────────────────────────
            $idem_key = function_exists( 'dinoco_idempotency_extract_key' )
                ? dinoco_idempotency_extract_key( $req ) : '';
            $idem_namespace = 'dinoco-claim/v1::pickup-at-warehouse';
            $idem_body = array(
                'claim_id'      => $claim_id,
                'actor_user_id' => $uid,
            );
            if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
                $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
                if ( is_wp_error( $cached ) ) {
                    return new WP_REST_Response( array(
                        'success' => false,
                        'message' => 'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                        'code'    => 'idempotency_conflict',
                    ), 409 );
                }
                if ( is_array( $cached ) ) {
                    $cached_code = isset( $cached['_idem_code'] ) ? (int) $cached['_idem_code'] : 201;
                    unset( $cached['_idem_code'] );
                    return new WP_REST_Response( $cached, $cached_code );
                }
            }

            // ─── Atomic single-helper postmeta write ────────────────────
            $pickup_id = dinoco_claim_persist_pickup_at_warehouse( $claim_id, $uid );

            $warehouse = dinoco_claim_flash_get_warehouse_info();

            $resp = array(
                'success'    => true,
                'pickup_id'  => $pickup_id,
                'claim_id'   => $claim_id,
                'warehouse'  => $warehouse,
                'created_at' => current_time( 'mysql' ),
            );

            // ─── Fire action for Notifier listener ──────────────────────
            try {
                do_action( 'dinoco/claim/pickup_ready', array(
                    'claim_id'      => $claim_id,
                    'pickup_id'     => $pickup_id,
                    'warehouse'     => $warehouse,
                    'actor_user_id' => $uid,
                ) );
            } catch ( \Throwable $hook_e ) {
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( 'warning', 'claim_pickup_ready_hook_threw', array(
                        'claim_id' => $claim_id,
                        'msg'      => $hook_e->getMessage(),
                    ) );
                }
                // Swallow — postmeta already persisted.
            }

            if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_store' ) ) {
                dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body,
                    array_merge( $resp, array( '_idem_code' => 201 ) ), 201 );
            }

            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'info', 'claim_pickup_at_warehouse_persisted', array(
                    'claim_id'  => $claim_id,
                    'pickup_id' => $pickup_id,
                    'uid'       => $uid,
                ) );
            }

            return new WP_REST_Response( $resp, 201 );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_pickup_at_warehouse_exception', array(
                    'msg' => $e->getMessage(),
                ) );
            }
            return new WP_REST_Response( array(
                'success' => false,
                'message' => 'Internal error',
                'code'    => 'internal_error',
            ), 500 );
        }
    }
}

// V.0.5 Sprint 28 Phase 3.3 — GET /dinoco-claim/v1/flash/list?claim_id=X
// Reads `_claim_flash_pnos[]` post meta written by helper at success branch.
// Enriches each entry with print_status from `_claim_flash_print_jobs[]`.
if ( ! function_exists( 'dinoco_claim_flash_rest_list' ) ) {
    function dinoco_claim_flash_rest_list( WP_REST_Request $req ) {
        try {
            $claim_id = intval( $req->get_param( 'claim_id' ) );
            $limit    = max( 1, min( 200, intval( $req->get_param( 'limit' ) ?: 50 ) ) );

            if ( $claim_id <= 0 || get_post_type( $claim_id ) !== 'claim_ticket' ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'bad_claim_id', 'code' => 'bad_claim_id', 'items' => array() ), 422 );
            }

            $pnos = get_post_meta( $claim_id, '_claim_flash_pnos', true );
            if ( ! is_array( $pnos ) ) $pnos = array();

            $print_jobs = get_post_meta( $claim_id, '_claim_flash_print_jobs', true );
            if ( ! is_array( $print_jobs ) ) $print_jobs = array();
            $print_by_pno = array();
            foreach ( $print_jobs as $pj ) {
                if ( is_array( $pj ) && isset( $pj['pno'] ) ) {
                    $print_by_pno[ (string) $pj['pno'] ] = $pj;
                }
            }

            $items = array();
            // Reverse — newest first
            $pnos_rev = array_reverse( $pnos );
            foreach ( $pnos_rev as $entry ) {
                if ( ! is_array( $entry ) ) continue;
                $pno = isset( $entry['pno'] ) ? (string) $entry['pno'] : '';
                if ( $pno === '' ) continue;
                $pj = isset( $print_by_pno[ $pno ] ) ? $print_by_pno[ $pno ] : null;
                $items[] = array(
                    'pno'          => $pno,
                    'direction'    => isset( $entry['direction'] ) ? (string) $entry['direction'] : '',
                    'status'       => isset( $entry['status'] ) ? (string) $entry['status'] : 'created',
                    'flash_state'  => isset( $entry['flash_state'] ) ? intval( $entry['flash_state'] ) : 0,
                    'sort_code'    => isset( $entry['sort_code'] ) ? (string) $entry['sort_code'] : '',
                    'out_trade_no' => isset( $entry['out_trade_no'] ) ? (string) $entry['out_trade_no'] : '',
                    'created_at'   => isset( $entry['created_at'] ) ? (string) $entry['created_at'] : '',
                    'updated_at'   => isset( $entry['updated_at'] ) ? (string) $entry['updated_at'] : '',
                    'print_status' => $pj ? ( isset( $pj['status'] ) ? (string) $pj['status'] : 'queued' ) : '',
                );
                if ( count( $items ) >= $limit ) break;
            }

            return new WP_REST_Response( array(
                'success' => true,
                'claim_id' => $claim_id,
                'items'    => $items,
                'total'    => count( $items ),
            ), 200 );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_flash_rest_list_exception', array( 'msg' => $e->getMessage() ) );
            }
