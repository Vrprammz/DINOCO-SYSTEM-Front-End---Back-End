if ( ! defined( 'DINOCO_CLAIM_FLASH_DIRECTIONS' ) ) {
    define( 'DINOCO_CLAIM_FLASH_DIRECTIONS', 'replacement|repaired_return|inbound_pickup' );
}

if ( ! function_exists( 'dinoco_claim_flash_direction_to_status' ) ) {
    /**
     * Map dispatch direction → claim_ticket target status.
     * Pure function — used by both helper + REST endpoint + tests.
     *
     * @param string $direction one of replacement/repaired_return/inbound_pickup
     * @return string target ticket_status (empty if unknown)
     */
    function dinoco_claim_flash_direction_to_status( $direction ) {
        $map = array(
            'replacement'     => 'Replacement Shipped',
            'repaired_return' => 'Repaired Item Dispatched',
            'inbound_pickup'  => 'In Transit to Company',
        );
        $direction = is_string( $direction ) ? strtolower( trim( $direction ) ) : '';
        return isset( $map[ $direction ] ) ? $map[ $direction ] : '';
    }
}

if ( ! function_exists( 'dinoco_claim_flash_direction_required_state' ) ) {
    /**
     * Map direction → required current claim_ticket state (pre-transition guard).
     * @return string required source state (empty = no guard)
     */
    function dinoco_claim_flash_direction_required_state( $direction ) {
        $map = array(
            'replacement'     => 'Approved',
            'repaired_return' => 'Repairing',
            'inbound_pickup'  => 'Pending Pickup',
        );
        $direction = is_string( $direction ) ? strtolower( trim( $direction ) ) : '';
        return isset( $map[ $direction ] ) ? $map[ $direction ] : '';
    }
}

if ( ! function_exists( 'dinoco_claim_flash_state_to_terminal_status' ) ) {
    /**
     * Map Flash state code → terminal claim_ticket status, given direction context.
     * State 5 = delivered. Terminal map varies per direction.
     * Returns '' for non-terminal / unmapped state.
     *
     * @param int    $flash_state Flash state code (1-9)
     * @param string $direction   stored direction on PNO record
     * @return string target ticket_status (empty = no transition)
     */
    function dinoco_claim_flash_state_to_terminal_status( $flash_state, $direction ) {
        $flash_state = intval( $flash_state );
        $direction   = is_string( $direction ) ? strtolower( trim( $direction ) ) : '';
        if ( $flash_state !== 5 ) return '';
        $delivered_map = array(
            'replacement'     => 'Replacement Shipped',
            'repaired_return' => 'Maintenance Completed',
            'inbound_pickup'  => 'In Repair Queue',
        );
        return isset( $delivered_map[ $direction ] ) ? $delivered_map[ $direction ] : '';
    }
}

// ──────────────────────────────────────────────────────────────────
// Internal helper: dinoco_claim_create_flash_shipment()
// ──────────────────────────────────────────────────────────────────

if ( ! function_exists( 'dinoco_claim_create_flash_shipment' ) ) {
    /**
     * Create Flash Express shipment for a claim_ticket.
     *
     * Reads ACF snap_group address; resolves sender from option
     * b2b_warehouse_address. Returns address (legal entity) from
     * b2b_registered_address. HMAC signs via b2b_flash_sign().
     * G2 1003 (duplicate outTradeNo) recovery — query Flash via
     * b2b_flash_get_order_by_mch_pno then retry with suffix.
     *
     * @param int   $claim_id claim_ticket post ID
     * @param array $params   { direction, weight_grams?, dimensions?, notes?, articleCategory? }
     * @return array|WP_Error  success → { pno, sort_code, label_url, out_trade_no }
     */
    function dinoco_claim_create_flash_shipment( $claim_id, array $params ) {
        $claim_id = intval( $claim_id );
        if ( $claim_id <= 0 ) {
            return new WP_Error( 'bad_claim_id', 'Invalid claim_id' );
        }
        if ( get_post_type( $claim_id ) !== 'claim_ticket' ) {
            return new WP_Error( 'not_claim_ticket', 'Post is not a claim_ticket' );
        }

        $direction = isset( $params['direction'] ) ? strtolower( trim( (string) $params['direction'] ) ) : '';
        if ( ! in_array( $direction, explode( '|', DINOCO_CLAIM_FLASH_DIRECTIONS ), true ) ) {
            return new WP_Error( 'invalid_direction', 'Direction must be one of: ' . DINOCO_CLAIM_FLASH_DIRECTIONS );
        }

        $weight_g = intval( $params['weight_grams'] ?? 500 );
        if ( $weight_g <= 0 ) $weight_g = 500;
        $dims = isset( $params['dimensions'] ) && is_array( $params['dimensions'] ) ? $params['dimensions'] : array();
        $L = intval( $dims['length_cm'] ?? 0 );
        $W = intval( $dims['width_cm']  ?? 0 );
        $H = intval( $dims['height_cm'] ?? 0 );
        $notes = isset( $params['notes'] ) ? sanitize_text_field( (string) $params['notes'] ) : '';
        $article_category = intval( $params['articleCategory'] ?? 99 ) ?: 99; // 99 = generic / claim shipment

        // Pull customer address from snap_group ACF (Service Center pattern)
        $snap = function_exists( 'get_field' ) ? get_field( 'snap_group', $claim_id ) : null;
        $cust_name  = '';
        $cust_phone = '';
        $cust_addr  = '';
        $cust_district = '';
        $cust_city  = '';
        $cust_province = '';
        $cust_postcode = '';
        if ( is_array( $snap ) ) {
            $cust_name     = (string) ( ! empty( $snap['name'] ) ? $snap['name'] : ( $snap['snapshot_name'] ?? '' ) );
            $cust_phone    = (string) ( $snap['snapshot_phone_number'] ?? '' );
            $addr_parts    = array();
            if ( ! empty( $snap['snapshot_addr_house_no'] ) ) $addr_parts[] = (string) $snap['snapshot_addr_house_no'];
            if ( ! empty( $snap['snapshot_addr_soi'] ) )      $addr_parts[] = 'ซ.' . (string) $snap['snapshot_addr_soi'];
            $cust_addr     = trim( implode( ' ', $addr_parts ) );
            $cust_district = (string) ( $snap['snapshot_addr_subdistrict'] ?? '' );
            $cust_city     = (string) ( $snap['snapshot_addr_district']    ?? '' );
            $cust_province = (string) ( $snap['snapshot_addr_province']    ?? '' );
            $cust_postcode = (string) ( $snap['snapshot_addr_zip']         ?? '' );
        }

        $wh  = get_option( 'b2b_warehouse_address',  array() );
        $reg = get_option( 'b2b_registered_address', array() );

        // outTradeNo: CLM-FLASH-{claim_id}-{rand4}. rand4 = 4-char Crockford-ish.
        $rand4 = strtoupper( wp_generate_password( 4, false, false ) );
        $out_trade_no = 'CLM-FLASH-' . $claim_id . '-' . $rand4;

        // Direction routing for src/dst
        if ( $direction === 'inbound_pickup' ) {
            // customer → DINOCO warehouse
            $src_name      = $cust_name;
            $src_phone     = $cust_phone;
            $src_address   = $cust_addr;
            $src_district  = $cust_district;
            $src_city      = $cust_city;
            $src_province  = $cust_province;
            $src_postcode  = $cust_postcode;
            $dst_name      = ! empty( $wh['wh_name'] )     ? (string) $wh['wh_name']     : 'DINOCO THAILAND';
            $dst_phone     = ! empty( $wh['wh_phone'] )    ? (string) $wh['wh_phone']    : '';
            $dst_address   = ! empty( $wh['wh_address'] )  ? (string) $wh['wh_address']  : '';
            $dst_district  = ! empty( $wh['wh_district'] ) ? (string) $wh['wh_district'] : '';
            $dst_city      = ! empty( $wh['wh_city'] )     ? (string) $wh['wh_city']     : '';
            $dst_province  = ! empty( $wh['wh_province'] ) ? (string) $wh['wh_province'] : '';
            $dst_postcode  = ! empty( $wh['wh_postcode'] ) ? (string) $wh['wh_postcode'] : '';
        } else {
            // replacement OR repaired_return: DINOCO warehouse → customer
            $src_name      = ! empty( $wh['wh_name'] )     ? (string) $wh['wh_name']     : 'DINOCO THAILAND';
            $src_phone     = ! empty( $wh['wh_phone'] )    ? (string) $wh['wh_phone']    : '';
            $src_address   = ! empty( $wh['wh_address'] )  ? (string) $wh['wh_address']  : '';
            $src_district  = ! empty( $wh['wh_district'] ) ? (string) $wh['wh_district'] : '';
            $src_city      = ! empty( $wh['wh_city'] )     ? (string) $wh['wh_city']     : '';
            $src_province  = ! empty( $wh['wh_province'] ) ? (string) $wh['wh_province'] : '';
            $src_postcode  = ! empty( $wh['wh_postcode'] ) ? (string) $wh['wh_postcode'] : '';
            $dst_name      = $cust_name;
            $dst_phone     = $cust_phone;
            $dst_address   = $cust_addr;
            $dst_district  = $cust_district;
            $dst_city      = $cust_city;
            $dst_province  = $cust_province;
            $dst_postcode  = $cust_postcode;
        }

        // Validate destination — required for Flash API
        $missing = array();
        if ( $dst_name === '' )     $missing[] = 'dst_name';
        if ( $dst_phone === '' )    $missing[] = 'dst_phone';
        if ( $dst_address === '' )  $missing[] = 'dst_address';
        if ( $dst_province === '' ) $missing[] = 'dst_province';
        if ( $dst_city === '' )     $missing[] = 'dst_city';
        if ( $dst_postcode === '' ) $missing[] = 'dst_postcode';
        if ( ! empty( $missing ) ) {
            return new WP_Error( 'missing_address', 'Missing fields: ' . implode( ',', $missing ), array( 'fields' => $missing, 'direction' => $direction ) );
        }

        $params_api = array(
            'outTradeNo'       => $out_trade_no,
            'expressCategory'  => 1, // standard parcel for claim
            'articleCategory'  => $article_category,
            'srcName'          => $src_name,
            'srcPhone'         => $src_phone,
            'srcDetailAddress' => $src_address,
            'srcDistrictName'  => $src_district,
            'srcCityName'      => $src_city,
            'srcProvinceName'  => $src_province,
            'srcPostalCode'    => $src_postcode,
            'dstName'          => $dst_name,
            'dstPhone'         => $dst_phone,
            'dstDetailAddress' => $dst_address,
            'dstDistrictName'  => $dst_district,
            'dstCityName'      => $dst_city,
            'dstProvinceName'  => $dst_province,
            'dstPostalCode'    => $dst_postcode,
            'weight'           => $weight_g,
            'insured'          => 0,
            'codEnabled'       => 0,
            'remark'           => 'Claim#' . $claim_id . ( $notes !== '' ? ' ' . mb_substr( $notes, 0, 80 ) : '' ),
        );
        if ( $L > 0 ) $params_api['length'] = $L;
        if ( $W > 0 ) $params_api['width']  = $W;
        if ( $H > 0 ) $params_api['height'] = $H;

        // returnXXX — registered address (legal entity returns)
        if ( ! empty( $reg ) && is_array( $reg ) ) {
            $params_api['returnName']          = ! empty( $reg['reg_name'] )     ? (string) $reg['reg_name']     : $src_name;
            $params_api['returnPhone']         = ! empty( $reg['reg_phone'] )    ? (string) $reg['reg_phone']    : $src_phone;
            $params_api['returnDetailAddress'] = ! empty( $reg['reg_address'] )  ? (string) $reg['reg_address']  : '';
            $params_api['returnDistrictName']  = ! empty( $reg['reg_district'] ) ? (string) $reg['reg_district'] : '';
            $params_api['returnCityName']      = ! empty( $reg['reg_city'] )     ? (string) $reg['reg_city']     : '';
            $params_api['returnProvinceName']  = ! empty( $reg['reg_province'] ) ? (string) $reg['reg_province'] : '';
            $params_api['returnPostalCode']    = ! empty( $reg['reg_postcode'] ) ? (string) $reg['reg_postcode'] : '';
        }

        global $wpdb;
        $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
        $audit_supported = (bool) $wpdb->get_var( "SHOW TABLES LIKE '{$audit_tbl}'" );

        // Flash API request with G2 1003 recovery
        $attempt = 0;
        $base_otn = $out_trade_no;
        $execute = function() use ( &$params_api, &$attempt, $base_otn ) {
            $attempt++;
            if ( ! function_exists( 'b2b_flash_request' ) ) {
                return array( 'ok' => false, 'error' => 'flash_helper_missing', 'error_code' => 'no_helper' );
            }
            $r = b2b_flash_request( 'open/v3/orders', $params_api );
            if ( is_array( $r ) && ! empty( $r['ok'] ) && ! empty( $r['data']['pno'] ) ) return $r;
            // G2 1003 recovery
            $code = '';
            if ( is_array( $r ) ) {
                if ( isset( $r['code'] ) )            $code = (string) $r['code'];
                elseif ( isset( $r['status_code'] ) ) $code = (string) $r['status_code'];
            }
            if ( $code === '1003' && function_exists( 'b2b_flash_get_order_by_mch_pno' ) ) {
                $lookup = b2b_flash_get_order_by_mch_pno( $params_api['outTradeNo'] );
                if ( is_array( $lookup ) && ! empty( $lookup['ok'] ) && ! empty( $lookup['data']['pno'] ) ) {
                    return $lookup;
                }
                // Regenerate suffix
                $params_api['outTradeNo'] = $base_otn . '-r' . $attempt;
            }
            if ( is_array( $r ) ) $r['error_code'] = $code;
            return $r;
        };

        $result = function_exists( 'dinoco_api_retry' )
            ? dinoco_api_retry( $execute, 3, array( 1, 2, 5 ) )
            : $execute();

        $is_ok = is_array( $result ) && ! empty( $result['ok'] ) && ! empty( $result['data']['pno'] );

        // Audit row — PII masked
        if ( $audit_supported ) {
            $masked_req = function_exists( 'b2b_flash_mask_request_for_dlq' )
                ? b2b_flash_mask_request_for_dlq( $params_api )
                : array_intersect_key( $params_api, array_flip( array( 'outTradeNo', 'expressCategory', 'articleCategory', 'weight' ) ) );
            $masked_req['claim_id']  = $claim_id;
            $masked_req['direction'] = $direction;
            $masked_req['attempts']  = $attempt;
            $wpdb->insert( $audit_tbl, array(
                'ticket_id'        => 0, // claim_id stored in request_summary; ticket_id reserved for b2b orders
                'event_type'       => $is_ok ? 'claim_flash_create' : 'claim_flash_create_fail',
                'expected_ec'      => 1,
                'actual_ec'        => 1,
                'request_summary'  => wp_json_encode( $masked_req ),
                'response_summary' => wp_json_encode( is_array( $result ) ? array_slice( $result, 0, 5, true ) : array() ),
                'user_id'          => get_current_user_id(),
                'created_at'       => current_time( 'mysql' ),
            ) );
        }

        if ( $is_ok ) {
            $pno = (string) $result['data']['pno'];
            $sort_code = isset( $result['data']['sortCode'] ) ? (string) $result['data']['sortCode'] : '';
            $label_url = isset( $result['data']['labelUrl'] )  ? (string) $result['data']['labelUrl']  : '';

            // Append to _claim_flash_pnos[]
            $pnos = get_post_meta( $claim_id, '_claim_flash_pnos', true );
            if ( ! is_array( $pnos ) ) $pnos = array();
            $pnos[] = array(
                'pno'        => $pno,
                'direction'  => $direction,
                'status'     => 'created',
                'flash_state' => 0,
                'out_trade_no' => $params_api['outTradeNo'],
                'sort_code'  => $sort_code,
                'created_at' => current_time( 'mysql' ),
                'updated_at' => current_time( 'mysql' ),
            );
            update_post_meta( $claim_id, '_claim_flash_pnos', $pnos );

            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'info', 'claim_flash_create_ok', array(
                    'claim_id'  => $claim_id,
                    'direction' => $direction,
                    'pno'       => $pno,
                    'attempts'  => $attempt,
                ) );
            }
            return array(
                'ok'           => true,
                'pno'          => $pno,
                'sort_code'    => $sort_code,
                'label_url'    => $label_url,
                'out_trade_no' => $params_api['outTradeNo'],
                'direction'    => $direction,
            );
        }

        $err = is_array( $result ) ? ( isset( $result['error'] ) ? (string) $result['error'] : 'unknown' ) : 'unknown';
        $err_code = is_array( $result ) ? ( isset( $result['error_code'] ) ? (string) $result['error_code'] : '' ) : '';
        if ( function_exists( 'dinoco_obs_capture' ) ) {
            dinoco_obs_capture( 'error', 'claim_flash_create_fail', array(
                'claim_id'   => $claim_id,
                'direction'  => $direction,
                'error'      => $err,
                'error_code' => $err_code,
                'attempts'   => $attempt,
            ) );
        }
        return new WP_Error( 'flash_api_failed', $err, array( 'error_code' => $err_code, 'attempts' => $attempt ) );
    }
}

