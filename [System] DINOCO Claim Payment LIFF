/**
 * Shared wrapper: rate limit + idempotency + transition.
 *
 * @param string $rl_key_prefix  rate-limit bucket id
 * @param string $idem_namespace short idempotency namespace
 * @param int    $charge_id
 * @param string $to_state
 * @param string $actor
 * @param array  $context
 * @param int    $max_per_hour
 * @return array|WP_Error
 */
if ( ! function_exists( 'dinoco_claim_payment_wrapped_transition' ) ) {
    function dinoco_claim_payment_wrapped_transition( $rl_key_prefix, $idem_namespace, $charge_id, $to_state, $actor, $context, $max_per_hour = 30 ) {
        // Rate limit per user
        $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( $rl_key_prefix . '_' . $uid, $max_per_hour, 3600 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        // V.0.6 Sprint 14 H1 fix — idempotency body hash MUST include `from_state`
        // (and `discriminator` if caller supplied) so identical (charge_id,
        // to_state, actor_user_id) triples at different lifecycle moments
        // produce distinct hashes. Without from_state: customer upload-slip
        // (pending_payment→pending_review) and customer re-upload after admin
        // rejected slip (rejected→pending_review) hash identically → cached
        // replay returns stale prior result without firing FSM transition.
        // We probe from_state via SELECT (cheap — single int read).
        $from_state = '';
        if ( function_exists( 'dinoco_claim_charges_table_name' ) ) {
            global $wpdb;
            $table = dinoco_claim_charges_table_name();
            $from_state = (string) $wpdb->get_var( $wpdb->prepare(
                "SELECT status FROM {$table} WHERE id = %d", (int) $charge_id
            ) );
        }
        $body = array(
            'charge_id'     => (int) $charge_id,
            'from_state'    => $from_state,
            'to_state'      => (string) $to_state,
            'actor_user_id' => $uid,
        );
        // Caller may pass a `discriminator` (e.g. slip_sha256 for upload, or
        // refund_amount_cents for refund) inside $context — copy it into hash
        // body so binary-fingerprint pattern (R42) survives at this layer.
        if ( isset( $context['idem_discriminator'] ) && $context['idem_discriminator'] !== '' ) {
            $body['discriminator'] = (string) $context['idem_discriminator'];
        }
        $idem_key = '';
        if ( function_exists( 'dinoco_idempotency_hash' ) && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_key = $idem_namespace . ':' . dinoco_idempotency_hash( $body );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( $cached ) return $cached;
        }

        $context['actor_user_id'] = $uid;
        $result = dinoco_claim_charge_transition( (int) $charge_id, (string) $to_state, (string) $actor, (array) $context );
        if ( is_wp_error( $result ) ) return $result;

        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $body, $result, 200 );
        }
        return $result;
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_upload_slip' ) ) {
    function dinoco_claim_payment_rest_upload_slip( $req ) {
        $chid = (int) $req->get_param( 'id' );

        // V.0.6 Sprint 14 H3 fix — rate-limit the ownership LOOKUP path itself
        // BEFORE any SELECT. Without this, an attacker iterating charge_id=1..N
        // gets a free per-ID DB probe (only the post-ownership transition path
        // was rate-limited). Per-user lookup cap = 100/hr (separate bucket
        // from claim_charge_upload). Returns 404 on ownership mismatch (not
        // 403) so attacker cannot distinguish "charge does not exist" from
        // "charge exists but not yours" — closes timing+code enumeration oracle.
        $cuid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'claim_charge_lookup_' . $cuid, 100, 3600 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        // Ownership check — customer can only upload their OWN slip
        global $wpdb;
        if ( function_exists( 'dinoco_claim_charges_table_name' ) ) {
            $table = dinoco_claim_charges_table_name();
            $owner = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT user_id FROM {$table} WHERE id = %d", $chid
            ) );
            if ( $owner === 0 || $owner !== $cuid ) {
                // 404 (not 403) — anti-enumeration: mask existence (R3 HIGH-5 pattern)
                return new WP_Error(
                    'charge_not_found',
                    'ไม่พบใบเรียกเก็บนี้',
                    array( 'status' => 404 )
                );
            }
        }

        // V.0.8 Sprint 20 — actually accept and store the slip image file.
        // multipart upload via $_FILES['slip_image'] (REST forwards via
        // get_file_params()). Validate mime + size + compute sha256. Store
        // to protected dir + UPDATE row pre-transition. Async Slip2Go verify
        // scheduled post-COMMIT.
        $files     = $req->get_file_params();
        $slip_file = isset( $files['slip_image'] ) ? $files['slip_image'] : null;

        $stored_url      = '';
        $slip_sha256     = '';
        $stored_relative = '';

        if ( $slip_file && is_array( $slip_file ) && ! empty( $slip_file['tmp_name'] ) ) {
            // File validation
            $allowed_mimes = array( 'image/jpeg', 'image/png' );
            $max_bytes     = 5 * 1024 * 1024;

            $size = isset( $slip_file['size'] ) ? (int) $slip_file['size'] : 0;
            if ( $size <= 0 || $size > $max_bytes ) {
                return new WP_Error( 'file_too_large', 'ไฟล์ใหญ่เกิน 5MB หรือว่าง', array( 'status' => 422 ) );
            }

            // Verify mime via finfo (extension is spoofable)
            $detected_mime = '';
            if ( function_exists( 'finfo_open' ) ) {
                $fi = finfo_open( FILEINFO_MIME_TYPE );
                if ( $fi ) {
                    $detected_mime = (string) finfo_file( $fi, $slip_file['tmp_name'] );
                    finfo_close( $fi );
                }
            }
            if ( $detected_mime === '' ) {
                $detected_mime = isset( $slip_file['type'] ) ? (string) $slip_file['type'] : '';
            }
            if ( ! in_array( $detected_mime, $allowed_mimes, true ) ) {
                return new WP_Error( 'invalid_mime', 'รองรับเฉพาะรูป JPG/PNG', array( 'status' => 422 ) );
            }

            // Compute sha256 of file content (slip_ref_hash + idem_discriminator)
            $slip_sha256 = (string) hash_file( 'sha256', $slip_file['tmp_name'] );
            if ( $slip_sha256 === '' ) {
                return new WP_Error( 'hash_failed', 'ไม่สามารถประมวลผลไฟล์ได้', array( 'status' => 500 ) );
            }

            // Protected dir: wp-content/uploads/dinoco-claim-slips/{YYYY-MM}/
            $uploads_base = wp_upload_dir();
            if ( empty( $uploads_base['basedir'] ) ) {
                return new WP_Error( 'uploads_unavailable', 'Uploads dir unavailable', array( 'status' => 500 ) );
            }
            $sub_month  = wp_date( 'Y-m' );
            $target_dir = trailingslashit( $uploads_base['basedir'] ) . 'dinoco-claim-slips/' . $sub_month;
            if ( ! file_exists( $target_dir ) ) {
                wp_mkdir_p( $target_dir );
                @chmod( $target_dir, 0750 );
            }
            // .htaccess deny direct (defense-in-depth — REST proxy is the
            // canonical read path; closes MED-3 direct-URL bypass)
            $htaccess = trailingslashit( $uploads_base['basedir'] ) . 'dinoco-claim-slips/.htaccess';
            if ( ! file_exists( $htaccess ) ) {
                @file_put_contents( $htaccess, "Order deny,allow\nDeny from all\n" );
            }

            // Pre-check uniqueness (defense before atomic UPDATE — UNIQUE
            // constraint still authoritative; this is fast-fail with a
            // user-friendly message before file I/O).
            if ( function_exists( 'dinoco_claim_charges_table_name' ) ) {
                $table = dinoco_claim_charges_table_name();
                $dup   = (int) $wpdb->get_var( $wpdb->prepare(
                    "SELECT COUNT(*) FROM {$table} WHERE slip_ref_hash = %s AND id != %d",
                    $slip_sha256, $chid
                ) );
                if ( $dup > 0 ) {
                    return new WP_Error(
                        'slip_replay_detected',
                        'สลิปนี้ถูกใช้งานไปแล้ว — กรุณาส่งสลิปใหม่',
                        array( 'status' => 409 )
                    );
                }
            }

            // Build filename — sha256 first 8 chars + 4 random hex (no PII)
            $ext      = ( $detected_mime === 'image/png' ) ? 'png' : 'jpg';
            $filename = substr( $slip_sha256, 0, 8 ) . '_' . wp_generate_password( 4, false, false ) . '.' . $ext;
            $abs_path = trailingslashit( $target_dir ) . $filename;
            $moved    = @move_uploaded_file( $slip_file['tmp_name'], $abs_path );
            if ( ! $moved ) {
                // PHP CLI / unit-test fallback (move_uploaded_file requires
                // is_uploaded_file() true which only holds on real POST)
                if ( defined( 'WP_CLI' ) || defined( 'PHPUNIT_RUNNING' ) ) {
                    @copy( $slip_file['tmp_name'], $abs_path );
                    $moved = file_exists( $abs_path );
                }
            }
            if ( ! $moved ) {
                return new WP_Error( 'upload_failed', 'อัปโหลดไม่สำเร็จ — ลองใหม่อีกครั้ง', array( 'status' => 500 ) );
            }
            @chmod( $abs_path, 0640 );

            $stored_relative = 'dinoco-claim-slips/' . $sub_month . '/' . $filename;
            $stored_url      = trailingslashit( $uploads_base['baseurl'] ) . $stored_relative;

            // Pre-write slip_image_url + slip_ref_hash BEFORE FSM transition so
            // UPDATE inside transition() can rely on hash uniqueness. UNIQUE
            // constraint will atomically reject race-replays.
            if ( function_exists( 'dinoco_claim_charges_table_name' ) ) {
                $tbl    = dinoco_claim_charges_table_name();
                $upd    = $wpdb->update(
                    $tbl,
                    array(
                        'slip_image_url' => $stored_url,
                        'slip_ref_hash'  => $slip_sha256,
                    ),
                    array( 'id' => $chid ),
                    array( '%s', '%s' ),
                    array( '%d' )
                );
                if ( $upd === false ) {
                    @unlink( $abs_path );
                    // Detect UNIQUE constraint violation by reading last_error.
                    $err = (string) $wpdb->last_error;
                    if ( stripos( $err, 'duplicate' ) !== false || stripos( $err, 'uq_slip_replay_claim' ) !== false ) {
                        return new WP_Error( 'slip_replay_detected',
                            'สลิปนี้ถูกใช้งานไปแล้ว', array( 'status' => 409 ) );
                    }
                    return new WP_Error( 'db_update_failed',
                        'บันทึกลงฐานข้อมูลล้มเหลว', array( 'status' => 500 ) );
                }
            }
        }

        // V.0.6 Sprint 14 H1 — idem_discriminator = sha256 so retry of SAME
        // slip dedup but DIFFERENT slip gets distinct hash (R42 binary-
        // fingerprint pattern).
        $result = dinoco_claim_payment_wrapped_transition(
            'claim_charge_upload', 'claim-charge-upload',
            $chid, 'pending_review', 'customer',
            array(
                'verify_method'      => 'slip2go_pending',
                'idem_discriminator' => $slip_sha256,
                'slip_image_url'     => $stored_url,
                'slip_ref_hash'      => $slip_sha256,
            ),
            10  // 10/hr per customer
        );

        // Schedule async Slip2Go verify post-transition success.
        if ( ! is_wp_error( $result ) && $slip_sha256 !== '' ) {
            if ( function_exists( 'wp_schedule_single_event' ) ) {
                // 5s delay so transition COMMIT propagates to replicas before
                // the async worker SELECTs the row.
                wp_schedule_single_event( time() + 5, 'dinoco_claim_payment_slip_verify_async', array( (int) $chid ) );
            }
        }

        return $result;
    }
}

