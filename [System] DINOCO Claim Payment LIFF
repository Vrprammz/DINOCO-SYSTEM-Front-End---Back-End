    function renderEmpty(target, msg){
        target.innerHTML = '<div class="dnc-claim-hist-empty">' + escHtml(msg) + '</div>';
    }

    function renderError(target, msg, retryAction){
        var html = '<div class="dnc-claim-hist-error" role="alert">' + escHtml(msg) + '<br>'
            + '<button type="button" class="dnc-claim-hist-error-retry" data-action="' + escHtml(retryAction) + '">🔄 ลองอีกครั้ง</button>'
            + '</div>';
        target.innerHTML = html;
    }

    function loadCharges(){
        var target = document.getElementById('dnc-claim-hist-charges-body');
        if (!target) return;
        target.innerHTML = '<div class="dnc-claim-hist-skel"></div><div class="dnc-claim-hist-skel"></div>';
        fetch(REST_CHARGES, { credentials: 'same-origin', headers: { 'X-WP-Nonce': NONCE } })
            .then(function(r){
                var ct = r.headers.get('content-type') || '';
                if (!r.ok) {
                    if (r.status === 404) { renderEmpty(target, 'ยังไม่มีรายการ'); return; }
                    if (r.status === 401 || r.status === 403) { renderError(target, 'กรุณาเข้าสู่ระบบ LINE เพื่อดูประวัติเคลม', 'retry-charges'); return; }
                    if (ct.indexOf('application/json') === 0) {
                        return r.json().then(function(d){
                            renderError(target, (d && d.message) || ('โหลดข้อมูลล้มเหลว (HTTP ' + r.status + ')'), 'retry-charges');
                        });
                    }
                    renderError(target, 'โหลดข้อมูลล้มเหลว (HTTP ' + r.status + ')', 'retry-charges');
                    return;
                }
                return r.json().then(function(d){
                    var items = (d && d.items) || [];
                    if (!items.length) { renderEmpty(target, 'ยังไม่มีรายการ'); return; }
                    var html = '';
                    for (var i = 0; i < items.length; i++) html += buildChargeRow(items[i]);
                    target.innerHTML = html;
                });
            })
            .catch(function(){ renderError(target, 'เครือข่ายขัดข้อง — กรุณาลองใหม่', 'retry-charges'); });
    }

    function loadFlash(){
        var target = document.getElementById('dnc-claim-hist-flash-body');
        if (!target) return;
        target.innerHTML = '<div class="dnc-claim-hist-skel"></div><div class="dnc-claim-hist-skel"></div>';
        fetch(REST_FLASH, { credentials: 'same-origin', headers: { 'X-WP-Nonce': NONCE } })
            .then(function(r){
                var ct = r.headers.get('content-type') || '';
                if (!r.ok) {
                    if (r.status === 404) { renderEmpty(target, 'ยังไม่มีรายการ'); return; }
                    if (r.status === 401 || r.status === 403) { renderError(target, 'กรุณาเข้าสู่ระบบ LINE เพื่อดูประวัติพัสดุ', 'retry-flash'); return; }
                    if (ct.indexOf('application/json') === 0) {
                        return r.json().then(function(d){
                            renderError(target, (d && d.message) || ('โหลดข้อมูลล้มเหลว (HTTP ' + r.status + ')'), 'retry-flash');
                        });
                    }
                    renderError(target, 'โหลดข้อมูลล้มเหลว (HTTP ' + r.status + ')', 'retry-flash');
                    return;
                }
                return r.json().then(function(d){
                    var items = (d && d.items) || [];
                    if (!items.length) { renderEmpty(target, 'ยังไม่มีรายการ'); return; }
                    var html = '';
                    for (var i = 0; i < items.length; i++) html += buildFlashRow(items[i]);
                    target.innerHTML = html;
                });
            })
            .catch(function(){ renderError(target, 'เครือข่ายขัดข้อง — กรุณาลองใหม่', 'retry-flash'); });
    }

    // ── Event delegation (UX-H3 strict — NO inline handlers) ─────────────
    app.addEventListener('click', function(ev){
        var t = ev.target;
        while (t && t !== app && !t.getAttribute('data-action')) t = t.parentNode;
        if (!t || t === app) return;
        var action = t.getAttribute('data-action');

        if (action === 'close') { window.history.length > 1 ? window.history.back() : window.close(); return; }
        if (action === 'back')  { if (window.history.length > 1) window.history.back(); else window.location.href = '/member-dashboard/'; return; }
        if (action === 'toggle-row') {
            var row = t.closest ? t.closest('.dnc-claim-hist-row') : null;
            if (!row) {
                // Fallback closest() polyfill for old browsers
                var p = t.parentNode;
                while (p && p.className && p.className.indexOf('dnc-claim-hist-row') === -1) p = p.parentNode;
                row = p;
            }
            if (!row) return;
            var cur = row.getAttribute('data-expanded') === '1';
            row.setAttribute('data-expanded', cur ? '0' : '1');
            t.setAttribute('aria-expanded', cur ? 'false' : 'true');
            return;
        }
        if (action === 'retry-charges') { loadCharges(); return; }
        if (action === 'retry-flash')   { loadFlash();   return; }
    });

    // Initial load — only if logged in
    if (<?php echo $logged_in ? 'true' : 'false'; ?>) {
        loadCharges();
        loadFlash();
    }
})();
</script>
