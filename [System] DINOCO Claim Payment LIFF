/* ═══════════════════════════════════════════════════════════════════════════
 * 1. FSM HELPER (pure logic — unit-testable, no WP/DB side effects)
 *
 *    Schema is authoritative (per orchestrator B1 binding). 7 states + 11
 *    transitions. Spec aliases mapped:
 *      spec `slip_uploaded`   → schema `pending_review`
 *      spec `verify_rejected` → schema `rejected`
 *      spec `completed`       → DROPPED (verified is success terminal)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! defined( 'DINOCO_CLAIM_CHARGE_FSM_TABLE' ) ) {
    /**
     * Transition matrix. Format: "from->to:actor[|actor]" pipe-separated for
     * actors (so the rule-level comma separator is unambiguous), rules
     * comma-separated. Encoded as constant string so PHPUnit fixtures can pin
     * determinism without depending on PHP < 7 array-constant restrictions.
     */
    define( 'DINOCO_CLAIM_CHARGE_FSM_TABLE',
        'pending_payment->pending_review:customer,' .
        'pending_payment->expired:system,' .
        'pending_payment->cancelled:admin,' .
        'pending_review->verified:system|admin,' .
        'pending_review->rejected:system|admin,' .
        'pending_review->pending_payment:admin,' .
        'pending_review->cancelled:admin,' .
        'verified->refunded:admin,' .
        'rejected->pending_review:customer,' .
        'expired->pending_payment:admin,' .
        'pending_payment->verified:system|admin'  // legacy fast-path (admin manual verify pre-slip, rare)
    );
}

if ( ! function_exists( 'dinoco_claim_charge_fsm_allowed' ) ) {
    /**
     * Determine if a transition (from → to) is allowed for an actor.
     *
     * @param string $from   schema state (one of DINOCO_CLAIM_CHARGES_STATUS_WHITELIST)
     * @param string $to     schema state
     * @param string $actor  one of {customer, admin, system}
     * @return array{allowed:bool, reason:string}
     */
    function dinoco_claim_charge_fsm_allowed( $from, $to, $actor ) {
        $from  = trim( (string) $from );
        $to    = trim( (string) $to );
        $actor = trim( (string) $actor );

        // Schema parity check — verify both states present in whitelist
        // constant. If drift detected, fail loud (per orchestrator B1 binding).
        if ( defined( 'DINOCO_CLAIM_CHARGES_STATUS_WHITELIST' ) ) {
            $whitelist = explode( ',', DINOCO_CLAIM_CHARGES_STATUS_WHITELIST );
            if ( $from !== '' && ! in_array( $from, $whitelist, true ) ) {
                return array( 'allowed' => false, 'reason' => 'invalid_from_state:' . $from );
            }
            if ( ! in_array( $to, $whitelist, true ) ) {
                return array( 'allowed' => false, 'reason' => 'invalid_to_state:' . $to );
            }
        }

        if ( $from === $to ) {
            return array( 'allowed' => false, 'reason' => 'terminal_state' );
        }

        // Decode table once (static cache). Rules comma-separated, actors
        // pipe-separated (so commas inside actor lists never collide with the
        // rule-level split).
        static $matrix = null;
        if ( $matrix === null ) {
            $matrix = array();
            foreach ( explode( ',', DINOCO_CLAIM_CHARGE_FSM_TABLE ) as $rule ) {
                if ( strpos( $rule, '->' ) === false || strpos( $rule, ':' ) === false ) continue;
                list( $fromto, $actors ) = explode( ':', $rule, 2 );
                list( $rf, $rt )         = explode( '->', $fromto, 2 );
                $key = trim( $rf ) . '->' . trim( $rt );
                if ( ! isset( $matrix[ $key ] ) ) $matrix[ $key ] = array();
                $matrix[ $key ] = array_merge( $matrix[ $key ], array_map( 'trim', explode( '|', $actors ) ) );
            }
        }

        $key = $from . '->' . $to;
        if ( ! isset( $matrix[ $key ] ) ) {
            return array( 'allowed' => false, 'reason' => 'transition_not_in_matrix' );
        }
        if ( ! in_array( $actor, $matrix[ $key ], true ) ) {
            return array( 'allowed' => false, 'reason' => 'actor_not_allowed:' . $actor );
        }
        return array( 'allowed' => true, 'reason' => 'ok' );
    }
}

if ( ! function_exists( 'dinoco_claim_charge_transition' ) ) {
    /**
     * Atomic state transition with GET_LOCK + FOR UPDATE + action fire.
     *
     * Pattern (Round 30+ orthodoxy):
     *   1. GET_LOCK('dnc_claim_charge_{id}', 5s)
     *   2. START TRANSACTION
     *   3. SELECT ... FOR UPDATE
     *   4. FSM validate (from current row state)
     *   5. UPDATE row + populate audit columns (verified_by/refund_approver_id/etc.)
     *   6. COMMIT
     *   7. do_action('dinoco/claim/charge_state_changed', ...) POST-COMMIT
     *   8. RELEASE_LOCK in finally
     *
     * @param int    $charge_id
     * @param string $to_state
     * @param string $actor    customer|admin|system
     * @param array  $context  reason / verify_method / refund_approver_id / etc.
     * @return array|WP_Error  {old_state, new_state, claim_id} on success
     */
    function dinoco_claim_charge_transition( $charge_id, $to_state, $actor, $context = array() ) {
        global $wpdb;
        $chid = (int) $charge_id;
        if ( $chid <= 0 ) return new WP_Error( 'invalid_charge_id', 'Invalid charge_id', array( 'status' => 400 ) );

        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        $table = dinoco_claim_charges_table_name();

        $lock_key = 'dnc_claim_charge_' . md5( (string) $chid );
        $got_lock = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT GET_LOCK(%s, %d)", $lock_key, 5
        ) );
        if ( $got_lock !== 1 ) {
            return new WP_Error( 'lock_timeout', 'Concurrent update — please retry', array( 'status' => 409 ) );
        }

        try {
            $wpdb->query( 'START TRANSACTION' );

            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, claim_id, user_id, amount_thb, status, verified_by FROM {$table} WHERE id = %d FOR UPDATE",
                $chid
            ), ARRAY_A );

            if ( ! $row ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'charge_not_found', 'Charge not found', array( 'status' => 404 ) );
            }

            $from_state = (string) $row['status'];
            $decision   = dinoco_claim_charge_fsm_allowed( $from_state, $to_state, $actor );
            if ( ! $decision['allowed'] ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error(
                    'fsm_denied',
                    'Transition denied: ' . $decision['reason'],
                    array( 'status' => 409, 'from' => $from_state, 'to' => $to_state, 'reason' => $decision['reason'] )
                );
            }

            // Build UPDATE column set per target state
            $set       = array( 'status' => $to_state );
            $where     = array( 'id' => $chid );
            $set_fmt   = array( '%s' );
            $where_fmt = array( '%d' );

            $actor_uid = isset( $context['actor_user_id'] ) ? (int) $context['actor_user_id'] : 0;
            $now_mysql = current_time( 'mysql' );

            if ( $to_state === 'verified' ) {
                $set['verified_at'] = $now_mysql;
                $set['verified_by'] = $actor_uid;
                $set_fmt[] = '%s'; $set_fmt[] = '%d';
            } elseif ( $to_state === 'refunded' ) {
                // 4-eyes: refund_approver_id must differ from verified_by ≥฿5K
                $amount       = (float) $row['amount_thb'];
                $verified_by  = (int) $row['verified_by'];
                $approver     = isset( $context['refund_approver_id'] ) ? (int) $context['refund_approver_id'] : 0;
                if ( $amount >= 5000.0 ) {
                    if ( $approver <= 0 ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'four_eyes_required', 'Refund ≥฿5,000 requires refund_approver_id', array( 'status' => 422 ) );
                    }
                    if ( $approver === $verified_by ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'four_eyes_self_approval', 'Approver must differ from original verifier', array( 'status' => 409 ) );
                    }
                }
                $set['refund_reason']      = isset( $context['reason'] ) ? mb_substr( (string) $context['reason'], 0, 500 ) : '';
                $set['refund_approver_id'] = $approver;
                $set['refunded_at']        = $now_mysql;
                $set['refunded_by']        = $actor_uid;
                $set_fmt[] = '%s'; $set_fmt[] = '%d'; $set_fmt[] = '%s'; $set_fmt[] = '%d';
            }

            $upd = $wpdb->update( $table, $set, $where, $set_fmt, $where_fmt );
            if ( $upd === false ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'db_update_failed', 'Failed to update charge row', array( 'status' => 500 ) );
            }

            $claim_id = (int) $row['claim_id'];
            $amount   = (float) $row['amount_thb'];

            $wpdb->query( 'COMMIT' );

            // POST-COMMIT action fire per orchestrator action contract
            $action_ctx = array(
                'actor'         => (string) $actor,
                'actor_user_id' => $actor_uid,
                'amount_thb'    => $amount,
                'reason'        => isset( $context['reason'] ) ? (string) $context['reason'] : '',
            );
            if ( isset( $context['verify_method'] ) ) {
                $action_ctx['verify_method'] = (string) $context['verify_method'];
            }
            do_action( 'dinoco/claim/charge_state_changed',
                $claim_id, $chid, $from_state, $to_state, $action_ctx );

            return array(
                'charge_id' => $chid,
                'claim_id'  => $claim_id,
                'old_state' => $from_state,
                'new_state' => $to_state,
            );
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_charge_transition_threw', array(
                    'charge_id' => $chid,
                    'to_state'  => (string) $to_state,
                    'actor'     => (string) $actor,
                    'exception' => $e->getMessage(),
                ) );
            }
            return new WP_Error( 'transition_exception', 'Transition failed: ' . $e->getMessage(), array( 'status' => 500 ) );
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
        }
    }
}


