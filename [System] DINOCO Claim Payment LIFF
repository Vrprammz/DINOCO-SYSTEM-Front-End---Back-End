            return '<span class="dnc-claim-hist-badge dnc-claim-hist-badge-ok">จัดส่งสำเร็จ</span>';
        }
        if (s === 'cancelled') return '<span class="dnc-claim-hist-badge dnc-claim-hist-badge-neu">ยกเลิก</span>';
        if (s === 'failed')    return '<span class="dnc-claim-hist-badge dnc-claim-hist-badge-rej">ล้มเหลว</span>';
        return '<span class="dnc-claim-hist-badge dnc-claim-hist-badge-pend">กำลังจัดส่ง</span>';
    }

