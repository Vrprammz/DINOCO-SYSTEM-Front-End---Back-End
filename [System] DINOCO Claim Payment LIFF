    function dinoco_claim_payment_rest_verify( $req ) {
        $chid    = (int) $req->get_param( 'id' );
        $method  = (string) ( $req->get_param( 'verify_method' ) ?: 'admin_manual' );
        return dinoco_claim_payment_wrapped_transition(
            'claim_charge_verify', 'claim-charge-verify',
            $chid, 'verified', 'admin',
            array( 'verify_method' => $method ),
            60
        );
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_reject' ) ) {
    function dinoco_claim_payment_rest_reject( $req ) {
        $chid   = (int) $req->get_param( 'id' );
