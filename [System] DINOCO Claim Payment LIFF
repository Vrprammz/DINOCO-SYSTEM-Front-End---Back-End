        register_rest_route( $base, '/charge/(?P<id>\\d+)/cancel', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_payment_rest_cancel',
            'permission_callback' => 'dinoco_claim_payment_perm_admin',
            'args' => array( 'id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ) ),
        ) );

        // Sprint 15 M4 — refund consent. Approver self-creates a single-use
        // consent token via their OWN authenticated session, then hands the
        // token to the refund actor who passes it in the refund body. Closes
        // the forgeable refund_approver_id gap.
        register_rest_route( $base, '/charges/(?P<id>\\d+)/approve-refund', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_payment_rest_approve_refund',
            'permission_callback' => 'dinoco_claim_payment_perm_admin',
            'args' => array(
                'id'          => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
                'ttl_minutes' => array( 'required' => false, 'type' => 'integer', 'minimum' => 5, 'maximum' => 60, 'default' => 15 ),
            ),
        ) );

        // Sprint 17 Phase 2.6 — admin charge create
        register_rest_route( $base, '/charges', array(
            // GET = admin list (filter by claim_id)
            array(
                'methods'             => 'GET',
                'callback'            => 'dinoco_claim_payment_rest_charges_list',
                'permission_callback' => 'dinoco_claim_payment_perm_admin',
                'args' => array(
                    'claim_id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
                    'status'   => array( 'required' => false, 'type' => 'string' ),
                    'limit'    => array( 'required' => false, 'type' => 'integer', 'minimum' => 1, 'maximum' => 50, 'default' => 20 ),
                    'offset'   => array( 'required' => false, 'type' => 'integer', 'minimum' => 0, 'default' => 0 ),
                ),
            ),
            // POST = admin create
            array(
                'methods'             => 'POST',
                'callback'            => 'dinoco_claim_payment_rest_charge_create',
                'permission_callback' => 'dinoco_claim_payment_perm_admin',
                'args' => array(
                    'claim_id'        => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
                    'amount_thb'      => array( 'required' => true, 'type' => 'number' ),
                    'reason'          => array( 'required' => true, 'type' => 'string', 'maxLength' => 32 ),
                    'reason_note'     => array( 'required' => false, 'type' => 'string', 'maxLength' => 500 ),
                    'bank_context'    => array( 'required' => false, 'type' => 'string', 'default' => 'default' ),
                    'expires_in_days' => array( 'required' => false, 'type' => 'integer', 'minimum' => 1, 'maximum' => 30, 'default' => 7 ),
                ),
            ),
        ) );

        // Sprint 17 Phase 2.6 — tiered single read
        register_rest_route( $base, '/charges/(?P<id>\\d+)', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_payment_rest_charge_read',
            // Permission: any logged-in user; tier resolution inside handler.
            'permission_callback' => function() { return is_user_logged_in(); },
            'args' => array(
                'id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
            ),
        ) );

        // V.0.8 Sprint 20 MED-3 — auth-gated slip image proxy. Combined with
        // .htaccess deny on uploads dir, defeats direct-URL access bypass.
        register_rest_route( $base, '/charges/(?P<id>\\d+)/slip-image', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_payment_rest_slip_image',
            'permission_callback' => function() { return is_user_logged_in(); },
            'args' => array(
                'id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
            ),
        ) );

        // V.0.10 Sprint 30 Phase 4 Batch C Item 5 — owner-scoped charges list
        // for "ประวัติเคลม" customer LIFF. Mirror of admin /charges list but
        // permission_callback only requires is_user_logged_in; handler walks
        // 3-tier ownership chain (customer_id ACF → post_author → warranty
        // owner_user_id) per V.0.7 HIGH-3 fix, rejects 403 owner_mismatch
        // when caller != owner. Status filter optional (same whitelist).
        // Rate limit 30/min/user. Slip image URL sanitized per V.0.7 owner
        // tier rules (only verified/refunded expose the auth-gated proxy
        // path; pre-verify pending review remains private to admin).
        register_rest_route( $base, '/my-charges', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_claim_payment_rest_my_charges',
            'permission_callback' => function() { return is_user_logged_in(); },
            'args' => array(
                'claim_id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
                'status'   => array( 'required' => false, 'type' => 'string' ),
                'limit'    => array( 'required' => false, 'type' => 'integer', 'minimum' => 1, 'maximum' => 50, 'default' => 20 ),
                'offset'   => array( 'required' => false, 'type' => 'integer', 'minimum' => 0, 'default' => 0 ),
            ),
        ) );
    }
}

