/* ═══════════════════════════════════════════════════════════════════════════
 * 3. CRON SWEEPS (called by Notifier V.0.5 cron handlers)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_payment_run_expire_sweep' ) ) {
    /**
     * Daily 02:25 ICT — flip `pending_payment` rows with expires_at < NOW()
     * to `expired`. Each transition uses dinoco_claim_charge_transition() so
     * action fire + idempotency + audit all work consistently.
     */
    function dinoco_claim_payment_run_expire_sweep() {
        global $wpdb;
        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) return;
        $table = dinoco_claim_charges_table_name();

        // V.0.6 Sprint 14 M2 fix — chunked + replication-safe + deadline-guarded.
        // Was: single LIMIT 500 without ORDER BY (Sprint 12 SEC-M3 spec)
        //      and no per-run deadline → worst case 500 × 5s GET_LOCK = 2500s
        //      could overlap next cron run.
        // Now: chunked 100/iter + ORDER BY id ASC (replication safe) + 240s
        //      total wall-clock deadline + finally-block heartbeat (R12).
        $deadline_at    = microtime( true ) + 240.0;
        $total_swept    = 0;
        $max_iters      = 5;     // 5 × 100 = 500 max per run (matches old cap)
        try {
            for ( $i = 0; $i < $max_iters; $i++ ) {
                if ( microtime( true ) >= $deadline_at ) break;
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT id FROM {$table} WHERE status = %s AND expires_at < %s
                      ORDER BY id ASC LIMIT 100",
                    'pending_payment', current_time( 'mysql' )
                ), ARRAY_A );
                if ( empty( $rows ) ) break;
                foreach ( $rows as $r ) {
                    if ( microtime( true ) >= $deadline_at ) break 2;
                    // M3 — cron-actor transitions: do NOT idempotency-wrap here
                    // (transition() itself doesn't wrap; we go direct + skip
                    // PERF-H2 minute-bucket dedup which assumes user-driven).
                    $res = dinoco_claim_charge_transition( (int) $r['id'], 'expired', 'system', array(
                        'reason'        => 'auto_expire_cron',
                        'actor_user_id' => 0,  // explicit — Health Monitor reads
                    ) );
                    if ( is_wp_error( $res ) && function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( 'warning', 'claim_charge_expire_skipped', array(
                            'charge_id' => (int) $r['id'],
                            'error'     => $res->get_error_code(),
                        ) );
                    } elseif ( ! is_wp_error( $res ) ) {
                        $total_swept++;
                    }
                }
            }
        } finally {
            // R12 pattern — heartbeat in finally so Health Monitor sees the cron
            // ran even if a transition throws. Sweep-level heartbeat distinct
            // from cron-level heartbeat (set in Notifier handler).
            update_option(
                'dinoco_cron_claim_charge_expire_sweep_last_run',
                current_time( 'mysql' ),
                false
            );
            update_option(
                'dinoco_cron_claim_charge_expire_sweep_swept_count',
                (int) $total_swept,
                false
            );
        }
    }
}

