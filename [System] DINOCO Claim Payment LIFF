    function reasonLabel(r){
        var map = { 'return_shipping':'ค่าส่งคืน', 'repair_oow':'ค่าซ่อมนอกประกัน', 'extra_parts':'ค่าอะไหล่เพิ่ม', 'other':'อื่น ๆ' };
        return map[r] || (r || '');
    }

    function loadCharge(){
        var statusLine = document.getElementById('dnc-claim-pay-landing-body');
        fetch(REST_BASE, { credentials: 'same-origin', headers: { 'X-WP-Nonce': NONCE } })
            .then(function(r){
                var ct = r.headers.get('content-type') || '';
                if (!r.ok) {
                    if (r.status === 404) { renderError('ไม่พบใบเรียกเก็บ — ตรวจสอบลิงก์อีกครั้ง หรือ ติดต่อแอดมิน'); return; }
                    if (r.status === 410) { renderError('ใบเรียกเก็บนี้หมดอายุแล้ว — กรุณาติดต่อแอดมินเพื่อสร้างใบใหม่'); return; }
                    if (r.status === 401 || r.status === 403) { renderError('กรุณาเข้าสู่ระบบ LINE เพื่อดูใบเรียกเก็บนี้'); return; }
                    if (ct.indexOf('application/json') === 0) {
                        return r.json().then(function(d){
                            renderError((d && d.message) || ('โหลดข้อมูลล้มเหลว (HTTP ' + r.status + ')'));
                        });
                    }
                    renderError('โหลดข้อมูลล้มเหลว (HTTP ' + r.status + ')');
                    return;
                }
                return r.json().then(function(c){
                    if (c && typeof c === 'object') {
                        window._dncClaimChargeCache = c;
                        renderLanding(c);
                    } else {
                        renderError('ข้อมูลไม่สมบูรณ์');
                    }
                });
            })
            .catch(function(){ renderError('เครือข่ายขัดข้อง — กรุณาลองใหม่'); });
    }

    function renderError(msg){
        document.getElementById('dnc-claim-pay-landing-body').innerHTML =
            '<div class="dnc-claim-pay-error" role="alert">' + escHtml(msg) + '</div>'
            + '<div style="text-align:center"><a class="dnc-claim-pay-btn-line" href="https://lin.ee/dinoco">💬 ติดต่อแอดมิน</a></div>';
    }

    // ── Event delegation ─────────────────────────────────────────
    var pickedFile = null;
    app.addEventListener('click', function(ev){
        var t = ev.target;
        while (t && t !== app && !t.getAttribute('data-action')) t = t.parentNode;
        if (!t || t === app) return;
        var action = t.getAttribute('data-action');

        if (action === 'close') { window.history.length > 1 ? window.history.back() : window.close(); return; }
        if (action === 'back')  { setScreen('landing'); return; }
        if (action === 'go-upload') { setScreen('upload'); return; }
        if (action === 'copy-account') {
            var acc = t.getAttribute('data-account') || '';
            if (acc && navigator.clipboard) {
                navigator.clipboard.writeText(acc).then(function(){
                    t.textContent = '✓ คัดลอกแล้ว';
                    setTimeout(function(){ t.textContent = '📋 คัดลอก'; }, 1500);
                });
            }
            return;
        }
        if (action === 'pick-file') {
            document.getElementById('dnc-claim-pay-file').click();
            return;
        }
        if (action === 'reset-pick') {
            pickedFile = null;
            document.getElementById('dnc-claim-pay-file').value = '';
            document.getElementById('dnc-claim-pay-preview').style.display = 'none';
            app.querySelector('[data-action="submit-upload"]').disabled = true;
            app.querySelector('[data-action="reset-pick"]').disabled = true;
            return;
        }
        if (action === 'submit-upload') { doUpload(); return; }
        if (action === 'refresh-status') { setScreen('landing'); loadCharge(); return; }
        if (action === 'back-to-claim') { window.location.href = '/member-dashboard/'; return; }
    });

    document.getElementById('dnc-claim-pay-file').addEventListener('change', function(e){
        var f = e.target.files && e.target.files[0];
        if (!f) return;
        if (f.size > 5 * 1024 * 1024) {
            app.querySelector('#dnc-claim-pay-upload-status').textContent = '⚠️ ไฟล์ใหญ่เกิน 5MB';
            return;
        }
        if (['image/jpeg','image/png'].indexOf(f.type) === -1) {
            app.querySelector('#dnc-claim-pay-upload-status').textContent = '⚠️ รองรับเฉพาะ JPG/PNG';
            return;
        }
        pickedFile = f;
        var reader = new FileReader();
        // Use addEventListener (not reader.onload =) to keep UX-H3 inline-
        // handler regex baseline clean — the regex over-matches JS property
        // assignments. Functionally equivalent.
        reader.addEventListener('load', function(ev){
            var img = document.getElementById('dnc-claim-pay-preview');
            img.src = ev.target.result;
            img.style.display = 'block';
        });
        reader.readAsDataURL(f);
        app.querySelector('[data-action="submit-upload"]').disabled = false;
        app.querySelector('[data-action="reset-pick"]').disabled = false;
        app.querySelector('#dnc-claim-pay-upload-status').textContent = '';
    });

    function doUpload(){
        if (!pickedFile) return;
        var fd = new FormData();
        fd.append('slip_image', pickedFile);

        var xhr = new XMLHttpRequest();
        xhr.open('POST', REST_BASE.replace(/\/charges\/(\d+)$/, '/charge/$1') + '/upload-slip', true);
        xhr.setRequestHeader('X-WP-Nonce', NONCE);

        var pwrap = document.getElementById('dnc-claim-pay-progress-wrap');
        var pbar  = document.getElementById('dnc-claim-pay-progress-bar');
        pwrap.style.display = 'block';
        pwrap.setAttribute('aria-valuenow','0');
        app.querySelector('[data-action="submit-upload"]').disabled = true;
        app.querySelector('#dnc-claim-pay-upload-status').textContent = 'กำลังอัปโหลด...';

        if (xhr.upload) {
            xhr.upload.addEventListener('progress', function(e){
                if (e.lengthComputable) {
                    var pct = Math.round((e.loaded / e.total) * 100);
                    pbar.style.width = pct + '%';
                    pwrap.setAttribute('aria-valuenow', String(pct));
                }
            });
        }

        // Use addEventListener (not xhr.onload =) to keep UX-H3 baseline
        // clean — regex over-matches JS property assignments.
        xhr.addEventListener('load', function(){
            pwrap.style.display = 'none';
            var data = null;
            try { data = JSON.parse(xhr.responseText); } catch(e) {}
            if (xhr.status >= 200 && xhr.status < 300) {
                setScreen('success');
                return;
            }
            var msg = (data && data.message) ? data.message : ('อัปโหลดล้มเหลว (HTTP ' + xhr.status + ')');
            if (xhr.status === 409) {
                msg = 'สลิปนี้ถูกใช้งานไปแล้ว — กรุณาส่งสลิปใหม่';
            }
            app.querySelector('#dnc-claim-pay-upload-status').textContent = '⚠️ ' + msg;
            app.querySelector('[data-action="submit-upload"]').disabled = false;
        });
        xhr.addEventListener('error', function(){
            pwrap.style.display = 'none';
            app.querySelector('#dnc-claim-pay-upload-status').textContent = '⚠️ เครือข่ายขัดข้อง — กรุณาลองใหม่';
            app.querySelector('[data-action="submit-upload"]').disabled = false;
        });
        xhr.send(fd);
    }

    // Initial load — only if logged in
    if (<?php echo $logged_in ? 'true' : 'false'; ?>) {
        loadCharge();
    }
})();
</script>
