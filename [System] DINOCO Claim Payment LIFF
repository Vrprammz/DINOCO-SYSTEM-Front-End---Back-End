// V.0.11 Sprint 32 — Deprecation redirect shortcode handler.
// Both [dinoco_claim_pay] and [dinoco_claim_history] now redirect to
// Member Dashboard inline charge UI. Original `dinoco_claim_pay_render`
// + `dinoco_claim_history_render` retained as dead code (drift detectors
// pin to function declarations; will be deleted Sprint 36+).
if ( ! function_exists( 'dinoco_claim_pay_deprecated_redirect' ) ) {
    function dinoco_claim_pay_deprecated_redirect( $atts = array() ) {
        // Honor flag — when off return empty (byte-identical pre-V.0.8).
        if ( ! (bool) get_option( 'dinoco_claim_payment_enabled', false ) ) {
            return '';
        }
        // Preserve query + hash. /claim-pay/?cid=X → /dashboard/?action=pay&claim_id=X
        $cid  = isset( $_GET['cid'] ) ? (int) $_GET['cid'] : 0;
        $chid = isset( $_GET['charge'] ) ? (int) $_GET['charge'] : ( isset( $_GET['charge_id'] ) ? (int) $_GET['charge_id'] : 0 );
        // /claim-history/?claim_id=X also handled (same shortcode router).
        if ( $cid === 0 && isset( $_GET['claim_id'] ) ) {
            $cid = (int) $_GET['claim_id'];
        }
        $url  = home_url( '/dashboard/' );
        $qs   = array();
        if ( $cid > 0 ) {
            $qs['action']    = 'pay';
            $qs['claim_id']  = $cid;
        }
        if ( $chid > 0 ) {
            $qs['charge_id'] = $chid;
        }
        if ( ! empty( $qs ) ) {
            $url .= '?' . http_build_query( $qs );
            if ( $cid > 0 && $chid > 0 ) {
                $url .= '#claim-' . $cid . '-charge-' . $chid;
            } elseif ( $cid > 0 ) {
                $url .= '#claim-' . $cid;
            }
        }
        $esc_url = esc_url( $url );
        $html  = '<div style="padding:30px 20px;text-align:center;font-family:sans-serif;">';
        $html .= '<meta http-equiv="refresh" content="0;url=' . esc_attr( $url ) . '">';
        $html .= '<div style="font-size:18px;color:#1f2937;margin-bottom:12px;">⏳ กำลังพาคุณไปหน้า Dashboard...</div>';
        $html .= '<div style="font-size:13px;color:#6b7280;margin-bottom:18px;">หน้านี้ได้ย้ายไปอยู่ในหน้า Member Dashboard แล้ว</div>';
        $html .= '<a href="' . $esc_url . '" style="display:inline-block;background:#16a34a;color:#fff;font-weight:700;padding:12px 24px;border-radius:8px;text-decoration:none;min-height:44px;">ไปหน้า Dashboard</a>';
        $html .= '<script>(function(){try{window.location.replace(' . wp_json_encode( $url ) . ');}catch(e){}})();</script>';
        $html .= '</div>';
        return $html;
    }
}

