if ( ! function_exists( 'dinoco_claim_payment_rest_refund' ) ) {
    function dinoco_claim_payment_rest_refund( $req ) {
        $chid       = (int) $req->get_param( 'id' );
        $reason     = sanitize_text_field( (string) $req->get_param( 'reason' ) );
        $approver   = (int) $req->get_param( 'refund_approver_id' );
        // Sprint 15 M4 — consent_token closes the forgeable refund_approver_id
        // gap. Token validated pre-lock here (cheap reads) — full atomic
        // consume happens inside transition() under FOR UPDATE.
        $consent_token = sanitize_text_field( (string) $req->get_param( 'consent_token' ) );
        // Strict char policy mirrors wp_generate_password(64, false, false)
        // output — alphanumeric only. Reject anything else early.
        if ( $consent_token !== '' && ! preg_match( '/^[A-Za-z0-9]{1,64}$/', $consent_token ) ) {
            return new WP_Error( 'consent_token_invalid_format', 'consent_token must be 1-64 alphanumeric chars', array( 'status' => 422 ) );
        }

        $consent_token_row_id = 0;
        $effective_approver   = $approver;

        if ( function_exists( 'dinoco_claim_charges_table_name' ) ) {
            global $wpdb;
            $table = dinoco_claim_charges_table_name();
            // Read amount_thb_at_create (immutable snapshot) to decide if
            // 4-eyes consent flow applies. Use the snapshot — not amount_thb —
            // so attacker who lowered amount_thb cannot skip this branch.
            $amount_create = (float) $wpdb->get_var( $wpdb->prepare(
                "SELECT amount_thb_at_create FROM {$table} WHERE id = %d", $chid
            ) );

            if ( $amount_create >= 5000.0 ) {
                if ( $consent_token === '' ) {
                    return new WP_Error( 'consent_token_required', 'Refund ≥฿5,000 requires consent_token from POST /charges/{id}/approve-refund', array( 'status' => 422 ) );
                }
                if ( function_exists( 'dinoco_claim_refund_approvals_table_name' ) ) {
                    $atable = dinoco_claim_refund_approvals_table_name();
                    // Pre-lock validate (cheap reads): token exists + matches
                    // charge + not expired + not yet consumed. Atomic consume
                    // happens inside transition() under transaction.
                    $row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT id, approver_user_id, expires_at, consumed_at
                           FROM {$atable}
                          WHERE consent_token = %s
                            AND charge_id = %d
                          LIMIT 1",
                        $consent_token, $chid
                    ), ARRAY_A );
                    if ( ! $row ) {
                        return new WP_Error( 'consent_token_not_found', 'consent_token does not match charge', array( 'status' => 403 ) );
                    }
                    if ( ! empty( $row['consumed_at'] ) ) {
                        return new WP_Error( 'consent_token_already_consumed', 'consent_token was already consumed', array( 'status' => 409 ) );
                    }
                    if ( strtotime( (string) $row['expires_at'] ) < strtotime( current_time( 'mysql' ) ) ) {
                        return new WP_Error( 'consent_token_expired', 'consent_token expired — request a new one', array( 'status' => 410 ) );
                    }
                    $row_approver = (int) $row['approver_user_id'];
                    $uid          = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
                    if ( $row_approver === $uid ) {
                        return new WP_Error( 'consent_self_approval', 'Approver cannot be the refund actor', array( 'status' => 409 ) );
                    }
                    // If caller also passed refund_approver_id explicitly,
                    // it MUST match the token's approver to prevent the
                    // forge-by-body attack (the whole point of M4).
                    if ( $approver > 0 && $approver !== $row_approver ) {
                        return new WP_Error( 'consent_approver_mismatch', 'refund_approver_id body param must match token.approver_user_id', array( 'status' => 422 ) );
                    }
                    $consent_token_row_id = (int) $row['id'];
                    $effective_approver   = $row_approver;
                }
            }
        }

        return dinoco_claim_payment_wrapped_transition(
            'claim_charge_refund', 'claim-charge-refund',
            $chid, 'refunded', 'admin',
            array(
                'reason'                => $reason,
                'refund_approver_id'    => $effective_approver,
                'consent_token_row_id'  => $consent_token_row_id,
                // Sprint 15 binary-fingerprint pattern (R42) — consent token
                // discriminates retry of the SAME refund from retry of a
                // DIFFERENT refund attempt (e.g. token rotated).
                'idem_discriminator'    => $consent_token,
            ),
            20  // tight — refunds are rare + high-risk
        );
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_approve_refund' ) ) {
    /**
     * Sprint 15 M4 — Approver self-creates single-use consent token.
     * Permission: manage_options (admin) + must NOT match charge.verified_by
     * (4-eyes invariant defended at refund time too, but reject early here).
     *
     * Body params:
     *   ttl_minutes  optional (default 15, range 5-60)
     *
     * Returns { token, expires_at, approver_user_id, charge_id }.
     */
    function dinoco_claim_payment_rest_approve_refund( $req ) {
        $chid        = (int) $req->get_param( 'id' );
        $ttl_minutes = (int) $req->get_param( 'ttl_minutes' );
        if ( $ttl_minutes < 5 )  $ttl_minutes = 5;
        if ( $ttl_minutes > 60 ) $ttl_minutes = 60;

        $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        if ( $uid <= 0 ) {
            return new WP_Error( 'unauthenticated', 'Approver must be authenticated', array( 'status' => 401 ) );
        }

        // Rate limit — 20/hr per approver. Refund consent issuance should be
        // rare; flood implies someone scripting against the endpoint.
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'claim_refund_approve_' . $uid, 20, 3600 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        // Round 56 (2026-05-15) — Idempotency-Key wrapper. CRITICAL 4-eyes audit op.
        // Approver "อนุมัติคืนเงิน" double-click on slow UPDATE prior-revoke + INSERT new
        // consent_token row → 2× UPDATE consumed_at (idempotent) + 2× INSERT new token
        // rows (orphan token risk — only ONE returned to admin via response, the other
        // is dangling in DB until uq_consent_token UNIQUE catches; downstream refund
        // handler uses returned token). Body hash = {charge_id, ttl_minutes, approver_uid}.
        // Different ttl_minutes mid-retry → 409 catches admin re-evaluating expiry window.
        // Layered defense over 20/hr rate limit (microsecond window — cached replay covers
        // 24h TTL beyond rate limit window).
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $req ) : '';
        $idem_namespace = 'dinoco-claim/v1::charge-approve-refund';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'charge_id'        => (int) $chid,
                'ttl_minutes'      => (int) $ttl_minutes,
                'approver_user_id' => (int) $uid,
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) {
                $err_data    = $cached->get_error_data();
                $status_code = ( is_array( $err_data ) && isset( $err_data['status'] ) ) ? (int) $err_data['status'] : 409;
                return new WP_Error( 'idempotency_conflict',
                    'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                    array( 'status' => $status_code ) );
            }
            if ( is_array( $cached ) ) {
                $resp = $cached;
                unset( $resp['_idem_code'] );
                return $resp;
            }
        }

        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) || ! function_exists( 'dinoco_claim_refund_approvals_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        global $wpdb;
        $table  = dinoco_claim_charges_table_name();
        $atable = dinoco_claim_refund_approvals_table_name();

        // Verify charge exists + state = verified (only verified charges can
        // be refunded — anything else is irrelevant). Also fetch verified_by
        // to enforce 4-eyes "approver != verifier" at issuance time.
        $charge = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, status, verified_by, amount_thb_at_create FROM {$table} WHERE id = %d",
            $chid
        ), ARRAY_A );
        if ( ! $charge ) {
            return new WP_Error( 'charge_not_found', 'Charge not found', array( 'status' => 404 ) );
        }
        if ( (string) $charge['status'] !== 'verified' ) {
            return new WP_Error( 'charge_not_verified', 'Consent token only issuable for verified charges', array( 'status' => 409, 'current_state' => (string) $charge['status'] ) );
        }
        if ( (int) $charge['verified_by'] === $uid ) {
            return new WP_Error( 'four_eyes_self_approval', 'Approver must differ from original verifier', array( 'status' => 409 ) );
        }
        $amount_create = (float) $charge['amount_thb_at_create'];
        if ( $amount_create < 5000.0 ) {
            // <฿5K refunds skip consent entirely — but allow issuance for
            // future-proofing (admin may pre-issue before knowing exact amount).
            // Audit only.
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'info', 'claim_refund_approve_below_threshold', array(
                    'charge_id'        => $chid,
                    'amount_at_create' => $amount_create,
                    'approver'         => $uid,
                ) );
            }
        }

        // Generate alphanumeric token (matches refund handler regex). 64 chars
        // = ~380 bits entropy, well above brute-force.
        $token = wp_generate_password( 64, false, false );

        // V.0.5 Sprint 16 C2 fix — was `gmdate('Y-m-d H:i:s', strtotime($now) + ...)`
        // which formatted as UTC while DB comparisons use Bangkok-local
        // `current_time('mysql')`. Net effect on production Asia/Bangkok server:
        // expires_at written 7h behind created_at → token expires-on-arrival →
        // every refund returned 410 consent_token_expired Day 1. Use date() —
        // formats with PHP default tz (WP sets to UTC then current_time
        // adjusts to gmt_offset/timezone_string → matches DB write semantics).
        $now      = current_time( 'mysql' );
        $expires  = date( 'Y-m-d H:i:s', strtotime( $now ) + ( $ttl_minutes * 60 ) );

        // V.0.5 Sprint 16 H2 fix — invalidate prior open consent tokens for
        // this charge BEFORE issuing a new one. Approver double-tap or rate-
        // limit-burst would otherwise produce 2+ simultaneously valid tokens →
        // both consumable for separate refund races. Soft-revoke preserves
        // audit trail (consumed_at + consumed_by_user_id=0 marker for system
        // revoke). Run inside same wrapper (no extra GET_LOCK — INSERT path
        // already serialized via approver rate limit + uq_consent_token UNIQUE
        // catch-22 on extreme race).
        $wpdb->query( $wpdb->prepare(
            "UPDATE {$atable}
                SET consumed_at = %s, consumed_by_user_id = 0
              WHERE charge_id = %d AND consumed_at IS NULL",
            $now, $chid
        ) );

        $inserted = $wpdb->insert( $atable, array(
            'charge_id'        => $chid,
            'approver_user_id' => $uid,
            'consent_token'    => $token,
            'created_at'       => $now,
            'expires_at'       => $expires,
        ), array( '%d', '%d', '%s', '%s', '%s' ) );
        if ( $inserted === false ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_refund_consent_insert_failed', array(
                    'charge_id' => $chid, 'approver' => $uid,
                    'db_error'  => isset( $wpdb->last_error ) ? (string) $wpdb->last_error : '',
                ) );
            }
            return new WP_Error( 'consent_insert_failed', 'Failed to issue consent token', array( 'status' => 500 ) );
        }

        $resp_arr = array(
            'token'            => $token,
            'expires_at'       => $expires,
            'approver_user_id' => $uid,
            'charge_id'        => $chid,
            'ttl_minutes'      => $ttl_minutes,
        );
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body,
                array_merge( $resp_arr, array( '_idem_code' => 200 ) ), 200 );
        }
        return $resp_arr;
    }
}

