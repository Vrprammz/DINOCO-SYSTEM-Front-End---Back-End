        if ( $reason === '' ) {
            return new WP_Error( 'reason_required', 'Reject reason required', array( 'status' => 422 ) );
        }
        return dinoco_claim_payment_wrapped_transition(
            'claim_charge_reject', 'claim-charge-reject',
            $chid, 'rejected', 'admin',
            array( 'reason' => $reason ),
            30
        );
    }
}

