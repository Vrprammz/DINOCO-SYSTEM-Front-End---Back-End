    // Buddhist year date formatter (Thai locale-aware).
    function fmtThaiDate(mysqlTs){
        if (!mysqlTs) return '';
        var d = new Date(mysqlTs.replace(' ', 'T') + '+07:00');
        if (isNaN(d.getTime())) return mysqlTs;
        var months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
        var be = d.getFullYear() + 543;
        return d.getDate() + ' ' + months[d.getMonth()] + ' ' + be;
    }

    function fmtExpiry(expMysql){
        if (!expMysql) return { text: '—', cls: 'dnc-claim-pay-expiry-ok' };
        var exp = new Date(expMysql.replace(' ', 'T') + '+07:00');
        var now = new Date();
        var diffMs = exp.getTime() - now.getTime();
        if (diffMs <= 0) return { text: 'หมดเขตชำระแล้ว', cls: 'dnc-claim-pay-expiry-expired' };
        var hrs = Math.floor(diffMs / 3600000);
        var days = Math.floor(hrs / 24);
        var rest = hrs - days*24;
        var cls = (hrs < 24) ? 'dnc-claim-pay-expiry-warn' : 'dnc-claim-pay-expiry-ok';
        var txt = (days > 0)
            ? 'หมดเขตใน ' + days + ' วัน ' + rest + ' ชม.'
            : 'หมดเขตใน ' + hrs + ' ชม.';
        return { text: txt, cls: cls };
    }

    function fmtTHB(n){
        var v = parseFloat(n);
        if (!isFinite(v)) return '0.00';
        return v.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function escHtml(s){
        return String(s == null ? '' : s)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }

