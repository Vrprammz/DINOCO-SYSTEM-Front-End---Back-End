/* ═══════════════════════════════════════════════════════════════════════════
 * 2.6. SPRINT 17 — CHARGE CREATE + TIERED READ + ADMIN LIST
 *
 * Closes Sprint 13 "Charge create + GET /charge/{id}" deferred backlog.
 *
 * Design notes (mirroring spec from feature-architect / api-specialist):
 *   • Idempotency body hash uses amount_cents = round($amt * 100) int — float
 *     normalization prevents drift across PHP versions / locales.
 *   • Bank snapshot at INSERT is IMMUTABLE per spec §6.4 — once charge row
 *     issued, admin's mid-flow bank edits cannot invalidate customer Flex.
 *   • amount_thb_at_create = amount_thb at INSERT — CHECK chk_amount_snapshot
 *     enforces equality on every UPDATE so refund handler 4-eyes gate cannot
 *     be bypassed by lowering amount_thb (Sprint 14 H2).
 *   • payment_ref CLM-CHG-{id}-{crockford4} computed POST-INSERT (need id).
 *   • Tiered read 404 on non-owner non-admin → anti-enumeration (Sprint 14 H3).
 *   • Per-tier transient 60s — invalidated on `dinoco/claim/charge_state_changed`.
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_payment_generate_payment_ref' ) ) {
    /**
     * Crockford alphabet (excludes I/L/O/U) — case-insensitive lookup
     * resistant. Same alphabet used by SN system (consistency).
     */
    function dinoco_claim_payment_generate_payment_ref( $charge_id ) {
        $alpha = 'ABCDEFGHJKMNPQRSTVWXYZ23456789'; // Crockford-ish, no IL OU/01
        $len = strlen( $alpha );
        $suf = '';
        for ( $i = 0; $i < 4; $i++ ) {
            $suf .= $alpha[ random_int( 0, $len - 1 ) ];
        }
        return 'CLM-CHG-' . str_pad( (string) (int) $charge_id, 4, '0', STR_PAD_LEFT ) . '-' . $suf;
    }
}

if ( ! function_exists( 'dinoco_claim_payment_mask_account' ) ) {
    /**
     * Mask bank account number — keep last 4 chars; replace remainder with •.
     * Used for owner-tier read response (admin always sees unmasked).
     */
    function dinoco_claim_payment_mask_account( $account ) {
        $account = (string) $account;
        $len = mb_strlen( $account );
        if ( $len <= 4 ) return str_repeat( '•', $len );
        return str_repeat( '•', $len - 4 ) . mb_substr( $account, -4 );
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_charge_create' ) ) {
    /**
     * POST /dinoco-claim/v1/charges — admin create charge for a claim.
     *
     * Flow:
     *   1. b2b_rate_limit 30/hr/admin
     *   2. Validate body (claim exists, amount range, reason whitelist,
     *      bank_context whitelist, expires_in_days 1-30)
     *   3. Reject if claim already has active charge (status IN pending/review/verified)
     *   4. Resolve bank snapshot via dinoco_claim_bank_resolve()
     *   5. GET_LOCK('claim_charge_create_{claim_id}', 5s)
     *   6. Idempotency check (cents int hash)
     *   7. START TRANSACTION → INSERT row (amount_thb = amount_thb_at_create)
     *      → UPDATE payment_ref post-id → COMMIT
     *   8. Fire `dinoco/claim/charge_state_changed` post-COMMIT
     *   9. Idempotency store + audit log
     *  10. RELEASE_LOCK in finally
     */
    function dinoco_claim_payment_rest_charge_create( $req ) {
        global $wpdb;

        $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        if ( $uid <= 0 ) {
            return new WP_Error( 'unauthenticated', 'Admin must be authenticated', array( 'status' => 401 ) );
        }

        // Rate limit
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'claim_charge_create_' . $uid, 30, 3600 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        // Schema availability
        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        $table = dinoco_claim_charges_table_name();

        // ── Body validation ──────────────────────────────────────────
        $claim_id        = (int) $req->get_param( 'claim_id' );
        $amount_thb_raw  = $req->get_param( 'amount_thb' );
        $reason          = sanitize_text_field( (string) $req->get_param( 'reason' ) );
        $reason_note     = sanitize_textarea_field( (string) $req->get_param( 'reason_note' ) );
        $bank_context_in = sanitize_text_field( (string) $req->get_param( 'bank_context' ) );
        $expires_days    = (int) $req->get_param( 'expires_in_days' );

        if ( $claim_id <= 0 ) {
            return new WP_Error( 'invalid_claim_id', 'claim_id must be positive integer', array( 'status' => 422 ) );
        }

        // Amount validation
        if ( ! is_numeric( $amount_thb_raw ) ) {
            return new WP_Error( 'invalid_amount', 'amount_thb must be numeric', array( 'status' => 422 ) );
        }
        $amount_thb = (float) $amount_thb_raw;
        if ( $amount_thb < 0.01 || $amount_thb > 9999999.99 ) {
            return new WP_Error( 'invalid_amount', 'amount_thb must be 0.01..9,999,999.99', array( 'status' => 422 ) );
        }
        // Round to 2 dp to align with DECIMAL(14,2) storage
        $amount_thb = round( $amount_thb, 2 );
        $amount_cents = (int) round( $amount_thb * 100.0 );

        // Reason whitelist
        if ( ! defined( 'DINOCO_CLAIM_CHARGES_REASON_WHITELIST' ) ) {
            return new WP_Error( 'schema_missing', 'Reason whitelist constant missing', array( 'status' => 500 ) );
        }
        $reason_wl = explode( ',', DINOCO_CLAIM_CHARGES_REASON_WHITELIST );
        if ( ! in_array( $reason, $reason_wl, true ) ) {
            return new WP_Error( 'invalid_reason', 'reason must be one of: ' . DINOCO_CLAIM_CHARGES_REASON_WHITELIST, array( 'status' => 422 ) );
        }

        // Bank context whitelist — spec param maps to schema bucket:
        //   'default' → schema bank_context 'claim'        → resolver use_walkin=false
        //   'walkin'  → schema bank_context 'claim_walkin' → resolver use_walkin=true
        if ( $bank_context_in === '' ) $bank_context_in = 'default';
        $allowed_input_contexts = array( 'default', 'walkin' );
        if ( ! in_array( $bank_context_in, $allowed_input_contexts, true ) ) {
            return new WP_Error( 'invalid_bank_context', "bank_context must be 'default' or 'walkin'", array( 'status' => 422 ) );
        }
        $use_walkin   = ( $bank_context_in === 'walkin' );
        $schema_bank_ctx = $use_walkin ? 'claim_walkin' : 'claim';

        if ( $expires_days < 1 || $expires_days > 30 ) {
            return new WP_Error( 'invalid_expires_in_days', 'expires_in_days must be 1..30', array( 'status' => 422 ) );
        }

        // Claim must exist
        $claim_post = get_post( $claim_id );
        if ( ! $claim_post || $claim_post->post_type !== 'claim_ticket' ) {
            return new WP_Error( 'claim_not_found', 'claim_id does not match any claim_ticket', array( 'status' => 422 ) );
        }

        // Resolve bank snapshot
        if ( ! function_exists( 'dinoco_claim_bank_resolve' ) ) {
            return new WP_Error( 'bank_resolver_missing', 'dinoco_claim_bank_resolve() not available', array( 'status' => 500 ) );
        }
        $bank = dinoco_claim_bank_resolve( $use_walkin );
        if ( ! empty( $bank['error'] ) ) {
            return new WP_Error(
                'bank_snapshot_incomplete',
                'Bank settings not complete for context: ' . $bank_context_in,
                array( 'status' => 422, 'bank_error' => $bank['error'], 'missing_fields' => isset( $bank['missing_fields'] ) ? $bank['missing_fields'] : array() )
            );
        }

        // Determine claim owner user_id for customer column.
        // V.0.7 Sprint 19 HIGH-3 fix — legacy claim_ticket rows pre-V.30 had
        // no `customer_id` ACF + post_author=0 (system-created). Owner-tier
        // read on charge.user_id=0 → 404 anti-enum → customer can never view
        // their own charge via /claim-pay/?cid=X. 3-tier fallback chain:
        //   1. ACF customer_id (post-V.30 standard)
        //   2. post_author (early claim records pre-customer_id ACF)
        //   3. NEW: warranty_registration linked_warranty_id → its owner_user
        //      (most pre-V.30 claims were created against a warranty so this
        //       walks 1 hop to find the original registrant).
        $claim_user_id = 0;
        if ( function_exists( 'get_field' ) ) {
            $maybe = get_field( 'customer_id', $claim_id );
            if ( is_numeric( $maybe ) && (int) $maybe > 0 ) $claim_user_id = (int) $maybe;
        }
        if ( $claim_user_id === 0 && (int) $claim_post->post_author > 0 ) {
            $claim_user_id = (int) $claim_post->post_author;
        }
        // Warranty fallback for legacy rows
        if ( $claim_user_id === 0 && function_exists( 'get_field' ) ) {
            $warr_id = (int) get_field( 'linked_warranty_id', $claim_id );
            if ( $warr_id > 0 ) {
                $warr_owner = (int) get_field( 'owner_user_id', $warr_id );
                if ( $warr_owner > 0 ) $claim_user_id = $warr_owner;
            }
        }
        // Reject create when owner cannot be resolved — admin must manually
        // link customer to claim BEFORE issuing charge (else customer can
        // never authenticate against this charge).
        if ( $claim_user_id === 0 ) {
            return new WP_Error(
                'claim_owner_unresolved',
                'ไม่พบเจ้าของเคลม — โปรดผูกลูกค้ากับเคลมก่อนออกใบเรียกเก็บ',
                array( 'status' => 422, 'claim_id' => $claim_id )
            );
        }

        // ── Idempotency body hash (cents int — no float drift) ──────
        $idem_namespace = 'claim-charge-create';
        $idem_body = array(
            'claim_id'      => $claim_id,
            'amount_cents'  => $amount_cents,
            'reason'        => $reason,
            'bank_context'  => $bank_context_in,
            'actor_user_id' => $uid,
        );
        $idem_key = '';
        if ( function_exists( 'dinoco_idempotency_hash' ) && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_key = $idem_namespace . ':' . dinoco_idempotency_hash( $idem_body );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( $cached ) {
                if ( is_array( $cached ) && isset( $cached['__resp'] ) ) {
                    // Idempotency Helper may wrap response; pass through transparently
                    return rest_ensure_response( $cached['__resp'] );
                }
                return rest_ensure_response( $cached );
            }
        }

        // ── Acquire GET_LOCK per claim ──────────────────────────────
        $lock_key = 'claim_charge_create_' . md5( (string) $claim_id );
        $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_key, 5 ) );
        if ( $got_lock !== 1 ) {
            return new WP_Error( 'lock_timeout', 'Concurrent charge create — please retry', array( 'status' => 409 ) );
        }

        $charge_id = 0;
        $payment_ref = '';
        $expires_at = '';
        $now_mysql  = current_time( 'mysql' );

        try {
            // V.0.7 Sprint 19 HIGH-1 fix — move active-charge SELECT INSIDE
            // transaction + FOR UPDATE row lock. Previously ran outside txn →
            // TOCTOU window if a sibling endpoint mutated charges without
            // acquiring the same `claim_charge_create_*` lock key. Per
            // reviewer recommendation: read-then-write inside same txn closes
            // the race even cross-endpoint.
            $wpdb->query( 'START TRANSACTION' );

            $active_count = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$table}
                  WHERE claim_id = %d
                    AND status IN ('pending_payment','pending_review','verified')
                  FOR UPDATE",
                $claim_id
            ) );
            if ( $active_count > 0 ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'charge_active_exists', 'เคลมนี้มี Charge ที่ยังไม่ปิดอยู่', array( 'status' => 409 ) );
            }

            // V.0.7 Sprint 19 MED-1 fix — `date()` reads PHP default tz which
            // is UTC on most WP installs; `current_time('mysql')` returns
            // Bangkok-local → 7hr drift on production server. Use `wp_date()`
            // with `wp_timezone()` to match DB write semantics regardless of
            // PHP default tz setting. Sprint 16 C2 lesson applied correctly.
            $expires_at = function_exists( 'wp_date' )
                ? wp_date( 'Y-m-d H:i:s', strtotime( $now_mysql ) + ( $expires_days * DAY_IN_SECONDS ),
                    function_exists( 'wp_timezone' ) ? wp_timezone() : null )
                : date( 'Y-m-d H:i:s', strtotime( $now_mysql ) + ( $expires_days * DAY_IN_SECONDS ) );

            $insert_data = array(
                'claim_id'              => $claim_id,
                'user_id'               => $claim_user_id,
                'amount_thb'            => $amount_thb,
                'amount_thb_at_create'  => $amount_thb,   // Sprint 14 H2: BOTH set to satisfy chk_amount_snapshot
                'reason'                => $reason,
                'reason_note'           => $reason_note,
                'status'                => 'pending_payment',
                'bank_code'             => isset( $bank['bank_code'] ) ? (string) $bank['bank_code'] : '',
                'bank_account'          => isset( $bank['bank_account'] ) ? (string) $bank['bank_account'] : '',
                'bank_holder'           => isset( $bank['bank_holder'] ) ? (string) $bank['bank_holder'] : '',
                'bank_name'             => isset( $bank['bank_name'] ) ? (string) $bank['bank_name'] : '',
                'bank_branch'           => isset( $bank['bank_branch'] ) ? (string) $bank['bank_branch'] : '',
                'bank_context'          => $schema_bank_ctx,
                'payment_ref'           => 'PENDING',                // temp placeholder — UPDATE post-INSERT
                'expires_at'            => $expires_at,
                'created_at'            => $now_mysql,
                'created_by'            => $uid,
            );
            $insert_fmt = array(
                '%d','%d','%f','%f','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%s','%d'
            );

            $ok = $wpdb->insert( $table, $insert_data, $insert_fmt );
            if ( $ok === false ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( 'error', 'claim_charge_create_insert_failed', array(
                        'claim_id' => $claim_id,
                        'db_error' => isset( $wpdb->last_error ) ? (string) $wpdb->last_error : '',
                    ) );
                }
                return new WP_Error( 'db_insert_failed', 'Failed to insert charge row', array( 'status' => 500 ) );
            }
            $charge_id = (int) $wpdb->insert_id;

            // Generate payment_ref (CLM-CHG-NNNN-XXXX) + UPDATE row.
            // V.0.7 Sprint 19 MED-2 fix — $wpdb->update returns 0 (falsy but
            // === 0) when no rows affected (e.g. row deleted by parallel
            // mutation). === false alone misses this path → COMMIT proceeds
            // with payment_ref=PENDING orphan row. Strict check on both
            // false AND 0 + db error string for fail-loud diagnostics.
            $payment_ref = dinoco_claim_payment_generate_payment_ref( $charge_id );
            $upd = $wpdb->update( $table, array( 'payment_ref' => $payment_ref ), array( 'id' => $charge_id ), array( '%s' ), array( '%d' ) );
            if ( $upd === false || $upd === 0 || ! empty( $wpdb->last_error ) ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'db_update_failed',
                    'Failed to populate payment_ref',
                    array( 'status' => 500, 'rows_affected' => (int) $upd, 'db_error' => (string) $wpdb->last_error )
                );
            }

            $wpdb->query( 'COMMIT' );

            // POST-COMMIT action fire — Notifier listens at priority 20.
            $action_ctx = array(
                'actor'         => 'admin',
                'actor_user_id' => $uid,
                'amount_thb'    => $amount_thb,
                'reason'        => $reason,
                'context'       => 'created',
            );
            do_action( 'dinoco/claim/charge_state_changed',
                $claim_id, $charge_id, '', 'pending_payment', $action_ctx );

            // Audit + obs
            if ( function_exists( 'dinoco_audit_log' ) ) {
                dinoco_audit_log( array(
                    'event_type'  => 'claim_charge_created',
                    'actor_type'  => 'admin',
                    'actor_id'    => (string) $uid,
                    'target_type' => 'claim_charge',
                    'target_id'   => (string) $charge_id,
                    'amount'      => $amount_thb,
                    'context'     => array(
                        'claim_id'      => $claim_id,
                        'reason'        => $reason,
                        'bank_context'  => $bank_context_in,
                        'payment_ref'   => $payment_ref,
                        'expires_at'    => $expires_at,
                    ),
                ) );
            }
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'info', 'claim_charge_created', array(
                    'charge_id'    => $charge_id,
                    'claim_id'     => $claim_id,
                    'amount_thb'   => $amount_thb,
                    'reason'       => $reason,
                    'bank_context' => $bank_context_in,
                    'actor_user_id'=> $uid,
                ) );
            }

            // Build response
            $bank_snapshot = array(
                'bank_code'    => isset( $bank['bank_code'] ) ? (string) $bank['bank_code'] : '',
                'bank_name'    => isset( $bank['bank_name'] ) ? (string) $bank['bank_name'] : '',
                'bank_account' => isset( $bank['bank_account'] ) ? (string) $bank['bank_account'] : '',
                'bank_holder'  => isset( $bank['bank_holder'] ) ? (string) $bank['bank_holder'] : '',
                'bank_branch'  => isset( $bank['bank_branch'] ) ? (string) $bank['bank_branch'] : '',
            );
            // LIFF URL — slug is /claim-pay/ per DB_ID 1212 description. Until
            // boss creates the WP page the route won't resolve — but the URL
            // itself is correct for when the page exists.
            $liff_url = home_url( '/claim-pay/?cid=' . $charge_id );

            $resp = array(
                'id'             => $charge_id,
                'charge_id'      => $charge_id,
                'payment_ref'    => $payment_ref,
                'amount_thb'     => $amount_thb,
                'expires_at'     => $expires_at,
                'bank_snapshot'  => $bank_snapshot,
                'liff_url'       => $liff_url,
            );

            if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_store' ) ) {
                dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, $resp, 201 );
            }

            $rest = rest_ensure_response( $resp );
            $rest->set_status( 201 );
            return $rest;
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'claim_charge_create_threw', array(
                    'claim_id'  => $claim_id,
                    'exception' => $e->getMessage(),
                ) );
            }
            return new WP_Error( 'create_exception', 'Charge create failed: ' . $e->getMessage(), array( 'status' => 500 ) );
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
        }
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_charge_read' ) ) {
    /**
     * GET /dinoco-claim/v1/charges/{id} — tiered read.
     *
     * Tiers:
     *   admin (manage_options)            → full row + unmasked account + audit
     *   owner (charge.user_id === uid)    → sanitized (masked account last-4, no audit)
     *   other                             → 404 (anti-enumeration per R3 HIGH-5)
     */
    function dinoco_claim_payment_rest_charge_read( $req ) {
        global $wpdb;
        $chid = (int) $req->get_param( 'id' );
        if ( $chid <= 0 ) {
            return new WP_Error( 'invalid_charge_id', 'Invalid charge id', array( 'status' => 400 ) );
        }

        $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        $is_admin = current_user_can( 'manage_options' );

        // Rate limit READ separately (cheap probe defense).
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'claim_charge_read_' . $uid, 60, 60 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        $table = dinoco_claim_charges_table_name();

        $tier = $is_admin ? 'admin' : 'owner';
        $cache_key = 'dinoco_claim_charge_v1_' . $chid . '_' . $tier;
        $cached = get_transient( $cache_key );
        if ( is_array( $cached ) ) {
            // Owner tier may have cached a row that's no longer owned — defensive
            // re-validate ownership before returning cached payload.
            if ( $is_admin || ( isset( $cached['user_id'] ) && (int) $cached['user_id'] === $uid ) ) {
                return rest_ensure_response( $cached );
            }
        }

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$table} WHERE id = %d", $chid
        ), ARRAY_A );

        if ( ! $row ) {
            return new WP_Error( 'charge_not_found', 'ไม่พบใบเรียกเก็บนี้', array( 'status' => 404 ) );
        }

        // Owner tier check — 404 (not 403) on mismatch
        if ( ! $is_admin ) {
            if ( (int) $row['user_id'] !== $uid ) {
                return new WP_Error( 'charge_not_found', 'ไม่พบใบเรียกเก็บนี้', array( 'status' => 404 ) );
            }
        }

        // Build response by tier
        $bank_snapshot = array(
            'bank_code'    => (string) $row['bank_code'],
            'bank_name'    => (string) $row['bank_name'],
            'bank_account' => $is_admin
                ? (string) $row['bank_account']
                : dinoco_claim_payment_mask_account( (string) $row['bank_account'] ),
            'bank_holder'  => (string) $row['bank_holder'],
            'bank_branch'  => (string) $row['bank_branch'],
        );

        $resp = array(
            'id'             => (int) $row['id'],
            'charge_id'      => (int) $row['id'],
            'claim_id'       => (int) $row['claim_id'],
            'user_id'        => (int) $row['user_id'],
            'amount_thb'     => (float) $row['amount_thb'],
            'reason'         => (string) $row['reason'],
            'reason_note'    => (string) $row['reason_note'],
            'status'         => (string) $row['status'],
            'payment_ref'    => (string) $row['payment_ref'],
            'bank_snapshot'  => $bank_snapshot,
            'bank_context'   => (string) $row['bank_context'],
            'expires_at'     => (string) $row['expires_at'],
            'created_at'     => (string) $row['created_at'],
            'liff_url'       => home_url( '/claim-pay/?cid=' . (int) $row['id'] ),
            // PromptPay QR — field present but null until helper lands (Phase 2.7)
            'promptpay_qr'   => null,
        );

        if ( $is_admin ) {
            $resp['amount_thb_at_create'] = isset( $row['amount_thb_at_create'] ) ? (float) $row['amount_thb_at_create'] : 0.0;
            $resp['slip_image_url']       = (string) $row['slip_image_url'];
            $resp['slip_ref_hash']        = (string) $row['slip_ref_hash'];
            $resp['verified_at']          = (string) $row['verified_at'];
            $resp['verified_by']          = (int) $row['verified_by'];
            $resp['refund_reason']        = (string) $row['refund_reason'];
            $resp['refund_approver_id']   = (int) $row['refund_approver_id'];
            $resp['refunded_at']          = (string) $row['refunded_at'];
            $resp['refunded_by']          = (int) $row['refunded_by'];
            $resp['created_by']           = (int) $row['created_by'];
        } else {
            // Owner tier — only expose slip URL after verified (so admin's
            // pre-verify review is private). Status pre-verify → null.
            $resp['slip_image_url'] = in_array( $row['status'], array( 'verified', 'refunded' ), true )
                ? (string) $row['slip_image_url']
                : '';
        }

        set_transient( $cache_key, $resp, 60 );
        return rest_ensure_response( $resp );
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_charges_list' ) ) {
    /**
     * GET /dinoco-claim/v1/charges?claim_id=X — admin-only list.
     */
    function dinoco_claim_payment_rest_charges_list( $req ) {
        global $wpdb;

        $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'claim_charge_list_' . $uid, 60, 60 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        $table = dinoco_claim_charges_table_name();

        $claim_id = (int) $req->get_param( 'claim_id' );
        $status   = sanitize_text_field( (string) $req->get_param( 'status' ) );
        $limit    = (int) $req->get_param( 'limit' );
        $offset   = (int) $req->get_param( 'offset' );
        if ( $limit < 1 || $limit > 50 ) $limit = 20;
        if ( $offset < 0 ) $offset = 0;

        if ( $claim_id <= 0 ) {
            return new WP_Error( 'invalid_claim_id', 'claim_id required', array( 'status' => 422 ) );
        }

        // Status filter is optional but must match whitelist when provided.
        $where  = "claim_id = %d";
        $params = array( $claim_id );
        if ( $status !== '' ) {
            if ( ! defined( 'DINOCO_CLAIM_CHARGES_STATUS_WHITELIST' ) ) {
                return new WP_Error( 'schema_missing', 'Status whitelist missing', array( 'status' => 500 ) );
            }
            $wl = explode( ',', DINOCO_CLAIM_CHARGES_STATUS_WHITELIST );
            if ( ! in_array( $status, $wl, true ) ) {
                return new WP_Error( 'invalid_status', 'status must be one of: ' . DINOCO_CLAIM_CHARGES_STATUS_WHITELIST, array( 'status' => 422 ) );
            }
            $where   .= " AND status = %s";
            $params[] = $status;
        }

        $params[] = $limit;
        $params[] = $offset;
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, claim_id, user_id, amount_thb, reason, reason_note, status,
                    payment_ref, bank_context, expires_at, created_at, created_by,
                    verified_at, refunded_at
               FROM {$table}
              WHERE {$where}
              ORDER BY created_at DESC
              LIMIT %d OFFSET %d",
            $params
        ), ARRAY_A );

        if ( ! is_array( $rows ) ) $rows = array();

        $items = array();
        foreach ( $rows as $r ) {
            $items[] = array(
                'id'           => (int) $r['id'],
                'charge_id'    => (int) $r['id'],
                'claim_id'     => (int) $r['claim_id'],
                'amount_thb'   => (float) $r['amount_thb'],
                'reason'       => (string) $r['reason'],
                'reason_note'  => (string) $r['reason_note'],
                'status'       => (string) $r['status'],
                'payment_ref'  => (string) $r['payment_ref'],
                'bank_context' => (string) $r['bank_context'],
                'expires_at'   => (string) $r['expires_at'],
                'created_at'   => (string) $r['created_at'],
                'created_by'   => (int) $r['created_by'],
                'verified_at'  => (string) $r['verified_at'],
                'refunded_at'  => (string) $r['refunded_at'],
            );
        }

        return rest_ensure_response( array(
            'items'    => $items,
            'claim_id' => $claim_id,
            'limit'    => $limit,
            'offset'   => $offset,
            'count'    => count( $items ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_claim_payment_resolve_claim_owner' ) ) {
    /**
     * V.0.10 — extracted ownership resolver (mirrors V.0.7 HIGH-3 fallback
     * chain from `dinoco_claim_payment_rest_charge_create`). Returns the
     * user_id who owns this claim_ticket or 0 if unresolvable.
     *
     * @param int $claim_id
     * @return int owner user_id (0 if unresolvable)
     */
    function dinoco_claim_payment_resolve_claim_owner( $claim_id ) {
        $claim_id = (int) $claim_id;
        if ( $claim_id <= 0 ) return 0;
        if ( get_post_type( $claim_id ) !== 'claim_ticket' ) return 0;
        $claim_user_id = 0;
        if ( function_exists( 'get_field' ) ) {
            $maybe = get_field( 'customer_id', $claim_id );
            if ( is_numeric( $maybe ) && (int) $maybe > 0 ) $claim_user_id = (int) $maybe;
        }
        if ( $claim_user_id === 0 ) {
            $cp = get_post( $claim_id );
            if ( $cp && (int) $cp->post_author > 0 ) $claim_user_id = (int) $cp->post_author;
        }
        if ( $claim_user_id === 0 && function_exists( 'get_field' ) ) {
            $warr_id = (int) get_field( 'linked_warranty_id', $claim_id );
            if ( $warr_id > 0 ) {
                $warr_owner = (int) get_field( 'owner_user_id', $warr_id );
                if ( $warr_owner > 0 ) $claim_user_id = $warr_owner;
            }
        }
        return $claim_user_id;
    }
}

if ( ! function_exists( 'dinoco_claim_payment_rest_my_charges' ) ) {
    /**
     * V.0.10 Sprint 30 Phase 4 Batch C Item 5 —
     * GET /dinoco-claim/v1/my-charges?claim_id=X (owner-scoped).
     *
     * Owner tier of /charges list endpoint. Same shape as admin list but:
     *   - Permission = is_user_logged_in (handler walks ownership chain).
     *   - WHERE user_id = caller_uid (AND claim_id = X).
     *   - 403 owner_mismatch if caller is not the resolved claim owner.
     *   - 404 charge-style is via empty items[] (claim itself may be
     *     non-existent — handler 404s that case for anti-enumeration).
     *   - slip_image_url is the auth-gated proxy path (never raw uploads).
     *
     * Powers Customer LIFF [dinoco_claim_history] "ประวัติเคลม" page.
     */
    function dinoco_claim_payment_rest_my_charges( $req ) {
        global $wpdb;

        $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        if ( $uid <= 0 ) {
            return new WP_Error( 'not_logged_in', 'กรุณาเข้าสู่ระบบ', array( 'status' => 401 ) );
        }

        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'claim_my_charges_' . $uid, 30, 60 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        $table = dinoco_claim_charges_table_name();

        $claim_id = (int) $req->get_param( 'claim_id' );
        $status   = sanitize_text_field( (string) $req->get_param( 'status' ) );
        $limit    = (int) $req->get_param( 'limit' );
        $offset   = (int) $req->get_param( 'offset' );
        if ( $limit < 1 || $limit > 50 ) $limit = 20;
        if ( $offset < 0 ) $offset = 0;

        if ( $claim_id <= 0 ) {
            return new WP_Error( 'invalid_claim_id', 'claim_id required', array( 'status' => 422 ) );
        }

        // Resolve claim ownership — must match caller.
        $owner_uid = dinoco_claim_payment_resolve_claim_owner( $claim_id );
        if ( $owner_uid <= 0 ) {
            return new WP_Error( 'claim_not_found', 'ไม่พบรายการเคลมนี้', array( 'status' => 404 ) );
        }
        if ( $owner_uid !== $uid ) {
            // 404 (anti-enumeration) — never let caller probe other claims.
            return new WP_Error( 'claim_not_found', 'ไม่พบรายการเคลมนี้', array( 'status' => 404 ) );
        }

        $where  = "claim_id = %d AND user_id = %d";
        $params = array( $claim_id, $uid );
        if ( $status !== '' ) {
            if ( ! defined( 'DINOCO_CLAIM_CHARGES_STATUS_WHITELIST' ) ) {
                return new WP_Error( 'schema_missing', 'Status whitelist missing', array( 'status' => 500 ) );
            }
            $wl = explode( ',', DINOCO_CLAIM_CHARGES_STATUS_WHITELIST );
            if ( ! in_array( $status, $wl, true ) ) {
                return new WP_Error( 'invalid_status', 'invalid status', array( 'status' => 422 ) );
            }
            $where   .= " AND status = %s";
            $params[] = $status;
        }

        $params[] = $limit;
        $params[] = $offset;
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, claim_id, user_id, amount_thb, reason, reason_note, status,
                    payment_ref, bank_context, expires_at, created_at,
                    verified_at, refunded_at, refund_reason
               FROM {$table}
              WHERE {$where}
              ORDER BY created_at DESC
              LIMIT %d OFFSET %d",
            $params
        ), ARRAY_A );

        if ( ! is_array( $rows ) ) $rows = array();

        $items = array();
        foreach ( $rows as $r ) {
            $st = (string) $r['status'];
            // Slip URL exposure rule — only for verified/refunded (mirror V.0.7
            // owner tier in /charges/{id} single read; pre-verify slips are
            // private to admin). Uses the auth-gated proxy path, never raw.
            $slip_url = '';
            if ( in_array( $st, array( 'verified', 'refunded' ), true ) ) {
                $slip_url = '/wp-json/dinoco-claim/v1/charges/' . (int) $r['id'] . '/slip-image';
            }
            $items[] = array(
                'id'           => (int) $r['id'],
                'charge_id'    => (int) $r['id'],
                'claim_id'     => (int) $r['claim_id'],
                'amount_thb'   => (float) $r['amount_thb'],
                'reason'       => (string) $r['reason'],
                'reason_note'  => (string) $r['reason_note'],
                'status'       => $st,
                'payment_ref'  => (string) $r['payment_ref'],
                'bank_context' => (string) $r['bank_context'],
                'expires_at'   => (string) $r['expires_at'],
                'created_at'   => (string) $r['created_at'],
                'verified_at'  => (string) $r['verified_at'],
                'refunded_at'  => (string) $r['refunded_at'],
                'refund_reason'=> (string) $r['refund_reason'],
                'slip_image_url' => $slip_url,
                'liff_url'     => home_url( '/claim-pay/?cid=' . (int) $r['id'] ),
            );
        }

        return rest_ensure_response( array(
            'items'    => $items,
            'claim_id' => $claim_id,
            'limit'    => $limit,
            'offset'   => $offset,
            'count'    => count( $items ),
        ) );
    }
}

