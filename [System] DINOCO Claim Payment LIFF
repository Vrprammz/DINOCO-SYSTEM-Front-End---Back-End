        $base = 'dinoco-claim/v1';

        register_rest_route( $base, '/charge/(?P<id>\\d+)/upload-slip', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_payment_rest_upload_slip',
            'permission_callback' => 'dinoco_claim_payment_perm_customer',
            'args' => array( 'id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ) ),
        ) );

        register_rest_route( $base, '/charge/(?P<id>\\d+)/verify', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_payment_rest_verify',
            'permission_callback' => 'dinoco_claim_payment_perm_admin',
            'args' => array( 'id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ) ),
        ) );

        register_rest_route( $base, '/charge/(?P<id>\\d+)/reject', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_payment_rest_reject',
            'permission_callback' => 'dinoco_claim_payment_perm_admin',
            'args' => array( 'id' => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ) ),
        ) );

        register_rest_route( $base, '/charge/(?P<id>\\d+)/refund', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_claim_payment_rest_refund',
            'permission_callback' => 'dinoco_claim_payment_perm_admin',
            // V.0.5 Sprint 16 H3 fix — declare consent_token + approver_id in
            // REST args schema so WP short-circuits malformed payloads with 400
            // BEFORE the handler runs (handler regex still validates as
            // defense-in-depth). Also surfaces in OpenAPI auto-doc.
            'args' => array(
                'id'                 => array( 'required' => true, 'type' => 'integer', 'minimum' => 1 ),
                'consent_token'      => array( 'required' => false, 'type' => 'string', 'pattern' => '^[A-Za-z0-9]{1,64}$' ),
                'refund_approver_id' => array( 'required' => false, 'type' => 'integer', 'minimum' => 1 ),
                'refund_reason'      => array( 'required' => false, 'type' => 'string', 'maxLength' => 500 ),
