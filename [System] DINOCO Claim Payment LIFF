/* ═══════════════════════════════════════════════════════════════════════════
 * 4. SLIP IMAGE PROXY (V.0.8 Sprint 20 MED-3)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_payment_rest_slip_image' ) ) {
    /**
     * GET /dinoco-claim/v1/charges/{id}/slip-image — auth-gated proxy.
     *
     * Tiers:
     *   - admin (manage_options) → any charge
     *   - owner customer         → own charge only
     *   - other                  → 404 anti-enumeration
     *
     * Rate limit 30/min/user. Cache-Control: private, max-age=300.
     */
    function dinoco_claim_payment_rest_slip_image( $req ) {
        global $wpdb;
        $chid = (int) $req->get_param( 'id' );
        $uid  = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
        $is_admin = current_user_can( 'manage_options' );

        // V.0.9 Sprint 22 HIGH-3 fix — split rate limits per tier. Admin
        // batch-reviews 50+ pending charges back-to-back; 30/min/admin tripped
        // mid-review. Owner stays at 30/min (customer typically views 1-3 own
        // slips). Admin gets 120/min to support sustained review sessions.
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $cap = $is_admin ? 120 : 30;
            $rl = b2b_rate_limit( 'claim_slip_image_' . $uid, $cap, 60 );
            if ( is_wp_error( $rl ) ) return $rl;
        }

        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) {
            return new WP_Error( 'schema_missing', 'Charges schema not installed', array( 'status' => 500 ) );
        }
        $table = dinoco_claim_charges_table_name();
        $row   = $wpdb->get_row( $wpdb->prepare(
            "SELECT user_id, slip_image_url, status FROM {$table} WHERE id = %d", $chid
        ), ARRAY_A );

        if ( ! $row ) {
            return new WP_Error( 'charge_not_found', 'ไม่พบใบเรียกเก็บนี้', array( 'status' => 404 ) );
        }

        // Owner tier — 404 (not 403) on mismatch
        if ( ! $is_admin ) {
            if ( (int) $row['user_id'] !== $uid ) {
                return new WP_Error( 'charge_not_found', 'ไม่พบใบเรียกเก็บนี้', array( 'status' => 404 ) );
            }
            // Owner can only view slip after verified/refunded — pre-verify is
            // admin-private review.
            if ( ! in_array( $row['status'], array( 'verified', 'refunded' ), true ) ) {
                return new WP_Error( 'slip_not_visible_yet', 'สลิปจะแสดงเมื่อตรวจสอบเสร็จ', array( 'status' => 403 ) );
            }
        }

        $url = (string) $row['slip_image_url'];
        if ( $url === '' ) {
            return new WP_Error( 'no_slip', 'ยังไม่มีสลิปแนบ', array( 'status' => 404 ) );
        }

        // Resolve absolute file path from stored URL.
        $uploads = wp_upload_dir();
        $base_url = isset( $uploads['baseurl'] ) ? (string) $uploads['baseurl'] : '';
        $base_dir = isset( $uploads['basedir'] ) ? (string) $uploads['basedir'] : '';
        if ( $base_url === '' || $base_dir === '' || strpos( $url, $base_url ) !== 0 ) {
            return new WP_Error( 'slip_path_resolve_failed', 'ไม่พบไฟล์สลิป', array( 'status' => 500 ) );
        }
        $rel  = substr( $url, strlen( $base_url ) );
        // Strict allowlist: must start with /dinoco-claim-slips/ + no traversal
        if ( strpos( $rel, '/dinoco-claim-slips/' ) !== 0 || strpos( $rel, '..' ) !== false ) {
            return new WP_Error( 'slip_path_invalid', 'Invalid slip path', array( 'status' => 400 ) );
        }
        $abs = $base_dir . $rel;
        if ( ! file_exists( $abs ) || ! is_readable( $abs ) ) {
            return new WP_Error( 'slip_file_missing', 'ไฟล์สลิปหาย', array( 'status' => 404 ) );
        }

        // Stream file via REST response (headers via WP REST mechanism).
        $mime = function_exists( 'finfo_open' )
            ? ( function () use ( $abs ) {
                $fi = finfo_open( FILEINFO_MIME_TYPE );
                $m  = $fi ? (string) finfo_file( $fi, $abs ) : 'application/octet-stream';
                if ( $fi ) finfo_close( $fi );
                return $m;
            } )()
            : 'application/octet-stream';
        if ( ! in_array( $mime, array( 'image/jpeg', 'image/png' ), true ) ) {
            return new WP_Error( 'slip_mime_invalid', 'Invalid slip mime', array( 'status' => 400 ) );
        }

        // Audit-log read (defensive — skip if obs not loaded)
        if ( function_exists( 'dinoco_obs_capture' ) ) {
            dinoco_obs_capture( 'info', 'claim_slip_image_read', array(
                'charge_id' => $chid, 'actor_user_id' => $uid, 'tier' => $is_admin ? 'admin' : 'owner',
            ) );
        }

        // Note: REST will JSON-encode array responses; for binary we use
        // WP_REST_Response with raw body + headers. Header X-Content-Type-
        // Options: nosniff prevents browser sniffing. Content-Disposition
        // inline so image renders in <img src=> tag.
        $body     = file_get_contents( $abs );
        $response = new \WP_REST_Response( $body, 200 );
        $response->header( 'Content-Type', $mime );
        $response->header( 'Cache-Control', 'private, max-age=300' );
        $response->header( 'X-Content-Type-Options', 'nosniff' );
        $response->header( 'Content-Disposition', 'inline' );
        $response->header( 'Content-Length', (string) strlen( $body ) );
        // V.0.9 Sprint 22 CRIT-2 fix — defense against SVG-with-JPEG-magic-bytes
        // hybrid masquerade. finfo mime check verifies declared image/jpeg|png
        // but cannot detect polyglot files. CSP `default-src 'none'; sandbox`
        // neuters any inline script execution if a browser MIME-sniffs the file
        // as HTML/SVG. img-src 'self' permits the response itself but blocks
        // any embedded external loads. X-Frame-Options DENY for clickjacking.
        $response->header( 'Content-Security-Policy', "default-src 'none'; img-src 'self'; sandbox" );
        $response->header( 'X-Frame-Options', 'DENY' );
        return $response;
    }
}


/* ═══════════════════════════════════════════════════════════════════════════
 * 5. SLIP2GO ASYNC VERIFY (V.0.8 Sprint 20)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_payment_verify_slip_async' ) ) {
    /**
     * wp_schedule_single_event handler — called 5s after upload-slip COMMIT.
     *
     * Reads charge row → calls existing b2f_verify_slip_image() pattern OR
     * dedicated b2b helper if available → transition to verified|rejected.
     * On Slip2Go timeout/HTTP error: leave state pending_review for admin
     * manual verify + Telegram dedup alert.
     */
    function dinoco_claim_payment_verify_slip_async( $charge_id ) {
        global $wpdb;
        $chid = (int) $charge_id;
        if ( $chid <= 0 ) return;
        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) return;

        $table = dinoco_claim_charges_table_name();
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT bank_code, bank_account, amount_thb, slip_image_url, status FROM {$table} WHERE id = %d",
            $chid
        ), ARRAY_A );
        if ( ! $row || (string) $row['status'] !== 'pending_review' ) {
            return; // state moved on already; nothing to do
        }

        $slip_url = (string) $row['slip_image_url'];
        $bank_code = (string) $row['bank_code'];
        $amount    = (float) $row['amount_thb'];

        if ( $slip_url === '' || $bank_code === '' ) {
            return; // missing data — leave for admin manual
        }

        // Fetch slip bytes → base64 for Slip2Go API. Use REST proxy resolver
        // pattern (uploads basedir).
        $uploads  = wp_upload_dir();
        $base_url = isset( $uploads['baseurl'] ) ? (string) $uploads['baseurl'] : '';
        $base_dir = isset( $uploads['basedir'] ) ? (string) $uploads['basedir'] : '';
        $image_b64 = '';
        if ( $base_url !== '' && $base_dir !== '' && strpos( $slip_url, $base_url ) === 0 ) {
            $rel = substr( $slip_url, strlen( $base_url ) );
            if ( strpos( $rel, '/dinoco-claim-slips/' ) === 0 && strpos( $rel, '..' ) === false ) {
                $abs = $base_dir . $rel;
                if ( is_readable( $abs ) ) {
                    $b = @file_get_contents( $abs );
                    if ( $b !== false ) {
                        $image_b64 = base64_encode( $b );
                    }
                }
            }
        }
        if ( $image_b64 === '' ) {
            if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                b2b_tg_send_dedup( 'claim_slip_image_unreadable',
                    sprintf( '[CHARGES] Slip image unreadable on charge #%d', $chid ),
                    3600 );
            }
            return;
        }

        // Slip2Go API call — manual implementation to avoid coupling to
        // b2f_verify_slip_image() which expects maker_id. Reuses same
        // Slip2Go secret + base URL conventions.
        $api_url = defined( 'B2B_SLIP2GO_API_URL' ) ? B2B_SLIP2GO_API_URL
                : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';
        $api_key = defined( 'B2B_SLIP2GO_SECRET_KEY' ) ? B2B_SLIP2GO_SECRET_KEY : '';
        if ( $api_key === '' ) {
            if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                b2b_tg_send_dedup( 'claim_slip2go_no_key',
                    '[CHARGES] B2B_SLIP2GO_SECRET_KEY not configured — claim slip verify disabled', 3600 );
            }
            return;
        }

        $payload = array(
            'payload' => array(
                'imageBase64'    => $image_b64,
                'checkCondition' => array(
                    'checkDuplicate' => true,
                    'checkReceiver'  => array(
                        array(
                            'accountNumber' => preg_replace( '/[^0-9]/', '', (string) $row['bank_account'] ),
                            'accountType'   => 'BANKAC',
                        ),
                    ),
                ),
            ),
        );

        $response = wp_remote_post( $api_url, array(
            'headers' => array(
                'Authorization' => 'Bearer ' . $api_key,
                'Content-Type'  => 'application/json',
            ),
            'body'    => wp_json_encode( $payload ),
            'timeout' => 10,
        ) );

        // Retry once on transient error
        if ( is_wp_error( $response ) ) {
            sleep( 1 );
            $response = wp_remote_post( $api_url, array(
                'headers' => array(
                    'Authorization' => 'Bearer ' . $api_key,
                    'Content-Type'  => 'application/json',
                ),
                'body'    => wp_json_encode( $payload ),
                'timeout' => 10,
            ) );
        }

        if ( is_wp_error( $response ) ) {
            if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                b2b_tg_send_dedup( 'claim_slip2go_down',
                    '[CHARGES] Slip2Go unreachable — leaving claim charges pending_review for admin manual verify', 3600 );
            }
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'slip2go_unavailable', array(
                    'charge_id' => $chid, 'error' => $response->get_error_message(),
                ) );
            }
            return;
        }

        $http_code  = (int) wp_remote_retrieve_response_code( $response );
        $body_raw   = (string) wp_remote_retrieve_body( $response );
        $body_decoded = json_decode( $body_raw, true );
        if ( $http_code !== 200 || empty( $body_decoded ) ) {
            if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                b2b_tg_send_dedup( 'claim_slip2go_http_' . $http_code,
                    sprintf( '[CHARGES] Slip2Go HTTP %d on charge #%d', $http_code, $chid ), 3600 );
            }
            return;
        }

        $api_code = isset( $body_decoded['code'] ) ? (string) $body_decoded['code'] : '';
        $data     = isset( $body_decoded['data'] ) ? $body_decoded['data'] : array();
        $slip_amount = isset( $data['amount'] ) ? floatval( $data['amount'] ) : 0;

        // Persist Slip2Go response (audit trail).
        $wpdb->update(
            $table,
            array( 'slip_verify_data' => wp_json_encode( $body_decoded ) ),
            array( 'id' => $chid ),
            array( '%s' ), array( '%d' )
        );

        $is_success = in_array( $api_code, array( '200000', '200200' ), true );
        $amount_match = ( abs( $slip_amount - $amount ) <= 0.01 );

        if ( $is_success && $amount_match ) {
            dinoco_claim_charge_transition( $chid, 'verified', 'system', array(
                'verify_method'  => 'slip2go',
                'actor_user_id'  => 0,
                'slip_amount'    => $slip_amount,
            ) );
            return;
        }

        // Mismatch — reject with reason. Admin can review slip_verify_data
        // + re-trigger if needed.
        $reason = $is_success ? 'amount_mismatch' : ( 'slip2go_' . $api_code );
        dinoco_claim_charge_transition( $chid, 'rejected', 'system', array(
            'reason'         => $reason,
            'actor_user_id'  => 0,
            'verify_method'  => 'slip2go',
            'slip_amount'    => $slip_amount,
        ) );
    }
}


/* ═══════════════════════════════════════════════════════════════════════════
 * 6. OWNER-TRANSFER CACHE INVALIDATION LISTENER (V.0.8 Sprint 20 HIGH-2)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_payment_invalidate_charges_on_owner_transfer' ) ) {
    /**
     * Fired by Manual Transfer + Member Transfer Warranty pages via
     * `do_action('dinoco/claim/owner_transferred', $old_uid, $new_uid, $ctx)`.
     *
     * Purges per-charge transients for any charge belonging to either user
     * (chunked 100/iter to bound memory on power users with many warranties).
     */
    function dinoco_claim_payment_invalidate_charges_on_owner_transfer( $old_uid, $new_uid, $context = array() ) {
        $old = (int) $old_uid;
        $new = (int) $new_uid;
        if ( $old <= 0 && $new <= 0 ) return;
        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) return;

        global $wpdb;
        $table = dinoco_claim_charges_table_name();

        $uids   = array();
        if ( $old > 0 ) $uids[] = $old;
        if ( $new > 0 && $new !== $old ) $uids[] = $new;

        foreach ( $uids as $u ) {
            $offset = 0;
            $batch  = 100;
            do {
                $rows = $wpdb->get_col( $wpdb->prepare(
                    "SELECT id FROM {$table} WHERE user_id = %d ORDER BY id ASC LIMIT %d OFFSET %d",
                    $u, $batch, $offset
                ) );
                if ( empty( $rows ) ) break;
                foreach ( $rows as $cid ) {
                    delete_transient( 'dinoco_claim_charge_v1_' . (int) $cid . '_admin' );
                    delete_transient( 'dinoco_claim_charge_v1_' . (int) $cid . '_owner' );
                }
                $offset += $batch;
            } while ( count( $rows ) === $batch );
        }
    }
}
add_action( 'dinoco/claim/owner_transferred', 'dinoco_claim_payment_invalidate_charges_on_owner_transfer', 5, 3 );


