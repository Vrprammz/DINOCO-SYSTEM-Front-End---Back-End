/* ═══════════════════════════════════════════════════════════════════════════
 * 3. CRON SWEEPS (called by Notifier V.0.5 cron handlers)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_payment_run_expire_sweep' ) ) {
    /**
     * Daily 02:25 ICT — flip `pending_payment` rows with expires_at < NOW()
     * to `expired`. Each transition uses dinoco_claim_charge_transition() so
     * action fire + idempotency + audit all work consistently.
     */
    function dinoco_claim_payment_run_expire_sweep() {
        global $wpdb;
        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) return;
        $table = dinoco_claim_charges_table_name();
        $rows  = $wpdb->get_results( $wpdb->prepare(
            "SELECT id FROM {$table} WHERE status = %s AND expires_at < %s LIMIT 500",
            'pending_payment', current_time( 'mysql' )
        ), ARRAY_A );
        if ( empty( $rows ) ) return;
        foreach ( $rows as $r ) {
            $res = dinoco_claim_charge_transition( (int) $r['id'], 'expired', 'system', array( 'reason' => 'auto_expire_cron' ) );
            if ( is_wp_error( $res ) && function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'claim_charge_expire_skipped', array(
                    'charge_id' => (int) $r['id'],
                    'error'     => $res->get_error_code(),
                ) );
            }
        }
    }
}

if ( ! function_exists( 'dinoco_claim_payment_run_pending_review_sweep' ) ) {
    /**
     * Hourly — flag `pending_review` rows stuck > 24h for admin attention.
     * Telegram alert via b2b_tg_send_dedup (1hr TTL prevents spam).
     */
    function dinoco_claim_payment_run_pending_review_sweep() {
        global $wpdb;
        if ( ! function_exists( 'dinoco_claim_charges_table_name' ) ) return;
        $table = dinoco_claim_charges_table_name();
        $count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$table} WHERE status = %s AND verified_at IS NULL AND created_at < DATE_SUB(%s, INTERVAL 24 HOUR)",
            'pending_review', current_time( 'mysql' )
        ) );
        if ( $count > 0 && function_exists( 'b2b_tg_send_dedup' ) ) {
            b2b_tg_send_dedup( 'claim_charge_review_stuck',
                sprintf( "[CHARGES] %d charges stuck > 24h in pending_review", $count ),
                3600 );
        }
    }
}


