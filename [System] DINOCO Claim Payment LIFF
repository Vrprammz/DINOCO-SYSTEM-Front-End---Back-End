            +   '<div class="dnc-claim-pay-bank-row">'
            +     '<span class="dnc-claim-pay-bank-label">เลขบัญชี</span>'
            +     '<span class="dnc-claim-pay-bank-value" id="dnc-claim-pay-account">' + escHtml(bank.bank_account || '-') + '</span>'
            +     '<button type="button" class="dnc-claim-pay-copy-btn" data-action="copy-account" data-account="' + escHtml(bank.bank_account || '') + '">📋 คัดลอก</button>'
            +   '</div>'
            +   '<div class="dnc-claim-pay-bank-row"><span class="dnc-claim-pay-bank-label">ชื่อบัญชี</span><span class="dnc-claim-pay-bank-value">' + escHtml(bank.bank_holder || '-') + '</span></div>'
            + (bank.bank_branch ? '<div class="dnc-claim-pay-bank-row"><span class="dnc-claim-pay-bank-label">สาขา</span><span class="dnc-claim-pay-bank-value">' + escHtml(bank.bank_branch) + '</span></div>' : '')
            + (charge.promptpay_qr ? '<div style="text-align:center"><img class="dnc-claim-pay-qr" src="' + escHtml(charge.promptpay_qr) + '" alt="PromptPay QR" loading="lazy"><div style="font-size:11px;color:#6B7280">บันทึก QR เพื่อใช้กับแอปธนาคาร</div></div>' : '')
