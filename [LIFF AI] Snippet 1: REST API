        $auth = $request->get_param( '_auth' );
        $id   = sanitize_text_field( $request->get_param( 'id' ) );

        // ตรวจว่า lead เป็นของ dealer นี้
        $lead_data = liff_ai_call_agent( 'GET', '/api/leads/' . $id );
        if ( is_wp_error( $lead_data ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบ Lead' ), 200 );
        }
        $lead = $lead_data['data'] ?? $lead_data;
        if ( strval( $lead['dealerId'] ?? '' ) !== strval( $auth['dealer_id'] ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่มีสิทธิ์รับ Lead นี้' ), 403 );
        }

        // Transition: dealer_notified → checking_contact
        $result = liff_ai_call_agent( 'POST', '/api/leads/' . $id . '/status', array(
            'status'   => 'checking_contact',
            'metadata' => array(
                'accepted_by' => $auth['uid'],
