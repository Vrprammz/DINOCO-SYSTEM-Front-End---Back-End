/**
 * File: [LIFF AI] Snippet 1: REST API
 * Description: REST API + Auth สำหรับ LIFF AI Command Center
 * Version: V.1.8 — Auto-provision `dinoco_line_uid` meta on admin first auth (S1 transition).
 *   After role='admin' determined (strict or fallback), look up WP administrator with
 *   `line_user_id = $line_uid` meta — if found and lacks `dinoco_line_uid` → auto-populate
 *   via `update_user_meta`. Next auth for same UID hits strict allowlist path automatically
 *   (no manual SQL / admin UI step needed for admins who've logged in via any LINE Login
 *   gateway before). Also register admin user profile field "LINE UID" at Users → Profile
 *   so admins without prior LINE Login can paste their UID directly (helper UI — optional
 *   path for admins who never went through LINE OAuth flow). Log INFO when auto-provisioned.
 * Version: V.1.7 — Phase 2 Group A S1: (a) require `id_token` non-empty + reject ถ้า LINE
 *   verify fail (no silent fallback). (b) bind admin role to LINE UID allowlist via new
 *   helper `liff_ai_is_admin_line_uid()` (scans WP administrator users with meta
 *   `dinoco_line_uid` or legacy `line_user_id`, cached per-request). admin role granted
 *   only when group_id matches B2B_ADMIN_GROUP_ID AND verified LINE UID is in allowlist.
 *   ถ้า allowlist ว่าง (legacy transition — ยังไม่ได้ provision `dinoco_line_uid` meta)
 *   → log WARN + yield admin role from group_id match (backward compat). Once admins link
 *   LINE accounts, allowlist populates → strict mode auto-activates.
 *   Migration step needed: provision `dinoco_line_uid` meta for WP administrator users.
 * Version: V.1.6 — M18: register claim-state vocabulary filter + migrate /claim/status to dinoco_set_claim_status()
 * DB_ID: 1173
 *
 * Dependencies:
 *   - [B2B] Snippet 15: DINOCO_JWT (encode/verify)
 *   - [B2B] Snippet 1: b2b_get_dist_by_group()
 *   - Agent proxy (agent:3000) สำหรับ Lead data
 *
 * Auth: LIFF + LINE ID Token verify → JWT session (X-LIFF-AI-Token)
 * Namespace: /wp-json/liff-ai/v1/
 *
 * Roles:
 *   admin  = WP user ที่มี manage_options + line_user_id meta
 *   dealer = WP user ที่มี line_user_id meta + linked distributor (user meta 'linked_distributor_id')
 *            หรือ distributor CPT ที่มี ACF 'owner_line_uid' = LINE UID
 */

// ══════════════════════════════════════════════════════════════
// M18 — Register LIFF AI authoritative claim-state vocabulary (V.1.6)
// ══════════════════════════════════════════════════════════════
// LIFF AI owns the 6 authoritative long-form claim labels used by the
// admin /claim/status endpoint. These are the labels surfaced in the
// admin dashboard dropdown and stored on claim_ticket.ticket_status.
// Other subsystems (Service Center, Member Dashboard, MCP Bridge) may
// contribute additional variants via the same filter. See M18 helper
// definition in [Admin System] DINOCO Service Center & Claims.

add_filter( 'dinoco/claim/allowed_states', 'liff_ai_register_claim_states' );
function liff_ai_register_claim_states( $states ) {
    return array_merge( is_array( $states ) ? $states : array(), array(
        'Maintenance Completed',
        'Repaired Item Dispatched',
        'Pending Issue Verification',
        'Replacement Approved',
        'Replacement Shipped',
        'Replacement Rejected by Company',
    ) );
}

