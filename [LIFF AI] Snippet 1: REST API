// ── GET /claim/{id} ──
if ( ! function_exists( 'liff_ai_rest_claim_detail' ) ) {
    function liff_ai_rest_claim_detail( WP_REST_Request $request ) {
        $id   = sanitize_text_field( $request->get_param( 'id' ) );
        $post = get_post( intval( $id ) );

        if ( ! $post || $post->post_type !== 'claim_ticket' ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบใบเคลม' ), 200 );
        }

        // Photos — normalize ACF gallery/repeater → array of URLs
        $raw_photos = get_field( 'claim_photos', $post->ID ) ?: array();
        $photo_urls = array();
        if ( is_array( $raw_photos ) ) {
            foreach ( $raw_photos as $p ) {
                if ( is_array( $p ) && ! empty( $p['url'] ) ) {
                    $photo_urls[] = $p['url'];
                } elseif ( is_string( $p ) ) {
                    $photo_urls[] = $p;
                } elseif ( is_numeric( $p ) ) {
                    $url = wp_get_attachment_url( intval( $p ) );
                    if ( $url ) $photo_urls[] = $url;
                }
            }
        }

        // AI analysis (ACF field or post meta)
        $ai_analysis = get_field( 'ai_analysis', $post->ID ) ?: get_post_meta( $post->ID, 'ai_analysis', true );

        // Status history (ACF repeater or serialized meta)
        $status_history = get_field( 'status_history', $post->ID ) ?: array();
        if ( ! is_array( $status_history ) ) $status_history = array();

        $claim = array(
            'id'              => $post->ID,
            'ticket'          => get_field( 'ticket_number', $post->ID ) ?: get_post_meta( $post->ID, 'ticket_number', true ),
            'customer'        => get_field( 'customer_name', $post->ID ) ?: get_the_title( $post->ID ),
            'product'         => get_field( 'product_name', $post->ID ) ?: '',
            'model'           => get_field( 'motorcycle_model', $post->ID ) ?: '',
            'status'          => get_field( 'ticket_status', $post->ID ) ?: 'Registered in System',
            'symptoms'        => get_field( 'symptoms', $post->ID ) ?: '',
            'phone'           => get_field( 'phone', $post->ID ) ?: '',
            'photos'          => $photo_urls,
            'ai_analysis'     => $ai_analysis ?: '',
            'admin_note'      => get_field( 'admin_note', $post->ID ) ?: '',
            'resolution'      => get_field( 'resolution', $post->ID ) ?: '',
            'status_history'  => $status_history,
            'created_at'      => get_the_date( 'c', $post->ID ),
            'updated_at'      => get_the_modified_date( 'c', $post->ID ),
        );

        return new WP_REST_Response( array( 'success' => true, 'data' => $claim ), 200 );
    }
}

// ── POST /claim/{id}/status ──
if ( ! function_exists( 'liff_ai_rest_claim_status' ) ) {
    function liff_ai_rest_claim_status( WP_REST_Request $request ) {
        $auth       = $request->get_param( '_auth' );
        $id         = intval( $request->get_param( 'id' ) );
        $new_status = sanitize_text_field( $request->get_param( 'status' ) );
        $note       = sanitize_textarea_field( $request->get_param( 'note' ) );

        $valid = array(
            'Registered in System',
            'Awaiting Customer Shipment',
            'In Transit to Company',
            'Received at Company',
            'Under Maintenance',
            'Maintenance Completed',
            'Repaired Item Dispatched',
            'Pending Issue Verification',
            'Replacement Approved',
            'Replacement Shipped',
            'Replacement Rejected by Company',
        );
        if ( ! in_array( $new_status, $valid, true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'สถานะไม่ถูกต้อง' ), 200 );
        }

        $post = get_post( $id );
        if ( ! $post || $post->post_type !== 'claim_ticket' ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบใบเคลม' ), 200 );
        }

        $old_status = get_field( 'ticket_status', $id ) ?: 'Registered in System';

        // M18: route through canonical helper. The $valid allowlist above (line 880)
        // already restricts $new_status to the 6 authoritative labels, so the helper's
        // filter check is a pure redundancy here — but it also fires the hook, appends
        // status_history, and records observability, which is why we call it instead
        // of writing directly.
        if ( function_exists( 'dinoco_set_claim_status' ) ) {
            $_r = dinoco_set_claim_status( $id, $new_status, array(
                'actor'  => $auth['uid'] ?? 'admin',
                'note'   => $note ?: '',
                'source' => 'liff_ai_admin',
            ) );
            if ( is_wp_error( $_r ) && $_r->get_error_code() === 'terminal_state' ) {
                // Idempotent — admin re-selected same status. Not an error, just continue.
                // History already has the prior entry; skip this duplicate.
            }
        } else {
            update_field( 'ticket_status', $new_status, $id );
            // Manual history append (legacy path) — kept for the no-helper fallback case.
            $history = get_field( 'status_history', $id ) ?: array();
            if ( ! is_array( $history ) ) $history = array();
            $history[] = array(
                'from'   => $old_status,
                'to'     => $new_status,
                'note'   => $note ?: '',
                'by'     => $auth['uid'] ?? 'admin',
                'at'     => current_time( 'c' ),
            );
            update_field( 'status_history', $history, $id );
            update_post_meta( $id, 'status_history', $history );
        }

        if ( $note ) {
            $existing = get_field( 'admin_note', $id ) ?: '';
            $timestamp = current_time( 'Y-m-d H:i' );
            $updated = $existing . "\n[{$timestamp}] {$note}";
            update_field( 'admin_note', trim( $updated ), $id );
        }

        liff_ai_log( sprintf( '[Claim] Status changed id=%d to=%s', $id, $new_status ) );

        return new WP_REST_Response( array( 'success' => true, 'message' => 'อัพเดทสถานะเคลมสำเร็จ' ), 200 );
    }
}


