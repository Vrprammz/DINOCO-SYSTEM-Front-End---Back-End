// ── GET /dealer-dashboard ──
if ( ! function_exists( 'liff_ai_rest_dealer_dashboard' ) ) {
    function liff_ai_rest_dealer_dashboard( WP_REST_Request $request ) {
        $auth      = $request->get_param( '_auth' );
        $dealer_id = intval( $auth['dealer_id'] ?? 0 );

        if ( ! $dealer_id ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบข้อมูลร้านค้า' ), 200 );
        }

        // ดึง lead ของตัวแทนนี้จาก Agent
        $leads = liff_ai_call_agent( 'GET', '/api/leads', array(
            'dealerId' => strval( $dealer_id ),
            'limit'    => 50,
        ) );

        $leads_data = is_array( $leads ) ? ( $leads['data'] ?? array() ) : array();

        // นับสถิติ
        $new_count     = 0;
        $active_count  = 0;
        $pending_leads = array();
        $active_statuses = array( 'checking_contact', 'dealer_contacted', 'waiting_order', 'order_placed', 'waiting_delivery', 'delivered', 'waiting_install', 'installed' );

        foreach ( $leads_data as $lead ) {
            $status = $lead['status'] ?? '';
            if ( in_array( $status, array( 'lead_created', 'dealer_notified' ), true ) ) {
                $new_count++;
                $pending_leads[] = $lead;
            }
            if ( in_array( $status, $active_statuses, true ) ) {
                $active_count++;
            }
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => array(
                'dealer_id'     => $dealer_id,
                'dealer_name'   => get_the_title( $dealer_id ),
                'new_leads'     => $new_count,
                'active_leads'  => $active_count,
                'pending_leads' => array_slice( $pending_leads, 0, 10 ),
                'recent_leads'  => array_slice( $leads_data, 0, 20 ),
                'updated_at'    => current_time( 'c' ),
            ),
        ), 200 );
    }
}


