// 6. DASHBOARD ENDPOINTS
// ══════════════════════════════════════════════════════════════

// ── GET /dashboard (Admin) ──
if ( ! function_exists( 'liff_ai_rest_dashboard' ) ) {
    function liff_ai_rest_dashboard( WP_REST_Request $request ) {
        $data = liff_ai_call_agent( 'GET', '/api/advisor/sources-changed', array(
            'since' => gmdate( 'Y-m-d\TH:i:s\Z', strtotime( '-24 hours' ) ),
        ) );

        // Lead stats จาก Agent
        $lead_stats = liff_ai_call_agent( 'GET', '/api/leads', array(
            'limit' => 0,
            'stats' => 'true',
        ) );

        // Claim stats จาก WP
        $claim_pending = new WP_Query( array(
            'post_type'      => 'warranty_claim',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'meta_query'     => array( array(
                'key'     => 'claim_status',
                'value'   => array( 'pending', 'reviewing', 'approved' ),
                'compare' => 'IN',
            ) ),
            'fields'         => 'ids',
        ) );

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => array(
                'active_conversations' => is_array( $data ) ? count( $data['sources'] ?? array() ) : 0,
                'lead_stats'           => is_array( $lead_stats ) ? ( $lead_stats['stats'] ?? array() ) : array(),
                'pending_claims'       => $claim_pending->found_posts,
                'updated_at'           => current_time( 'c' ),
            ),
        ), 200 );
    }
}

// ── GET /dealer-dashboard ──
if ( ! function_exists( 'liff_ai_rest_dealer_dashboard' ) ) {
    function liff_ai_rest_dealer_dashboard( WP_REST_Request $request ) {
        $auth      = $request->get_param( '_auth' );
        $dealer_id = intval( $auth['dealer_id'] ?? 0 );

        if ( ! $dealer_id ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบข้อมูลร้านค้า' ), 200 );
        }

        // ดึง lead ของตัวแทนนี้จาก Agent
        $leads = liff_ai_call_agent( 'GET', '/api/leads', array(
            'dealerId' => strval( $dealer_id ),
            'limit'    => 50,
        ) );

        $leads_data = is_array( $leads ) ? ( $leads['data'] ?? array() ) : array();

        // นับสถิติ
        $new_count     = 0;
        $active_count  = 0;
        $pending_leads = array();
        $active_statuses = array( 'checking_contact', 'dealer_contacted', 'waiting_order', 'order_placed', 'waiting_delivery', 'delivered', 'waiting_install', 'installed' );

        foreach ( $leads_data as $lead ) {
            $status = $lead['status'] ?? '';
            if ( in_array( $status, array( 'lead_created', 'dealer_notified' ), true ) ) {
                $new_count++;
                $pending_leads[] = $lead;
            }
            if ( in_array( $status, $active_statuses, true ) ) {
                $active_count++;
            }
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => array(
                'dealer_id'     => $dealer_id,
                'dealer_name'   => get_the_title( $dealer_id ),
                'new_leads'     => $new_count,
                'active_leads'  => $active_count,
                'pending_leads' => array_slice( $pending_leads, 0, 10 ),
                'recent_leads'  => array_slice( $leads_data, 0, 20 ),
                'updated_at'    => current_time( 'c' ),
            ),
        ), 200 );
    }
}


// ══════════════════════════════════════════════════════════════
// 7. LEAD ENDPOINTS
// ══════════════════════════════════════════════════════════════

// ── GET /leads ──
if ( ! function_exists( 'liff_ai_rest_leads' ) ) {
    function liff_ai_rest_leads( WP_REST_Request $request ) {
        $auth   = $request->get_param( '_auth' );
        $status = sanitize_text_field( $request->get_param( 'status' ) );
        $page   = max( 1, intval( $request->get_param( 'page' ) ) );
        $limit  = min( 50, max( 1, intval( $request->get_param( 'limit' ) ?: 20 ) ) );

        $params = array(
            'page'  => $page,
            'limit' => $limit,
        );
        if ( $status ) {
            $params['status'] = $status;
        }

        // Dealer = own leads only
        if ( $auth['role'] === 'dealer' ) {
            $params['dealerId'] = strval( $auth['dealer_id'] );
        }

        $result = liff_ai_call_agent( 'GET', '/api/leads', $params );
        if ( is_wp_error( $result ) ) {
            return new WP_REST_Response( array(
                'success' => false,
                'message' => 'ไม่สามารถเชื่อมต่อระบบ Lead ได้',
            ), 200 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'data'    => $result['data'] ?? array(),
            'total'   => $result['total'] ?? 0,
            'page'    => $page,
        ), 200 );
    }
}

// ── GET /lead/{id} ──
if ( ! function_exists( 'liff_ai_rest_lead_detail' ) ) {
    function liff_ai_rest_lead_detail( WP_REST_Request $request ) {
        $auth = $request->get_param( '_auth' );
        $id   = sanitize_text_field( $request->get_param( 'id' ) );

        $result = liff_ai_call_agent( 'GET', '/api/leads/' . $id );
        if ( is_wp_error( $result ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบข้อมูล Lead' ), 200 );
        }

        $lead = $result['data'] ?? $result;

        // Dealer สามารถดูได้เฉพาะ lead ของตัวเอง
        if ( $auth['role'] === 'dealer' ) {
            $lead_dealer = strval( $lead['dealerId'] ?? '' );
            if ( $lead_dealer !== strval( $auth['dealer_id'] ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่มีสิทธิ์ดู Lead นี้' ), 403 );
            }
        }

        return new WP_REST_Response( array( 'success' => true, 'data' => $lead ), 200 );
    }
}

// ── POST /lead/{id}/accept (Dealer กดรับ) ──
if ( ! function_exists( 'liff_ai_rest_lead_accept' ) ) {
    function liff_ai_rest_lead_accept( WP_REST_Request $request ) {
        $auth = $request->get_param( '_auth' );
        $id   = sanitize_text_field( $request->get_param( 'id' ) );

        // ตรวจว่า lead เป็นของ dealer นี้
        $lead_data = liff_ai_call_agent( 'GET', '/api/leads/' . $id );
        if ( is_wp_error( $lead_data ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบ Lead' ), 200 );
        }
        $lead = $lead_data['data'] ?? $lead_data;
        if ( strval( $lead['dealerId'] ?? '' ) !== strval( $auth['dealer_id'] ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่มีสิทธิ์รับ Lead นี้' ), 403 );
        }

        // Transition: dealer_notified → checking_contact
        $result = liff_ai_call_agent( 'POST', '/api/leads/' . $id . '/status', array(
            'status'   => 'checking_contact',
            'metadata' => array(
                'accepted_by' => $auth['uid'],
                'accepted_at' => current_time( 'c' ),
            ),
        ) );

        if ( is_wp_error( $result ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่สามารถรับ Lead ได้' ), 200 );
        }

        liff_ai_log( sprintf( '[Lead] Accepted id=%s by dealer=%d', $id, $auth['dealer_id'] ) );

        return new WP_REST_Response( array( 'success' => true, 'message' => 'รับ Lead สำเร็จ' ), 200 );
    }
}

// ── POST /lead/{id}/note ──
if ( ! function_exists( 'liff_ai_rest_lead_note' ) ) {
    function liff_ai_rest_lead_note( WP_REST_Request $request ) {
        $auth = $request->get_param( '_auth' );
        $id   = sanitize_text_field( $request->get_param( 'id' ) );
        $note = sanitize_textarea_field( $request->get_param( 'note' ) );

        if ( empty( $note ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'กรุณากรอกหมายเหตุ' ), 200 );
        }

        // Dealer ownership check
        if ( $auth['role'] === 'dealer' ) {
            $lead_data = liff_ai_call_agent( 'GET', '/api/leads/' . $id );
            if ( is_wp_error( $lead_data ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่พบ Lead' ), 200 );
            }
            $lead = $lead_data['data'] ?? $lead_data;
            if ( strval( $lead['dealerId'] ?? '' ) !== strval( $auth['dealer_id'] ) ) {
                return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่มีสิทธิ์' ), 403 );
            }
        }

        $result = liff_ai_call_agent( 'POST', '/api/leads/' . $id . '/note', array(
            'note'  => $note,
            'by'    => $auth['role'] === 'dealer' ? get_the_title( $auth['dealer_id'] ) : 'Admin',
            'uid'   => $auth['uid'],
            'at'    => current_time( 'c' ),
        ) );

        if ( is_wp_error( $result ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'บันทึกหมายเหตุไม่สำเร็จ' ), 200 );
        }

        return new WP_REST_Response( array( 'success' => true, 'message' => 'บันทึกหมายเหตุสำเร็จ' ), 200 );
    }
}

// ── POST /lead/{id}/status (Admin only) ──
if ( ! function_exists( 'liff_ai_rest_lead_status' ) ) {
    function liff_ai_rest_lead_status( WP_REST_Request $request ) {
        $auth       = $request->get_param( '_auth' );
        $id         = sanitize_text_field( $request->get_param( 'id' ) );
        $new_status = sanitize_text_field( $request->get_param( 'status' ) );

        $valid_statuses = array(
            'lead_created', 'dealer_notified', 'checking_contact',
            'dealer_contacted', 'dealer_no_response',
            'waiting_order', 'order_placed',
            'waiting_delivery', 'delivered',
            'waiting_install', 'installed',
            'satisfaction_checked',
            'closed_satisfied', 'closed_lost', 'closed_cancelled',
            'admin_escalated', 'dormant',
        );

        if ( ! in_array( $new_status, $valid_statuses, true ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'สถานะไม่ถูกต้อง' ), 200 );
        }

        $result = liff_ai_call_agent( 'POST', '/api/leads/' . $id . '/status', array(
            'status'   => $new_status,
            'metadata' => array(
                'changed_by' => 'admin',
                'uid'        => $auth['uid'],
            ),
        ) );

        if ( is_wp_error( $result ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'อัพเดทสถานะไม่สำเร็จ' ), 200 );
        }

        liff_ai_log( sprintf( '[Lead] Status changed id=%s to=%s by admin', $id, $new_status ) );

        return new WP_REST_Response( array( 'success' => true, 'message' => 'อัพเดทสถานะสำเร็จ' ), 200 );
    }
}


