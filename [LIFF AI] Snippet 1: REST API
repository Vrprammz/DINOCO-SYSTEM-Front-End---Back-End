// ══════════════════════════════════════════════════════════════
// 2. AUTH ENDPOINT — POST /liff-ai/v1/auth
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'liff_ai_rest_auth' ) ) {
    function liff_ai_rest_auth( WP_REST_Request $request ) {
        // Rate limit: 20 per 5 min per IP
        $ip       = isset( $_SERVER['REMOTE_ADDR'] ) ? $_SERVER['REMOTE_ADDR'] : 'unknown';
        $rate_key = 'liff_ai_auth_' . md5( $ip );
        $attempts = intval( get_transient( $rate_key ) );
        if ( $attempts > 20 ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'Too many attempts' ), 429 );
        }
        set_transient( $rate_key, $attempts + 1, 300 );

        $line_uid = sanitize_text_field( $request->get_param( 'line_user_id' ) );
        $id_token = sanitize_text_field( $request->get_param( 'id_token' ) );

        if ( empty( $line_uid ) ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'ต้องเปิดผ่าน LINE เท่านั้น' ), 200 );
        }

        // ── Verify LINE ID Token (primary auth layer) ──
        if ( ! empty( $id_token ) ) {
            $liff_channel_id = '';
            if ( defined( 'B2B_LIFF_ID' ) ) {
                $liff_channel_id = preg_replace( '/-.*$/', '', B2B_LIFF_ID );
            }
            if ( $liff_channel_id ) {
                $verify_resp = wp_remote_post( 'https://api.line.me/oauth2/v2.1/verify', array(
                    'body'    => array( 'id_token' => $id_token, 'client_id' => $liff_channel_id ),
                    'timeout' => 10,
                ) );
                if ( ! is_wp_error( $verify_resp ) ) {
                    $verify_body = json_decode( wp_remote_retrieve_body( $verify_resp ), true );
                    if ( ! empty( $verify_body['sub'] ) ) {
                        $line_uid = sanitize_text_field( $verify_body['sub'] );
                    } else {
                        return new WP_REST_Response( array(
                            'authorized' => false,
                            'message'    => 'ยืนยันตัวตนไม่สำเร็จ กรุณาลองใหม่',
                        ), 200 );
                    }
                }
            }
        }

        // ── Determine role ──
        $role      = '';
        $dealer_id = 0;
        $name      = '';

        // 1) Check WP admin user
        $admin_users = get_users( array(
            'meta_key'   => 'line_user_id',
            'meta_value' => $line_uid,
            'role'       => 'administrator',
            'number'     => 1,
        ) );
        if ( ! empty( $admin_users ) ) {
            $role = 'admin';
            $name = $admin_users[0]->display_name;
        }

        // 2) Check distributor CPT by LINE group_id (ACF field 'line_group_id')
        //    LIFF ส่ง group_id มา (จาก liff.getContext().groupId)
        $group_id = sanitize_text_field( $request->get_param( 'group_id' ) );
        if ( empty( $role ) && ! empty( $group_id ) ) {
            $dist_posts = get_posts( array(
                'post_type'      => 'distributor',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array( array(
                    'key'   => 'line_group_id',
                    'value' => $group_id,
                ) ),
            ) );
            if ( ! empty( $dist_posts ) ) {
                $role      = 'dealer';
                $dealer_id = $dist_posts[0]->ID;
                $name      = get_the_title( $dist_posts[0]->ID );
            }
        }

        // 2b) Fallback: check distributor by personal LINE UID (ถ้ามี field)
        if ( empty( $role ) ) {
            $dist_posts = get_posts( array(
                'post_type'      => 'distributor',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array( array(
                    'key'   => 'owner_line_uid',
                    'value' => $line_uid,
                ) ),
            ) );
            if ( ! empty( $dist_posts ) ) {
                $role      = 'dealer';
                $dealer_id = $dist_posts[0]->ID;
                $name      = get_the_title( $dist_posts[0]->ID );
            }
        }

        // 3) Check WP user linked to distributor (user meta linked_distributor_id)
        if ( empty( $role ) ) {
            $wp_users = get_users( array(
                'meta_key'   => 'line_user_id',
                'meta_value' => $line_uid,
                'number'     => 1,
            ) );
            if ( ! empty( $wp_users ) ) {
                $linked = get_user_meta( $wp_users[0]->ID, 'linked_distributor_id', true );
                if ( $linked && get_post_status( $linked ) === 'publish' ) {
                    $role      = 'dealer';
                    $dealer_id = intval( $linked );
                    $name      = get_the_title( $dealer_id );
                }
            }
        }

        // Not found
        if ( empty( $role ) ) {
            return new WP_REST_Response( array(
                'authorized' => false,
                'message'    => 'ไม่พบสิทธิ์ในระบบ กรุณาติดต่อแอดมิน',
            ), 200 );
        }

        // ── Issue JWT ──
        $payload = array(
            'uid'       => $line_uid,
            'role'      => $role,
            'dealer_id' => $dealer_id,
        );
        $token = '';
        if ( class_exists( 'DINOCO_JWT' ) ) {
            $token = DINOCO_JWT::create( $payload, 7200 );
        } else {
            // Fallback: transient-based token
            $token = bin2hex( random_bytes( 32 ) );
            $payload['created'] = time();
            set_transient( 'liff_ai_sess_' . $token, $payload, 7200 );
        }

        liff_ai_log( sprintf( '[Auth] OK uid=%s role=%s dealer=%d', $line_uid, $role, $dealer_id ) );

        return new WP_REST_Response( array(
            'authorized' => true,
            'token'      => $token,
            'role'       => $role,
            'dealer_id'  => $dealer_id,
            'name'       => $name,
        ), 200 );
    }
}


// ══════════════════════════════════════════════════════════════
// 3. TOKEN VERIFY MIDDLEWARE
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'liff_ai_verify_token' ) ) {
    /**
     * Verify JWT token จาก X-LIFF-AI-Token header
     * @return array|WP_Error  { uid, role, dealer_id } หรือ WP_Error
     */
    function liff_ai_verify_token( WP_REST_Request $request ) {
        // WP admin session fallback
        if ( current_user_can( 'manage_options' ) ) {
            $uid = get_user_meta( get_current_user_id(), 'line_user_id', true );
            return array( 'uid' => $uid ?: 'wp_admin', 'role' => 'admin', 'dealer_id' => 0 );
        }

        $token = $request->get_header( 'X-LIFF-AI-Token' );
        if ( empty( $token ) ) {
            $token = sanitize_text_field( $request->get_param( '_token' ) );
        }
        if ( empty( $token ) ) {
            return new WP_Error( 'no_token', 'ไม่พบ token กรุณาเข้าสู่ระบบใหม่', array( 'status' => 401 ) );
        }

        // JWT verify
        if ( class_exists( 'DINOCO_JWT' ) && strpos( $token, '.' ) !== false ) {
            $payload = DINOCO_JWT::verify( $token );
            if ( $payload && ! empty( $payload['role'] ) ) {
                return array(
                    'uid'       => $payload['uid'] ?? '',
                    'role'      => $payload['role'],
                    'dealer_id' => intval( $payload['dealer_id'] ?? 0 ),
                );
            }
            return new WP_Error( 'invalid_token', 'Token หมดอายุ กรุณาเข้าสู่ระบบใหม่', array( 'status' => 401 ) );
        }

        // Transient fallback
        $clean = preg_replace( '/[^a-f0-9]/i', '', $token );
        if ( empty( $clean ) ) {
            return new WP_Error( 'invalid_token', 'Token ไม่ถูกต้อง', array( 'status' => 401 ) );
        }
        $data = get_transient( 'liff_ai_sess_' . $clean );
        if ( ! $data || empty( $data['role'] ) ) {
            return new WP_Error( 'expired_token', 'Token หมดอายุ กรุณาเข้าสู่ระบบใหม่', array( 'status' => 401 ) );
        }
        return $data;
    }
}


// ══════════════════════════════════════════════════════════════
// 4. PERMISSION CALLBACKS
// ══════════════════════════════════════════════════════════════

function liff_ai_perm_admin( WP_REST_Request $request ) {
    $auth = liff_ai_verify_token( $request );
    if ( is_wp_error( $auth ) ) return $auth;
    if ( $auth['role'] !== 'admin' ) {
        return new WP_Error( 'forbidden', 'ไม่มีสิทธิ์เข้าถึง', array( 'status' => 403 ) );
    }
    $request->set_param( '_auth', $auth );
    return true;
}

function liff_ai_perm_dealer( WP_REST_Request $request ) {
    $auth = liff_ai_verify_token( $request );
    if ( is_wp_error( $auth ) ) return $auth;
    if ( $auth['role'] !== 'dealer' && $auth['role'] !== 'admin' ) {
        return new WP_Error( 'forbidden', 'ไม่มีสิทธิ์เข้าถึง', array( 'status' => 403 ) );
    }
    $request->set_param( '_auth', $auth );
    return true;
}

function liff_ai_perm_any( WP_REST_Request $request ) {
    $auth = liff_ai_verify_token( $request );
    if ( is_wp_error( $auth ) ) return $auth;
    $request->set_param( '_auth', $auth );
    return true;
}


// ══════════════════════════════════════════════════════════════
// 5. AGENT PROXY — เรียก Agent API (agent:3000)
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'liff_ai_call_agent' ) ) {
    /**
     * เรียก Agent API (MongoDB-backed)
     * @param string $method   GET|POST|PUT|DELETE
     * @param string $endpoint เช่น /api/leads
     * @param array  $body     Body สำหรับ POST/PUT
     * @return array|WP_Error
     */
    function liff_ai_call_agent( $method, $endpoint, $body = null ) {
        $base_url = LIFF_AI_AGENT_URL;
        $url = rtrim( $base_url, '/' ) . '/' . ltrim( $endpoint, '/' );

        $args = array(
            'method'  => strtoupper( $method ),
            'headers' => array(
                'Content-Type'  => 'application/json',
                'Authorization' => 'Bearer ' . LIFF_AI_AGENT_KEY,
            ),
            'timeout' => 10,
        );

        if ( $body && in_array( $args['method'], array( 'POST', 'PUT', 'PATCH' ), true ) ) {
            $args['body'] = wp_json_encode( $body );
        }

        // URL params สำหรับ GET
        if ( $body && $args['method'] === 'GET' ) {
            $url = add_query_arg( $body, $url );
        }

        $response = wp_remote_request( $url, $args );

        if ( is_wp_error( $response ) ) {
            // Fallback: try localhost
            if ( strpos( $base_url, 'agent:' ) !== false ) {
                $fallback_url = str_replace( 'agent:', 'localhost:', $url );
                $response = wp_remote_request( $fallback_url, $args );
                if ( is_wp_error( $response ) ) {
                    return $response;
                }
            } else {
                return $response;
            }
        }

        $code = wp_remote_retrieve_response_code( $response );
        $body_str = wp_remote_retrieve_body( $response );
        $data = json_decode( $body_str, true );

        if ( $code >= 400 ) {
            return new WP_Error( 'agent_error', $data['message'] ?? 'Agent error', array( 'status' => $code ) );
        }

        return $data ?: array();
    }
}


