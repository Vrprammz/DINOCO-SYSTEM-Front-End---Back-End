// ══════════════════════════════════════════════════════════════
// 0.5. ADMIN ALLOWLIST HELPER — V.1.7 (S1)
// ══════════════════════════════════════════════════════════════
// Returns true if $line_uid is bound to a WP administrator account via either
// `dinoco_line_uid` (preferred, V.1.7 convention) OR legacy `line_user_id` meta.
// Cached per-request. Returns false when allowlist is empty (legacy mode — no admins
// have linked LINE UID yet) AND sets a flag caller can inspect to decide backward-compat
// fallback. This is a transition-period safeguard: once ANY administrator has
// `dinoco_line_uid` (or `line_user_id`) meta populated, allowlist becomes non-empty →
// strict mode auto-activates — unregistered UIDs cannot claim admin role via group_id alone.
if ( ! function_exists( 'liff_ai_is_admin_line_uid' ) ) {
    function liff_ai_is_admin_line_uid( $line_uid ) {
        static $cache = null;
        if ( $cache === null ) {
            $cache = array();
            $admin_users = get_users( array(
                'role__in' => array( 'administrator' ),
                'fields'   => array( 'ID' ),
                'number'   => 200,
            ) );
            foreach ( $admin_users as $u ) {
                $uid_new = get_user_meta( $u->ID, 'dinoco_line_uid', true );
                if ( ! empty( $uid_new ) ) $cache[] = (string) $uid_new;
                $uid_legacy = get_user_meta( $u->ID, 'line_user_id', true );
                if ( ! empty( $uid_legacy ) ) $cache[] = (string) $uid_legacy;
            }
            $cache = array_values( array_unique( array_filter( $cache ) ) );
        }
        // Expose empty-state flag so caller can decide backward-compat behavior
        $GLOBALS['_liff_ai_admin_allowlist_empty'] = empty( $cache );
        if ( empty( $cache ) ) return false;
        return in_array( (string) $line_uid, $cache, true );
    }
}


