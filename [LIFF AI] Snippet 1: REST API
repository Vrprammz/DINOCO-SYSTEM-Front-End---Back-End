// ══════════════════════════════════════════════════════════════
// 2. AUTH ENDPOINT — POST /liff-ai/v1/auth
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'liff_ai_rest_auth' ) ) {
    function liff_ai_rest_auth( WP_REST_Request $request ) {
        // Rate limit: 20 per 5 min per IP
        $ip       = isset( $_SERVER['REMOTE_ADDR'] ) ? $_SERVER['REMOTE_ADDR'] : 'unknown';
        $rate_key = 'liff_ai_auth_' . md5( $ip );
        $attempts = intval( get_transient( $rate_key ) );
        if ( $attempts > 20 ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'Too many attempts' ), 429 );
        }
        set_transient( $rate_key, $attempts + 1, 300 );

        $line_uid = sanitize_text_field( $request->get_param( 'line_user_id' ) );
        $id_token = sanitize_text_field( $request->get_param( 'id_token' ) );

        if ( empty( $line_uid ) ) {
            return new WP_REST_Response( array( 'authorized' => false, 'message' => 'ต้องเปิดผ่าน LINE เท่านั้น' ), 200 );
        }

        // ── V.1.7 (S1) — require id_token non-empty ──
        if ( empty( $id_token ) ) {
            return new WP_Error(
                'missing_id_token',
                'ต้องส่ง id_token (LINE verify required)',
                array( 'status' => 400 )
            );
        }

        // ── Verify LINE ID Token (primary auth layer) — V.1.7: required, no silent fallback ──
        $liff_channel_id = '';
        if ( defined( 'B2B_LIFF_ID' ) ) {
            $liff_channel_id = preg_replace( '/-.*$/', '', B2B_LIFF_ID );
        }
        if ( empty( $liff_channel_id ) ) {
            liff_ai_log( '[Auth] ERROR — B2B_LIFF_ID not defined, cannot verify id_token' );
            return new WP_Error(
                'server_misconfigured',
                'เซิร์ฟเวอร์ยังไม่พร้อมใช้งาน (missing LIFF channel ID)',
                array( 'status' => 500 )
            );
        }

        $verify_resp = wp_remote_post( 'https://api.line.me/oauth2/v2.1/verify', array(
            'body'    => array( 'id_token' => $id_token, 'client_id' => $liff_channel_id ),
            'timeout' => 10,
        ) );
        if ( is_wp_error( $verify_resp ) ) {
            liff_ai_log( '[Auth] LINE verify transport error: ' . $verify_resp->get_error_message() );
            return new WP_Error(
                'id_token_verify_failed',
                'ไม่สามารถยืนยันกับ LINE ได้ กรุณาลองใหม่',
                array( 'status' => 502 )
            );
        }
        $verify_body = json_decode( wp_remote_retrieve_body( $verify_resp ), true );
        if ( empty( $verify_body['sub'] ) ) {
            return new WP_Error(
                'id_token_invalid',
                'ยืนยันตัวตนไม่สำเร็จ กรุณาลองใหม่',
                array( 'status' => 401 )
            );
        }
        // Authoritative LINE UID = $verify_body['sub'] (overrides client-supplied line_user_id)
        $line_uid = sanitize_text_field( $verify_body['sub'] );

        // ── Determine role ──
        $role      = '';
        $dealer_id = 0;
        $name      = '';

        // 1a) Check Admin by B2B_ADMIN_GROUP_ID + LINE UID allowlist — V.1.7 (S1)
        //     group_id ไม่ใช่ secret (เปิดใน Flex URL/screenshot ได้) — must bind to verified LINE UID.
        $group_id = sanitize_text_field( $request->get_param( 'group_id' ) );
        $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
        if ( ! empty( $group_id ) && ! empty( $admin_group ) && $group_id === $admin_group ) {
            $in_allowlist = liff_ai_is_admin_line_uid( $line_uid );
            $allowlist_empty = ! empty( $GLOBALS['_liff_ai_admin_allowlist_empty'] );

            if ( $in_allowlist ) {
                // Strict path — UID ∈ allowlist
                $role = 'admin';
                $name = 'DINOCO Admin';
            } elseif ( $allowlist_empty ) {
                // Backward compat transition — no admin has linked LINE UID yet.
                // Yield admin from group match + log WARN so migration can be tracked.
                $role = 'admin';
                $name = 'DINOCO Admin';
                liff_ai_log( sprintf(
                    '[Auth][WARN] admin role granted via group_id fallback (allowlist empty) — '
                    . 'uid=%s — provision wp_user_meta dinoco_line_uid to enable strict mode',
                    $line_uid
                ) );
            } else {
                // Allowlist populated but UID not in it — refuse admin, fall through to dealer check
                liff_ai_log( sprintf(
                    '[Auth][DENY] admin group matched but uid=%s not in allowlist',
                    $line_uid
                ) );
            }
        }

        // 1b) Fallback: Check WP admin user by LINE UID (user_meta line_user_id)
        if ( empty( $role ) ) {
            $admin_users = get_users( array(
                'meta_key'   => 'line_user_id',
                'meta_value' => $line_uid,
                'role'       => 'administrator',
                'number'     => 1,
            ) );
            if ( ! empty( $admin_users ) ) {
                $role = 'admin';
                $name = $admin_users[0]->display_name;
            }
        }

        // 2) Check distributor CPT by LINE group_id (ACF field 'line_group_id')
        //    LIFF ส่ง group_id มา (จาก liff.getContext().groupId)
        $group_id = sanitize_text_field( $request->get_param( 'group_id' ) );
        if ( empty( $role ) && ! empty( $group_id ) ) {
            $dist_posts = get_posts( array(
                'post_type'      => 'distributor',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array( array(
                    'key'   => 'line_group_id',
                    'value' => $group_id,
                ) ),
            ) );
            if ( ! empty( $dist_posts ) ) {
                $role      = 'dealer';
                $dealer_id = $dist_posts[0]->ID;
                $name      = get_the_title( $dist_posts[0]->ID );
            }
        }

        // 2b) Fallback: check distributor by personal LINE UID (ถ้ามี field)
        if ( empty( $role ) ) {
            $dist_posts = get_posts( array(
                'post_type'      => 'distributor',
                'posts_per_page' => 1,
                'post_status'    => 'publish',
                'meta_query'     => array( array(
                    'key'   => 'owner_line_uid',
                    'value' => $line_uid,
                ) ),
            ) );
            if ( ! empty( $dist_posts ) ) {
                $role      = 'dealer';
                $dealer_id = $dist_posts[0]->ID;
                $name      = get_the_title( $dist_posts[0]->ID );
            }
        }

        // 3) Check WP user linked to distributor (user meta linked_distributor_id)
        if ( empty( $role ) ) {
            $wp_users = get_users( array(
                'meta_key'   => 'line_user_id',
                'meta_value' => $line_uid,
                'number'     => 1,
            ) );
            if ( ! empty( $wp_users ) ) {
                $linked = get_user_meta( $wp_users[0]->ID, 'linked_distributor_id', true );
                if ( $linked && get_post_status( $linked ) === 'publish' ) {
                    $role      = 'dealer';
                    $dealer_id = intval( $linked );
                    $name      = get_the_title( $dealer_id );
                }
            }
        }

        // Not found
        if ( empty( $role ) ) {
            return new WP_REST_Response( array(
                'authorized' => false,
                'message'    => 'ไม่พบสิทธิ์ในระบบ กรุณาติดต่อแอดมิน',
            ), 200 );
        }

        // ── V.1.8 Auto-provision `dinoco_line_uid` for admin (S1 transition helper) ──
        // When role='admin' (strict or fallback) + WP admin exists w/ line_user_id matching
        // this LINE UID but `dinoco_line_uid` not yet set → populate it. Next auth with
        // same UID will land on strict allowlist path automatically (no SQL step needed).
        if ( $role === 'admin' ) {
            $wp_admin_candidates = get_users( array(
                'meta_key'   => 'line_user_id',
                'meta_value' => $line_uid,
                'role'       => 'administrator',
                'number'     => 1,
                'fields'     => array( 'ID' ),
            ) );
            if ( ! empty( $wp_admin_candidates ) ) {
                $admin_uid = intval( $wp_admin_candidates[0]->ID );
                $existing  = get_user_meta( $admin_uid, 'dinoco_line_uid', true );
                if ( empty( $existing ) ) {
                    update_user_meta( $admin_uid, 'dinoco_line_uid', $line_uid );
                    liff_ai_log( sprintf(
                        '[Auth][INFO] Auto-provisioned dinoco_line_uid for WP admin #%d (uid=%s) — strict mode activates on next auth',
                        $admin_uid, $line_uid
                    ) );
                }
            }
        }

        // ── Issue JWT ──
        $payload = array(
            'uid'       => $line_uid,
            'role'      => $role,
            'dealer_id' => $dealer_id,
        );
        $token = '';
        if ( class_exists( 'DINOCO_JWT' ) ) {
            $token = DINOCO_JWT::create( $payload, 7200 );
        } else {
            // Fallback: transient-based token
            $token = bin2hex( random_bytes( 32 ) );
            $payload['created'] = time();
            set_transient( 'liff_ai_sess_' . $token, $payload, 7200 );
        }

        liff_ai_log( sprintf( '[Auth] OK uid=%s role=%s dealer=%d', $line_uid, $role, $dealer_id ) );

        return new WP_REST_Response( array(
            'authorized' => true,
            'token'      => $token,
            'role'       => $role,
            'dealer_id'  => $dealer_id,
            'name'       => $name,
        ), 200 );
    }
}


// ══════════════════════════════════════════════════════════════
// 3. TOKEN VERIFY MIDDLEWARE
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'liff_ai_verify_token' ) ) {
    /**
     * Verify JWT token จาก X-LIFF-AI-Token header
     * @return array|WP_Error  { uid, role, dealer_id } หรือ WP_Error
     */
    function liff_ai_verify_token( WP_REST_Request $request ) {
        // WP admin session fallback
        if ( current_user_can( 'manage_options' ) ) {
            $uid = get_user_meta( get_current_user_id(), 'line_user_id', true );
            return array( 'uid' => $uid ?: 'wp_admin', 'role' => 'admin', 'dealer_id' => 0 );
        }

        $token = $request->get_header( 'X-LIFF-AI-Token' );
        if ( empty( $token ) ) {
            $token = sanitize_text_field( $request->get_param( '_token' ) );
        }
        if ( empty( $token ) ) {
            return new WP_Error( 'no_token', 'ไม่พบ token กรุณาเข้าสู่ระบบใหม่', array( 'status' => 401 ) );
        }

        // JWT verify
        if ( class_exists( 'DINOCO_JWT' ) && strpos( $token, '.' ) !== false ) {
            $payload = DINOCO_JWT::verify( $token );
            if ( $payload && ! empty( $payload['role'] ) ) {
                return array(
                    'uid'       => $payload['uid'] ?? '',
                    'role'      => $payload['role'],
                    'dealer_id' => intval( $payload['dealer_id'] ?? 0 ),
                );
            }
            return new WP_Error( 'invalid_token', 'Token หมดอายุ กรุณาเข้าสู่ระบบใหม่', array( 'status' => 401 ) );
        }

        // Transient fallback
        $clean = preg_replace( '/[^a-f0-9]/i', '', $token );
        if ( empty( $clean ) ) {
            return new WP_Error( 'invalid_token', 'Token ไม่ถูกต้อง', array( 'status' => 401 ) );
        }
        $data = get_transient( 'liff_ai_sess_' . $clean );
        if ( ! $data || empty( $data['role'] ) ) {
            return new WP_Error( 'expired_token', 'Token หมดอายุ กรุณาเข้าสู่ระบบใหม่', array( 'status' => 401 ) );
        }
        return $data;
    }
}


