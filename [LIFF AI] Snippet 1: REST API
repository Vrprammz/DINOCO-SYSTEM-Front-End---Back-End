            return new WP_REST_Response( array( 'success' => false, 'message' => 'บันทึกหมายเหตุไม่สำเร็จ' ), 200 );
        }

        return new WP_REST_Response( array( 'success' => true, 'message' => 'บันทึกหมายเหตุสำเร็จ' ), 200 );
    }
}

