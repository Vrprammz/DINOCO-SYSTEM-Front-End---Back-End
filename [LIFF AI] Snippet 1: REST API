if ( ! function_exists( 'liff_ai_save_line_uid_field' ) ) {
    function liff_ai_save_line_uid_field( $user_id ) {
        if ( ! current_user_can( 'manage_options' ) ) return;
        if ( ! user_can( $user_id, 'administrator' ) ) return;
        if ( empty( $_POST['_liff_ai_link_nonce'] ) ) return;
        if ( ! wp_verify_nonce( $_POST['_liff_ai_link_nonce'], 'liff_ai_link_line_uid_' . $user_id ) ) return;

        if ( ! isset( $_POST['dinoco_line_uid'] ) ) return;
        $raw = trim( sanitize_text_field( wp_unslash( $_POST['dinoco_line_uid'] ) ) );

        // Validate: empty allowed (clear), or "U" + 32+ hex chars
        if ( $raw === '' ) {
            delete_user_meta( $user_id, 'dinoco_line_uid' );
            return;
        }
        if ( ! preg_match( '/^U[0-9a-f]{32,}$/', $raw ) ) {
            // Invalid format — silently skip (form validation client-side catches typical typos)
            return;
        }
        update_user_meta( $user_id, 'dinoco_line_uid', $raw );
        if ( function_exists( 'liff_ai_log' ) ) {
            liff_ai_log( sprintf( '[Admin][INFO] manual provision dinoco_line_uid for user #%d via profile UI', $user_id ) );
        }
    }
}
