// 10. AI AGENT CHAT — POST /liff-ai/v1/agent-ask (V.1.2)
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'liff_ai_rest_agent_ask' ) ) {
    function liff_ai_rest_agent_ask( WP_REST_Request $request ) {
        $question = sanitize_text_field( $request->get_param( 'question' ) );
        if ( empty( $question ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'question required' ), 400 );
        }

        // Proxy ไป Agent /api/agent-ask
        $result = liff_ai_call_agent( 'POST', '/api/agent-ask', array( 'question' => $question ) );

        if ( is_wp_error( $result ) ) {
            liff_ai_log( 'agent-ask error: ' . $result->get_error_message() );
            return new WP_REST_Response( array(
                'success' => false,
                'answer'  => 'ไม่สามารถเชื่อมต่อ AI ได้ กรุณาลองใหม่',
                'agentId' => 'problem-solver',
            ), 200 );
        }

        return new WP_REST_Response( array(
            'success' => true,
            'answer'  => isset( $result['answer'] )  ? $result['answer']  : 'ไม่มีคำตอบ',
            'agentId' => isset( $result['agentId'] ) ? $result['agentId'] : 'problem-solver',
            'stats'   => isset( $result['stats'] )   ? $result['stats']   : null,
        ), 200 );
    }
}

