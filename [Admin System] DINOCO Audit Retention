if ( ! function_exists( 'dinoco_audit_retention_get_stats' ) ) {
    /**
     * Return current audit_log table size + last run summary.
     *
     * @return array
     */
    function dinoco_audit_retention_get_stats() {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_audit_log';

        $exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $exists ) {
            return array(
                'table_exists' => false,
                'row_count'    => 0,
                'size_bytes'   => 0,
                'last_run'     => null,
                'archive'      => array( 'size_bytes' => 0, 'file_count' => 0 ),
            );
        }

        $row_count = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$table}" );
        // Approximate size via INFORMATION_SCHEMA (data + index)
        $size_bytes = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT (data_length + index_length)
             FROM INFORMATION_SCHEMA.TABLES
             WHERE table_schema = DATABASE() AND table_name = %s",
            $table
        ) );

        $last_run_raw = get_option( '_dinoco_audit_retention_last_run', null );
        $last_run = null;
        if ( $last_run_raw ) {
            $decoded = json_decode( $last_run_raw, true );
            if ( is_array( $decoded ) ) $last_run = $decoded;
        }

        $archive = function_exists( 'dinoco_audit_retention_archive_size' )
            ? dinoco_audit_retention_archive_size()
            : array( 'size_bytes' => 0, 'file_count' => 0 );

        return array(
            'table_exists' => true,
            'row_count'    => $row_count,
            'size_bytes'   => $size_bytes,
            'last_run'     => $last_run,
            'archive'      => $archive,
        );
    }
}

/* ============================================================
 * 6. CRON REGISTRATION
 * ============================================================ */

add_action( 'init', function() {
    if ( ! function_exists( 'dinoco_register_cron' ) ) {
        // Health Monitor not loaded — fall back to vanilla wp_schedule_event
        if ( ! wp_next_scheduled( 'dinoco_audit_retention_cron' ) ) {
            wp_schedule_event( time() + 300, 'daily', 'dinoco_audit_retention_cron' );
        }
        add_action( 'dinoco_audit_retention_cron', 'dinoco_audit_retention_handler' );
        return;
    }

    dinoco_register_cron(
        'dinoco_audit_retention_cron',
        'daily',
        'dinoco_audit_retention_handler'
    );
}, 30 );

if ( ! function_exists( 'dinoco_audit_retention_handler' ) ) {
    /**
     * Cron handler — invokes runner with dry_run=false.
     */
    function dinoco_audit_retention_handler() {
        if ( function_exists( 'dinoco_audit_retention_run' ) ) {
            dinoco_audit_retention_run( false );
        }
    }
}

/* ============================================================
 * 7. REST ENDPOINTS — admin manual trigger + status
 * ============================================================ */

add_action( 'rest_api_init', function() {
    register_rest_route( 'dinoco/v1', '/audit/retention/status', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_audit_retention_rest_status',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
    ) );

    register_rest_route( 'dinoco/v1', '/audit/retention/run', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_audit_retention_rest_run',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
        'args'                => array(
            'dry_run' => array( 'default' => false, 'sanitize_callback' => 'rest_sanitize_boolean' ),
        ),
    ) );
} );

if ( ! function_exists( 'dinoco_audit_retention_rest_status' ) ) {
    function dinoco_audit_retention_rest_status( $request ) {
        return rest_ensure_response( dinoco_audit_retention_get_stats() );
    }
}

if ( ! function_exists( 'dinoco_audit_retention_rest_run' ) ) {
    function dinoco_audit_retention_rest_run( $request ) {
        $uid = get_current_user_id();
        // Rate limit 3/min/user (destructive — DELETEs from audit_log)
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'audit_retention_u' . $uid, 3, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 3/min)', array( 'status' => 429 ) );
            }
        }
        $dry_run = (bool) $request->get_param( 'dry_run' );

        // Round 57 — Idempotency wrap on destructive DELETE batch. Admin "รัน Retention"
        // double-click on slow chunked DELETE → 2× DELETE storm (idempotent after 1st but
        // audit row spam). dry_run vs commit distinct via body hash.
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco/v1::audit-retention-run';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'action'        => 'audit-retention-run',
                'dry_run'       => (bool) $dry_run,
                'actor_user_id' => (int) $uid,
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) return $cached;
            if ( is_array( $cached ) ) { unset( $cached['_idem_code'] ); return rest_ensure_response( $cached ); }
        }

        $result = dinoco_audit_retention_run( $dry_run );

        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) && is_array( $result ) ) {
            dinoco_idempotency_store( $idem_key, $idem_namespace, $idem_body, array_merge( $result, array( '_idem_code' => 200 ) ), 200 );
        }
        return rest_ensure_response( $result );
    }
}
