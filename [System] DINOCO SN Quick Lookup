        <script>
        (function() {
            var REST_BASE = <?php echo wp_json_encode( $rest_url ); ?>;
            var NONCE = <?php echo wp_json_encode( $nonce ); ?>;
            var input = document.getElementById('dnc-scq-input');
            var goBtn = document.getElementById('dnc-scq-go');
            var result = document.getElementById('dnc-scq-result');

            // Initial empty state
            result.innerHTML = '<div class="dnc-scq-result-empty">พิมพ์ S/N ด้านบนเพื่อค้นหา</div>';

            function escapeHtml(s) {
                var d = document.createElement('div');
                d.textContent = s == null ? '' : String(s);
                return d.innerHTML;
            }

            function fmtDate(s) {
                if (!s) return '—';
                try {
                    var d = new Date(String(s).replace(' ', 'T'));
                    if (isNaN(d.getTime())) return s;
                    return d.toLocaleString('th-TH', { hour12: false });
                } catch (e) { return s; }
            }

            function classifyStatus(status) {
                if (status === 'registered' || status === 'claimed') return 'active';
                if (status === 'voided' || status === 'recalled') return 'danger';
                if (status === 'in_pool' || status === 'reserved') return 'inactive';
                return 'warning'; // allocated_to_order, shipped, transferred, replaced
            }

            function statusLabelTh(status) {
                var map = {
                    'reserved':           'สำรองไว้ (ยังไม่ใช้)',
                    'in_pool':            'พร้อมใช้ (ในคลัง)',
                    'allocated_to_order': 'จองให้ออเดอร์',
                    'shipped':            'ส่งออกแล้ว (กำลังเดินทาง)',
                    'registered':         'ลงทะเบียนแล้ว ✓',
                    'claimed':            'กำลังเคลม',
                    'replaced':           'เปลี่ยนใหม่แล้ว',
                    'transferred':        'โอนเจ้าของแล้ว',
                    'voided':             'ยกเลิก ❌',
                    'recalled':           'เรียกคืน ⚠️',
                };
                return map[status] || status;
            }

            function doLookup() {
                var sn = (input.value || '').trim().toUpperCase();
                if (!sn) {
                    result.innerHTML = '<div class="dnc-scq-result-empty">พิมพ์ S/N ด้านบน</div>';
                    return;
                }
                if (!/^[A-Z0-9]{3,40}$/.test(sn)) {
                    result.innerHTML = '<div class="dnc-scq-result-not-found">รูปแบบ S/N ไม่ถูกต้อง<br><small>ตัวอย่าง: DNCSS0001234</small></div>';
                    return;
                }
                input.value = sn;
                result.innerHTML = '<div class="dnc-scq-result-empty">⏳ กำลังค้นหา…</div>';

                // V.0.2 audit fix (P0-1): use /sc-lookup which accepts warehouse
                // capability. Old /sn/{sn} required admin → 403 for SC users.
                fetch(REST_BASE + '/sc-lookup/' + encodeURIComponent(sn), {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin',
                })
                .then(function(r) {
                    return r.json().then(function(j) { return { ok: r.ok, status: r.status, data: j }; });
                })
                .then(function(res) {
                    if (!res.ok) {
                        if (res.status === 404) {
                            result.innerHTML = '<div class="dnc-scq-result-not-found">' +
                                '<h3>❌ ไม่พบ S/N</h3>' +
                                '<p>S/N <code>' + escapeHtml(sn) + '</code> ไม่อยู่ในระบบ</p>' +
                                '<small>อาจเป็นเพลทปลอม หรือยังไม่ได้รับเข้าระบบ</small>' +
                            '</div>';
                            return;
                        }
                        result.innerHTML = '<div class="dnc-scq-result-not-found">' +
                            '<h3>เกิดข้อผิดพลาด</h3>' +
                            '<p>' + escapeHtml(res.data.message || res.data.code || 'unknown') + '</p>' +
                        '</div>';
                        return;
                    }
                    if (!res.data || !res.data.sn) {
                        result.innerHTML = '<div class="dnc-scq-result-not-found">ไม่พบข้อมูล</div>';
                        return;
                    }
                    var p = res.data.sn;
                    var cls = classifyStatus(p.status);
                    var html = '<div class="dnc-scq-result-found">' +
                        '<h3>' + escapeHtml(p.sn) + '</h3>' +
                        '<span class="dnc-scq-status dnc-scq-status-' + cls + '">' +
                            escapeHtml(statusLabelTh(p.status)) +
                        '</span>' +
                        '<div class="dnc-scq-detail-grid">' +
                            '<div class="dnc-scq-detail-label">SKU</div>' +
                            '<div class="dnc-scq-detail-val">' + escapeHtml(p.linked_sku || '—') + '</div>' +
                            '<div class="dnc-scq-detail-label">Top SET</div>' +
                            '<div class="dnc-scq-detail-val">' + escapeHtml(res.data.top_set_sku || '—') + '</div>' +
                            '<div class="dnc-scq-detail-label">Batch</div>' +
                            '<div class="dnc-scq-detail-val">' + escapeHtml(p.batch_code || '—') + '</div>' +
                            '<div class="dnc-scq-detail-label">รับเข้าคลัง</div>' +
                            '<div class="dnc-scq-detail-val">' + escapeHtml(fmtDate(p.received_at)) + '</div>' +
                            '<div class="dnc-scq-detail-label">ลงทะเบียน</div>' +
                            '<div class="dnc-scq-detail-val">' + escapeHtml(fmtDate(p.registered_at)) + '</div>' +
                        '</div>';

                    // Customer info if available — masked unless view_pii
                    if (res.data.customer) {
                        html += '<div style="margin-top:12px;padding-top:12px;border-top:1px solid #e5e7eb;">' +
                            '<div class="dnc-scq-detail-label">ลูกค้า</div>' +
                            '<div class="dnc-scq-detail-val">' +
                                escapeHtml(res.data.customer.display_name || '—') +
                                ' <small style="color:#9ca3af;">' + escapeHtml(res.data.customer.email || '') + '</small>' +
                            '</div></div>';
                    }

                    // Action hint based on status
                    if (p.status === 'voided' || p.status === 'recalled') {
                        html += '<div style="margin-top:12px;padding:12px;background:#fee2e2;border-radius:8px;color:#991b1b;font-size:13px;">' +
                            '⚠️ S/N นี้อยู่ในสถานะ <strong>' + statusLabelTh(p.status) + '</strong> — แจ้งให้ลูกค้าทราบ + escalate to admin' +
                        '</div>';
                    } else if (p.status === 'in_pool' || p.status === 'reserved') {
                        html += '<div style="margin-top:12px;padding:12px;background:#dbeafe;border-radius:8px;color:#1e40af;font-size:13px;">' +
                            'ℹ️ ลูกค้ายังไม่ได้ลงทะเบียน — แนะนำให้ลูกค้าสแกน QR ที่ตัวสินค้าเอง' +
                        '</div>';
                    } else if (p.status === 'shipped') {
                        html += '<div style="margin-top:12px;padding:12px;background:#fef3c7;border-radius:8px;color:#b45309;font-size:13px;">' +
                            '📦 ส่งออกแล้ว แต่ลูกค้ายังไม่ activate — ขอเอกสารใบเสร็จ + ช่วยลูกค้าลงทะเบียน' +
                        '</div>';
                    }

                    html += '</div>';
                    result.innerHTML = html;
                })
                .catch(function(e) {
                    result.innerHTML = '<div class="dnc-scq-result-not-found">' +
                        '<h3>Network error</h3>' +
                        '<p>' + escapeHtml(e.message) + '</p>' +
                    '</div>';
                });
            }

            goBtn.addEventListener('click', doLookup);
            input.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    doLookup();
                }
            });
            // USB barcode scanner support — auto-submit on rapid Enter
            input.focus();
        })();
        </script>
        <?php
        return ob_get_clean();
    }
