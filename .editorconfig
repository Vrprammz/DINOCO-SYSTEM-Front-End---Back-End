# EditorConfig — cross-IDE formatting consistency
# https://editorconfig.org
#
# Most editors (VSCode, JetBrains, vim, Sublime) auto-detect this.
# Eliminates tab-vs-space and line-ending churn in PRs.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# JS/TS/JSON/MD/YAML — 4 spaces matches existing liff-src/ style
[*.{js,ts,jsx,tsx,mjs,cjs,json,html,css}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # MD line breaks need trailing spaces

# PHP — WordPress/DINOCO snippets use tabs (legacy convention)
# But there's no <?php tag at line 1; not really PHP from EditorConfig
# perspective. Leave indent_style default.
[*.php]
indent_style = tab
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Makefile requires tabs
[Makefile]
indent_style = tab

# Lockfiles + minified — leave as-is
[{package-lock.json,composer.lock,*.min.js,*.min.css}]
insert_final_newline = false
trim_trailing_whitespace = false
