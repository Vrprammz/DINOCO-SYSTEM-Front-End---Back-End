            'profile' => 'ไม่สามารถดึงข้อมูลโปรไฟล์ได้',
        );
        $err_text = isset($err_messages[$login_err]) ? $err_messages[$login_err] : 'เกิดข้อผิดพลาด';
        echo '<div style="background:#fee;border:1px solid #c00;padding:15px;border-radius:8px;margin:15px;text-align:center;font-size:14px;">';
        echo '<strong>' . esc_html($err_text) . '</strong><br>กรุณาลองใหม่อีกครั้ง หรือติดต่อฝ่ายสนับสนุน';
        echo '</div>';
    }

