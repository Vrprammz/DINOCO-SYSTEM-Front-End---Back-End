// -------------------------------------------------------------------
// PART 2: The REAL Callback Processor (Instant UI Rendering + AJAX)
// -------------------------------------------------------------------
add_action( 'template_redirect', 'dinoco_master_line_callback' );

function dinoco_master_line_callback() {
    
    // 1. เช็คว่าเป็นหน้า Callback
    if ( ! is_page( 'callback-login' ) && strpos( $_SERVER['REQUEST_URI'], 'callback-login' ) === false ) { return; }
    
    // =================================================================
    // NEW LOGIC: INSTANT UI RENDER (แก้ปัญหาหน้าขาว)
    // =================================================================
    
    // ถ้ามี Code มา แต่ไม่มี Flag Process -> แสดง Loading ก่อนเลย
    if ( isset( $_GET['code'] ) && ! isset( $_GET['dinoco_process'] ) ) {
        
        $current_url = home_url( add_query_arg( NULL, NULL ) );
        $process_url = add_query_arg( 'dinoco_process', '1', $current_url );
        $moto_hero   = 'https://dinoco.in.th/wp-content/uploads/2026/02/xllogin1.webp'; 
        $text_logo   = 'https://dinoco.in.th/wp-content/uploads/elementor/thumbs/800x800-riocrwy2320s7fp9ckfr60v72hcgkotli7ipsiol48.png';

        nocache_headers();
        ?>
        <!DOCTYPE html>
        <html lang="th">
        <head>
            <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>กำลังเข้าสู่ระบบ...</title>
            <style>
                body { margin: 0; padding: 0; height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; background: linear-gradient(180deg, #FFFFFF 0%, #F4F6F9 100%); font-family: 'Noto Sans Thai', 'Prompt', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; overflow: hidden; }
                .dinoco-loader-logo { width: 100px; height: auto; margin-bottom: 20px; animation: pulse 1.5s infinite ease-in-out; z-index: 10; }
                .loading-text { font-size: 16px; color: #666; font-weight: 500; z-index: 10; }
                .dinoco-bg-moto { position: absolute; bottom: 0; right: 0; width: 100%; height: 60vh; display: flex; justify-content: flex-end; align-items: flex-end; pointer-events: none; opacity: 0; animation: fadeIn 1s forwards; }
                .dinoco-bg-moto img { width: auto; max-width: 100%; height: auto; max-height: 50vh; opacity: 0.15; filter: grayscale(100%); transform: translateX(20%); }
                @keyframes pulse { 0% { transform: scale(0.95); opacity: 0.8; } 50% { transform: scale(1.05); opacity: 1; } 100% { transform: scale(0.95); opacity: 0.8; } }
                @keyframes fadeIn { to { opacity: 1; } }
            </style>
        </head>
        <body>
            <div class="dinoco-bg-moto"><img src="<?php echo esc_url($moto_hero); ?>"></div>
            <img src="<?php echo esc_url($text_logo); ?>" class="dinoco-loader-logo">
            <div class="loading-text">กำลังยืนยันตัวตน...</div>
            <script>
                fetch(<?php echo wp_json_encode( $process_url ); ?>, { credentials: 'same-origin' })
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    if (data.success && data.data && data.data.redirect) {
                        window.location.replace(data.data.redirect);
                    } else {
                        console.error('LINE callback error:', data);
                        document.querySelector('.loading-text').textContent = 'เกิดข้อผิดพลาด: ' + (data.data && data.data.message ? data.data.message : 'Unknown');
                        setTimeout(function() { window.location.replace("<?php echo home_url('/warranty/'); ?>"); }, 3000);
                    }
                })
                .catch(function(e) {
                    console.error('LINE callback fetch error:', e);
                    document.querySelector('.loading-text').textContent = 'เชื่อมต่อไม่สำเร็จ กำลังลองใหม่...';
                    setTimeout(function() { window.location.replace("<?php echo home_url('/warranty/'); ?>"); }, 3000);
                });
            </script>
        </body>
        </html>
        <?php
        exit;
    }

    // =================================================================
    // PROCESS LOGIC (AJAX Process)
    // =================================================================
    
    nocache_headers();
    if ( ! defined( 'DONOTCACHEPAGE' ) ) { define( 'DONOTCACHEPAGE', true ); }

    // Try constants first (wp-config.php), then fallback to wp_options
    $client_id     = defined( 'DINOCO_LINE_CHANNEL_ID' )     ? DINOCO_LINE_CHANNEL_ID     : get_option( 'dinoco_line_channel_id', '' );
    $client_secret = defined( 'DINOCO_LINE_CHANNEL_SECRET' ) ? DINOCO_LINE_CHANNEL_SECRET : get_option( 'dinoco_line_channel_secret', '' );
    $redirect_uri  = defined( 'DINOCO_LINE_REDIRECT_URI' )   ? DINOCO_LINE_REDIRECT_URI   : get_option( 'dinoco_line_redirect_uri', 'https://www.dinoco.in.th/callback-login' );

    if ( empty( $client_id ) || empty( $client_secret ) ) {
        error_log( '[DINOCO LINE] OAuth not configured. CHANNEL_ID defined=' . ( defined('DINOCO_LINE_CHANNEL_ID') ? 'yes' : 'no' ) . ' CHANNEL_SECRET defined=' . ( defined('DINOCO_LINE_CHANNEL_SECRET') ? 'yes' : 'no' ) );
        if ( isset( $_GET['dinoco_process'] ) ) {
            wp_send_json_error( array( 'message' => 'LINE OAuth not configured — กรุณาตรวจสอบ wp-config.php' ) );
        }
        wp_safe_redirect( home_url( '/warranty/' ) ); exit;
    }

    // Handle LINE error responses (user denied, expired session, etc.)
    if ( isset( $_GET['error'] ) ) {
        $line_error = sanitize_text_field( $_GET['error'] );
        $line_error_desc = isset( $_GET['error_description'] ) ? sanitize_text_field( $_GET['error_description'] ) : '';
        error_log( '[DINOCO LINE] LINE returned error: ' . $line_error . ' — ' . $line_error_desc );
        if ( isset( $_GET['dinoco_process'] ) ) {
            wp_send_json_error( array( 'message' => 'LINE Login Error: ' . $line_error ) );
        }
        wp_safe_redirect( home_url( '/warranty/?login_error=denied' ) ); exit;
    }

    // Guard: code is required
    if ( empty( $_GET['code'] ) ) {
        error_log( '[DINOCO LINE] No code parameter — user may have visited callback directly' );
        if ( isset( $_GET['dinoco_process'] ) ) {
            wp_send_json_error( array( 'message' => 'ไม่พบ code จาก LINE กรุณาลองเข้าสู่ระบบใหม่' ) );
        }
        wp_safe_redirect( home_url( '/warranty/' ) ); exit;
    }

    $code  = sanitize_text_field( $_GET['code'] );
    $state = isset( $_GET['state'] ) ? sanitize_text_field( $_GET['state'] ) : '';

    // V.30.6 — Audit I1 v3: strict state handling (no grandfather window).
    // Policy:
    //   (a) Empty state                 → HARD REJECT
    //   (b) 32-char transient token     → single-use verify; delete on success
    //   (c) Raw WARRANTY serial pattern → accepted (legacy direct-URL from QR codes)
    //   (d) Anything else (incl. legacy literals GENERAL_LOGIN/WARRANTY_PAGE) → HARD REJECT
    $state_payload = null;

    if ( empty( $state ) ) {
        error_log( '[DINOCO LINE] OAuth callback with empty state → hard reject' );
        wp_safe_redirect( home_url( '/warranty/?login_error=no_state' ) );
        exit;
    }

    $state_payload = get_transient( 'dinoco_line_state_' . $state );
    if ( $state_payload ) {
        delete_transient( 'dinoco_line_state_' . $state ); // single-use
    } else {
        // Not a transient → must be raw WARRANTY serial (4-32 alnum+dash).
        // Literal legacy states GENERAL_LOGIN/WARRANTY_PAGE happen to match the length regex,
        // so explicitly block them.
        $blocked_literals = array( 'GENERAL_LOGIN', 'WARRANTY_PAGE' );
        if ( in_array( $state, $blocked_literals, true )
             || ! preg_match( '/^[A-Z0-9\-]{4,32}$/i', $state ) ) {
            error_log( '[DINOCO LINE] Invalid/expired OAuth state rejected: ' . $state );
            wp_safe_redirect( home_url( '/warranty/?login_error=state' ) );
            exit;
        }
    }

    $token_url = 'https://api.line.me/oauth2/v2.1/token';
    $response  = wp_remote_post( $token_url, array(
        'body' => array('grant_type' => 'authorization_code', 'code' => $code, 'redirect_uri' => $redirect_uri, 'client_id' => $client_id, 'client_secret' => $client_secret),
        'timeout' => 30
    ));

    if ( is_wp_error( $response ) ) {
        error_log( '[DINOCO LINE] Token request failed: ' . $response->get_error_message() );
        if ( isset( $_GET['dinoco_process'] ) ) {
            wp_send_json_error( array( 'message' => 'เชื่อมต่อ LINE ไม่สำเร็จ กรุณาลองใหม่' ) );
        } else {
            wp_safe_redirect( home_url( '/warranty/?login_error=failed' ) );
            exit;
        }
    }
    $token_data = json_decode( wp_remote_retrieve_body( $response ), true );
    if ( ! isset( $token_data['access_token'] ) ) {
        error_log( '[DINOCO LINE] Invalid token response: ' . wp_remote_retrieve_body( $response ) );
        if ( isset( $_GET['dinoco_process'] ) ) {
            wp_send_json_error( array( 'message' => 'Invalid Token — ' . ( isset($token_data['error_description']) ? $token_data['error_description'] : 'Unknown error' ) ) );
        } else {
            wp_safe_redirect( home_url( '/warranty/?login_error=failed' ) );
            exit;
        }
    }

    // M14: explicit timeout — default WP (5s) is borderline for LINE profile fetch on slow networks,
    // and this call sits in the synchronous OAuth redirect path (user is staring at a spinner).
    $profile_res = wp_remote_get( 'https://api.line.me/v2/profile', array(
        'headers' => array( 'Authorization' => 'Bearer ' . $token_data['access_token'] ),
        'timeout' => 10,
    ) );
    $profile      = json_decode( wp_remote_retrieve_body( $profile_res ), true );

    // Bug fix V.30.3: null-check LINE profile response
    if ( empty( $profile ) || ! isset( $profile['userId'] ) ) {
        error_log( '[DINOCO LINE] Profile response invalid or missing userId' );
        if ( isset( $_GET['dinoco_process'] ) ) {
            wp_send_json_error( array( 'message' => 'ไม่สามารถดึงข้อมูล LINE Profile ได้' ) );
        } else {
            wp_safe_redirect( home_url( '/warranty/?login_error=profile' ) );
            exit;
        }
    }

    // V.30.4 — Audit I8: LINE profile name may contain HTML/script. Sanitize + length cap.
    $line_user_id = sanitize_text_field( $profile['userId'] );
    $display_name = sanitize_text_field( $profile['displayName'] ?? '' );
    if ( mb_strlen( $display_name ) > 60 ) { $display_name = mb_substr( $display_name, 0, 60 ); }
    if ( empty( $display_name ) ) { $display_name = 'LINE User'; }
    $picture_url  = isset( $profile['pictureUrl'] ) ? esc_url_raw( $profile['pictureUrl'] ) : '';

    $user_query = get_users( array('meta_key' => 'line_user_id', 'meta_value' => $line_user_id, 'number' => 1) );
    $user_id = 0; $is_new_user = false;

    if ( ! empty( $user_query ) ) { $user_id = $user_query[0]->ID; }
    else {
        $user_id = wp_create_user( 'line_' . substr( $line_user_id, 0, 8 ) . '_' . time(), wp_generate_password( 16, true ), $line_user_id . '@line.login.dinoco' );
        if ( is_wp_error( $user_id ) ) {
            error_log( '[DINOCO LINE] wp_create_user failed: ' . $user_id->get_error_message() );
            wp_send_json_error( array( 'message' => 'ไม่สามารถสร้างบัญชีได้ กรุณาลองใหม่อีกครั้ง' ) );
        }
        update_user_meta( $user_id, 'line_user_id', $line_user_id );
        wp_update_user( array( 'ID' => $user_id, 'display_name' => $display_name ) );
        $is_new_user = true;
    }

    if ( $user_id && ! is_wp_error( $user_id ) ) {
        update_user_meta( $user_id, 'line_picture_url', $picture_url );
        if ( function_exists( 'update_field' ) ) { update_field( 'line_picture_url', $picture_url, 'user_' . $user_id ); }

        wp_set_current_user( $user_id );
        wp_set_auth_cookie( $user_id, true );
        do_action( 'wp_login', get_userdata( $user_id )->user_login, get_userdata( $user_id ) );

        $redirect_params = array();
        if ( $is_new_user ) { $redirect_params['welcome'] = 'new'; } else { $redirect_params['welcome'] = 'back'; }
        // V.30.7 — Audit L1: read intended serial from verified state payload, or fall through to raw serial.
        // Legacy literals GENERAL_LOGIN/WARRANTY_PAGE are already blocked at line 301-307 upstream,
        // so they can never reach this branch — removed dead `!== literal` guards.
        if ( is_array( $state_payload ) && ! empty( $state_payload['serial'] ) ) {
            $redirect_params['register_serial'] = $state_payload['serial'];
        } elseif ( $state && ! $state_payload ) {
            // Raw WARRANTY serial (regex-validated upstream at line 310)
            $redirect_params['register_serial'] = $state;
        }

        $redirect_to = add_query_arg( $redirect_params, home_url( '/member-dashboard/' ) );
        
        // Respond with JSON for the JS redirect
        wp_send_json_success( array( 'redirect' => $redirect_to ) );
    }
}

