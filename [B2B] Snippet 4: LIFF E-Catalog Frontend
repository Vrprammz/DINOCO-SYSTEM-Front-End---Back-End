    <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;"><span style="background:#334155;color:#cbd5e1;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;">2</span><span style="font-size:13px;color:#cbd5e1;">พิมพ์ <span style="border:1px solid #475569;padding:3px 10px;border-radius:4px;font-weight:600;font-size:12px;color:#e2e8f0;">@DINOCO B2B SYSTEM</span></span></div>
    <div style="display:flex;align-items:center;gap:12px;"><span style="background:#334155;color:#cbd5e1;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;">3</span><span style="font-size:13px;color:#cbd5e1;">ระบบจะส่งเมนูใหม่ให้อัตโนมัติ</span></div>
