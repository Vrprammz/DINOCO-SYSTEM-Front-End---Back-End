          }else if(act==='minus'){
            typedQty = Math.max(1, typedQty - 1);
            if(input) input.value = typedQty;
          }else if(act==='add'){
            var dup=checkCartDuplicate(sku);
            if(dup&&dup.hasConflict){showCartDuplicateBlock(dup);return;}
            state.cart[sku]=(state.cart[sku]||0)+typedQty;
            saveCart();updateCartBar();
            renderSetDetailItems(product);
            if(product)updateSetDetailAddBtn(product);
            if(typeof toast==='function') toast('+' + typedQty + ' เพิ่มแล้ว');
          }
        });
      });
      if(input){
        input.addEventListener('change',function(){
          var v = Math.max(1, Math.min(999, parseInt(this.value, 10) || 1));
          this.value = v;
        });
        input.addEventListener('keydown',function(e){
          if(e.key==='Enter'){
            e.preventDefault();
            var addBtn = wrap.querySelector('[data-stepact="add"]');
            if(addBtn) addBtn.click();
          }
        });
      }
    });

    // V.32.4: collapsed "+ สั่งแยก" → reveal stepper + add 1 to cart
    container.querySelectorAll('.b2b-cat-sub-add-btn').forEach(function(btn){
      btn.addEventListener('click',function(e){
        e.stopPropagation();
        var addSku = btn.getAttribute('data-subaddsku');
        if(!addSku) return;
        var dup = checkCartDuplicate(addSku);
        if(dup && dup.hasConflict){ showCartDuplicateBlock(dup); return; }
        state.cart[addSku] = (state.cart[addSku] || 0) + 1;
        saveCart(); updateCartBar();
        renderSetDetailItems(product);
        if(product) updateSetDetailAddBtn(product);
        // Find name for toast
        var childName = addSku;
        (product && product.children_detail || []).forEach(function(ch){
          if(ch.sku === addSku) childName = ch.name;
          (ch.grandchildren || []).forEach(function(gc){ if(gc.sku === addSku) childName = gc.name; });
        });
        if(typeof toast === 'function') toast('+1 ' + String(childName).substring(0,20));
      });
    });
  }

  /* V.32.2: Qty stepper builder (typable input + − + + "+ เพิ่ม") */
  /* V.32.4: collapsedDefault=true → ซ่อน stepper ถ้า qty=0 + แสดงปุ่ม "+ สั่งแยก" (ใช้กับ sub-items ใน SET Detail) */
  function buildB2bStepper(sku, currentQty, collapsedDefault){
    var safeSku = esc(sku);
    var q = (typeof currentQty === 'number' && currentQty > 0) ? currentQty : 1;
    var inCart = (state.cart[sku] && state.cart[sku] > 0);
    // V.32.4: collapsed mode — ถ้าไม่มีในตะกร้า → แสดงปุ่ม "+ สั่งแยก"
    if (collapsedDefault && !inCart) {
      return '<button type="button" class="b2b-cat-sub-add-btn" data-subaddsku="'+safeSku+'">+ สั่งแยก</button>';
    }
    return '<div class="b2b-qty-stepper" data-stepsku="'+safeSku+'">'
      + '<div class="b2b-qty-stepper-group">'
      + '<button type="button" class="b2b-qty-stepper-btn" data-stepact="minus" aria-label="ลด">−</button>'
      + '<input type="number" class="b2b-qty-stepper-input" value="'+q+'" min="1" max="999" inputmode="numeric" data-stepact="input">'
      + '<button type="button" class="b2b-qty-stepper-btn" data-stepact="plus" aria-label="เพิ่ม">+</button>'
      + '</div>'
      + '<button type="button" class="b2b-qty-stepper-add'+(inCart?' in-cart':'')+'" data-stepact="add">'
      + (inCart ? ('+เพิ่ม ('+state.cart[sku]+')') : '+ เพิ่ม')
      + '</button>'
      + '</div>';
  }

  /* ═══ CART DUPLICATE DETECTION (V.32.1 — H-10 block instead of warn) ═══ */
  function checkCartDuplicate(addingSku){
    // Check if the SKU being added is a child/grandchild of a SET already in cart (or vice versa)
    // Returns { hasConflict: bool, type: 'set_has_child'|'child_in_set', parentName: string, childName: string }
    var result={hasConflict:false,type:'',parentName:'',childName:''};
    var cartSkus=Object.keys(state.cart).filter(function(k){return state.cart[k]>0;});
    if(!cartSkus.length)return result;

    for(var i=0;i<state.products.length;i++){
      var p=state.products[i];
      if(!p.is_set||!p.children_detail)continue;
      var setInCart=cartSkus.indexOf(p.sku)>=0;
      var childSkus=[];
      (p.children_detail||[]).forEach(function(ch){
        childSkus.push(ch.sku);
        (ch.grandchildren||[]).forEach(function(gc){childSkus.push(gc.sku);});
      });

      // Case 1: Adding a child/grandchild SKU while the parent SET is in cart
      if(setInCart&&childSkus.indexOf(addingSku)>=0){
        var childName=addingSku;
        (p.children_detail||[]).forEach(function(ch){
          if(ch.sku===addingSku)childName=ch.name;
          (ch.grandchildren||[]).forEach(function(gc){if(gc.sku===addingSku)childName=gc.name;});
        });
        result.hasConflict=true;
        result.type='child_in_set';
        result.parentName=p.name;
        result.childName=childName;
        return result;
      }

      // Case 2: Adding the parent SET while a child/grandchild is already in cart
      if(addingSku===p.sku){
        for(var j=0;j<childSkus.length;j++){
          var cs=childSkus[j];
          if(cartSkus.indexOf(cs)>=0){
            var csName=cs;
            (p.children_detail||[]).forEach(function(ch){
              if(ch.sku===cs)csName=ch.name;
              (ch.grandchildren||[]).forEach(function(gc){if(gc.sku===cs)csName=gc.name;});
            });
            result.hasConflict=true;
            result.type='set_has_child';
            result.parentName=p.name;
            result.childName=csName;
            return result;
          }
        }
      }
    }
    return result;
  }

