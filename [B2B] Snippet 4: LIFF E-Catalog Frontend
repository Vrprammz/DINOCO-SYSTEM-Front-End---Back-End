  /* ═══ CART BAR ═══ */
  function updateCartBar(){
    var keys=Object.keys(state.cart),count=0,total=0;
    keys.forEach(function(sku){var q=state.cart[sku];if(!q)return;count+=q;var p=state.products.find(function(x){return x.sku===sku;});if(p)total+=p.dealer_price*q;});
    document.getElementById('cartCount').textContent=count;
    document.getElementById('cartTotal').textContent='฿'+fmt(total);
    document.getElementById('cartBar').classList.toggle('visible',count>0&&state.activeTab==='catalog');
    document.getElementById('cartSubmit').textContent=state.editMode?'ส่งรายการแก้ไข':'สั่งซื้อ';
  }

  /* ═══ CART SUMMARY MODAL ═══ */
  document.getElementById('cartSubmit').addEventListener('click',function(){
    var items=[];
    Object.keys(state.cart).forEach(function(sku){var q=state.cart[sku];if(!q)return;var p=state.products.find(function(x){return x.sku===sku;});if(p)items.push({sku:p.sku,name:p.name,qty:q,price:p.dealer_price});});
    if(!items.length){toast('กรุณาเลือกสินค้าอย่างน้อย 1 รายการ');return;}
    showCartModal(items);
  });

  function showCartModal(items){
    var body=document.getElementById('cartModalBody');
    var gt=0;var h='';
    items.forEach(function(i){
      var lt=i.price*i.qty;gt+=lt;
      h+='<div class="b2b-cat-modal-item"><div class="b2b-cat-modal-item-info"><div class="b2b-cat-modal-item-name">'+esc(i.name)+'</div>';
      h+='<div class="b2b-cat-modal-item-detail">'+esc(i.sku)+' x '+i.qty+' @ ฿'+fmt(i.price)+'</div></div>';
      h+='<div class="b2b-cat-modal-item-total">฿'+fmt(lt)+'</div></div>';
    });
    h+='<div class="b2b-cat-note-section"><div class="b2b-cat-note-label">หมายเหตุ (ถ้ามี)</div>';
    h+='<textarea class="b2b-cat-note-input" id="cartNoteInput" placeholder="เช่น ส่งด่วน, แพ็คแยก..."></textarea></div>';
    body.innerHTML=h;
    document.getElementById('cartModalTotal').textContent='฿'+fmt(gt);
    document.getElementById('cartConfirmBtn').textContent=state.editMode?'ยืนยันแก้ไข':'ยืนยันสั่งสินค้า';
    document.getElementById('cartModal').classList.add('show');
  }

  document.getElementById('cartModalClose').addEventListener('click',function(){document.getElementById('cartModal').classList.remove('show');});
  document.getElementById('cartModal').addEventListener('click',function(e){if(e.target===this)this.classList.remove('show');});

  /* ═══ CONFIRM ORDER ═══ */
  document.getElementById('cartConfirmBtn').addEventListener('click',function(){
    this.disabled=true;
    document.getElementById('cartModal').classList.remove('show');
    var items=[];
    Object.keys(state.cart).forEach(function(sku){var q=state.cart[sku];if(!q)return;var p=state.products.find(function(x){return x.sku===sku;});if(p)items.push({sku:p.sku,name:p.name,qty:q,price:p.dealer_price});});
    if(!items.length)return;
    var note=(document.getElementById('cartNoteInput')||{}).value||'';
    var overlay=document.getElementById('submitOverlay');
    overlay.classList.add('show');
    document.getElementById('submitSpinner').style.display='';
    document.getElementById('submitMsg').innerHTML='กำลังส่งคำสั่งซื้อ...<br>กรุณาอย่าปิดหน้านี้';
    var cartItems=items.map(function(i){return{sku:i.sku,name:i.name,qty:i.qty,price:i.price};});
    authFetch(REST+'place-order',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({items:cartItems,note:note||'',edit_ticket:state.editMode?state.editTicket:0})
    }).then(function(r){return r.json();}).then(function(d){
      if(d.success){
        document.getElementById('submitSpinner').style.display='none';
        document.getElementById('submitMsg').innerHTML='<div class="success">✅</div>ส่งออเดอร์เรียบร้อย!';
        state.cart={};saveCart();state.editMode=false;renderProducts();updateCartBar();
        document.getElementById('editBanner').style.display='none';
        setTimeout(function(){overlay.classList.remove('show');liff.closeWindow();},3000);
      }else{throw new Error(d.message||'Order failed');}
    }).catch(function(e){
      overlay.classList.remove('show');
      document.getElementById('cartConfirmBtn').disabled=false;
      toast(e.message);
    });
  });

  /* ═══ RECOMMENDED SKUs ═══ */
  function loadRecommended(){
    authFetch(REST+'order-history')
    .then(function(r){return r.json();})
    .then(function(d){
      if(!d.success)return;
      state.recommendedSkus=d.recommended_skus||[];
      renderRecommendedChips();
    }).catch(function(){});
  }

  function renderRecommendedChips(){
    var sec=document.getElementById('freqSection');
    var el=document.getElementById('freqChips');
    if(!state.recommendedSkus.length||!state.products.length){sec.style.display='none';return;}
    el.innerHTML='';var shown=0;
    state.recommendedSkus.forEach(function(sku){
      var p=state.products.find(function(x){return x.sku.toUpperCase()===sku.toUpperCase();});
      if(!p||shown>=6)return;shown++;
      var chip=document.createElement('div');chip.className='b2b-cat-freq-chip';
      chip.innerHTML='<span class="b2b-cat-freq-name">'+esc(p.name.length>16?p.name.substr(0,16)+'...':p.name)+'</span><span class="b2b-cat-freq-add">+</span>';
      chip.onclick=function(){
        state.cart[p.sku]=(state.cart[p.sku]||0)+1;saveCart();
        renderProducts();updateCartBar();
        toast('+1 '+p.name.substr(0,20));
      };
      el.appendChild(chip);
    });
    sec.style.display=(shown>0&&state.viewMode==='home')?'':'none';
  }

  /* ═══ ORDER HISTORY ═══ */
  var historyFilters=[
    {key:'',label:'ทั้งหมด'},
    {key:'pending',label:'รอดำเนินการ'},
    {key:'awaiting_payment',label:'รอชำระ'},
    {key:'paid',label:'จ่ายแล้ว'},
    {key:'packed',label:'แพ็คแล้ว'},
    {key:'shipped',label:'จัดส่งแล้ว'},
    {key:'backorder',label:'Backorder'},
    {key:'completed',label:'เสร็จสิ้น'},
    {key:'change_requested',label:'ขอแก้ไข'},
    {key:'claim_opened',label:'เคลม'},
    {key:'cancelled',label:'ยกเลิก'},
  ];

  function renderHistoryFilter(){
    var el=document.getElementById('historyFilter');el.innerHTML='';
    historyFilters.forEach(function(f){
      var chip=document.createElement('button');
      chip.className='b2b-cat-filter-chip'+(state.historyFilter===f.key?' active':'');
      chip.textContent=f.label;
      chip.onclick=function(){state.historyFilter=f.key;state.historyPage=1;state.orders=[];loadOrderHistory();};
      el.appendChild(chip);
    });
  }

  document.getElementById('historyRefresh').addEventListener('click',function(){
    state.historyPage=1;state.orders=[];loadOrderHistory();
  });

  function loadOrderHistory(append){
    if(state.historyLoading)return;
    state.historyLoading=true;
    if(!append){renderHistoryFilter();}
    var list=document.getElementById('historyList');
    if(!append)list.innerHTML='<div style="text-align:center;padding:40px;color:#999;"><div style="width:24px;height:24px;border:2px solid #ddd;border-top-color:#111;border-radius:50%;animation:b2bSpin .8s linear infinite;margin:0 auto 12px;"></div>กำลังโหลด...</div>';
    var url=REST+'order-history?page='+state.historyPage+'&per_page=10';
    if(state.historyFilter)url+='&status='+encodeURIComponent(state.historyFilter);
    authFetch(url)
    .then(function(r){return r.json();})
    .then(function(d){
      state.historyLoading=false;
      if(!d.success){if(!append)list.innerHTML='';document.getElementById('historyEmpty').style.display='block';return;}
      document.getElementById('historyEmpty').style.display='none';
      if(append){state.orders=state.orders.concat(d.orders||[]);}
      else{state.orders=d.orders||[];state.recommendedSkus=d.recommended_skus||[];}
      state.historyTotal=d.total||0;
      state.historyTotalPages=d.total_pages||1;
      document.getElementById('historyPageInfo').textContent=state.orders.length+' / '+state.historyTotal+' รายการ';
      renderHistory();
    }).catch(function(){state.historyLoading=false;if(!append)list.innerHTML='<div style="text-align:center;padding:40px;color:#ef4444;">โหลดไม่สำเร็จ</div>';if(append){state.historyPage--;renderHistory();}});
  }

  function renderHistory(){
    var list=document.getElementById('historyList');list.innerHTML='';
    var sc={draft:{bg:'#f1f5f9',c:'#475569'},pending:{bg:'#f1f5f9',c:'#9e9e9e'},checking_stock:{bg:'#dbeafe',c:'#1d4ed8'},awaiting_confirm:{bg:'#fef3c7',c:'#92400e'},awaiting_payment:{bg:'#fed7aa',c:'#9a3412'},paid:{bg:'#dcfce7',c:'#166534'},packed:{bg:'#f3e5f5',c:'#7b1fa2'},shipped:{bg:'#fef9c3',c:'#854d0e'},completed:{bg:'#dcfce7',c:'#166534'},backorder:{bg:'#fee2e2',c:'#991b1b'},cancel_requested:{bg:'#fef2f2',c:'#dc2626'},cancelled:{bg:'#f1f5f9',c:'#64748b'},change_requested:{bg:'#f5f3ff',c:'#6d28d9'},claim_opened:{bg:'#fce7f3',c:'#9d174d'},claim_resolved:{bg:'#dcfce7',c:'#166534'}};
    var sl={draft:'Draft',pending:'รอดำเนินการ',checking_stock:'เช็คสต็อก',awaiting_confirm:'รอยืนยัน',awaiting_payment:'รอชำระ',paid:'ชำระแล้ว',packed:'แพ็คแล้ว',shipped:'จัดส่งแล้ว',completed:'เสร็จสิ้น',backorder:'Backorder',cancel_requested:'ขอยกเลิก',cancelled:'ยกเลิก',change_requested:'ขอแก้ไข',claim_opened:'เคลม',claim_resolved:'เคลมเสร็จ'};

    state.orders.forEach(function(o){
      var c=sc[o.status]||{bg:'#f1f5f9',c:'#475569'};
      var card=document.createElement('div');card.className='b2b-cat-history-card';
      var h='<div class="b2b-cat-history-top"><div><span class="b2b-cat-history-id">'+esc(o.sub_label||'Ticket #'+o.id)+'</span><span class="b2b-cat-history-date">'+esc(o.date)+'</span></div>';
      h+='<span class="b2b-cat-history-status" style="background:'+c.bg+';color:'+c.c+';">'+(sl[o.status]||esc(o.status))+'</span></div>';
      if(o.items&&o.items.length>0){
        h+='<div class="b2b-cat-hi-items">';
        o.items.forEach(function(it,i){
          h+='<div class="b2b-cat-hi-row"><span class="b2b-cat-hi-no">'+(i+1)+'.</span><span class="b2b-cat-hi-name">'+esc(it.name||it.sku)+'</span><span class="b2b-cat-hi-qty">x'+it.qty+'</span>';
          if(it.price)h+='<span class="b2b-cat-hi-price">฿'+fmt(it.price)+'</span>';
          h+='</div>';
        });
        h+='</div>';
      }else{
        h+='<div style="font-size:12px;color:#888;margin-bottom:6px;">'+esc(o.items_preview||'-')+'</div>';
      }

      var meta='';
      if(o.due_date&&(o.status==='awaiting_payment'||o.status==='paid'))meta+='<span class="due">กำหนดชำระ: '+esc(o.due_date)+'</span>';
      if(o.tracking)meta+='<span>'+esc(o.tracking)+(o.carrier?' ('+esc(o.carrier)+')':'')+'</span>';
      if(meta)h+='<div class="b2b-cat-history-meta">'+meta+'</div>';

      h+='<div class="b2b-cat-history-bottom"><span class="b2b-cat-history-total">฿'+fmt(o.total)+'</span><div class="b2b-cat-history-actions">';
      if(o.ticket_url)h+='<button class="b2b-cat-hbtn detail" data-view="'+esc(o.ticket_url)+'">ดู</button>';
      if(o.can_cancel&&o.status!=='cancelled'&&o.status!=='cancel_requested')h+='<button class="b2b-cat-hbtn danger" data-cancel="'+esc(String(o.id))+'">ยกเลิก</button>';
      h+='<button class="b2b-cat-hbtn primary" data-reorder="'+esc(String(o.id))+'">สั่งซ้ำ</button>';
      if(o.status==='shipped'||o.status==='completed')h+='<button class="b2b-cat-hbtn warn" data-claim="'+esc(String(o.id))+'">เคลม</button>';
      h+='</div></div>';
      card.innerHTML=h;list.appendChild(card);
    });

    // Load More
    if(state.historyPage<state.historyTotalPages){
      var btn=document.createElement('button');btn.className='b2b-cat-load-more';btn.textContent='โหลดเพิ่ม (หน้า '+(state.historyPage+1)+'/'+state.historyTotalPages+')';
      btn.onclick=function(){state.historyPage++;btn.disabled=true;btn.textContent='กำลังโหลด...';loadOrderHistory(true);};
      list.appendChild(btn);
    }

    // Event listeners
    list.querySelectorAll('[data-view]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var url=this.getAttribute('data-view');
        if(liff.isInClient&&liff.isInClient())liff.openWindow({url:url,external:false});else window.open(url,'_blank');
      });
    });
    list.querySelectorAll('[data-cancel]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var oid=this.getAttribute('data-cancel');
        state.cancelTarget=oid;document.getElementById('cancelTicketId').textContent=oid;document.getElementById('cancelModal').classList.add('show');
      });
    });
    list.querySelectorAll('[data-reorder]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var oid=this.getAttribute('data-reorder');
        var order=state.orders.find(function(o){return o.id==oid;});
        if(!order||!order.items)return;
        var hasCart=Object.keys(state.cart).some(function(k){return state.cart[k]>0;});
        if(hasCart&&!confirm('ตะกร้าปัจจุบันจะถูกแทนที่ด้วยรายการเดิม ดำเนินการต่อ?'))return;
        state.cart={};
        order.items.forEach(function(item){if(item.sku&&item.qty)state.cart[item.sku]=item.qty;});
        saveCart();
        document.getElementById('tabCatalog').click();renderProducts();updateCartBar();toast('โหลดรายการเดิมแล้ว!');
      });
    });
    list.querySelectorAll('[data-claim]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var oid=this.getAttribute('data-claim');
        liff.sendMessages([{type:'text',text:'@เคลม #'+oid}]).then(function(){toast('ส่งคำขอเคลมแล้ว');setTimeout(function(){liff.closeWindow();},1500);});
      });
    });
  }

  /* ═══ CANCEL MODAL ═══ */
  document.getElementById('cancelModal').addEventListener('click',function(e){if(e.target===this){this.classList.remove('show');state.cancelTarget=null;}});
  document.getElementById('cancelNo').addEventListener('click',function(){
    document.getElementById('cancelModal').classList.remove('show');state.cancelTarget=null;
  });
  document.getElementById('cancelYes').addEventListener('click',function(){
    if(!state.cancelTarget)return;var tid=state.cancelTarget;
    document.getElementById('cancelModal').classList.remove('show');
    liff.sendMessages([{type:'text',text:'@ยกเลิก #'+tid}]).then(function(){
      toast('ส่งคำขอยกเลิก #'+tid+' แล้ว');
      var order=state.orders.find(function(o){return o.id==tid;});
      if(order){order.status='cancel_requested';order.can_cancel=false;}
      renderHistory();state.cancelTarget=null;
    }).catch(function(e){toast('ส่งไม่สำเร็จ: '+e.message);state.cancelTarget=null;});
  });

  /* ═══ EDIT ORDER ═══ */
  function loadEditOrder(tid){
    state.editMode=true;
    document.getElementById('editBanner').style.display='flex';
    document.getElementById('cartSubmit').textContent='ส่งรายการแก้ไข';
    authFetch(REST+'order-detail?ticket_id='+tid)
    .then(function(r){return r.json();})
    .then(function(d){
      if(!d.success||!d.items){state.editMode=false;document.getElementById('editBanner').style.display='none';document.getElementById('cartSubmit').textContent='สั่งซื้อ';toast('โหลดรายการไม่สำเร็จ');return;}
      state.cart={};
      d.items.forEach(function(i){if(i.sku&&i.qty)state.cart[i.sku]=i.qty;});
      saveCart();
      renderProducts();updateCartBar();
      toast('โหลดรายการเดิมแล้ว แก้ไขได้เลย!');
    }).catch(function(){state.editMode=false;document.getElementById('editBanner').style.display='none';document.getElementById('cartSubmit').textContent='สั่งซื้อ';toast('เกิดข้อผิดพลาด');});
  }

  /* ═══ UTILITIES ═══ */
  function showAuthError(t,m,retryable){
    document.getElementById('loadingScreen').classList.add('hide');
    document.getElementById('authErrTitle').textContent=t;
    document.getElementById('authErrMsg').textContent=m;
    document.getElementById('authError').style.display='block';
    var btn=document.getElementById('authRetryBtn');
    if(retryable){
      btn.style.display='inline-block';
      btn.onclick=function(){
        btn.style.display='none';
        document.getElementById('authError').style.display='none';
        document.getElementById('loadingScreen').classList.remove('hide');
        document.querySelector('.b2b-cat-loading-text').textContent='กำลังเชื่อมต่อใหม่...';
        authAndLoad();
      };
    }else{btn.style.display='none';}
  }
  function showLinkExpired(){
    document.getElementById('loadingScreen').classList.add('hide');
    document.getElementById('authError').style.display='none';
    document.getElementById('linkExpired').style.display='block';
  }
  function toast(m){var el=document.getElementById('liffToast');el.textContent=m;el.classList.add('show');setTimeout(function(){el.classList.remove('show');},3000);}
  function fmt(n){return Math.round(n).toLocaleString();}
})();
</script>
</body>
</html>
