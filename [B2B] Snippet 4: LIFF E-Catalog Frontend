<script>
(function(){
  var LIFF_ID='<?php echo esc_js($liff_id); ?>';
  var REST='<?php echo esc_js($rest_url); ?>';

  // ── State ──
  var state={
    gid:'',uid:'',idToken:'',token:'',dist:null,
    products:[],cart:{},
    activeTab:'catalog',
    orders:[],recommendedSkus:[],
    cancelTarget:null,editMode:false,editTicket:'',
    historyPage:1,historyFilter:'',historyTotal:0,historyTotalPages:0,historyLoading:false,
    // V.31.0: Filter state machine
    viewMode:'home', // home | model | category | search
    filterModel:'',
    filterCategory:'',
    searchQuery:'',
    crossFilter:'', // cross-filter pill inside sub-page
    // Moto + category data
    motoCatalog:[],
    availableModels:[], // [{name,image_url}] models ที่มีสินค้า
    availableCategories:[], // [{name,icon}] categories ที่มีสินค้า
    modelImageMap:{} // model_name -> image_url
  };

  // ── Category Icons ──
  var CAT_ICONS={
    'กันล้ม':'🛡️','กล่อง':'📦','กล่องอลูมิเนียม':'📦',
    'แร็ค':'🔧','กระเป๋า':'💼','ชุดกล่อง':'📦',
    'กันล้มและแร็ค':'🛡️','ตะแกรง':'🔧','เบาะ':'🪑',
    'อื่นๆ':'📋','ชุดแต่ง':'🎨','ไฟ':'💡','กระจก':'🪞'
  };
  function catIcon(name){return CAT_ICONS[name]||'📋';}

  function escapeHtml(str){if(!str)return '';var d=document.createElement('div');d.appendChild(document.createTextNode(str));return d.innerHTML;}
  var esc=escapeHtml;

  var CART_KEY='dinoco_cart';
  function saveCart(){try{localStorage.setItem(CART_KEY,JSON.stringify(state.cart));}catch(e){}}
  function loadCart(){try{var s=localStorage.getItem(CART_KEY);if(s)state.cart=JSON.parse(s);}catch(e){state.cart={};}}

  function authFetch(url,opts,retries){
    retries=retries===undefined?2:retries;
    opts=opts||{};opts.headers=opts.headers||{};
    if(state.token)opts.headers['X-B2B-Token']=state.token;
    return fetch(url,opts).then(function(r){
      if(r.status===401){return authAndLoad().then(function(){opts.headers['X-B2B-Token']=state.token;return fetch(url,opts);});}
      return r;
    }).catch(function(e){
      if(retries>0&&(e.message.indexOf('Failed to fetch')!==-1||e.message.indexOf('NetworkError')!==-1)){
        toast('กำลังลองใหม่...');
        return new Promise(function(resolve){setTimeout(resolve,1500);}).then(function(){return authFetch(url,opts,retries-1);});
      }
      throw e;
    });
  }

  // Timeout guard
  setTimeout(function(){if(!state.dist){showAuthError('โหลดนานเกินไป','กรุณาปิดแล้วเปิดลิงก์ใหม่',true);}},15000);

  liff.init({liffId:LIFF_ID}).then(function(){
    if(!liff.isLoggedIn()){liff.login();return;}
    var params=new URLSearchParams(location.search);
    state.gid=params.get('gid')||'';
    state.editTicket=parseInt(params.get('edit'),10)||0;
    state.initTab=params.get('tab')||'';
    state.initFilter=params.get('filter')||'';
    if(!state.gid){showLinkExpired();return;}
    return liff.getProfile();
  }).then(function(profile){
    if(!profile)return;
    state.uid=profile.userId;
    state.idToken=liff.getIDToken()||'';
    document.querySelector('.b2b-cat-loading-text').textContent='กำลังโหลดสินค้า...';
    return authAndLoad();
  }).catch(function(e){
    var msg=e.message||'';
    var isLiffErr=msg.indexOf('INIT_FAILED')!==-1||msg.indexOf('liff')!==-1;
    if(isLiffErr){showAuthError('เปิด LIFF ไม่สำเร็จ','กรุณาปิดแล้วเปิดลิงก์ใหม่อีกครั้ง');}
    else{showAuthError('เกิดข้อผิดพลาด',msg||'ไม่สามารถเชื่อมต่อได้',true);}
  });

  function authAndLoad(){
    var urlParams=new URLSearchParams(location.search);
    return fetch(REST+'auth-group',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({group_id:state.gid,line_user_id:state.uid,id_token:state.idToken,_sig:urlParams.get('_sig')||'',_ts:parseInt(urlParams.get('_ts'))||0})})
    .then(function(r){
      if(r.status===503)throw new Error('maintenance');
      if(!r.ok)throw new Error('Server error: '+r.status);
      var ct=r.headers.get('content-type')||'';
      if(ct.indexOf('application/json')===-1)throw new Error('maintenance');
      return r.json();
    })
    .then(function(d){
      if(!d.authorized){
        var msg=d.message||'ไม่มีสิทธิ์';
        if(d.reason==='credit_hold'){msg='บัญชีถูกระงับ กรุณาชำระยอดค้างก่อนครับ';showAuthError('ไม่สามารถเข้าใช้งานได้',msg);return;}
        if(msg.indexOf('หมดอายุ')!==-1||msg.indexOf('ไม่ถูกต้อง')!==-1){showLinkExpired();return;}
        showAuthError('ไม่สามารถเข้าใช้งานได้',msg);return;
      }
      state.dist=d;
      state.token=d.token||'';
      var rl={standard:'Standard',silver:'Silver',gold:'Gold',platinum:'Platinum',diamond:'Diamond'};
      document.getElementById('shopName').textContent=d.dist_name;
      document.getElementById('shopInfo').innerHTML='<span class="b2b-cat-rank">'+(rl[d.rank]||esc(d.rank))+'</span>';
      if(d.dist_logo){document.getElementById('distAvatar').innerHTML='<img src="'+esc(d.dist_logo)+'" alt="">';}else{document.getElementById('distInitial').textContent=(d.dist_name||'D').charAt(0);}
      return authFetch(REST+'catalog');
    })
    .then(function(r){
      if(!r)return null;
      if(!r.ok){
        return r.text().then(function(body){
          var detail='';try{var j=JSON.parse(body);detail=j.message||j.code||'';}catch(e){detail=body.substring(0,200);}
          throw new Error('โหลดสินค้าไม่สำเร็จ ('+r.status+')'+(detail?' — '+detail:''));
        });
      }
      return r.json();
    })
    .then(function(d){
      if(!d)return;
      if(!d.success){showAuthError('โหลดสินค้าไม่สำเร็จ','กรุณาปิดแล้วเปิดใหม่อีกครั้ง');return;}
      state.products=d.products||[];
      state.motoCatalog=d.moto_catalog||[];

      // Build model image map from moto_catalog (PHP returns object keyed by brand_slug)
      if(state.motoCatalog&&typeof state.motoCatalog==='object'){
        var mc=state.motoCatalog;
        (Array.isArray(mc)?mc:Object.values(mc)).forEach(function(brand){
          if(brand&&brand.models){
            brand.models.forEach(function(m){
              if(m.name&&(m.image||m.image_url))state.modelImageMap[m.name]=m.image||m.image_url;
            });
          }
        });
      }

      // Parse available models & categories from products
      var modelSet={},catSet={};
      state.products.forEach(function(p){
        // Parse compatible_models
        var models=[];
        try{models=JSON.parse(p.compatible_models||'[]');}catch(e){}
        if(!Array.isArray(models))models=[];
        p._models=models; // cache parsed models on product
        models.forEach(function(m){
          var name=typeof m==='string'?m:(m.name||'');
          if(name&&!modelSet[name]){
            modelSet[name]={name:name,image_url:state.modelImageMap[name]||''};
          }
        });
        // Category
        var cat=p.category||'';
        if(cat&&!catSet[cat])catSet[cat]={name:cat,icon:catIcon(cat)};
      });
      state.availableModels=Object.keys(modelSet).sort().map(function(k){return modelSet[k];});
      state.availableCategories=Object.keys(catSet).sort().map(function(k){return catSet[k];});

      loadCart();
      renderHome();
      renderProducts();
      updateCartBar();
      document.getElementById('loadingScreen').classList.add('hide');
      document.getElementById('app').style.display='';
      if(state.editTicket)loadEditOrder(state.editTicket);
      if(state.initTab==='history'){
        if(state.initFilter)state.historyFilter=state.initFilter;
        document.getElementById('tabHistory').click();
      }
      loadRecommended();
    })
    .catch(function(e){
      console.error('authAndLoad error:',e);
      var msg=e.message||'';
      var isMaint=msg.indexOf('maintenance')!==-1||msg.indexOf('503')!==-1;
      var isNetwork=msg.indexOf('Failed to fetch')!==-1||msg.indexOf('NetworkError')!==-1||msg.indexOf('timeout')!==-1;
      if(isMaint){showAuthError('ระบบกำลังปรับปรุง','เซิร์ฟเวอร์กำลังอัปเดต กรุณารอสักครู่แล้วกด "ลองใหม่"',true);}
      else if(isNetwork){showAuthError('เชื่อมต่อไม่ได้','ตรวจสอบสัญญาณอินเทอร์เน็ตแล้วกด "ลองใหม่"',true);}
      else{showAuthError('เกิดข้อผิดพลาด',msg||'ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้',true);}
    });
  }

  /* ═══ TABS ═══ */
  document.querySelectorAll('.b2b-cat-tab').forEach(function(btn){
    btn.addEventListener('click',function(){
      var tab=this.getAttribute('data-tab');state.activeTab=tab;
      document.querySelectorAll('.b2b-cat-tab').forEach(function(b){b.classList.remove('active');});
      this.classList.add('active');
      document.getElementById('catalogPanel').style.display=tab==='catalog'?'':'none';
      document.getElementById('historyPanel').style.display=tab==='history'?'block':'none';
      document.getElementById('cartBar').style.display=tab==='catalog'?'':'none';
      if(tab==='history'){state.historyPage=1;state.orders=[];loadOrderHistory();}
      if(tab==='catalog')updateCartBar();
    });
  });

  /* V.32.6 P13: history empty state CTA — switch to catalog tab */
  (function(){
    var cta=document.getElementById('historyEmptyCta');
    if(!cta) return;
    cta.addEventListener('click',function(){
      var catalogTab=document.querySelector('.b2b-cat-tab[data-tab="catalog"]');
      if(catalogTab){catalogTab.click();window.scrollTo(0,0);}
    });
  })();

  /* ═══ FILTER STATE MACHINE ═══ */
  function setView(mode,value){
    state.viewMode=mode;
    state.crossFilter='';
    if(mode==='home'){
      state.filterModel='';state.filterCategory='';state.searchQuery='';
      document.getElementById('searchBox').value='';
    }else if(mode==='model'){
      state.filterModel=value;state.filterCategory='';
    }else if(mode==='category'){
      state.filterCategory=value;state.filterModel='';
    }else if(mode==='search'){
      state.searchQuery=value;
    }
    renderViewState();
    renderProducts();
  }

  function renderViewState(){
    var isHome=state.viewMode==='home';
    var isSub=state.viewMode==='model'||state.viewMode==='category';
    // Show/hide home rows
    document.getElementById('homeRows').style.display=isHome?'':'none';
    document.getElementById('searchWrap').style.display=(isHome||state.viewMode==='search')?'':'none';
    document.getElementById('freqSection').style.display=(isHome&&state.recommendedSkus.length)?'':'none';
    // Sub-header
    var sub=document.getElementById('subHeader');
    if(isSub){
      sub.classList.add('visible');
      document.getElementById('subTitle').textContent=state.viewMode==='model'?state.filterModel:state.filterCategory;
    }else{
      sub.classList.remove('visible');
    }
    // Cross-filter pills
    renderCrossFilterPills();
  }

  function renderCrossFilterPills(){
    var el=document.getElementById('crossPills');
    var isSub=state.viewMode==='model'||state.viewMode==='category';
    if(!isSub){el.style.display='none';return;}
    el.style.display='flex';el.innerHTML='';

    // "ทั้งหมด" pill
    var allP=document.createElement('button');allP.className='b2b-cat-pill'+(!state.crossFilter?' active':'');
    allP.textContent='ทั้งหมด';
    allP.onclick=function(){state.crossFilter='';renderCrossFilterPills();renderProducts();};
    el.appendChild(allP);

    if(state.viewMode==='model'){
      // Show category pills for this model
      var cats={};
      state.products.forEach(function(p){
        if(!productMatchesModel(p,state.filterModel))return;
        var c=p.category||'';if(c)cats[c]=true;
      });
      Object.keys(cats).sort().forEach(function(c){
        var pill=document.createElement('button');pill.className='b2b-cat-pill'+(state.crossFilter===c?' active':'');
        pill.textContent=c;
        pill.onclick=function(){state.crossFilter=c;renderCrossFilterPills();renderProducts();};
        el.appendChild(pill);
      });
    }else if(state.viewMode==='category'){
      // Show model pills for this category
      var models={};
      state.products.forEach(function(p){
        if((p.category||'')!==state.filterCategory)return;
        (p._models||[]).forEach(function(m){
          var n=typeof m==='string'?m:(m.name||'');if(n)models[n]=true;
        });
      });
      Object.keys(models).sort().forEach(function(m){
        var pill=document.createElement('button');pill.className='b2b-cat-pill'+(state.crossFilter===m?' active':'');
        pill.textContent=m;
        pill.onclick=function(){state.crossFilter=m;renderCrossFilterPills();renderProducts();};
        el.appendChild(pill);
      });
    }
