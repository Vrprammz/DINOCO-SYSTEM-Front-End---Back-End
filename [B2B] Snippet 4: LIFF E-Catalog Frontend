if ( ! defined( 'ABSPATH' ) ) exit;

add_action( 'template_redirect', function () {
    if ( ! is_page( 'b2b-catalog' ) ) return;

    // ── LIFF Router: ถ้า liff.state ชี้ไป path อื่น → redirect ──
    // V.30.4: Forward query params ด้วย (LINE แยก query params ออกจาก liff.state)
    $liff_state = isset( $_GET['liff.state'] ) ? $_GET['liff.state'] : '';
    if ( $liff_state && strpos( $liff_state, '/b2b-catalog' ) === false ) {
        $liff_path   = $liff_state;
        $liff_params = array();
        if ( strpos( $liff_state, '?' ) !== false ) {
            list( $liff_path, $liff_qs ) = explode( '?', $liff_state, 2 );
            parse_str( $liff_qs, $liff_params );
        }
        $forward_params = $_GET;
        unset( $forward_params['liff.state'] );
        $all_params = array_merge( $liff_params, $forward_params );
        $redirect_url = home_url( $liff_path );
        if ( ! empty( $all_params ) ) {
            $redirect_url = add_query_arg( $all_params, $redirect_url );
        }
        wp_redirect( $redirect_url, 302 );
        exit;
    }

    $liff_id  = defined('B2B_LIFF_ID') ? B2B_LIFF_ID : '';
    $rest_url = esc_url( rest_url('b2b/v1/') );
    $logo_url = function_exists('b2b_get_logo_url') ? b2b_get_logo_url() : 'https://dinoco.in.th/wp-content/uploads/2026/02/logodnc.png';

    header('Content-Type: text/html; charset=UTF-8');
?>
