      // V.32.2: Qty stepper (typable + − + + "+ เพิ่ม") — V.32.4: collapsed default สำหรับ sub-items
      var qtyH = chOOS ? '' : buildB2bStepper(child.sku, chQty, true);

      row.innerHTML=imgH+infoH+qtyH;
      wrap.appendChild(row);

      // Grandchildren section
      var gcs=child.grandchildren||[];
