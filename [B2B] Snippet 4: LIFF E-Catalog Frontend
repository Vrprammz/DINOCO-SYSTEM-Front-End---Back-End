  function showCartModal(items){
    var body=document.getElementById('cartModalBody');
    // V.32.6 P3: if modal opened with zero items, show empty state (don't leave body blank)
    if(!items||!items.length){
      body.innerHTML='<div class="b2b-cart-empty"><div class="icon" aria-hidden="true">🛒</div><div class="msg">ตะกร้าว่างแล้ว</div><div class="sub">กลับไปเลือกสินค้าจากแคตตาล็อก</div></div>';
      var tEl=document.getElementById('cartModalTotal'); if(tEl) tEl.textContent='฿0';
      var cBtn=document.getElementById('cartConfirmBtn'); if(cBtn){cBtn.disabled=true;cBtn.textContent='กลับไปเลือกสินค้า';}
      document.getElementById('cartModal').classList.add('show');
      return;
    }
    var cBtn2=document.getElementById('cartConfirmBtn'); if(cBtn2) cBtn2.disabled=false;
    var gt=0;var h='';
    items.forEach(function(i){
      var lt=i.price*i.qty;gt+=lt;
      // V.32.3: lookup product for thumbnail
      var prod=state.products.find(function(x){return x.sku===i.sku;});
      var imgUrl=(prod&&prod.img)?prod.img:'';
      var thumb=imgUrl
        ? '<img class="b2b-cat-modal-item-thumb" src="'+esc(imgUrl)+'" alt="'+esc(i.name)+'" loading="lazy" onerror="this.outerHTML=\'<div class=&quot;b2b-cat-modal-item-thumb placeholder&quot;>&#128230;</div>\'">'
        : '<div class="b2b-cat-modal-item-thumb placeholder">&#128230;</div>';
      h+='<div class="b2b-cat-modal-item">'+thumb+'<div class="b2b-cat-modal-item-info"><div class="b2b-cat-modal-item-name">'+esc(i.name)+'</div>';
      h+='<div class="b2b-cat-modal-item-detail">'+esc(i.sku)+' x '+i.qty+' @ ฿'+fmt(i.price)+'</div></div>';
      h+='<div class="b2b-cat-modal-item-total">฿'+fmt(lt)+'</div>';
      // V.32.4: remove button — ลบ item ออกจากตะกร้าได้จาก modal โดยตรง
      h+='<button type="button" class="b2b-cart-remove-btn" data-rmsku="'+esc(i.sku)+'" aria-label="ลบรายการ" title="ลบ"><span aria-hidden="true">🗑️</span><span class="sr-only">ลบ</span></button>';
      h+='</div>';
    });
    h+='<div class="b2b-cat-note-section"><div class="b2b-cat-note-label">หมายเหตุ (ถ้ามี)</div>';
    h+='<textarea class="b2b-cat-note-input" id="cartNoteInput" maxlength="300" placeholder="เช่น ส่งด่วน, แพ็คแยก..."></textarea></div>';
    body.innerHTML=h;
    document.getElementById('cartModalTotal').textContent='฿'+fmt(gt);
    document.getElementById('cartConfirmBtn').textContent=state.editMode?'ยืนยันแก้ไข':'ยืนยันสั่งสินค้า';
    document.getElementById('cartModal').classList.add('show');

    // V.32.4: Wire up remove buttons per item (ลบออกจากตะกร้าใน modal)
    body.querySelectorAll('.b2b-cart-remove-btn').forEach(function(rb){
      rb.addEventListener('click', function(e){
        e.stopPropagation();
        var rmSku = rb.getAttribute('data-rmsku');
        if(!rmSku) return;
        delete state.cart[rmSku];
        saveCart(); updateCartBar();
        // Re-render modal with updated items
        var items2=[];
        Object.keys(state.cart).forEach(function(sku){
          var q=state.cart[sku]; if(!q)return;
          var p=state.products.find(function(x){return x.sku===sku;});
          if(p) items2.push({sku:p.sku,name:p.name,qty:q,price:p.dealer_price});
        });
        if(!items2.length){
          document.getElementById('cartModal').classList.remove('show');
          if(typeof toast==='function') toast('ตะกร้าว่างแล้ว');
          // Also refresh product grid to reset card states
          if(typeof renderProducts==='function') renderProducts();
        } else {
          // Preserve typed note
          var noteEl=document.getElementById('cartNoteInput');
          var typedNote=noteEl?noteEl.value:'';
          showCartModal(items2);
          var noteEl2=document.getElementById('cartNoteInput');
          if(noteEl2 && typedNote) noteEl2.value=typedNote;
        }
      });
    });
  }

