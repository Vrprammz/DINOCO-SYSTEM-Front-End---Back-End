<style>
/* ═══ DINOCO B2B — Navy Brand CI (V.20.0) ═══ */
:root{--brand-navy:#111;--brand-navy-end:#1a1a1a;--primary:#2563eb;--success:#16a34a;--warning:#f59e0b;--danger:#dc2626;--orange:#f97316;--text:#1e293b;--text-secondary:#64748b;--text-muted:#94a3b8;--bg:#f1f5f9;--bg-card:#fff;--bg-row:#f8fafc;--border:#e2e8f0;--radius-sm:8px;--radius-md:12px;--radius-lg:16px;--shadow-sm:0 1px 2px rgba(0,0,0,0.05);--font:'Noto Sans Thai',-apple-system,system-ui,sans-serif;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:var(--font);background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;padding-bottom:100px;font-size:14px;line-height:1.5;}

/* ── Header (Navy Gradient) ── */
.liff-header{background:linear-gradient(135deg,var(--brand-navy),var(--brand-navy-end));padding:20px 16px 12px;position:sticky;top:0;z-index:100;border-bottom:none;}
.header-row{display:flex;align-items:center;gap:12px;margin-bottom:4px;}
.header-row .dist-av{width:40px;height:40px;border-radius:50%;flex-shrink:0;overflow:hidden;background:rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;}
.header-row .dist-av img{width:100%;height:100%;object-fit:cover;}
.header-row .dist-av span{font-size:16px;font-weight:800;color:rgba(255,255,255,0.7);}
.header-left{flex:1;min-width:0;}
.header-logo{height:28px;flex-shrink:0;}
.shop-name{color:#fff;font-weight:700;font-size:16px;line-height:1.3;}
.shop-info{color:rgba(255,255,255,0.6);font-size:12px;margin-top:2px;}
.rank-badge{display:inline-block;background:rgba(192,160,98,0.15);color:#c0a062;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;margin-left:4px;border:1px solid rgba(192,160,98,0.3);backdrop-filter:blur(4px);}

/* ── Tabs ── */
.tab-bar{display:flex;background:rgba(255,255,255,0.1);border-radius:var(--radius-sm);margin:12px 0 0;padding:3px;}
.tab-btn{flex:1;padding:10px 8px;border:none;background:transparent;color:rgba(255,255,255,0.5);font-size:13px;font-weight:600;border-radius:6px;cursor:pointer;font-family:var(--font);transition:all .2s;min-height:40px;}
.tab-btn.active{background:#fff;color:var(--brand-navy);}

/* ── Search ── */
.search-wrap{padding:12px 16px 0;position:relative;}
.search-box{width:100%;padding:12px 16px 12px 40px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-md);font-size:14px;font-family:var(--font);outline:none;transition:border .2s;min-height:48px;}
.search-box:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(37,99,235,0.1);}
.search-wrap::before{content:'🔍';position:absolute;left:28px;top:50%;transform:translateY(-50%);font-size:16px;pointer-events:none;}

/* ── Category ── */
.cat-filter{display:flex;gap:8px;padding:12px 16px;overflow-x:auto;-webkit-overflow-scrolling:touch;}
.cat-filter::-webkit-scrollbar{display:none;}
.cat-btn{flex-shrink:0;padding:10px 16px;border-radius:20px;border:1px solid var(--border);background:var(--bg-card);font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font);transition:all .2s;color:var(--text-secondary);min-height:40px;}
.cat-btn.active{background:var(--brand-navy);color:#fff;border-color:var(--brand-navy);}

/* ── Product Grid ── */
.product-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;padding:0 16px 16px;align-items:stretch;}
.prod-card{background:var(--bg-card);border-radius:var(--radius-md);overflow:hidden;border:1px solid rgba(0,0,0,0.04);position:relative;transition:transform .15s;display:flex;flex-direction:column;box-shadow:var(--shadow-sm);}
.prod-card:active{transform:scale(0.98);}
.prod-card.oos{opacity:0.6;filter:grayscale(0.5);}
.oos-label{position:absolute;top:8px;left:8px;background:var(--brand-navy);color:#fff;font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px;z-index:2;}
.prod-img-wrap{width:100%;aspect-ratio:1;display:flex;align-items:center;justify-content:center;background:var(--bg-row);overflow:hidden;padding:8px;}
.prod-img-wrap img{width:100%;height:100%;object-fit:contain;}
.prod-info{padding:10px;flex:1;display:flex;flex-direction:column;}
.prod-name{font-weight:600;font-size:13px;line-height:1.4;color:var(--text);word-break:break-word;}
.prod-sub{font-size:11px;color:var(--text-muted);margin-top:2px;}
.prod-price-row{margin-top:6px;}
.prod-price-line{display:flex;justify-content:space-between;align-items:center;line-height:1.5;}
.prod-price-label{font-size:10px;color:var(--text-muted);}
.prod-price-val{font-size:11px;color:var(--text-muted);text-decoration:line-through;}
.prod-dealer-line{display:flex;justify-content:space-between;align-items:center;line-height:1.5;}
.prod-dealer-label{font-size:10px;color:var(--text);font-weight:600;}
.prod-dealer-val{font-size:15px;font-weight:700;color:var(--text);}
.prod-discount-badge{display:inline-block;background:var(--danger);color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;margin-top:3px;}
.prod-actions{display:flex;align-items:center;justify-content:center;gap:0;margin-top:auto;padding-top:8px;background:var(--bg);border-radius:var(--radius-sm);overflow:hidden;}
.qty-btn{width:44px;height:44px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;cursor:pointer;user-select:none;color:var(--text-secondary);transition:background .15s;}
.qty-btn:active{background:var(--border);}
.qty-display{width:32px;text-align:center;font-weight:700;font-size:14px;color:var(--text);}

/* ── Skeleton Loading ── */
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
.skel-card{background:var(--bg-card);border-radius:var(--radius-md);overflow:hidden;border:1px solid rgba(0,0,0,0.04);}
.skel-img{width:100%;aspect-ratio:1;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;}
.skel-line{height:12px;border-radius:6px;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;margin:8px 10px;}
.skel-line.short{width:60%;}

/* ── Cart Bar ── */
.cart-bar{position:fixed;bottom:0;left:0;right:0;background:var(--brand-navy);border-top:none;padding:14px 16px;padding-bottom:calc(14px + env(safe-area-inset-bottom));display:flex;align-items:center;justify-content:space-between;z-index:200;transform:translateY(100%);transition:transform .3s;box-shadow:0 -4px 20px rgba(0,0,0,0.15);}
.cart-bar.visible{transform:translateY(0);}
.cart-info{font-size:13px;color:rgba(255,255,255,0.6);}.cart-info strong{color:#fff;font-size:16px;}
.cart-submit{padding:14px 28px;background:#fff;color:var(--brand-navy);border:none;border-radius:var(--radius-md);font-size:14px;font-weight:700;cursor:pointer;font-family:var(--font);transition:all .15s;min-height:48px;}
.cart-submit:active{transform:scale(0.97);background:var(--bg);}
.cart-submit:disabled{background:rgba(255,255,255,0.2);color:rgba(255,255,255,0.4);cursor:not-allowed;}

/* ── V.9: F1 Cart Summary Modal ── */
.cart-modal{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:flex-end;justify-content:center;z-index:9999;opacity:0;pointer-events:none;transition:opacity .25s;}
.cart-modal.show{opacity:1;pointer-events:all;}
.cart-modal-box{background:var(--bg-card);border-radius:20px 20px 0 0;width:100%;max-width:480px;max-height:85vh;display:flex;flex-direction:column;transform:translateY(100%);transition:transform .3s;}
.cart-modal.show .cart-modal-box{transform:translateY(0);}
.cart-modal-header{padding:16px 20px 12px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.cart-modal-header h3{font-size:16px;font-weight:700;}
.cart-modal-close{width:36px;height:36px;border-radius:50%;border:none;background:var(--bg);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.cart-modal-body{flex:1;overflow-y:auto;padding:16px 20px;}
.cart-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--bg);}
.cart-item:last-child{border-bottom:none;}
.cart-item-info{flex:1;min-width:0;}
.cart-item-name{font-size:13px;font-weight:600;color:var(--text);}
.cart-item-detail{font-size:11px;color:var(--text-muted);margin-top:2px;}
.cart-item-total{font-size:14px;font-weight:700;color:var(--text);flex-shrink:0;margin-left:12px;}
.cart-note-section{margin-top:16px;padding-top:16px;border-top:1px solid var(--border);}
.cart-note-label{font-size:12px;font-weight:600;color:var(--text);margin-bottom:6px;}
.cart-note-input{width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:10px;font-size:13px;font-family:var(--font);resize:none;outline:none;min-height:60px;transition:border .2s;}
.cart-note-input:focus{border-color:var(--primary);}
.cart-modal-footer{padding:16px 20px;padding-bottom:calc(16px + env(safe-area-inset-bottom));border-top:1px solid var(--border);display:flex;flex-direction:column;gap:10px;}
.cart-grand-total{display:flex;justify-content:space-between;font-size:16px;font-weight:700;color:var(--text);}
.cart-confirm-btn{width:100%;padding:14px;background:var(--brand-navy);color:#fff;border:none;border-radius:var(--radius-md);font-size:15px;font-weight:700;cursor:pointer;font-family:var(--font);transition:all .15s;min-height:48px;}
.cart-confirm-btn:active{background:var(--brand-navy-end);transform:scale(0.98);}

/* ── V.9: F2 History Filter Chips ── */
.history-toolbar{padding:12px 16px 8px;display:flex;flex-direction:column;gap:8px;}
.history-filter{display:flex;gap:6px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding:4px 0;}
.history-filter::-webkit-scrollbar{display:none;}
.filter-chip{flex-shrink:0;padding:10px 14px;border-radius:20px;border:1px solid var(--border);background:var(--bg-card);font-size:11px;font-weight:600;cursor:pointer;font-family:var(--font);transition:all .2s;color:var(--text-secondary);min-height:36px;}
.filter-chip.active{background:var(--brand-navy);color:#fff;border-color:var(--brand-navy);}
.history-refresh-row{display:flex;justify-content:space-between;align-items:center;}
.history-page-info{font-size:11px;color:var(--text-muted);}
.history-refresh-btn{padding:8px 12px;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--bg-card);font-size:11px;font-weight:600;cursor:pointer;font-family:var(--font);min-height:36px;}
.history-refresh-btn:active{background:var(--bg);}
.history-load-more{width:100%;padding:14px;border-radius:var(--radius-md);border:1px solid var(--border);background:var(--bg-card);font-size:13px;font-weight:600;cursor:pointer;font-family:var(--font);margin-top:8px;transition:all .15s;color:var(--text);min-height:48px;}
.history-load-more:active{background:#f0f0f0;}
.history-load-more:disabled{color:#999;cursor:not-allowed;}

/* ── History Cards ── */
.history-panel{padding:0;display:none;}
.history-card{background:var(--bg-card);border-radius:0;border:none;border-bottom:1px solid var(--border);padding:16px;margin-bottom:0;transition:border-color .2s;}
.history-card:active{border-color:var(--brand-navy);}
.history-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;gap:8px;}
.history-id{font-weight:700;font-size:14px;color:var(--text);}
.history-date{font-size:11px;color:var(--text-muted);margin-left:8px;}
.history-status{font-size:11px;font-weight:600;padding:3px 8px;border-radius:6px;white-space:nowrap;flex-shrink:0;}
.history-items{font-size:12px;color:var(--text-secondary);margin-bottom:8px;line-height:1.6;}
.hi-items{margin-bottom:8px;}
.hi-row{display:flex;align-items:center;gap:4px;font-size:12px;color:#555;padding:2px 0;}
.hi-no{color:#999;width:18px;flex-shrink:0;}
.hi-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.hi-qty{font-weight:600;flex-shrink:0;}
.hi-price{font-weight:600;color:#111;flex-shrink:0;min-width:50px;text-align:right;}
.history-meta{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:8px;font-size:11px;color:#888;}
.history-meta .due{color:#dc2626;font-weight:600;}
.history-meta .due.ok{color:#16a34a;}
.history-bottom{display:flex;justify-content:space-between;align-items:center;}
.history-total{font-weight:700;color:var(--text);font-size:15px;}
.history-actions{display:flex;gap:6px;flex-wrap:wrap;}
.history-btn{padding:7px 12px;border-radius:8px;border:1px solid #ddd;background:#fff;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s;}
.history-btn:active{transform:scale(0.96);}
.history-btn.primary{border-color:#111;background:#111;color:#fff;}
.history-btn.primary:active{background:#333;}
.history-btn.detail{border-color:#2563eb;color:#2563eb;background:#eff6ff;}
.history-btn.detail:active{background:#dbeafe;}
.history-btn.danger{border-color:#dc2626;color:#dc2626;background:#fef2f2;}
.history-btn.danger:active{background:#fee2e2;}
.history-btn.warn{border-color:#999;background:#f5f5f5;color:#333;}
.history-tracking{margin-top:8px;font-size:11px;color:#999;background:#fafafa;padding:6px 10px;border-radius:6px;}
.history-tracking span{font-weight:600;color:#333;}
.history-empty{text-align:center;padding:40px 16px;color:#999;}
.history-empty .icon{font-size:48px;margin-bottom:8px;}

/* ── Recommended Section ── */
.freq-section{padding:12px 16px 0;}
.freq-title{font-size:12px;font-weight:600;color:#111;margin-bottom:8px;}
.freq-chips{display:flex;gap:8px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:4px;}
.freq-chips::-webkit-scrollbar{display:none;}
.freq-chip{flex-shrink:0;display:flex;align-items:center;gap:6px;padding:8px 14px;background:#fff;border:1px solid #e5e5e5;border-radius:10px;font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;}
.freq-chip:active{background:#f0f0f0;transform:scale(0.97);}
.freq-chip .freq-icon{font-size:16px;}
.freq-chip .freq-name{max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#111;}
.freq-chip .freq-add{background:#111;color:#fff;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;flex-shrink:0;}

/* ── Cancel Confirm Modal ── */
.cancel-modal{position:fixed;inset:0;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:9999;opacity:0;pointer-events:none;transition:opacity .2s;}
.cancel-modal.show{opacity:1;pointer-events:all;}
.cancel-box{background:#fff;border-radius:16px;padding:24px;width:85%;max-width:320px;text-align:center;}
.cancel-box h3{font-size:16px;margin-bottom:8px;}
.cancel-box p{font-size:13px;color:#666;margin-bottom:16px;}
.cancel-box .cancel-btns{display:flex;gap:8px;}
.cancel-box .cancel-btns button{flex:1;padding:10px;border-radius:10px;border:none;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;}
.cancel-box .btn-no{background:#f5f5f5;color:#333;}
.cancel-box .btn-yes{background:#dc2626;color:#fff;}

/* ── Overlays ── */
.submit-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.92);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;opacity:0;pointer-events:none;transition:opacity .3s;}
.submit-overlay.show{opacity:1;pointer-events:all;}
.submit-overlay .spinner{width:40px;height:40px;border:3px solid rgba(255,255,255,0.15);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;}
.submit-overlay .msg{color:#fff;font-size:14px;margin-top:16px;text-align:center;}
.submit-overlay .success{color:#4ade80;font-size:24px;margin-bottom:8px;}

/* ── Loading Screen ── */
.loading-screen{position:fixed;inset:0;background:#111;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .4s;}
.loading-screen.hide{opacity:0;pointer-events:none;}
.loading-screen img{height:48px;margin-bottom:16px;}
.loading-spinner{width:32px;height:32px;border:3px solid rgba(255,255,255,0.15);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;}
.loading-text{color:#aaa;font-size:13px;margin-top:12px;}
@keyframes spin{to{transform:rotate(360deg);}}

/* ── Auth / Empty / Toast ── */
.auth-error{text-align:center;padding:60px 24px;display:none;}.auth-error .icon{font-size:48px;margin-bottom:16px;}
.auth-error h2{font-size:18px;margin-bottom:8px;color:#111;}.auth-error p{color:#666;font-size:14px;line-height:1.6;}
.empty-state{text-align:center;padding:40px 24px;color:#999;display:none;}.empty-state .icon{font-size:48px;margin-bottom:8px;}
.liff-toast{position:fixed;bottom:120px;left:50%;transform:translateX(-50%) translateY(20px);background:#111;color:#fff;padding:10px 20px;border-radius:10px;font-size:13px;z-index:9999;opacity:0;transition:all .3s;pointer-events:none;border:1px solid #333;}
.liff-toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── V.9: N2 Edit Mode Banner ── */
.edit-banner{background:#fef3c7;border:none;border-bottom:1px solid #f59e0b;border-radius:0;margin:0;padding:10px 16px;font-size:12px;color:#92400e;font-weight:600;display:none;align-items:center;gap:8px;}
.edit-banner .edit-icon{font-size:16px;}
</style>
