          if(gc.img){
            gcH+='<img class="b2b-cat-set-gc-img" src="'+esc(gc.img)+'" alt="" loading="lazy">';
          }else{
            gcH+='<div class="b2b-cat-set-gc-img" style="display:flex;align-items:center;justify-content:center;font-size:14px;color:#ccc;">📦</div>';
          }
          gcH+='<div class="b2b-cat-set-gc-info"><div class="b2b-cat-set-gc-name">'+esc(gc.name)+'</div>';
