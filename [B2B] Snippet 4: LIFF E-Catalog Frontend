  /* ═══ HELPER: check if product matches model ═══ */
  function productMatchesModel(p,modelName){
    if(!modelName)return true;
    var models=p._models||[];
    for(var i=0;i<models.length;i++){
      var n=typeof models[i]==='string'?models[i]:(models[i].name||'');
      if(n===modelName)return true;
    }
    return false;
  }

  /* ═══ RENDER PRODUCTS ═══ */
  function renderProducts(){
    var grid=document.getElementById('productGrid');grid.innerHTML='';
    var search=state.searchQuery.toLowerCase();

    var filtered=state.products.filter(function(p){
      // Search mode: match name, sku, model, category
      if(state.viewMode==='search'&&search){
        var haystack=(p.name+' '+p.sku+' '+(p.category||'')+' '+(p.compatible_models||'')).toLowerCase();
        return haystack.indexOf(search)>=0;
      }
      // Model mode
      if(state.viewMode==='model'){
        if(!productMatchesModel(p,state.filterModel))return false;
        if(state.crossFilter&&(p.category||'')!==state.crossFilter)return false;
        return true;
      }
      // Category mode
      if(state.viewMode==='category'){
        if((p.category||'')!==state.filterCategory)return false;
        if(state.crossFilter&&!productMatchesModel(p,state.crossFilter))return false;
        return true;
      }
      // Home: show all (can apply search from search box)
      var q=(document.getElementById('searchBox').value||'').toLowerCase();
      if(q){
        var haystack=(p.name+' '+p.sku+' '+(p.category||'')+' '+(p.compatible_models||'')).toLowerCase();
        return haystack.indexOf(q)>=0;
      }
      return true;
    });

    // Update sub-page count
    if(state.viewMode==='model'||state.viewMode==='category'){
      document.getElementById('subCount').textContent=filtered.length+' รายการ';
    }

    document.getElementById('emptyState').style.display=filtered.length?'none':'block';

    filtered.forEach(function(p,idx){
      var sd=p.stock_display||p.stock_status||'in_stock';
      var isOOS=sd==='out_of_stock';
      var isLow=sd==='low_stock';
      var isSet=p.is_set===true;
      var qty=state.cart[p.sku]||0;
      var card=document.createElement('div');card.className='b2b-cat-product'+(isOOS?' oos':'');
      var h='';

      // Badge: SET badge (left) + stock badge (right)
      if(isSet){
        h+='<div class="b2b-cat-badge set">SET</div>';
      }
      if(isOOS){
        h+='<div class="b2b-cat-badge oos">สินค้าหมด</div>';
      }else if(isLow){
        h+='<div class="b2b-cat-badge low">ใกล้หมด</div>';
      }

      // Image — V.32.6 P18: first 6 images get fetchpriority="high" + eager loading for LCP boost
      var imgPriority=idx<6?' fetchpriority="high" loading="eager"':' loading="lazy"';
      h+='<div class="b2b-cat-img">'+(p.img?'<img src="'+esc(p.img)+'" alt="'+esc(p.name||p.sku)+'"'+imgPriority+'>':'<div class="b2b-cat-img-placeholder" aria-hidden="true">📦</div>')+'</div>';

      // Info
      h+='<div class="b2b-cat-info">';
      h+='<div class="b2b-cat-name">'+esc(p.name)+'</div>';

      // Model tags
      var models=p._models||[];
      if(models.length){
        h+='<div class="b2b-cat-model-tags">';
        var shown=0;
        models.forEach(function(m){
          if(shown>=3)return;shown++;
          var n=typeof m==='string'?m:(m.name||'');
          if(n)h+='<span class="b2b-cat-model-tag">'+esc(n)+'</span>';
        });
        if(models.length>3)h+='<span class="b2b-cat-model-tag">+'+( models.length-3)+'</span>';
        h+='</div>';
      }

      // ETA for OOS
      if(isOOS){
        if(p.stock_eta){
          var parts=p.stock_eta.split('-');
          var etaFmt=parts.length===3?(parts[2]+'/'+parts[1]+'/'+parts[0]):'';
          h+='<div class="b2b-cat-eta">คาดว่ามีของ '+esc(etaFmt)+'</div>';
        }else{
          h+='<div class="b2b-cat-eta">ยังไม่ทราบกำหนด</div>';
        }
      }
      if(isLow){
        h+='<div class="b2b-cat-eta" style="display:inline-block;background:#fff3e0;color:#e65100;font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;">สั่งก่อนหมด</div>';
      }

      // Price
      h+='<div class="b2b-cat-price-row">';
      if(p.discount>0){
        h+='<div class="b2b-cat-retail">฿'+fmt(p.price)+'</div>';
        h+='<span class="b2b-cat-dealer">฿'+fmt(p.dealer_price)+'</span>';
        h+='<span class="b2b-cat-discount">-'+Math.round(p.discount)+'%</span>';
      }else{
        h+='<span class="b2b-cat-dealer">฿'+fmt(p.dealer_price)+'</span>';
      }
      h+='</div>';
      h+='</div>'; // end info

      // Cart row — SET products show "ดูชุด" button instead of add-to-cart
      h+='<div class="b2b-cat-cart-row">';
      if(isSet&&!isOOS){
        if(qty>0){
          h+='<div class="b2b-cat-qty-row"><button class="b2b-cat-qty-btn" data-sku="'+esc(p.sku)+'" data-action="minus">−</button><div class="b2b-cat-qty-val" id="qty-'+esc(p.sku)+'">'+qty+'</div><button class="b2b-cat-qty-btn" data-sku="'+esc(p.sku)+'" data-action="plus">+</button></div>';
        }else{
          h+='<button class="b2b-cat-add-btn" data-sku="'+esc(p.sku)+'" data-action="detail" style="background:#7c3aed;border-color:#7c3aed;">ดูชุด</button>';
        }
      }else if(isOOS){
        h+='<div class="b2b-cat-add-btn" style="opacity:0.3;pointer-events:none;">สินค้าหมด</div>';
      }else if(qty>0){
        h+='<div class="b2b-cat-qty-row"><button class="b2b-cat-qty-btn" data-sku="'+esc(p.sku)+'" data-action="minus">−</button><div class="b2b-cat-qty-val" id="qty-'+esc(p.sku)+'">'+qty+'</div><button class="b2b-cat-qty-btn" data-sku="'+esc(p.sku)+'" data-action="plus">+</button></div>';
      }else{
        h+='<button class="b2b-cat-add-btn" data-sku="'+esc(p.sku)+'" data-action="add">+ เพิ่ม</button>';
      }
      h+='</div>';

      card.innerHTML=h;grid.appendChild(card);
    });

    // Event delegation for qty buttons
    grid.querySelectorAll('[data-action]').forEach(function(btn){
      btn.addEventListener('click',function(e){
        e.stopPropagation();
        var sku=this.getAttribute('data-sku'),act=this.getAttribute('data-action');
        if(act==='detail'){
          // V.32.0: Open SET detail view
          var prod=state.products.find(function(x){return x.sku===sku;});
          if(prod)openSetDetail(prod);
          return;
        }
        if(act==='add'){
          var dup=checkCartDuplicate(sku);
          if(dup&&dup.hasConflict){showCartDuplicateBlock(dup);return;}
          state.cart[sku]=1;
          if(navigator.vibrate)navigator.vibrate(20); // P16 haptic
        }else if(act==='plus'){
          state.cart[sku]=(state.cart[sku]||0)+1;
          if(navigator.vibrate)navigator.vibrate(15); // P16 haptic
        }else if(act==='minus'){
          var cur=state.cart[sku]||0;
          if(cur>1)state.cart[sku]=cur-1;
          else delete state.cart[sku];
        }
        saveCart();
        renderProducts(); // re-render to switch between add btn and qty row
        updateCartBar();
      });
    });
  }

  /* ═══ SET DETAIL VIEW (V.32.0) ═══ */
  var _setDetailScrollY=0;
  var _setDetailProduct=null;

  function openSetDetail(product){
    _setDetailProduct=product;
    _setDetailScrollY=window.scrollY;

    // Populate header
    var imgEl=document.getElementById('setDetailImg');
    if(product.img){imgEl.src=product.img;imgEl.style.display='';}else{imgEl.style.display='none';}
    document.getElementById('setDetailName').textContent=product.name;
    document.getElementById('setDetailSku').textContent='SKU: '+product.sku;
    document.getElementById('setDetailPrice').textContent='฿'+fmt(product.dealer_price);
    var retailEl=document.getElementById('setDetailRetail');
    if(product.discount>0){retailEl.textContent='฿'+fmt(product.price);retailEl.style.display='';}
    else{retailEl.style.display='none';}

    // V.32.3: "+ ชุดเต็ม" main button → qty stepper (กดครั้งเดียวเพิ่มหลายชุดได้)
    renderSetDetailMainStepper(product);

    // Render children
    renderSetDetailItems(product);

    // Show detail, hide catalog
    document.getElementById('catalogPanel').style.display='none';
    document.querySelector('.b2b-cat-header').style.display='none';
    document.getElementById('setDetailView').style.display='';
    document.getElementById('cartBar').style.display='';
    window.scrollTo(0,0);

    // Push history state
    history.pushState({view:'detail',sku:product.sku},'','#detail-'+product.sku);
  }

  // V.32.3: render main SET qty stepper (preserve typed qty across re-renders)
  function renderSetDetailMainStepper(product){
    var wrap=document.getElementById('setDetailAddWrap');
    if(!wrap) return;
    var sdSet=product.stock_display||product.stock_status||'in_stock';
    if(sdSet==='out_of_stock'){
      wrap.innerHTML='<button disabled style="min-height:48px;padding:0 20px;border:none;border-radius:10px;background:#cbd5e1;color:#fff;font-size:14px;font-weight:700;cursor:not-allowed;opacity:0.6;">สินค้าหมด</button>';
      return;
    }
    var qtyInCart=state.cart[product.sku]||0;
    var currentInput=wrap.querySelector('.b2b-qty-stepper-input');
    var preserveTyped=currentInput?Math.max(1,Math.min(999,parseInt(currentInput.value,10)||1)):1;
    var safeSku=esc(product.sku);
    var inCart=qtyInCart>0;
    // V.32.6 P1: MOQ hint — support min_order_qty (B2B) or moq field
    var moq=parseInt(product.min_order_qty||product.moq||1,10)||1;
    var moqHtml=moq>1?('<div class="b2b-cat-moq-hint" role="note">ขั้นต่ำ '+moq+' ชุด</div>'):'';
    wrap.innerHTML=
       '<div class="b2b-qty-stepper" data-stepsku="'+safeSku+'" data-setmain="1">'
      +'<div class="b2b-qty-stepper-group">'
      +'<button type="button" class="b2b-qty-stepper-btn" data-stepact="minus" aria-label="ลด">−</button>'
      +'<input type="number" class="b2b-qty-stepper-input" value="'+preserveTyped+'" min="1" max="999" inputmode="numeric" data-stepact="input">'
      +'<button type="button" class="b2b-qty-stepper-btn" data-stepact="plus" aria-label="เพิ่ม">+</button>'
      +'</div>'
      +'<button type="button" class="b2b-qty-stepper-add'+(inCart?' in-cart':'')+'" data-stepact="add" style="background:'+(inCart?'#10b981':'#1e293b')+';">'
      +(inCart?('+ ชุดเต็ม (ในตะกร้า '+qtyInCart+')'):'+ ชุดเต็ม')
      +'</button>'
      +'</div>'
      +moqHtml;
  }

  // Backward compat: some callers still invoke updateSetDetailAddBtn(product)
  function updateSetDetailAddBtn(product){
    if(product) renderSetDetailMainStepper(product);
  }

  function closeSetDetail(){
    _setDetailProduct=null;
    document.getElementById('setDetailView').style.display='none';
    document.getElementById('catalogPanel').style.display='';
    document.querySelector('.b2b-cat-header').style.display='';
    renderProducts();
    updateCartBar();
    window.scrollTo(0,_setDetailScrollY);
  }

  // V.32.3: SET Detail main "+ ชุดเต็ม" stepper — event delegation
  (function(){
    var wrap=document.getElementById('setDetailAddWrap');
    if(!wrap) return;
    wrap.addEventListener('click',function(e){
      var btn=e.target.closest('[data-stepact]');
      if(!btn) return;
      var stepWrap=btn.closest('.b2b-qty-stepper');
      if(!stepWrap||stepWrap.getAttribute('data-setmain')!=='1') return;
      if(!_setDetailProduct) return;
      var act=btn.getAttribute('data-stepact');
      if(act==='input') return;
      e.stopPropagation();
      var input=stepWrap.querySelector('.b2b-qty-stepper-input');
      var typedQty=Math.max(1,Math.min(999,parseInt((input&&input.value)||'1',10)||1));
      if(act==='plus'){
        typedQty=Math.min(999,typedQty+1);
        if(input) input.value=typedQty;
      }else if(act==='minus'){
        typedQty=Math.max(1,typedQty-1);
        if(input) input.value=typedQty;
      }else if(act==='add'){
        var p=_setDetailProduct;
        var sdp=p.stock_display||p.stock_status||'in_stock';
        if(sdp==='out_of_stock') return;
        var dup=checkCartDuplicate(p.sku);
        if(dup&&dup.hasConflict){showCartDuplicateBlock(dup);return;}
        state.cart[p.sku]=(state.cart[p.sku]||0)+typedQty;
        saveCart();updateCartBar();
        renderSetDetailMainStepper(p);
        renderSetDetailItems(p);
        if(typeof toast==='function') toast('+'+typedQty+' ชุด '+(p.name||p.sku).substring(0,20));
      }
    });
    wrap.addEventListener('change',function(e){
      if(!e.target.classList.contains('b2b-qty-stepper-input')) return;
      var v=Math.max(1,Math.min(999,parseInt(e.target.value,10)||1));
      e.target.value=v;
    });
    wrap.addEventListener('keydown',function(e){
      if(!e.target.classList.contains('b2b-qty-stepper-input')) return;
      if(e.key==='Enter'){
        e.preventDefault();
        var w=e.target.closest('.b2b-qty-stepper');
        if(!w) return;
        var addBtn=w.querySelector('[data-stepact="add"]');
        if(addBtn) addBtn.click();
      }
    });
  })();

