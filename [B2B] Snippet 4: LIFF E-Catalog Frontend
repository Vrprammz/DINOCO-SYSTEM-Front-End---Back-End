<script>
(function(){
  var LIFF_ID='<?php echo esc_js($liff_id); ?>';
  var REST='<?php echo esc_js($rest_url); ?>';
  var state={gid:'',uid:'',idToken:'',token:'',dist:null,products:[],cart:{},categories:['ทั้งหมด'],activeCat:'ทั้งหมด',activeTab:'catalog',orders:[],recommendedSkus:[],cancelTarget:null,editMode:false,editTicket:'',historyPage:1,historyFilter:'',historyTotal:0,historyTotalPages:0,historyLoading:false};

  function escapeHtml(str) {
      if (!str) return '';
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
  }

  var CART_KEY = 'dinoco_cart';

  function saveCart() {
      try { localStorage.setItem(CART_KEY, JSON.stringify(state.cart)); } catch(e) {}
  }

  function loadCart() {
      try {
          var saved = localStorage.getItem(CART_KEY);
          if (saved) state.cart = JSON.parse(saved);
      } catch(e) { state.cart = {}; }
  }

  function authFetch(url, opts, retries) {
    retries = retries === undefined ? 2 : retries;
    opts = opts || {};
    opts.headers = opts.headers || {};
    if (state.token) opts.headers['X-B2B-Token'] = state.token;
    return fetch(url, opts).then(function(r) {
        if (r.status === 401) {
            return authAndLoad().then(function() {
                opts.headers['X-B2B-Token'] = state.token;
                return fetch(url, opts);
            });
        }
        return r;
    }).catch(function(e) {
        if (retries > 0 && (e.message.indexOf('Failed to fetch') !== -1 || e.message.indexOf('NetworkError') !== -1)) {
            toast('📡 กำลังลองใหม่...');
            return new Promise(function(resolve) { setTimeout(resolve, 1500); })
                .then(function() { return authFetch(url, opts, retries - 1); });
        }
        throw e;
    });
  }

  // P24: Timeout guard — ถ้า LIFF init ค้างเกิน 15 วินาที แสดง error
  setTimeout(function(){ if(!state.dist){ showAuthError('โหลดนานเกินไป','กรุณาปิดแล้วเปิดลิงก์ใหม่',true); } }, 15000);

  liff.init({liffId:LIFF_ID}).then(function(){
    if(!liff.isLoggedIn()){liff.login();return;}
    var params=new URLSearchParams(location.search);
    state.gid=params.get('gid')||'';
    state.editTicket=parseInt(params.get('edit'),10)||0;
    state.initTab=params.get('tab')||'';
    state.initFilter=params.get('filter')||'';
    if(!state.gid){showLinkExpired();return;}
    return liff.getProfile();
  }).then(function(profile){
    if(!profile)return;
    state.uid=profile.userId;
    state.idToken=liff.getIDToken()||'';
    document.querySelector('.loading-text').textContent='กำลังโหลดสินค้า...';
    return authAndLoad();
  }).catch(function(e){
    var msg=e.message||'';
    var isLiffErr=msg.indexOf('INIT_FAILED')!==-1||msg.indexOf('liff')!==-1;
    if(isLiffErr){showAuthError('เปิด LIFF ไม่สำเร็จ','กรุณาปิดแล้วเปิดลิงก์ใหม่อีกครั้ง');}
    else{showAuthError('เกิดข้อผิดพลาด',msg||'ไม่สามารถเชื่อมต่อได้',true);}
  });

  function authAndLoad(){
    var urlParams=new URLSearchParams(location.search);
    return fetch(REST+'auth-group',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({group_id:state.gid,line_user_id:state.uid,id_token:state.idToken,_sig:urlParams.get('_sig')||'',_ts:parseInt(urlParams.get('_ts'))||0})})
    .then(function(r){
      if(r.status===503) throw new Error('maintenance');
      if(!r.ok) throw new Error('Server error: '+r.status);
      var ct=r.headers.get('content-type')||'';
      if(ct.indexOf('application/json')===-1) throw new Error('maintenance');
      return r.json();
    })
    .then(function(d){
      if(!d.authorized){
        var msg=d.message||'ไม่มีสิทธิ์';
        if(d.reason==='credit_hold'){msg='⛔ บัญชีถูกระงับ กรุณาชำระยอดค้างก่อนครับ';showAuthError('ไม่สามารถเข้าใช้งานได้',msg);return;}
        if(msg.indexOf('หมดอายุ')!==-1||msg.indexOf('ไม่ถูกต้อง')!==-1){showLinkExpired();return;}
        showAuthError('ไม่สามารถเข้าใช้งานได้',msg);return;
      }
      state.dist=d;
      state.token=d.token||'';
      var rl={standard:'⭐ Standard',silver:'🥈 Silver',gold:'🥇 Gold',platinum:'💎 Platinum',diamond:'💠 Diamond'};
      document.getElementById('shopName').textContent=d.dist_name;
      document.getElementById('shopInfo').innerHTML='Rank: <span class="rank-badge">'+(rl[d.rank]||esc(d.rank))+'</span>';
      if(d.dist_logo){document.getElementById('distAvatar').innerHTML='<img src="'+esc(d.dist_logo)+'" alt="">';}else{document.getElementById('distInitial').textContent=(d.dist_name||'D').charAt(0);}
      return authFetch(REST+'catalog');
    })
    .then(function(r){
      if(!r)return null;
      if(!r.ok){
        return r.text().then(function(body){
          var detail='';
          try{var j=JSON.parse(body);detail=j.message||j.code||'';}catch(e){detail=body.substring(0,200);}
          throw new Error('โหลดสินค้าไม่สำเร็จ ('+r.status+')'+(detail?' — '+detail:''));
        });
      }
      return r.json();
    })
    .then(function(d){
      if(!d)return;
      if(!d.success){showAuthError('โหลดสินค้าไม่สำเร็จ','กรุณาปิดแล้วเปิดใหม่อีกครั้ง');return;}
      state.products=d.products||[];
      var cats=new Set(['ทั้งหมด']);
      state.products.forEach(function(p){if(p.sub)cats.add(p.sub);});
      state.categories=Array.from(cats);
      loadCart();
      renderCategories();renderProducts();
      document.getElementById('loadingScreen').classList.add('hide');
      document.getElementById('app').style.display='';
      if(state.editTicket)loadEditOrder(state.editTicket);
      // URL param: auto-switch to history tab with optional filter
      if(state.initTab==='history'){
        if(state.initFilter)state.historyFilter=state.initFilter;
        document.getElementById('tabHistory').click();
      }
      loadRecommended();
    })
    .catch(function(e){
      console.error('authAndLoad error:',e);
      var msg=e.message||'';
      var isMaint=msg.indexOf('maintenance')!==-1||msg.indexOf('503')!==-1;
      var isNetwork=msg.indexOf('Failed to fetch')!==-1||msg.indexOf('NetworkError')!==-1||msg.indexOf('timeout')!==-1;
      if(isMaint){
        showAuthError('🔧 ระบบกำลังปรับปรุง','เซิร์ฟเวอร์กำลังอัปเดต กรุณารอสักครู่แล้วกด "ลองใหม่"',true);
      }else if(isNetwork){
        showAuthError('📡 เชื่อมต่อไม่ได้','ตรวจสอบสัญญาณอินเทอร์เน็ตแล้วกด "ลองใหม่"',true);
      }else{
        showAuthError('เกิดข้อผิดพลาด',msg||'ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้',true);
      }
    });
  }

  /* ═══ TABS ═══ */
  document.querySelectorAll('.tab-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var tab=this.getAttribute('data-tab');state.activeTab=tab;
      document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active');});
      this.classList.add('active');
      document.getElementById('catalogPanel').style.display=tab==='catalog'?'':'none';
      document.getElementById('historyPanel').style.display=tab==='history'?'block':'none';
      document.getElementById('cartBar').style.display=tab==='catalog'?'':'none';
      if(tab==='history'){state.historyPage=1;state.orders=[];loadOrderHistory();}
    });
  });

  /* ═══ CATALOG ═══ */
  function renderCategories(){
    var el=document.getElementById('catFilter');el.innerHTML='';
    state.categories.forEach(function(c){
      var btn=document.createElement('button');btn.className='cat-btn'+(c===state.activeCat?' active':'');
      btn.textContent=c;btn.onclick=function(){state.activeCat=c;renderCategories();renderProducts();};
      el.appendChild(btn);
    });
  }

  function renderProducts(){
    var grid=document.getElementById('productGrid');grid.innerHTML='';
    var search=(document.getElementById('searchBox').value||'').toLowerCase();
    var filtered=state.products.filter(function(p){
      if(state.activeCat!=='ทั้งหมด'&&p.sub!==state.activeCat)return false;
      if(search&&p.name.toLowerCase().indexOf(search)<0&&p.sku.toLowerCase().indexOf(search)<0)return false;
      return true;
    });
    document.getElementById('emptyState').style.display=filtered.length?'none':'block';
    filtered.forEach(function(p){
      var isOOS=p.stock_status==='out_of_stock';
      var qty=state.cart[p.sku]||0;
      var card=document.createElement('div');card.className='prod-card'+(isOOS?' oos':'');
      var h='';
      if(isOOS)h+='<div class="oos-label">หมดชั่วคราว'+(p.oos_eta?' · ETA '+esc(p.oos_eta):'')+'</div>';
      h+='<div class="prod-img-wrap">'+(p.img?'<img src="'+esc(p.img)+'" alt="" loading="lazy">':'<div style="font-size:40px;color:#cbd5e1;">📦</div>')+'</div>';
      h+='<div class="prod-info"><div class="prod-name">'+esc(p.name)+'</div>';
      if(p.sub)h+='<div class="prod-sub">'+esc(p.sub)+'</div>';
      h+='<div class="prod-price-row">';
      if(p.discount>0){
        h+='<div class="prod-price-line"><span class="prod-price-label">ราคาปลีก</span><span class="prod-price-val">฿'+fmt(p.price)+'</span></div>';
        h+='<div class="prod-dealer-line"><span class="prod-dealer-label">ราคาส่ง</span><span class="prod-dealer-val">฿'+fmt(p.dealer_price)+'</span></div>';
        h+='<span class="prod-discount-badge">🏷️ -'+Math.round(p.discount)+'%</span>';
      } else {
        h+='<div class="prod-dealer-line"><span class="prod-dealer-label">ราคา</span><span class="prod-dealer-val">฿'+fmt(p.dealer_price)+'</span></div>';
      }
      h+='</div>';
      h+='<div class="prod-actions"><div class="qty-btn" data-sku="'+esc(p.sku)+'" data-action="minus">−</div><div class="qty-display" id="qty-'+esc(p.sku)+'">'+qty+'</div><div class="qty-btn" data-sku="'+esc(p.sku)+'" data-action="plus">+</div></div>';
      h+='</div>';
      card.innerHTML=h;grid.appendChild(card);
    });
    grid.querySelectorAll('.qty-btn').forEach(function(btn){btn.addEventListener('click',function(){
      var sku=this.getAttribute('data-sku'),act=this.getAttribute('data-action');
      var cur=state.cart[sku]||0;
      if(act==='plus')state.cart[sku]=cur+1;
      else if(act==='minus'&&cur>0)state.cart[sku]=cur-1;
      if(state.cart[sku]===0)delete state.cart[sku];
      saveCart();
      var el=document.getElementById('qty-'+sku);if(el)el.textContent=state.cart[sku]||0;
      updateCartBar();
    });});
  }

  function updateCartBar(){
    var keys=Object.keys(state.cart),count=0,total=0;
    keys.forEach(function(sku){var q=state.cart[sku];if(!q)return;count+=q;var p=state.products.find(function(x){return x.sku===sku;});if(p)total+=p.dealer_price*q;});
    document.getElementById('cartCount').textContent=count;
    document.getElementById('cartTotal').textContent='฿'+fmt(total);
    document.getElementById('cartBar').classList.toggle('visible',count>0);
    // V.9: N2 Edit mode button text
    document.getElementById('cartSubmit').textContent=state.editMode?'✏️ ส่งรายการแก้ไข':'🛒 สั่งสินค้า';
  }

  /* ═══ V.9: F1 — CART SUMMARY MODAL ═══ */
  document.getElementById('cartSubmit').addEventListener('click',function(){
    var items=[];
    Object.keys(state.cart).forEach(function(sku){var q=state.cart[sku];if(!q)return;var p=state.products.find(function(x){return x.sku===sku;});if(p)items.push({sku:p.sku,name:p.name,qty:q,price:p.dealer_price});});
    if(!items.length){toast('กรุณาเลือกสินค้าอย่างน้อย 1 รายการ');return;}
    showCartModal(items);
  });

  function showCartModal(items){
    var body=document.getElementById('cartModalBody');
    var gt=0;
    var h='';
    items.forEach(function(i){
      var lt=i.price*i.qty;gt+=lt;
      h+='<div class="cart-item"><div class="cart-item-info"><div class="cart-item-name">'+esc(i.name)+'</div>';
      h+='<div class="cart-item-detail">'+esc(i.sku)+' × '+i.qty+' @ ฿'+fmt(i.price)+'</div></div>';
      h+='<div class="cart-item-total">฿'+fmt(lt)+'</div></div>';
    });
    // V.9: N5 — Customer Note
    h+='<div class="cart-note-section"><div class="cart-note-label">📝 หมายเหตุ (ถ้ามี)</div>';
    h+='<textarea class="cart-note-input" id="cartNoteInput" placeholder="เช่น ส่งด่วน, แพ็คแยก..."></textarea></div>';
    body.innerHTML=h;
    document.getElementById('cartModalTotal').textContent='฿'+fmt(gt);
    document.getElementById('cartConfirmBtn').textContent=state.editMode?'✏️ ยืนยันแก้ไข':'✅ ยืนยันสั่งสินค้า';
    document.getElementById('cartModal').classList.add('show');
  }

  document.getElementById('cartModalClose').addEventListener('click',function(){
    document.getElementById('cartModal').classList.remove('show');
  });
  document.getElementById('cartModal').addEventListener('click',function(e){
    if(e.target===this)this.classList.remove('show');
  });

  /* ═══ CONFIRM ORDER (from modal) ═══ */
  document.getElementById('cartConfirmBtn').addEventListener('click',function(){
    this.disabled=true; // FIX #3: ป้องกันกดซ้ำ → double order
    document.getElementById('cartModal').classList.remove('show');
    var items=[];
    Object.keys(state.cart).forEach(function(sku){var q=state.cart[sku];if(!q)return;var p=state.products.find(function(x){return x.sku===sku;});if(p)items.push({sku:p.sku,name:p.name,qty:q,price:p.dealer_price});});
    if(!items.length)return;

    var note=(document.getElementById('cartNoteInput')||{}).value||'';

    var overlay=document.getElementById('submitOverlay');
    overlay.classList.add('show');
    document.getElementById('submitSpinner').style.display='';
    document.getElementById('submitMsg').innerHTML='กำลังส่งคำสั่งซื้อ...<br>กรุณาอย่าปิดหน้านี้';

    var cartItems=items.map(function(i){return {sku:i.sku,name:i.name,qty:i.qty,price:i.price};});
    authFetch(REST+'place-order',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({items:cartItems,note:note||'',edit_ticket:state.editMode?state.editTicket:0})
    }).then(function(r){return r.json();}).then(function(d){
      if(d.success){
        document.getElementById('submitSpinner').style.display='none';
        document.getElementById('submitMsg').innerHTML='<div class="success">✅</div>ส่งออเดอร์เรียบร้อย!';
        state.cart={};saveCart();state.editMode=false;renderProducts();updateCartBar();
        document.getElementById('editBanner').style.display='none';
        setTimeout(function(){overlay.classList.remove('show');liff.closeWindow();},3000);
      } else {
        throw new Error(d.message||'Order failed');
      }
    }).catch(function(e){
      overlay.classList.remove('show');
      document.getElementById('cartConfirmBtn').disabled=false;
      toast('❌ '+e.message);
    });
  });

  /* ═══ RECOMMENDED SKUs ═══ */
  function loadRecommended(){
    authFetch(REST+'order-history')
    .then(function(r){return r.json();})
    .then(function(d){
      if(!d.success)return;
      state.recommendedSkus=d.recommended_skus||[];
      renderRecommendedChips();
    }).catch(function(){});
  }

  function renderRecommendedChips(){
    var sec=document.getElementById('freqSection');
    var el=document.getElementById('freqChips');
    if(!state.recommendedSkus.length||!state.products.length){sec.style.display='none';return;}
    el.innerHTML='';var shown=0;
    state.recommendedSkus.forEach(function(sku){
      var p=state.products.find(function(x){return x.sku.toUpperCase()===sku.toUpperCase();});
      if(!p||shown>=6)return;shown++;
      var chip=document.createElement('div');chip.className='freq-chip';
      chip.innerHTML='<span class="freq-icon">📦</span><span class="freq-name">'+esc(p.name.length>18?p.name.substr(0,18)+'…':p.name)+'</span><span class="freq-add">+</span>';
      chip.onclick=function(){
        state.cart[p.sku]=(state.cart[p.sku]||0)+1;saveCart();
        var qel=document.getElementById('qty-'+p.sku);if(qel)qel.textContent=state.cart[p.sku];
        updateCartBar();toast('🛒 +1 '+p.name.substr(0,20));
      };
      el.appendChild(chip);
    });
    sec.style.display=shown>0?'':'none';
  }

  /* ═══ V.9: F2 — ORDER HISTORY with Pagination + Filter ═══ */
  var historyFilters=[
    {key:'',label:'ทั้งหมด'},
    {key:'pending',label:'⏳ รอดำเนินการ'},
    {key:'awaiting_payment',label:'💳 รอชำระ'},
    {key:'paid',label:'✅ จ่ายแล้ว'},
    {key:'packed',label:'📦 แพ็คแล้ว'},
    {key:'shipped',label:'🚚 จัดส่งแล้ว'},
    {key:'backorder',label:'🚫 Backorder'},
    {key:'completed',label:'🏁 เสร็จสิ้น'},
    {key:'change_requested',label:'✏️ ขอแก้ไข'},
    {key:'claim_opened',label:'↩️ เคลม'},
    {key:'cancelled',label:'🗑️ ยกเลิก'},
  ];

  function renderHistoryFilter(){
    var el=document.getElementById('historyFilter');el.innerHTML='';
    historyFilters.forEach(function(f){
      var chip=document.createElement('button');
      chip.className='filter-chip'+(state.historyFilter===f.key?' active':'');
      chip.textContent=f.label;
      chip.onclick=function(){state.historyFilter=f.key;state.historyPage=1;state.orders=[];loadOrderHistory();};
      el.appendChild(chip);
    });
  }

  document.getElementById('historyRefresh').addEventListener('click',function(){
    state.historyPage=1;state.orders=[];loadOrderHistory();
  });

  function loadOrderHistory(append){
    if(state.historyLoading)return;
    state.historyLoading=true;
    if(!append){renderHistoryFilter();}
    var list=document.getElementById('historyList');
    if(!append)list.innerHTML='<div style="text-align:center;padding:40px;color:#999;"><div style="width:24px;height:24px;border:2px solid #ddd;border-top-color:#111;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 12px;"></div>กำลังโหลด...</div>';

    var url=REST+'order-history?page='+state.historyPage+'&per_page=10';
    if(state.historyFilter)url+='&status='+encodeURIComponent(state.historyFilter);

    authFetch(url)
    .then(function(r){return r.json();})
    .then(function(d){
      state.historyLoading=false;
      if(!d.success){if(!append)list.innerHTML='';document.getElementById('historyEmpty').style.display='block';return;}
      document.getElementById('historyEmpty').style.display='none';

      if(append){state.orders=state.orders.concat(d.orders||[]);}
      else{state.orders=d.orders||[];state.recommendedSkus=d.recommended_skus||[];}

      state.historyTotal=d.total||0;
      state.historyTotalPages=d.total_pages||1;

      document.getElementById('historyPageInfo').textContent=state.orders.length+' / '+state.historyTotal+' รายการ';

      renderHistory();
    }).catch(function(){state.historyLoading=false;if(!append)list.innerHTML='<div style="text-align:center;padding:40px;color:#ef4444;">❌ โหลดไม่สำเร็จ</div>';if(append){state.historyPage--;renderHistory();}});
  }

  function renderHistory(){
    var list=document.getElementById('historyList');list.innerHTML='';
    var sc={draft:{bg:'#f1f5f9',c:'#475569'},pending:{bg:'#f1f5f9',c:'#9e9e9e'},checking_stock:{bg:'#dbeafe',c:'#1d4ed8'},awaiting_confirm:{bg:'#fef3c7',c:'#92400e'},awaiting_payment:{bg:'#fed7aa',c:'#9a3412'},paid:{bg:'#dcfce7',c:'#166534'},packed:{bg:'#f3e5f5',c:'#7b1fa2'},shipped:{bg:'#fef9c3',c:'#854d0e'},completed:{bg:'#dcfce7',c:'#166534'},backorder:{bg:'#fee2e2',c:'#991b1b'},cancel_requested:{bg:'#fef2f2',c:'#dc2626'},cancelled:{bg:'#f1f5f9',c:'#64748b'},change_requested:{bg:'#f5f3ff',c:'#6d28d9'},claim_opened:{bg:'#fce7f3',c:'#9d174d'},claim_resolved:{bg:'#dcfce7',c:'#166534'}};
    var sl={draft:'📝 Draft',pending:'⏳ รอดำเนินการ',checking_stock:'🔍 เช็คสต็อก',awaiting_confirm:'📋 รอยืนยัน',awaiting_payment:'💳 รอชำระ',paid:'✅ ชำระแล้ว',packed:'📦 แพ็คแล้ว',shipped:'🚚 จัดส่งแล้ว',completed:'🏁 เสร็จสิ้น',backorder:'🚫 Backorder',cancel_requested:'⚠️ ขอยกเลิก',cancelled:'🗑️ ยกเลิก',change_requested:'✏️ ขอแก้ไข',claim_opened:'↩️ เคลม',claim_resolved:'✅ เคลมเสร็จ'};

    state.orders.forEach(function(o){
      var c=sc[o.status]||{bg:'#f1f5f9',c:'#475569'};
      var card=document.createElement('div');card.className='history-card';
      var h='<div class="history-top"><div><span class="history-id">'+esc(o.sub_label||'Ticket #'+o.id)+'</span><span class="history-date">'+esc(o.date)+'</span></div>';
      h+='<span class="history-status" style="background:'+c.bg+';color:'+c.c+';">'+(sl[o.status]||esc(o.status))+'</span></div>';
      if(o.items&&o.items.length>0){
        h+='<div class="hi-items">';
        o.items.forEach(function(it,i){
          h+='<div class="hi-row"><span class="hi-no">'+(i+1)+'.</span><span class="hi-name">'+esc(it.name||it.sku)+'</span><span class="hi-qty">x'+it.qty+'</span>';
          if(it.price)h+='<span class="hi-price">฿'+fmt(it.price)+'</span>';
          h+='</div>';
        });
        h+='</div>';
      }else{
        h+='<div class="history-items">'+esc(o.items_preview||'-')+'</div>';
      }

      var meta='';
      if(o.due_date&&(o.status==='awaiting_payment'||o.status==='paid'))meta+='<span class="due">📅 กำหนดชำระ: '+esc(o.due_date)+'</span>';
      if(o.tracking)meta+='<span>📦 '+esc(o.tracking)+(o.carrier?' ('+esc(o.carrier)+')':'')+'</span>';
      if(meta)h+='<div class="history-meta">'+meta+'</div>';

      h+='<div class="history-bottom"><span class="history-total">฿'+fmt(o.total)+'</span><div class="history-actions">';
      if(o.ticket_url)h+='<button class="history-btn detail" data-view="'+esc(o.ticket_url)+'">📋 ดู</button>';
      if(o.can_cancel&&o.status!=='cancelled'&&o.status!=='cancel_requested')h+='<button class="history-btn danger" data-cancel="'+esc(String(o.id))+'">❌ ยกเลิก</button>';
      h+='<button class="history-btn primary" data-reorder="'+esc(String(o.id))+'">🔄 สั่งซ้ำ</button>';
      if(o.status==='shipped'||o.status==='completed')h+='<button class="history-btn warn" data-claim="'+esc(String(o.id))+'">↩️ เคลม</button>';
      h+='</div></div>';
      card.innerHTML=h;list.appendChild(card);
    });

    // V.9: F2 — Load More button
    if(state.historyPage<state.historyTotalPages){
      var btn=document.createElement('button');btn.className='history-load-more';btn.textContent='📄 โหลดเพิ่ม (หน้า '+(state.historyPage+1)+'/'+state.historyTotalPages+')';
      btn.onclick=function(){state.historyPage++;btn.disabled=true;btn.textContent='⏳ กำลังโหลด...';loadOrderHistory(true);};
      list.appendChild(btn);
    }

    // Event listeners
    list.querySelectorAll('[data-view]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var url=this.getAttribute('data-view');
        if(liff.isInClient&&liff.isInClient())liff.openWindow({url:url,external:false});else window.open(url,'_blank');
      });
    });
    list.querySelectorAll('[data-cancel]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var oid=this.getAttribute('data-cancel');
        state.cancelTarget=oid;document.getElementById('cancelTicketId').textContent=oid;document.getElementById('cancelModal').classList.add('show');
      });
    });
    list.querySelectorAll('[data-reorder]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var oid=this.getAttribute('data-reorder');
        var order=state.orders.find(function(o){return o.id==oid;});
        if(!order||!order.items)return;
        var hasCart=Object.keys(state.cart).some(function(k){return state.cart[k]>0;});
        if(hasCart&&!confirm('ตะกร้าปัจจุบันจะถูกแทนที่ด้วยรายการเดิม ดำเนินการต่อ?'))return;
        state.cart={};
        order.items.forEach(function(item){if(item.sku&&item.qty)state.cart[item.sku]=item.qty;});
        saveCart();
        document.getElementById('tabCatalog').click();renderProducts();updateCartBar();toast('🔄 โหลดรายการเดิมแล้ว!');
      });
    });
    list.querySelectorAll('[data-claim]').forEach(function(btn){
      btn.addEventListener('click',function(e){e.stopPropagation();var oid=this.getAttribute('data-claim');
        liff.sendMessages([{type:'text',text:'@เคลม #'+oid}]).then(function(){toast('↩️ ส่งคำขอเคลมแล้ว');setTimeout(function(){liff.closeWindow();},1500);});
      });
    });
  }

  /* ═══ CANCEL MODAL ═══ */
  document.getElementById('cancelModal').addEventListener('click',function(e){if(e.target===this){this.classList.remove('show');state.cancelTarget=null;}});
  document.getElementById('cancelNo').addEventListener('click',function(){
    document.getElementById('cancelModal').classList.remove('show');state.cancelTarget=null;
  });
  document.getElementById('cancelYes').addEventListener('click',function(){
    if(!state.cancelTarget)return;var tid=state.cancelTarget;
    document.getElementById('cancelModal').classList.remove('show');
    liff.sendMessages([{type:'text',text:'@ยกเลิก #'+tid}]).then(function(){
      toast('⚠️ ส่งคำขอยกเลิก #'+tid+' แล้ว');
      var order=state.orders.find(function(o){return o.id==tid;});
      if(order){order.status='cancel_requested';order.can_cancel=false;}
      renderHistory();state.cancelTarget=null;
    }).catch(function(e){toast('❌ ส่งไม่สำเร็จ: '+e.message);state.cancelTarget=null;});
  });

  /* ═══ V.9: N2 — EDIT ORDER ═══ */
  function loadEditOrder(tid){
    state.editMode=true;
    document.getElementById('editBanner').style.display='flex';
    document.getElementById('cartSubmit').textContent='✏️ ส่งรายการแก้ไข';
    authFetch(REST+'order-detail?ticket_id='+tid)
    .then(function(r){return r.json();})
    .then(function(d){
      if(!d.success||!d.items){state.editMode=false;document.getElementById('editBanner').style.display='none';document.getElementById('cartSubmit').textContent='🛒 สั่งสินค้า';toast('❌ โหลดรายการไม่สำเร็จ');return;}
      state.cart={};
      d.items.forEach(function(i){if(i.sku&&i.qty)state.cart[i.sku]=i.qty;});
      saveCart();
      renderProducts();updateCartBar();
      toast('✏️ โหลดรายการเดิมแล้ว แก้ไขได้เลย!');
    }).catch(function(){state.editMode=false;document.getElementById('editBanner').style.display='none';document.getElementById('cartSubmit').textContent='🛒 สั่งสินค้า';toast('❌ เกิดข้อผิดพลาด');});
  }

  document.getElementById('searchBox').addEventListener('input',function(){renderProducts();});

  function showAuthError(t,m,retryable){
    document.getElementById('loadingScreen').classList.add('hide');
    document.getElementById('authErrTitle').textContent=t;
    document.getElementById('authErrMsg').textContent=m;
    document.getElementById('authError').style.display='block';
    var btn=document.getElementById('authRetryBtn');
    if(retryable){
      btn.style.display='inline-block';
      btn.onclick=function(){
        btn.style.display='none';
        document.getElementById('authError').style.display='none';
        document.getElementById('loadingScreen').classList.remove('hide');
        document.querySelector('.loading-text').textContent='กำลังเชื่อมต่อใหม่...';
        authAndLoad();
      };
    }else{btn.style.display='none';}
  }
  function showLinkExpired(){
    document.getElementById('loadingScreen').classList.add('hide');
    document.getElementById('authError').style.display='none';
    document.getElementById('linkExpired').style.display='block';
  }
  function toast(m){var el=document.getElementById('liffToast');el.textContent=m;el.classList.add('show');setTimeout(function(){el.classList.remove('show');},3000);}
  function fmt(n){return Math.round(n).toLocaleString();}
  function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML;}
})();
</script>
</body>
</html>
