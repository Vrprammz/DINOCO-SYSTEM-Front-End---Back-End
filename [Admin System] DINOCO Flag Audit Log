 * ╔══════════════════════════════════════════════════════════════════╗
 * ║  [Admin System] DINOCO Flag Audit Log                            ║
 * ║  Version: V.1.1 (2026-04-30) — Round 28: register dinoco_flag_   ║
 * ║    audit_retention_cron via dinoco_register_cron heartbeat       ║
 * ║    tracking (Health Monitor visibility). Fallback to legacy      ║
 * ║    add_action preserved when Health Monitor snippet not synced.  ║
 * ║  Version: V.1.0 (2026-04-29) — Round 3 Pending Items Sprint      ║
 * ║  DB_ID: (pending — populate after first WP Code Snippets sync)   ║
 * ║  Description: Centralized audit trail for ALL feature-flag and   ║
 * ║    config-key toggles across DINOCO (B2B, B2F, Observability,    ║
 * ║    GDPR, Flash V.42, BO config, etc).                            ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *
 * PROBLEM
 * -------
 * Each subsystem stamps wp_options separately:
 *   - BO Snippet 16        → b2b_flag_bo_system / beta_distributors / 12 BO config keys
 *   - B2F Audit            → b2f_flag_v11_explicit_mode / order_intent / shadow_write / read_from_junction / coverage_autosync
 *   - Flash V.42 Go-Live   → dinoco_shipping_meta_enabled (via dinoco_set_shipping_flag)
 *   - V.33.5 hotfixes      → dinoco_oos_gate_hierarchy_compute / dinoco_auto_unlock_enabled
 *   - Observability        → dinoco_obs_sentry_enabled / correlation_enabled / structured_log
 *   - GDPR                 → dinoco_gdpr_enabled
 *   - Inventory God Mode   → varies
 *
 * Existing audit was scattered:
 *   - b2f_log_flag_change()  → log file (text), no query
 *   - b2b_log()              → log file (text), no query
 *   - dinoco_set_shipping_flag → wp_dinoco_flash_audit (only Flash V.42)
 *   - Most direct update_option() calls → NO audit at all
 *
 * Incident debug "ใครเปิด flag X เมื่อไหร่?" → manual grep across log files (slow, lossy).
 *
 * SOLUTION
 * --------
 * Single canonical table `wp_dinoco_flag_audit` (90-day retention) +
 * `dinoco_flag_audit_log()` helper that ALL flag toggle sites can call.
 *
 *   - Persistent (queryable) instead of text log files
 *   - Auto-redacts PII via dinoco_obs_redact_context (if loaded)
 *   - Admin viewer UI (`[dinoco_flag_audit_viewer]` shortcode)
 *   - REST API (`/wp-json/dinoco/v1/flag-audit*`) for cron/CLI tools
 *   - 90-day TTL via cron `dinoco_flag_audit_retention_cron`
 *   - Defensive: silent fail-soft if table missing (no fatal)
 *
 * DESIGN PRINCIPLES (Modal Helpers / Observability / Audit Log pattern)
 *   - DUAL-WRITE — never replaces existing audit (b2f_log_flag_change keeps logging)
 *   - NON-THROWING — best-effort insert; failure → error_log + return false
 *   - ADDITIVE     — zero behavior change at existing toggle sites
 *
 * Public API:
 *   dinoco_flag_audit_log( $flag, $old, $new, [$reason], [$source] ) : int|false
 *   dinoco_flag_audit_query( $args ) : array      // admin viewer + REST
 *   dinoco_flag_audit_retention_run() : int       // cron + manual
 *
 * Backward compat:
 *   - If flag value unchanged → no-op (skip insert)
 *   - If table missing → silent return false (snippet activated before Snippet 15 sync)
 *   - If function_exists() guard at caller → safe to deploy in any order
 */

if ( ! defined( 'ABSPATH' ) ) exit;

/* ═══════════════════════════════════════════════════════════════════════════
 * 1. SCHEMA INSTALL (lazy, idempotent)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_flag_audit_schema_install' ) ) {
    /**
     * Install wp_dinoco_flag_audit table via dbDelta. Idempotent — tracks
     * version in wp_option 'dinoco_flag_audit_schema_version'.
     *
     * Schema rationale:
     *   - flag_name VARCHAR(64) — covers all current keys (longest:
     *     'dinoco_oos_gate_hierarchy_compute' = 33 chars; 64 = headroom)
     *   - old/new VARCHAR(255) — most flags are bool '0'|'1' or short JSON;
     *     longer values truncated by helper before insert
     *   - source ENUM-like VARCHAR(32) — not real ENUM (ALTER-friendly)
     *   - 3 indexes: flag_name (filter by flag), changed_at (time queries
     *     + retention DELETE), user_id (audit "who changed")
     *
     * @return void
     */
    function dinoco_flag_audit_schema_install() {
        global $wpdb;

        $current = get_option( 'dinoco_flag_audit_schema_version', '0' );
        $target  = '1.0';
        if ( $current === $target ) return;

        $table   = $wpdb->prefix . 'dinoco_flag_audit';
        $charset = $wpdb->get_charset_collate();

        // dbDelta requires specific formatting (PRIMARY KEY inside, no FOREIGN KEY)
        $sql = "CREATE TABLE {$table} (
            id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
            flag_name VARCHAR(64) NOT NULL,
            old_value VARCHAR(255) DEFAULT NULL,
            new_value VARCHAR(255) DEFAULT NULL,
            user_id BIGINT(20) UNSIGNED DEFAULT NULL,
            source VARCHAR(32) DEFAULT NULL,
            reason VARCHAR(255) DEFAULT NULL,
            request_ip VARCHAR(45) DEFAULT NULL,
            user_agent VARCHAR(128) DEFAULT NULL,
            request_id VARCHAR(64) DEFAULT NULL,
            changed_at DATETIME NOT NULL,
            PRIMARY KEY  (id),
            KEY idx_flag_name (flag_name),
            KEY idx_changed_at (changed_at),
            KEY idx_user_id (user_id)
        ) {$charset};";

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';
        dbDelta( $sql );

        update_option( 'dinoco_flag_audit_schema_version', $target, false );
    }
}

// Lazy install on admin_init (fast — dbDelta is idempotent + version-gated)
add_action( 'admin_init', function() {
    if ( get_option( 'dinoco_flag_audit_schema_version', '0' ) !== '1.0' ) {
        dinoco_flag_audit_schema_install();
    }
} );

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. WRITE API — dinoco_flag_audit_log()
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_flag_audit_serialize_value' ) ) {
    /**
     * Serialize an arbitrary value for storage in VARCHAR(255).
     *
     * Rules:
     *   - bool   → '1' / '0' (matches wp_options convention)
     *   - null   → '' (NULL handled at caller via DB layer)
     *   - scalar → cast to string
     *   - array/object → JSON encode (truncated to 255 chars with '…' suffix if longer)
     *
     * @param mixed $value
     * @return string|null  null if input is null (DB stores NULL); else string ≤ 255
     */
    function dinoco_flag_audit_serialize_value( $value ) {
        if ( $value === null ) return null;
        if ( is_bool( $value ) ) return $value ? '1' : '0';
        if ( is_scalar( $value ) ) return substr( (string) $value, 0, 255 );
        // Array/object — JSON encode
        $json = wp_json_encode( $value );
        if ( $json === false ) $json = '[encode_failed]';
        if ( strlen( $json ) > 255 ) {
            // Reserve 1 char for ellipsis marker
            $json = substr( $json, 0, 254 ) . '…';
        }
        return $json;
    }
}

if ( ! function_exists( 'dinoco_flag_audit_resolve_ip' ) ) {
    /**
     * Resolve client IP. Prefers GDPR snippet's Cloudflare/proxy-aware helper,
     * falls back to raw REMOTE_ADDR if GDPR snippet missing.
     *
     * @return string IPv4/IPv6 (max 45 chars) or '' if unavailable
     */
    function dinoco_flag_audit_resolve_ip() {
        if ( function_exists( 'dinoco_gdpr_get_client_ip' ) ) {
            return (string) dinoco_gdpr_get_client_ip();
        }
        return isset( $_SERVER['REMOTE_ADDR'] ) ? (string) $_SERVER['REMOTE_ADDR'] : '';
    }
}

if ( ! function_exists( 'dinoco_flag_audit_log' ) ) {
    /**
     * Persist a flag-change event. No-op if old === new (idempotent re-saves).
     *
     * Never throws — if anything fails (table missing, DB error), logs to
     * error_log() and returns false. Callers SHOULD NOT branch on result.
     *
     * @param string $flag_name  Flag option key (e.g. 'b2b_flag_bo_system')
     * @param mixed  $old_value  Previous value (any type — serialized)
     * @param mixed  $new_value  New value (any type — serialized)
     * @param string $reason     Optional admin note (free-text, ≤255 chars)
     * @param string $source     One of 'admin_ui'|'cron'|'cli'|'rest_api'|'snippet_init'|'auto_rollback'|'other'
     * @return int|false  insert_id on success, false otherwise
     */
    function dinoco_flag_audit_log( $flag_name, $old_value, $new_value, $reason = '', $source = 'admin_ui' ) {
        // No-op short-circuit — comparison preserves type for bool/string/int.
        // Strict equality avoids false-positive "0" vs 0 changes.
        if ( $old_value === $new_value ) return false;

        // Loose-equality also no-op — admin saving same form twice with mixed
        // type (e.g. wp_options stores '1' string, code passes true bool).
        // We DO want to log type-only changes for forensics, BUT not when
        // both serialize to the same string. Let serializer decide.
        $old_str = dinoco_flag_audit_serialize_value( $old_value );
        $new_str = dinoco_flag_audit_serialize_value( $new_value );
        if ( $old_str === $new_str ) return false;

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_flag_audit';

        // Defensive — schema not yet installed (snippet activated before Snippet 15 sync)
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SHOW TABLES LIKE %s", $wpdb->esc_like( $table )
        ) );
        if ( $exists !== $table ) {
            // Try lazy install once per request
            static $tried_install = false;
            if ( ! $tried_install ) {
                $tried_install = true;
                if ( function_exists( 'dinoco_flag_audit_schema_install' ) ) {
                    dinoco_flag_audit_schema_install();
                    $exists = $wpdb->get_var( $wpdb->prepare(
                        "SHOW TABLES LIKE %s", $wpdb->esc_like( $table )
                    ) );
                }
            }
            if ( $exists !== $table ) {
                if ( ! get_transient( 'dinoco_flag_audit_table_missing_logged' ) ) {
                    error_log( '[DINOCO_FLAG_AUDIT] table missing — flag changes not persisted' );
                    set_transient( 'dinoco_flag_audit_table_missing_logged', 1, HOUR_IN_SECONDS );
                }
                return false;
            }
        }

        // Whitelist sources — keeps cardinality bounded for filter UI
        $allowed_sources = array( 'admin_ui', 'cron', 'cli', 'rest_api', 'snippet_init', 'auto_rollback', 'manual_rollback', 'other' );
        if ( ! in_array( $source, $allowed_sources, true ) ) $source = 'other';

        $request_id = function_exists( 'dinoco_obs_get_request_id' )
            ? (string) dinoco_obs_get_request_id()
            : '';

        $row = array(
            'flag_name'  => substr( (string) $flag_name, 0, 64 ),
            'old_value'  => $old_str,    // already trimmed by serializer
            'new_value'  => $new_str,
            'user_id'    => get_current_user_id() ?: null,
            'source'     => $source,
            'reason'     => substr( (string) $reason, 0, 255 ),
            'request_ip' => substr( dinoco_flag_audit_resolve_ip(), 0, 45 ),
            'user_agent' => isset( $_SERVER['HTTP_USER_AGENT'] )
                ? substr( (string) $_SERVER['HTTP_USER_AGENT'], 0, 128 )
                : null,
            'request_id' => $request_id !== '' ? substr( $request_id, 0, 64 ) : null,
            'changed_at' => current_time( 'mysql' ),
        );

        try {
            $ok = $wpdb->insert( $table, $row );
            if ( $ok === false ) {
                if ( ! get_transient( 'dinoco_flag_audit_insert_failed_logged' ) ) {
                    error_log( '[DINOCO_FLAG_AUDIT] INSERT failed: ' . $wpdb->last_error );
                    set_transient( 'dinoco_flag_audit_insert_failed_logged', 1, HOUR_IN_SECONDS );
                }
                return false;
            }
            return (int) $wpdb->insert_id;
        } catch ( \Throwable $e ) {
            error_log( '[DINOCO_FLAG_AUDIT] exception: ' . $e->getMessage() );
            return false;
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 3. QUERY API — dinoco_flag_audit_query() / get_by_id()
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_flag_audit_query' ) ) {
    /**
     * Query audit rows with filters + pagination.
     *
     * @param array $args {
     *   @type string $flag       Filter by flag_name (exact match)
     *   @type int    $user_id    Filter by user_id
     *   @type string $source     Filter by source
     *   @type int    $days       Filter by changed_at >= NOW() - N days (default 30)
     *   @type string $from       Filter changed_at >= 'YYYY-MM-DD HH:MM:SS'
     *   @type string $to         Filter changed_at <= 'YYYY-MM-DD HH:MM:SS'
     *   @type int    $limit      Page size (default 50, max 500)
     *   @type int    $offset     Pagination offset (default 0)
     *   @type string $orderby    'changed_at'|'flag_name' (default changed_at)
     *   @type string $order      'ASC'|'DESC' (default DESC)
     * }
     * @return array { rows: array<object>, total: int }
     */
    function dinoco_flag_audit_query( $args = array() ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_flag_audit';

        $defaults = array(
            'flag'    => '',
            'user_id' => 0,
            'source'  => '',
            'days'    => 30,
            'from'    => '',
            'to'      => '',
            'limit'   => 50,
            'offset'  => 0,
            'orderby' => 'changed_at',
            'order'   => 'DESC',
        );
        $args = wp_parse_args( $args, $defaults );

        // Sanitize
        $where  = array( '1=1' );
        $params = array();

        if ( ! empty( $args['flag'] ) ) {
            $where[]  = 'flag_name = %s';
            $params[] = (string) $args['flag'];
        }
        if ( ! empty( $args['user_id'] ) ) {
            $where[]  = 'user_id = %d';
            $params[] = (int) $args['user_id'];
        }
        if ( ! empty( $args['source'] ) ) {
            $where[]  = 'source = %s';
            $params[] = (string) $args['source'];
        }
        if ( ! empty( $args['from'] ) ) {
            $where[]  = 'changed_at >= %s';
            $params[] = (string) $args['from'];
        }
        if ( ! empty( $args['to'] ) ) {
            $where[]  = 'changed_at <= %s';
            $params[] = (string) $args['to'];
        }
        if ( empty( $args['from'] ) && empty( $args['to'] ) && (int) $args['days'] > 0 ) {
            $where[]  = 'changed_at >= DATE_SUB(NOW(), INTERVAL %d DAY)';
            $params[] = (int) $args['days'];
        }

        $orderby = in_array( $args['orderby'], array( 'changed_at', 'flag_name', 'id' ), true )
            ? $args['orderby'] : 'changed_at';
        $order   = strtoupper( $args['order'] ) === 'ASC' ? 'ASC' : 'DESC';

        $limit  = max( 1, min( 500, (int) $args['limit'] ) );
        $offset = max( 0, (int) $args['offset'] );

        $where_sql = implode( ' AND ', $where );

        // Count first (without LIMIT/OFFSET)
        $count_sql = "SELECT COUNT(*) FROM {$table} WHERE {$where_sql}";
        $total = (int) ( $params
            ? $wpdb->get_var( $wpdb->prepare( $count_sql, $params ) )
            : $wpdb->get_var( $count_sql ) );

        // Rows
        $row_sql = "SELECT * FROM {$table} WHERE {$where_sql} ORDER BY {$orderby} {$order} LIMIT %d OFFSET %d";
        $row_params = array_merge( $params, array( $limit, $offset ) );
        $rows = $wpdb->get_results( $wpdb->prepare( $row_sql, $row_params ) );
        if ( ! is_array( $rows ) ) $rows = array();

        return array( 'rows' => $rows, 'total' => $total );
    }
}

if ( ! function_exists( 'dinoco_flag_audit_get_by_id' ) ) {
    /**
     * Fetch single row by ID (admin viewer detail page).
     * @param int $id
     * @return object|null
     */
    function dinoco_flag_audit_get_by_id( $id ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_flag_audit';
        return $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$table} WHERE id = %d LIMIT 1",
            (int) $id
        ) );
    }
}

if ( ! function_exists( 'dinoco_flag_audit_distinct_flags' ) ) {
    /**
     * Get distinct flag names for filter dropdown UI. Cached 60s.
     * @return array<string>
     */
    function dinoco_flag_audit_distinct_flags() {
        $cache_key = 'dinoco_flag_audit_distinct_flags';
        $cached = get_transient( $cache_key );
        if ( is_array( $cached ) ) return $cached;
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_flag_audit';
        $rows = $wpdb->get_col( "SELECT DISTINCT flag_name FROM {$table} ORDER BY flag_name ASC LIMIT 200" );
        if ( ! is_array( $rows ) ) $rows = array();
        set_transient( $cache_key, $rows, MINUTE_IN_SECONDS );
        return $rows;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 4. RETENTION CRON (90-day default)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_flag_audit_retention_run' ) ) {
    /**
     * DELETE rows older than retention_days. Chunked 1000/iter to avoid
     * long lock + deadlock with concurrent INSERTs. Max 20 iterations
     * (= 20K rows/run cap — anything more carries to next run).
     *
     * Default 90 days (configurable via wp_option 'dinoco_flag_audit_retention_days').
     *
     * @return int Total rows deleted this run
     */
    function dinoco_flag_audit_retention_run() {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_flag_audit';
        if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $table ) ) ) !== $table ) {
            return 0;
        }

        $days = (int) get_option( 'dinoco_flag_audit_retention_days', 90 );
        if ( $days < 30 ) $days = 30;   // Floor — protect against misconfiguration
        if ( $days > 365 ) $days = 365; // Ceiling

        $total_deleted = 0;
        $max_iters     = 20;
        for ( $i = 0; $i < $max_iters; $i++ ) {
            $deleted = $wpdb->query( $wpdb->prepare(
                "DELETE FROM {$table} WHERE changed_at < DATE_SUB(NOW(), INTERVAL %d DAY) LIMIT 1000",
                $days
            ) );
            if ( ! $deleted || $deleted === false ) break;
            $total_deleted += (int) $deleted;
            if ( $deleted < 1000 ) break;  // Last batch — stop early
            // Tiny gap to let other queries breathe
            usleep( 50000 ); // 50ms
        }

        if ( $total_deleted > 0 ) {
            update_option( 'dinoco_flag_audit_retention_last_run', array(
                'ran_at'  => current_time( 'mysql' ),
                'deleted' => $total_deleted,
                'days'    => $days,
            ), false );
        }

        return $total_deleted;
    }
}

if ( ! wp_next_scheduled( 'dinoco_flag_audit_retention_cron' ) ) {
    // Schedule daily at ~03:00 server time (slightly offset so Bangkok-area
    // cron fleet doesn't all hit DB at exactly 03:00 — cluster spread).
    $first_run = strtotime( 'tomorrow 03:00' );
    if ( ! $first_run ) $first_run = time() + DAY_IN_SECONDS;
    wp_schedule_event( $first_run, 'daily', 'dinoco_flag_audit_retention_cron' );
}
// V.1.1 Round 28: register heartbeat tracking via dinoco_register_cron when Health Monitor available;
// fallback to legacy add_action when snippet not synced (preserves backward compat).
if ( function_exists( 'dinoco_register_cron' ) && function_exists( 'dinoco_flag_audit_retention_run' ) ) {
    dinoco_register_cron( 'dinoco_flag_audit_retention_cron', 'daily', 'dinoco_flag_audit_retention_run' );
} else {
    add_action( 'dinoco_flag_audit_retention_cron', 'dinoco_flag_audit_retention_run' );
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 5. REST API — /wp-json/dinoco/v1/flag-audit*
 * ═══════════════════════════════════════════════════════════════════════════ */

add_action( 'rest_api_init', function() {

    $perm_admin = function() {
        return current_user_can( 'manage_options' );
    };

    // GET /flag-audit — list with filters
    register_rest_route( 'dinoco/v1', '/flag-audit', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function( WP_REST_Request $req ) {
            $args = array(
                'flag'    => sanitize_text_field( (string) $req->get_param( 'flag' ) ),
                'user_id' => absint( $req->get_param( 'user_id' ) ),
                'source'  => sanitize_text_field( (string) $req->get_param( 'source' ) ),
                'days'    => max( 1, min( 365, (int) ( $req->get_param( 'days' ) ?: 30 ) ) ),
                'from'    => sanitize_text_field( (string) $req->get_param( 'from' ) ),
                'to'      => sanitize_text_field( (string) $req->get_param( 'to' ) ),
                'limit'   => max( 1, min( 500, (int) ( $req->get_param( 'limit' ) ?: 50 ) ) ),
                'offset'  => max( 0, (int) $req->get_param( 'offset' ) ),
                'orderby' => sanitize_text_field( (string) ( $req->get_param( 'orderby' ) ?: 'changed_at' ) ),
                'order'   => sanitize_text_field( (string) ( $req->get_param( 'order' ) ?: 'DESC' ) ),
            );
            $result = dinoco_flag_audit_query( $args );
            return rest_ensure_response( array(
                'success' => true,
                'data'    => $result['rows'],
                'meta'    => array(
                    'total'  => $result['total'],
                    'limit'  => $args['limit'],
                    'offset' => $args['offset'],
                    'flags'  => dinoco_flag_audit_distinct_flags(),
                ),
            ) );
        },
    ) );

    // GET /flag-audit/{id} — single row
    register_rest_route( 'dinoco/v1', '/flag-audit/(?P<id>\d+)', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function( WP_REST_Request $req ) {
            $id = (int) $req['id'];
            $row = dinoco_flag_audit_get_by_id( $id );
            if ( ! $row ) {
                return new WP_Error( 'not_found', 'Audit row not found', array( 'status' => 404 ) );
            }
            return rest_ensure_response( array( 'success' => true, 'data' => $row ) );
        },
    ) );

    // POST /flag-audit/retention/run — manual trigger (admin only)
    register_rest_route( 'dinoco/v1', '/flag-audit/retention/run', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin,
        'callback'            => function( WP_REST_Request $req ) {
            $deleted = dinoco_flag_audit_retention_run();
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'deleted' => $deleted,
                    'last_run' => get_option( 'dinoco_flag_audit_retention_last_run', null ),
                ),
            ) );
        },
    ) );

    // GET /flag-audit/export — CSV download
    register_rest_route( 'dinoco/v1', '/flag-audit/export', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function( WP_REST_Request $req ) {
            // Reuse query but cap at 5000 rows for CSV
            $args = array(
                'flag'   => sanitize_text_field( (string) $req->get_param( 'flag' ) ),
                'days'   => max( 1, min( 365, (int) ( $req->get_param( 'days' ) ?: 90 ) ) ),
                'limit'  => 5000,
                'offset' => 0,
            );
            $result = dinoco_flag_audit_query( $args );

            // Build CSV
            $csv = "id,flag_name,old_value,new_value,user_id,source,reason,request_ip,changed_at\n";
            foreach ( $result['rows'] as $r ) {
                $csv .= sprintf(
                    "%d,%s,%s,%s,%d,%s,%s,%s,%s\n",
                    (int) $r->id,
                    str_replace( ',', ' ', (string) $r->flag_name ),
                    str_replace( ',', ' ', (string) $r->old_value ),
                    str_replace( ',', ' ', (string) $r->new_value ),
                    (int) $r->user_id,
                    str_replace( ',', ' ', (string) $r->source ),
                    str_replace( array( ',', "\n", "\r" ), ' ', (string) $r->reason ),
                    (string) $r->request_ip,
                    (string) $r->changed_at
                );
            }

            // UTF-8 BOM for Excel compat
            $csv = "\xEF\xBB\xBF" . $csv;

            $filename = 'dinoco_flag_audit_' . current_time( 'Ymd_His' ) . '.csv';
            $resp = new WP_REST_Response( $csv );
            $resp->set_headers( array(
                'Content-Type'        => 'text/csv; charset=utf-8',
                'Content-Disposition' => 'attachment; filename="' . $filename . '"',
            ) );
            return $resp;
        },
    ) );
} );

