/* ═══════════════════════════════════════════════════════════════════════════
 * 7. PASSIVE HOOK — auto-capture update_option() on tracked flags
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * For sites we cannot edit directly (e.g. Snippet 1 V.34.25 dinoco_set_shipping_flag,
 * Flash Go-Live wizard's update_option() outside our reach, or any future flag
 * not explicitly wired), WordPress's `update_option_{$option}` action fires AFTER
 * every persisted change. We listen for a curated list and audit-log automatically.
 *
 * This is a SAFETY NET — explicit dinoco_flag_audit_log() calls at toggle sites
 * are still preferred (carry richer reason/source context). When both fire for
 * the same flag, the no-op short-circuit (old===new) prevents duplicate rows.
 *
 * Filter `dinoco_flag_audit_tracked_flags` lets future snippets register their
 * own flags without modifying this file. */

if ( ! function_exists( 'dinoco_flag_audit_get_tracked_flags' ) ) {
    /**
     * Curated whitelist of flags whose update_option events we auto-capture.
     * Filterable so other snippets can register additional flags.
     *
     * @return array<string>
     */
    function dinoco_flag_audit_get_tracked_flags() {
        $defaults = array(
            // B2B BO Backorder System
            'b2b_flag_bo_system',
            'b2b_flag_bo_beta_distributors',
            // V.33.5 hotfix toggles (BO Snippet 16 Flag Manager)
            'dinoco_oos_gate_hierarchy_compute',
            'dinoco_auto_unlock_enabled',
            // Flash Shipping V.42 master kill switch
            'dinoco_shipping_meta_enabled',
            // B2F Migration Audit (Option F Hybrid Shadow-Write + V.7.0 Order Intent)
            'b2f_flag_shadow_write',
            'b2f_flag_read_from_junction',
            'b2f_flag_auto_sync_sets',
            'b2f_flag_v11_explicit_mode',
            'b2f_flag_order_intent',
            'b2f_flag_coverage_autosync',
            // Observability scaffolding (V.1.0 — Sprint 5)
            'dinoco_obs_sentry_enabled',
            'dinoco_obs_correlation_enabled',
            'dinoco_obs_structured_log',
            // GDPR scaffolding (V.1.0 — Sprint 5)
            'dinoco_gdpr_enabled',
            // Catch-all retention setting (also audited if changed)
            'dinoco_flag_audit_retention_days',
        );
        return apply_filters( 'dinoco_flag_audit_tracked_flags', $defaults );
    }
}

if ( ! function_exists( 'dinoco_flag_audit_passive_listener' ) ) {
    /**
     * Generic update_option listener — fires for EVERY wp_options write.
     * We filter inside to only audit tracked flags.
     *
     * Hook signature (WP):
     *   do_action( "update_option_{$option}", $old_value, $value, $option )
     *
     * Using the generic 'updated_option' (without {$option} suffix) so we get
     * one registration covering all flags — cheaper than 16 add_action calls.
     *
     * @param string $option   Option name
     * @param mixed  $old_value
     * @param mixed  $value
     * @return void
     */
    function dinoco_flag_audit_passive_listener( $option, $old_value, $value ) {
        // Whitelist gate — short-circuit for unrelated wp_options writes.
        // dinoco_flag_audit_get_tracked_flags() is cached statically inside
        // get_tracked_flags() per request via apply_filters memoization.
        static $tracked_set = null;
        if ( $tracked_set === null ) {
            $tracked_set = array_flip( dinoco_flag_audit_get_tracked_flags() );
        }
        if ( ! isset( $tracked_set[ $option ] ) ) return;

        // Re-entrancy guard — explicit dinoco_flag_audit_log() callers may
        // still trigger this passive listener (since they call update_option
        // before logging). The no-op short-circuit on (old===new) inside
        // dinoco_flag_audit_log handles deduplication, but we also flag
        // a per-request seen set to skip the second call entirely (saves
        // a redundant SHOW TABLES + serialize + INSERT attempt).
        static $seen = array();
        $seen_key = $option . '|' . md5( serialize( array( $old_value, $value ) ) );
        if ( isset( $seen[ $seen_key ] ) ) return;
        $seen[ $seen_key ] = true;

        if ( function_exists( 'dinoco_flag_audit_log' ) ) {
            dinoco_flag_audit_log( $option, $old_value, $value, '[passive: updated_option hook]', 'other' );
        }
    }
}

// Register listener — `updated_option` fires for ALL wp_options writes.
// We filter inside listener for tracked flags only — keeps overhead minimal.
add_action( 'updated_option', 'dinoco_flag_audit_passive_listener', 99, 3 );

/* ═══════════════════════════════════════════════════════════════════════════
 * 8. CONVENIENCE WRAPPER — for use INSIDE update_option() chains
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_flag_set' ) ) {
    /**
     * Atomic flag setter with audit log built in.
     * Reads current value, persists new, logs change.
     *
     * Usage (B2B / B2F / Inventory toggle endpoints):
     *
     *   dinoco_flag_set( 'b2b_flag_bo_system', true, 'Phase A-D rollout', 'admin_ui' );
     *
     * @param string $flag    Option key
     * @param mixed  $new_val New value
     * @param string $reason  Free-text reason
     * @param string $source  'admin_ui'|'rest_api'|'cron'|'cli'|...
     * @return array { ok, old, new, no_change?, audit_id? }
     */
    function dinoco_flag_set( $flag, $new_val, $reason = '', $source = 'admin_ui' ) {
        $old_val = get_option( $flag, null );

        // Normalize bools to '0'/'1' string for wp_options compat (matches Flash Go-Live)
        if ( is_bool( $new_val ) ) $new_val = $new_val ? '1' : '0';

        // No-op detection — avoid writing wp_option + audit row
        $cmp_old = is_bool( $old_val ) ? ( $old_val ? '1' : '0' ) : $old_val;
        if ( $cmp_old === $new_val ) {
            return array( 'ok' => true, 'old' => $old_val, 'new' => $new_val, 'no_change' => true );
        }

        $persist_ok = update_option( $flag, $new_val );

        $audit_id = false;
        if ( function_exists( 'dinoco_flag_audit_log' ) ) {
            $audit_id = dinoco_flag_audit_log( $flag, $old_val, $new_val, $reason, $source );
        }

        return array(
            'ok'       => (bool) $persist_ok,
            'old'      => $old_val,
            'new'      => $new_val,
            'audit_id' => $audit_id,
        );
    }
}

