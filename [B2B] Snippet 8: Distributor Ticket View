// Cancel
function cancelOrder(tid){
  document.getElementById('cfmTitle').textContent='ยกเลิกออเดอร์ #'+tid+'?';
  document.getElementById('cfmDesc').textContent='ระบบจะยกเลิกออเดอร์นี้';
  document.getElementById('confirmOverlay').classList.add('show');
  document.getElementById('cfmOk').onclick=function(){
    closeCfm();showToast('กำลังยกเลิก...');
    apiCall('cancel-request',{ticket_id:tid},function(d){
      if(d.success){showToast('ส่งคำขอยกเลิกแล้ว');setTimeout(function(){location.reload();},1500);}
      else{showToast(d.message||'Error','err');}
    });
  };
}

// Confirm action
var pendingMsg='';
function confirmAction(title,msg){
  pendingMsg=msg;
  document.getElementById('cfmTitle').textContent=title;
  document.getElementById('cfmDesc').textContent='ระบบจะส่งคำสั่งไปยังกลุ่ม LINE ของคุณ';
  document.getElementById('confirmOverlay').classList.add('show');
  document.getElementById('cfmOk').onclick=function(){closeCfm();sendMsg(pendingMsg);};
}
function closeCfm(){document.getElementById('confirmOverlay').classList.remove('show');pendingMsg='';}
document.getElementById('confirmOverlay').addEventListener('click',function(e){if(e.target===this)closeCfm();});

function sendMsg(txt){
  if(!txt)return;
  if(!liffOK||!liff.isInClient()){showToast('กรุณาเปิดผ่าน LINE','err');return;}
  liff.sendMessages([{type:'text',text:txt}]).then(function(){showToast('ส่งคำสั่งแล้ว');setTimeout(function(){liff.closeWindow();},1500);}).catch(function(e){showToast(e.message||'ส่งไม่สำเร็จ','err');});
}

function apiCall(ep,data,cb){
  var headers={'Content-Type':'application/json'};
  if(b2bToken) headers['X-B2B-Token']=b2bToken;
  fetch(REST_URL+ep,{method:'POST',headers:headers,body:JSON.stringify(data)}).then(function(r){return r.json()}).then(cb).catch(function(e){showToast(e.message,'err');});
}

function closeLiff(){
  if(liffOK&&liff.isInClient()){liff.closeWindow();}
  else{showToast('กรุณาเปิดผ่าน LINE','err');}
}

