                    <script>
                    (function(){
                        // Defensive: only run if section is rendered (guest flow only).
                        var section = document.querySelector('.dnc-gateway-sn-section[data-dnc-gateway-sn-version]');
                        if (!section) return;

                        var ACTIVATE_BASE = <?php echo wp_json_encode( $warranty_activate_base ); ?>;
                        // Boss R3: QR Content format = B (URL with sn= param) — also accept raw S/N text.
                        // S/N format derived from [System] DINOCO Warranty Activation LIFF V.0.3
                        // preliminary regex /^[A-Z0-9]{8,16}$/ ; tighter "DNCSS\d+" used as primary hint.
                        var SN_PRIMARY_REGEX  = /^DNCSS\d{4,12}$/;
                        var SN_FALLBACK_REGEX = /^[A-Z0-9]{8,16}$/;

                        // dinoco_gateway_qr_parse — exposed for tests + drift detector.
                        // Pure-logic: turn raw QR text into a normalized S/N or null.
                        function dinoco_gateway_qr_parse(raw) {
                            if (raw == null) return null;
                            var s = String(raw).trim();
                            if (s === '') return null;

                            // Try URL form first (boss R3 format B): https://dinoco.in.th/warranty/activate?sn=DNCSS0001234
                            // Accept any host gracefully — we only care about ?sn=
                            try {
                                if (/^https?:\/\//i.test(s)) {
                                    var u = new URL(s);
                                    var snParam = u.searchParams.get('sn');
                                    if (snParam) {
                                        var up = String(snParam).trim().toUpperCase();
                                        if (SN_PRIMARY_REGEX.test(up) || SN_FALLBACK_REGEX.test(up)) {
                                            return up;
                                        }
                                        return null;
                                    }
                                    return null;
                                }
                            } catch (_e) { /* fallthrough to raw */ }

                            // Raw S/N text path
                            var up2 = s.toUpperCase();
                            if (SN_PRIMARY_REGEX.test(up2) || SN_FALLBACK_REGEX.test(up2)) {
                                return up2;
                            }
                            return null;
                        }

                        // Expose on window for shared testing/debug + drift detector hint.
                        try { window.dinocoGatewayQrParse = dinoco_gateway_qr_parse; } catch (_e) {}

                        var inputEl  = document.getElementById('dnc-gateway-sn-input');
                        var submitEl = document.getElementById('dnc-gateway-sn-submit');
                        var errorEl  = document.getElementById('dnc-gateway-sn-error');
                        var scanBtn  = document.getElementById('dnc-gateway-sn-scan-btn');
                        var overlay  = document.getElementById('dnc-gateway-sn-qr-overlay');
                        var closeBtn = document.getElementById('dnc-gateway-sn-qr-close');
                        var statusEl = document.getElementById('dnc-gateway-sn-qr-status');

                        function showError(msg) {
                            if (!errorEl) return;
                            errorEl.textContent = msg || 'รูปแบบ S/N ไม่ถูกต้อง';
                            errorEl.classList.add('dnc-gateway-sn-visible');
                            if (inputEl) inputEl.classList.add('dnc-gateway-sn-error');
                        }
                        function clearError() {
                            if (!errorEl) return;
                            errorEl.textContent = '';
                            errorEl.classList.remove('dnc-gateway-sn-visible');
                            if (inputEl) inputEl.classList.remove('dnc-gateway-sn-error');
                        }

                        function gotoActivate(sn) {
                            if (!sn) return;
                            // Defensive obs hook (no-op if not present).
                            try {
                                if (typeof window.dinoco_sn_obs_capture === 'function') {
                                    window.dinoco_sn_obs_capture('gateway_scan_success', { sn: sn });
                                }
                            } catch (_e) {}
                            var url = ACTIVATE_BASE + '?sn=' + encodeURIComponent(sn);
                            window.location.href = url;
                        }

                        // ── Type S/N path ───────────────────────────────────
                        function submitTyped() {
                            if (!inputEl) return;
                            var raw = (inputEl.value || '').trim().toUpperCase();
                            if (raw === '') {
                                showError('กรุณาพิมพ์ S/N ก่อน');
                                return;
                            }
                            var parsed = dinoco_gateway_qr_parse(raw);
                            if (!parsed) {
                                showError('รูปแบบ S/N ไม่ถูกต้อง (ตัวอย่าง: DNCSS0001234)');
                                return;
                            }
                            clearError();
                            gotoActivate(parsed);
                        }
                        if (submitEl) submitEl.addEventListener('click', submitTyped);
                        if (inputEl) {
                            inputEl.addEventListener('input', clearError);
                            inputEl.addEventListener('blur', function(){
                                var raw = (inputEl.value || '').trim();
                                if (raw === '') return;
                                if (!dinoco_gateway_qr_parse(raw.toUpperCase())) {
                                    showError('รูปแบบ S/N ไม่ถูกต้อง (ตัวอย่าง: DNCSS0001234)');
                                }
                            });
                            inputEl.addEventListener('keydown', function(e){
                                if (e.key === 'Enter') {
                                    e.preventDefault();
                                    submitTyped();
                                }
                            });
                        }

                        // ── Scan QR path (lazy-load html5-qrcode on first click) ──
                        var qrLib    = null;
                        var qrInst   = null;
                        var qrActive = false;

                        function loadQrLibrary() {
                            // Cache flag — safe across re-clicks.
                            if (window._html5QrcodeLoaded && window.Html5Qrcode) {
                                return Promise.resolve(window.Html5Qrcode);
                            }
                            return new Promise(function(resolve, reject){
                                // Defensive optional-loader hook (snippet authors can override).
                                if (typeof window.html5_qrcode_lazy_load === 'function') {
                                    try {
                                        var p = window.html5_qrcode_lazy_load();
                                        if (p && typeof p.then === 'function') {
                                            p.then(function(){
                                                window._html5QrcodeLoaded = true;
                                                resolve(window.Html5Qrcode);
                                            }).catch(reject);
                                            return;
                                        }
                                    } catch (_e) { /* fallthrough to CDN */ }
                                }
                                var s = document.createElement('script');
                                s.src = 'https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js';
                                s.async = true;
                                // Use addEventListener (not s.onload=) to satisfy UX-H3
                                // inline-handler regression guard.
                                s.addEventListener('load', function(){
                                    window._html5QrcodeLoaded = true;
                                    resolve(window.Html5Qrcode);
                                });
                                s.addEventListener('error', function(){
                                    reject(new Error('qr_lib_load_failed'));
                                });
                                document.head.appendChild(s);
                            });
                        }

                        function openQrOverlay() {
                            if (!overlay) return;
                            overlay.classList.add('dnc-gateway-sn-active');
                            overlay.setAttribute('aria-hidden', 'false');
                        }
                        function closeQrOverlay() {
                            if (overlay) {
                                overlay.classList.remove('dnc-gateway-sn-active');
                                overlay.setAttribute('aria-hidden', 'true');
                            }
                            if (qrInst && qrActive) {
                                try {
                                    qrInst.stop().then(function(){
                                        try { qrInst.clear(); } catch (_e) {}
                                        qrActive = false;
                                    }).catch(function(){
                                        qrActive = false;
                                    });
                                } catch (_e) { qrActive = false; }
                            }
                        }

                        function startScanner() {
                            if (statusEl) statusEl.textContent = 'กำลังเปิดกล้อง...';
                            loadQrLibrary().then(function(Html5Qrcode){
                                if (!Html5Qrcode) {
                                    if (statusEl) statusEl.textContent = 'โหลดกล้องไม่สำเร็จ — กรุณาพิมพ์ S/N เอง';
                                    return;
                                }
                                try {
                                    qrInst = new Html5Qrcode('dnc-gateway-sn-qr-reader');
                                    qrActive = true;
                                    qrInst.start(
                                        { facingMode: 'environment' },
                                        { fps: 10, qrbox: { width: 240, height: 240 } },
                                        function onScanSuccess(decodedText) {
                                            var sn = dinoco_gateway_qr_parse(decodedText);
                                            if (sn) {
                                                if (statusEl) statusEl.textContent = 'พบ S/N: ' + sn;
                                                closeQrOverlay();
                                                gotoActivate(sn);
                                            }
                                            // else: keep scanning
                                        },
                                        function onScanError(_err) { /* per-frame errors, ignore */ }
                                    ).catch(function(_err){
                                        // Camera permission denied or unavailable.
                                        qrActive = false;
                                        if (statusEl) statusEl.textContent = 'ไม่สามารถเปิดกล้อง — กรุณาอนุญาตสิทธิ์ หรือพิมพ์ S/N เอง';
                                        // Highlight the typed-input fallback for the user.
                                        if (inputEl) {
                                            try { inputEl.focus(); } catch (_e) {}
                                            inputEl.classList.add('dnc-gateway-sn-error');
                                            setTimeout(function(){ inputEl.classList.remove('dnc-gateway-sn-error'); }, 1500);
                                        }
                                    });
                                } catch (_e) {
                                    qrActive = false;
                                    if (statusEl) statusEl.textContent = 'ไม่สามารถเปิดกล้อง — กรุณาพิมพ์ S/N เอง';
                                }
                            }).catch(function(){
                                if (statusEl) statusEl.textContent = 'โหลดกล้องไม่สำเร็จ — กรุณาพิมพ์ S/N เอง';
                            });
                        }

                        if (scanBtn) {
                            scanBtn.addEventListener('click', function(){
                                openQrOverlay();
                                startScanner();
                            });
                        }
                        if (closeBtn) closeBtn.addEventListener('click', closeQrOverlay);
                        // ESC closes overlay (a11y)
                        document.addEventListener('keydown', function(e){
                            if (e.key === 'Escape' && overlay && overlay.classList.contains('dnc-gateway-sn-active')) {
                                closeQrOverlay();
                            }
                        });
                    })();
                    </script>
                <?php endif; ?>
            </div>
        </div>
        <?php
        return ob_get_clean();
    }
}
