// =========================================================================================
// [PART 1] BACKEND LOGIC (Moved to Init Hook for Cache Bypass)
// =========================================================================================
add_action( 'init', function() {

    /* [FIX] Check for specific transfer action key */
    if ( $_SERVER['REQUEST_METHOD'] === 'POST' && isset( $_POST['dinoco_transfer_action'] ) ) {
        
        /* [FIX] Clean Buffer & Suppress Errors */
        if ( ob_get_length() ) {
            ob_clean();
        }
        error_reporting( 0 ); @ini_set('display_errors', 0);
        
        /* [FIX] Send No-Cache Headers */
        if ( ! headers_sent() ) {
            header( 'Content-Type: application/json; charset=utf-8' );
            header( "Cache-Control: no-store, no-cache, must-revalidate, max-age=0" );
            header( "Cache-Control: post-check=0, pre-check=0", false );
            header( "Pragma: no-cache" );
            header( "Expires: Sat, 26 Jul 1997 05:00:00 GMT" );
        }

        /* Security Check */
        if ( ! current_user_can( 'manage_options' ) ) {
            echo json_encode( [ 'success' => false, 'message' => 'Access Denied' ] );
            exit;
        }

        /* CSRF Protection
         * V.31.0 Phase 1 audit BUG-S2: hardened nonce verification.
         * The canonical nonce action used by the shortcode emitter (line ~158:
         * wp_create_nonce('dinoco_admin_action')) MUST match the action passed
         * here. Defensive — also accepts legacy action 'dinoco_transfer_v3'
         * during rollout window. Every verify failure is logged for observability.
         */
        $nonce_received = isset( $_POST['dinoco_admin_nonce'] ) ? (string) $_POST['dinoco_admin_nonce'] : '';
        if ( $nonce_received === '' ) {
            error_log( '[ManualTransfer] BUG-S2: nonce field missing from POST payload' );
            echo json_encode( [ 'success' => false, 'message' => 'Security token invalid. Please refresh.' ] );
            exit;
        }
        $nonce_ok = wp_verify_nonce( $nonce_received, 'dinoco_admin_action' );
        if ( ! $nonce_ok ) {
            // Defensive fallback for any older client hitting this endpoint.
            $nonce_ok = wp_verify_nonce( $nonce_received, 'dinoco_transfer_v3' );
        }
        if ( ! $nonce_ok ) {
            error_log( '[ManualTransfer] BUG-S2: wp_verify_nonce failed for both canonical + legacy actions' );
            echo json_encode( [ 'success' => false, 'message' => 'Security token invalid. Please refresh.' ] );
            exit;
        }

        global $wpdb;
        $action = sanitize_text_field( $_POST['dinoco_transfer_action'] );

        try {

            // -----------------------------------------------------------------
            // ACTION: FORCE TRANSFER
            // -----------------------------------------------------------------
            if ( $action === 'force_transfer' ) {
                
                $target_sn = isset( $_POST['sn'] ) ? sanitize_text_field( $_POST['sn'] ) : '';
                $new_owner = isset( $_POST['username'] ) ? sanitize_text_field( $_POST['username'] ) : '';

                /* 1. Validate Inputs */
                if ( empty( $target_sn ) || empty( $new_owner ) ) {
                    echo json_encode( [ 'success' => false, 'message' => 'กรุณาระบุข้อมูลให้ครบถ้วน' ] );
                    exit;
                }

                /* 2. Check if SN Exists */
                $sn_posts = get_posts( [
                    'post_type'      => 'serial_number',
                    'meta_key'       => 'serial_code',
                    'meta_value'     => $target_sn,
                    'posts_per_page' => 1,
                    'post_status'    => 'publish', // Only active products
                    'fields'         => 'ids'
                ] );

                if ( empty( $sn_posts ) ) {
                    echo json_encode( [ 'success' => false, 'message' => 'ไม่พบ Serial Number นี้ในระบบ' ] );
                    exit;
                }
                $pid = $sn_posts[0];

                /* 3. Check if User Exists */
                $user = get_user_by( 'login', $new_owner );
                if ( ! $user ) {
                    echo json_encode( [ 'success' => false, 'message' => 'ไม่พบ Username นี้ในระบบ' ] );
                    exit;
                }

                /* 4. Perform Transfer */
                $old_owner = get_field( 'owner_product', $pid ) ?: 'System/Unknown';

                // [SECURITY FIX] Block transfer of locked products
                $w_status = get_field('w_status', $pid);
                if ( in_array($w_status, ['claim_process', 'stolen', 'void', 'warranty_pending'], true) ) {
                    echo json_encode(['success' => false, 'message' => "Cannot transfer: product status is $w_status"]);
                    exit;
                }

                /* V.31.0 Phase 2 W6.6 — sn_pool atomic flip (PRE-FLIGHT + ATOMIC).
                 * Boss decision Q16: Customer transfer = ใช้เพลทเดิม (same SN, new owner).
                 * Resolves new_owner username → user_id for sn_pool registered_user_id.
                 * Defensive: function_exists guard + graceful no-op when sn_pool missing.
                 */
                $new_owner_user = get_user_by( 'login', $new_owner );
                $new_owner_uid  = $new_owner_user ? (int) $new_owner_user->ID : 0;
                $old_owner_user = is_string( $old_owner ) ? get_user_by( 'login', $old_owner ) : null;
                $old_owner_uid  = $old_owner_user ? (int) $old_owner_user->ID : 0;

                if ( function_exists( 'dinoco_sn_transfer_owner_by_sn' ) ) {
                    $sn_transfer_result = dinoco_sn_transfer_owner_by_sn( $target_sn, $old_owner_uid, $new_owner_uid );
                    if ( is_wp_error( $sn_transfer_result ) ) {
                        echo json_encode( [
                            'success' => false,
                            'message' => $sn_transfer_result->get_error_message(),
                            'code'    => $sn_transfer_result->get_error_code(),
                        ] );
                        exit;
                    }
                }

                // Update Owner
                update_field( 'owner_product', $new_owner, $pid );

                // Update Sequence (Optional: Increment)
                $current_seq = (int) get_field( 'owner_sequence', $pid );
                update_field( 'owner_sequence', $current_seq + 1, $pid );

                // Log History
                $log_entry = date( 'd/m/Y H:i' ) . " : Admin Force Transfer from [{$old_owner}] to [{$new_owner}]";
                $current_logs = get_field( 'transfer_logs', $pid );
                $new_logs = $log_entry . "\n" . $current_logs;
                update_field( 'transfer_logs', $new_logs, $pid );

                // V.31.5 Sprint 20 HIGH-2 — fire `dinoco/claim/owner_transferred`
                // post-COMMIT. Claim Payment LIFF V.0.8 listener invalidates
                // per-user charge transients for both old + new owner so
                // tier-resolved cache cannot leak charges to wrong user.
                // Non-blocking: action listeners are best-effort.
                if ( function_exists( 'do_action' ) ) {
                    do_action( 'dinoco/claim/owner_transferred',
                        (int) $old_owner_uid,
                        (int) $new_owner_uid,
                        array(
                            'source'    => 'manual_transfer',
                            'sn'        => $target_sn,
                            'pid'       => (int) $pid,
                            'old_login' => (string) $old_owner,
                            'new_login' => (string) $new_owner,
                        )
                    );
                }

                echo json_encode( [
                    'success' => true,
                    'message' => "โอนย้ายสำเร็จ! ({$target_sn} -> {$new_owner})",
                    'data'    => [
                        'sn'        => $target_sn,
                        'old_owner' => $old_owner,
                        'new_owner' => $new_owner
                    ]
                ] );
                exit;
            }

        } catch ( Exception $e ) {
            echo json_encode( [
                'success' => false,
                'message' => 'Error: ' . $e->getMessage(),
            ] );
            exit;
        }
    }

}, 20 ); // Priority 20

