// V.31.0 Phase 2 W6.6 — sn_pool atomic owner transfer helpers (shared)
// ═══════════════════════════════════════════════════════════════════════════
//
// Helpers may be loaded by EITHER this snippet OR [System] Transfer Warranty
// Page (whichever fires first wins) — therefore both define them inside
// function_exists guards. Boss decision Q16 (binding):
//   "Customer transfer = ใช้เพลทเดิม" — same physical SN plate, new owner.
//
// Atomic flow per plan v2.6 §Gap E:
//   GET_LOCK(dnc_sn_{sn}, 15s)           ← V.31.3 R4 BLOCKER #3: 5s → 15s
//   START TRANSACTION
//     SELECT ... FOR UPDATE   (snapshot status + lock_version)
//     blocked_states early-exit (claimed/voided/recalled/stolen/replaced)
//     UPDATE status='transferred' (intermediate, ~5s)
//     UPDATE status='registered', registered_user_id=<new>
//   COMMIT
//   RELEASE_LOCK
//   audit row (best-effort)
//
// V.31.1 C1 FIX: lock key changed from per-action 'dnc_sn_transfer_{md5}' →
// shared 'dnc_sn_{md5}' — must match Activation/Service Center/Claim sync
// hooks so concurrent transfer + claim + activate ops on the same SN
// serialize correctly. Without unified key, transfer could interleave a
// claim → prev_status corruption (state machine sees unexpected from-state).
//
// Defensive policy:
//   • Missing wp_dinoco_sn_pool table  → return true (graceful no-op)
//   • Missing row for this SN          → return true (legacy SN, pre-Phase 1 W2)
//   • Blocked status                   → return WP_Error (HTTP 422)
//   • Same old/new owner               → return true (no-op, write nothing)
//   • DB exception                     → ROLLBACK + return WP_Error (HTTP 500)

if ( ! function_exists( 'dinoco_sn_transfer_owner_by_sn' ) ) {
    /**
     * V.31.0 — Phase 2 W6.6/W6.7 atomic warranty owner transfer (by SN string).
     *
     * @param string $sn           Plate S/N string (uppercased internally).
     * @param int    $old_owner_id Previous WP user_id (0 = unknown legacy).
     * @param int    $new_owner_id New WP user_id (must be > 0).
     * @return true|WP_Error true on success or graceful no-op, WP_Error if blocked.
     */
    function dinoco_sn_transfer_owner_by_sn( $sn, $old_owner_id, $new_owner_id ) {
        global $wpdb;

        $sn = strtoupper( trim( (string) $sn ) );
        if ( $sn === '' ) {
            return new WP_Error( 'sn_empty', 'Serial number is empty', array( 'status' => 400 ) );
        }
        $new_owner_id = (int) $new_owner_id;
        $old_owner_id = (int) $old_owner_id;
        if ( $new_owner_id <= 0 ) {
            // Manual Transfer accepts username string — caller may have failed
            // to resolve. Fall through gracefully (legacy ACF logic still runs).
            return true;
        }

        $tbl = $wpdb->prefix . 'dinoco_sn_pool';

        // Defensive: table may not exist yet (Phase 1 W2 not deployed)
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        if ( ! $exists ) {
            return true; // graceful no-op
        }

        // Same owner → write nothing (idempotent caller)
        if ( $old_owner_id > 0 && $old_owner_id === $new_owner_id ) {
            return true;
        }

        // V.31.2 — canonical helper from REST API V.0.29 (constant timeout)
        // V.31.3 R4 BLOCKER #3 — fallback literal 5 → 15 (matches new constant)
        $lock_name = function_exists( 'dinoco_sn_lock_name' )
            ? dinoco_sn_lock_name( $sn )
            : 'dnc_sn_' . md5( $sn );
        $lock_to   = defined( 'DINOCO_SN_LOCK_TIMEOUT' ) ? (int) DINOCO_SN_LOCK_TIMEOUT : 15;
        $got_lock  = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_name, $lock_to ) );

        try {
            $wpdb->query( "START TRANSACTION" );

            $plate = $wpdb->get_row( $wpdb->prepare(
                "SELECT sn, status, registered_user_id, registered_warranty_id, lock_version
                 FROM {$tbl} WHERE sn = %s FOR UPDATE",
                $sn
            ) );

            if ( ! $plate ) {
                $wpdb->query( "ROLLBACK" );
                return true; // legacy SN without sn_pool entry — graceful
            }

            // Block if not transferable
            $blocked_states = array( 'claimed', 'voided', 'recalled', 'stolen', 'replaced' );
            if ( in_array( $plate->status, $blocked_states, true ) ) {
                $wpdb->query( "ROLLBACK" );

                if ( $plate->status === 'stolen' ) {
                    // Best-effort alert บอส (LINE)
                    if ( function_exists( 'b2b_line_push' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
                        @b2b_line_push( B2B_ADMIN_GROUP_ID,
                            "🚨 SN STOLEN ATTEMPTED TRANSFER\nSN: {$sn}\nFrom UID: {$old_owner_id}\nTo UID: {$new_owner_id}\nBlocked at " . current_time( 'mysql' )
                        );
                    }
                    return new WP_Error( 'plate_stolen',
                        sprintf( 'เพลท %s ถูกแจ้งหาย/ระงับสิทธิ์ — โอนไม่ได้', $sn ),
                        array( 'status' => 422, 'sn' => $sn )
                    );
                }

                $msg_map = array(
                    'claimed'  => 'เพลทกำลังเปิดเคลม โอนไม่ได้',
                    'voided'   => 'เพลทถูกยกเลิก โอนไม่ได้',
                    'recalled' => 'เพลทถูกเรียกคืน (Recall) โอนไม่ได้',
                    'replaced' => 'เพลทถูกเปลี่ยนใหม่แล้ว โอนไม่ได้',
                );
                return new WP_Error( 'plate_not_transferable',
                    isset( $msg_map[ $plate->status ] ) ? $msg_map[ $plate->status ]
                        : sprintf( 'เพลท %s อยู่ในสถานะ %s โอนไม่ได้', $sn, $plate->status ),
                    array( 'status' => 422, 'sn' => $sn, 'sn_status' => $plate->status )
                );
            }

            // Intermediate state: registered → transferred (audit visibility ~5s window)
            $wpdb->update( $tbl,
                array(
                    'status'       => 'transferred',
                    'prev_status'  => $plate->status,
                    'lock_version' => ( (int) $plate->lock_version ) + 1,
                ),
                array( 'sn' => $sn ),
                array( '%s', '%s', '%d' ),
                array( '%s' )
            );

            // Final flip: transferred → registered with new owner
            $wpdb->update( $tbl,
                array(
                    'status'             => 'registered',
                    'prev_status'        => 'transferred',
                    'registered_user_id' => $new_owner_id,
                    'lock_version'       => ( (int) $plate->lock_version ) + 2,
                ),
                array( 'sn' => $sn ),
                array( '%s', '%s', '%d', '%d' ),
                array( '%s' )
            );

            $wpdb->query( "COMMIT" );

            // Audit (defensive — never throws)
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $sn, 'plate_transferred',
                    $plate->status, 'registered',
                    array(
                        'warranty_id'    => isset( $plate->registered_warranty_id ) ? (int) $plate->registered_warranty_id : 0,
                        'old_owner_id'   => $old_owner_id,
                        'new_owner_id'   => $new_owner_id,
                        'source'         => 'manual_transfer_tool',
                    )
                );
            }

            // V.31.2 CRIT-3 + F-NEW-1 — post-COMMIT fire status_changed.
            // Status string didn't change ('registered' → 'registered') but the
            // owner did, and listeners (cache invalidation, Member Dashboard)
            // need to refresh. Fire BOTH owners' for_user variant so old
            // owner's dashboard removes the plate AND new owner's adds it.
            if ( function_exists( 'dinoco_sn_fire_status_changed' ) ) {
                dinoco_sn_fire_status_changed( $sn, (string) $plate->status, 'registered', $new_owner_id );
                if ( $old_owner_id > 0 ) {
                    do_action( 'dinoco_sn_pool_status_changed_for_user',
                        $old_owner_id, $sn, (string) $plate->status, 'registered' );
                }
            } else {
                do_action( 'dinoco_sn_pool_status_changed', $sn, (string) $plate->status, 'registered' );
                if ( $new_owner_id > 0 ) {
                    do_action( 'dinoco_sn_pool_status_changed_for_user',
                        $new_owner_id, $sn, (string) $plate->status, 'registered' );
                }
                if ( $old_owner_id > 0 ) {
                    do_action( 'dinoco_sn_pool_status_changed_for_user',
                        $old_owner_id, $sn, (string) $plate->status, 'registered' );
                }
            }

            return true;
        } catch ( \Throwable $e ) {
            $wpdb->query( "ROLLBACK" );
            error_log( '[SN Transfer] ' . $e->getMessage() );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                @dinoco_obs_capture_exception( $e, array( 'context' => 'sn_transfer_owner_by_sn', 'sn' => $sn ) );
            }
            return new WP_Error( 'transfer_failed', $e->getMessage(), array( 'status' => 500 ) );
        } finally {
            if ( $got_lock ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        }
    }
}

if ( ! function_exists( 'dinoco_sn_transfer_owner' ) ) {
    /**
     * V.31.0 — Plan-spec wrapper: lookup sn_pool by registered_warranty_id.
     *
     * Used when caller has warranty_id (e.g. warranty_registration CPT context).
     * Falls through to dinoco_sn_transfer_owner_by_sn() once SN resolved.
     *
     * @return true|WP_Error
     */
    function dinoco_sn_transfer_owner( $warranty_id, $old_owner_id, $new_owner_id ) {
        global $wpdb;

        $warranty_id = (int) $warranty_id;
        if ( $warranty_id <= 0 ) return true;

        $tbl = $wpdb->prefix . 'dinoco_sn_pool';
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        if ( ! $exists ) return true;

        $sn = $wpdb->get_var( $wpdb->prepare(
            "SELECT sn FROM {$tbl} WHERE registered_warranty_id = %d LIMIT 1",
            $warranty_id
        ) );
        if ( ! $sn ) return true; // legacy warranty without sn_pool row — graceful

        return dinoco_sn_transfer_owner_by_sn( $sn, $old_owner_id, $new_owner_id );
    }
}
