// REST: Save Discount Mapping (kept for backward compatibility — other systems may call it)
// ═══════════════════════════════════════
add_action( 'rest_api_init', function () {
    register_rest_route( 'b2b/v1', '/discount-mapping', array(
        'methods' => 'POST', 'callback' => 'b2b_rest_discount_mapping',
        'permission_callback' => function( WP_REST_Request $req ) {
            return wp_verify_nonce( $req->get_header('X-WP-Nonce'), 'wp_rest' ) && current_user_can('manage_options');
        },
    ) );
} );

function b2b_rest_discount_mapping( WP_REST_Request $request ) {
    $items   = $request->get_param('items');
    $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
    if ( ! is_array($items) ) return new WP_REST_Response( array('success'=>false,'message'=>'Invalid data'), 400 );
    if ( count($items) > 500 ) return new WP_REST_Response( array('success'=>false,'message'=>'Too many items (max 500)'), 400 );

    $updated = 0; $new_posts = array();
    $rank_fields = array('ps'=>'price_standard','psi'=>'price_silver','pg'=>'price_gold','pp'=>'price_platinum','pd'=>'price_diamond');

    foreach ( $items as $sku => $data ) {
        $sku = sanitize_text_field($sku);
        $post_id = intval($data['post_id']);

        if ( ! $post_id || get_post_type($post_id) !== 'b2b_product' ) {
            $name = isset($catalog[$sku]['name']) ? $catalog[$sku]['name'] : $sku;
            $post_id = wp_insert_post( array('post_type'=>'b2b_product','post_title'=>$name.' ('.$sku.')','post_status'=>'publish') );
            if ( is_wp_error($post_id) ) continue;
            update_field('product_sku', $sku, $post_id);
            update_field('stock_status', 'in_stock', $post_id);
            $new_posts[$sku] = $post_id;
        }

        if ( isset($data['discount']) ) {
            $discount = max(0, min(100, floatval($data['discount'])));
            update_field('b2b_discount_percent', $discount, $post_id);
        }

        foreach ( $rank_fields as $key => $acf_field ) {
            if ( isset($data[$key]) ) {
                $rank_price = max(0, floatval($data[$key]));
                update_field($acf_field, $rank_price, $post_id);
            }
        }

        if ( isset($data['category']) ) {
            update_field('product_category', sanitize_text_field($data['category']), $post_id);
        }

        // V.31.1: Dual-write to custom table
        if ( class_exists('DINOCO_Catalog') ) {
            $ct_data = array('sku' => $sku);
            if ( isset($data['discount']) ) $ct_data['b2b_discount_percent'] = max(0, min(100, floatval($data['discount'])));
            $rank_ct = array('ps'=>'base_price','psi'=>'price_silver','pg'=>'price_gold','pp'=>'price_platinum','pd'=>'price_diamond');
            foreach ( $rank_ct as $key => $col ) {
                if ( isset($data[$key]) ) $ct_data[$col] = max(0, floatval($data[$key]));
            }
            if ( isset($data['category']) ) $ct_data['category'] = sanitize_text_field($data['category']);
            DINOCO_Catalog::upsert($ct_data);
        }

        $updated++;
    }
    delete_transient('b2b_sku_data_map');
    return new WP_REST_Response( array('success'=>true,'updated'=>$updated,'new_posts'=>$new_posts), 200 );
}
