      var s=document.getElementById('dmSearch');
      if(s)s.addEventListener('input',function(){var q=this.value.toLowerCase();document.querySelectorAll('.dm-row').forEach(function(r){var sk=r.getAttribute('data-sku').toLowerCase();var nm=(r.getAttribute('data-name')||'').toLowerCase();r.style.display=(sk.indexOf(q)>=0||nm.indexOf(q)>=0)?'':'none';});});

      // Column sort
      var sortCol=null,sortDir='asc';
      document.querySelectorAll('#dmTable th.sortable').forEach(function(th){
        th.addEventListener('click',function(){
          var col=this.getAttribute('data-col');
          if(sortCol===col){sortDir=sortDir==='asc'?'desc':'asc';}else{sortCol=col;sortDir='asc';}
          document.querySelectorAll('#dmTable th.sortable').forEach(function(h){h.classList.remove('asc','desc');});
          this.classList.add(sortDir);
          var tbody=document.querySelector('#dmTable tbody');
          var rows=Array.from(tbody.querySelectorAll('.dm-row'));
          rows.sort(function(a,b){
            var va,vb;
            if(col==='sku'){va=a.getAttribute('data-sku');vb=b.getAttribute('data-sku');return sortDir==='asc'?va.localeCompare(vb):vb.localeCompare(va);}
            if(col==='name'){va=a.getAttribute('data-name')||'';vb=b.getAttribute('data-name')||'';return sortDir==='asc'?va.localeCompare(vb):vb.localeCompare(va);}
            if(col==='price'){va=parseFloat(a.getAttribute('data-price'))||0;vb=parseFloat(b.getAttribute('data-price'))||0;}
            else{
              var fieldMap={discount:5,ps:6,psi:7,pg:8,pp:9,pd:10};
              var idx=fieldMap[col];
              if(idx!==undefined){
                var tdsA=a.querySelectorAll('td');var tdsB=b.querySelectorAll('td');
                va=tdsA[idx]?parseFloat(tdsA[idx].textContent.replace(/[^0-9.-]/g,''))||0:0;
                vb=tdsB[idx]?parseFloat(tdsB[idx].textContent.replace(/[^0-9.-]/g,''))||0:0;
              } else { va=0;vb=0; }
            }
            return sortDir==='asc'?va-vb:vb-va;
          });
          rows.forEach(function(r){tbody.appendChild(r);});
        });
      });
    })();
