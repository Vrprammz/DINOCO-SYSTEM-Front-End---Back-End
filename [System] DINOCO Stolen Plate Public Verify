        <script>
        (function () {
            if ( window._dncSnStolenCheckLoaded ) return;
            window._dncSnStolenCheckLoaded = true;

            var root = document.querySelector( '.dnc-sn-stolen-check' );
            if ( ! root ) return;

            var form = root.querySelector( '[data-action="stolen-check-submit"]' );
            var input = root.querySelector( '.dnc-sn-stolen-input' );
            var submit = root.querySelector( '.dnc-sn-stolen-submit' );
            var result = root.querySelector( '.dnc-sn-stolen-result' );
            var restUrl = root.getAttribute( 'data-rest-url' );

            function setState( state, html ) {
                result.setAttribute( 'data-state', state );
                if ( typeof html === 'string' ) {
                    // textContent for safety; only known-safe HTML uses innerHTML below
                    result.textContent = '';
                    if ( html ) {
                        var div = document.createElement( 'div' );
                        div.textContent = html;
                        result.appendChild( div );
                    }
                }
            }

            function renderClean( sn ) {
                result.setAttribute( 'data-state', 'clean' );
                result.innerHTML = '';
                var h = document.createElement( 'h3' );
                h.textContent = '✓ ไม่พบรายงานในระบบ';
                var p1 = document.createElement( 'p' );
                p1.textContent = 'เพลท ' + sn + ' ไม่มีรายงานใน DINOCO ขณะนี้';
                var p2 = document.createElement( 'p' );
                p2.style.fontSize = '13px';
                p2.style.marginTop = '8px';
                p2.textContent = 'หมายเหตุ: ผลตรวจสอบนี้สะท้อนสถานะปัจจุบันเท่านั้น';
                result.appendChild( h );
                result.appendChild( p1 );
                result.appendChild( p2 );
            }

            function renderStolen( sn, reportedAt ) {
                result.setAttribute( 'data-state', 'stolen' );
                result.innerHTML = '';
                var h = document.createElement( 'h3' );
                h.textContent = '⚠️ เพลทนี้มีรายงานในระบบ';
                var p1 = document.createElement( 'p' );
                p1.textContent = 'S/N: ' + sn;
                var p2 = document.createElement( 'p' );
                if ( reportedAt ) {
                    p2.textContent = 'รายงานเมื่อ: ' + reportedAt;
                }
                var p3 = document.createElement( 'p' );
                p3.style.marginTop = '12px';
                p3.style.fontWeight = '600';
                p3.textContent = 'โปรดติดต่อ DINOCO Support เพื่อยืนยันสถานะ';
                result.appendChild( h );
                result.appendChild( p1 );
                if ( reportedAt ) result.appendChild( p2 );
                result.appendChild( p3 );
            }

            function renderError( msg ) {
                result.setAttribute( 'data-state', 'error' );
                result.innerHTML = '';
                var h = document.createElement( 'h3' );
                h.textContent = 'ตรวจสอบไม่สำเร็จ';
                var p = document.createElement( 'p' );
                p.textContent = msg || 'กรุณาลองใหม่อีกครั้ง';
                result.appendChild( h );
                result.appendChild( p );
            }

            form.addEventListener( 'submit', function ( e ) {
                e.preventDefault();
                var sn = ( input.value || '' ).trim().toUpperCase().replace(/[\s\-]+/g, '');
                if ( ! sn ) return;
                if ( ! /^[A-Z0-9]+$/.test( sn ) ) {
                    renderError( 'รูปแบบ S/N ไม่ถูกต้อง — ใช้เฉพาะตัวอักษร A-Z และตัวเลข' );
                    return;
                }

                submit.disabled = true;
                setState( 'loading', 'กำลังตรวจสอบ...' );

                fetch( restUrl + encodeURIComponent( sn ), {
                    method: 'GET',
                    credentials: 'omit',
                    headers: { 'Accept': 'application/json' }
                } )
                .then( function ( r ) {
                    if ( r.status === 429 ) {
                        throw new Error( 'rate_limit' );
                    }
                    if ( ! r.ok ) {
                        throw new Error( 'http_' + r.status );
                    }
                    return r.json();
                } )
                .then( function ( data ) {
                    if ( data && data.is_stolen ) {
                        renderStolen( sn, data.reported_at || null );
                    } else {
                        renderClean( sn );
                    }
                } )
                .catch( function ( err ) {
                    var msg = 'กรุณาลองใหม่ในอีกสักครู่';
                    if ( err && err.message === 'rate_limit' ) {
                        msg = 'มีคำขอมากเกินไป กรุณารอ 1 นาทีแล้วลองใหม่';
                    }
                    renderError( msg );
                } )
                .finally( function () {
                    submit.disabled = false;
                } );
            } );
        })();
        </script>
