if ( ! function_exists( 'dinoco_sn_maybe_install' ) ) {
    function dinoco_sn_maybe_install() {
        // Only install if version mismatch (cheap check)
        if ( version_compare( dinoco_sn_schema_version(), DINOCO_SN_SCHEMA_VERSION, '>=' ) ) {
            return;
        }
        try {
            dinoco_sn_schema_install();
        } catch ( \Throwable $e ) {
            // Non-throwing — log + continue
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_schema_install' ) );
            } else {
                error_log( '[DINOCO S/N] Schema install failed: ' . $e->getMessage() );
            }
        }
    }
}

