/* ═══════════════════════════════════════════════════════════════════════════
 * 6. SLA EXPIRATION CRON
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_run_approval_sla' ) ) {
    /**
     * Every 15min — find pending requests past expires_at + mark expired.
     * Atomic via UPDATE...WHERE pattern (no FOR UPDATE — we don't fire
     * the executor hook on expire, so race with concurrent approval is
     * acceptable: UPDATE WHERE status='pending' returns 0 if it raced).
     */
    function dinoco_sn_run_approval_sla() {
        // Heartbeat for Health Monitor (Round 28+ pattern)
        update_option( 'dinoco_cron_sn_approval_sla_last_run', current_time( 'mysql' ) );

        if ( ! dinoco_sn_approval_table_exists() ) return;

        global $wpdb;
        $tbl = dinoco_sn_approval_table_name();
        $now = current_time( 'mysql' );

        try {
            // Find expired BEFORE update (so we can fire hooks + telegram)
            $expired = $wpdb->get_results( $wpdb->prepare(
                "SELECT request_uuid, action, sn, actor_user_id, tier, urgency, context_json
                 FROM {$tbl}
                 WHERE status = 'pending' AND expires_at < %s
                 LIMIT 50",
                $now
            ), ARRAY_A );

            if ( empty( $expired ) ) return;

            foreach ( $expired as $row ) {
                // Atomic single-row mark expired
                $upd = $wpdb->update(
                    $tbl,
                    array(
                        'status'     => 'expired',
                        'decided_at' => $now,
                    ),
                    array(
                        'request_uuid' => $row['request_uuid'],
                        'status'       => 'pending',
                    )
                );
                if ( $upd === 0 || $upd === false ) continue; // raced — concurrent decision won

                $context = array();
                if ( ! empty( $row['context_json'] ) ) {
                    $decoded = json_decode( $row['context_json'], true );
                    if ( is_array( $decoded ) ) $context = $decoded;
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log(
                        $row['sn'],
                        'approval_expired',
                        'pending',
                        'expired',
                        array( 'uuid' => $row['request_uuid'], 'action' => $row['action'] ),
                        (int) $row['actor_user_id'],
                        null,
                        'SLA expired',
                        'approval_expire',
                        ( $row['tier'] === '4_eyes' )
                    );
                }

                // Telegram alert บอส — defensive (no-op if helper missing)
                try {
                    $msg = sprintf(
                        "⏰ SN Approval EXPIRED\nUUID: %s\nAction: %s\nS/N: %s\nActor: #%d\nTier: %s",
                        $row['request_uuid'],
                        strtoupper( $row['action'] ),
                        $row['sn'],
                        (int) $row['actor_user_id'],
                        $row['tier']
                    );
                    if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                        b2b_tg_send_dedup( 'sn_appr_exp_' . $row['request_uuid'], $msg, 86400 );
                    } elseif ( function_exists( 'sendTelegramAlert' ) ) {
                        sendTelegramAlert( 'sn_approval_expired', $msg );
                    }
                } catch ( \Throwable $e ) {
                    error_log( '[SN-Approval] expire telegram failed: ' . $e->getMessage() );
                }

                // Fire executor hook so listeners can notify actor via LINE
                do_action( 'dinoco_sn_approval_expired', $row['request_uuid'], $row['action'], $context );
            }
        } catch ( \Throwable $e ) {
            error_log( '[SN-Approval] SLA cron failed: ' . $e->getMessage() );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_approval_sla_cron' ) );
            }
        }
    }
}

