if ( ! function_exists( 'dinoco_sn_approval_register_routes' ) ) {
    function dinoco_sn_approval_register_routes() {
        if ( ! defined( 'DINOCO_SN_REST_NAMESPACE' ) ) return; // REST API snippet not synced

        $ns = DINOCO_SN_REST_NAMESPACE;

        // POST /approval/request — actor creates request
        register_rest_route( $ns, '/approval/request', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_approval_create',
            'permission_callback' => function_exists( 'dinoco_sn_perm_admin' )
                                       ? 'dinoco_sn_perm_admin' : '__return_true',
            'args'                => array(
                'action'        => array(
                    'required'          => true,
                    'type'              => 'string',
                    'sanitize_callback' => 'sanitize_text_field',
                    'validate_callback' => function( $val ) {
                        return dinoco_sn_approval_valid_action( $val );
                    },
                ),
                'sn'            => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'sn_target'     => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'current_state' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'bulk_count'    => array( 'type' => 'integer', 'default' => 1, 'sanitize_callback' => 'absint' ),
                'urgency'       => array(
                    'type'    => 'string',
                    'default' => 'normal',
                    'enum'    => array( 'urgent', 'normal', 'low' ),
                ),
                'reason'        => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_textarea_field' ),
                'context'       => array( 'type' => 'object', 'default' => array() ),
            ),
        ) );

        // POST /approval/{uuid}/approve
        register_rest_route( $ns, '/approval/(?P<uuid>[a-f0-9\\-]{36})/approve', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_approval_approve',
            'permission_callback' => 'dinoco_sn_rest_approval_perm_approver',
            'args'                => array(
                'uuid'  => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'notes' => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_textarea_field' ),
            ),
        ) );

        // POST /approval/{uuid}/reject
        register_rest_route( $ns, '/approval/(?P<uuid>[a-f0-9\\-]{36})/reject', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_approval_reject',
            'permission_callback' => 'dinoco_sn_rest_approval_perm_approver',
            'args'                => array(
                'uuid'  => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'notes' => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_textarea_field' ),
            ),
        ) );

        // POST /approval/{uuid}/cancel
        register_rest_route( $ns, '/approval/(?P<uuid>[a-f0-9\\-]{36})/cancel', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_approval_cancel',
            'permission_callback' => function_exists( 'dinoco_sn_perm_admin' )
                                       ? 'dinoco_sn_perm_admin' : '__return_true',
            'args'                => array(
                'uuid' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
            ),
        ) );

        // GET /approval/pending
        register_rest_route( $ns, '/approval/pending', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_approval_pending',
            'permission_callback' => function_exists( 'dinoco_sn_perm_admin' )
                                       ? 'dinoco_sn_perm_admin' : '__return_true',
            'args'                => array(
                'tier'    => array( 'type' => 'string' ),
                'action'  => array( 'type' => 'string' ),
                'actor'   => array( 'type' => 'integer' ),
                'approver' => array( 'type' => 'integer' ),
                'limit'   => array( 'type' => 'integer', 'default' => 50, 'sanitize_callback' => 'absint' ),
                'offset'  => array( 'type' => 'integer', 'default' => 0, 'sanitize_callback' => 'absint' ),
            ),
        ) );

        // GET /approval/{uuid} — single request detail
        register_rest_route( $ns, '/approval/(?P<uuid>[a-f0-9\\-]{36})', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_approval_get',
            'permission_callback' => 'dinoco_sn_rest_approval_perm_owner_or_admin',
            'args'                => array(
                'uuid' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
            ),
        ) );
    }
}

