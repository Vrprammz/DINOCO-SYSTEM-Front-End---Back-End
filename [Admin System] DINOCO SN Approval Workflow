if ( ! function_exists( 'dinoco_sn_rest_approval_perm_approver' ) ) {
    function dinoco_sn_rest_approval_perm_approver( $req ) {
        // dinoco_sn_user_can_approver returns true for approver cap or manage_options
        if ( function_exists( 'dinoco_sn_user_can_approver' ) ) {
            if ( ! dinoco_sn_user_can_approver() ) {
                return new WP_Error( 'rest_forbidden',
                    __( 'Approver capability required.', 'dinoco-sn' ),
                    array( 'status' => 403 ) );
            }
            return true;
        }
        // Fallback: manage_options only
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'rest_forbidden', __( 'Forbidden.', 'dinoco-sn' ), array( 'status' => 403 ) );
        }
        return true;
    }
}

if ( ! function_exists( 'dinoco_sn_rest_approval_perm_owner_or_admin' ) ) {
    /**
     * Read access: actor (request owner) OR approver (assigned) OR admin.
     */
    function dinoco_sn_rest_approval_perm_owner_or_admin( $req ) {
        if ( ! is_user_logged_in() ) {
            return new WP_Error( 'rest_not_logged_in', __( 'Login required.', 'dinoco-sn' ), array( 'status' => 401 ) );
        }
        if ( current_user_can( 'manage_options' ) ) return true;

        $uuid = $req->get_param( 'uuid' );
        $row  = dinoco_sn_approval_get_request( $uuid );
        if ( ! $row ) {
            return new WP_Error( 'not_found', __( 'Approval request not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
        }
        $uid = (int) get_current_user_id();
        if ( (int) $row['actor_user_id'] === $uid ) return true;
        if ( (int) $row['approver_user_id'] === $uid ) return true;

        return new WP_Error( 'rest_forbidden',
            __( 'You do not have access to this approval request.', 'dinoco-sn' ),
            array( 'status' => 403 ) );
    }
}

