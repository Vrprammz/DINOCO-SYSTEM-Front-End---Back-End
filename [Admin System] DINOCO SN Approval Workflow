if ( ! function_exists( 'dinoco_sn_rest_approval_pending' ) ) {
    function dinoco_sn_rest_approval_pending( $req ) {
        $filter = array(
            'tier'     => $req->get_param( 'tier' ),
            'action'   => $req->get_param( 'action' ),
            'actor'    => $req->get_param( 'actor' ),
            'approver' => $req->get_param( 'approver' ),
            'limit'    => $req->get_param( 'limit' ) ?: 50,
            'offset'   => $req->get_param( 'offset' ) ?: 0,
        );
        $rows = dinoco_sn_get_pending_approvals( $filter );

        // Decode context_json + strip raw column for cleaner response
        $rows = array_map( function( $r ) {
            $ctx = array();
            if ( ! empty( $r['context_json'] ) ) {
                $decoded = json_decode( $r['context_json'], true );
                if ( is_array( $decoded ) ) $ctx = $decoded;
            }
            unset( $r['context_json'] );
            $r['context'] = $ctx;
            return $r;
        }, $rows );

        return rest_ensure_response( array(
            'success' => true,
            'count'   => count( $rows ),
            'rows'    => $rows,
            'limit'   => (int) $filter['limit'],
            'offset'  => (int) $filter['offset'],
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_approval_get' ) ) {
    function dinoco_sn_rest_approval_get( $req ) {
        $uuid = $req->get_param( 'uuid' );
        $row  = dinoco_sn_approval_get_request( $uuid );
        if ( ! $row ) {
            return new WP_Error( 'not_found', __( 'Approval request not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
        }
        $ctx = array();
        if ( ! empty( $row['context_json'] ) ) {
            $decoded = json_decode( $row['context_json'], true );
            if ( is_array( $decoded ) ) $ctx = $decoded;
        }
        unset( $row['context_json'] );
        $row['context'] = $ctx;

        return rest_ensure_response( array(
            'success' => true,
            'request' => $row,
        ) );
    }
}

