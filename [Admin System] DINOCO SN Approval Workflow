            $uid   = (int) get_current_user_id();

            $result = dinoco_sn_approve_request( $uuid, $uid, $notes );
            if ( is_wp_error( $result ) ) return $result;

            return rest_ensure_response( array_merge( array( 'success' => true ), $result ) );
        };

        if ( function_exists( 'dinoco_sn_with_idempotency' ) ) {
            return dinoco_sn_with_idempotency( $req, 'approval-approve',
                array( 'uuid', 'notes' ), $handler );
        }
        return $handler( $req );
    }
}

