if ( ! function_exists( 'dinoco_sn_rest_approval_create' ) ) {
    function dinoco_sn_rest_approval_create( $req ) {
        if ( function_exists( 'dinoco_sn_is_enabled' ) && ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        $handler = function( $req ) {
            $action  = $req->get_param( 'action' );
            $sn      = $req->get_param( 'sn' );
            $state   = $req->get_param( 'current_state' );
            $reason  = $req->get_param( 'reason' );
            $context = (array) $req->get_param( 'context' );
            $context['sn_target']  = $req->get_param( 'sn_target' );
            $context['bulk_count'] = $req->get_param( 'bulk_count' );
            $context['urgency']    = $req->get_param( 'urgency' );

            $result = dinoco_sn_create_approval_request( $action, $sn, $state, $reason, $context );
            if ( is_wp_error( $result ) ) return $result;

            $row = dinoco_sn_approval_get_request( $result );
            return rest_ensure_response( array(
                'success'    => true,
                'uuid'       => $result,
                'tier'       => $row ? $row['tier'] : null,
                'expires_at' => $row ? $row['expires_at'] : null,
                'status'     => 'pending',
            ) );
        };

        if ( function_exists( 'dinoco_sn_with_idempotency' ) ) {
            return dinoco_sn_with_idempotency( $req, 'approval-request',
                array( 'action', 'sn', 'sn_target', 'current_state', 'bulk_count', 'reason' ),
                $handler );
        }
        return $handler( $req );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_approval_approve' ) ) {
    function dinoco_sn_rest_approval_approve( $req ) {
        $handler = function( $req ) {
