if ( ! function_exists( 'dinoco_claim_bank_rest_save' ) ) {
    function dinoco_claim_bank_rest_save( $req ) {
        global $wpdb;
        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) $body = $req->get_params();

        $bucket = isset( $body['bucket'] ) && $body['bucket'] === 'walkin'
            ? 'walkin' : 'default';

        // V.33.2 HIGH-2 fix — serialize concurrent saves via MySQL GET_LOCK.
        // Two parallel REST calls (clear from Admin A + save from Admin B) could
        // produce non-deterministic final state. GET_LOCK with 5s timeout matches
        // b2b_rate_limit / b2b_debt_add patterns. try/finally guarantees RELEASE.
        $lock_key = 'dnc_claim_bank_save';
        $lock_acquired = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_key, 5 ) );
        if ( $lock_acquired !== 1 ) {
            return new WP_Error(
                'claim_bank_save_busy',
                'ระบบกำลังบันทึกการเปลี่ยนแปลงอื่นอยู่ กรุณาลองอีกครั้ง',
                array( 'status' => 503, 'retry_after' => 5 )
            );
        }

        try {
            return _dinoco_claim_bank_rest_save_inner( $body, $bucket );
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
        }
    }
}

if ( ! function_exists( '_dinoco_claim_bank_rest_save_inner' ) ) {
    function _dinoco_claim_bank_rest_save_inner( $body, $bucket ) {
        // V.33.1 CRIT-1 fix — walkin bucket explicit clear semantic.
        $clear = ! empty( $body['clear'] ) && $bucket === 'walkin';

        if ( $clear ) {
            $keys = dinoco_claim_bank_field_keys( $bucket );
            $diff = array();
            foreach ( array( 'name', 'name_en', 'account', 'holder', 'code', 'branch', 'logo_url' ) as $field ) {
                $opt_key = $keys['options'][ $field ];
                $before  = (string) get_option( $opt_key, '' );
                if ( $before !== '' ) {
                    delete_option( $opt_key );
                    $diff[ $opt_key ] = array( 'before' => $before, 'after' => '' );
                }
            }
            if ( ! empty( $diff ) ) {
                dinoco_claim_bank_audit_save( $diff, $bucket . '_clear' );
            }
            return rest_ensure_response( array(
                'saved'        => true,
                'bucket'       => $bucket,
                'cleared'      => true,
                'changed_keys' => array_keys( $diff ),
                'change_count' => count( $diff ),
                'resolver'     => dinoco_claim_bank_resolve( true ),  // proves fallback chain works
            ) );
        }

        $payload = isset( $body['payload'] ) && is_array( $body['payload'] )
            ? $body['payload'] : array();

        $validation = dinoco_claim_bank_validate( $payload, $bucket );
        if ( ! $validation['ok'] ) {
            return new WP_Error(
                'claim_bank_validation_failed',
                'ข้อมูลธนาคารไม่ถูกต้อง',
                array( 'status' => 422, 'errors' => $validation['errors'] )
            );
        }

        $keys = dinoco_claim_bank_field_keys( $bucket );
        $diff = array();
        foreach ( array( 'name', 'name_en', 'account', 'holder', 'code', 'branch', 'logo_url' ) as $field ) {
            $opt_key  = $keys['options'][ $field ];
            $before   = (string) get_option( $opt_key, '' );
            $after_k  = ( $field === 'logo_url' ) ? 'bank_logo_url' : 'bank_' . $field;
            $after    = isset( $validation['sanitized'][ $after_k ] )
                ? (string) $validation['sanitized'][ $after_k ] : '';
            if ( $before !== $after ) {
                update_option( $opt_key, $after, false );
                $diff[ $opt_key ] = array( 'before' => $before, 'after' => $after );
            }
        }

        if ( ! empty( $diff ) ) {
            dinoco_claim_bank_audit_save( $diff, $bucket );
        }

        return rest_ensure_response( array(
            'saved'        => true,
            'bucket'       => $bucket,
            'changed_keys' => array_keys( $diff ),
            'change_count' => count( $diff ),
            'resolver'     => dinoco_claim_bank_resolve( $bucket === 'walkin' ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_claim_bank_rest_test' ) ) {
    function dinoco_claim_bank_rest_test( $req ) {
        // V.33.3 Sprint 12 SEC-H2 fix — rate limit. Admin-only endpoint but the
        // preview returns full bank config; chained calls = log noise + small
        // info-disclosure window if an admin session is compromised. 10/min cap
        // matches b2b_rate_limit defensive pattern (e.g. claim_bank_test bucket).
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $uid = function_exists( 'get_current_user_id' ) ? (int) get_current_user_id() : 0;
            $rl  = b2b_rate_limit( 'claim_bank_test', $uid, 10, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error(
                    'rate_limited',
                    'เรียกทดสอบบ่อยเกินไป — กรุณารอสักครู่',
                    array( 'status' => 429, 'retry_after' => 60 )
                );
            }
        }

        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) $body = $req->get_params();
        $use_walkin = ! empty( $body['use_walkin'] );

        $bank = dinoco_claim_bank_resolve( $use_walkin );
        if ( ! empty( $bank['error'] ) ) {
            return new WP_Error(
                'no_claim_bank_configured',
                'ยังไม่ได้ตั้งค่าบัญชีรับเงินสำหรับเคลม — กรุณาตั้งค่าก่อนทดสอบ',
                array( 'status' => 422 )
            );
        }

        // PREVIEW ONLY — no LINE push, no DB row, no charge created.
        // Phase 2 will add real test charge with amount=1 THB via separate endpoint.
        $flex = dinoco_claim_bank_build_preview_flex( $bank );

        return rest_ensure_response( array(
            'preview_only' => true,
            'note'         => 'Phase 1 foundation — Flex rendered but NOT pushed. Phase 2 will add sandbox charge.',
            'bank'         => $bank,
            'flex'         => $flex,
        ) );
    }
}

