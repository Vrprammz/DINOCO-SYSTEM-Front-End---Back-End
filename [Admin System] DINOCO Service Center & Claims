        // preview fetches → rate-limit burn. Replaced with MutationObserver
        // scoped to modal container. Falls back to lazy preview on first
        // active pill if observer unavailable.
        (function() {
            if (typeof MutationObserver === 'undefined') return;
            var observer = new MutationObserver(function(mutations) {
                for (var i = 0; i < mutations.length; i++) {
                    var added = mutations[i].addedNodes;
                    for (var j = 0; j < added.length; j++) {
                        var node = added[j];
                        if (!node || node.nodeType !== 1) continue;
                        // Detect newly-inserted #dnc-cc-bank-pills
