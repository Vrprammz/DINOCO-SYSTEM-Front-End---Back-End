                    +       escHtml(groupHeaderLabel[d] || d)
                    +       ' <span class="dnc-cf-group-count dnc-cf-group-count-' + escHtml(d) + '">' + arr.length + '</span>'
                    +       (collapsed === '1' && firstPno !== '' ? ' <span class="dnc-cf-meta" style="margin-left:8px">PNO ' + escHtml(firstPno) + ' …</span>' : '')
                    +     '</span>'
                    +   '</button>'
                    +   '<div class="dnc-cf-group-body">'
                    +     arr.map(_cfRowHtml).join('')
                    +   '</div>'
                    + '</div>';
            });
            if (otherGroup.length > 0) {
                var collapsedO = (firstNonEmpty === '__other__') ? '0' : '1';
                html += ''
                    + '<div class="dnc-cf-group" data-group="other" data-collapsed="' + collapsedO + '">'
                    +   '<button type="button" class="dnc-cf-group-header" data-action="dnc-cf-toggle-group" data-group="other" aria-expanded="' + (collapsedO === '0' ? 'true' : 'false') + '">'
                    +     '<span>'
