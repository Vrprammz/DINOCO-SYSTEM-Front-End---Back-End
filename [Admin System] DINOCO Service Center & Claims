                    ? '<span class="dnc-cf-print-badge" title="รอ RPi ปริ้น">🖨️ คิวปริ้น</span>'
                    : (it.print_status === 'done' ? '<span class="dnc-cf-print-badge" title="ปริ้นแล้ว" style="background:#d1fae5;color:#065f46">🖨️ ปริ้นแล้ว</span>' : '');
                return ''
                    + '<div class="dnc-cf-row" data-pno="' + escHtml(pno) + '">'
                    +   '<span class="dnc-cf-dir-badge dnc-cf-dir-' + escHtml(dir) + '">' + escHtml(_cfDirLabel(dir)) + '</span>'
                    +   '<button type="button" class="dnc-cf-pno" data-action="dnc-cf-view-tracking" data-pno="' + escHtml(pno) + '">' + escHtml(pno) + '</button>'
                    +   '<span class="dnc-cf-status-badge dnc-cf-st-' + escHtml(st) + '">' + escHtml(stLabel) + '</span>'
                    +   printBadge
                    +   '<span class="dnc-cf-meta">' + escHtml(it.sort_code || '') + ' · ' + escHtml(_cfFmtDate(it.created_at || it.updated_at)) + '</span>'
                    +   '<div class="dnc-cf-actions">'
                    +     '<button type="button" class="dnc-cf-btn dnc-cf-btn-view" data-action="dnc-cf-view-tracking" data-pno="' + escHtml(pno) + '"><i class="fa-solid fa-eye"></i> ดู</button>'
                    +     (canCancel ? '<button type="button" class="dnc-cf-btn dnc-cf-btn-cancel" data-action="dnc-cf-cancel" data-pno="' + escHtml(pno) + '"><i class="fa-solid fa-xmark"></i> ยกเลิก</button>' : '')
                    +   '</div>'
                    + '</div>';
            }

            // Header labels per direction (match _cfDirOptions).
            var groupHeaderLabel = {
                replacement:     '🟢 ส่งของแทน',
                repaired_return: '🔵 ส่งคืนหลังซ่อม',
                inbound_pickup:  '🟠 รับเข้าโกดัง'
            };

            // First non-empty group is expanded; others collapsed.
            var firstNonEmpty = null;
            groupOrder.forEach(function(d) {
                if (!firstNonEmpty && groups[d].length > 0) firstNonEmpty = d;
            });
            if (!firstNonEmpty && otherGroup.length > 0) firstNonEmpty = '__other__';

            var html = '';
            groupOrder.forEach(function(d) {
                var arr = groups[d];
                if (arr.length === 0) return;
                var collapsed = (d === firstNonEmpty) ? '0' : '1';
                var firstPno = String(arr[0].pno || '');
                html += ''
                    + '<div class="dnc-cf-group" data-group="' + escHtml(d) + '" data-collapsed="' + collapsed + '">'
                    +   '<button type="button" class="dnc-cf-group-header" data-action="dnc-cf-toggle-group" data-group="' + escHtml(d) + '" aria-expanded="' + (collapsed === '0' ? 'true' : 'false') + '">'
                    +     '<span>'
