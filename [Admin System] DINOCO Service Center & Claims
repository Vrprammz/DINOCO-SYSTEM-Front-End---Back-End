                    +       'อื่นๆ <span class="dnc-cf-group-count">' + otherGroup.length + '</span>'
                    +     '</span>'
                    +   '</button>'
                    +   '<div class="dnc-cf-group-body">'
                    +     otherGroup.map(_cfRowHtml).join('')
                    +   '</div>'
                    + '</div>';
            }
            $('#dnc-cf-list-panel').html(html);
        }

