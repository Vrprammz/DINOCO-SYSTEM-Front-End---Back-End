/**
 * Return 7 wp_option keys + corresponding constant names for a bucket.
 *
 * @param string $bucket  'default' or 'walkin'
 * @return array{options:array<string,string>, constants:array<string,string>}
 */
if ( ! function_exists( 'dinoco_claim_bank_field_keys' ) ) {
    function dinoco_claim_bank_field_keys( $bucket = 'default' ) {
        $bucket = ( $bucket === 'walkin' ) ? 'walkin' : 'default';
        $opt_prefix   = ( $bucket === 'walkin' )
            ? 'dinoco_claim_walkin_bank_'
            : 'dinoco_claim_bank_';
        $const_prefix = ( $bucket === 'walkin' )
            ? 'DINOCO_CLAIM_WALKIN_BANK_'
            : 'DINOCO_CLAIM_BANK_';

        $fields = array( 'name', 'name_en', 'account', 'holder', 'code', 'branch', 'logo_url' );
        $options = array();
        $constants = array();
        foreach ( $fields as $f ) {
            $options[ $f ]   = $opt_prefix . $f;
            $constants[ $f ] = $const_prefix . strtoupper( $f );
        }
        return array(
            'options'   => $options,
            'constants' => $constants,
        );
    }
}

/**
 * 3-tier resolver per spec §6.4:
 *   Tier 1: wp_options (admin-editable, highest priority)
 *   Tier 2: WP constants (wp-config.php fallback)
 *   Tier 3: Sentinel error array
 *
 * @param bool $use_walkin  When true, read walk-in bucket; falls back to default
 *                          if walk-in not configured (per spec — checkbox UX).
 * @return array {
 *   bank_name, bank_name_en, bank_account, bank_holder, bank_code, bank_branch,
 *   bank_logo_url, bucket, source, ?error
 * }
 */
if ( ! function_exists( 'dinoco_claim_bank_resolve' ) ) {
    function dinoco_claim_bank_resolve( $use_walkin = false ) {
        $bucket   = $use_walkin ? 'walkin' : 'default';
        $resolved = dinoco_claim_bank_read_bucket( $bucket );

        // Walk-in fallback to default if walk-in bucket empty (admin opted to
        // share default bank — checkbox in Settings UI leaves walkin opts empty).
        if ( $use_walkin && ! empty( $resolved['error'] ) ) {
            $fallback = dinoco_claim_bank_read_bucket( 'default' );
            if ( empty( $fallback['error'] ) ) {
                $fallback['bucket'] = 'walkin_via_default';
                return $fallback;
            }
        }

        return $resolved;
    }
}

/**
 * Internal — read a single bucket (default or walkin) using 3-tier priority.
 * Public callers should use dinoco_claim_bank_resolve() which adds the
 * walk-in-to-default fallback chain.
 */
if ( ! function_exists( 'dinoco_claim_bank_read_bucket' ) ) {
    function dinoco_claim_bank_read_bucket( $bucket ) {
        $keys = dinoco_claim_bank_field_keys( $bucket );
        $out = array(
            'bank_name'     => '',
            'bank_name_en'  => '',
            'bank_account'  => '',
            'bank_holder'   => '',
            'bank_code'     => '',
            'bank_branch'   => '',
            'bank_logo_url' => '',
            'bucket'        => $bucket,
            'source'        => 'sentinel',
        );

        // Tier 1 — wp_options
        $opt_values = array();
        $any_opt_set = false;
        foreach ( $keys['options'] as $field => $opt_key ) {
            $v = get_option( $opt_key, '' );
            $opt_values[ $field ] = is_string( $v ) ? trim( $v ) : '';
            if ( $opt_values[ $field ] !== '' ) $any_opt_set = true;
        }

        // Tier 2 — constants (only when wp_options entirely empty for this bucket)
        $const_values = array();
        $any_const_set = false;
        if ( ! $any_opt_set ) {
            foreach ( $keys['constants'] as $field => $const_name ) {
                $v = defined( $const_name ) ? constant( $const_name ) : '';
                $const_values[ $field ] = is_string( $v ) ? trim( $v ) : '';
                if ( $const_values[ $field ] !== '' ) $any_const_set = true;
            }
        }

        $required = array( 'name', 'account', 'holder', 'code' );

        if ( $any_opt_set ) {
            // Validate required fields present
            $missing = array();
            foreach ( $required as $f ) {
                if ( $opt_values[ $f ] === '' ) $missing[] = $f;
            }
            $out['bank_name']     = $opt_values['name'];
            $out['bank_name_en']  = $opt_values['name_en'];
            $out['bank_account']  = $opt_values['account'];
            $out['bank_holder']   = $opt_values['holder'];
            $out['bank_code']     = $opt_values['code'];
            $out['bank_branch']   = $opt_values['branch'];
            $out['bank_logo_url'] = $opt_values['logo_url'];
            $out['source']        = 'wp_options';
            if ( ! empty( $missing ) ) {
                $out['error']           = 'incomplete_bank_settings';
                $out['missing_fields']  = $missing;
            }
            // Auto-fill bank_name_en from whitelist if empty
            if ( $out['bank_name_en'] === '' ) {
                $wl = dinoco_claim_bank_code_whitelist();
                if ( isset( $wl[ $out['bank_code'] ] ) ) {
                    $out['bank_name_en'] = $wl[ $out['bank_code'] ];
                }
            }
            return $out;
        }

        if ( $any_const_set ) {
            $missing = array();
            foreach ( $required as $f ) {
                if ( ! isset( $const_values[ $f ] ) || $const_values[ $f ] === '' ) {
                    $missing[] = $f;
                }
            }
            $out['bank_name']     = isset( $const_values['name'] ) ? $const_values['name'] : '';
            $out['bank_name_en']  = isset( $const_values['name_en'] ) ? $const_values['name_en'] : '';
            $out['bank_account']  = isset( $const_values['account'] ) ? $const_values['account'] : '';
            $out['bank_holder']   = isset( $const_values['holder'] ) ? $const_values['holder'] : '';
            $out['bank_code']     = isset( $const_values['code'] ) ? $const_values['code'] : '';
            $out['bank_branch']   = isset( $const_values['branch'] ) ? $const_values['branch'] : '';
            $out['bank_logo_url'] = isset( $const_values['logo_url'] ) ? $const_values['logo_url'] : '';
            $out['source']        = 'constants';
            if ( ! empty( $missing ) ) {
                $out['error']          = 'incomplete_bank_settings';
                $out['missing_fields'] = $missing;
            }
            if ( $out['bank_name_en'] === '' ) {
                $wl = dinoco_claim_bank_code_whitelist();
                if ( isset( $wl[ $out['bank_code'] ] ) ) {
                    $out['bank_name_en'] = $wl[ $out['bank_code'] ];
                }
            }
            return $out;
        }

        // Tier 3 — sentinel
        $out['error']     = 'no_claim_bank_configured';
        $out['bank_name'] = 'ไม่ได้ตั้งค่า';
        return $out;
    }
}

/**
 * Server-side validation per spec §6.4 Validation Rules.
 *
 * @param array  $payload  Raw POST body (associative array)
 * @param string $bucket   'default' or 'walkin' (logs which bucket the err refers to)
 * @return array{ok:bool, errors:array<string,string>, sanitized:array}
 */
if ( ! function_exists( 'dinoco_claim_bank_validate' ) ) {
    function dinoco_claim_bank_validate( $payload, $bucket = 'default' ) {
        $errors = array();
        $clean  = array();

        $name = isset( $payload['bank_name'] ) ? trim( (string) $payload['bank_name'] ) : '';
        if ( $name === '' ) {
            $errors['bank_name'] = 'ต้องระบุชื่อธนาคาร';
        } elseif ( mb_strlen( $name ) > 64 ) {
            $errors['bank_name'] = 'ชื่อธนาคารเกิน 64 ตัวอักษร';
        }
        $clean['bank_name'] = sanitize_text_field( $name );

        $name_en = isset( $payload['bank_name_en'] ) ? trim( (string) $payload['bank_name_en'] ) : '';
        if ( mb_strlen( $name_en ) > 64 ) {
            $errors['bank_name_en'] = 'ชื่อภาษาอังกฤษเกิน 64 ตัวอักษร';
        }
        $clean['bank_name_en'] = sanitize_text_field( $name_en );

        $account = isset( $payload['bank_account'] ) ? trim( (string) $payload['bank_account'] ) : '';
        if ( $account === '' ) {
            $errors['bank_account'] = 'ต้องระบุเลขบัญชี';
        } elseif ( ! preg_match( '/^[0-9-]{8,20}$/', $account ) ) {
            $errors['bank_account'] = 'รูปแบบเลขบัญชีไม่ถูกต้อง (ต้องเป็นตัวเลข/ขีดกลาง 8-20 ตัว)';
        }
        $clean['bank_account'] = sanitize_text_field( $account );

        $holder = isset( $payload['bank_holder'] ) ? trim( (string) $payload['bank_holder'] ) : '';
        if ( $holder === '' ) {
            $errors['bank_holder'] = 'ต้องระบุชื่อบัญชี';
        } elseif ( mb_strlen( $holder ) > 128 ) {
            $errors['bank_holder'] = 'ชื่อบัญชีเกิน 128 ตัวอักษร';
        }
        $clean['bank_holder'] = sanitize_text_field( $holder );

        $code = isset( $payload['bank_code'] ) ? trim( (string) $payload['bank_code'] ) : '';
        $wl   = dinoco_claim_bank_code_whitelist();
        if ( $code === '' ) {
            $errors['bank_code'] = 'ต้องระบุรหัสธนาคาร';
        } elseif ( ! isset( $wl[ $code ] ) ) {
            $errors['bank_code'] = 'รหัสธนาคารไม่ถูกต้อง (ต้องเป็น Slip2Go canonical code)';
        }
        $clean['bank_code'] = sanitize_text_field( $code );

        $branch = isset( $payload['bank_branch'] ) ? trim( (string) $payload['bank_branch'] ) : '';
        if ( mb_strlen( $branch ) > 128 ) {
            $errors['bank_branch'] = 'ชื่อสาขาเกิน 128 ตัวอักษร';
        }
        $clean['bank_branch'] = sanitize_text_field( $branch );

        $logo = isset( $payload['bank_logo_url'] ) ? trim( (string) $payload['bank_logo_url'] ) : '';
        if ( $logo !== '' ) {
            // Must be https:// only (no http, no other schemes)
            if ( ! preg_match( '#^https://#i', $logo ) ) {
                $errors['bank_logo_url'] = 'URL โลโก้ต้องขึ้นต้นด้วย https:// เท่านั้น';
            } elseif ( ! filter_var( $logo, FILTER_VALIDATE_URL ) ) {
                $errors['bank_logo_url'] = 'URL โลโก้ไม่ถูกต้อง';
            } elseif ( mb_strlen( $logo ) > 500 ) {
                $errors['bank_logo_url'] = 'URL โลโก้ยาวเกิน 500 ตัวอักษร';
            }
        }
        $clean['bank_logo_url'] = esc_url_raw( $logo );

        return array(
            'ok'        => empty( $errors ),
            'errors'    => $errors,
            'sanitized' => $clean,
            'bucket'    => $bucket,
        );
    }
}

/**
 * One-time migration: seed wp_options from constants if defined and wp_options
 * empty. Idempotent via flag `dinoco_claim_bank_seeded_from_constants` — won't
 * re-seed on subsequent admin_init runs.
 */
if ( ! function_exists( 'dinoco_claim_bank_maybe_migrate_constants' ) ) {
    function dinoco_claim_bank_maybe_migrate_constants() {
        if ( get_option( 'dinoco_claim_bank_seeded_from_constants', '' ) === '1' ) {
            return; // already ran
        }
        // V.33.2 MED-1 fix (Sprint 11) — fast-path short-circuit when NO constants
        // defined. V.33.1 HIGH-3 made the flag conditional so this function would
        // re-run on every admin_init for UI-only admins. ~14 get_option() calls
        // per admin request × N admins = real perf bleed at fleet scale. Cheap
        // defined() check exits BEFORE option lookups.
        $any_const_defined = false;
        foreach ( array( 'DINOCO_CLAIM_BANK_NAME', 'DINOCO_CLAIM_BANK_ACCOUNT',
            'DINOCO_CLAIM_BANK_HOLDER', 'DINOCO_CLAIM_BANK_CODE',
            'DINOCO_CLAIM_WALKIN_BANK_NAME', 'DINOCO_CLAIM_WALKIN_BANK_ACCOUNT' ) as $c ) {
            if ( defined( $c ) ) { $any_const_defined = true; break; }
        }
        if ( ! $any_const_defined ) return;

        // V.33.2 MED-1 fix — serialize concurrent admin_init runs via non-blocking
        // GET_LOCK (timeout=0 → skip if another worker already migrating). Without
        // this, cron tick + admin AJAX firing simultaneously could both pass the
        // flag-check, both INSERT into wp_options, both write audit rows.
        global $wpdb;
        $lock = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT GET_LOCK(%s, 0)", 'dinoco_claim_bank_migrate'
        ) );
        if ( $lock !== 1 ) return; // another process is migrating — defer

        try {
            // Re-check flag inside lock (TOCTOU defense)
            if ( get_option( 'dinoco_claim_bank_seeded_from_constants', '' ) === '1' ) {
                return;
            }

            $touched = 0;
            foreach ( array( 'default', 'walkin' ) as $bucket ) {
                $keys = dinoco_claim_bank_field_keys( $bucket );
                foreach ( $keys['options'] as $field => $opt_key ) {
                    $const_name = $keys['constants'][ $field ];
                    if ( ! defined( $const_name ) ) continue;
                    $current = get_option( $opt_key, '' );
                    if ( $current !== '' && $current !== false ) continue;
                    $val = constant( $const_name );
                    if ( ! is_string( $val ) || trim( $val ) === '' ) continue;
                    update_option( $opt_key, sanitize_text_field( $val ), false );
                    $touched++;
                }
            }
            // V.33.1 HIGH-3 — flag only set when at least one seed happened so
            // future constant additions still trigger migration on next admin_init.
            if ( $touched > 0 ) {
                update_option( 'dinoco_claim_bank_seeded_from_constants', '1', true );
                if ( function_exists( 'dinoco_audit_log' ) ) {
                    // V.33.3 Sprint 12 SEC-H1 fix — capture wp_get_current_user()->ID
                    // for forensic traceability. admin_init fires under an authenticated
                    // admin session — record who triggered the (one-shot) seed.
                    $actor_uid = 0;
                    if ( function_exists( 'wp_get_current_user' ) ) {
                        $u = wp_get_current_user();
                        $actor_uid = ( $u && isset( $u->ID ) ) ? (int) $u->ID : 0;
                    }
                    dinoco_audit_log( array(
                        'event_type'    => 'claim_bank_seeded_from_constants',
                        'actor_user_id' => $actor_uid,
                        'actor_type'    => $actor_uid > 0 ? 'admin' : 'system',
                        'target_type'   => 'wp_option',
                        'context'       => array(
                            'fields_seeded' => $touched,
                            'trigger'       => 'admin_init',
                            'ip'            => isset( $_SERVER['REMOTE_ADDR'] )
                                ? sanitize_text_field( wp_unslash( $_SERVER['REMOTE_ADDR'] ) ) : '',
                        ),
                    ) );
                }
            }
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", 'dinoco_claim_bank_migrate' ) );
        }
    }
}
add_action( 'admin_init', 'dinoco_claim_bank_maybe_migrate_constants' );

/**
 * Dual-channel audit log for save events.
 *
 * Channel 1 = dinoco_audit_log() — primary forensic row with full diff (1 row)
 * Channel 2 = dinoco_flag_audit_log() — per-key state transition (1 row per changed field)
 *
 * @param array $diff   array<wp_option_key, ['before'=>x, 'after'=>y]>
 * @param string $bucket 'default' or 'walkin'
 */
if ( ! function_exists( 'dinoco_claim_bank_audit_save' ) ) {
    function dinoco_claim_bank_audit_save( $diff, $bucket = 'default' ) {
        if ( empty( $diff ) ) return;

        // V.33.3 Sprint 12 SEC-L3 fix — mask middle digits of bank_account in
        // audit diff before persisting. Audit table may be readable via Flag
        // Audit Viewer by non-finance admins. Full PAN-style numbers should
        // never sit in plaintext at rest. Keeps first 3 + last 3 digits +
        // ellipsis for forensic identifiability without account-reuse risk.
        $masked_diff = array();
        foreach ( $diff as $opt_key => $delta ) {
            $is_account = ( strpos( $opt_key, 'bank_account' ) !== false );
            $masked_diff[ $opt_key ] = $is_account
                ? array(
                    'before' => dinoco_claim_bank_mask_account( isset( $delta['before'] ) ? $delta['before'] : '' ),
                    'after'  => dinoco_claim_bank_mask_account( isset( $delta['after'] )  ? $delta['after']  : '' ),
                )
                : $delta;
        }

        // Channel 1 — primary forensic row
        if ( function_exists( 'dinoco_audit_log' ) ) {
            dinoco_audit_log( array(
                'event_type' => 'claim_bank_settings_changed',
                'context'    => array(
                    'bucket' => $bucket,
                    'diff'   => $masked_diff,
                    'source' => 'claim_bank_settings_admin_ui',
                ),
            ) );
        } else {
            error_log( '[ClaimBank] dinoco_audit_log unavailable — skipped Channel 1 forensic row' );
        }

        // Channel 2 — per-key mirror (drives Flag Audit Viewer UI). Same masking
        // applied so Flag Audit Viewer cannot leak raw account numbers either.
        if ( function_exists( 'dinoco_flag_audit_log' ) ) {
            foreach ( $masked_diff as $opt_key => $delta ) {
                dinoco_flag_audit_log(
                    $opt_key,
                    isset( $delta['before'] ) ? $delta['before'] : '',
                    isset( $delta['after'] )  ? $delta['after']  : '',
                    'claim_bank_settings_save',
                    'admin_ui'
                );
            }
        }
    }
}

if ( ! function_exists( 'dinoco_claim_bank_mask_account' ) ) {
    /**
     * Mask bank account number for audit storage. Sprint 12 SEC-L3.
     * Format: first 3 + ellipsis + last 3. Strings ≤6 chars left as-is
     * (already low-value). Non-string falls back to ''.
     */
    function dinoco_claim_bank_mask_account( $val ) {
        if ( ! is_string( $val ) ) return '';
        $val = trim( $val );
        if ( $val === '' ) return '';
        $len = strlen( $val );
        if ( $len <= 6 ) return $val;
        return substr( $val, 0, 3 ) . str_repeat( '•', max( 3, $len - 6 ) ) . substr( $val, -3 );
    }
}

