// [FIX] Schedule cron event on init (only if not already scheduled)
add_action('init', 'dinoco_schedule_auto_close_cron');
function dinoco_schedule_auto_close_cron() {
    if (!wp_next_scheduled('dinoco_daily_auto_close_event')) {
        wp_schedule_event(time(), 'daily', 'dinoco_daily_auto_close_event');
    }
}

// Hook the auto-close function to cron event
add_action('dinoco_daily_auto_close_event', 'dinoco_daily_auto_close_tickets');

// Cleanup: Unschedule cron when plugin/theme is deactivated
register_deactivation_hook(__FILE__, 'dinoco_deactivate_auto_close_cron');
function dinoco_deactivate_auto_close_cron() {
    $timestamp = wp_next_scheduled('dinoco_daily_auto_close_event');
    if ($timestamp) {
        wp_unschedule_event($timestamp, 'dinoco_daily_auto_close_event');
    }
}

function dinoco_daily_auto_close_tickets() {

    $target_statuses = [
        'Replacement Shipped',
        'Repaired Item Dispatched',
        'Replacement Rejected by Company'
    ];

    $args = [
        'post_type'      => 'claim_ticket',
        'posts_per_page' => 50,
        'post_status'    => ['publish', 'private'],
        'meta_query'     => [
            [
                'key'     => 'ticket_status',
                'value'   => $target_statuses,
                'compare' => 'IN'
            ],
            [
                'key'     => 'status_last_updated',
                'value'   => date('Y-m-d H:i:s', strtotime('-30 days')),
                'compare' => '<',
                'type'    => 'DATETIME'
            ]
        ]
    ];

    $query = new WP_Query($args);

    if ($query->have_posts()) {
        while ($query->have_posts()) {
            $query->the_post();
            $pid = get_the_ID();

            $condition = get_field('claim_condition', $pid);
            if ($condition === 'send_part') {
                $sn_code = get_field('snapshot_serial_code', $pid);
                $snap_group = get_field('shipping_snap', $pid);
                $original_w_status = isset($snap_group['snapshot_w_status']) ? $snap_group['snapshot_w_status'] : '';

                $w_map_reverse = [
                    'สามารถลงทะเบียนรับประกันได้'            => 'warranty_available',
                    'รอตรวจสอบประกัน ติดต่อแอดมิน'          => 'warranty_pending',
                    'ระบบประกันเก่าไม่สามารถเช็คการซ่อมได้' => 'old_warranty',
                    'รับประกันสินค้าสินค้าใหม่สภาพสมบูรณ์'  => 'warranty_on',
                    'ผ่านการซ่อมบำรุง'                       => 'repaired',
                    'สภาพพร้อมใช้งาน'                        => 'refurbished',
                    'ดัดแปลงสภาพ'                            => 'modified',
                    'อยู่ระหว่างดำเนินการซ่อมบำรุง'          => 'claim_process'
                ];

                $target_w_status = isset($w_map_reverse[$original_w_status]) ? $w_map_reverse[$original_w_status] : $original_w_status;

                if ($sn_code && $target_w_status) {
                    $sn_posts = get_posts([
                        'post_type'      => 'serial_number',
                        'meta_key'       => 'serial_code',
                        'meta_value'     => $sn_code,
                        'posts_per_page' => 1,
                        'fields'         => 'ids'
                    ]);

                    if (!empty($sn_posts)) {
                        update_field('w_status', $target_w_status, $sn_posts[0]);
                    }
                }
            }

            // M18: route through helper — logs history + fires state_changed hook + records observation
            if ( function_exists( 'dinoco_set_claim_status' ) ) {
                dinoco_set_claim_status( $pid, 'Maintenance Completed', array(
                    'actor'  => 'system',
                    'source' => 'auto_close_cron',
                    'note'   => 'Auto-closed after 30 days (PCLM)',
                ) );
            } else {
                update_field('ticket_status', 'Maintenance Completed', $pid);
            }

            $current_note = get_field('admin_internal_note', $pid);
            $log = "[" . current_time('d/m/Y H:i') . "] System: Auto-closed after 30 days (PCLM).";
            update_field('admin_internal_note', $log . "\n" . $current_note, $pid);

            update_field('status_last_updated', current_time('Y-m-d H:i:s'), $pid);
        }
        wp_reset_postdata();
    }
}

