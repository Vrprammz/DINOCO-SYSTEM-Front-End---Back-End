        <script>
        (function() {
            var REST_BASE = <?php echo wp_json_encode( $rest_url ); ?>;
            var NONCE     = <?php echo wp_json_encode( $nonce ); ?>;
            var ADMIN_CLAIMS_URL = <?php echo wp_json_encode( $admin_claims_url ); ?>;

            var input    = document.getElementById('dnc-sn-sc-lookup-input');
            var goBtn    = document.getElementById('dnc-sn-sc-lookup-go');
            var scanBtn  = document.getElementById('dnc-sn-sc-lookup-scan');
            var scannerEl = document.getElementById('dnc-sn-sc-lookup-scanner');
            var scanCancelBtn = document.getElementById('dnc-sn-sc-lookup-scan-cancel');
            var resultEl = document.getElementById('dnc-sn-sc-lookup-result');
            var toastEl  = document.getElementById('dnc-sn-sc-lookup-toast');

            // Initial state
            resultEl.innerHTML = '<div class="dnc-sn-sc-lookup-result-empty">'
                + '👋 พิมพ์ S/N หรือกดปุ่มสแกน QR ด้านบน<br>'
                + '<small style="color:#9ca3af;">ตัวอย่าง: <code>DNCSS0001234</code></small>'
                + '</div>';

            // ─── Helpers ───────────────────────────────────────────────────
            function escapeHtml(s) {
                var d = document.createElement('div');
                d.textContent = s == null ? '' : String(s);
                return d.innerHTML;
            }
            function fmtDate(s) {
                if (!s) return '—';
                try {
                    var d = new Date(String(s).replace(' ', 'T'));
                    if (isNaN(d.getTime())) return s;
                    return d.toLocaleString('th-TH', { hour12: false });
                } catch (e) { return s; }
            }
            function showToast(msg, isError) {
                toastEl.textContent = msg;
                toastEl.style.background = isError ? '#dc2626' : '#1f2937';
                toastEl.classList.add('show');
                setTimeout(function() { toastEl.classList.remove('show'); }, 3000);
            }
            function classifyStatus(status) {
                if (status === 'registered' || status === 'claimed') return 'active';
                if (status === 'voided' || status === 'recalled' || status === 'stolen') return 'danger';
                if (status === 'in_pool' || status === 'reserved') return 'inactive';
                return 'warning';
            }
            function statusLabelTh(status) {
                var map = {
                    'reserved':              'สำรองไว้ (ยังไม่ใช้)',
                    'in_pool':               'พร้อมใช้ (ในคลัง)',
                    'allocated_to_order':    'จองให้ออเดอร์',
                    'shipped':               'ส่งออกแล้ว (กำลังเดินทาง)',
                    'registered':            'ลงทะเบียนแล้ว ✓',
                    'claimed':               'กำลังเคลม',
                    'replaced':              'เปลี่ยนใหม่แล้ว',
                    'transferred':           'โอนเจ้าของแล้ว',
                    'voided':                'ยกเลิก ❌',
                    'recalled':              'เรียกคืน ⚠️',
                    'stolen':                '🚨 รายงานหาย',
                    'reserved_for_legacy':   'สำรองสำหรับ Legacy',
                    'shipped_legacy':        'ส่ง Legacy แล้ว',
                    'cancelled_batch':       'ยกเลิก Batch',
                };
                return map[status] || status || '—';
            }
            function eventLabelTh(et) {
                var map = {
                    'plate_received':       '📦 รับเข้าคลัง',
                    'plate_allocated':      '🏷️ จัดสรรให้ออเดอร์',
                    'plate_shipped':        '🚚 ส่งออก',
                    'warranty_activated':   '✅ ลูกค้าลงทะเบียน',
                    'plate_voided':         '❌ ยกเลิก',
                    'plate_recalled':       '⚠️ เรียกคืน',
                    'plate_swapped':        '🔄 สลับเพลท',
                    'plate_transferred':    '↔️ โอนเจ้าของ',
                    'sc_quick_lookup':      '🔍 ตรวจที่ Service Center',
                };
                return map[et] || et || '—';
            }

            // ─── Audit logging via REST hit (best-effort, non-blocking) ───
            // Using existing /sc-lookup endpoint which already logs server-side
            // so no client-side audit call needed (defensive — backend handles).

            // ─── QR Scanner (lazy-loaded) ─────────────────────────────────
            var html5QrLib = null;
            var qrScannerInstance = null;

            function loadQrLibrary() {
                if (window._html5QrcodeLoaded && window.Html5Qrcode) {
                    return Promise.resolve(window.Html5Qrcode);
                }
                return new Promise(function(resolve, reject) {
                    var script = document.createElement('script');
                    script.src = 'https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js';
                    script.onload = function() {
                        window._html5QrcodeLoaded = true;
                        if (window.Html5Qrcode) resolve(window.Html5Qrcode);
                        else reject(new Error('html5-qrcode loaded but not exposed'));
                    };
                    script.onerror = function() { reject(new Error('Failed to load html5-qrcode')); };
                    document.head.appendChild(script);
                });
            }

            function startScan() {
                scannerEl.style.display = 'block';
                loadQrLibrary().then(function(Html5Qrcode) {
                    html5QrLib = Html5Qrcode;
                    qrScannerInstance = new Html5Qrcode('dnc-sn-sc-lookup-qr-reader');
                    qrScannerInstance.start(
                        { facingMode: 'environment' },
                        { fps: 10, qrbox: { width: 240, height: 240 } },
                        function(decodedText) {
                            // Extract S/N from QR (could be URL or raw S/N)
                            var sn = String(decodedText || '').trim().toUpperCase();
                            // Heuristic: if URL, try ?sn= or last path segment
                            var m = sn.match(/[?&]SN=([A-Z0-9]+)/i);
                            if (m) sn = m[1].toUpperCase();
                            else if (sn.indexOf('/') >= 0) {
                                var parts = sn.split('/').filter(Boolean);
                                sn = parts[parts.length - 1];
                            }
                            stopScan();
                            input.value = sn;
                            doLookup();
                        },
                        function(/* errorMsg */) { /* ignore per-frame errors */ }
                    ).catch(function(err) {
                        scannerEl.style.display = 'none';
                        showToast('ไม่สามารถเปิดกล้อง: ' + (err.message || err), true);
                        input.focus();
                    });
                }).catch(function(err) {
                    scannerEl.style.display = 'none';
                    showToast('โหลด QR scanner ไม่สำเร็จ — กรุณาพิมพ์ S/N แทน', true);
                    input.focus();
                });
            }

            function stopScan() {
                scannerEl.style.display = 'none';
                if (qrScannerInstance) {
                    try {
                        qrScannerInstance.stop().then(function() {
                            qrScannerInstance.clear();
                            qrScannerInstance = null;
                        }).catch(function() {});
                    } catch (e) {}
                }
            }

            // ─── Lookup ───────────────────────────────────────────────────
            function doLookup() {
                var sn = (input.value || '').trim().toUpperCase();
                if (!sn) {
                    resultEl.innerHTML = '<div class="dnc-sn-sc-lookup-result-empty">พิมพ์ S/N ด้านบน</div>';
                    return;
                }
                if (!/^[A-Z0-9]{3,40}$/.test(sn)) {
                    resultEl.innerHTML = '<div class="dnc-sn-sc-lookup-result-not-found">'
                        + '<h3>รูปแบบ S/N ไม่ถูกต้อง</h3>'
                        + '<small>ตัวอย่าง: DNCSS0001234</small>'
                        + '</div>';
                    return;
                }
                input.value = sn;
                resultEl.innerHTML = '<div class="dnc-sn-sc-lookup-result-loading">'
                    + '⏳ กำลังค้นหา S/N <code>' + escapeHtml(sn) + '</code>…'
                    + '</div>';

                fetch(REST_BASE + '/sc-lookup/' + encodeURIComponent(sn), {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin'
                })
                .then(function(r) {
                    return r.json().then(function(j) {
                        return { ok: r.ok, status: r.status, data: j };
                    });
                })
                .then(function(res) { renderResult(sn, res); })
                .catch(function(e) {
                    resultEl.innerHTML = '<div class="dnc-sn-sc-lookup-result-not-found">'
