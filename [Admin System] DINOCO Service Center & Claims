                    +     '<div><strong>สถานะ:</strong> <span class="dnc-cf-status-badge dnc-cf-st-' + escHtml(res.status || 'created') + '">' + escHtml(_cfStatusLabels[res.status] || res.status || '-') + '</span></div>'
                    +     '<div><strong>สร้างเมื่อ:</strong> ' + escHtml(_cfFmtDate(res.created_at || '')) + '</div>'
