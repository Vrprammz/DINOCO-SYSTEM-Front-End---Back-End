        async function deleteTicket(id) {
            var ok = await _scCfm('ต้องการลบ Ticket #' + id + ' จริงหรือไม่?\n\nข้อมูลจะหายถาวรและสถานะประกันจะถูกคืนค่าเดิม', {title:'ลบ Ticket (ขั้นที่ 1)', confirmText:'ดำเนินการต่อ', danger:true});
            if (!ok) return;

            let confirmText = await _scPrompt('พิมพ์ "ลบ" เพื่อยืนยันการลบถาวร:', {title:'ยืนยันการลบถาวร (ขั้นที่ 2)', placeholder:'พิมพ์: ลบ', required:true, maxLength:10, confirmText:'ลบถาวร'});
            if (confirmText !== 'ลบ') {
                await _scAlert('ยกเลิกการลบ', 'info');
                return;
            }

            // N7 — inline progress indicator
            var btn = document.querySelector('[data-delete-tid="' + id + '"]');
            var origHtml = btn ? btn.innerHTML : null;
            if (btn) { btn.disabled = true; btn.innerHTML = '⏳ กำลังลบ...'; }

            $.post(getAjaxUrl(), { dinoco_claims_module_action: 'delete_claim_ticket', tid: id, _dinoco_admin_nonce: dinoco_admin_nonce }, function(res){
                if(res.success) {
                    _scAlert('ลบ Ticket #' + id + ' เรียบร้อยแล้ว', 'success').then(function(){
                        refreshDashboard();
                        loadList();
                    });
                } else {
                    if (btn && origHtml !== null) { btn.disabled = false; btn.innerHTML = origHtml; }
                    _scAlert('เกิดข้อผิดพลาดในการลบ: ' + (res.message || 'Unknown Error'), 'error');
                }
            }).fail(function() {
                if (btn && origHtml !== null) { btn.disabled = false; btn.innerHTML = origHtml; }
                _scAlert('เชื่อมต่อเซิร์ฟเวอร์ไม่สำเร็จ กรุณาลองใหม่', 'error');
            });
        }

