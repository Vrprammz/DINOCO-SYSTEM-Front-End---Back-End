         * V.34.6 Sprint 29 Phase 4 Batch B Item 3 — Multi-shipment grouping.
         * Groups rows by direction. Default — first non-empty group is
         * expanded, others collapsed. Preserves all per-row actions (cancel,
         * view tracking). UX-H3 strict — data-action delegation only.
         */
        function _cfRenderList(items) {
            if (!items || items.length === 0) {
                $('#dnc-cf-list-panel').html('<div class="dnc-cf-empty">ยังไม่มี Flash Shipment สำหรับงานนี้</div>');
                return;
            }

            // Bucket items by direction (deterministic order replacement →
            // repaired_return → inbound_pickup → other).
            var groupOrder = ['replacement', 'repaired_return', 'inbound_pickup'];
            var groups = {};
            groupOrder.forEach(function(d) { groups[d] = []; });
            var otherGroup = [];
            items.forEach(function(it) {
                var dir = String(it.direction || '');
                if (groups.hasOwnProperty(dir)) {
                    groups[dir].push(it);
                } else {
                    otherGroup.push(it);
                }
            });

            // Render each row (sub-function to keep parity with old structure).
            function _cfRowHtml(it) {
                var dir = String(it.direction || '');
                var st = String(it.status || 'created');
                var stLabel = _cfStatusLabels[st] || st;
                var canCancel = (st === 'created');
                var pno = String(it.pno || '');
