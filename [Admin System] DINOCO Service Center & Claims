        // ─────────────────────────────────────────────────────────────────
        // V.32.0 Sprint 8 — Phase 1 Task 1.5: Claim Notifications Log
        //
        // Reads Claim Lifecycle Notifier V.0.3 audit trail via REST endpoints:
        //   GET  /wp-json/dinoco-claim/v1/notif/log?claim_id=N
        //   POST /wp-json/dinoco-claim/v1/notif/resend
        //
        // Section auto-hidden when wp_option `dinoco_claim_notif_enabled=0`
        // (server-side render gate adds .hidden class to #sc-notif-log-section).
        // ─────────────────────────────────────────────────────────────────

        function escNotifHtml(s) { return $('<div>').text(s == null ? '' : String(s)).html(); }

        function loadNotifLog(tid) {
            var $section = $('#sc-notif-log-section');
            if (!$section.length || $section.attr('data-enabled') !== '1') return;
            var $body  = $('#sc-notif-log-body');
            var $count = $('#sc-notif-log-count');
            $body.html('<div class="text-center py-6 text-slate-400 text-xs"><i class="fa-solid fa-spinner fa-spin mr-1"></i> กำลังโหลด...</div>');
            $count.text('—');

            $.ajax({
                url: '/wp-json/dinoco-claim/v1/notif/log?claim_id=' + encodeURIComponent(tid),
                method: 'GET',
                headers: { 'X-WP-Nonce': (window.wpApiSettings && window.wpApiSettings.nonce) || '' },
                cache: false
            }).done(function(res) {
                if (!res || !Array.isArray(res.log)) {
                    $body.html('<div class="text-center py-4 text-slate-400 text-xs">ไม่พบประวัติการแจ้งเตือน</div>');
                    $count.text('0 รายการ');
                    return;
                }
                renderNotifLog(res.log, tid);
                $count.text(res.count + ' รายการ');
            }).fail(function(xhr) {
                var msg = (xhr.responseJSON && xhr.responseJSON.message) || ('HTTP ' + xhr.status);
                $body.html('<div class="text-center py-4 text-red-500 text-xs">โหลดประวัติแจ้งเตือนล้มเหลว: ' + escNotifHtml(msg) + '</div>');
                $count.text('—');
            });
        }

        function renderNotifLog(rows, tid) {
            var $body = $('#sc-notif-log-body');
            if (!rows.length) {
                $body.html('<div class="text-center py-4 text-slate-400 text-xs">ยังไม่มีประวัติแจ้งเตือน (ยังไม่เคยส่ง LINE Flex)</div>');
                return;
            }
            // Reverse — show most recent first
            var html = '<div class="overflow-x-auto"><table class="w-full text-xs">';
            html += '<thead><tr class="text-slate-400 uppercase text-[10px] border-b border-slate-200">';
            html += '<th class="text-left p-2 font-semibold">เวลา</th>';
            html += '<th class="text-left p-2 font-semibold">สถานะที่แจ้ง</th>';
            html += '<th class="text-center p-2 font-semibold">ผล</th>';
            html += '<th class="text-left p-2 font-semibold">เหตุผล/Error</th>';
            html += '<th class="text-right p-2 font-semibold w-24">ส่งใหม่</th>';
            html += '</tr></thead><tbody>';
            for (var i = rows.length - 1; i >= 0; i--) {
                var r = rows[i] || {};
                var ts = escNotifHtml(r.ts || '');
                var status = escNotifHtml(r.status || '');
                var success = !!r.success;
                var badge = success
                    ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-100 text-emerald-700">✓ ส่งแล้ว</span>'
                    : '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700">✗ ล้มเหลว</span>';
                var err = success ? '<span class="text-slate-400">—</span>' : '<span class="text-red-600 font-mono text-[10px]">' + escNotifHtml(r.error || '') + '</span>';
                html += '<tr class="border-b border-slate-50 hover:bg-slate-50/50">';
                html += '<td class="p-2 text-slate-500 font-mono">' + ts + '</td>';
                html += '<td class="p-2 text-slate-700">' + status + '</td>';
                html += '<td class="p-2 text-center">' + badge + '</td>';
                html += '<td class="p-2">' + err + '</td>';
                html += '<td class="p-2 text-right"><button type="button" class="js-sc-resend-notif text-blue-600 hover:text-blue-700 border border-blue-200 hover:border-blue-300 bg-white px-2.5 py-1 rounded-md text-[10px] font-bold transition active:scale-95" data-tid="' + (tid | 0) + '" data-status="' + status + '">🔁 ส่งใหม่</button></td>';
                html += '</tr>';
            }
            html += '</tbody></table></div>';
            $body.html(html);
        }

        async function resendNotif(tid, status) {
            var ok = await _scCfm(
                'ส่ง LINE Flex สถานะ "' + status + '" ซ้ำให้ลูกค้า?\n\n' +
                '(ระบบจะข้าม dedup 60s + idempotency cache เพื่อบังคับส่งใหม่)',
                { title: 'ยืนยันส่งใหม่', confirmText: 'ส่งใหม่' }
            );
            if (!ok) return;

            $.ajax({
                url: '/wp-json/dinoco-claim/v1/notif/resend',
                method: 'POST',
                contentType: 'application/json',
                headers: { 'X-WP-Nonce': (window.wpApiSettings && window.wpApiSettings.nonce) || '' },
                data: JSON.stringify({ claim_id: tid, status: status || '' })
            }).done(function(res) {
                var r = res && res.result ? res.result : {};
                if (r.sent) {
                    _scAlert('ส่ง LINE Flex สำเร็จ', 'success');
                } else {
