        <script>
        (function(){
            var root = document.querySelector('.dnc-cb-root');
            if (!root) return;
            var restUrl = root.getAttribute('data-rest');
            var nonce = root.getAttribute('data-nonce');
            var resultBox = root.querySelector('#dnc-cb-result');

            // Modal helpers — reuse Service Center _scCfm/_scAlert pattern (UX-C2)
            async function cbCfm(msg, opts){
                opts = opts || {};
                try { return await window.dinocoModal.confirm({
                    title: opts.title || 'ยืนยัน', message: msg,
                    confirmText: opts.confirmText || 'ตกลง', cancelText: 'ยกเลิก',
                    danger: !!opts.danger
                }); } catch(e){ return confirm(msg); }
            }
            async function cbAlert(msg, type){
                try { await window.dinocoModal.alert({
                    title: type==='error'?'เกิดข้อผิดพลาด':'แจ้งเตือน',
                    message: msg, type: type||'info'
                }); } catch(e){ alert(msg); }
            }

            function showResult(html, ok){
                resultBox.innerHTML = '<div class="' + (ok ? 'dnc-cb-result-ok' : 'dnc-cb-result-err') + '">' + html + '</div>';
            }

            function collectPayload(bucket){
                var prefix = bucket === 'walkin' ? '#dnc-cb-w-' : '#dnc-cb-d-';
                return {
                    bank_name:     (root.querySelector(prefix + 'name') || {}).value || '',
                    bank_name_en:  (root.querySelector(prefix + 'name_en') || {}).value || '',
                    bank_account:  (root.querySelector(prefix + 'account') || {}).value || '',
                    bank_holder:   (root.querySelector(prefix + 'holder') || {}).value || '',
                    bank_code:     (root.querySelector(prefix + 'code') || {}).value || '',
                    bank_branch:   (root.querySelector(prefix + 'branch') || {}).value || '',
                    bank_logo_url: (root.querySelector(prefix + 'logo') || {}).value || ''
                };
            }

            // V.33.1 MED-5 fix — full HTML escape for Flex preview (was single-char only).
            // V.33.2 LOW-2 fix (Sprint 11) — 200-char cap on output. Network errors
            // can produce multi-MB strings from misbehaving servers — capping
            // prevents toast UI from rendering megabytes of escaped chars.
            function escFull(s){
                s = String(s == null ? '' : s);
                if (s.length > 200) s = s.slice(0, 200) + '…';
                return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                        .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
            }
            // Unbounded variant for trusted JSON.stringify(data.flex) output —
            // backend-controlled content + already JSON.stringify'd → no length surprises.
            function escFullUnbounded(s){
                s = String(s == null ? '' : s);
                return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                        .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
            }

            // V.33.1 HIGH-2 fix — stale nonce auto-reload (mirrors Manual Invoice V.34.9).
            // Long admin sessions (>24h) hit rest_cookie_invalid_nonce 403 → without
            // this guard, every save silently fails. One-shot dialog → reload page →
            // fresh nonce + restart clean. Whitelist exact error codes only (Sprint 7
            // MED-2 precedent — don't catch unrelated 403s like rate_limit).
            //
            // V.33.2 MED-2 (Sprint 11) — added rest_user_invalid_session (WP core
            // emits this when session_tokens table row disappears) + TODO note.
            // NOTE: guard depends on native confirm() blocking the event loop.
            // Migration to async dinocoModal.confirm() will require explicit
            // serialization (e.g., shared Promise lock) to preserve one-shot behavior.
            var _claimBankNonceReloadShown = false;
            function _claimBankHandleAuthError(status, errCode){
                if (status !== 403 && status !== 401) return false;
                var nonceCodes = {
                    'rest_cookie_invalid_nonce': 'nonce',
                    'rest_user_invalid_session': 'logout',
                    'rest_forbidden': 'logout',
                    'rest_not_logged_in': 'logout',
                };
                var match = nonceCodes[errCode];
                if (!match) return false;
                if (_claimBankNonceReloadShown) return true;
                _claimBankNonceReloadShown = true;
                if (match === 'nonce') {
                    var ok = confirm('Security token หมดอายุ — กดตกลงเพื่อโหลดหน้าใหม่ (ข้อมูลที่กรอกค้างจะหายไป)');
                    if (ok) window.location.reload();
                    else _claimBankNonceReloadShown = false;
                } else {
                    window.location.href = '/wp-login.php?redirect_to=' + encodeURIComponent(window.location.href);
                }
                return true;
            }

            async function saveBucket(bucket){
                // V.33.1 CRIT-1 fix — walkin "ใช้บัญชีเดียวกับบัญชีหลัก" must wipe
                // walkin wp_options server-side (UI-only hide leaks stale data into
                // Phase 2 charge handler). Detect walkin + checkbox checked → send
                // clear:true instead of payload.
                var clearWalkin = (bucket === 'walkin' && walkinToggle && walkinToggle.checked);

                var confirmMsg = clearWalkin
                    ? 'ยืนยันใช้บัญชีเดียวกับบัญชีหลัก? (ระบบจะลบข้อมูลบัญชี Walk-in ออกจาก database)'
                    : 'ยืนยันการบันทึกบัญชี' + (bucket === 'walkin' ? ' Walk-in' : 'หลัก') + '?';
                var ok = await cbCfm(confirmMsg, {
                    title: clearWalkin ? 'ลบบัญชี Walk-in' : 'บันทึกบัญชี',
                    confirmText: clearWalkin ? 'ลบและใช้บัญชีหลัก' : 'บันทึก',
                    danger: !!clearWalkin
                });
                if (!ok) return;

                var bodyObj = clearWalkin
                    ? { bucket: 'walkin', clear: true }
                    : { bucket: bucket, payload: collectPayload(bucket) };

                try {
                    var resp = await fetch(restUrl, {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json', 'X-WP-Nonce': nonce},
                        body: JSON.stringify(bodyObj)
                    });
                    var data = await resp.json();
                    if (!resp.ok) {
                        var errCode = data && data.code ? data.code : '';
                        if (_claimBankHandleAuthError(resp.status, errCode)) return;
                        var errMsgs = [];
                        if (data && data.data && data.data.errors) {
                            for (var k in data.data.errors) errMsgs.push(k + ': ' + data.data.errors[k]);
                        }
                        showResult('บันทึกล้มเหลว — ' + (errMsgs.join(', ') || (data && data.message) || 'unknown'), false);
                        return;
                    }
                    if (clearWalkin) {
                        showResult('✅ ลบบัญชี Walk-in เรียบร้อย — ' + (data.change_count || 0) + ' ฟิลด์ถูกล้าง', true);
                    } else {
                        showResult('✅ บันทึกเรียบร้อย — เปลี่ยน ' + (data.change_count || 0) + ' ฟิลด์', true);
                    }
                } catch (e) {
                    showResult('Network error: ' + escFull(e.message), false);
                }
            }

            async function testBucket(bucket){
                try {
                    var resp = await fetch(restUrl + '/test', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json', 'X-WP-Nonce': nonce},
                        body: JSON.stringify({use_walkin: bucket === 'walkin'})
                    });
                    var data = await resp.json();
                    if (!resp.ok) {
                        var errCode = data && data.code ? data.code : '';
                        if (_claimBankHandleAuthError(resp.status, errCode)) return;
                        showResult('ทดสอบล้มเหลว — ' + ((data && data.message) || 'unknown'), false);
                        return;
                    }
                    // V.33.1 MED-5 fix — full HTML escape (was &lt; only). Bank fields
                    // can contain user-controlled strings that flow into JSON preview.
                    // V.33.2 LOW-2 (Sprint 11) — JSON.stringify output may legitimately
                    // exceed 200 chars (Flex bubble JSON ~500-2000 chars). Use the
                    // unbounded variant — backend-controlled + already JSON.stringify'd.
                    showResult('🧪 Flex Preview (Phase 1 — ไม่ได้ส่งจริง):<br><pre>' +
                        escFullUnbounded(JSON.stringify(data.flex, null, 2)) + '</pre>', true);
                } catch (e) {
                    showResult('Network error: ' + escFull(e.message), false);
                }
            }

            // Walk-in toggle — show/hide form
            var walkinToggle = root.querySelector('#dnc-cb-walkin-share');
            var walkinForm = root.querySelector('.dnc-cb-walkin-form');
            if (walkinToggle && walkinForm) {
                walkinToggle.addEventListener('change', function(){
                    if (walkinToggle.checked) {
                        walkinForm.setAttribute('hidden', '');
                    } else {
                        walkinForm.removeAttribute('hidden');
                    }
                });
            }

            // Event delegation — save + test buttons (covers both buckets)
            root.addEventListener('click', function(ev){
                var saveBtn = ev.target.closest('.js-dnc-cb-save');
                var testBtn = ev.target.closest('.js-dnc-cb-test');
                if (saveBtn) {
                    ev.preventDefault();
                    saveBucket(saveBtn.getAttribute('data-bucket') || 'default');
                }
                if (testBtn) {
                    ev.preventDefault();
                    testBucket(testBtn.getAttribute('data-bucket') || 'default');
                }
            });
        })();
        </script>
        <?php
        return ob_get_clean();
    }
}

