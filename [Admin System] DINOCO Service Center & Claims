                ok = await window.dinocoModal.confirm({
                    title: '📦 สร้าง Flash Shipment สำหรับเคลม #' + _cfCurrentTid,
                    message: html,
                    content: html,
                    confirmText: 'สร้าง Shipment',
                    cancelText: 'ยกเลิก',
                    danger: false,
                    onConfirm: function() {
                        captured = {
                            /* V.34.6 Sprint 29 Phase 4 Batch B Item 7 — pickup mode flag */
                            pickup_at_warehouse: !!$('#dnc-cf-pickup-at-wh').is(':checked'),
                            direction: $('#dnc-cf-dir-pills .dnc-cf-dir-pill-active').attr('data-dir') || 'replacement',
                            name:      ($('#dnc-cf-name').val() || '').trim(),
                            phone:     ($('#dnc-cf-phone').val() || '').trim(),
                            address:   ($('#dnc-cf-address').val() || '').trim(),
                            district:  ($('#dnc-cf-district').val() || '').trim(),
                            city:      ($('#dnc-cf-city').val() || '').trim(),
                            province:  ($('#dnc-cf-province').val() || '').trim(),
                            postcode:  ($('#dnc-cf-postcode').val() || '').trim(),
                            weight:    parseInt($('#dnc-cf-weight').val(), 10) || 500,
                            article:   parseInt($('#dnc-cf-article').val(), 10) || 99,
                            length:    parseInt($('#dnc-cf-length').val(), 10) || 0,
