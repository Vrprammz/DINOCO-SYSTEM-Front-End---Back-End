        /**
         * V.34.4 — Generate UUID v4 for X-Idempotency-Key header.
         */
        function _cfUuid() {
            if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                return window.crypto.randomUUID();
            }
            // Fallback: 8-4-4-4-12 hex pattern via Math.random
            return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
                return v.toString(16);
            });
        }

        function _cfDirLabel(v) {
            for (var i = 0; i < _cfDirOptions.length; i++) {
                if (_cfDirOptions[i].value === v) return _cfDirOptions[i].label;
            }
            return v || '';
        }

        /**
         * V.34.4 — Format Buddhist year on dates (claim UX standard).
         */
        function _cfFmtDate(s) {
            if (!s) return '-';
            var d = new Date(String(s).replace(' ', 'T'));
            if (isNaN(d.getTime())) return String(s).substring(0, 16);
            var dd = ('0' + d.getDate()).slice(-2);
            var mm = ('0' + (d.getMonth() + 1)).slice(-2);
            var yy = d.getFullYear() + 543;
            var hh = ('0' + d.getHours()).slice(-2);
            var mn = ('0' + d.getMinutes()).slice(-2);
            return dd + '/' + mm + '/' + yy + ' ' + hh + ':' + mn;
        }

