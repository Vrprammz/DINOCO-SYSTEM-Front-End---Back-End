                        return true;
                    }
                });
            } catch (e) {
                ok = confirm('สร้าง Flash Shipment? (Modal Helpers ไม่พร้อม — ใช้ default replacement)');
                if (!ok) return;
                captured = { pickup_at_warehouse: false, direction: 'replacement', name: snap.name || '', phone: snap.phone || '', address: snap.address || '', weight: 500, article: 99 };
            }
            if (!ok || !captured) return;

            var submitTid = _cfCurrentTid;
            if (!submitTid) { _scAlert('ไม่พบหมายเลขเคลม', 'error'); return; }

            var $btn = $('#dnc-cf-trigger-btn');
            $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin mr-1"></i> กำลังสร้าง...');

            // V.34.6 Item 7 — Branch on pickup-at-warehouse opt-in. When checked,
            // route to /pickup-at-warehouse (no Flash dispatch, no PNO).
            if (captured.pickup_at_warehouse) {
                var pickupBody = {
                    claim_id: submitTid
                };
                $.ajax({
                    url: '/wp-json/dinoco-claim/v1/pickup-at-warehouse',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(pickupBody),
                    beforeSend: function(xhr) {
                        xhr.setRequestHeader('X-WP-Nonce', (window.wpApiSettings && window.wpApiSettings.nonce) || '');
                        xhr.setRequestHeader('X-Idempotency-Key', _cfUuid());
                    }
                }).done(function(res) {
                    _scAlert('บันทึก "มารับเองที่โกดัง" สำเร็จ — ลูกค้าจะได้รับ Flex แจ้งที่อยู่โกดัง', 'success');
                    if (typeof scLoadFlashList === 'function') {
                        scLoadFlashList(submitTid, { customer_info_snap: _cfCurrentSnap });
                    }
                }).fail(function(xhr) {
                    var data = xhr && xhr.responseJSON;
                    var msg = (data && data.message) || ('บันทึก pickup ล้มเหลว (HTTP ' + (xhr ? xhr.status : '?') + ')');
                    _scAlert(msg, 'error');
                }).always(function() {
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-plus"></i> สร้าง Flash Shipment');
                });
                return;
            }

            var body = {
                claim_id:        submitTid,
                direction:       captured.direction,
                weight_grams:    captured.weight,
                articleCategory: captured.article,
                dimensions: {
                    length_cm: captured.length || 0,
                    width_cm:  captured.width  || 0,
                    height_cm: captured.height || 0
                },
                notes: captured.notes,
                recipient_override: {
                    name:     captured.name,
                    phone:    captured.phone,
                    address:  captured.address,
                    district: captured.district,
                    city:     captured.city,
                    province: captured.province,
                    postcode: captured.postcode
                }
            };

            $.ajax({
                url: '/wp-json/dinoco-claim/v1/flash-create',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(body),
                beforeSend: function(xhr) {
                    xhr.setRequestHeader('X-WP-Nonce', (window.wpApiSettings && window.wpApiSettings.nonce) || '');
                    xhr.setRequestHeader('X-Idempotency-Key', _cfUuid());
                }
            }).done(function(res) {
                _scAlert('สร้าง Flash สำเร็จ — PNO ' + (res.pno || '-'), 'success');
                scLoadFlashList(submitTid, { customer_info_snap: _cfCurrentSnap });
            }).fail(function(xhr) {
                var data = xhr && xhr.responseJSON;
                var code = (data && data.code) || '';
                var msg = (data && data.message) || ('สร้าง Flash ล้มเหลว (HTTP ' + (xhr ? xhr.status : '?') + ')');
                if (code === 'missing_address') {
                    var fields = (data.data && data.data.fields) ? data.data.fields.join(', ') : '';
                    msg = 'ข้อมูลที่อยู่ไม่ครบ: ' + fields;
                }
                _scAlert(msg, 'error');
            }).always(function() {
                $btn.prop('disabled', false).html('<i class="fa-solid fa-plus"></i> สร้าง Flash Shipment');
            });
        }

        // V.34.6 Item 7 — toggle pickup-at-warehouse — collapse address+dims sections.
        $(document).on('change', '[data-action="dnc-cf-toggle-pickup"]', function() {
            var on = $(this).is(':checked');
