// ==============================================================================
// M18 — Canonical claim-status helper (V.30.5, 2026-04-12)
// ==============================================================================
//
// Single write point for claim_ticket.ticket_status mutations across all
// subsystems (Service Center admin UI, LIFF AI, Member Dashboard, MCP Bridge).
//
// Design notes (Option A from Sprint 2 decision):
//   1. Soft allowlist via `apply_filters('dinoco/claim/allowed_states', ...)`
//      instead of hardcoded matrix. Reason: the real claim state space is
//      free-form text with ~6 variants per logical state (Thai + English +
//      slug + PascalCase) across 5 files. A strict transition matrix needs a
//      product decision on state canonicalization — tracked as M20.
//   2. Each subsystem registers its own vocabulary via add_filter in its own
//      file, documenting ownership (LIFF AI owns the 6 authoritative labels,
//      Member Dashboard owns the legacy variants, etc.)
//   3. Observability option `dinoco_claim_observations` records every
//      (from, to) pair for M20 data collection. Cap 200 entries, trim to
//      top-100 by count on overflow. autoload=false so it doesn't bloat every
//      WP request.
//   4. Idempotent: from === to → WP_Error('terminal_state'), no write.
//   5. Fires `dinoco/claim/state_changed` hook for downstream listeners.
//   6. Appends to `status_history` ACF field + post_meta fallback (mirrors
//      the LIFF AI pattern).
//
// Callers should guard with function_exists() because this file loads on
// init just like all other snippets — load order between snippets isn't
// guaranteed, so some callers may fire before this helper is defined.
// ==============================================================================

if ( ! function_exists( 'dinoco_set_claim_status' ) ) {
    /**
     * Canonical claim-status transition helper.
     *
     * @param int    $claim_id  claim_ticket post ID
     * @param string $to_state  target state string (must pass the allowlist filter)
     * @param array  $context   optional: ['actor' => string, 'note' => string, 'source' => string]
     * @return true|WP_Error    true on success, WP_Error on invalid/terminal
     */
    function dinoco_set_claim_status( $claim_id, $to_state, $context = array() ) {
        $claim_id = intval( $claim_id );
        if ( $claim_id <= 0 ) {
            return new WP_Error( 'bad_claim_id', 'Invalid claim_id' );
        }
        $to_state = is_string( $to_state ) ? trim( $to_state ) : '';
        if ( $to_state === '' ) {
            return new WP_Error( 'empty_state', 'Target state is empty' );
        }

        // 1. Read current state (before observation so we can record it)
        $from_state = get_field( 'ticket_status', $claim_id );
        if ( ! is_string( $from_state ) ) $from_state = '';

        // 2. Record observation for M20 — do this FIRST, before allowlist + idempotency
        //    checks, so we capture EVERY attempted transition including:
        //    - invalid_state rejections (chatbot or client sending unregistered labels)
        //    - terminal_state no-ops (how often does the UI re-apply the same state?)
        //    This is the primary data source for M20 canonicalization.
        if ( function_exists( 'dinoco_claim_record_observation' ) ) {
            dinoco_claim_record_observation( $from_state, $to_state );
        }

        // 3. Allowlist — each subsystem registers its vocabulary via filter
        $allowed = apply_filters( 'dinoco/claim/allowed_states', array() );
        if ( ! is_array( $allowed ) ) $allowed = array();
        if ( ! in_array( $to_state, $allowed, true ) ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[ClaimStatus] Invalid state: #%d → %s', $claim_id, $to_state ) );
            }
            return new WP_Error(
                'invalid_state',
                sprintf( 'Unknown claim state: %s (register via dinoco/claim/allowed_states filter)', $to_state )
            );
        }

        // 4. Idempotency — same state = no-op (mirrors FSM terminal_state semantics)
        if ( $from_state === $to_state ) {
            return new WP_Error( 'terminal_state', 'Already in state: ' . $to_state );
        }

        // 5. Apply write
        update_field( 'ticket_status', $to_state, $claim_id );

        // 6. Append status_history (mirror LIFF AI Snippet 1 pattern)
        $history = get_field( 'status_history', $claim_id );
        if ( ! is_array( $history ) ) $history = array();
        $history[] = array(
            'from'   => $from_state,
            'to'     => $to_state,
            'actor'  => isset( $context['actor'] )  ? (string) $context['actor']  : 'system',
            'note'   => isset( $context['note'] )   ? (string) $context['note']   : '',
            'source' => isset( $context['source'] ) ? (string) $context['source'] : '',
            'at'     => current_time( 'c' ),
        );
        update_field( 'status_history', $history, $claim_id );
        update_post_meta( $claim_id, 'status_history', $history ); // defensive fallback

        // 7. Fire hook for downstream listeners
        do_action( 'dinoco/claim/state_changed', $claim_id, $from_state, $to_state, $context );

        // 8. Log
        if ( function_exists( 'b2b_log' ) ) {
            $actor = isset( $context['actor'] ) ? $context['actor'] : 'system';
            b2b_log( sprintf( "[ClaimStatus] #%d: '%s' → '%s' (actor=%s)", $claim_id, $from_state, $to_state, $actor ) );
        }

        return true;
    }
}

if ( ! function_exists( 'dinoco_claim_record_observation' ) ) {
    /**
     * Record a (from, to) transition observation for M20 state canonicalization.
     *
     * Storage: wp_option 'dinoco_claim_observations' (autoload=false)
     * Schema:  md5(from||to) => { from, to, count, first_seen, last_seen }
     * Cap:     200 entries max; on overflow, trim to top-100 by count
     *
     * Used to answer: "Which from→to transitions actually happen in production?"
     * Feeds into M20 analysis — once we have 2–4 weeks of data, we can see which
     * state-string variants are real (e.g. 'registered' vs 'Registered in System')
     * and make a product decision on canonicalization.
     */
    function dinoco_claim_record_observation( $from_state, $to_state ) {
        $obs = get_option( 'dinoco_claim_observations', array() );
        if ( ! is_array( $obs ) ) $obs = array();
        $key = md5( (string) $from_state . '||' . (string) $to_state );
        $now = current_time( 'mysql' );

        if ( isset( $obs[ $key ] ) && is_array( $obs[ $key ] ) ) {
            $obs[ $key ]['count']     = intval( $obs[ $key ]['count'] ?? 0 ) + 1;
            $obs[ $key ]['last_seen'] = $now;
        } else {
            $obs[ $key ] = array(
                'from'       => (string) $from_state,
                'to'         => (string) $to_state,
                'count'      => 1,
                'first_seen' => $now,
                'last_seen'  => $now,
            );
        }

        // Cap: if over 200, keep top-100 by count (drop rarely-seen transitions)
        if ( count( $obs ) > 200 ) {
            uasort( $obs, function( $a, $b ) {
                return intval( $b['count'] ?? 0 ) <=> intval( $a['count'] ?? 0 );
            });
            $obs = array_slice( $obs, 0, 100, true );
        }

        update_option( 'dinoco_claim_observations', $obs, false ); // autoload=false
    }
}

// ==============================================================================
// V.31.0 — Phase 2 W6.4 sn_pool integration listener
// ==============================================================================
//
// Hooks into the EXISTING `dinoco/claim/state_changed` action fired by
// dinoco_set_claim_status() (M18 V.30.5). This listener is purely additive —
// it does NOT modify the canonical helper. If sn_pool tables are not yet
// installed (Phase 1 W2 not yet deployed) every code path defensively no-ops.
//
// Status mapping (v2.6 spec §Gap A):
//   pending / reviewing / Pending Issue Verification          → claimed
//   approved / Replacement Approved                            → claimed
//   in_progress / Under Maintenance / Awaiting Customer Shipment → claimed
//   waiting_parts / Pending Issue Verification (parts wait)    → claimed
//   repairing / quality_check / Maintenance Completed          → claimed
//   completed + claim_condition=send_repair (Repaired Item Dispatched) → registered (revert)
//   completed + Replacement Shipped → replaced (old plate; new plate chained separately)
//   rejected / Replacement Rejected by Company                 → registered (revert via prev_status)
//   cancelled                                                  → registered (revert)
//   closed                                                     → final (no flip — already terminal)
//
// `prev_status` preservation:
//   When transitioning to `claimed`, capture current sn_pool.status into prev_status
//   so rejected/cancelled can revert to the original (almost always `registered`).
//
// Backward compat:
//   Legacy claim_ticket records without a sn_pool counterpart return early
//   with a debug log (no error). serial_code lookup is the join key — falls back
//   to `snapshot_serial_code` ACF field if `serial_code` empty.
// ==============================================================================

add_action( 'dinoco/claim/state_changed', 'dinoco_sn_claim_status_changed', 10, 4 );

if ( ! function_exists( 'dinoco_sn_claim_status_changed' ) ) {
    /**
     * Sync claim_ticket.ticket_status mutations into wp_dinoco_sn_pool.status.
     *
     * @param int    $claim_id  claim_ticket post ID
     * @param string $from_state previous claim status string
     * @param string $to_state   new claim status string
     * @param array  $context    optional metadata from dinoco_set_claim_status()
     * @return void
     */
    function dinoco_sn_claim_status_changed( $claim_id, $from_state, $to_state, $context = array() ) {
        $claim_id = intval( $claim_id );
        if ( $claim_id <= 0 ) return;

        // Guard 1: sn_pool table not deployed yet → silent no-op
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return;
        }

        // Guard 2: master kill switch off → silent no-op
        if ( function_exists( 'dinoco_sn_is_enabled' ) && ! dinoco_sn_is_enabled() ) {
            return;
        }

        // Resolve serial code → sn_pool row
        $sn_code = get_field( 'serial_code', $claim_id );
        if ( empty( $sn_code ) ) {
            $sn_code = get_field( 'snapshot_serial_code', $claim_id );
        }
        $sn_code = is_string( $sn_code ) ? strtoupper( trim( $sn_code ) ) : '';
        if ( $sn_code === '' ) {
            // Legacy claim with no serial → expected, no log
            return;
        }

        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_sn_pool';

        // Resolve target sn_pool.status from claim status
        $mapping = dinoco_sn_map_claim_to_pool_status( $to_state, $claim_id );
        if ( $mapping['action'] === 'no_change' ) {
            // Closed (already terminal) — no plate flip
            return;
        }

        // GET_LOCK + START TRANSACTION for atomic prev_status preservation.
        //
        // V.31.3 C1 FIX: unified lock key 'dnc_sn_{md5}' — was per-action
        // 'dnc_sn_claim_{md5}'. Must match Activation + Manual Transfer
        // lock key so concurrent claim status flip + transfer + activate
        // ops on the same SN serialize correctly. Without unified key,
        // claim FSM flip interleaved with transfer → prev_status corruption
        // (state machine sees unexpected from-state).
        // V.31.4 — unified key + constant timeout from REST API V.0.29
        // V.31.5 R4 BLOCKER #3 — fallback literal 5 → 15 (matches new constant)
        $lock_key = function_exists( 'dinoco_sn_lock_name' )
            ? dinoco_sn_lock_name( $sn_code )
            : 'dnc_sn_' . md5( $sn_code );
        $lock_to  = defined( 'DINOCO_SN_LOCK_TIMEOUT' ) ? (int) DINOCO_SN_LOCK_TIMEOUT : 15;
        $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_key, $lock_to ) );
        if ( ! $got_lock ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[SN-Claim] GET_LOCK timeout sn=%s claim=#%d', $sn_code, $claim_id ) );
            }
            return;
        }

        try {
            $wpdb->query( 'START TRANSACTION' );

            // Read current pool row
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT sn, status, prev_status FROM {$tbl} WHERE sn = %s FOR UPDATE",
                $sn_code
            ) );

            if ( ! $row ) {
                // No sn_pool row — legacy claim, log + abort txn
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( sprintf( '[SN-Claim] No sn_pool row for sn=%s claim=#%d (legacy claim, OK)', $sn_code, $claim_id ) );
                }
                return;
            }

            $old_pool_status = (string) $row->status;
            $new_pool_status = (string) $mapping['target'];

            if ( $old_pool_status === $new_pool_status ) {
                // Idempotent — already in target state
                $wpdb->query( 'COMMIT' );
                return;
            }

            // Preserve prev_status when locking (claimed) so rejected/cancelled can revert
            $prev_to_write = $row->prev_status;
            if ( $new_pool_status === 'claimed' && $old_pool_status !== 'claimed' ) {
                $prev_to_write = $old_pool_status;
            } elseif ( $mapping['action'] === 'revert' ) {
                // For revert flows, fall back to stored prev_status if present, else assume 'registered'
                if ( empty( $row->prev_status ) ) {
                    $new_pool_status = 'registered';
                } else {
                    $new_pool_status = $row->prev_status;
                }
                $prev_to_write = null;
            }

            $update_data = array(
                'status'      => $new_pool_status,
                'prev_status' => $prev_to_write,
            );
            $update_format = array( '%s', '%s' );
            if ( $prev_to_write === null ) {
                $update_data['prev_status'] = null;
                // wpdb does not handle NULL via format — use direct SQL
                $wpdb->query( $wpdb->prepare(
                    "UPDATE {$tbl} SET status = %s, prev_status = NULL, updated_at = %s WHERE sn = %s",
                    $new_pool_status,
                    current_time( 'mysql' ),
                    $sn_code
                ) );
            } else {
                $wpdb->query( $wpdb->prepare(
                    "UPDATE {$tbl} SET status = %s, prev_status = %s, updated_at = %s WHERE sn = %s",
                    $new_pool_status,
                    $prev_to_write,
                    current_time( 'mysql' ),
                    $sn_code
                ) );
            }

            // Audit log — defensive function_exists guard
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log(
                    $sn_code,
                    'claim_status_synced',
                    $old_pool_status,
                    $new_pool_status,
                    array(
                        'claim_id'        => $claim_id,
                        'claim_from'      => (string) $from_state,
                        'claim_to'        => (string) $to_state,
                        'mapping_action'  => $mapping['action'],
                        'context_actor'   => isset( $context['actor'] )  ? (string) $context['actor']  : '',
                        'context_source'  => isset( $context['source'] ) ? (string) $context['source'] : '',
                    ),
                    null,
                    null,
                    sprintf( 'Claim #%d: %s → %s', $claim_id, $from_state, $to_state ),
                    'claim_sync',
                    false
                );
            }

            $wpdb->query( 'COMMIT' );

            // V.31.4 CRIT-3 + F-NEW-1 — fire status_changed AFTER commit so
            // listeners (REST/MCP cache invalidation, Member Dashboard) only
            // see committed state. registered_user_id was selected once via
            // FOR UPDATE; re-fetch a fresh row to expose the user_id for the
            // for_user variant (skipped if no owner present).
            $owner_uid = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT registered_user_id FROM {$tbl} WHERE sn = %s LIMIT 1",
                $sn_code
            ) );
            if ( function_exists( 'dinoco_sn_fire_status_changed' ) ) {
                dinoco_sn_fire_status_changed( $sn_code, $old_pool_status, $new_pool_status, $owner_uid );
            } else {
                do_action( 'dinoco_sn_pool_status_changed', $sn_code, $old_pool_status, $new_pool_status );
                if ( $owner_uid > 0 ) {
                    do_action( 'dinoco_sn_pool_status_changed_for_user', $owner_uid, $sn_code, $old_pool_status, $new_pool_status );
                }
            }

            // Replacement flow scaffold (Phase 3 will allocate new plate via UI):
            // when status flipped to `replaced`, set ACF flag for admin banner.
            if ( $new_pool_status === 'replaced' ) {
                update_post_meta( $claim_id, '_sn_replacement_pending', '1' );
            }

            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf(
                    '[SN-Claim] sn=%s claim=#%d pool: %s → %s (action=%s)',
                    $sn_code, $claim_id, $old_pool_status, $new_pool_status, $mapping['action']
                ) );
            }

        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture_exception( $e, array( 'context' => 'sn_claim_status_sync', 'claim_id' => $claim_id, 'sn' => $sn_code ) );
            }
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( sprintf( '[SN-Claim] EXCEPTION sn=%s claim=#%d: %s', $sn_code, $claim_id, $e->getMessage() ) );
            }
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_map_claim_to_pool_status' ) ) {
    /**
     * Map 11-status claim_ticket FSM → sn_pool.status flip directive.
     *
     * Pure logic — easily unit-testable without DB.
     *
     * @param string $claim_status  Target claim_ticket.ticket_status
     * @param int    $claim_id      Optional — used to detect replacement flow via meta
     * @return array { action: 'lock'|'revert'|'replace'|'no_change', target: string }
     */
    function dinoco_sn_map_claim_to_pool_status( $claim_status, $claim_id = 0 ) {
        $cs = is_string( $claim_status ) ? trim( $claim_status ) : '';

        // Closed = terminal, plate already in final state
        if ( $cs === 'closed' || $cs === 'Closed' ) {
            return array( 'action' => 'no_change', 'target' => '' );
        }

        // Rejected / Replacement Rejected by Company / Cancelled → revert plate
        if ( in_array( $cs, array(
            'rejected', 'Rejected',
            'Replacement Rejected by Company',
            'cancelled', 'Cancelled',
        ), true ) ) {
            return array( 'action' => 'revert', 'target' => 'registered' );
        }

        // Completed flows: depends on claim_condition / replacement flag
        if ( in_array( $cs, array(
            'completed', 'Completed',
            'Repaired Item Dispatched',
            'Maintenance Completed',
        ), true ) ) {
            // Repair return → plate registered (same plate back to customer)
            if ( $claim_id > 0 ) {
                $replacement_sent = get_post_meta( $claim_id, '_b2b_replacement_sent', true );
                if ( $replacement_sent === '1' ) {
                    return array( 'action' => 'replace', 'target' => 'replaced' );
                }
            }
            return array( 'action' => 'revert', 'target' => 'registered' );
        }

        if ( $cs === 'Replacement Shipped' ) {
            return array( 'action' => 'replace', 'target' => 'replaced' );
        }

        // All other in-flight statuses → lock plate as `claimed`
        $in_flight = array(
            'pending', 'Pending',
            'reviewing', 'Reviewing',
            'approved', 'Approved',
            'in_progress', 'In Progress',
            'waiting_parts', 'Waiting Parts',
            'repairing', 'Repairing',
            'quality_check', 'Quality Check',
            'Registered in System',
            'Pending Issue Verification',
            'Awaiting Customer Shipment',
            'In Transit to Company',
            'Received at Company',
            'Under Maintenance',
            'Replacement Approved',
        );
        if ( in_array( $cs, $in_flight, true ) ) {
            return array( 'action' => 'lock', 'target' => 'claimed' );
        }

        // Unknown → defensive no-op
        return array( 'action' => 'no_change', 'target' => '' );
    }
}

