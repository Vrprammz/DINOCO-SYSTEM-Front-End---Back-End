        async function submitCloseJob() {
            let w_status = $('#inp-close-wstatus').val();

            if(!w_status) {
                await _scAlert('กรุณาเลือกสถานะประกันหลังซ่อม', 'warning');
                return;
            }

            let logs = [];
            $('input[name="repair_logs_cb[]"]:checked').each(function(){
                logs.push($(this).val());
            });

            if(logs.length === 0) {
                var ok = await _scCfm('คุณไม่ได้เลือกรายการซ่อมเลย\n\nยืนยันที่จะปิดงานหรือไม่?', {title:'ปิดงานไม่มี log', confirmText:'ปิดงาน'});
                if(!ok) return;
