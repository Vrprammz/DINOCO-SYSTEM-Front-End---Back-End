            }).fail(function(xhr) {
                var data = xhr && xhr.responseJSON;
                _scAlert((data && data.message) || ('โหลด tracking ล้มเหลว (HTTP ' + (xhr ? xhr.status : '?') + ')'), 'error');
            });
        }

        /* ────────────────────────────────────────────────────────────────
         * V.34.6 Sprint 29 Phase 4 Batch B Item 2 — Refund Audit Dashboard.
         * Reads GET /wp-json/dinoco-claim/v1/refund-audit. Filter chips +
         * date range + approver/requester UID + pagination 50/page.
         * ──────────────────────────────────────────────────────────────── */
        var _raCurrentTid = 0;
        var _raCurrentState = '';
        var _raCurrentPage = 1;
        var _raPerPage = 50;
        var _raLastFilters = {};

        var _raStateLabel = {
            pending:  '⏳ Pending',
            consumed: '✅ Consumed',
            expired:  '⌛ Expired'
        };

        function scLoadRefundAudit(tid) {
            var $section = $('#sc-refund-audit-section');
            if (!$section.length || $section.attr('data-enabled') !== '1') return;
            _raCurrentTid = parseInt(tid, 10) || 0;
            _raCurrentPage = 1;
            _raCurrentState = '';
            _raLastFilters = {};
            $('#dnc-ra-state-chips .dnc-ra-chip').removeClass('dnc-ra-chip-active').attr('aria-selected', 'false');
            $('#dnc-ra-state-chips .dnc-ra-chip[data-state=""]').addClass('dnc-ra-chip-active').attr('aria-selected', 'true');
            $('#dnc-ra-from').val('');
            $('#dnc-ra-to').val('');
            $('#dnc-ra-approver').val('');
            $('#dnc-ra-requester').val('');
            _raFetch();
        }

        function _raReadFilters() {
            var f = {
                state:     _raCurrentState || '',
                from:      ($('#dnc-ra-from').val() || '').trim(),
                to:        ($('#dnc-ra-to').val() || '').trim(),
                approver:  parseInt($('#dnc-ra-approver').val(), 10) || 0,
                requester: parseInt($('#dnc-ra-requester').val(), 10) || 0
            };
            _raLastFilters = f;
            return f;
        }

        function _raFetch() {
            var f = _raReadFilters();
            $('#dnc-ra-list-panel').html('<div class="text-center py-6 text-slate-400 text-xs"><i class="fa-solid fa-spinner fa-spin mr-1"></i> กำลังโหลด...</div>');
            $('#dnc-ra-count').text('—');
            var params = { page: _raCurrentPage, per_page: _raPerPage };
            if (f.state)     params.status    = f.state;
            if (f.from)      params.from      = f.from;
            if (f.to)        params.to        = f.to;
            if (f.approver)  params.approver  = f.approver;
            if (f.requester) params.requester = f.requester;
            $.ajax({
                url: '/wp-json/dinoco-claim/v1/refund-audit',
                method: 'GET',
                data: params,
                beforeSend: function(xhr) {
                    xhr.setRequestHeader('X-WP-Nonce', (window.wpApiSettings && window.wpApiSettings.nonce) || '');
                }
            }).done(function(res) {
                var items = (res && res.items) || [];
                var meta = (res && res.meta) || { total: 0, page: 1, per_page: _raPerPage, pages: 1 };
                $('#dnc-ra-count').text(meta.total + ' รายการ');
                _raRenderList(items);
                _raRenderPagination(meta);
            }).fail(function(xhr) {
                var msg = (xhr && xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'โหลด refund audit ล้มเหลว';
                $('#dnc-ra-list-panel').html('<div class="dnc-ra-empty">' + escHtml(msg) + '</div>');
                $('#dnc-ra-count').text('error');
                $('#dnc-ra-pagination').addClass('hidden');
            });
        }

        function _raRenderList(items) {
            if (!items || items.length === 0) {
                $('#dnc-ra-list-panel').html('<div class="dnc-ra-empty">ไม่พบ refund audit ตามเงื่อนไข</div>');
                return;
            }
            var rows = items.map(function(it) {
                var state = String(it.state || '');
                var stateLabel = _raStateLabel[state] || state;
                var reason = String(it.reason || '');
                var reasonShort = reason.length > 60 ? reason.substring(0, 60) + '…' : reason;
                return ''
                    + '<div class="dnc-ra-row" data-charge-id="' + escHtml(it.charge_id) + '">'
                    +   '<span class="dnc-ra-charge-id">#' + escHtml(it.charge_id) + '</span>'
                    +   '<div>'
                    +     '<div><span class="dnc-ra-token" title="consent_token (masked first 8 chars)">' + escHtml(it.consent_token) + '</span>'
                    +       (reasonShort ? ' <span class="dnc-ra-meta">· ' + escHtml(reasonShort) + '</span>' : '')
                    +     '</div>'
                    +     '<div class="dnc-ra-meta">'
                    +       'Req: ' + escHtml(it.requester || '—')
                    +       ' · Appr: ' + escHtml(it.approver || '—')
                    +       (it.executor ? ' · Exec: ' + escHtml(it.executor) : '')
                    +     '</div>'
                    +     '<div class="dnc-ra-meta">'
                    +       'สร้าง: ' + escHtml(_cfFmtDate(it.created_at))
                    +       (it.executed_at ? ' · คืนเงิน: ' + escHtml(_cfFmtDate(it.executed_at)) : '')
                    +     '</div>'
                    +   '</div>'
                    +   '<span class="dnc-ra-amount">฿' + escHtml(it.amount_thb) + '</span>'
                    +   '<span class="dnc-ra-state-badge dnc-ra-state-' + escHtml(state) + '">' + escHtml(stateLabel) + '</span>'
                    +   '<span class="dnc-ra-meta">claim #' + escHtml(it.claim_id) + '</span>'
                    + '</div>';
            }).join('');
            $('#dnc-ra-list-panel').html(rows);
        }

        function _raRenderPagination(meta) {
            var pages = parseInt(meta.pages, 10) || 1;
            var page  = parseInt(meta.page, 10) || 1;
            if (pages <= 1) {
                $('#dnc-ra-pagination').addClass('hidden');
                return;
            }
            $('#dnc-ra-page-info').text('หน้า ' + page + ' / ' + pages);
            $('#dnc-ra-pagination [data-action="dnc-ra-prev"]').prop('disabled', page <= 1);
            $('#dnc-ra-pagination [data-action="dnc-ra-next"]').prop('disabled', page >= pages);
            $('#dnc-ra-pagination').removeClass('hidden');
        }

        // Filter chip handler
        $(document).on('click', '[data-action="dnc-ra-pick-state"]', function() {
            var state = $(this).attr('data-state') || '';
            $('#dnc-ra-state-chips .dnc-ra-chip').removeClass('dnc-ra-chip-active').attr('aria-selected', 'false');
            $(this).addClass('dnc-ra-chip-active').attr('aria-selected', 'true');
            _raCurrentState = state;
            _raCurrentPage = 1;
            _raFetch();
        });

        $(document).on('click', '[data-action="dnc-ra-apply"]', function(e) {
            e.preventDefault();
            _raCurrentPage = 1;
            _raFetch();
        });
        $(document).on('click', '[data-action="dnc-ra-reset"]', function(e) {
            e.preventDefault();
            $('#dnc-ra-from').val('');
            $('#dnc-ra-to').val('');
            $('#dnc-ra-approver').val('');
            $('#dnc-ra-requester').val('');
            _raCurrentState = '';
            $('#dnc-ra-state-chips .dnc-ra-chip').removeClass('dnc-ra-chip-active').attr('aria-selected', 'false');
            $('#dnc-ra-state-chips .dnc-ra-chip[data-state=""]').addClass('dnc-ra-chip-active').attr('aria-selected', 'true');
            _raCurrentPage = 1;
            _raFetch();
        });
        $(document).on('click', '[data-action="dnc-ra-prev"]', function(e) {
            e.preventDefault();
            if (_raCurrentPage > 1) { _raCurrentPage--; _raFetch(); }
        });
        $(document).on('click', '[data-action="dnc-ra-next"]', function(e) {
            e.preventDefault();
            _raCurrentPage++;
            _raFetch();
        });

        $(document).ready(function() {
            loadList('all');
            $(document).on('click', '.js-manage-trigger', function(e) {
                e.preventDefault();
                e.stopPropagation();
                DINOCO.openManage($(this).data('id'));
            });
            $(document).on('click', '.js-close-modal', function() {
                $('#manage-modal').removeClass('active-flex').addClass('hidden');
            });
        });

        return {
            loadList,
            filter: loadList,
            filterPipeline,
            openManage,
            openShip,
            quickPrint,
            update,
            updateInline,
            saveNote,
            saveTracking,
            selectStatus,
            saveStatusChange,
            submitReturn,
            showReturnForm,
            deleteTicket,
            toggleExpand,
            showApprovalForm,
            addCustomPart,
            saveApproval,
            printTicket,
            refreshDashboard, // Exported
            // ADDED MISSING EXPORTS
            showCloseJobForm,
            submitCloseJob,
            // V.32.0 Sprint 8 — Phase 1 Task 1.5 Claim Notifications Log
            loadNotifLog,
            resendNotif,
            // V.34.0 Sprint 17 — Claim Charges (Phase 2.6)
            scLoadCharges,
            scOpenCreateCharge,
            // V.34.4 Sprint 28 — Claim Flash Shipments (Phase 3.3)
            scLoadFlashList,
            scOpenCreateFlash,
            // V.34.6 Sprint 29 Phase 4 Batch B Item 2 — Refund Audit Dashboard
            scLoadRefundAudit
        };
    })(jQuery);
    
    window.loadClaims = DINOCO.loadList;

    // Auto-refresh: reload claims every 30s when global toggle is ON
    // Managed by Admin Dashboard's setInterval override (blocks when OFF)
    setInterval(function(){ DINOCO.refreshDashboard(); DINOCO.loadList('all'); }, 30000);
    </script>
