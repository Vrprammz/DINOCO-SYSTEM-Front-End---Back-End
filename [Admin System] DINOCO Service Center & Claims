        // Live comma formatting on amount input (only allow digits + 1 dot)
        $(document).on('input', '#dnc-cc-amount', function() {
            var v = ($(this).val() || '').toString().replace(/[^\d.]/g, '');
            var parts = v.split('.');
            if (parts.length > 2) v = parts[0] + '.' + parts.slice(1).join('');
            // Comma format integer part
            var dot = v.indexOf('.');
            var intPart = dot === -1 ? v : v.substring(0, dot);
            var decPart = dot === -1 ? '' : v.substring(dot);
            if (intPart.length > 1) intPart = intPart.replace(/^0+/, '') || '0';
            intPart = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            $(this).val(intPart + decPart);
