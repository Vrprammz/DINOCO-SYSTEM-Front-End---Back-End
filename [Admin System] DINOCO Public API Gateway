/* ═══════════════════════════════════════════════════════════════════════════
 * 4. ADMIN TOKEN MANAGEMENT (separate namespace, WP nonce)
 * ═══════════════════════════════════════════════════════════════════════════ */

add_action( 'rest_api_init', function() {
    $ns = 'dinoco-sn/v1';

    // POST /api-tokens — issue new token (admin)
    register_rest_route( $ns, '/api-tokens', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_sn_pubapi_admin_issue',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
        'args'                => array(
            'partner_name'       => array( 'required' => true, 'type' => 'string' ),
            'partner_type'       => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_key' ),
            'scopes'             => array( 'type' => 'array' ),
            'rate_limit_per_min' => array( 'type' => 'integer' ),
            'ip_allowlist'       => array( 'type' => 'string' ),
            'expires_at'         => array( 'type' => 'string' ),
        ),
    ) );

    // GET /api-tokens — list tokens (admin)
    register_rest_route( $ns, '/api-tokens', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_sn_pubapi_admin_list',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
    ) );

    // POST /api-tokens/{id}/disable — disable token (soft kill)
    register_rest_route( $ns, '/api-tokens/(?P<id>\d+)/disable', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_sn_pubapi_admin_disable',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
        'args'                => array(
            'id' => array( 'required' => true, 'type' => 'integer' ),
        ),
    ) );
} );

if ( ! function_exists( 'dinoco_sn_pubapi_admin_issue' ) ) {
    function dinoco_sn_pubapi_admin_issue( $request ) {
        $result = dinoco_sn_pubapi_issue_token( array(
            'partner_name'       => $request->get_param( 'partner_name' ),
            'partner_type'       => $request->get_param( 'partner_type' ),
            'scopes'             => $request->get_param( 'scopes' ),
            'rate_limit_per_min' => $request->get_param( 'rate_limit_per_min' ),
            'ip_allowlist'       => $request->get_param( 'ip_allowlist' ),
            'expires_at'         => $request->get_param( 'expires_at' ),
        ) );
        if ( is_wp_error( $result ) ) return $result;
        return rest_ensure_response( array_merge( $result, array(
            'note' => 'api_secret shown ONCE — save it now, cannot retrieve later',
        ) ) );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_admin_list' ) ) {
    function dinoco_sn_pubapi_admin_list( $request ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_tokens' ) ) {
            return rest_ensure_response( array( 'rows' => array() ) );
        }
        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_tokens' );
        $rows = $wpdb->get_results(
            "SELECT id, partner_name, partner_type, api_key, scopes,
                    rate_limit_per_min, ip_allowlist, is_active, expires_at,
                    last_used_at, created_at
             FROM {$tbl}
             ORDER BY created_at DESC
             LIMIT 200",
            ARRAY_A
        );
        $rows = array_map( function( $r ) {
            $r['scopes'] = json_decode( (string) $r['scopes'], true ) ?: array();
            $r['is_active'] = (bool) $r['is_active'];
            // NEVER include api_secret_hash in response
            return $r;
        }, $rows ?: array() );
        return rest_ensure_response( array( 'rows' => $rows ) );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_admin_disable' ) ) {
    function dinoco_sn_pubapi_admin_disable( $request ) {
        $id = (int) $request->get_param( 'id' );
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_tokens' ) ) {
            return new WP_Error( 'schema_not_ready', '', array( 'status' => 503 ) );
        }
        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_tokens' );
        $upd = $wpdb->update( $tbl, array( 'is_active' => 0 ), array( 'id' => $id ) );
        if ( $upd === false ) {
            return new WP_Error( 'update_failed', '', array( 'status' => 500 ) );
        }
        return rest_ensure_response( array( 'success' => true, 'id' => $id, 'is_active' => false ) );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 5. CLEANUP CRON (90-day api_log retention per v2.13 §F.15)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_pubapi_run_log_cleanup' ) ) {
    function dinoco_sn_pubapi_run_log_cleanup() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_log' ) ) return;

        try {
            global $wpdb;
            $tbl = dinoco_sn_pubapi_table( 'api_log' );
            $cutoff = gmdate( 'Y-m-d H:i:s', time() - 90 * 86400 );

            $deleted = 0;
            // Chunked DELETE (max 5000 rows per cron tick)
            for ( $i = 0; $i < 10; $i++ ) {
                $batch = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl} WHERE created_at < %s LIMIT 500",
                    $cutoff
                ) );
                if ( $batch === 0 ) break;
                $deleted += (int) $batch;
                usleep( 50000 );
            }

            update_option( 'dinoco_sn_pubapi_log_cleanup_last_run', array(
                'at'      => current_time( 'mysql' ),
                'deleted' => $deleted,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture_exception( $e, array( 'context' => 'sn_pubapi_log_cleanup' ) );
            }
        }
        update_option( 'dinoco_cron_sn_pubapi_log_cleanup_last_run', current_time( 'mysql' ) );
    }
}

add_action( 'init', function() {
    if ( ! wp_next_scheduled( 'dinoco_sn_pubapi_log_cleanup_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_sn_pubapi_log_cleanup_cron' );
    }
    if ( function_exists( 'dinoco_register_cron' ) ) {
        dinoco_register_cron( 'dinoco_sn_pubapi_log_cleanup_cron', 'daily', 'dinoco_sn_pubapi_run_log_cleanup' );
    } elseif ( ! has_action( 'dinoco_sn_pubapi_log_cleanup_cron', 'dinoco_sn_pubapi_run_log_cleanup' ) ) {
        add_action( 'dinoco_sn_pubapi_log_cleanup_cron', 'dinoco_sn_pubapi_run_log_cleanup' );
    }
} );
