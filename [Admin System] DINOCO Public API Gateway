if ( ! function_exists( 'dinoco_sn_pubapi_perm_factory' ) ) {
    /**
     * Returns permission_callback verifying token + scope + rate limit + log.
     */
    function dinoco_sn_pubapi_perm_factory( $required_scope ) {
        return function( $request ) use ( $required_scope ) {
            $auth = dinoco_sn_pubapi_verify_request( $request, $required_scope );
            if ( is_wp_error( $auth ) ) {
                return $auth;
            }
            // Stash token info on request for handler to log
            $request->set_param( '_pubapi_token_id', $auth['token_id'] );
            $request->set_param( '_pubapi_token_info', $auth );

            // Rate limit
            if ( ! dinoco_sn_pubapi_check_rate_limit( $auth['token_id'], $auth['rate_limit'] ) ) {
                return new WP_Error( 'rate_limit_exceeded',
                    sprintf( __( 'Rate limit %d/min exceeded.', 'dinoco-sn' ), $auth['rate_limit'] ),
                    array( 'status' => 429 ) );
            }
            return true;
        };
    }
}

