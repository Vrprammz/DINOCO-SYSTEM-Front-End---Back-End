} );

if ( ! function_exists( 'dinoco_sn_pubapi_handle_verify' ) ) {
    function dinoco_sn_pubapi_handle_verify( $request ) {
        $start_ms = microtime( true ) * 1000;
        $sn = strtoupper( trim( (string) $request->get_param( 'sn' ) ) );
        $token_id = (int) $request->get_param( '_pubapi_token_id' );

        $resp = array(
            'sn'    => $sn,
            'valid' => false,
        );
        $status = 200;

        if ( $sn === '' ) {
            $resp['error'] = 'sn required';
            $status = 400;
        } elseif ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            $resp['error'] = 'schema not ready';
            $status = 503;
        } else {
            global $wpdb;
            $pool = dinoco_sn_pubapi_table( 'pool' );
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT status FROM {$pool} WHERE sn = %s LIMIT 1", $sn
            ), ARRAY_A );

            if ( $row ) {
                $valid_states = array( 'registered', 'claimed', 'shipped', 'allocated_to_order' );
                $resp['valid'] = in_array( $row['status'], $valid_states, true );
                $resp['public_status'] = $resp['valid'] ? 'active' : 'invalid';
            } else {
                $resp['public_status'] = 'unknown';
            }
        }

        $duration = (int) ( microtime( true ) * 1000 - $start_ms );
        dinoco_sn_pubapi_log_request( $token_id, 'verify', $status, $duration, 'sn=' . $sn );
        return new WP_REST_Response( $resp, $status );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_handle_claim_status' ) ) {
    function dinoco_sn_pubapi_handle_claim_status( $request ) {
        $start_ms = microtime( true ) * 1000;
        $sn = strtoupper( trim( (string) $request->get_param( 'sn' ) ) );
        $token_id = (int) $request->get_param( '_pubapi_token_id' );

        $resp = array(
            'sn'           => $sn,
            'has_claim'    => false,
            'claim_status' => null,
        );
        $status = 200;

        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            $resp['error'] = 'schema not ready';
            $status = 503;
        } else {
            global $wpdb;
            $pool = dinoco_sn_pubapi_table( 'pool' );
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT status, claim_id FROM {$pool} WHERE sn = %s LIMIT 1", $sn
            ), ARRAY_A );

            if ( $row && in_array( $row['status'], array( 'claimed', 'replaced' ), true ) ) {
                $resp['has_claim'] = true;
                $resp['claim_status'] = $row['status'] === 'replaced' ? 'completed' : 'in_progress';
            }
        }

        $duration = (int) ( microtime( true ) * 1000 - $start_ms );
        dinoco_sn_pubapi_log_request( $token_id, 'claim-status', $status, $duration, 'sn=' . $sn );
        return new WP_REST_Response( $resp, $status );
    }
}

