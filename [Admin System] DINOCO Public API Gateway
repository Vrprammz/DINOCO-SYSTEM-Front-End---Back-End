if ( ! function_exists( 'dinoco_sn_pubapi_master_key' ) ) {
    /**
     * Master encryption key for AES-256-GCM. Auto-generated on first use,
     * stored in wp_options. Operator can override via constant
     * DINOCO_SN_PUBAPI_MASTER_KEY (recommended for production).
     *
     * Returns 32-byte binary key.
     */
    function dinoco_sn_pubapi_master_key() {
        if ( defined( 'DINOCO_SN_PUBAPI_MASTER_KEY' ) ) {
            $hex = DINOCO_SN_PUBAPI_MASTER_KEY;
            if ( ctype_xdigit( $hex ) && strlen( $hex ) === 64 ) {
                return hex2bin( $hex );
            }
        }
        $stored = get_option( 'dinoco_sn_pubapi_master_key_hex', '' );
        if ( ! $stored || strlen( $stored ) !== 64 ) {
            $key   = random_bytes( 32 );
            $stored = bin2hex( $key );
            update_option( 'dinoco_sn_pubapi_master_key_hex', $stored, false );
            return $key;
        }
        return hex2bin( $stored );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_encrypt' ) ) {
    /**
     * AES-256-GCM authenticated encryption.
     * Output: base64( iv (12) || ciphertext || tag (16) )
     * Returns null on encryption failure.
     */
    function dinoco_sn_pubapi_encrypt( $plaintext ) {
        if ( ! function_exists( 'openssl_encrypt' ) ) return null;
        $key = dinoco_sn_pubapi_master_key();
        if ( ! $key ) return null;
        $iv  = random_bytes( 12 );
        $tag = '';
        $ct  = openssl_encrypt(
            (string) $plaintext, 'aes-256-gcm', $key,
            OPENSSL_RAW_DATA, $iv, $tag, '', 16
        );
        if ( $ct === false ) return null;
        return base64_encode( $iv . $ct . $tag );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_decrypt' ) ) {
    /**
     * Reverse of encrypt(). Returns plaintext or null on failure
     * (auth tag mismatch / corrupt input / missing openssl).
     */
    function dinoco_sn_pubapi_decrypt( $blob ) {
        if ( ! function_exists( 'openssl_decrypt' ) ) return null;
        $key = dinoco_sn_pubapi_master_key();
        if ( ! $key ) return null;
        $raw = base64_decode( (string) $blob, true );
        if ( $raw === false || strlen( $raw ) < 28 ) return null;
        $iv  = substr( $raw, 0, 12 );
        $tag = substr( $raw, -16 );
        $ct  = substr( $raw, 12, -16 );
        $pt = openssl_decrypt(
            $ct, 'aes-256-gcm', $key,
            OPENSSL_RAW_DATA, $iv, $tag, ''
        );
        return ( $pt === false ) ? null : $pt;
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_compute_hmac' ) ) {
    /**
     * Compute the canonical HMAC signature.
     *
     * Format signed: timestamp + "\n" + body
     * Output: HMAC-SHA256 hex (lowercase)
     *
     * Client + server MUST agree on this format. Document in
     * docs/api/openapi.yaml snApiKey securityScheme.
     */
    function dinoco_sn_pubapi_compute_hmac( $secret, $timestamp, $body ) {
        $payload = (string) $timestamp . "\n" . (string) $body;
        return hash_hmac( 'sha256', $payload, (string) $secret );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_ensure_secret_column' ) ) {
    /**
     * Lazy ALTER TABLE: ensure api_secret_encrypted column exists. Idempotent.
     * Tokens issued before V.0.2 will have NULL — verify path returns
     * 'legacy_token_no_hmac' so admin can rotate.
     */
    function dinoco_sn_pubapi_ensure_secret_column() {
        static $checked = false;
        if ( $checked ) return;
        $checked = true;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'api_tokens' ) ) return;
        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_tokens' );
        $col = $wpdb->get_var( $wpdb->prepare(
            "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS
             WHERE TABLE_SCHEMA = DATABASE()
               AND TABLE_NAME = %s
               AND COLUMN_NAME = %s",
            $tbl, 'api_secret_encrypted'
        ) );
        if ( ! $col ) {
            $wpdb->query( "ALTER TABLE {$tbl} ADD COLUMN api_secret_encrypted TEXT NULL AFTER api_secret_hash" );
        }
    }
}
add_action( 'admin_init', 'dinoco_sn_pubapi_ensure_secret_column' );

if ( ! function_exists( 'dinoco_sn_pubapi_issue_token' ) ) {
    /**
     * Generate new API token + secret pair. Returns plaintext secret ONCE
     * (for admin to display to partner). Hash stored in DB.
     *
     * Scopes: array of strings — verify, claim_status, stolen_check, full
     */
    function dinoco_sn_pubapi_issue_token( array $args ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_tokens' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'api_tokens table not installed.', 'dinoco-sn' ) );
        }

        $partner_name = trim( (string) ( $args['partner_name'] ?? '' ) );
        $partner_type = sanitize_key( (string) ( $args['partner_type'] ?? 'other' ) );
        $scopes       = (array) ( $args['scopes'] ?? array( 'verify' ) );
        $rate_limit   = (int) ( $args['rate_limit_per_min'] ?? 30 );
        $ip_allowlist = (string) ( $args['ip_allowlist'] ?? '' );
        $expires_at   = (string) ( $args['expires_at'] ?? '' );

        if ( $partner_name === '' || mb_strlen( $partner_name ) > 128 ) {
            return new WP_Error( 'invalid_input', __( 'partner_name 1-128 chars required.', 'dinoco-sn' ) );
        }
        $allowed_types = array( 'dealer', 'insurance', 'government', 'other' );
        if ( ! in_array( $partner_type, $allowed_types, true ) ) {
            $partner_type = 'other';
        }

        $allowed_scopes = array( 'verify', 'claim_status', 'stolen_check', 'full' );
        $clean_scopes   = array_values( array_filter( $scopes, function( $s ) use ( $allowed_scopes ) {
            return in_array( $s, $allowed_scopes, true );
        } ) );
        if ( ! $clean_scopes ) $clean_scopes = array( 'verify' );

        // Ensure encrypted column exists (lazy migrate for V.0.2 upgrade path)
        dinoco_sn_pubapi_ensure_secret_column();

        // Generate secure random key + secret
        $api_key = 'pk_' . bin2hex( random_bytes( 16 ) );    // 35 chars total
        $api_secret = 'sk_' . bin2hex( random_bytes( 24 ) ); // 51 chars total

        // Dual-store: bcrypt hash (audit/lookup integrity) + AES-GCM encrypted
        // (HMAC verify needs raw secret). Encrypted may be null if openssl
        // missing — issue_token will refuse rather than degrade silently.
        $api_secret_hash      = wp_hash_password( $api_secret );
        $api_secret_encrypted = dinoco_sn_pubapi_encrypt( $api_secret );
        if ( $api_secret_encrypted === null ) {
            return new WP_Error( 'crypto_unavailable',
                __( 'AES-256-GCM (openssl) unavailable on this server. Cannot issue HMAC-verifiable token.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_tokens' );

        $ok = $wpdb->insert( $tbl, array(
            'partner_name'         => $partner_name,
            'partner_type'         => $partner_type,
            'api_key'              => $api_key,
            'api_secret_hash'      => $api_secret_hash,
            'api_secret_encrypted' => $api_secret_encrypted,
            'scopes'               => wp_json_encode( $clean_scopes ),
            'rate_limit_per_min'   => max( 1, min( 1000, $rate_limit ) ),
            'ip_allowlist'         => $ip_allowlist ?: null,
            'is_active'            => 1,
            'expires_at'           => $expires_at ?: null,
            'created_at'           => current_time( 'mysql' ),
            'created_by'           => (int) get_current_user_id(),
        ) );

        if ( ! $ok ) {
            return new WP_Error( 'insert_failed', __( 'Token insert failed.', 'dinoco-sn' ) );
        }

        return array(
            'id'          => (int) $wpdb->insert_id,
            'api_key'     => $api_key,
            'api_secret'  => $api_secret,  // shown ONCE — caller must save
            'scopes'      => $clean_scopes,
            'partner_name' => $partner_name,
            'partner_type' => $partner_type,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_verify_request' ) ) {
    /**
     * Verify incoming public API request.
     *
     * Headers required:
     *   X-API-Key      — token api_key
     *   X-API-Sig      — HMAC-SHA256(secret, body) hex
     *   X-API-Timestamp — Unix timestamp (5-min skew tolerance)
     *
     * Returns array on success or WP_Error.
     */
    function dinoco_sn_pubapi_verify_request( $request, $required_scope = 'verify' ) {
        // Q22 OVERRIDE (2026-05-05): F#15 deferred — boss "ยังไม่มีแผนใช้"
        // Flag-gate ALL public endpoint dispatch. Set wp_option to '1' to activate.
        if ( ! (bool) get_option( 'dinoco_sn_pubapi_enabled', '0' ) ) {
            return new WP_Error( 'feature_disabled',
                __( 'Public API gateway is not enabled. Contact admin.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $api_key = $request->get_header( 'x_api_key' );
        $sig     = $request->get_header( 'x_api_sig' );
        $ts      = (int) $request->get_header( 'x_api_timestamp' );

        if ( empty( $api_key ) || empty( $sig ) ) {
            return new WP_Error( 'missing_auth_headers',
                __( 'Missing X-API-Key or X-API-Sig.', 'dinoco-sn' ),
                array( 'status' => 401 ) );
        }

        // 5-minute skew tolerance to prevent replay attacks
        if ( $ts > 0 && abs( time() - $ts ) > 300 ) {
            return new WP_Error( 'timestamp_skew',
                __( 'Request timestamp out of acceptable window.', 'dinoco-sn' ),
                array( 'status' => 401 ) );
        }

        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_tokens' ) ) {
            return new WP_Error( 'schema_not_ready', '', array( 'status' => 503 ) );
        }

        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_tokens' );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, partner_name, partner_type, api_secret_hash, api_secret_encrypted, scopes,
                    rate_limit_per_min, ip_allowlist, is_active, expires_at
             FROM {$tbl}
             WHERE api_key = %s LIMIT 1",
            $api_key
        ), ARRAY_A );

        if ( ! $row ) {
            return new WP_Error( 'invalid_key',
                __( 'API key not found.', 'dinoco-sn' ),
                array( 'status' => 401 ) );
        }
        if ( ! (int) $row['is_active'] ) {
            return new WP_Error( 'token_disabled',
                __( 'API key disabled.', 'dinoco-sn' ),
                array( 'status' => 403 ) );
        }
        if ( ! empty( $row['expires_at'] ) && strtotime( $row['expires_at'] ) < time() ) {
            return new WP_Error( 'token_expired',
                __( 'API key expired.', 'dinoco-sn' ),
                array( 'status' => 401 ) );
        }

        // IP allowlist check
        if ( ! empty( $row['ip_allowlist'] ) ) {
            $client_ip = $_SERVER['REMOTE_ADDR'] ?? '';
            $allowed = array_filter( array_map( 'trim', preg_split( '/[\s,]+/', $row['ip_allowlist'] ) ) );
            if ( $allowed && ! in_array( $client_ip, $allowed, true ) ) {
                return new WP_Error( 'ip_not_allowed',
                    __( 'IP not in allowlist.', 'dinoco-sn' ),
                    array( 'status' => 403 ) );
            }
        }

        // Scope check
        $scopes = json_decode( (string) $row['scopes'], true ) ?: array();
        if ( ! in_array( $required_scope, $scopes, true ) && ! in_array( 'full', $scopes, true ) ) {
            return new WP_Error( 'scope_denied',
                sprintf( __( 'Required scope: %s.', 'dinoco-sn' ), $required_scope ),
                array( 'status' => 403 ) );
        }

        // Phase 4 W12.5 (V.0.2) — Real HMAC verify with AES-256-GCM stored secret.
        //
        // Token lifecycle:
        //   pre-V.0.2: api_secret_encrypted = NULL → 'legacy_token_no_hmac' →
        //     admin must rotate token (issue new one, revoke old).
        //   V.0.2+:    decrypt → recompute HMAC-SHA256(secret, ts + "\n" + body)
        //     → hash_equals (constant-time compare) for timing-attack defense.
        //
        // Body: read raw POST body via file_get_contents('php://input') BEFORE
        // any json_decode side effects. WP_REST_Request->get_body() also works
        // and is the recommended path here.

        if ( empty( $row['api_secret_encrypted'] ) ) {
            return new WP_Error( 'legacy_token_no_hmac',
                __( 'Token created before HMAC support. Admin must rotate.', 'dinoco-sn' ),
                array( 'status' => 401 ) );
        }

        $secret = dinoco_sn_pubapi_decrypt( $row['api_secret_encrypted'] );
        if ( $secret === null ) {
            // Decrypt failed — corrupt blob OR master_key changed
            return new WP_Error( 'crypto_decrypt_failed',
                __( 'Cannot decrypt stored secret — admin must rotate token.', 'dinoco-sn' ),
                array( 'status' => 500 ) );
        }

        $body = (string) $request->get_body();
        $expected = dinoco_sn_pubapi_compute_hmac( $secret, $ts, $body );

        // Constant-time compare prevents byte-by-byte timing attack
        if ( ! hash_equals( $expected, (string) $sig ) ) {
            // Defensive — wipe secret from memory before throwing
            $secret = str_repeat( "\0", strlen( $secret ) );
            unset( $secret );
            return new WP_Error( 'hmac_invalid',
                __( 'HMAC signature mismatch.', 'dinoco-sn' ),
                array( 'status' => 401 ) );
        }

        // Wipe secret from PHP memory (best-effort — GC will collect later)
        $secret = str_repeat( "\0", strlen( $secret ) );
        unset( $secret );

        return array(
            'token_id'      => (int) $row['id'],
            'partner_name'  => $row['partner_name'],
            'partner_type'  => $row['partner_type'],
            'rate_limit'    => (int) $row['rate_limit_per_min'],
            'scopes'        => $scopes,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_check_rate_limit' ) ) {
    /**
     * Sliding 1-minute window per token via api_log table.
     */
    function dinoco_sn_pubapi_check_rate_limit( $token_id, $rate_per_min ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_log' ) ) {
            return true; // Fail-open if log table missing — Phase 4 W12 OK
        }
        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_log' );
        $count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$tbl}
             WHERE api_token_id = %d
               AND created_at >= DATE_SUB(NOW(), INTERVAL 1 MINUTE)",
            $token_id
        ) );
        return $count < $rate_per_min;
    }
}

if ( ! function_exists( 'dinoco_sn_pubapi_log_request' ) ) {
    /**
     * Log every public API request for audit + rate limit window.
     */
    function dinoco_sn_pubapi_log_request( $token_id, $endpoint, $status, $duration_ms, $summary = '' ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'api_log' ) ) {
            return false;
        }
        global $wpdb;
        $tbl = dinoco_sn_pubapi_table( 'api_log' );
        return (bool) $wpdb->insert( $tbl, array(
            'api_token_id'     => (int) $token_id,
            'endpoint'         => mb_substr( (string) $endpoint, 0, 128 ),
            'http_status'      => (int) $status,
            'response_time_ms' => (int) $duration_ms,
            'ip_address'       => isset( $_SERVER['REMOTE_ADDR'] ) ? mb_substr( $_SERVER['REMOTE_ADDR'], 0, 45 ) : null,
            'request_summary'  => mb_substr( (string) $summary, 0, 1000 ),
            'created_at'       => current_time( 'mysql' ),
        ) );
    }
}

