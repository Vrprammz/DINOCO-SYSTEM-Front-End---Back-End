// 6. AUTO-COMPLETE (shipped เกิน 7 วัน)
// ════════════════════════════════════════════
add_action( 'b2b_auto_complete_check', 'b2b_run_auto_complete' );

function b2b_run_auto_complete() {
    try {
    b2b_log('[Cron] Auto-complete check');

    $shipped = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(
            array('key'=>'order_status','value'=>'shipped'),
            array('key'=>'shipped_date','value'=>'','compare'=>'!='),
        ),
    ));

    $count = 0;
    $threshold = time() - (7 * DAY_IN_SECONDS);

    foreach ($shipped as $t) {
        $shipped_date = get_field('shipped_date', $t->ID);
        if (!$shipped_date) continue;
        $shipped_ts = function_exists('b2b_parse_due_date_ts') ? b2b_parse_due_date_ts($shipped_date) : strtotime($shipped_date);
        if (!$shipped_ts || $shipped_ts > $threshold) continue;

        if (function_exists('b2b_set_order_status')) { b2b_set_order_status($t->ID, 'completed'); } else { update_field('order_status', 'completed', $t->ID); }
        update_field('completed_date', b2b_date('Y-m-d H:i:s'), $t->ID);
        update_field('completed_by', 'auto', $t->ID);

        $group_id = get_field('source_group_id', $t->ID);
        // V.30.3: ยกเลิก 24hr cron ที่อาจค้างอยู่ + guaranteed push
        $ts_24hr = wp_next_scheduled('b2b_flash_24hr_complete', array($t->ID));
        if ($ts_24hr) wp_unschedule_event($ts_24hr, 'b2b_flash_24hr_complete', array($t->ID));
        if ($group_id) {
            if (b2b_is_bot_enabled_for_group($group_id)) {
                $msg = "🏁 Ticket #".$t->ID." ปิดอัตโนมัติแล้วครับ (จัดส่งครบ 7 วัน)\nหากมีปัญหา พิมพ์ '@เคลม #".$t->ID."' ได้เลย";
                if ( function_exists('b2b_push_guaranteed') ) {
                    b2b_push_guaranteed($group_id, array(array('type'=>'text','text'=>$msg)), $t->ID, 'auto_complete_7d');
                } else {
                    b2b_line_push($group_id, $msg);
                }
            } else {
                b2b_log("[Auto-Complete] Bot disabled — skip LINE push for #{$t->ID}");
            }
        }

        $count++;
    }

    b2b_log("[Cron] Auto-completed: {$count} tickets");
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_auto_complete FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_auto_complete FATAL: ' . $e->getMessage());
    }
}

// ════════════════════════════════════════════
// 6b. V.30.3: FLASH 24HR AUTO-COMPLETE (single event)
// Scheduled by webhook state 5 — ถ้าลูกค้าไม่กดยืนยัน 24 ชม. → complete อัตโนมัติ
// ════════════════════════════════════════════
add_action( 'b2b_flash_24hr_complete', 'b2b_run_flash_24hr_complete' );
function b2b_run_flash_24hr_complete( $ticket_id ) {
    try {
        if ( ! $ticket_id ) return;
        $cur = get_field( 'order_status', $ticket_id );
        if ( $cur === 'completed' || $cur === 'cancelled' ) {
            b2b_log( '[Flash 24hr] #' . $ticket_id . ' already ' . $cur . ' — skip' );
            return;
        }
        $delivered_at = get_post_meta( $ticket_id, '_flash_delivered_at', true );
        if ( empty( $delivered_at ) ) {
            b2b_log( '[Flash 24hr] #' . $ticket_id . ' no _flash_delivered_at — skip' );
            return;
        }
        // เช็คว่าผ่าน 24 ชม. จริง (ป้องกัน manual schedule ผิดเวลา)
        $delivered_ts = strtotime( $delivered_at );
        if ( $delivered_ts && ( time() - $delivered_ts ) < 23 * HOUR_IN_SECONDS ) {
            b2b_log( '[Flash 24hr] #' . $ticket_id . ' not yet 24hr — skip' );
            return;
        }
        // Auto-complete
        if ( function_exists( 'b2b_set_order_status' ) ) {
            b2b_set_order_status( $ticket_id, 'completed' );
        } else {
            update_field( 'order_status', 'completed', $ticket_id );
        }
        update_field( 'completed_date', function_exists( 'b2b_date' ) ? b2b_date( 'Y-m-d H:i:s' ) : current_time( 'mysql' ), $ticket_id );
        update_field( 'completed_by', 'auto_24hr', $ticket_id );
        b2b_add_audit_log( $ticket_id, 'flash_auto_complete_24hr', 'ปิดอัตโนมัติ 24 ชม. หลังส่งถึง (ลูกค้าไม่กดยืนยัน)' );

        $sgid = get_field( 'source_group_id', $ticket_id );
        if ( $sgid && function_exists( 'b2b_is_bot_enabled_for_group' ) && b2b_is_bot_enabled_for_group( $sgid ) ) {
            $msg = "🏁 Ticket #" . $ticket_id . " ปิดอัตโนมัติแล้วครับ (ส่งถึงครบ 24 ชม.)\nหากมีปัญหา พิมพ์ '@เคลม #" . $ticket_id . "' ได้เลย";
            if ( function_exists( 'b2b_push_guaranteed' ) ) {
                b2b_push_guaranteed( $sgid, array( array( 'type' => 'text', 'text' => $msg ) ), $ticket_id, 'flash_auto_complete_24hr' );
            } else {
                b2b_line_push( $sgid, $msg );
            }
        }
        b2b_log( '[Flash 24hr] #' . $ticket_id . ' auto-completed' );
    } catch ( Exception $e ) {
        b2b_log( '[Flash 24hr] FAILED #' . $ticket_id . ': ' . $e->getMessage() );
    }
}

// ════════════════════════════════════════════
// 7. OOS EXPIRY CHECK
// ════════════════════════════════════════════
add_action( 'b2b_oos_expiry_check', 'b2b_run_oos_expiry_check' );

function b2b_run_oos_expiry_check() {
    // Guard: ถ้าระบบ Inventory เปิดแล้ว → ไม่ต้อง auto-expire เอง (dinoco_stock_auto_status จัดการ)
    if (get_option('dinoco_inv_initialized')) return;

    try {
    b2b_log('[Cron] OOS expiry check');

    $count = 0;

    // V.30.5: Read from custom table first (source of truth)
    if ( class_exists('DINOCO_Catalog') ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $expired = $wpdb->get_results(
            "SELECT sku, oos_timestamp, oos_duration_hours FROM {$table}
             WHERE is_active = 1 AND stock_status = 'out_of_stock'
             AND oos_timestamp IS NOT NULL AND oos_timestamp > 0
             AND oos_duration_hours IS NOT NULL AND oos_duration_hours > 0",
            ARRAY_A
        );
        foreach ($expired as $row) {
            $ts = intval($row['oos_timestamp']);
            $hrs = intval($row['oos_duration_hours']);
            if ($ts && $hrs && time() >= $ts + ($hrs * 3600)) {
                $sku = $row['sku'];
                // Dual-write: custom table
                $wpdb->update($table, array(
                    'stock_status'       => 'in_stock',
                    'oos_timestamp'      => null,
                    'oos_duration_hours' => null,
                    'oos_eta_date'       => null,
                ), array('sku' => $sku));
                // Dual-write: ACF
                if (function_exists('b2b_find_product_by_sku')) {
                    $pid = b2b_find_product_by_sku($sku);
                    if ($pid) {
                        update_field('stock_status', 'in_stock', $pid);
                        update_field('oos_timestamp', 0, $pid);
                    }
                }
                b2b_log("[OOS] Auto-unlocked SKU: {$sku}");
                $count++;
            }
        }
    } else {
        // Fallback: ACF
        $products = get_posts(array(
            'post_type'=>'b2b_product','posts_per_page'=>-1,'post_status'=>'publish',
            'meta_query'=>array(
                array('key'=>'stock_status','value'=>'out_of_stock'),
                array('key'=>'oos_timestamp','value'=>0,'compare'=>'>'),
                array('key'=>'oos_duration_hours','value'=>0,'compare'=>'>'),
            ),
        ));
        foreach ($products as $p) {
            $ts = intval(get_field('oos_timestamp', $p->ID));
            $hrs = intval(get_field('oos_duration_hours', $p->ID));
            if ($ts && $hrs && time() >= $ts + ($hrs * 3600)) {
                $sku = get_field('product_sku', $p->ID);
                update_field('stock_status', 'in_stock', $p->ID);
                update_field('oos_timestamp', 0, $p->ID);
                b2b_log("[OOS] Auto-unlocked SKU: {$sku}");
                $count++;
            }
        }
    }

    delete_transient('b2b_sku_data_map');
    b2b_log("[Cron] OOS expired: {$count} products unlocked");
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_oos_expiry_check FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_oos_expiry_check FATAL: ' . $e->getMessage());
    }
}

// ════════════════════════════════════════════
// 8. WEEKLY REPORT (V.9: N1 — NEW)
// ทุกอาทิตย์ 17:30 ICT — สรุปยอดสัปดาห์
// ════════════════════════════════════════════
add_action( 'b2b_weekly_report_event', 'b2b_run_weekly_report' );

function b2b_run_weekly_report() {
    try {
    if ( !defined('B2B_ADMIN_GROUP_ID') ) return;
    b2b_log('[Cron] Weekly report start');

    // Date range: Mon-Sun of current/last week depending on day of execution
    $today_str = b2b_date('Y-m-d');
    $today_ts  = strtotime($today_str);
    $dow       = (int) date('w', $today_ts); // 0=Sun, 1=Mon...
    if ($dow === 0) {
        // Running on Sunday: report Mon-Sun of this week (ending today)
        $week_start = b2b_date('Y-m-d', strtotime('last monday', $today_ts));
        $week_end   = $today_str;
    } else {
        // Manual trigger on other day: use last completed Mon-Sun
        $last_sun   = strtotime('last sunday', $today_ts);
        $week_end   = b2b_date('Y-m-d', $last_sun);
        $week_start = b2b_date('Y-m-d', strtotime('-6 days', $last_sun));
    }

    // ── ออเดอร์สัปดาห์ที่ผ่านมา ──
    $week_orders = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'date_query'=>array(array('after'=>$week_start.' 00:00:00','before'=>$week_end.' 23:59:59','inclusive'=>true)),
        'meta_query'=>array(array('key'=>'order_status','value'=>array('cancelled','cancel_requested'),'compare'=>'NOT IN')),
    ));

    $total_revenue = 0;
    $dist_sales = array(); // group_id => total

    foreach ($week_orders as $o) {
        $amt = floatval(get_field('total_amount', $o->ID));
        $total_revenue += $amt;
        $gid = get_field('source_group_id', $o->ID);
        if ($gid) {
            if (!isset($dist_sales[$gid])) $dist_sales[$gid] = 0;
            $dist_sales[$gid] += $amt;
        }
    }

    // ── Top 5 Distributors ──
    arsort($dist_sales);
    $top5 = array_slice($dist_sales, 0, 5, true);
    $top_lines = array();
    $rank_num = 1;
    foreach ($top5 as $gid => $sales) {
        $dist = b2b_get_dist_by_group($gid);
        $dname = $dist ? get_the_title($dist->ID) : 'Unknown';
        $medal = $rank_num <= 3 ? array('🥇','🥈','🥉')[$rank_num-1] : '  '.$rank_num.'.';
        $top_lines[] = $medal.' '.$dname.' — ฿'.number_format($sales, 0);
        $rank_num++;
    }

    // ── BO + Claim ค้าง ──
    $bo_count = count(get_posts(array('post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>'backorder')),'fields'=>'ids')));
    $claim_count = count(get_posts(array('post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>'claim_opened')),'fields'=>'ids')));

    // ── Overdue payment count ──
    $overdue_count = 0;
    $dists = get_posts(array('post_type'=>'distributor','posts_per_page'=>-1,'post_status'=>'publish'));
    foreach ($dists as $d) {
        if (floatval(get_field('current_debt', $d->ID)) > 0 && get_field('credit_hold', $d->ID)) {
            $overdue_count++;
        }
    }

    // ── Build message ──
    $msg = "📊 Weekly Report\n";
    $msg .= "📅 ".$week_start." — ".$week_end."\n";
    $msg .= "━━━━━━━━━━━━━━━━\n\n";
    $msg .= "📦 ออเดอร์: ".count($week_orders)." รายการ\n";
    $msg .= "💰 ยอดรวม: ฿".number_format($total_revenue, 0)."\n\n";

    if (!empty($top_lines)) {
        $msg .= "🏆 Top Distributors:\n".implode("\n", $top_lines)."\n\n";
    }

    $msg .= "📋 ค้างดำเนินการ:\n";
    $msg .= "  🚫 Backorder: ".$bo_count."\n";
    $msg .= "  ↩️ Claim เปิด: ".$claim_count."\n";
    $msg .= "  ⛔ Credit Hold: ".$overdue_count."\n";

    b2b_push_to_admin($msg);
    b2b_log('[Cron] Weekly report done');
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_weekly_report FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_weekly_report FATAL: ' . $e->getMessage());
    }
}

// ════════════════════════════════════════════
// 9. SHIPPING OVERDUE SUMMARY (V.11.0)
// ทุกวัน 15:00 ICT — สรุปค้างจัดส่ง
// ════════════════════════════════════════════
add_action( 'b2b_shipping_overdue_cron', 'b2b_run_shipping_overdue_summary' );

function b2b_run_shipping_overdue_summary() {
    try {
    if ( !defined('B2B_ADMIN_GROUP_ID') ) return;
    b2b_log('[Cron] Shipping overdue summary start');

    $orders = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>array('awaiting_payment','paid'),'compare'=>'IN')), // FIX #4: รวม paid ที่ค้างแพ็คด้วย
        'orderby'=>'date','order'=>'ASC',
    ));

    if (empty($orders)) {
        b2b_log('[Cron] Shipping overdue: no pending orders');
        return;
    }

    $urgent = array(); // > 2 days
    $normal = array(); // <= 2 days
    $total_urgent = 0; $total_normal = 0;

    foreach ($orders as $o) {
        $order_date = get_post_time('U', true, $o->ID);
        $days = floor((time() - $order_date) / 86400);
        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $amt = floatval(get_field('total_amount', $o->ID));

        $item = array('id'=>$o->ID, 'shop'=>$shop, 'days'=>$days, 'amt'=>$amt);
        if ($days >= 2) { $urgent[] = $item; $total_urgent += $amt; }
        else { $normal[] = $item; $total_normal += $amt; }
    }

    $msg = "📦 สรุปค้างจัดส่ง — ".b2b_date('d/m/Y H:i')."\n";
    $msg .= "━━━━━━━━━━━━━━━━\n\n";

    if (!empty($urgent)) {
        $msg .= "⚠️ ค้างเกิน 2 วัน (".count($urgent)." รายการ · ฿".number_format($total_urgent,0)."):\n";
        foreach ($urgent as $u) {
            $msg .= "  🔴 #".$u['id']." ".$u['shop']." — ค้าง ".$u['days']." วัน · ฿".number_format($u['amt'],0)."\n";
        }
        $msg .= "\n";
    }

    if (!empty($normal)) {
        $msg .= "✅ ไม่เกิน 2 วัน (".count($normal)." รายการ · ฿".number_format($total_normal,0)."):\n";
        foreach ($normal as $n) {
            $msg .= "  📦 #".$n['id']." ".$n['shop']." — ".$n['days']." วัน · ฿".number_format($n['amt'],0)."\n";
        }
        $msg .= "\n";
    }

    $msg .= "📊 รวม: ".count($orders)." รายการ · ฿".number_format($total_urgent + $total_normal, 0);

    b2b_push_to_admin($msg);
    b2b_log('[Cron] Shipping overdue: '.count($urgent).' urgent, '.count($normal).' normal');
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_shipping_overdue_summary FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_shipping_overdue_summary FATAL: ' . $e->getMessage());
    }
}

// ════════════════════════════════════════════
// 10. RPi HEARTBEAT CHECK (every 5 min, business hours only)
// ════════════════════════════════════════════
add_action( 'b2b_rpi_heartbeat_check', 'b2b_check_rpi_heartbeat' );

function b2b_check_rpi_heartbeat() {
    try {
    if ( !defined('B2B_LINE_ACCESS_TOKEN') || !defined('B2B_ADMIN_GROUP_ID') ) return;

    // Business hours: 10:00 - 20:00 ICT only
    $ict_hour = (int) ( new DateTime('now', new DateTimeZone('Asia/Bangkok')) )->format('G');
    if ( $ict_hour < 10 || $ict_hour >= 20 ) {
        return; // Outside business hours — skip check
    }

    $device      = get_option('b2b_print_device_info', array());
    $last_ts     = isset($device['timestamp']) ? (int) $device['timestamp'] : 0;
    $age_seconds = time() - $last_ts;
    $was_offline = get_option('b2b_rpi_offline_notified', false);

    // Threshold: 2 minutes (120 seconds) without heartbeat = offline
    if ( $age_seconds > 120 ) {
        $age_min = round($age_seconds / 60);

        // Count pending print jobs in queue
        $pending_jobs = get_posts(array(
            'post_type'   => 'b2b_order',
            'post_status' => 'publish',
            'meta_query'  => array(array('key'=>'print_status','value'=>'queue','compare'=>'=')),
            'fields'      => 'ids',
            'numberposts' => -1,
        ));
        $queue_count = count($pending_jobs);

        if ( !$was_offline ) {
            // First offline notification
            $msg = "🔴 RPi ออฟไลน์!\n"
                . "━━━━━━━━━━━━━━━━\n"
                . "Heartbeat หายไป {$age_min} นาที\n"
                . "เครื่องปริ้นอาจปิดอยู่หรือเน็ตหลุด\n";
            if ( $queue_count > 0 ) {
                $msg .= "⚠️ มี {$queue_count} งานค้างรอปริ้น!\n";
            }
            $msg .= "รอ RPi กลับมาจะพิมพ์อัตโนมัติ";
            b2b_push_to_admin($msg);
            update_option('b2b_rpi_offline_notified', true, false);
            update_option('b2b_rpi_offline_last_remind', time(), false);
            b2b_log('[Cron] RPi offline — heartbeat age: ' . $age_min . ' min, queue: ' . $queue_count);
        } elseif ( $queue_count > 0 ) {
            // Already notified but there are pending jobs — remind every 30 min
            $last_remind = (int) get_option('b2b_rpi_offline_last_remind', 0);
            if ( time() - $last_remind >= 1800 ) {
                $hrs = floor($age_min / 60);
                $mins = $age_min % 60;
                $age_str = $hrs > 0 ? "{$hrs} ชม. {$mins} นาที" : "{$mins} นาที";
                b2b_push_to_admin(
                    "⚠️ RPi ยังออฟไลน์อยู่ ({$age_str})\n"
                    . "━━━━━━━━━━━━━━━━\n"
                    . "📋 มี {$queue_count} งานค้างรอปริ้น\n"
                    . "กรุณาตรวจสอบเครื่อง RPi\n"
                    . "• เช็คว่าเปิดอยู่ + เน็ตเชื่อมต่อ\n"
                    . "• SSH: sudo systemctl restart dinoco-print"
                );
                update_option('b2b_rpi_offline_last_remind', time(), false);
                b2b_log('[Cron] RPi still offline — reminder sent, queue: ' . $queue_count);
            }
        }
    } else {
        // RPi is online
        if ( $was_offline ) {
            $hostname = isset($device['hostname']) ? $device['hostname'] : 'RPi';
            b2b_push_to_admin(
                "🟢 RPi กลับมาออนไลน์แล้ว!\n"
                . "━━━━━━━━━━━━━━━━\n"
                . "Host: {$hostname}\n"
                . "IP: " . ($device['ip'] ?? '-') . "\n"
                . "Job ที่ค้างจะเริ่มพิมพ์อัตโนมัติ"
            );
            update_option('b2b_rpi_offline_notified', false, false);
            delete_option('b2b_rpi_offline_last_remind');
            b2b_log('[Cron] RPi back online — ' . $hostname);
        }
    }
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_check_rpi_heartbeat FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_check_rpi_heartbeat FATAL: ' . $e->getMessage());
    }
}


// ════════════════════════════════════════════
// V.22: FLASH TRACKING FALLBACK CRON
// Polls Flash routesBatch every 2 hours for orders not yet delivered
// ════════════════════════════════════════════
add_action( 'b2b_flash_tracking_cron', 'b2b_run_flash_tracking_fallback' );
function b2b_run_flash_tracking_fallback() {
    try {
    if ( ! function_exists( 'b2b_flash_get_routes_batch' ) ) {
        b2b_log( '[Flash Cron] S1 not loaded — skip' );
        return;
    }

    // Find Flash orders that are shipped but not delivered/returned/cancelled
    $active_statuses = array( 'flash_created', 'print_queued', 'print_done', 'ready_to_ship', 'courier_called', 'picked_up', 'in_transit', 'delivering', 'detained', 'problem' );
    $orders = get_posts( array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => 200,
        'post_status'    => 'publish',
        'meta_query'     => array(
            array( 'key' => '_flash_packing_status', 'value' => $active_statuses, 'compare' => 'IN' ),
        ),
        'fields' => 'ids',
    ) );

    if ( empty( $orders ) ) {
        b2b_log( '[Flash Cron] No active Flash orders' );
        return;
    }

    // Collect all pnos and map pno -> ticket_id
    $pno_map = array();
    foreach ( $orders as $tid ) {
        $pnos = get_post_meta( $tid, '_flash_tracking_numbers', true );
        if ( is_array( $pnos ) ) {
            foreach ( $pnos as $pno ) {
                $pno_map[ $pno ] = $tid;
            }
        }
    }

    if ( empty( $pno_map ) ) return;

    // Batch by 10 (Flash limit)
    $all_pnos = array_keys( $pno_map );
    $chunks = array_chunk( $all_pnos, 10 );
    $updated = 0;

    foreach ( $chunks as $chunk ) {
        $csv = implode( ',', $chunk );
        $result = b2b_flash_get_routes_batch( $csv );

        if ( ! $result['ok'] || ! isset( $result['data'] ) ) {
            b2b_log( '[Flash Cron] Batch failed: ' . ( $result['error'] ?? 'unknown' ) );
            continue;
        }

        $routes_data = is_array( $result['data'] ) ? $result['data'] : array();
        // FIX: routesBatch return array of objects [{pno, routes, state}, ...] ไม่ใช่ key-value
        foreach ( $routes_data as $item ) {
            $pno = isset( $item['pno'] ) ? $item['pno'] : ( is_string( $item ) ? $item : '' );
            $routes = isset( $item['routes'] ) ? $item['routes'] : ( is_array( $item ) && ! isset( $item['pno'] ) ? $item : array() );
            if ( empty( $pno ) || ! isset( $pno_map[ $pno ] ) ) continue;
            $tid = $pno_map[ $pno ];

            if ( ! is_array( $routes ) || empty( $routes ) ) continue;

            // Get latest route
            $latest = end( $routes );
            $action = isset( $latest['routeAction'] ) ? $latest['routeAction'] : '';
            $label = function_exists( 'b2b_flash_route_label' ) ? b2b_flash_route_label( $action ) : $action;

            // Append each route as event (deduplicate by routedAt)
            $existing_events = get_post_meta( $tid, '_flash_tracking_events', true ) ?: array();
            $existing_times = array();
            foreach ( $existing_events as $ev ) {
                if ( isset( $ev['routedAt'] ) ) $existing_times[] = $ev['routedAt'];
            }

            foreach ( $routes as $route ) {
                $rat = isset( $route['routedAt'] ) ? $route['routedAt'] : '';
                if ( $rat && in_array( $rat, $existing_times ) ) continue;
                $rlabel = function_exists( 'b2b_flash_route_label' ) ? b2b_flash_route_label( $route['routeAction'] ?? '' ) : '';
                b2b_flash_append_event( $tid, array(
                    'type'     => 'routes_cron',
                    'pno'      => $pno,
                    'action'   => $route['routeAction'] ?? '',
                    'label'    => $rlabel,
                    'message'  => $route['message'] ?? '',
                    'province' => $route['currentProvince'] ?? '',
                    'routedAt' => $rat,
                ) );
            }

            // Update status based on latest action
            $action_to_status = array(
                'RECEIVED' => 'picked_up', 'SHIPPING' => 'in_transit', 'ARRIVED_WAREHOUSE' => 'in_transit',
                'DELIVERING' => 'delivering', 'SIGNED' => 'delivered', 'RETURNED' => 'returned',
                'DETAINED' => 'detained', 'PROBLEM' => 'problem', 'CLOSED' => 'closed', 'CANCELLED' => 'cancelled',
            );
            if ( isset( $action_to_status[ $action ] ) ) {
                $new_status = $action_to_status[ $action ];
                $current_status = get_post_meta( $tid, '_flash_status', true );
                $terminal = array( 'delivered', 'returned', 'closed', 'cancelled' );
                if ( in_array( $current_status, $terminal, true ) && ! in_array( $new_status, $terminal, true ) ) {
                    continue; // Don't revert terminal states
                }
                update_post_meta( $tid, '_flash_status', $new_status );
                update_post_meta( $tid, '_flash_packing_status', $new_status );

                // V.30.3: ถ้า delivered → ส่ง Flex ให้ลูกค้ายืนยัน + schedule 24hr (เหมือน webhook state 5)
                if ( $new_status === 'delivered' ) {
                    $cur = get_field( 'order_status', $tid );
                    $delivered_at = get_post_meta( $tid, '_flash_delivered_at', true );
                    if ( $cur !== 'completed' && empty( $delivered_at ) ) {
                        // Webhook ยังไม่ทำ → cron fallback: mark delivered + ส่ง Flex + schedule 24hr
                        update_post_meta( $tid, '_flash_delivered_at', current_time( 'mysql' ) );
                        // ส่ง Flex ให้ตัวแทนยืนยันรับสินค้า (ใช้ generic flash status Flex)
                        $sgid = get_field( 'source_group_id', $tid );
                        if ( $sgid && function_exists( 'b2b_build_flex_flash_status' ) ) {
                            $flex = b2b_build_flex_flash_status( $tid, 5, 'พัสดุส่งถึงแล้ว (ตรวจพบจาก Tracking)' );
                            if ( function_exists( 'b2b_push_guaranteed' ) ) {
                                b2b_push_guaranteed( $sgid, array( $flex ), $tid, 'flash_delivered_cron' );
                            } else {
                                b2b_line_push_raw( $sgid, array( $flex ) );
                            }
                        }
                        // Schedule 24hr auto-complete แทน complete ทันที
                        wp_schedule_single_event( time() + ( 24 * HOUR_IN_SECONDS ), 'b2b_flash_24hr_complete', array( $tid ) );
                        b2b_add_audit_log( $tid, 'flash_delivered_cron', 'Flash Cron: ส่งถึง (fallback) — รอยืนยันรับ 24 ชม.' );
                    }
                    // ถ้า delivered_at มีอยู่แล้ว = webhook ทำไปแล้ว กำลังรอลูกค้ายืนยัน → ไม่ทำซ้ำ
                }
            }
            $updated++;
        }
    }

    b2b_log( '[Flash Cron] Updated ' . $updated . ' orders from ' . count( $all_pnos ) . ' pnos' );
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_flash_tracking_fallback FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_flash_tracking_fallback FATAL: ' . $e->getMessage());
    }
}

// ════════════════════════════════════════════
// V.35: FLASH COURIER RETRY (single event, scheduled by flash-ready endpoint)
// Retries Flash /notify for orders that failed due to network errors.
// Retry schedule: 2min → 5min → 10min → 15min (max 4 retries)
// ════════════════════════════════════════════
add_action( 'b2b_flash_courier_retry', 'b2b_run_flash_courier_retry' );
function b2b_run_flash_courier_retry( $tid ) {
    try {
    $tid = intval( $tid );
    if ( ! $tid || get_post_type( $tid ) !== 'b2b_order' ) return;

    $packing = get_post_meta( $tid, '_flash_packing_status', true );
    // Only retry if still in error/ready state (not if already courier_called)
    if ( ! in_array( $packing, array( 'notify_error', 'ready_to_ship' ), true ) ) {
        b2b_log( '[Flash Retry] #' . $tid . ' status=' . $packing . ' — skip (already handled)' );
        return;
    }

    // Check if active pickup already exists (another order may have triggered it)
    $active_pickup = get_transient( 'b2b_flash_active_pickup' );
    if ( is_array( $active_pickup ) && ! empty( $active_pickup['pickup_id'] ) ) {
        // Active pickup exists → just link this order to it
        $pnos = get_post_meta( $tid, '_flash_tracking_numbers', true );
        $parcels = is_array( $pnos ) ? count( $pnos ) : 1;
        $active_pickup['parcel_count'] = intval( $active_pickup['parcel_count'] ?? 0 ) + $parcels;
        if ( ! is_array( $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'] = array();
        if ( ! in_array( $tid, $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'][] = $tid;
        set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );

        update_post_meta( $tid, '_flash_packing_status', 'courier_called' );
        update_post_meta( $tid, '_flash_pickup_id', $active_pickup['pickup_id'] );
        update_post_meta( $tid, '_flash_courier_info', array(
            'name'  => $active_pickup['staff_name'],
            'phone' => $active_pickup['staff_phone'],
        ) );
        b2b_log( '[Flash Retry] #' . $tid . ' linked to existing pickup ' . $active_pickup['pickup_id'] );

        // V.37: Flex Card แทน text
        if ( function_exists( 'b2b_build_flex_pickup_added' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
            $flex = b2b_build_flex_pickup_added( $tid, $active_pickup );
            b2b_push_raw_to_admin( array( $flex ) );
        } elseif ( function_exists( 'b2b_push_to_admin' ) ) {
            $dist = get_field( 'dist_name', $tid ) ?: '';
            b2b_push_to_admin( '📦 retry สำเร็จ — เพิ่ม #' . $tid . ' ' . $dist . ' เข้า pickup (คูเรียร์: ' . $active_pickup['staff_name'] . ')' );
        }
        return;
    }

    // No active pickup → call Flash /notify
    if ( ! function_exists( 'b2b_flash_notify_courier_from_warehouse' ) ) {
        b2b_log( '[Flash Retry] S1 not loaded — skip' );
        return;
    }

    $pnos = get_post_meta( $tid, '_flash_tracking_numbers', true );
    $total_parcels = is_array( $pnos ) ? count( $pnos ) : 1;
    $result = b2b_flash_notify_courier_from_warehouse( $total_parcels, 'Retry order: ' . $tid );

    $pickup_data = null;
    if ( $result['ok'] && ! empty( $result['data'] ) ) {
        $pickup_data = $result['data'];
    } elseif ( ! $result['ok'] && function_exists( 'b2b_flash_get_notifications' ) ) {
        // Flash rejected → check /notifications for active pickup
        $notif = b2b_flash_get_notifications( date( 'Y-m-d' ) );
        if ( $notif['ok'] && ! empty( $notif['data'] ) ) {
            foreach ( (array) $notif['data'] as $pu ) {
                if ( isset( $pu['state'] ) && in_array( intval( $pu['state'] ), array( 0, 1 ), true ) ) {
                    $pickup_data = $pu;
                    break;
                }
            }
        }
    }

    if ( $pickup_data ) {
        // Success — cache and update
        $staff   = $pickup_data['staffInfoName']  ?? $pickup_data['staffInfoname'] ?? '';
        $phone   = $pickup_data['staffInfoPhone'] ?? $pickup_data['staffInfomobile'] ?? '';
        $timeout = $pickup_data['timeoutAtText']  ?? '';
        $pid     = $pickup_data['ticketPickupId']  ?? '';

        $active = array(
            'pickup_id'    => $pid,
            'staff_name'   => $staff,
            'staff_phone'  => $phone,
            'timeout_text' => $timeout,
            'created_at'   => time(),
            'parcel_count' => $total_parcels,
            'ticket_ids'   => array( $tid ),
        );
        set_transient( 'b2b_flash_active_pickup', $active, 4 * HOUR_IN_SECONDS );

        update_post_meta( $tid, '_flash_packing_status', 'courier_called' );
        update_post_meta( $tid, '_flash_pickup_id', $pid );
        update_post_meta( $tid, '_flash_courier_info', array( 'name' => $staff, 'phone' => $phone, 'pickupId' => $pid ) );
        delete_post_meta( $tid, '_flash_courier_retry_count' );

        b2b_log( '[Flash Retry] #' . $tid . ' SUCCESS: courier=' . $staff . ' pickup=' . $pid );

        if ( function_exists( 'b2b_build_flex_courier_pickup' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
            b2b_push_raw_to_admin( array( b2b_build_flex_courier_pickup( $active ) ) );
        } elseif ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '🚛 retry สำเร็จ — เรียกรถ Flash #' . $tid . ' คูเรียร์: ' . $staff . ' ' . $phone );
        }
    } else {
        // Still failing — schedule next retry or give up
        $retry_count = intval( get_post_meta( $tid, '_flash_courier_retry_count', true ) );
        update_post_meta( $tid, '_flash_courier_retry_count', $retry_count + 1 );
        $delays = array( 120, 300, 600, 900 ); // 2min, 5min, 10min, 15min

        if ( $retry_count < count( $delays ) ) {
            wp_schedule_single_event( time() + $delays[ $retry_count ], 'b2b_flash_courier_retry', array( $tid ) );
            b2b_log( '[Flash Retry] #' . $tid . ' FAILED retry #' . ( $retry_count + 1 ) . ' — next in ' . $delays[ $retry_count ] . 's' );
        } else {
            // All retries exhausted → alert admin with Flex
            b2b_log( '[Flash Retry] #' . $tid . ' ALL RETRIES EXHAUSTED' );
            if ( function_exists( 'b2b_build_flex_flash_admin' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
                $err = get_post_meta( $tid, '_flash_notify_error', true ) ?: 'Unknown error';
                $flex = b2b_build_flex_flash_admin( $tid, 'courier_fail', array(
                    'error' => $err . ' (retry ' . ( $retry_count + 1 ) . ' ครั้ง หมดแล้ว)',
                ) );
                b2b_push_raw_to_admin( array( $flex ) );
            }
        }
    }

    } catch ( Exception $e ) {
        b2b_log( '[Flash Retry] FAILED: ' . $e->getMessage() );
    } catch ( Error $e ) {
        b2b_log( '[Flash Retry] FATAL: ' . $e->getMessage() );
    }
}

function b2b_retry_pending_flex() {
    $posts = get_posts(array(
        'post_type' => 'b2b_order',
        'meta_key' => '_pending_flex',
        'posts_per_page' => 50,
        'fields' => 'ids',
    ));
    if (empty($posts)) return;

    $ok = 0; $retry = 0; $failed = 0;
    foreach ($posts as $pid) {
        $entries = get_post_meta($pid, '_pending_flex', false);
        delete_post_meta($pid, '_pending_flex');

        foreach ($entries as $entry) {
            if (!is_array($entry) || empty($entry['messages']) || empty($entry['group_id'])) continue;

            $result = b2b_line_push_raw($entry['group_id'], $entry['messages']);
            $success = is_array($result) && isset($result['code']) && $result['code'] === 200;

            if ($success) {
                $ok++;
                b2b_log('[FlexRetry] OK #' . $pid . ' type=' . $entry['flex_type']);
            } elseif (intval($entry['attempts']) < 5) {
                $entry['attempts'] = intval($entry['attempts']) + 1;
                add_post_meta($pid, '_pending_flex', $entry);
                $retry++;
            } else {
                $failed++;
                b2b_log('[FlexRetry] GAVE UP #' . $pid . ' type=' . $entry['flex_type'] . ' after 5 attempts');
                if (defined('B2B_ADMIN_GROUP_ID') && function_exists('b2b_line_push')) {
                    b2b_line_push(B2B_ADMIN_GROUP_ID, '❌ Flex ส่งไม่สำเร็จ 5 ครั้ง\nTicket #' . $pid . '\nType: ' . $entry['flex_type']);
                }
            }
        }
    }
    if ($ok + $retry + $failed > 0) {
        b2b_log('[FlexRetry] Summary: ' . $ok . ' ok, ' . $retry . ' retry, ' . $failed . ' gave up');
    }
}
