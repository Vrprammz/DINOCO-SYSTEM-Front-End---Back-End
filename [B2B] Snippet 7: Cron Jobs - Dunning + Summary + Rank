add_filter( 'cron_schedules', function( $s ) {
    $s['daily_b2b']      = array('interval'=>DAY_IN_SECONDS,'display'=>'Daily (B2B)');
    $s['weekly_b2b']     = array('interval'=>WEEK_IN_SECONDS,'display'=>'Weekly (B2B)'); // V.9: N1
    $s['every_5min_b2b'] = array('interval'=>300,'display'=>'Every 5 min (B2B)'); // RPi heartbeat check
    $s['every_2hr_b2b']  = array('interval'=>7200,'display'=>'Every 2 hours (B2B)'); // V.22: Flash tracking fallback
    $s['every_1min_b2b'] = array('interval' => 60, 'display' => 'Every 1 min (B2B Flex retry)');
    return $s;
});

// ════════════════════════════════════════════
// REGISTER ALL CRON EVENTS
// ════════════════════════════════════════════
add_action( 'init', function() {
    // Force reschedule when cron times change (bump version to re-register)
    $cron_ver = 'v2'; // v2: daily 17:30, weekly Sun 17:30
    if ( get_option('b2b_cron_schedule_ver') !== $cron_ver ) {
        foreach ( array('b2b_daily_summary_cron','b2b_weekly_report_event') as $_h ) {
            wp_clear_scheduled_hook($_h);
        }
        update_option('b2b_cron_schedule_ver', $cron_ver);
    }

    $events = array(
        'b2b_dunning_cron_event'  => '02:00:00', // 09:00 ICT
        'b2b_daily_summary_cron'  => '10:30:00', // 17:30 ICT
        'b2b_bo_overdue_check'    => '03:00:00', // 10:00 ICT
        'b2b_auto_complete_check' => '04:00:00', // 11:00 ICT
        'b2b_oos_expiry_check'    => '23:00:00', // 06:00 ICT (+1)
        'b2b_shipping_overdue_cron' => '08:00:00', // 15:00 ICT — V.11.0
    );
    foreach ($events as $hook => $utc) {
        if ( !wp_next_scheduled($hook) ) {
            $next = strtotime("today {$utc} UTC");
            if ($next < time()) $next = strtotime("tomorrow {$utc} UTC");
            wp_schedule_event($next, 'daily_b2b', $hook);
        }
    }
    // Rank — 1st of month
    if ( !wp_next_scheduled('b2b_rank_update_event') ) {
        wp_schedule_event(mktime(0,5,0,(int)b2b_date('n')+1,1), 'daily_b2b', 'b2b_rank_update_event');
    }
    // V.9: N1 — Weekly Report (Sunday 17:30 ICT = 10:30 UTC)
    if ( !wp_next_scheduled('b2b_weekly_report_event') ) {
        $next_sun = strtotime('next sunday 10:30:00 UTC'); // 17:30 ICT
        wp_schedule_event($next_sun, 'weekly_b2b', 'b2b_weekly_report_event');
    }
    // RPi heartbeat check — every 5 min
    if ( !wp_next_scheduled('b2b_rpi_heartbeat_check') ) {
        wp_schedule_event(time(), 'every_5min_b2b', 'b2b_rpi_heartbeat_check');
    }
    // V.22: Flash tracking fallback — every 2 hours
    // ใช้ 'everytwohours' (จาก WP Fastest Cache plugin) เพราะ 'every_2hr_b2b' อาจไม่ load ใน REST context
    $flash_interval = wp_get_schedules();
    $flash_recurrence = isset($flash_interval['every_2hr_b2b']) ? 'every_2hr_b2b' : (isset($flash_interval['everytwohours']) ? 'everytwohours' : 'twicedaily');
    if ( !wp_next_scheduled('b2b_flash_tracking_cron') ) {
        wp_schedule_event(time() + 600, $flash_recurrence, 'b2b_flash_tracking_cron');
    }
    // Flex retry — every 1 min
    if (!wp_next_scheduled('b2b_flex_retry_cron')) {
        wp_schedule_event(time(), 'every_1min_b2b', 'b2b_flex_retry_cron');
    }
    add_action('b2b_flex_retry_cron', 'b2b_retry_pending_flex');
});

// ════════════════════════════════════════════
// 1. DUNNING PROCESS
// ════════════════════════════════════════════
add_action( 'b2b_dunning_cron_event', 'b2b_run_dunning_process' );

function b2b_run_dunning_process() {
    try {
    if ( !defined('B2B_LINE_ACCESS_TOKEN') || !defined('B2B_ADMIN_GROUP_ID') ) return;
    b2b_log('[Cron] Dunning start');

    $dists = get_posts(array('post_type'=>'distributor','posts_per_page'=>-1,'post_status'=>'publish'));
    if (!empty($dists)) update_post_meta_cache(wp_list_pluck($dists, 'ID'));
    $count = 0;

    // Pre-fetch all awaiting_payment orders
    // V.30.6: exclude manual_invoice — Manual Invoice System handles its own dunning
    //         (คู่ตัวทวงซ้ำกับ dinoco_inv_cron_reminder / dinoco_inv_cron_overdue)
    $all_ap_orders = get_posts(array(
        'post_type' => 'b2b_order', 'posts_per_page' => -1,
        'post_status' => 'publish', 'fields' => 'ids',
        'meta_query' => array(
            'relation' => 'AND',
            array('key' => 'order_status', 'value' => 'awaiting_payment'),
            array(
                'relation' => 'OR',
                array('key' => '_order_source', 'compare' => 'NOT EXISTS'),
                array('key' => '_order_source', 'value' => 'manual_invoice', 'compare' => '!='),
            ),
        ),
    ));
    if (!empty($all_ap_orders)) update_post_meta_cache($all_ap_orders);
    $orders_by_group = array();
    foreach ($all_ap_orders as $oid) {
        $gid = get_post_meta($oid, 'source_group_id', true);
        if ($gid) $orders_by_group[$gid][] = $oid;
    }

    // V.30.6: per-distributor daily guard — กัน double push ต่อให้ cron ยิงซ้ำในวันเดียวกัน
    $today_str = b2b_date('Y-m-d');

    foreach ($dists as $d) {
        $debt = floatval(get_field('current_debt', $d->ID));
        if ($debt <= 0) continue;

        // V.30.6: skip ถ้าส่ง dunning Flex ไปวันนี้แล้ว
        $last_sent = get_post_meta($d->ID, '_b2b_dunning_last_sent', true);
        if ($last_sent === $today_str) continue;

        $gid = get_field('line_group_id', $d->ID);
        $order_ids = isset($orders_by_group[$gid]) ? $orders_by_group[$gid] : array();

        if (empty($order_ids)) continue;
        // Find the most overdue order (earliest due_date) across ALL orders
        $worst_due = null;
        $worst_due_ts = PHP_INT_MAX;
        foreach ($order_ids as $oid) {
            $d_due = get_post_meta($oid, 'due_date', true);
            if (!$d_due) continue;
            $d_ts = function_exists('b2b_parse_due_date_ts') ? b2b_parse_due_date_ts($d_due) : strtotime($d_due);
            if ($d_ts && $d_ts < $worst_due_ts) { $worst_due_ts = $d_ts; $worst_due = $d_due; }
        }
        $due = $worst_due;
        if (!$due) continue;

        $gid = get_field('line_group_id', $d->ID);
        $name = get_the_title($d->ID);
        if (!$gid) continue;

        // Fix: ใช้ robust parser ที่ handle dd/mm/yyyy จาก ACF ถูกต้อง
        $due_ts = function_exists('b2b_parse_due_date_ts') ? b2b_parse_due_date_ts($due) : strtotime($due);
        if (!$due_ts) continue;

        $now_ts = strtotime(b2b_date('Y-m-d') . ' 00:00:00');
        $days_until_due = (int)(($due_ts - $now_ts) / DAY_IN_SECONDS);
        $days_overdue = -$days_until_due;

        // Auto-release credit hold if not actually overdue (>= 5 days)
        if ($days_overdue < 5 && get_field('credit_hold', $d->ID)) {
            update_field('credit_hold', false, $d->ID);
            b2b_push_to_admin("✅ ปลด Credit Hold: ".$name." (ไม่เกินกำหนดแล้ว)");
            b2b_log("[Dunning] Released hold: {$name} — days_overdue={$days_overdue}");
        }

        $bot_on = b2b_is_bot_enabled_for_group($gid);

        if ($days_until_due == 2) {
            if ($bot_on) {
                $flex = b2b_build_flex_dunning_friendly($name, $debt, $days_until_due);
                b2b_line_push_raw($gid, array($flex));
                update_post_meta($d->ID, '_b2b_dunning_last_sent', $today_str); // V.30.6
            } else {
                b2b_log("[Dunning] Bot disabled — skip LINE push for {$name}");
            }
            b2b_log("[Dunning] Friendly: {$name} — due in 2 days");
            $count++;
        }
        elseif ($days_until_due == 0) {
            if ($bot_on) {
                $flex = b2b_build_flex_dunning_official($name, $debt, 0);
                b2b_line_push_raw($gid, array($flex));
                update_post_meta($d->ID, '_b2b_dunning_last_sent', $today_str); // V.30.6
            } else {
                b2b_log("[Dunning] Bot disabled — skip LINE push for {$name}");
            }
            b2b_push_to_admin("⚠️ วันนี้ครบกำหนดชำระ: ".$name." — ฿".number_format($debt,0));
            $count++;
        }
        elseif ($days_overdue >= 1 && $days_overdue <= 4) {
            if ($bot_on) {
                $flex = b2b_build_flex_dunning_official($name, $debt, $days_overdue);
                b2b_line_push_raw($gid, array($flex));
                update_post_meta($d->ID, '_b2b_dunning_last_sent', $today_str); // V.30.6
            } else {
                b2b_log("[Dunning] Bot disabled — skip LINE push for {$name}");
            }
            b2b_push_to_admin("🔴 เลยกำหนดชำระ ".$days_overdue." วัน: ".$name." — ฿".number_format($debt,0));
            $count++;
        }
        elseif ($days_overdue >= 5) {
            update_field('credit_hold', true, $d->ID);
            if ($bot_on) {
                $flex = b2b_build_flex_dunning_final($name, $debt);
                b2b_line_push_raw($gid, array($flex));
                update_post_meta($d->ID, '_b2b_dunning_last_sent', $today_str); // V.30.6
            } else {
                b2b_log("[Dunning] Bot disabled — skip LINE push for {$name}");
            }
            b2b_push_to_admin("⛔ Credit Hold: ".$name." — ฿".number_format($debt,0)." (เลย ".$days_overdue." วัน)");
            $count++;
        }
    }

    b2b_log("[Cron] Dunning done — {$count} notified");
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_dunning_process FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_dunning_process FATAL: ' . $e->getMessage());
    }
}

// ════════════════════════════════════════════
// 2. DAILY SUMMARY
// ════════════════════════════════════════════
add_action( 'b2b_daily_summary_cron', 'b2b_run_daily_summary' );

function b2b_run_daily_summary() {
    try {
    if ( !defined('B2B_ADMIN_GROUP_ID') ) return;
    b2b_log('[Cron] Daily summary start');

    $today = b2b_date('Y-m-d');
    $date_display = b2b_date('d/m/Y');

    // ── 1. Today's orders (all non-cancelled created today) ──
    $today_orders = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'date_query'=>array(array('after'=>$today.' 00:00:00','before'=>$today.' 23:59:59','inclusive'=>true)),
        'meta_query'=>array(array('key'=>'order_status','value'=>'cancelled','compare'=>'!=')),
    ));

    $total_revenue = 0;
    $dist_sales = array();
    foreach ($today_orders as $o) {
        $amt = floatval(get_field('total_amount', $o->ID));
        $total_revenue += $amt;
        $gid = get_field('source_group_id', $o->ID);
        if ($gid) {
            if (!isset($dist_sales[$gid])) {
                $dist = function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
                $dname = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : 'Unknown';
                $dist_sales[$gid] = array('name'=>$dname, 'total'=>0);
            }
            $dist_sales[$gid]['total'] += $amt;
        }
    }

    // ── 2. Shipped today ──
    $shipped_today_ids = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(
            array('key'=>'order_status','value'=>'shipped'),
            array('key'=>'shipped_date','value'=>$today,'compare'=>'LIKE'),
        ),'fields'=>'ids',
    ));
    $shipped_count = count($shipped_today_ids);
    $shipped_amount = 0;
    foreach ($shipped_today_ids as $sid) {
        $shipped_amount += floatval(get_field('total_amount', $sid));
    }

    // ── 3. Paid today (transition → paid today via status history) ──
    $paid_all = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>'paid')),
        'date_query'=>array(array('column'=>'post_modified','after'=>$today.' 00:00:00')),
        'fields'=>'ids',
    ));
    $paid_count = 0;
    $paid_amount = 0;
    foreach ($paid_all as $pid) {
        $history = get_post_meta($pid, '_b2b_status_history', true);
        if (!is_array($history)) continue;
        foreach ($history as $h) {
            if ($h['to'] === 'paid' && !empty($h['at']) && strpos($h['at'], $today) === 0) {
                $paid_count++;
                $paid_amount += floatval(get_field('total_amount', $pid));
                break;
            }
        }
    }

    // ── 4. Pipeline status counts + amounts ──
    $pipeline_defs = array(
        'checking_stock'   => '🔍 เช็คสต็อก',
        'awaiting_confirm' => '📋 รอยืนยัน',
        'awaiting_payment' => '💳 รอชำระเงิน',
        'paid'             => '✅ ชำระแล้ว (รอส่ง)',
        'shipped'          => '🚚 กำลังส่ง',
        'backorder'        => '🚫 Backorder',
        'cancel_requested' => '⚠️ ขอยกเลิก',
        'claim_opened'     => '↩️ เคลม',
    );
    global $wpdb;
    $pipeline_raw = $wpdb->get_results("
        SELECT s.meta_value AS status,
               COUNT(*) AS cnt,
               COALESCE(SUM(CAST(a.meta_value AS DECIMAL(12,2))), 0) AS total_amt
        FROM {$wpdb->posts} p
        INNER JOIN {$wpdb->postmeta} s ON p.ID = s.post_id AND s.meta_key = 'order_status'
        LEFT JOIN {$wpdb->postmeta} a ON p.ID = a.post_id AND a.meta_key = 'total_amount'
        WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
        GROUP BY s.meta_value
    ", ARRAY_A);
    $pipeline_map = array();
    foreach ($pipeline_raw as $row) {
        $pipeline_map[$row['status']] = array(
            'count'  => intval($row['cnt']),
            'amount' => floatval($row['total_amt']),
        );
    }
    $pipeline = array();
    foreach ($pipeline_defs as $status => $label) {
        $d = isset($pipeline_map[$status]) ? $pipeline_map[$status] : array('count' => 0, 'amount' => 0);
        $pipeline[] = array('label' => $label, 'count' => $d['count'], 'amount' => $d['amount']);
    }

    // ── 5. Pending shipment + per-order details (ค้างจัดส่ง) ──
    $pending_ship = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>array('awaiting_payment','paid'),'compare'=>'IN')),
        'orderby'=>'date','order'=>'ASC',
    ));
    $ship_urgent = 0; $ship_urgent_amt = 0;
    $ship_normal = 0; $ship_normal_amt = 0;
    $ship_urgent_details = array();
    $ship_normal_details = array();
    foreach ($pending_ship as $o) {
        $days = (int) floor((time() - get_post_time('U', true, $o->ID)) / 86400);
        $amt = floatval(get_field('total_amount', $o->ID));
        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $detail = array('id'=>$o->ID, 'shop'=>$shop, 'days'=>$days, 'amt'=>$amt);
        if ($days >= 2) { $ship_urgent++; $ship_urgent_amt += $amt; $ship_urgent_details[] = $detail; }
        else { $ship_normal++; $ship_normal_amt += $amt; $ship_normal_details[] = $detail; }
    }

    // ── 6. MTD revenue (month-to-date) ──
    $month_start = b2b_date('Y-m-01');
    $mtd_ids = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'date_query'=>array(array('after'=>$month_start.' 00:00:00','before'=>$today.' 23:59:59','inclusive'=>true)),
        'meta_query'=>array(array('key'=>'order_status','value'=>array('cancelled','cancel_requested'),'compare'=>'NOT IN')),
        'fields'=>'ids',
    ));
    $mtd_revenue = 0;
    foreach ($mtd_ids as $mid) $mtd_revenue += floatval(get_field('total_amount', $mid));

    // ── 7. Outstanding debt + credit holds ──
    $dists = get_posts(array('post_type'=>'distributor','posts_per_page'=>-1,'post_status'=>'publish'));
    $total_outstanding = 0;
    $credit_holds = 0;
    foreach ($dists as $d) {
        $debt = floatval(get_field('current_debt', $d->ID));
        if ($debt > 0) $total_outstanding += $debt;
        if (get_field('credit_hold', $d->ID)) $credit_holds++;
    }

    // ── 8. Top 3 distributors today ──
    uasort($dist_sales, function($a, $b) { return $b['total'] <=> $a['total']; });
    $top_distributors = array();
    foreach (array_slice($dist_sales, 0, 3, true) as $ds) {
        if ($ds['total'] <= 0) continue;
        $top_distributors[] = array('name'=>$ds['name'], 'amount'=>$ds['total']);
    }

    // ── 9. Alerts ──
    $alerts = array();
    if ($ship_urgent > 0) {
        $alerts[] = '📦 ' . $ship_urgent . ' ออเดอร์ค้างส่งเกิน 2 วัน (฿' . number_format($ship_urgent_amt, 0) . ')';
    }
    if ($credit_holds > 0) {
        $alerts[] = '⛔ ' . $credit_holds . ' ร้านถูก Credit Hold';
    }
    // pipeline[5] = backorder, pipeline[7] = claim_opened
    if ($pipeline[5]['count'] > 0) {
        $alerts[] = '🚫 ' . $pipeline[5]['count'] . ' Backorder ค้าง';
    }
    if ($pipeline[7]['count'] > 0) {
        $alerts[] = '↩️ ' . $pipeline[7]['count'] . ' เคลมรอดำเนินการ';
    }

    // ── 10. Build Flex and push ──
    $admin_group_id = B2B_ADMIN_GROUP_ID;
    if ( function_exists('b2b_is_bot_enabled_for_group') && !b2b_is_bot_enabled_for_group($admin_group_id) ) {
        b2b_log('[Cron] Daily summary skipped — bot disabled for admin group');
    } elseif ( function_exists('b2b_build_flex_daily_summary') ) {
        $flex = b2b_build_flex_daily_summary(array(
            'date'              => $date_display,
            'new_orders'        => count($today_orders),
            'total_revenue'     => $total_revenue,
            'shipped_count'     => $shipped_count,
            'shipped_amount'    => $shipped_amount,
            'paid_count'        => $paid_count,
            'paid_amount'       => $paid_amount,
            'pipeline'          => $pipeline,
            'ship_total'        => $ship_urgent + $ship_normal,
            'ship_total_amt'    => $ship_urgent_amt + $ship_normal_amt,
            'ship_urgent'       => $ship_urgent,
            'ship_urgent_amt'   => $ship_urgent_amt,
            'ship_normal'       => $ship_normal,
            'ship_normal_amt'   => $ship_normal_amt,
            'ship_urgent_details' => $ship_urgent_details,
            'ship_normal_details' => $ship_normal_details,
            'mtd_revenue'       => $mtd_revenue,
            'total_outstanding' => $total_outstanding,
            'credit_holds'      => $credit_holds,
            'top_distributors'  => $top_distributors,
            'alerts'            => $alerts,
        ));
        b2b_push_raw_to_admin(array($flex));
    } else {
        // Fallback: plain text if S1 builder not available
        $msg = "📊 Daily Summary — " . $date_display . "\n";
        $msg .= "💰 ยอดวันนี้: ฿" . number_format($total_revenue, 0) . " (" . count($today_orders) . " ออเดอร์)\n";
        $msg .= "📦 ค้างส่ง: " . ($ship_urgent + $ship_normal) . " (เกิน 2 วัน: " . $ship_urgent . ")\n";
        if (!empty($ship_urgent_details)) {
            $msg .= "\n⚠️ ค้างเกิน 2 วัน:\n";
            foreach ($ship_urgent_details as $u) {
                $msg .= "  🔴 #".$u['id']." ".$u['shop']." — ".$u['days']." วัน · ฿".number_format($u['amt'],0)."\n";
            }
        }
        if (!empty($ship_normal_details)) {
            $msg .= "\n✅ ไม่เกิน 2 วัน:\n";
            foreach ($ship_normal_details as $n) {
                $msg .= "  📦 #".$n['id']." ".$n['shop']." — ".$n['days']." วัน · ฿".number_format($n['amt'],0)."\n";
            }
        }
        b2b_push_to_admin($msg);
    }

    b2b_log('[Cron] Daily summary done — ' . count($today_orders) . ' orders, ฿' . number_format($total_revenue, 0));
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_daily_summary FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_daily_summary FATAL: ' . $e->getMessage());
    }
}

