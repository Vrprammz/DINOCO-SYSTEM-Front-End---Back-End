// HELPER: Check if bot is enabled for a distributor group
// ════════════════════════════════════════════
if ( ! function_exists( 'b2b_is_bot_enabled_for_group' ) ) {
    function b2b_is_bot_enabled_for_group( $group_id ) {
        if ( empty( $group_id ) ) return true;
        global $wpdb;
        $val = $wpdb->get_var( $wpdb->prepare(
            "SELECT pm2.meta_value FROM {$wpdb->postmeta} pm1
             JOIN {$wpdb->posts} p ON p.ID = pm1.post_id AND p.post_type = 'distributor'
             JOIN {$wpdb->postmeta} pm2 ON pm2.post_id = pm1.post_id AND pm2.meta_key = 'bot_enabled'
             WHERE pm1.meta_key = 'line_group_id' AND pm1.meta_value = %s LIMIT 1",
            $group_id
        ) );
        return $val !== '0';
    }
}

