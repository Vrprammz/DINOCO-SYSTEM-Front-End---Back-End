// 5. DELIVERY CONFIRMATION (C3)
// ⚠️ Function ประกาศใน S2 (Webhook) — S7 hook เท่านั้น ห้ามประกาศซ้ำ
// ⚠️ ถ้า S2 ไม่ได้ active → fallback ประกาศที่นี่
// ════════════════════════════════════════════
if ( ! function_exists( 'b2b_handle_delivery_check' ) ) {
    function b2b_handle_delivery_check( $ticket_id ) {
        try {
        if ( get_post_type($ticket_id) !== 'b2b_order' ) return;
        $status = get_field('order_status', $ticket_id);
        if ( $status !== 'shipped' ) return;

        $group_id = get_field('source_group_id', $ticket_id);
        if (!$group_id) return;

        if (!b2b_is_bot_enabled_for_group($group_id)) {
            b2b_log("[Delivery] Bot disabled — skip LINE push for #{$ticket_id}");
            return;
        }

        $flex = b2b_build_flex_delivery_ask($ticket_id);
        // V.30.3: guaranteed push — retry on fail
        if ( function_exists( 'b2b_push_guaranteed' ) ) {
            b2b_push_guaranteed( $group_id, array( $flex ), $ticket_id, 'delivery_check' );
        } else {
            b2b_line_push_raw( $group_id, array( $flex ) );
        }

        b2b_log("[Delivery] Asked confirmation for #{$ticket_id}");
