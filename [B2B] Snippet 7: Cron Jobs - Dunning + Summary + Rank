// 3. RANK UPDATE (1st of month)
// ════════════════════════════════════════════
add_action( 'b2b_rank_update_event', 'b2b_run_rank_update' );

function b2b_run_rank_update() {
    try {
    // Guard: only run on 1st of month (scheduled as daily_b2b but should be monthly)
    if ( (int) b2b_date('j') !== 1 ) return;
    b2b_log('[Cron] Rank update start');
    $dists = get_posts(array('post_type'=>'distributor','posts_per_page'=>-1,'post_status'=>'publish'));

    $thresholds = array(
        'diamond'  => 500000,
        'platinum' => 200000,
        'gold'     => 100000,
        'silver'   => 50000,
        'standard' => 0,
    );

    foreach ($dists as $d) {
        $mtd = floatval(get_field('monthly_sales_mtd', $d->ID));
        $new_rank = 'standard';
        foreach ($thresholds as $rank => $min) {
            if ($mtd >= $min) { $new_rank = $rank; break; }
        }

        $old_rank = get_field('rank_system', $d->ID) ?: 'standard';
        if ($new_rank !== $old_rank) {
            update_field('rank_system', $new_rank, $d->ID);
            $gid = get_field('line_group_id', $d->ID);
            if ($gid) {
                if (b2b_is_bot_enabled_for_group($gid)) {
                    $labels = array('standard'=>'⭐','silver'=>'🥈','gold'=>'🥇','platinum'=>'💎','diamond'=>'💠');
                    $icon = isset($labels[$new_rank]) ? $labels[$new_rank] : '⭐';
                    b2b_line_push($gid, $icon." Rank อัพเดท!\nยอดเดือนที่ผ่านมา: ฿".number_format($mtd,0)."\nRank ใหม่: ".ucfirst($new_rank)."\n\nขอบคุณที่ไว้วางใจ DINOCO ครับ 🙏");
                } else {
                    b2b_log("[Rank] Bot disabled — skip LINE push for " . get_the_title($d->ID));
                }
            }
        }

        update_field('prev_month_sales', $mtd, $d->ID);
        update_field('monthly_sales_mtd', 0, $d->ID);
    }

    b2b_log('[Cron] Rank update done');
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_rank_update FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_rank_update FATAL: ' . $e->getMessage());
    }
}

