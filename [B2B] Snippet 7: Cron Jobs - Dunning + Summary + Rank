// 4. BO OVERDUE CHECK
// ════════════════════════════════════════════
add_action( 'b2b_bo_overdue_check', 'b2b_run_bo_overdue_check' );

function b2b_run_bo_overdue_check() {
    try {
    if ( !defined('B2B_ADMIN_GROUP_ID') ) return;
    b2b_log('[Cron] BO overdue check');

    $bo_tickets = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(
            array('key'=>'order_status','value'=>'backorder'),
            array('key'=>'bo_eta_date','value'=>'','compare'=>'!='),
        ),
    ));

    $today = b2b_date('Y-m-d');
    $count = 0;

    foreach ($bo_tickets as $t) {
        $eta = get_field('bo_eta_date', $t->ID);
        if (!$eta) continue;
        // Fix: ใช้ robust parser ที่ handle dd/mm/yyyy จาก ACF ถูกต้อง
        $eta_ts = function_exists('b2b_parse_due_date_ts') ? b2b_parse_due_date_ts($eta) : strtotime($eta);
        if (!$eta_ts || $eta_ts > strtotime(b2b_date('Y-m-d') . ' 00:00:00')) continue;

        $group_id = get_field('source_group_id', $t->ID);
        $dist = $group_id ? b2b_get_dist_by_group($group_id) : null;
        $dist_name = $dist ? get_the_title($dist->ID) : 'Unknown';

        $flex = b2b_build_flex_bo_overdue($t->ID, b2b_parse_date($eta), $dist_name);
        b2b_push_raw_to_admin(array($flex));

        if ($group_id) {
            if (b2b_is_bot_enabled_for_group($group_id)) {
                b2b_line_push($group_id, "⚠️ Ticket #".$t->ID." — สินค้า Backorder เกิน ETA แล้วครับ\nทีมงานกำลังตรวจสอบสถานะสินค้าให้ กรุณารอสักครู่");
            } else {
                b2b_log("[BO Overdue] Bot disabled — skip LINE push for group {$group_id}");
            }
        }

        $count++;
    }

    b2b_log("[Cron] BO overdue: {$count} tickets overdue");
    } catch ( Exception $e ) {
        b2b_log('[Cron] b2b_run_bo_overdue_check FAILED: ' . $e->getMessage());
    } catch ( Error $e ) {
        b2b_log('[Cron] b2b_run_bo_overdue_check FATAL: ' . $e->getMessage());
    }
}

