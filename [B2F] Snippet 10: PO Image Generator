if ( ! function_exists( 'b2f_generate_po_pages' ) ) {
    function b2f_generate_po_pages( $po_id ) {
        if ( ! function_exists( 'imagecreatetruecolor' ) || ! function_exists( 'imagettftext' ) ) {
            if ( function_exists( 'b2f_log' ) ) b2f_log( '[PO-IMG] GD/FreeType not available' );
            return false;
        }

        $font  = b2f_po_get_font( false );
        $fontB = b2f_po_get_font( true );
        if ( ! $font ) return false;
        if ( ! $fontB ) $fontB = $font;

        $upload = wp_upload_dir();
        $dir = $upload['basedir'] . '/b2f-po';
        if ( ! file_exists( $dir ) ) wp_mkdir_p( $dir );
        // ลบไฟล์เก่า
        $old = glob( $dir . '/po-' . $po_id . '-*.png' );
        if ( ! empty( $old ) ) array_map( 'unlink', $old );

        // ── PO Data ──
        $po_number = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;
        $maker_id  = get_field( 'po_maker_id', $po_id );
        $maker_name = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ) : 'โรงงาน';
        $maker_addr = is_numeric( $maker_id ) ? ( get_field( 'maker_address', $maker_id ) ?: '' ) : '';
        $maker_contact = is_numeric( $maker_id ) ? ( get_field( 'maker_contact', $maker_id ) ?: '' ) : '';
        $maker_phone = is_numeric( $maker_id ) ? ( get_field( 'maker_phone', $maker_id ) ?: '' ) : '';
        $items     = get_field( 'po_items', $po_id ) ?: array();
        $total     = floatval( get_field( 'po_total_amount', $po_id ) ?: 0 );
        $note      = get_field( 'po_admin_note', $po_id ) ?: '';
        $requested = get_field( 'po_requested_date', $po_id );
        $credit_term = get_field( 'maker_credit_term_days', is_numeric( $maker_id ) ? $maker_id : 0 ) ?: 30;
        $po_date   = get_the_date( 'd/m/Y', $po_id );

        // ── Parse items ──
        $parsed = array();
        foreach ( $items as $item ) {
            $qty  = intval( $item['poi_qty_ordered'] ?? 0 );
            $cost = floatval( $item['poi_unit_cost'] ?? 0 );
            $parsed[] = array(
                'sku'   => $item['poi_sku'] ?? '',
                'name'  => $item['poi_product_name'] ?? $item['poi_sku'] ?? '',
                'qty'   => $qty,
                'price' => $cost,
                'total' => $qty * $cost,
            );
        }

        // ── Pagination ──
        $first_max = 12;
        $extra_max = 18;
        $pages_data = array();
        if ( count( $parsed ) <= $first_max ) {
            $pages_data[] = $parsed;
        } else {
            $pages_data[] = array_slice( $parsed, 0, $first_max );
            $rest = array_slice( $parsed, $first_max );
            while ( ! empty( $rest ) ) {
                $pages_data[] = array_slice( $rest, 0, $extra_max );
                $rest = array_slice( $rest, $extra_max );
            }
        }
        $total_pages = count( $pages_data );

        // ── Company info ──
        $company = 'บริษัท พีพีที กรุ๊ป คอร์ปอเรชั่น จำกัด';
        $company_addr = 'รามอินทรา 14 แขวงท่าแร้ง เขตบางเขน กรุงเทพฯ 10220';
        $company_tel = '061-639-9994';

        $W = B2F_PO_W; $H = B2F_PO_H; $MX = B2F_PO_MX;
        $content_w = $W - 2 * $MX;
        // Table columns: # | SKU | Name | Qty | Price | Total
        $cols = array( 60, 160, 440, 100, 180, 180 ); // = 1120

        $urls = array();
        $item_idx = 0;

        for ( $pg = 0; $pg < $total_pages; $pg++ ) {
            $img = imagecreatetruecolor( $W, $H );
            $white   = imagecolorallocate( $img, 255, 255, 255 );
            $black   = imagecolorallocate( $img, 30, 41, 59 );
            $gray    = imagecolorallocate( $img, 100, 116, 139 );
            $lgray   = imagecolorallocate( $img, 226, 232, 240 );
            $zebra   = imagecolorallocate( $img, 248, 250, 252 );
            $amber   = imagecolorallocate( $img, 217, 119, 6 );
            $navy    = imagecolorallocate( $img, 15, 36, 71 );
            $green   = imagecolorallocate( $img, 5, 150, 105 );
            imagefill( $img, 0, 0, $white );

            $y = 40;

            if ( $pg === 0 ) {
                // ── HEADER ──
                // Logo
                $logo = b2f_po_get_logo_gd();
                if ( $logo ) {
                    $lw = imagesx( $logo ); $lh = imagesy( $logo );
                    $target_h = 70; $ratio = $target_h / $lh; $target_w = (int)( $lw * $ratio );
                    $resized = imagecreatetruecolor( $target_w, $target_h );
                    imagealphablending( $resized, false ); imagesavealpha( $resized, true );
                    $trans = imagecolorallocatealpha( $resized, 0, 0, 0, 127 );
                    imagefill( $resized, 0, 0, $trans );
                    imagecopyresampled( $resized, $logo, 0, 0, 0, 0, $target_w, $target_h, $lw, $lh );
                    imagecopy( $img, $resized, $MX, $y, 0, 0, $target_w, $target_h );
                    imagedestroy( $resized ); imagedestroy( $logo );
                }

                // Company name + address (ขวาของ logo)
                b2f_po_text( $img, 14, $MX + 90, $y + 20, $company, $fontB, $navy );
                b2f_po_text( $img, 10, $MX + 90, $y + 40, $company_addr, $font, $gray );
                b2f_po_text( $img, 10, $MX + 90, $y + 55, 'โทร: ' . $company_tel, $font, $gray );

                // Title: ใบสั่งซื้อ / PURCHASE ORDER
                $y += 90;
                b2f_po_text( $img, 22, $MX, $y, 'ใบสั่งซื้อ / PURCHASE ORDER', $fontB, $amber, 'center', $content_w );
                $y += 15;
                // PO Number
                b2f_po_text( $img, 12, 0, $y, 'เลขที่: ' . $po_number, $fontB, $navy, 'right', $W - $MX );
                $y += 20;
                b2f_po_line( $img, $y, $lgray );
                $y += 15;

                // ── INFO SECTION ──
                $info_left_x = $MX;
                $info_right_x = $MX + 600;

                // ผู้ขาย (Maker)
                b2f_po_text( $img, 11, $info_left_x, $y, 'ผู้ขาย (Supplier)', $fontB, $gray );
                b2f_po_text( $img, 11, $info_right_x, $y, 'ข้อมูลใบสั่งซื้อ', $fontB, $gray );
                $y += 22;
                b2f_po_text( $img, 13, $info_left_x, $y, $maker_name, $fontB, $black );
                b2f_po_text( $img, 11, $info_right_x, $y, 'วันที่ออก: ' . $po_date, $font, $black );
                $y += 20;
                if ( $maker_addr ) { b2f_po_text( $img, 10, $info_left_x, $y, $maker_addr, $font, $gray ); }
                if ( $requested ) { b2f_po_text( $img, 11, $info_right_x, $y, 'ต้องการรับภายใน: ' . date( 'd/m/Y', strtotime( $requested ) ), $font, $green ); }
                $y += 18;
                if ( $maker_contact ) { b2f_po_text( $img, 10, $info_left_x, $y, 'ผู้ติดต่อ: ' . $maker_contact, $font, $gray ); }
                b2f_po_text( $img, 11, $info_right_x, $y, 'เงื่อนไข: เครดิต ' . $credit_term . ' วัน', $font, $black );
                $y += 18;
                if ( $maker_phone ) { b2f_po_text( $img, 10, $info_left_x, $y, 'โทร: ' . $maker_phone, $font, $gray ); }
                $y += 25;
                b2f_po_line( $img, $y, $lgray );
                $y += 15;
            } // end header (page 0 only)

            // ── TABLE HEADER ──
            $tx = $MX;
            imagefilledrectangle( $img, $MX, $y - 5, $W - $MX, $y + 25, $navy );
            $headers = array( '#', 'SKU', 'ชื่อสินค้า', 'จำนวน', 'ราคา/หน่วย', 'รวม' );
            $aligns  = array( 'center', 'left', 'left', 'center', 'right', 'right' );
            $cx = $MX;
            foreach ( $headers as $hi => $ht ) {
                b2f_po_text( $img, 10, $cx + 5, $y + 15, $ht, $fontB, $white, $aligns[ $hi ], $cols[ $hi ] - 10 );
                $cx += $cols[ $hi ];
            }
            $y += 30;

            // ── TABLE ROWS ──
            $page_items = $pages_data[ $pg ];
            foreach ( $page_items as $ri => $row ) {
                $item_idx++;
                $row_bg = ( $ri % 2 === 1 ) ? $zebra : $white;
                imagefilledrectangle( $img, $MX, $y - 2, $W - $MX, $y + 28, $row_bg );

                $cx = $MX;
                $vals = array(
                    strval( $item_idx ),
                    mb_substr( $row['sku'], 0, 18 ),
                    mb_substr( $row['name'], 0, 35 ),
                    number_format( $row['qty'] ),
                    number_format( $row['price'], 2 ),
                    number_format( $row['total'], 2 ),
                );
                foreach ( $vals as $vi => $vt ) {
                    b2f_po_text( $img, 10, $cx + 5, $y + 18, $vt, $font, $black, $aligns[ $vi ], $cols[ $vi ] - 10 );
                    $cx += $cols[ $vi ];
                }
                // Row bottom line
                imageline( $img, $MX, $y + 30, $W - $MX, $y + 30, $lgray );
                $y += 32;
            }

            // ── SUMMARY + SIGNATURE (last page only) ──
            if ( $pg === $total_pages - 1 ) {
                $y += 20;
                // Summary box
                $box_x = $W - $MX - 400;
                imagefilledrectangle( $img, $box_x, $y, $W - $MX, $y + 50, imagecolorallocate( $img, 255, 251, 235 ) );
                imagerectangle( $img, $box_x, $y, $W - $MX, $y + 50, $amber );
                b2f_po_text( $img, 12, $box_x + 15, $y + 22, 'ยอดรวมทั้งสิ้น', $fontB, $black );
                b2f_po_text( $img, 16, 0, $y + 22, '฿' . number_format( $total, 2 ), $fontB, $amber, 'right', $W - $MX - 15 );
                $y += 55;
                // Baht text
                $btxt = '(' . b2f_baht_text( $total ) . ')';
                b2f_po_text( $img, 10, 0, $y + 5, $btxt, $font, $gray, 'right', $W - $MX );
                $y += 25;

                // Note
                if ( $note ) {
                    $y += 10;
                    b2f_po_text( $img, 10, $MX, $y, 'หมายเหตุ: ' . mb_substr( $note, 0, 80 ), $font, $gray );
                    $y += 20;
                }

                // ── SIGNATURE ──
                $y += 30;
                b2f_po_line( $img, $y, $lgray );
                $y += 30;

                $sig_left = $MX + 50;
                $sig_right = $W - $MX - 350;

                b2f_po_text( $img, 11, $sig_left, $y, 'ผู้สั่งซื้อ (Buyer)', $fontB, $black );
                b2f_po_text( $img, 11, $sig_right, $y, 'ผู้รับคำสั่งซื้อ (Supplier)', $fontB, $black );
                $y += 40;

                // Digital signature
                b2f_po_text( $img, 14, $sig_left, $y, 'DINOCO SYSTEM', $fontB, $navy );
                // Maker signature line
                imageline( $img, $sig_right, $y + 5, $sig_right + 250, $y + 5, $gray );
                $y += 25;

                b2f_po_text( $img, 10, $sig_left, $y, 'วันที่ ' . $po_date, $font, $gray );
                b2f_po_text( $img, 10, $sig_right, $y, 'วันที่ ..............................', $font, $gray );
            }

            // ── FOOTER ──
            $footer_y = $H - 40;
            b2f_po_text( $img, 9, $MX, $footer_y, 'หน้า ' . ( $pg + 1 ) . '/' . $total_pages, $font, $gray, 'center', $content_w );

            // ── SAVE ──
            $filepath = $dir . '/po-' . $po_id . '-' . ( $pg + 1 ) . '.png';
            imagepng( $img, $filepath, 6 );
            imagedestroy( $img );

            $urls[] = $upload['baseurl'] . '/b2f-po/po-' . $po_id . '-' . ( $pg + 1 ) . '.png';
        }

        // Save URLs in meta
        update_post_meta( $po_id, '_po_image_urls', $urls );
        update_post_meta( $po_id, '_po_image_generated_at', time() );

        return $urls;
    }
}

// ════════════════════════════════════════════
// 6. SEND PO IMAGE TO LINE
// ════════════════════════════════════════════
if ( ! function_exists( 'b2f_send_po_image' ) ) {
    function b2f_send_po_image( $group_id, $po_id ) {
        if ( empty( $group_id ) ) return false;

        $urls = b2f_get_cached_po_pages( $po_id );
        if ( empty( $urls ) ) $urls = b2f_generate_po_pages( $po_id );
        if ( empty( $urls ) ) return false;

        // Send first page as image message
        $img_url = $urls[0];
        $messages = array( array(
            'type'               => 'image',
            'originalContentUrl' => $img_url,
            'previewImageUrl'    => $img_url,
        ) );

        if ( function_exists( 'b2f_line_push' ) ) {
            return b2f_line_push( $group_id, $messages );
        }
        return false;
    }
}

// ════════════════════════════════════════════
// 7. PO NUMBER GENERATOR (random 6 digits)
// ════════════════════════════════════════════
if ( ! function_exists( 'b2f_generate_po_number_v2' ) ) {
    /**
     * สร้างเลข PO: PO-DNC-XXXXXX (6 หลัก random ไม่ซ้ำ)
     */
    function b2f_generate_po_number_v2() {
        global $wpdb;
        $max_attempts = 10;
        for ( $i = 0; $i < $max_attempts; $i++ ) {
            $num = 'PO-DNC-' . str_pad( mt_rand( 0, 999999 ), 6, '0', STR_PAD_LEFT );
            $exists = $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->postmeta} WHERE meta_key = 'po_number' AND meta_value = %s", $num
            ) );
            if ( ! $exists ) return $num;
        }
        // Fallback: timestamp-based
        return 'PO-DNC-' . substr( time(), -6 );
    }
}
