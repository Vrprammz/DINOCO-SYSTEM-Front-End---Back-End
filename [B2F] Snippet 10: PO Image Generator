if ( ! function_exists( 'b2f_po_text' ) ) {
    function b2f_po_text( $img, $size, $x, $y, $text, $font, $color, $align = 'left', $max_w = 0 ) {
        if ( ! $font || ! $text ) return;
        $box = imagettfbbox( $size, 0, $font, $text );
        $tw = abs( $box[2] - $box[0] );
        if ( $align === 'center' && $max_w > 0 ) $x = $x + ( $max_w - $tw ) / 2;
        elseif ( $align === 'right' && $max_w > 0 ) $x = $x + $max_w - $tw;
        imagettftext( $img, $size, 0, (int) $x, (int) $y, $color, $font, $text );
    }
}

if ( ! function_exists( 'b2f_po_line' ) ) {
    function b2f_po_line( $img, $y, $color, $x1 = -1, $x2 = -1 ) {
        if ( $x1 < 0 ) $x1 = B2F_PO_MX;
        if ( $x2 < 0 ) $x2 = B2F_PO_W - B2F_PO_MX;
        imageline( $img, $x1, $y, $x2, $y, $color );
    }
}

