if ( ! function_exists( 'b2f_po_get_font' ) ) {
    function b2f_po_get_font( $bold = false ) {
        // Reuse B2B font ถ้ามี
        if ( function_exists( 'b2b_inv_get_font' ) ) return b2b_inv_get_font( $bold );

        $upload = wp_upload_dir();
        $dir = $upload['basedir'] . '/b2b-fonts';
        if ( ! file_exists( $dir ) ) wp_mkdir_p( $dir );
        $name = $bold ? 'Sarabun-Bold.ttf' : 'Sarabun-Regular.ttf';
        $file = $dir . '/' . $name;
        if ( file_exists( $file ) && filesize( $file ) > 50000 ) return $file;

        $urls = $bold ? array(
            'https://fonts.gstatic.com/s/sarabun/v15/DtVjJx26TKEr37c9YOZqik4s.ttf',
        ) : array(
            'https://fonts.gstatic.com/s/sarabun/v15/DtVjJx26TKEr37c9YL5rik4s.ttf',
        );
        foreach ( $urls as $url ) {
            $resp = wp_remote_get( $url, array( 'timeout' => 30, 'headers' => array( 'User-Agent' => 'Mozilla/5.0' ) ) );
            if ( ! is_wp_error( $resp ) && wp_remote_retrieve_response_code( $resp ) === 200 ) {
                $body = wp_remote_retrieve_body( $resp );
                if ( strlen( $body ) > 50000 ) { file_put_contents( $file, $body ); return $file; }
            }
        }
        $sys = '/usr/share/fonts/truetype/dejavu/DejaVuSans' . ( $bold ? '-Bold' : '' ) . '.ttf';
        return file_exists( $sys ) ? $sys : false;
    }
}

if ( ! function_exists( 'b2f_po_get_logo_gd' ) ) {
    function b2f_po_get_logo_gd() {
        if ( function_exists( 'b2b_inv_get_logo_gd' ) ) return b2b_inv_get_logo_gd();
        $url = 'https://dinoco.in.th/wp-content/uploads/2026/02/logodnc.png';
        $resp = wp_remote_get( $url, array( 'timeout' => 15 ) );
        if ( is_wp_error( $resp ) ) return false;
        $src = @imagecreatefromstring( wp_remote_retrieve_body( $resp ) );
        if ( $src ) { imagealphablending( $src, true ); imagesavealpha( $src, true ); }
        return $src ?: false;
    }
}

if ( ! function_exists( 'b2f_baht_text' ) ) {
    function b2f_baht_text( $amount ) {
        if ( function_exists( 'b2b_baht_text' ) ) return b2b_baht_text( $amount );
        $amount = round( $amount, 2 );
        if ( $amount == 0 ) return 'ศูนย์บาทถ้วน';
        $t1 = array( '', 'หนึ่ง', 'สอง', 'สาม', 'สี่', 'ห้า', 'หก', 'เจ็ด', 'แปด', 'เก้า' );
        $t2 = array( '', 'สิบ', 'ร้อย', 'พัน', 'หมื่น', 'แสน', 'ล้าน' );
        $baht = intval( $amount ); $sat = round( ( $amount - $baht ) * 100 ); $r = '';
        if ( $baht > 0 ) {
            $s = strval( $baht ); $len = strlen( $s );
            for ( $i = 0; $i < $len; $i++ ) {
                $d = intval( $s[ $i ] ); $p = $len - $i - 1;
                if ( $d == 0 ) continue;
                if ( $p == 1 && $d == 1 ) { $r .= 'สิบ'; continue; }
                if ( $p == 1 && $d == 2 ) { $r .= 'ยี่สิบ'; continue; }
                if ( $p == 0 && $d == 1 && $len > 1 ) { $r .= 'เอ็ด'; continue; }
                $r .= $t1[ $d ] . $t2[ $p % 6 ];
                if ( $p >= 6 && $p % 6 == 0 ) $r .= 'ล้าน';
            }
            $r .= 'บาท';
        }
        if ( $sat > 0 ) {
            $s2 = str_pad( strval( $sat ), 2, '0', STR_PAD_LEFT );
            $d1 = intval( $s2[0] ); $d2 = intval( $s2[1] );
            if ( $d1 == 1 ) $r .= 'สิบ'; elseif ( $d1 == 2 ) $r .= 'ยี่สิบ'; elseif ( $d1 > 0 ) $r .= $t1[ $d1 ] . 'สิบ';
            if ( $d2 == 1 && $d1 > 0 ) $r .= 'เอ็ด'; elseif ( $d2 > 0 ) $r .= $t1[ $d2 ];
            $r .= 'สตางค์';
        } else { $r .= 'ถ้วน'; }
        return $r;
    }
}

