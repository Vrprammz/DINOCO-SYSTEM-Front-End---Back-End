if ( ! function_exists( 'b2f_get_cached_po_pages' ) ) {
    function b2f_get_cached_po_pages( $po_id ) {
        $upload = wp_upload_dir();
        $dir = $upload['basedir'] . '/b2f-po';
        $base_url = $upload['baseurl'] . '/b2f-po';
        $pattern = $dir . '/po-' . $po_id . '-*.png';
        $files = glob( $pattern );
        if ( empty( $files ) ) return array();

        // Cache 1 ชม.
        if ( filemtime( $files[0] ) < time() - 3600 ) return array();

        sort( $files );
        $urls = array();
        foreach ( $files as $f ) {
            $urls[] = $base_url . '/' . basename( $f );
        }
        return $urls;
    }
}

