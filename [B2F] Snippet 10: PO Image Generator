// 1. REST ENDPOINT
// ════════════════════════════════════════════
add_action( 'rest_api_init', function () {
    register_rest_route( 'b2f/v1', '/po-image', array(
        'methods'  => 'GET',
        'callback' => 'b2f_rest_serve_po_image',
        'permission_callback' => function ( WP_REST_Request $req ) {
            if ( current_user_can( 'manage_options' ) ) return true;
            // Signed URL fallback
            $sig = sanitize_text_field( $req->get_param( '_sig' ) );
            $ts  = intval( $req->get_param( '_ts' ) );
            if ( $sig && $ts && abs( time() - $ts ) < 14400 ) {
                $secret = defined( 'B2B_LINE_CHANNEL_SECRET' ) ? B2B_LINE_CHANNEL_SECRET : wp_salt( 'auth' );
                $data = 'po-image|po_id=' . intval( $req->get_param( 'po_id' ) ) . '|_ts=' . $ts;
                $expected = substr( hash_hmac( 'sha256', $data, $secret ), 0, 16 );
                return hash_equals( $expected, $sig );
            }
            return false;
        },
    ) );
} );

if ( ! function_exists( 'b2f_rest_serve_po_image' ) ) {
    function b2f_rest_serve_po_image( WP_REST_Request $r ) {
        $po_id = intval( $r->get_param( 'po_id' ) );
        if ( ! $po_id || get_post_type( $po_id ) !== 'b2f_order' ) {
            return new WP_REST_Response( array( 'error' => 'Invalid po_id' ), 400 );
        }

        $format = sanitize_text_field( $r->get_param( 'format' ) );
        $urls = b2f_get_cached_po_pages( $po_id );
        if ( empty( $urls ) ) {
            $urls = b2f_generate_po_pages( $po_id );
        }
        if ( ! $urls ) return new WP_REST_Response( array( 'error' => 'Generation failed' ), 500 );

        if ( $format === 'json' ) {
            return new WP_REST_Response( array( 'success' => true, 'pages' => $urls ) );
        }

        if ( count( $urls ) === 1 ) {
            header( 'Location: ' . $urls[0], true, 302 );
            exit;
        }

        header( 'Content-Type: text/html; charset=UTF-8' );
        echo '<!DOCTYPE html><html lang="th"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">';
        echo '<title>PO #' . $po_id . '</title>';
        echo '<style>body{margin:0;padding:16px;background:#f1f5f9;font-family:sans-serif;text-align:center}img{max-width:100%;margin:8px auto;display:block;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.1)}</style>';
        echo '</head><body>';
        foreach ( $urls as $i => $url ) {
            echo '<p style="color:#64748b;font-size:13px;">หน้า ' . ( $i + 1 ) . '/' . count( $urls ) . '</p>';
            echo '<img src="' . esc_url( $url ) . '" alt="PO page ' . ( $i + 1 ) . '">';
        }
        echo '</body></html>';
        exit;
    }
}

