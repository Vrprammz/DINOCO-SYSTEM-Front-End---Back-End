<script>
(function() {
    'use strict';

    var root = document.querySelector('.b2b-warr-root');
    if (!root) return;
    var config = {};
    try { config = JSON.parse(root.dataset.config || '{}'); } catch (e) {}

    var sections = {
        input:    root.querySelector('[data-state="input"]'),
        scanning: root.querySelector('[data-state="scanning"]'),
        loading:  root.querySelector('[data-state="loading"]'),
        result:   root.querySelector('[data-state="result"]')
    };

    function showState(name) {
        Object.keys(sections).forEach(function(k) {
            sections[k].hidden = (k !== name);
        });
    }

    function normalizeSn(raw) {
        if (!raw) return '';
        var v = String(raw).trim().toUpperCase();
        // Allow URL form (?sn=DNCSS...) — extract sn param
        if (v.indexOf('SN=') !== -1) {
            try {
                var url = new URL(v.indexOf('://') === -1 ? 'https://x/?' + v : v);
                v = (url.searchParams.get('sn') || '').toUpperCase();
            } catch (e) {}
        }
        // Allow plain DNCSS prefix or full URL
        var match = v.match(/DNC[A-Z0-9]{4,16}/);
        return match ? match[0] : v;
    }

    function fmtBuddhistDate(iso) {
        if (!iso) return '—';
        var d = new Date(iso);
        if (isNaN(d.getTime())) return '—';
        var months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
        return d.getDate() + ' ' + months[d.getMonth()] + ' ' + (d.getFullYear() + 543);
    }

    function daysUntil(iso) {
        if (!iso) return null;
        var d = new Date(iso);
        if (isNaN(d.getTime())) return null;
        var now = new Date();
        return Math.ceil((d - now) / (1000 * 60 * 60 * 24));
    }

    function renderResult(data) {
        var badge = root.querySelector('#b2b-warr-result-badge');
        var title = root.querySelector('#b2b-warr-result-title');
        var snEl  = root.querySelector('#b2b-warr-result-sn');
        var body  = root.querySelector('#b2b-warr-result-body');

        var status = data.status || 'unknown';
        var sn = data.sn || '';
        snEl.textContent = 'S/N: ' + sn;

        var rows = [];
        var statusLabel, statusClass, badgeIcon;

        switch (status) {
            case 'registered':
                badgeIcon = '✅';
                statusLabel = 'ลงทะเบียนแล้ว';
                statusClass = 'positive';
                break;
            case 'claimed':
                badgeIcon = '🔧';
                statusLabel = 'กำลังเคลม';
                statusClass = 'warning';
                break;
            case 'replaced':
                badgeIcon = '🔄';
                statusLabel = 'เปลี่ยนสินค้าใหม่แล้ว';
                statusClass = 'warning';
                break;
            case 'stolen':
                badgeIcon = '🚨';
                statusLabel = 'แจ้งหาย — เพลทถูกล็อค';
                statusClass = 'danger';
                break;
            case 'voided':
            case 'recalled':
                badgeIcon = '⛔';
                statusLabel = 'ติดต่อร้านค้า';
                statusClass = 'danger';
                break;
            case 'in_pool':
            case 'shipped':
                badgeIcon = '📦';
                statusLabel = 'ยังไม่ลงทะเบียน';
                statusClass = 'warning';
                break;
            default:
                badgeIcon = '❓';
                statusLabel = 'ไม่พบข้อมูล';
                statusClass = 'danger';
        }

        badge.textContent = badgeIcon;
        title.textContent = statusLabel;
        title.className = 'b2b-warr-result-title';

        // Product info
        if (data.product) {
            var setName = data.product.top_set_name || data.product.linked_sku || '—';
            rows.push({ label: 'สินค้า', value: setName });
        }

        // Warranty info
        if (data.warranty && data.warranty.registered) {
            rows.push({ label: 'ลงทะเบียน', value: fmtBuddhistDate(data.warranty.registered_at) });

            if (data.warranty.warranty_until) {
                var until = fmtBuddhistDate(data.warranty.warranty_until);
                var days = daysUntil(data.warranty.warranty_until);
                var valueClass = '';
                if (days !== null) {
                    if (days < 0) valueClass = 'danger';
                    else if (days < 30) valueClass = 'warning';
                    else valueClass = 'positive';
                }
                rows.push({ label: 'ประกันถึง', value: until + (days !== null ? ' (' + (days < 0 ? 'หมดอายุ' : 'เหลือ ' + days + ' วัน') + ')' : ''), cls: valueClass });
            }

            if (data.warranty.owner_masked) {
                rows.push({ label: 'เจ้าของ', value: data.warranty.owner_masked });
            }
        } else if (status === 'in_pool' || status === 'shipped') {
            rows.push({ label: 'หมายเหตุ', value: 'ลูกค้ายังไม่ activate' });
        }

        body.innerHTML = rows.map(function(r) {
            var cls = r.cls ? ' ' + r.cls : '';
            return '<div class="b2b-warr-result-row"><span class="label">' + r.label + '</span><span class="value' + cls + '">' + r.value + '</span></div>';
        }).join('');
    }

    function fetchLookup(sn) {
        showState('loading');
        var url = config.rest_url + 'lookup/' + encodeURIComponent(sn);
        fetch(url, { method: 'GET', headers: { 'Accept': 'application/json' } })
            .then(function(r) {
                if (!r.ok && r.status !== 404) throw new Error('HTTP ' + r.status);
                return r.json().then(function(data) { return { ok: r.ok, status: r.status, data: data }; });
            })
            .then(function(res) {
                if (res.status === 404) {
                    renderResult({ status: 'not_found', sn: sn });
                } else if (res.ok) {
                    renderResult(res.data);
                } else {
                    renderResult({ status: 'error', sn: sn });
                }
                showState('result');
            })
            .catch(function(err) {
                renderResult({ status: 'error', sn: sn });
                showState('result');
            });
    }

    // ── Wire up: manual S/N check ──
    var btnCheck = root.querySelector('#b2b-warr-btn-check');
    var snInput = root.querySelector('#b2b-warr-sn-input');
    btnCheck.addEventListener('click', function() {
        var sn = normalizeSn(snInput.value);
        if (!sn || sn.length < 6) {
            snInput.focus();
            snInput.style.borderColor = '#dc2626';
            setTimeout(function() { snInput.style.borderColor = ''; }, 2000);
            return;
        }
        fetchLookup(sn);
    });
    snInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); btnCheck.click(); }
    });

    // ── Wire up: scan QR (lazy-load html5-qrcode CDN) ──
    var btnScan = root.querySelector('#b2b-warr-btn-scan');
    var btnCancelScan = root.querySelector('#b2b-warr-btn-cancel-scan');
    var scanner = null;

    function startScanner() {
        if (!window.Html5Qrcode) {
            var s = document.createElement('script');
            s.src = 'https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js';
            s.addEventListener('load', function() { startScanner(); });
            s.addEventListener('error', function() { alert('โหลด scanner ไม่สำเร็จ — กรุณาพิมพ์ S/N เอง'); showState('input'); });
            document.head.appendChild(s);
            return;
        }
        showState('scanning');
        scanner = new Html5Qrcode('b2b-warr-scanner-region');
        scanner.start(
            { facingMode: 'environment' },
            { fps: 10, qrbox: { width: 240, height: 240 } },
            function(decodedText) {
                stopScanner();
                var sn = normalizeSn(decodedText);
                if (sn) fetchLookup(sn);
                else { alert('QR ไม่ถูกต้อง'); showState('input'); }
            },
            function() {} // ignore scan errors
        ).catch(function() {
            alert('ไม่สามารถเปิดกล้องได้ — กรุณาอนุญาตสิทธิ์กล้องใน Settings');
            showState('input');
        });
    }
    function stopScanner() {
        if (scanner && scanner.isScanning) {
            scanner.stop().catch(function() {});
        }
    }

    btnScan.addEventListener('click', startScanner);
    btnCancelScan.addEventListener('click', function() {
        stopScanner();
        showState('input');
    });

    // ── Wire up: try again ──
    root.querySelector('#b2b-warr-btn-again').addEventListener('click', function() {
        snInput.value = '';
        showState('input');
        snInput.focus();
    });

    // ── Event delegation for [data-action] (UX-H3 compliant) ──
    root.addEventListener('click', function(e) {
        var t = e.target.closest('[data-action]');
        if (!t) return;
        if (t.dataset.action === 'back') {
            if (window.liff && liff.isInClient && liff.isInClient()) {
                liff.closeWindow();
            } else {
                history.back();
            }
        }
    });

    // ── LIFF init (D11 pattern — LINE OAuth + WP session) ──
    if (window.liff && config.liff_id) {
        liff.init({ liffId: config.liff_id })
            .then(function() {
                // No JWT — relies on existing WP session from LIFF login
                if (!liff.isLoggedIn() && liff.isInClient()) {
                    liff.login();
                }
            })
            .catch(function(e) {
                // Soft fail — page still works for manual S/N input
                console.warn('LIFF init failed', e);
            });
    }

    // ── Auto-check if ?sn=... in URL ──
    if (config.prefill_sn) {
        fetchLookup(config.prefill_sn);
    } else {
        showState('input');
    }
})();
</script>
        <?php
        return ob_get_clean();
    }
    add_shortcode( 'b2b_warranty_check', 'b2b_warr_render_page' );
}

