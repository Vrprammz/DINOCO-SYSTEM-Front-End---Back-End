// SECTION 3: Auto-create WP page on activation (idempotent)
// ═══════════════════════════════════════════════════════════════

if ( ! function_exists( 'b2b_warr_ensure_page' ) ) {
    function b2b_warr_ensure_page() {
        $existing = get_page_by_path( 'b2b-warranty-check' );
        if ( $existing ) return;

        // V.0.4 P0.3 — capture error if wp_insert_post fails (permission / DB lock / etc.)
        $result = wp_insert_post( array(
            'post_title'   => 'B2B Warranty Check',
            'post_name'    => 'b2b-warranty-check',
            'post_status'  => 'publish',
            'post_type'    => 'page',
            'post_content' => '[b2b_warranty_check]',
        ), true ); // 2nd arg true = return WP_Error on failure

        if ( is_wp_error( $result ) || $result === 0 ) {
            $err_msg = is_wp_error( $result ) ? $result->get_error_message() : 'insert returned 0';
            error_log( '[b2b_warr_ensure_page] Failed to create page: ' . $err_msg );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', 'warranty_check_page_create_failed', array(
                    'error'  => $err_msg,
                    'hint'   => 'customer scan QR will 404 — investigate WP permissions + DB lock',
                ) );
            }
        }
    }
    add_action( 'admin_init', 'b2b_warr_ensure_page', 20 );
}

// V.0.4 P0.3 NEW: health check endpoint (admin + ops can verify page alive without scanning QR)
if ( ! function_exists( 'b2b_warr_rest_health' ) ) {
    function b2b_warr_rest_health( $req ) {
        $page = get_page_by_path( 'b2b-warranty-check' );
        $exists = (bool) $page;
        return rest_ensure_response( array(
            'page_exists' => $exists,
            'page_id'     => $exists ? (int) $page->ID : null,
            'page_url'    => $exists ? get_permalink( $page->ID ) : null,
            'page_status' => $exists ? $page->post_status : null,
            'last_check'  => current_time( 'mysql' ),
            'shortcode'   => '[b2b_warranty_check]',
            'shortcode_registered' => shortcode_exists( 'b2b_warranty_check' ),
        ) );
    }
    add_action( 'rest_api_init', function() {
        register_rest_route( 'b2b/v1', '/warranty-check-health', array(
            'methods'             => 'GET',
            'callback'            => 'b2b_warr_rest_health',
            'permission_callback' => function() {
                return current_user_can( 'manage_options' );
            },
        ) );
    } );
}

