// ── Kill Switch ──
if ( defined( 'B2F_DISABLED' ) && B2F_DISABLED ) return;

add_action( 'template_redirect', function () {
    if ( ! is_page( 'b2f-catalog' ) ) return;

    if ( defined( 'B2F_DISABLED' ) && B2F_DISABLED ) {
        wp_die( 'ระบบปิดปรับปรุงชั่วคราว', 'B2F Disabled', array( 'response' => 503 ) );
    }

    // V.2.0: ไม่ block ที่ PHP — ปล่อยให้ LIFF auth ใน JS ตรวจแทน
    // ถ้าเปิดจาก PC browser + WP admin session → ใช้ nonce
    // ถ้าเปิดจาก LIFF → auth ผ่าน /b2f/v1/auth-admin → ใช้ X-B2F-Token
    $is_wp_admin = current_user_can( 'manage_options' );
    $rest_url  = esc_url( rest_url( 'b2f/v1/' ) );
    $nonce     = $is_wp_admin ? wp_create_nonce( 'wp_rest' ) : '';
    $liff_id   = defined( 'B2F_LIFF_ID' ) ? B2F_LIFF_ID : ( defined( 'B2B_LIFF_ID' ) ? B2B_LIFF_ID : '' );
    $logo_url  = 'https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png';
    $dash_url  = esc_url( home_url( '/admin-command-center/#b2f_orders' ) );
    $is_wp_admin_js = $is_wp_admin ? 'true' : 'false';
    // V.7.0: Feature flag gate — ALL V.7.0 UI behind this flag
    $b2f_order_intent = get_option( 'b2f_flag_order_intent', false ) ? 'true' : 'false';

    header( 'Content-Type: text/html; charset=UTF-8' );
?>
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>DINOCO B2F -- สั่งซื้อโรงงาน</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
