    // V.7.0: Reset mode toggle + render mode toggle UI
    // V.7.5 UX-H16: restore last-used mode per-SKU from localStorage (default full_set)
    var _modeStorageKey = 'b2f_setdetail_mode_' + (p.sku || '').toUpperCase();
    var _storedMode = null;
    try {
      _storedMode = window.localStorage ? window.localStorage.getItem(_modeStorageKey) : null;
    } catch (err) { _storedMode = null; }
    setDetailMode = (_storedMode === 'parts' || _storedMode === 'full_set') ? _storedMode : 'full_set';

    // "สั่งชุดเต็ม" button
    updateSetDetailAddBtn();

    // V.7.0: Inject mode toggle directly after hero (image+title+SKU) so it sits at top of
    // scrollable content. V.7.3: sticky CSS keeps it in view while scrolling → user can
    // always switch modes without pressing Back (fixes "toggle disappears when in parts mode" UX bug)
    var _modeToggleContainer = document.getElementById('b2fSetDetailModeToggle');
    if (_modeToggleContainer) _modeToggleContainer.remove();
    if (ORDER_INTENT_ENABLED) {
      var heroEl = document.querySelector('.b2f-cat-set-detail-hero');
      if (heroEl && heroEl.parentNode) {
        var toggleDiv = document.createElement('div');
        toggleDiv.id = 'b2fSetDetailModeToggle';
        toggleDiv.className = 'b2f-cat-mode-toggle';
        // V.7.5 UX-H16: reflect restored mode in button active class
        var _fullActive = (setDetailMode === 'full_set') ? 'active' : '';
        var _partsActive = (setDetailMode === 'parts') ? 'active-amber' : '';
        toggleDiv.innerHTML = '<button type="button" class="b2f-cat-mode-toggle-btn ' + _fullActive + '" data-mode="full_set">\uD83D\uDFE3 สั่งครบชุด</button>'
          + '<button type="button" class="b2f-cat-mode-toggle-btn ' + _partsActive + '" data-mode="parts">\uD83D\uDFE0 สั่งแยก</button>';
        // Insert AFTER hero (toggle becomes first scrollable element below header → sticky anchor)
        if (heroEl.nextSibling) heroEl.parentNode.insertBefore(toggleDiv, heroEl.nextSibling);
        else heroEl.parentNode.appendChild(toggleDiv);
        // Event delegation
        toggleDiv.addEventListener('click', function(e) {
          var btn = e.target.closest('.b2f-cat-mode-toggle-btn');
          if (!btn) return;
          var mode = btn.getAttribute('data-mode');
          setDetailMode = mode;
          // V.7.5 UX-H16: persist choice per-SKU for next visit
          try {
            if (window.localStorage) window.localStorage.setItem(_modeStorageKey, mode);
          } catch (err) { /* quota full / private mode — ignore */ }
          toggleDiv.querySelectorAll('.b2f-cat-mode-toggle-btn').forEach(function(b) {
            b.classList.remove('active', 'active-amber');
          });
          btn.classList.add(mode === 'parts' ? 'active-amber' : 'active');
          // Toggle visibility of mode-specific sections — toggle itself stays visible always
          var priceBlock = document.querySelector('.b2f-cat-set-detail-price-block');
          var itemsSection = document.getElementById('b2fSetDetailItems');
          var divider = document.querySelector('.b2f-cat-set-detail-divider');
          if (mode === 'full_set') {
            if (priceBlock) priceBlock.style.display = 'flex';
            if (itemsSection) itemsSection.style.display = 'none';
            if (divider) divider.style.display = 'none';
          } else {
            if (priceBlock) priceBlock.style.display = 'none';
            if (itemsSection) itemsSection.style.display = 'block';
            if (divider) divider.style.display = 'flex';
            renderSetDetailItems();
          }
        });
        // V.7.5 UX-H16: apply initial visibility from restored mode
        var itemsSec = document.getElementById('b2fSetDetailItems');
        var divEl = document.querySelector('.b2f-cat-set-detail-divider');
        var priceBlockInit = document.querySelector('.b2f-cat-set-detail-price-block');
        if (setDetailMode === 'parts') {
          if (priceBlockInit) priceBlockInit.style.display = 'none';
          if (itemsSec) itemsSec.style.display = 'block';
          if (divEl) divEl.style.display = 'flex';
        } else {
          if (priceBlockInit) priceBlockInit.style.display = 'flex';
          if (itemsSec) itemsSec.style.display = 'none';
          if (divEl) divEl.style.display = 'none';
        }
      }
    } else {
      // V.6.6: show both sections (no mode toggle)
      var itemsSec2 = document.getElementById('b2fSetDetailItems');
      var divEl2 = document.querySelector('.b2f-cat-set-detail-divider');
      if (itemsSec2) itemsSec2.style.display = 'block';
      if (divEl2) divEl2.style.display = 'flex';
    }

    // Missing leaves warning (still useful for real SET with incomplete registration)
    var missingEl = document.getElementById('b2fSetDetailMissing');
    var warnings = [];
    var meta = hierarchyMeta[(p.sku||'').toUpperCase()];
    if (meta && meta.missing_leaves && meta.missing_leaves.length) {
      warnings.push('&#9888;&#65039; ชิ้นส่วนไม่ครบ: ขาด ' + meta.missing_leaves.length + ' รายการ ('
        + meta.missing_leaves.map(function(s) { return esc(s); }).join(', ') + ')');
    }
    if (warnings.length) {
      missingEl.style.display = 'block';
      missingEl.innerHTML = warnings.join('');
    } else {
      missingEl.style.display = 'none';
    }

    // Render children
    renderSetDetailItems();

    // Show detail view
    $setDetail.classList.add('show');
    $setDetail.scrollTop = 0;

    // Push history state
    history.pushState({ view: 'b2f-set-detail', sku: p.sku }, '', '#detail-' + p.sku);
  }

