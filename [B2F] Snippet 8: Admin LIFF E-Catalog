  // V.6.2: Update moto icon in cart bar ตาม selected model / maker
  function updateCartMotoIcon() {
    var iconEl = document.getElementById('b2fCartMotoIcon');
    if (!iconEl) return;
    var imgUrl = '';
    // Priority 1: filterModel → find moto_catalog entry with matching model name
    if (filterModel && motoCatalog && motoCatalog.length) {
      for (var i = 0; i < motoCatalog.length; i++) {
        var brand = motoCatalog[i];
        if (!brand.models) continue;
        for (var j = 0; j < brand.models.length; j++) {
          var m = brand.models[j];
          var mn = (m.name || m.model_name || '').toString();
          if (mn && filterModel && mn.toLowerCase() === String(filterModel).toLowerCase()) {
            imgUrl = m.image_url || m.img || '';
            break;
          }
        }
        if (imgUrl) break;
      }
    }
    // Priority 2: first product image (fallback)
    if (!imgUrl && products && products.length) {
      for (var k = 0; k < products.length; k++) {
        if (products[k].image_url) { imgUrl = products[k].image_url; break; }
      }
    }
    if (imgUrl) {
      // V.7.5 UX-H5: cart bar icon is presentational — keep alt="" to avoid screen-reader noise
      // (the cart link/label already announces context). Do not change.
      iconEl.innerHTML = '<img src="' + esc(imgUrl) + '" alt="" loading="lazy" onerror="this.parentNode.innerHTML=\'<span class=&quot;b2f-cat-cart-icon-fallback&quot;>&#128665;</span>\';">';
    } else {
      iconEl.innerHTML = '<span class="b2f-cat-cart-icon-fallback">&#128665;</span>';
    }
  }

  function renderSetDetailItems() {
    var container = document.getElementById('b2fSetDetailItems');
    container.innerHTML = '';
    if (!setDetailProduct) return;

    var parentSku = setDetailProduct.sku;
    var parentSkuU = (parentSku || '').toUpperCase(); // V.4.2: case-insensitive
    var csym = getMakerSymbol();

    // V.4.3: Forward lookup — ใช้ skuRelations หา children ของ SET (DD-3 shared child fix)
    var setChildSkus = skuRelations[parentSkuU] || [];
    var productBySku = {};
    products.forEach(function(p) { productBySku[(p.sku || '').toUpperCase()] = p; });

    var children = [];
    setChildSkus.forEach(function(childSku) {
      var cp = productBySku[childSku];
      if (cp) children.push(cp);
    });

    // Also include grandchildren via forward lookup (intermediate child -> grandchild)
    var grandchildrenByParent = {};
    setChildSkus.forEach(function(midSku) {
      var gcSkus = skuRelations[midSku] || [];
      gcSkus.forEach(function(gcSku) {
        var gp = productBySku[gcSku];
        if (gp) {
          if (!grandchildrenByParent[midSku]) grandchildrenByParent[midSku] = [];
          grandchildrenByParent[midSku].push(gp);
        }
      });
    });

    if (!children.length && !Object.keys(grandchildrenByParent).length) {
      // Fallback: show all leaves from hierarchy_meta
      var meta = hierarchyMeta[parentSkuU];
      if (meta && meta.all_leaves && meta.all_leaves.length) {
        container.innerHTML = '<div style="text-align:center;padding:20px;color:#999;font-size:13px;">มี ' + meta.all_leaves.length + ' ชิ้นส่วนในชุด (Maker ยังไม่ได้ลงทะเบียนทั้งหมด)</div>';
      } else {
        container.innerHTML = '<div style="text-align:center;padding:20px;color:#999;font-size:13px;">ไม่มีรายการสินค้าย่อย</div>';
      }
      return;
    }

    children.forEach(function(child) {
      var chQty = cart[child.sku] ? cart[child.sku].qty : 0;
      var gcs = grandchildrenByParent[(child.sku || '').toUpperCase()] || [];

      var wrap = document.createElement('div');
      wrap.className = 'b2f-cat-set-child';

      // Main row
      var row = document.createElement('div');
      row.className = 'b2f-cat-set-child-row';

      // Image (V.7.5 UX-H5: meaningful alt for informational thumbnail)
      var imgH = '';
      if (child.image_url) {
        imgH = '<img class="b2f-cat-set-child-img" src="' + esc(child.image_url) + '" alt="' + esc(child.product_name || child.sku) + '" loading="lazy" onerror="this.style.display=\'none\'">';
      } else {
        imgH = '<div class="b2f-cat-set-child-img" style="display:flex;align-items:center;justify-content:center;font-size:20px;color:#ccc;">&#128230;</div>';
      }

      // Info
      var infoH = '<div class="b2f-cat-set-child-info">';
      infoH += '<div class="b2f-cat-set-child-name">' + esc(child.product_name) + '</div>';
      infoH += '<div class="b2f-cat-set-child-sku">' + esc(child.sku) + '</div>';
      infoH += '<div class="b2f-cat-set-child-price">' + csym + fmt(child.unit_cost) + '</div>';
      // V.5.0 DD-3: shared badge — ถ้า child อยู่ในหลาย SET
      var childParents = (child._jsParents || child.parent_skus || []).length;
      // Count top-level SETs by walking up
      var sharedSetCount = countTopSetsForProduct(child.sku);
      if (sharedSetCount > 1) {
        infoH += '<div style="margin-top:4px;font-size:10px;color:#d97706;font-weight:600;">🔗 ใช้ใน ' + sharedSetCount + ' ชุด</div>';
      }
      infoH += '</div>';

      // Qty stepper (V.6.2: typable input + add button) — V.6.4: collapsed default สำหรับ sub-items
      var qtyH = buildQtyStepperHtml(child.sku, chQty, true);

      row.innerHTML = imgH + infoH + qtyH;
      wrap.appendChild(row);

      // Grandchildren section
      if (gcs.length) {
        var gcWrap = document.createElement('div');
        gcWrap.className = 'b2f-cat-set-gc';
        var gcH = '<div class="b2f-cat-set-gc-label">ซื้อแยกชิ้น</div>';
        gcs.forEach(function(gc) {
          var gcQty = cart[gc.sku] ? cart[gc.sku].qty : 0;
          gcH += '<div class="b2f-cat-set-gc-item">';
          if (gc.image_url) {
            // V.7.5 UX-H5: meaningful alt for informational thumbnail
            gcH += '<img class="b2f-cat-set-gc-img" src="' + esc(gc.image_url) + '" alt="' + esc(gc.product_name || gc.sku) + '" loading="lazy" onerror="this.style.display=\'none\'">';
          } else {
            gcH += '<div class="b2f-cat-set-gc-img" style="display:flex;align-items:center;justify-content:center;font-size:14px;color:#ccc;">&#128230;</div>';
          }
          gcH += '<div class="b2f-cat-set-gc-info">';
          gcH += '<div class="b2f-cat-set-gc-name">' + esc(gc.product_name) + '</div>';
          gcH += '<div class="b2f-cat-set-gc-sku">' + esc(gc.sku) + '</div>';
          gcH += '<div class="b2f-cat-set-gc-price">' + csym + fmt(gc.unit_cost) + '</div>';
          gcH += '</div>';

          // Qty stepper สำหรับ grandchild (V.6.2) — V.6.4: collapsed default
          gcH += buildQtyStepperHtml(gc.sku, gcQty, true);
          gcH += '</div>';
        });
        gcWrap.innerHTML = gcH;
        wrap.appendChild(gcWrap);
      }

      container.appendChild(wrap);
    });
  }

  // ── Cart setQty ──
  // V.7.0: optional params for order_mode/source_sku/intent_notes
  function setQty(sku, qty, opts) {
    var p = products.find(function(x) { return x.sku === sku; });
    if (!p) return;
    qty = Math.max(0, parseInt(qty) || 0);
    if (qty <= 0) { delete cart[sku]; }
    else {
      var imgUrl = p.image_url || '';
      if (!imgUrl && typeof catalogMap !== 'undefined' && catalogMap) {
        var cm = catalogMap[(p.sku || '').toUpperCase()];
        if (cm && cm.image_url) imgUrl = cm.image_url;
      }
      // Preserve existing V.7.0 fields if already in cart and no explicit opts
      var existing = cart[sku] || {};
      var o = opts || {};
      cart[sku] = {
        sku: p.sku, product_name: p.product_name, unit_cost: p.unit_cost, qty: qty,
        moq: p.moq || 1, shipping_land: p.shipping_land||0, shipping_sea: p.shipping_sea||0,
        product_type: p._jsType || 'single', image_url: imgUrl,
        // V.7.0 fields
        order_mode: o.order_mode || existing.order_mode || deriveOrderMode(p),
        source_sku: o.source_sku || existing.source_sku || p.sku,
        intent_notes: o.intent_notes !== undefined ? o.intent_notes : (existing.intent_notes || '')
      };
    }
    var card = document.querySelector('.b2f-cat-card[data-sku="' + sku + '"]');
    if (card) {
      card.classList.toggle('in-cart', qty > 0);
      var input = card.querySelector('.b2f-cat-qty-val');
      if (input) input.value = qty;
      var setBtn = card.querySelector('.b2f-cat-set-btn');
      if (setBtn) {
        if (qty > 0) {
          setBtn.textContent = qty + ' ชุดในตะกร้า';
          setBtn.classList.add('in-cart-btn');
        } else {
          setBtn.textContent = 'ดูชุด';
          setBtn.classList.remove('in-cart-btn');
        }
      }
    }
    updateCartUI();
    saveCartToStorage(); // V.7.0: persist to localStorage
  }

  function updateCartUI() {
    var skus = Object.keys(cart); var count = skus.length; var total = 0;
    skus.forEach(function(s) { total += cart[s].unit_cost * cart[s].qty; });
    var csym = getMakerSymbol();
    $cartCount.textContent = count; $cartTotal.textContent = csym + fmt(total);
    $cartBar.classList.toggle('visible', count > 0);
    // V.6.2: refresh moto icon ตาม filter/products
    updateCartMotoIcon();
  }

  function getCartTotal() {
    var total = 0; Object.keys(cart).forEach(function(s) { total += cart[s].unit_cost * cart[s].qty; }); return total;
  }

  // ── V.4.0: Detect duplicate (SET + its leaf in cart) ──
  function detectCartDuplicates() {
    var warnings = [];
    var cartSkus = Object.keys(cart);
    cartSkus.forEach(function(sku) {
      var item = cart[sku];
      if (item.product_type === 'set') {
        // Check if any leaf of this SET is also individually in cart
        var meta = hierarchyMeta[(sku||'').toUpperCase()];
        if (meta && meta.all_leaves) {
          meta.all_leaves.forEach(function(leafSku) {
            if (cart[leafSku]) {
              warnings.push('ชุด "' + (item.product_name || sku) + '" กับ "' + (cart[leafSku].product_name || leafSku) + '" อยู่ในตะกร้าทั้งคู่ (อาจสั่งซ้ำ)');
            }
          });
        }
        // V.4.3: Also check children via forward lookup (skuRelations) — DD-3 safe
        var setSkuU = (sku||'').toUpperCase();
        function _checkChildDup(childSku) {
          var lc = childSku.toUpperCase();
          // Check the child itself
          if (cart[childSku] && childSku !== sku) {
            var cp = cart[childSku];
            var already = warnings.some(function(w) { return w.indexOf(childSku) >= 0 || w.indexOf(cp.product_name) >= 0; });
            if (!already) {
              warnings.push('ชุด "' + (item.product_name || sku) + '" กับ "' + (cp.product_name || childSku) + '" อยู่ในตะกร้าทั้งคู่ (อาจสั่งซ้ำ)');
            }
          }
          // Check grandchildren of this child
          (skuRelations[lc] || []).forEach(function(gcSku) {
            if (cart[gcSku] && gcSku !== sku) {
              var gp = cart[gcSku];
              var already2 = warnings.some(function(w) { return w.indexOf(gcSku) >= 0 || w.indexOf(gp.product_name) >= 0; });
              if (!already2) {
                warnings.push('ชุด "' + (item.product_name || sku) + '" กับ "' + (gp.product_name || gcSku) + '" อยู่ในตะกร้าทั้งคู่ (อาจสั่งซ้ำ)');
              }
            }
          });
        }
        (skuRelations[setSkuU] || []).forEach(_checkChildDup);
      }
    });
    return warnings;
  }

  // V.6.3: build 56x56 thumbnail for cart row (priority: cart.image_url → products lookup → catalogMap → placeholder)
  function buildCartItemThumbHtml(cartEntry) {
    var imgUrl = cartEntry.image_url || '';
    if (!imgUrl) {
      var p = products.find(function(x) { return x.sku === cartEntry.sku; });
      if (p && p.image_url) imgUrl = p.image_url;
    }
    if (!imgUrl && typeof catalogMap !== 'undefined' && catalogMap) {
      var cm = catalogMap[(cartEntry.sku || '').toUpperCase()];
      if (cm && cm.image_url) imgUrl = cm.image_url;
    }
    if (imgUrl) {
      return '<img class="b2f-cat-item-thumb" src="' + esc(imgUrl) + '" alt="' + esc(cartEntry.product_name || '') + '" loading="lazy" onerror="this.outerHTML=\'<div class=&quot;b2f-cat-item-thumb placeholder&quot;>&#128230;</div>\'">';
    }
    return '<div class="b2f-cat-item-thumb placeholder">&#128230;</div>';
  }

  // ── V.4.0: Cart Modal with Hierarchy Grouping ──
  // V.7.0: Dual-section cart (🟣 ชุดเต็ม / 🟠+⚪ แยกชุด+ชิ้นเดี่ยว) when flag ON
  function renderCartModal() {
