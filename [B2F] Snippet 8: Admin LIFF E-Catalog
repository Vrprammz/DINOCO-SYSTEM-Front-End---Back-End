<script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
<script>
(function(){
  'use strict';

  var API   = <?php echo json_encode( $rest_url ); ?>;
  var NONCE = <?php echo json_encode( $nonce ); ?>;
  var LIFF_ID = <?php echo json_encode( $liff_id ); ?>;
  var IS_WP_ADMIN = <?php echo $is_wp_admin_js; ?>;

  var makers = [];
  var products = [];
  var hierarchyMeta = {};
  var skuRelations = {}; // V.4.3: forward lookup map from API
  var motoCatalog = [];
  var cart = {};
  var selectedMaker = null;
  var selectedMakerData = null;
  var submitting = false;
  var B2F_TOKEN = '';

  // V.4.0 filter state
  var filterModel = '';
  var filterType = '';  // '' | 'set' | 'single'
  var setDetailProduct = null;
  var setDetailScrollY = 0;

  var $makerSelect = document.getElementById('b2fMakerSelect');
  var $searchWrap  = document.getElementById('b2fSearchWrap');
  var $search      = document.getElementById('b2fSearch');
  var $productArea = document.getElementById('b2fProductArea');
  var $cartBar     = document.getElementById('b2fCartBar');
  var $cartCount   = document.getElementById('b2fCartCount');
  var $cartTotal   = document.getElementById('b2fCartTotal');
  var $cartModal   = document.getElementById('b2fCartModal');
  var $cartBody    = document.getElementById('b2fCartBody');
  var $cartNote    = document.getElementById('b2fCartNote');
  var $modalTotal  = document.getElementById('b2fModalTotal');
  var $submitBtn   = document.getElementById('b2fSubmitOrder');
  var $dupModal    = document.getElementById('b2fDupModal');
  var $dupMsg      = document.getElementById('b2fDupMsg');
  var $success     = document.getElementById('b2fSuccess');
  var $modelRow    = document.getElementById('b2fModelRow');
  var $typeChips   = document.getElementById('b2fTypeChips');
  var $setDetail   = document.getElementById('b2fSetDetail');

  function api(method, path, body) {
    var headers = { 'Content-Type': 'application/json' };
    var opts = { method: method, headers: headers };
    // WP admin session -> use nonce; LIFF -> use B2F token
    if (IS_WP_ADMIN && NONCE) {
      headers['X-WP-Nonce'] = NONCE;
      opts.credentials = 'same-origin';
    } else if (B2F_TOKEN) {
      headers['X-B2F-Token'] = B2F_TOKEN;
    }
    if (body) opts.body = JSON.stringify(body);
    return fetch(API + path, opts).then(function(r) { return r.json(); });
  }

  // ── LIFF Auth Flow (V.2.0) ──
  function initAuth() {
    if (IS_WP_ADMIN) {
      loadMakers();
      return;
    }

    if (!LIFF_ID) { showAuthError('ระบบยังไม่ถูกตั้งค่า LIFF ID'); return; }

    liff.init({ liffId: LIFF_ID }).then(function() {
      if (!liff.isLoggedIn()) { liff.login(); return; }
      return liff.getProfile();
    }).then(function(profile) {
      if (!profile) return;
      var lineUid = profile.userId;
      var idToken = liff.getIDToken() || '';
      var params = new URLSearchParams(window.location.search);
      var sig = params.get('_sig') || '';
      var ts = params.get('_ts') || '';

      return fetch(API + 'auth-admin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line_user_id: lineUid, id_token: idToken, _sig: sig, _ts: parseInt(ts) || 0 })
      }).then(function(r) { return r.json(); });
    }).then(function(res) {
      if (!res) return;
      if (res.authorized && res.token) {
        B2F_TOKEN = res.token;
        loadMakers();
      } else {
        showAuthError(res.message || 'ไม่มีสิทธิ์เข้าใช้งาน');
      }
    }).catch(function(e) {
      showAuthError('ไม่สามารถยืนยันตัวตนได้: ' + (e.message || ''));
    });
  }

  function showAuthError(msg) {
    var initEl = document.getElementById('b2fInitLoading');
    var mainEl = document.getElementById('b2fMainContent');
    if (initEl) initEl.style.display = 'none';
    if (mainEl) mainEl.style.display = 'block';
    $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#128274;</div><div style="font-size:14px;font-weight:600;margin-bottom:8px;">ไม่สามารถเข้าใช้งานได้</div><div style="font-size:12px;color:var(--b2f-text-muted);">' + esc(msg) + '</div></div>';
  }

  function toast(msg, type) {
    var $t = document.getElementById('b2fToast');
    $t.textContent = msg;
    $t.className = 'b2f-cat-toast ' + (type || '') + ' show';
    setTimeout(function() { $t.classList.remove('show'); }, 3000);
  }

  function fmt(n) { return Number(n).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 }); }

  function esc(s) { var d = document.createElement('div'); d.appendChild(document.createTextNode(s || '')); return d.innerHTML; }

  function loadMakers() {
    api('GET', 'makers').then(function(res) {
      var initEl = document.getElementById('b2fInitLoading');
      var mainEl = document.getElementById('b2fMainContent');
      if (initEl) initEl.style.display = 'none';
      if (mainEl) mainEl.style.display = 'block';

      if (res.success && res.data) {
        makers = res.data.filter(function(m) { return m.status === 'active'; });
        $makerSelect.innerHTML = '<option value="">-- เลือกโรงงาน (' + makers.length + ' แห่ง) --</option>';
        makers.forEach(function(m) {
          var opt = document.createElement('option'); opt.value = m.id; opt.textContent = m.name;
          $makerSelect.appendChild(opt);
        });
        $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#127981;</div><div>เลือกโรงงานเพื่อดูสินค้า</div></div>';
      } else {
        toast('โหลดรายชื่อโรงงานไม่สำเร็จ', 'error');
      }
    }).catch(function() {
      var initEl = document.getElementById('b2fInitLoading');
      var mainEl = document.getElementById('b2fMainContent');
      if (initEl) initEl.style.display = 'none';
      if (mainEl) mainEl.style.display = 'block';
      toast('เชื่อมต่อเซิร์ฟเวอร์ไม่ได้', 'error');
    });
  }

  function getMakerCurrency() {
    if (!selectedMakerData) return 'THB';
    return selectedMakerData.currency || 'THB';
  }
  function getMakerSymbol() {
    var c = getMakerCurrency();
    return c === 'CNY' ? '\u00A5' : (c === 'USD' ? '$' : '\u0E3F');
  }

  // ── V.4.0: Parse compatible_models from products ──
  // V.5.1: Normalize object {brand_name, name} → display name string
  //        (Inventory V.42.0 H-11 whitelist เก็บเป็น JSON array ของ objects)
  function parseModels(p) {
    if (!p.compatible_models) return [];
    var raw = p.compatible_models;
    if (typeof raw === 'string') {
      try { raw = JSON.parse(raw); } catch(e) { return []; }
    }
    if (!Array.isArray(raw)) return [];
    var out = [];
    raw.forEach(function(m) {
      if (!m) return;
      if (typeof m === 'string') out.push(m);
      else if (typeof m === 'object') {
        var name = m.name || m.model_name || m.slug || '';
        if (name) out.push(String(name));
      }
    });
    return out;
  }

  // V.5.3: collect all model strings for a product (direct + descendants for SETs/children)
  // Admin ใส่ model ที่ leaf (L/R) เท่านั้น → SET ต้อง walk descendants ผ่าน skuRelations
  function collectModelsWithDescendants(p, hier) {
    var out = {};
    parseModels(p).forEach(function(m) { out[m] = true; });

    var at = p._jsType || 'single';
    if (at !== 'set' && at !== 'child') return Object.keys(out);

    var skuU = (p.sku || '').toUpperCase();
    var walked = {};
    var queue = [skuU];
    while (queue.length) {
      var cur = queue.shift();
      if (walked[cur]) continue;
      walked[cur] = true;
      var children = skuRelations[cur] || [];
      children.forEach(function(childSku) {
        var childU = String(childSku).toUpperCase();
        var cp = (hier && hier.bysku) ? hier.bysku[childU] : null;
        if (cp) {
          parseModels(cp).forEach(function(m) { out[m] = true; });
        }
        if (!walked[childU]) queue.push(childU);
      });
    }
    return Object.keys(out);
  }

  // V.5.3: model filter — match ถ้า product ตัวเอง หรือ descendant ตัวใดตัวหนึ่งมี model ที่เลือก
  function productMatchesModel(p, model, hier) {
    var models = collectModelsWithDescendants(p, hier);
    return models.indexOf(model) >= 0;
  }

  // ── V.4.0: Get model image from moto_catalog ──
  function getModelImage(modelName) {
    if (!motoCatalog || !motoCatalog.length) return '';
    for (var i = 0; i < motoCatalog.length; i++) {
      var brand = motoCatalog[i];
      if (!brand.models) continue;
      for (var j = 0; j < brand.models.length; j++) {
        if (brand.models[j].model_name === modelName && brand.models[j].image_url) {
          return brand.models[j].image_url;
        }
      }
    }
    return '';
  }

  // ── V.4.4: Build hierarchy lookup using forward lookup + JS-derived types ──
  function buildHierarchyLookup() {
    var lookup = { bysku: {}, setSkus: [], childrenOf: {}, grandchildrenOf: {} };
    products.forEach(function(p) { lookup.bysku[(p.sku || '').toUpperCase()] = p; });
    products.forEach(function(p) {
      var at = p._jsType || 'single';
      if (at === 'set') {
        lookup.setSkus.push((p.sku || '').toUpperCase());
      }
    });
    // V.4.3: Forward lookup จาก skuRelations แทน reverse lookup จาก parent_sku
    // DD-3 shared child: product อาจเป็นลูกของหลาย parent → forward lookup ถูกเสมอ
    Object.keys(skuRelations).forEach(function(parentSku) {
      var childSkus = skuRelations[parentSku] || [];
      childSkus.forEach(function(childSku) {
        var cp = lookup.bysku[childSku];
        if (!cp) return;
        // ถ้า parent เป็น SET (top-level) → childrenOf
        // ถ้า parent มี parent อีกที → grandchildrenOf
        if (!lookup.childrenOf[parentSku]) lookup.childrenOf[parentSku] = [];
        lookup.childrenOf[parentSku].push(cp);
        // Check if parent has a grandparent (= this is grandchild relation)
        Object.keys(skuRelations).forEach(function(gpSku) {
          if ((skuRelations[gpSku] || []).indexOf(parentSku) !== -1) {
            if (!lookup.grandchildrenOf[parentSku]) lookup.grandchildrenOf[parentSku] = [];
            lookup.grandchildrenOf[parentSku].push(cp);
          }
        });
      });
    });
    return lookup;
  }

  function loadProducts(makerId) {
    selectedMaker = makerId; cart = {}; updateCartUI();
    filterModel = ''; filterType = '';
    selectedMakerData = makerId ? makers.find(function(m){ return String(m.id) === String(makerId); }) : null;
    if (!makerId) {
      $searchWrap.style.display = 'none';
      $modelRow.style.display = 'none';
      $typeChips.style.display = 'none';
      $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#127981;</div><div>เลือกโรงงานเพื่อดูสินค้า</div></div>';
      return;
    }
    $productArea.innerHTML = '<div class="b2f-cat-loading"><div class="b2f-cat-spinner"></div><div style="color:var(--b2f-text-muted);font-size:13px;">กำลังโหลดสินค้า...</div></div>';
    $searchWrap.style.display = 'block'; $search.value = '';
    api('GET', 'maker-products/' + makerId).then(function(res) {
      if (res.success && res.data) {
        products = res.data.filter(function(p) { return p.status === 'active'; });
        hierarchyMeta = res.hierarchy_meta || {};
        skuRelations = res.sku_relations || {};
        motoCatalog = res.moto_catalog || [];

        // V.4.4: JS-side type derivation from sku_relations (source of truth = same as Product Catalog computeProductTypes)
        var _c2p = {};
        Object.keys(skuRelations).forEach(function(pk) {
          (skuRelations[pk] || []).forEach(function(ck) {
            var cu = String(ck).toUpperCase();
            if (!_c2p[cu]) _c2p[cu] = [];
            if (_c2p[cu].indexOf(pk) === -1) _c2p[cu].push(pk);
          });
        });
        products.forEach(function(p) {
          var su = (p.sku || '').toUpperCase();
          var myChildren = skuRelations[su] || [];
          var isParent = myChildren.length > 0;
          var myParents = _c2p[su] || [];
          var myParent = myParents[0] || null;
          var isLeaf = !isParent;

          if (myParent && isLeaf) p._jsType = 'grandchild';
          else if (myParent && isParent) p._jsType = 'child';
          else if (isParent) p._jsType = 'set';
          else p._jsType = 'single';

          p._jsParents = myParents;
          p._jsChildrenCount = myChildren.length;
        });

        renderModelFilter();
        renderTypeChips();
        renderFilteredProducts();
      } else {
        products = []; hierarchyMeta = {}; skuRelations = {}; motoCatalog = [];
        $modelRow.style.display = 'none';
        $typeChips.style.display = 'none';
        $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#128230;</div><div>ยังไม่มีสินค้าในโรงงานนี้</div></div>';
      }
    }).catch(function() { toast('โหลดสินค้าไม่สำเร็จ', 'error'); });
  }

  // ── V.4.0 / V.5.3: Model Filter Row ──
  // V.5.3: รวม models จาก descendants ด้วย (SET ที่ admin ใส่ model ที่ leaf)
  function renderModelFilter() {
    var models = {};
    var hier = buildHierarchyLookup();
    products.forEach(function(p) {
      collectModelsWithDescendants(p, hier).forEach(function(m) {
        if (m && typeof m === 'string') models[m] = true;
      });
    });
    var modelList = Object.keys(models).sort();
    if (!modelList.length) { $modelRow.style.display = 'none'; return; }

    var inner = document.getElementById('b2fModelRowInner');
    inner.innerHTML = '';

    // "ทั้งหมด" card
    var allCard = document.createElement('div');
    allCard.className = 'b2f-cat-model-card' + (!filterModel ? ' active' : '');
    allCard.innerHTML = '<div class="b2f-cat-model-card-placeholder">&#127981;</div>'
      + '<div class="b2f-cat-model-card-name">ทั้งหมด</div>';
    allCard.onclick = function() { filterModel = ''; renderModelFilter(); renderFilteredProducts(); };
    inner.appendChild(allCard);

    modelList.forEach(function(m) {
      var card = document.createElement('div');
      card.className = 'b2f-cat-model-card' + (filterModel === m ? ' active' : '');
      var imgUrl = getModelImage(m);
      var imgHtml = imgUrl
        ? '<img class="b2f-cat-model-card-img" src="' + esc(imgUrl) + '" alt="' + esc(m) + '" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">'
          + '<div class="b2f-cat-model-card-placeholder" style="display:none;">&#128661;</div>'
        : '<div class="b2f-cat-model-card-placeholder">&#128661;</div>';
      card.innerHTML = imgHtml + '<div class="b2f-cat-model-card-name">' + esc(m) + '</div>';
      card.onclick = (function(model) { return function() {
        filterModel = filterModel === model ? '' : model;
        renderModelFilter();
        renderFilteredProducts();
      }; })(m);
      inner.appendChild(card);
    });

    $modelRow.style.display = 'block';
  }

  // ── V.4.0 / V.5.1 / V.5.2: Type Filter Chips ──
  // V.5.1: count badges "(N)" + hide chips if count=0
  // V.5.2: align labels + categories กับ Inventory Stock Management (source of truth)
  //        5 chips: ทั้งหมด / ชุด SET / เดี่ยว / ลูกชิ้นส่วน / ชิ้นส่วนย่อย
  function renderTypeChips() {
    // นับ count per type (internal keys ยังคงเดิมเพื่อ backend/API compat)
    var counts = { '': products.length, set: 0, child: 0, grandchild: 0, single: 0 };
    products.forEach(function(p) {
      var t = p._jsType || 'single';
      if (counts[t] !== undefined) counts[t]++;
    });
    // V.5.2: แสดง chip row ถ้ามี hierarchy หรือ singles (Maker อาจมีเฉพาะ singles)
    if (!counts.set && !counts.child && !counts.grandchild && !counts.single) {
      $typeChips.style.display = 'none'; return;
    }

    var inner = document.getElementById('b2fTypeChipsInner');
    inner.innerHTML = '';

    // V.5.2: labels ตรงกับ Inventory Stock Management เป๊ะ
    var types = [
      { key: '',           label: 'ทั้งหมด' },
      { key: 'set',        label: 'ชุด SET' },
      { key: 'single',     label: 'เดี่ยว' },
      { key: 'child',      label: 'ลูกชิ้นส่วน' },
      { key: 'grandchild', label: 'ชิ้นส่วนย่อย' }
    ];
    types.forEach(function(t) {
      var n = counts[t.key] || 0;
      // V.5.1: ซ่อน chip ถ้า count=0 (ยกเว้น "ทั้งหมด")
      if (t.key !== '' && n === 0) return;

      var chip = document.createElement('button');
      chip.className = 'b2f-cat-type-chip' + (filterType === t.key ? ' active' : '');
      chip.setAttribute('data-type', t.key);
      chip.textContent = t.label + ' (' + n + ')';
      chip.onclick = function() { filterType = filterType === t.key ? '' : t.key; renderTypeChips(); renderFilteredProducts(); };
      inner.appendChild(chip);
    });

    $typeChips.style.display = 'block';
  }

  // ── V.4.0: Apply all filters then render ──
  function renderFilteredProducts() {
    var q = ($search.value || '').trim().toLowerCase();
    var hier = buildHierarchyLookup();

    // V.4.4: Use JS-derived _jsType for all filtering
    var setSkusInList = {};
    products.forEach(function(p) {
      if (p._jsType === 'set') setSkusInList[(p.sku || '').toUpperCase()] = true;
    });

    var filtered = products.filter(function(p) {
      var at = p._jsType || 'single';

      // V.4.4: เมื่อไม่ได้ filter type เจาะจง → ซ่อน child/gc ที่ SET อยู่ใน list (แสดงใน SET detail แทน)
      // DD-3 fix: ใช้ _jsParents (array from sku_relations) เช็คทุก SET parent
      if (!filterType || filterType === 'set') {
        if (at === 'child' || at === 'grandchild') {
          var pskus = p._jsParents || [];
          var hiddenBySet = false;
          for (var pi = 0; pi < pskus.length; pi++) {
            var psu = String(pskus[pi]).toUpperCase();
            if (setSkusInList[psu]) { hiddenBySet = true; break; }
            // Walk up: check if parent's parent is a SET in list
            Object.keys(skuRelations).forEach(function(gpSku) {
              if ((skuRelations[gpSku] || []).indexOf(psu) !== -1 && setSkusInList[gpSku]) {
                hiddenBySet = true;
              }
            });
            if (hiddenBySet) break;
          }
          if (hiddenBySet) return false;
        }
      }

      // Search filter
      if (q) {
        var matchSearch = (p.sku || '').toLowerCase().indexOf(q) >= 0
          || (p.product_name || '').toLowerCase().indexOf(q) >= 0
          || (p.compatible_models || '').toLowerCase().indexOf(q) >= 0;
        if (!matchSearch) return false;
      }

      // V.5.3: Model filter — SETs inherit models จาก descendants
      // Admin ใส่ model ที่ leaf (L/R) เท่านั้น → SET ต้อง walk descendants เอง
      if (filterModel) {
        if (!productMatchesModel(p, filterModel, hier)) return false;
      }

      // V.5.1 / V.5.2: Type filter — mutually exclusive (align กับ Inventory Stock Management)
      // ชุด SET / เดี่ยว / ลูกชิ้นส่วน / ชิ้นส่วนย่อย — 1 SKU = 1 tab
      if (filterType === 'set') {
        if (at !== 'set') return false;
      } else if (filterType === 'single') {
        if (at !== 'single') return false;
      } else if (filterType === 'child') {
        if (at !== 'child') return false;
      } else if (filterType === 'grandchild') {
        if (at !== 'grandchild') return false;
      }

      return true;
    });

    renderProducts(filtered, hier);
  }

  function renderProducts(list, hier) {
    if (!list || !list.length) {
      $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#128270;</div><div>ไม่พบสินค้าที่ค้นหา</div></div>';
      return;
    }
    var csym = getMakerSymbol();
    var html = '<div class="b2f-cat-grid">';
    list.forEach(function(p) {
      var jsType = p._jsType || 'single';
      var isSet = jsType === 'set';
      var inCart = cart[p.sku] ? true : false;
      var qty = cart[p.sku] ? cart[p.sku].qty : 0;

      var imgHtml = p.image_url
        ? '<div class="b2f-cat-card-img"><img src="' + esc(p.image_url) + '" alt="' + esc(p.product_name) + '" loading="lazy" onerror="this.parentElement.innerHTML=\'&#128230;\'"></div>'
        : '<div class="b2f-cat-card-img" style="font-size:32px;display:flex;align-items:center;justify-content:center;">&#128230;</div>';

      var shipLine = '';
      if ((p.shipping_land && p.shipping_land > 0) || (p.shipping_sea && p.shipping_sea > 0)) {
        shipLine = '<div style="font-size:9px;color:var(--b2f-text-muted);margin-bottom:2px;">ค่าส่ง: รถ \u0E3F' + fmt(p.shipping_land||0) + ' | เรือ \u0E3F' + fmt(p.shipping_sea||0) + '</div>';
      }

      // V.4.4: Type badge from JS-derived _jsType
      var typeBadge = '';
      if (isSet) {
        var leafCount = '';
        if (hierarchyMeta[(p.sku||'').toUpperCase()]) leafCount = hierarchyMeta[(p.sku||'').toUpperCase()].total_leaves || '';
        else if (p._jsChildrenCount) leafCount = p._jsChildrenCount;
        typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-set">ชุด ' + (leafCount ? leafCount + ' ชิ้น' : '') + '</span>';
      } else if (jsType === 'child') {
        typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-child">ชิ้นส่วน</span>';
      } else if (jsType === 'grandchild') {
        typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-grandchild">ชิ้นส่วนย่อย</span>';
      }

      // Breadcrumb for orphan children/grandchildren (SET not in maker list)
      var breadcrumb = '';
      if ((jsType === 'child' || jsType === 'grandchild') && p.top_parent_name) {
        breadcrumb = '<div class="b2f-cat-breadcrumb">' + esc(p.top_parent_name) + '</div>';
      }

      // Card classes
      var cardClass = 'b2f-cat-card';
      if (isSet) cardClass += ' is-set';
      if (inCart) cardClass += ' in-cart';

      html += '<div class="' + cardClass + '" data-sku="' + esc(p.sku) + '">'
        + imgHtml
        + '<div class="b2f-cat-card-body">'
        + typeBadge
        + breadcrumb
        + '<div class="b2f-cat-card-sku">' + esc(p.sku) + '</div>'
        + '<div class="b2f-cat-card-name">' + esc(p.product_name) + '</div>'
        + '<div class="b2f-cat-card-cost">' + csym + fmt(p.unit_cost) + '</div>'
        + shipLine
        + '<div class="b2f-cat-card-meta"><span>MOQ: ' + (p.moq||1) + '</span><span>Lead: ' + (p.lead_time_days||0) + ' วัน</span></div>';

      if (isSet) {
        // SET card: "ดูชุด" button instead of qty control
        var setBtnClass = 'b2f-cat-set-btn' + (inCart ? ' in-cart-btn' : '');
        var setBtnText = inCart ? qty + ' ชุดในตะกร้า' : 'ดูชุด';
        html += '<button class="' + setBtnClass + '" data-setsku="' + esc(p.sku) + '">' + setBtnText + '</button>';
      } else {
        // Leaf/Single: qty control
        html += '<div class="b2f-cat-qty-wrap">'
          + '<button class="b2f-cat-qty-btn minus" data-sku="' + esc(p.sku) + '" data-action="minus">-</button>'
          + '<input type="number" class="b2f-cat-qty-val" data-sku="' + esc(p.sku) + '" value="' + qty + '" min="0" inputmode="numeric">'
          + '<button class="b2f-cat-qty-btn plus" data-sku="' + esc(p.sku) + '" data-action="plus">+</button>'
          + '</div>';
      }

      html += '</div></div>';
    });
    html += '</div>';
    $productArea.innerHTML = html;
  }

