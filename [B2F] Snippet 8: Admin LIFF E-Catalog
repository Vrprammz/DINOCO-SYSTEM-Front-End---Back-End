<script>
(function(){
  'use strict';

  var API   = <?php echo json_encode( $rest_url ); ?>;
  var NONCE = <?php echo json_encode( $nonce ); ?>;
  var LIFF_ID = <?php echo json_encode( $liff_id ); ?>;
  var IS_WP_ADMIN = <?php echo $is_wp_admin_js; ?>;
  // V.7.0: Feature flag — ALL V.7.0 UI gated behind this
  var ORDER_INTENT_ENABLED = <?php echo $b2f_order_intent; ?>;

  var makers = [];
  var products = [];
  var hierarchyMeta = {};
  var skuRelations = {}; // V.4.3: forward lookup map from API
  var catalogMap = {};   // V.5.4: { UPPERCASE_SKU: {sku, name, image_url, compatible_models, category} } จาก API (source of truth = wp_dinoco_products)
  var motoCatalog = [];
  var cart = {};
  var selectedMaker = null;
  var selectedMakerData = null;
  var submitting = false;
  var B2F_TOKEN = '';

  // V.7.0: maker_profile from enriched API response
  var makerProfile = null;

  // V.4.0 filter state
  var filterModel = '';
  var filterType = '';  // '' | 'set' | 'single'
  var setDetailProduct = null;
  var setDetailScrollY = 0;
  // V.7.0: SET Detail mode (ใช้เมื่อ ORDER_INTENT_ENABLED)
  var setDetailMode = 'full_set'; // 'full_set' | 'parts'

  // V.6.5: Virtual SETs toggle — default OFF (ซ่อน virtual top-level SETs ที่ประกอบจากชิ้นส่วน)
  // V.6.6: localStorage key scoped per-maker (`b2f_show_virtual_sets_{makerId}`) ให้ preference
  // แยกต่อโรงงาน. Intermediate sub-SETs (virtual_reason='intermediate_sub_set') ยังโชว์เสมอ
  // เพราะจำเป็นสำหรับ renderSetDetailItems lookup
  var showVirtualSets = false;
  function getShowVirtualKey() {
    // selectedMaker อาจเป็น null/empty ตอน init (ก่อนเลือก maker) → fallback '0'
    return 'b2f_show_virtual_sets_' + (selectedMaker || '0');
  }
  function loadShowVirtualFromStorage() {
    try {
      showVirtualSets = localStorage.getItem(getShowVirtualKey()) === '1';
    } catch (e) { /* localStorage disabled */ showVirtualSets = false; }
  }
  loadShowVirtualFromStorage();

  var $makerSelect = document.getElementById('b2fMakerSelect');
  var $searchWrap  = document.getElementById('b2fSearchWrap');
  var $search      = document.getElementById('b2fSearch');
  var $productArea = document.getElementById('b2fProductArea');
  var $cartBar     = document.getElementById('b2fCartBar');
  var $cartCount   = document.getElementById('b2fCartCount');
  var $cartTotal   = document.getElementById('b2fCartTotal');
  var $cartModal   = document.getElementById('b2fCartModal');
  var $cartBody    = document.getElementById('b2fCartBody');
  var $cartNote    = document.getElementById('b2fCartNote');
  var $modalTotal  = document.getElementById('b2fModalTotal');
  var $submitBtn   = document.getElementById('b2fSubmitOrder');
  var $dupModal    = document.getElementById('b2fDupModal');
  var $dupMsg      = document.getElementById('b2fDupMsg');
  var $success     = document.getElementById('b2fSuccess');
  var $modelRow    = document.getElementById('b2fModelRow');
  var $typeChips   = document.getElementById('b2fTypeChips');
  var $setDetail   = document.getElementById('b2fSetDetail');
  // V.6.5: Virtual SETs toggle row
  var $virtualToggleRow   = document.getElementById('b2fVirtualToggleRow');
  var $virtualToggle      = document.getElementById('b2fVirtualToggle');
  var $virtualToggleIcon  = document.getElementById('b2fVirtualToggleIcon');
  var $virtualToggleCount = document.getElementById('b2fVirtualToggleCount');

  function api(method, path, body) {
    var headers = { 'Content-Type': 'application/json' };
    var opts = { method: method, headers: headers };
    // WP admin session -> use nonce; LIFF -> use B2F token
    if (IS_WP_ADMIN && NONCE) {
      headers['X-WP-Nonce'] = NONCE;
      opts.credentials = 'same-origin';
    } else if (B2F_TOKEN) {
      headers['X-B2F-Token'] = B2F_TOKEN;
    }
    if (body) opts.body = JSON.stringify(body);
    return fetch(API + path, opts).then(function(r) { return r.json(); });
  }

  // ── LIFF Auth Flow (V.2.0) ──
  function initAuth() {
    if (IS_WP_ADMIN) {
      loadMakers();
      return;
    }

    if (!LIFF_ID) { showAuthError('ระบบยังไม่ถูกตั้งค่า LIFF ID'); return; }

    liff.init({ liffId: LIFF_ID }).then(function() {
      if (!liff.isLoggedIn()) { liff.login(); return; }
      return liff.getProfile();
    }).then(function(profile) {
      if (!profile) return;
      var lineUid = profile.userId;
      var idToken = liff.getIDToken() || '';
      var params = new URLSearchParams(window.location.search);
      var sig = params.get('_sig') || '';
      var ts = params.get('_ts') || '';

      return fetch(API + 'auth-admin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line_user_id: lineUid, id_token: idToken, _sig: sig, _ts: parseInt(ts) || 0 })
      }).then(function(r) { return r.json(); });
    }).then(function(res) {
      if (!res) return;
      if (res.authorized && res.token) {
        B2F_TOKEN = res.token;
        loadMakers();
      } else {
        showAuthError(res.message || 'ไม่มีสิทธิ์เข้าใช้งาน');
      }
    }).catch(function(e) {
      showAuthError('ไม่สามารถยืนยันตัวตนได้: ' + (e.message || ''));
    });
  }

  function showAuthError(msg) {
    var initEl = document.getElementById('b2fInitLoading');
    var mainEl = document.getElementById('b2fMainContent');
    if (initEl) initEl.style.display = 'none';
    if (mainEl) mainEl.style.display = 'block';
    $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#128274;</div><div style="font-size:14px;font-weight:600;margin-bottom:8px;">ไม่สามารถเข้าใช้งานได้</div><div style="font-size:12px;color:var(--b2f-text-muted);">' + esc(msg) + '</div></div>';
  }

  function toast(msg, type) {
    var $t = document.getElementById('b2fToast');
    $t.textContent = msg;
    $t.className = 'b2f-cat-toast ' + (type || '') + ' show';
    setTimeout(function() { $t.classList.remove('show'); }, 3000);
  }

  function fmt(n) { return Number(n).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 }); }

  function esc(s) { var d = document.createElement('div'); d.appendChild(document.createTextNode(s || '')); return d.innerHTML; }

  // ── V.7.0: Cart localStorage persistence ──
  function getCartStorageKey() {
    return 'b2f_cart_v7_' + (selectedMaker || '0');
  }
  function saveCartToStorage() {
    if (!ORDER_INTENT_ENABLED || !selectedMaker) return;
    try {
      var data = { _schema: 7, items: {}, updated_at: new Date().toISOString() };
      Object.keys(cart).forEach(function(sku) {
        var c = cart[sku];
        data.items[sku] = { qty: c.qty, price: c.unit_cost, name: c.product_name, image: c.image_url || '', order_mode: c.order_mode || 'single_leaf', source_sku: c.source_sku || '', intent_notes: c.intent_notes || '' };
      });
      localStorage.setItem(getCartStorageKey(), JSON.stringify(data));
    } catch (e) { /* localStorage disabled or full */ }
  }
  function loadCartFromStorage() {
    if (!ORDER_INTENT_ENABLED || !selectedMaker) return;
    try {
      var raw = localStorage.getItem(getCartStorageKey());
      if (!raw) return;
      var data = JSON.parse(raw);
      if (!data || data._schema !== 7 || !data.items) return;
      // Restore cart entries — match against loaded products for full data
      Object.keys(data.items).forEach(function(sku) {
        var stored = data.items[sku];
        var p = products.find(function(x) { return x.sku === sku; });
        if (!p) return; // product no longer exists for this maker
        var imgUrl = p.image_url || stored.image || '';
        if (!imgUrl) {
          var cm = catalogMap[(sku || '').toUpperCase()];
          if (cm && cm.image_url) imgUrl = cm.image_url;
        }
        cart[sku] = {
          sku: sku, product_name: p.product_name, unit_cost: p.unit_cost,
          qty: stored.qty || 0, moq: p.moq || 1,
          shipping_land: p.shipping_land || 0, shipping_sea: p.shipping_sea || 0,
          product_type: p._jsType || 'single', image_url: imgUrl,
          order_mode: stored.order_mode || 'single_leaf',
          source_sku: stored.source_sku || '',
          intent_notes: stored.intent_notes || ''
        };
      });
      updateCartUI();
    } catch (e) { /* corrupt data — ignore */ }
  }
  function clearCartStorage() {
    if (!selectedMaker) return;
    try { localStorage.removeItem(getCartStorageKey()); } catch (e) {}
  }

  // V.7.0: Derive order_mode from product
  function deriveOrderMode(p) {
    if (!ORDER_INTENT_ENABLED || !p) return '';
    var pm = p.production_mode || '';
    if (pm === 'set_assembled' || pm === 'cross_factory_assembly') return 'full_set';
    if (pm === 'sub_unit') return 'sub_unit';
    return 'single_leaf';
  }

  // V.7.0: Get order_mode label for display
  function orderModeLabel(mode) {
    if (mode === 'full_set') return 'ชุดเต็ม';
    if (mode === 'sub_unit') return 'แยกชุด';
    if (mode === 'single_leaf') return 'ชิ้นเดี่ยว';
    return '';
  }
  function orderModeBadgeClass(mode) {
    if (mode === 'full_set') return 'purple';
    if (mode === 'sub_unit') return 'amber';
    return 'gray';
  }

  // V.7.0: Render Maker Banner (Screen 1)
  function renderMakerBanner() {
    var $banner = document.getElementById('b2fMakerBanner');
    if (!$banner || !ORDER_INTENT_ENABLED) { if ($banner) $banner.classList.remove('show'); return; }
    if (!makerProfile || !makerProfile.stats) { $banner.classList.remove('show'); return; }
    var stats = makerProfile.stats;
    var uc = stats.unconfirmed_count || 0;
    // Per Decision #12: if unconfirmed=0 → hide banner entirely
    if (uc === 0) { $banner.classList.remove('show'); return; }

    var $stats = document.getElementById('b2fMakerBannerStats');
    var $warn = document.getElementById('b2fMakerBannerWarn');
    var $warnText = document.getElementById('b2fMakerBannerWarnText');

    $stats.innerHTML = '<span>' + (stats.set_count || 0) + ' ชุด</span>'
      + '<span>' + (stats.sub_unit_count || 0) + ' แยกชุด</span>'
      + '<span>' + (stats.single_count || 0) + ' เดี่ยว</span>';

    $warnText.textContent = '\u26A0\uFE0F มี ' + uc + ' SET รอยืนยัน';
    $warn.style.display = 'flex';
    $banner.classList.add('show');
  }

  // V.7.0: Render Submit Review Gate (Screen 5)
  function openReviewGate() {
    var skus = Object.keys(cart);
    if (!skus.length) return toast('ตะกร้าว่าง', 'error');
    var csym = getMakerSymbol();

    // Group by order_mode
    var buckets = { full_set: [], sub_unit: [], single_leaf: [] };
    skus.forEach(function(s) {
      var c = cart[s];
      var mode = c.order_mode || 'single_leaf';
      if (!buckets[mode]) buckets[mode] = [];
      buckets[mode].push(c);
    });

    var html = '';
    if (selectedMakerData) {
      html += '<div style="font-size:14px;font-weight:700;color:var(--b2f-text);margin-bottom:12px;">&#128230; ' + esc(selectedMakerData.name) + '</div>';
    }

    var configs = [
      { key: 'full_set', icon: '\uD83D\uDFE3', label: 'ชุดเต็ม', unit: 'ชุด', defaultOpen: true },
      { key: 'sub_unit', icon: '\uD83D\uDFE0', label: 'แยกชุด', unit: 'ชุด', defaultOpen: true },
      { key: 'single_leaf', icon: '\u26AA', label: 'ชิ้นเดี่ยว', unit: 'ชิ้น', defaultOpen: false }
    ];

    var grandTotal = 0;
    configs.forEach(function(cfg) {
      var items = buckets[cfg.key] || [];
      if (!items.length) return;
      var bucketTotal = 0; var bucketCount = 0;
      items.forEach(function(c) { bucketTotal += c.unit_cost * c.qty; bucketCount += c.qty; });
      grandTotal += bucketTotal;

      var expanded = cfg.defaultOpen ? ' expanded' : '';
      var bodyShow = cfg.defaultOpen ? ' show' : '';

      html += '<div class="b2f-cat-review-bucket">';
      html += '<div class="b2f-cat-review-bucket-hdr' + expanded + '" onclick="this.classList.toggle(\'expanded\');this.nextElementSibling.classList.toggle(\'show\');">';
      html += '<span class="b2f-cat-review-bucket-arrow">\u25B6</span> ';
      html += cfg.icon + ' ' + cfg.label + ': ' + bucketCount + ' ' + cfg.unit;
      html += '<span style="margin-left:auto;font-weight:800;">' + csym + fmt(bucketTotal) + '</span>';
      html += '</div>';
      html += '<div class="b2f-cat-review-bucket-body' + bodyShow + '">';
      items.forEach(function(c) {
        html += '<div class="b2f-cat-review-bucket-item">';
        html += '<span>' + esc(c.product_name || c.sku) + ' x' + c.qty + '</span>';
        html += '<span>' + csym + fmt(c.unit_cost * c.qty) + '</span>';
        html += '</div>';
        // Show intent_notes via textContent (XSS safe) — render as escaped text
        if (c.intent_notes) {
          html += '<div class="b2f-cat-intent-note-display">' + esc(c.intent_notes) + '</div>';
        }
      });
      html += '</div></div>';
    });

    html += '<div class="b2f-cat-review-total">';
    html += '<span>รวม</span><span style="color:var(--b2f-accent);">' + csym + fmt(grandTotal) + '</span>';
    html += '</div>';

    document.getElementById('b2fReviewBody').innerHTML = html;
    var $rm = document.getElementById('b2fReviewModal');
    $rm.classList.add('show');
    document.getElementById('b2fReviewSubmitBtn').disabled = false;
    document.getElementById('b2fReviewSubmitBtn').textContent = 'ยืนยันส่ง';
  }

  function closeReviewGate() {
    document.getElementById('b2fReviewModal').classList.remove('show');
