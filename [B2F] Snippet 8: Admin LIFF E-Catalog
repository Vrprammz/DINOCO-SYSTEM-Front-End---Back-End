  // V.7.0: Maker Banner "รีวิว" button — scroll to type filter and select unconfirmed
  // V.7.1: filter key aligned to active chip set (ORDER_INTENT_ENABLED → 'full_set')
  var _bannerReview = document.getElementById('b2fMakerBannerReviewBtn');
