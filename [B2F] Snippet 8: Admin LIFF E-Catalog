      submitting = false;
      if (res.success) {
        closeCartModal(); closeReviewGate(); showSuccess(res.po_number, res.po_id, res.warnings);
        cart = {}; clearCartStorage(); updateCartUI(); toast('สร้าง PO สำเร็จ!', 'success');
