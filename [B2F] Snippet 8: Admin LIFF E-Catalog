      toast(ORDER_INTENT_ENABLED
        ? 'แสดงเฉพาะ \uD83D\uDFE3 ชุดเต็ม — ตรวจสอบ \u26A0\uFE0F ที่ยังไม่ยืนยัน'
        : 'แสดงเฉพาะชุด SET — ตรวจสอบ \u26A0\uFE0F ที่ยังไม่ยืนยัน');
    });
  }

  initAuth();

  // V.5.8: Re-expose debug namespace (permanent — user บ่นว่า debug ไม่ได้)
  window._b2fcat = {
    get makers()          { return makers; },
