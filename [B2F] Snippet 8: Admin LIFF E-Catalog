            + '<div class="b2f-cat-item-detail">' + esc(c.sku) + ' | ' + c.qty + ' x ' + csym + fmt(c.unit_cost) + '</div>'
            + (modeLabel ? '<span class="b2f-cat-cart-mode-badge ' + modeClass + '">' + esc(modeLabel) + '</span>' : '')
            + '</div>'
            + '<div class="b2f-cat-item-total">' + csym + fmt(sub) + '</div>'
            + '<button class="b2f-cat-item-remove" data-sku="' + esc(s) + '">&#10005;</button></div>';
          if (c.intent_notes) {
            html += '<div class="b2f-cat-intent-note-display">\uD83D\uDCDD ' + esc(c.intent_notes) + '</div>';
          }
        });
        html += '<div class="b2f-cat-cart-section-sub">รวม: ' + csym + fmt(secTotal2) + '</div>';
      }
    } else {
    // V.6.6 fallback: original layout
    var setItems = [];
    var regularItems = [];
    skus.forEach(function(s) {
      if (cart[s].product_type === 'set') setItems.push(s);
      else regularItems.push(s);
    });

    // Render SET items with group header
    setItems.forEach(function(s) {
      var c = cart[s]; var sub = c.unit_cost * c.qty;
      var meta = hierarchyMeta[(s||'').toUpperCase()];

      // SET header
      html += '<div class="b2f-cat-cart-set-header">';
      html += '<div class="b2f-cat-cart-set-title">&#9726; ' + esc(c.product_name) + '</div>';
      html += '<div class="b2f-cat-cart-set-detail">' + esc(c.sku) + ' | ' + c.qty + ' x ' + csym + fmt(c.unit_cost) + '</div>';

      // Show leaves preview (DD-7 expand)
      if (meta && meta.all_leaves && meta.all_leaves.length) {
        html += '<div class="b2f-cat-cart-set-leaves">';
        html += '<div style="font-size:10px;color:var(--b2f-purple);font-weight:600;margin-bottom:2px;">DD-7 จะขยายเป็น ' + meta.all_leaves.length + ' ชิ้น:</div>';
        meta.all_leaves.forEach(function(leaf) {
          var leafProduct = products.find(function(p) { return p.sku === leaf; });
          var leafName = leafProduct ? leafProduct.product_name : leaf;
          html += '<div class="b2f-cat-cart-set-leaf">' + esc(leaf) + ' - ' + esc(leafName) + '</div>';
        });
        html += '</div>';

        // Missing leaves warning
        if (meta.missing_leaves && meta.missing_leaves.length) {
          html += '<div class="b2f-cat-cart-warning">&#9888;&#65039; ชิ้นส่วนไม่ครบ: ขาด ' + meta.missing_leaves.length + ' รายการ</div>';
        }
      }

      html += '</div>';

      // SET item row — V.6.3: add thumbnail 56x56
      html += '<div class="b2f-cat-item">'
        + buildCartItemThumbHtml(c)
        + '<div class="b2f-cat-item-info"><div class="b2f-cat-item-name">' + esc(c.product_name) + '</div>'
        + '<div class="b2f-cat-item-detail">' + esc(c.sku) + ' | ' + c.qty + ' x ' + csym + fmt(c.unit_cost) + '</div></div>'
        + '<div class="b2f-cat-item-total">' + csym + fmt(sub) + '</div>'
        + '<button class="b2f-cat-item-remove" data-sku="' + esc(s) + '">&#10005;</button></div>';
    });

    // Duplicate warnings
    var dupWarnings = detectCartDuplicates();
    if (dupWarnings.length) {
      dupWarnings.forEach(function(w) {
        html += '<div class="b2f-cat-cart-dup-warn">&#9888;&#65039; ' + esc(w) + '</div>';
      });
    }

    // Render regular items — V.6.3: add thumbnail 56x56
    regularItems.forEach(function(s) {
      var c = cart[s]; var sub = c.unit_cost * c.qty;
      html += '<div class="b2f-cat-item">'
        + buildCartItemThumbHtml(c)
        + '<div class="b2f-cat-item-info"><div class="b2f-cat-item-name">' + esc(c.product_name) + '</div>'
        + '<div class="b2f-cat-item-detail">' + esc(c.sku) + ' | ' + c.qty + ' x ' + csym + fmt(c.unit_cost) + '</div></div>'
        + '<div class="b2f-cat-item-total">' + csym + fmt(sub) + '</div>'
        + '<button class="b2f-cat-item-remove" data-sku="' + esc(s) + '">&#10005;</button></div>';
    });

    // Currency section for foreign makers
    if (isForeign) {
      html += '<div style="margin-top:16px;padding:14px;background:#eff6ff;border-radius:10px;border:1px solid #bfdbfe;">';
      html += '<div style="font-size:13px;font-weight:600;color:#1e40af;margin-bottom:10px;">&#128177; ข้อมูลสกุลเงิน (' + getMakerCurrency() + ')</div>';
      html += '<div style="margin-bottom:8px;"><label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">วิธีส่ง <span style="color:#dc2626;">*</span></label>';
      html += '<select id="b2fShippingMethod" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;font-family:var(--b2f-font);min-height:44px;" onchange="window._b2fRecalcCartSummary()">';
      html += '<option value="">-- เลือกวิธีส่ง --</option><option value="land">ทางรถ (K)</option><option value="sea">ทางเรือ (M)</option></select></div>';
      html += '<div style="margin-bottom:8px;"><label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">อัตราแลกเปลี่ยน (1 ' + getMakerCurrency() + ' = ? THB) <span style="color:#dc2626;">*</span></label>';
      html += '<input type="number" id="b2fExchangeRate" step="0.0001" min="0.01" placeholder="0.00" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;font-family:var(--b2f-font);min-height:44px;" oninput="window._b2fRecalcCartSummary()">';
      html += '<div id="b2fRateHint" style="font-size:11px;color:var(--b2f-text-muted);margin-top:4px;"></div></div>';
      html += '<div id="b2fCostSummary" style="display:none;padding:10px;background:#fffbeb;border-radius:8px;border:1px solid #fcd34d;font-size:13px;">';
      html += '<div>ยอดสินค้า (' + getMakerCurrency() + '): <strong id="b2fSumForeign">0</strong></div>';
      html += '<div>ยอดสินค้า (THB): <strong id="b2fSumThb">0</strong></div>';
      html += '<div>ค่าส่งรวม (THB): <strong id="b2fSumShipping">0</strong></div>';
      html += '<div style="font-size:15px;margin-top:4px;color:#92400e;">ต้นทุนรวม: <strong id="b2fSumGrand">\u0E3F0</strong></div>';
      html += '</div></div>';
    } else {
      // THB: show shipping if any products have shipping
      var hasShip = skus.some(function(s){ return (cart[s].shipping_land||0) > 0 || (cart[s].shipping_sea||0) > 0; });
      if (hasShip) {
        html += '<div style="margin-top:16px;padding:14px;background:#f0fdf4;border-radius:10px;border:1px solid #bbf7d0;">';
        html += '<div style="font-size:13px;font-weight:600;color:#166534;margin-bottom:8px;">&#128666; ค่าส่ง</div>';
        html += '<select id="b2fShippingMethod" style="width:100%;padding:10px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;font-family:var(--b2f-font);margin-bottom:8px;min-height:44px;" onchange="window._b2fRecalcCartSummary()">';
        html += '<option value="">ไม่ระบุ</option><option value="land">ทางรถ</option><option value="sea">ทางเรือ</option></select>';
        html += '<div id="b2fThbShipSummary" style="font-size:13px;color:#64748b;"></div>';
        html += '</div>';
      }
    }

    } // end V.6.6 fallback else block (ORDER_INTENT_ENABLED check)

    // V.5.0 DD-3: Manufacturing summary สำหรับ shared leaves
    html += renderCartManufacturingSummary();

    $cartBody.innerHTML = html;
    $modalTotal.textContent = csym + fmt(getCartTotal());
    $submitBtn.disabled = false;
    // V.7.0: Update submit button label
    $submitBtn.textContent = ORDER_INTENT_ENABLED ? 'ตรวจสอบ + ส่งคำสั่งซื้อ' : 'สั่งซื้อ';

    // Fetch last rate hint for foreign maker
    if (isForeign && selectedMaker) {
      api('GET', 'po-history?maker_id=' + selectedMaker + '&per_page=1').then(function(r) {
        if (r.success && r.data && r.data.length && r.data[0].exchange_rate && parseFloat(r.data[0].exchange_rate) !== 1) {
          var hint = document.getElementById('b2fRateHint');
          if (hint) hint.textContent = 'PO ล่าสุด (' + (r.data[0].po_number||'') + '): ' + r.data[0].exchange_rate;
          var rateInput = document.getElementById('b2fExchangeRate');
          if (rateInput && !rateInput.value) rateInput.placeholder = r.data[0].exchange_rate;
        }
      });
    }
  }

  // Recalculate cost summary in cart modal
  window._b2fRecalcCartSummary = function() {
    var csym = getMakerSymbol();
    var isForeign = getMakerCurrency() !== 'THB';
    var shipMethodEl = document.getElementById('b2fShippingMethod');
    var shipMethod = shipMethodEl ? shipMethodEl.value : '';
    var total = getCartTotal();

    // Calc shipping
    var totalShipping = 0;
    Object.keys(cart).forEach(function(s) {
      var c = cart[s];
      if (shipMethod === 'land') totalShipping += (c.shipping_land||0) * c.qty;
      else if (shipMethod === 'sea') totalShipping += (c.shipping_sea||0) * c.qty;
    });

    if (isForeign) {
      var rateInput = document.getElementById('b2fExchangeRate');
      var rate = parseFloat(rateInput ? rateInput.value : 0) || 0;
      var sumEl = document.getElementById('b2fCostSummary');
      if (rate > 0) {
        sumEl.style.display = 'block';
        document.getElementById('b2fSumForeign').textContent = csym + fmt(total);
        document.getElementById('b2fSumThb').textContent = '\u0E3F' + fmt(total * rate);
        document.getElementById('b2fSumShipping').textContent = '\u0E3F' + fmt(totalShipping);
        document.getElementById('b2fSumGrand').textContent = '\u0E3F' + fmt(total * rate + totalShipping);
        $modalTotal.textContent = csym + fmt(total) + ' (\u2248\u0E3F' + fmt(total * rate + totalShipping) + ')';
      } else {
        sumEl.style.display = 'none';
        $modalTotal.textContent = csym + fmt(total);
      }
    } else {
      // THB
      var thbSummary = document.getElementById('b2fThbShipSummary');
      if (thbSummary) {
        if (totalShipping > 0) {
          thbSummary.innerHTML = 'ค่าส่ง: <strong>\u0E3F' + fmt(totalShipping) + '</strong> | ต้นทุนรวม: <strong>\u0E3F' + fmt(total + totalShipping) + '</strong>';
        } else {
          thbSummary.innerHTML = '';
        }
      }
      $modalTotal.textContent = '\u0E3F' + fmt(total + totalShipping);
    }
  };

  function submitOrder(force) {
    if (submitting) return;
    var items = [];
    Object.keys(cart).forEach(function(s) {
      var entry = { sku: cart[s].sku, qty: cart[s].qty };
      // V.7.0: include order_mode + source_sku + intent_notes when flag ON
      if (ORDER_INTENT_ENABLED) {
        entry.order_mode = cart[s].order_mode || 'single_leaf';
        entry.source_sku = cart[s].source_sku || cart[s].sku;
        if (cart[s].intent_notes) entry.intent_notes = String(cart[s].intent_notes).substring(0, 200);
      }
      items.push(entry);
    });
    if (!items.length) return toast('ตะกร้าว่าง', 'error');
    if (!selectedMaker) return toast('กรุณาเลือกโรงงาน', 'error');

    // Validate foreign currency fields
    var isForeign = getMakerCurrency() !== 'THB';
    var shipMethodEl = document.getElementById('b2fShippingMethod');
    var shipMethod = shipMethodEl ? shipMethodEl.value : '';
    if (isForeign) {
      var rateInput = document.getElementById('b2fExchangeRate');
      var rate = parseFloat(rateInput ? rateInput.value : 0);
      if (!rate || rate <= 0) return toast('กรุณากรอกอัตราแลกเปลี่ยน', 'error');
      if (!shipMethod) return toast('กรุณาเลือกวิธีส่ง', 'error');
    }

    submitting = true; $submitBtn.disabled = true; $submitBtn.textContent = 'กำลังสร้าง PO...';
    var body = { maker_id: parseInt(selectedMaker), items: items, note: $cartNote.value.trim() || '' };
    if (force) body.force = true;
    // Multi-currency params
    if (isForeign) {
      body.exchange_rate = parseFloat(document.getElementById('b2fExchangeRate').value);
      body.shipping_method = shipMethod;
    } else if (shipMethod) {
      body.shipping_method = shipMethod;
    }

