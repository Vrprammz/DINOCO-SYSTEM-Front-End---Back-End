  // V.5.0 DD-3: นับว่า product นี้อยู่ใน top-level SET กี่ตัว (walk-up recursive)
  function countTopSetsForProduct(sku) {
    if (!skuRelations) return 0;
    var skuU = (sku || '').toUpperCase();
    var topSets = {};
    function walkUp(s) {
      s = String(s).toUpperCase();
      var found = [];
      Object.keys(skuRelations).forEach(function(maybeParent) {
        if ((skuRelations[maybeParent] || []).indexOf(s) !== -1) found.push(maybeParent.toUpperCase());
      });
      if (found.length === 0) { topSets[s] = true; }
      else { found.forEach(walkUp); }
    }
    // เริ่มจาก sku — ถ้า sku ไม่มี parent ไม่นับ (สินค้าเดี่ยว)
    var hasParent = false;
    Object.keys(skuRelations).forEach(function(mp) {
      if ((skuRelations[mp] || []).indexOf(skuU) !== -1) hasParent = true;
    });
    if (!hasParent) return 0;
    walkUp(skuU);
    return Object.keys(topSets).length;
  }

  // V.5.0 DD-3: Compute manufacturing summary for cart
  // Returns { leafSku: { qty: total, breakdown: [{parent_sku, qty}] } }
  function computeCartManufacturingSummary() {
    var summary = {};
    Object.keys(cart).forEach(function(sku) {
      var item = cart[sku];
      var qty = item.qty || 0;
      if (qty <= 0) return;
      var skuU = sku.toUpperCase();
      // Check if SET (has children in skuRelations)
      var children = skuRelations[skuU] || [];
      if (children.length > 0) {
        // Walk down to leaves + add qty to each leaf
        function walkDown(parentSku, multiplier, parentName) {
          var chs = skuRelations[parentSku.toUpperCase()] || [];
          chs.forEach(function(ch) {
            var chU = ch.toUpperCase();
            var gcs = skuRelations[chU] || [];
            if (gcs.length === 0) {
              // leaf
              if (!summary[chU]) summary[chU] = { qty: 0, breakdown: [] };
              summary[chU].qty += multiplier;
              summary[chU].breakdown.push({ parent_sku: parentSku, parent_name: parentName, qty: multiplier });
            } else {
              walkDown(ch, multiplier, parentName);
            }
          });
        }
        walkDown(skuU, qty, item.product_name || skuU);
      } else {
        // standalone leaf
        if (!summary[skuU]) summary[skuU] = { qty: 0, breakdown: [] };
        summary[skuU].qty += qty;
        summary[skuU].breakdown.push({ parent_sku: '__standalone__', parent_name: '', qty: qty });
      }
    });
    return summary;
  }

  // V.5.0: Render manufacturing summary section in cart
  function renderCartManufacturingSummary() {
    var summary = computeCartManufacturingSummary();
    var sharedLeaves = Object.keys(summary).filter(function(sku) {
      return summary[sku].breakdown.length > 1;
    });
    if (sharedLeaves.length === 0) return ''; // ไม่มี shared leaf ไม่ต้องแสดง

    var h = '<div style="margin:12px 0;padding:12px;background:#fef3c7;border:1px solid #fde68a;border-radius:10px;font-size:12px;color:#92400e;">';
    h += '<div style="font-weight:700;margin-bottom:6px;">⚠️ ข้อมูลการผลิต</div>';
    sharedLeaves.forEach(function(sku) {
      var s = summary[sku];
      var parts = s.breakdown.map(function(b) {
        var n = b.parent_sku === '__standalone__' ? 'เดี่ยว' : (b.parent_name || b.parent_sku);
        return n + '×' + b.qty;
      }).join(' + ');
      h += '<div style="margin:4px 0;">• <b>' + esc(sku) + '</b> ต้องผลิต <b>' + s.qty + '</b> ชิ้น <span style="color:#a16207;">(' + parts + ')</span></div>';
    });
    h += '</div>';
    return h;
  }

