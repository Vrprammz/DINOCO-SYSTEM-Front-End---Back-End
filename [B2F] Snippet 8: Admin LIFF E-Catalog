  // V.6.3: SET Detail main "+ ชุดเต็ม" stepper — event delegation บน wrapper
  var _setFullAddWrap = document.getElementById('b2fSetDetailAddWrap');
  if (_setFullAddWrap) {
    _setFullAddWrap.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-stepact]');
