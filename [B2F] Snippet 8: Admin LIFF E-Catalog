      var imgHtml = imgUrl
        ? '<img class="b2f-cat-model-card-img" src="' + esc(imgUrl) + '" alt="' + esc(m) + '" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">'
          + '<div class="b2f-cat-model-card-placeholder" style="display:none;">\uD83C\uDFCD\uFE0F</div>'
        : '<div class="b2f-cat-model-card-placeholder">\uD83C\uDFCD\uFE0F</div>';
      card.innerHTML = imgHtml + '<div class="b2f-cat-model-card-name">' + esc(m) + '</div>';
      card.onclick = (function(model) { return function() {
        filterModel = filterModel === model ? '' : model;
        renderModelFilter();
        renderTypeChips(); // V.7.2: chip counts follow model filter
        renderFilteredProducts();
        updateCartMotoIcon(); // V.6.2: refresh moto icon ในแถบตะกร้า
      }; })(m);
      inner.appendChild(card);
    });

    $modelRow.style.display = 'block';
  }

  // ── V.4.0 / V.5.1 / V.5.2 / V.7.1: Type Filter Chips ──
  // V.5.1: count badges "(N)" + hide chips if count=0
  // V.5.2: align labels + categories กับ Inventory Stock Management (source of truth)
  // V.7.1: เมื่อ ORDER_INTENT_ENABLED → ใช้ 3 chips V.7.0 taxonomy (🟣 ชุดเต็ม / 🟠 แยกชุด / ⚪ ชิ้นเดี่ยว)
  //        filterType key ใช้ชื่อเดียวกับ order_mode (full_set / sub_unit / single_leaf) เพื่อ consistency
  //        flag OFF → fallback 5 chips เดิม (hierarchy-based: set/child/grandchild/single)
  function renderTypeChips() {
    // V.5.9: count ใช้ _jsDisplayType (respect override) — ตรงกับ Product Catalog chip counts
    // V.6.5: count **หลัง** virtual filter — chip counts ต้องตรงกับที่ user เห็นใน grid
    // V.7.2: ต้องนับ **หลัง** search + model filter ด้วย — ถ้าเลือกรุ่น NX500
    //        chip counts ต้องสะท้อน products ของ NX500 เท่านั้น
    var q = ($search && $search.value ? $search.value : '').trim().toLowerCase();
    var hier = buildHierarchyLookup();
    var visibleProducts = products.filter(function(p) {
      if (isHiddenVirtual(p)) return false;
      // Search filter
      if (q) {
        var matchSearch = (p.sku || '').toLowerCase().indexOf(q) >= 0
          || (p.product_name || '').toLowerCase().indexOf(q) >= 0
          || (p.compatible_models || '').toLowerCase().indexOf(q) >= 0;
        if (!matchSearch) return false;
      }
      // Model filter (uses same helper as renderFilteredProducts for consistency)
      if (filterModel) {
        if (!productMatchesModel(p, filterModel, hier)) return false;
      }
      return true;
    });

    var inner = document.getElementById('b2fTypeChipsInner');
    inner.innerHTML = '';
    var types;
    var counts;

    if (ORDER_INTENT_ENABLED) {
      // V.7.0 taxonomy — 3 chips tied to production_mode
      counts = { '': visibleProducts.length, full_set: 0, sub_unit: 0, single_leaf: 0 };
      visibleProducts.forEach(function(p) {
        var pm = (p.production_mode || '').toLowerCase();
        if (pm === 'set_assembled' || pm === 'cross_factory_assembly') {
          counts.full_set++;
        } else if (pm === 'sub_unit') {
          counts.sub_unit++;
        } else if (pm === 'single' || !pm) {
          counts.single_leaf++;
        }
      });
      if (!counts.full_set && !counts.sub_unit && !counts.single_leaf) {
        $typeChips.style.display = 'none'; return;
      }
      types = [
        { key: '',            label: 'ทั้งหมด' },
        { key: 'full_set',    label: '\uD83D\uDFE3 ชุดเต็ม' },
        { key: 'sub_unit',    label: '\uD83D\uDFE0 แยกชุด' },
        { key: 'single_leaf', label: '\u26AA ชิ้นเดี่ยว' }
      ];
    } else {
      // Legacy V.6.6 — 5 chips (hierarchy-based)
      counts = { '': visibleProducts.length, set: 0, child: 0, grandchild: 0, single: 0 };
      visibleProducts.forEach(function(p) {
        var t = p._jsDisplayType || p._jsType || 'single';
        if (counts[t] !== undefined) counts[t]++;
      });
      if (!counts.set && !counts.child && !counts.grandchild && !counts.single) {
        $typeChips.style.display = 'none'; return;
      }
      types = [
        { key: '',           label: 'ทั้งหมด' },
        { key: 'set',        label: 'ชุด SET' },
        { key: 'single',     label: 'เดี่ยว' },
        { key: 'child',      label: 'ลูกชิ้นส่วน' },
        { key: 'grandchild', label: 'ชิ้นส่วนย่อย' }
      ];
    }

    types.forEach(function(t) {
      var n = counts[t.key] || 0;
      // V.5.1: ซ่อน chip ถ้า count=0 (ยกเว้น "ทั้งหมด")
      if (t.key !== '' && n === 0) return;

      var chip = document.createElement('button');
      chip.className = 'b2f-cat-type-chip' + (filterType === t.key ? ' active' : '');
      chip.setAttribute('data-type', t.key);
      chip.textContent = t.label + ' (' + n + ')';
      chip.onclick = function() { filterType = filterType === t.key ? '' : t.key; renderTypeChips(); renderFilteredProducts(); };
      inner.appendChild(chip);
    });

    $typeChips.style.display = 'block';
  }

  // ── V.4.0: Apply all filters then render ──
  function renderFilteredProducts() {
    var q = ($search.value || '').trim().toLowerCase();
    var hier = buildHierarchyLookup();

    // V.4.4: Use JS-derived _jsType for all filtering
    // V.6.5: setSkusInList ใช้นับเฉพาะ SET ที่ "จะแสดงจริง" (หลัง virtual filter)
    //        ถ้า virtual SET ถูกซ่อน → ลูกของมันไม่ควรถูก hide ด้วยเหตุผล "อยู่ใน SET in list"
    var setSkusInList = {};
    products.forEach(function(p) {
      if (isHiddenVirtual(p)) return; // virtual SET ที่ซ่อน → ไม่นับเป็น "SET in list"
      if (p._jsType === 'set') setSkusInList[(p.sku || '').toUpperCase()] = true;
    });

    var filtered = products.filter(function(p) {
      // V.6.5: virtual top-level SET toggle OFF → ซ่อน
      if (isHiddenVirtual(p)) return false;

      var at = p._jsType || 'single';

      // V.4.4: เมื่อไม่ได้ filter type เจาะจง → ซ่อน child/gc ที่ SET อยู่ใน list (แสดงใน SET detail แทน)
      // DD-3 fix: ใช้ _jsParents (array from sku_relations) เช็คทุก SET parent
      // V.7.1: รวม 'full_set' key (V.7.0 taxonomy) — semantics เหมือน 'set' เดิม
      if (!filterType || filterType === 'set' || filterType === 'full_set') {
        if (at === 'child' || at === 'grandchild') {
          var pskus = p._jsParents || [];
          var hiddenBySet = false;
          for (var pi = 0; pi < pskus.length; pi++) {
            var psu = String(pskus[pi]).toUpperCase();
            if (setSkusInList[psu]) { hiddenBySet = true; break; }
            // Walk up: check if parent's parent is a SET in list
            Object.keys(skuRelations).forEach(function(gpSku) {
              if ((skuRelations[gpSku] || []).indexOf(psu) !== -1 && setSkusInList[gpSku]) {
                hiddenBySet = true;
              }
            });
            if (hiddenBySet) break;
          }
          if (hiddenBySet) return false;
        }
      }

      // Search filter
      if (q) {
        var matchSearch = (p.sku || '').toLowerCase().indexOf(q) >= 0
          || (p.product_name || '').toLowerCase().indexOf(q) >= 0
          || (p.compatible_models || '').toLowerCase().indexOf(q) >= 0;
        if (!matchSearch) return false;
      }

      // V.5.3: Model filter — SETs inherit models จาก descendants
      // Admin ใส่ model ที่ leaf (L/R) เท่านั้น → SET ต้อง walk descendants เอง
      if (filterModel) {
        if (!productMatchesModel(p, filterModel, hier)) return false;
      }

      // V.5.9: Type filter ใช้ _jsDisplayType (respect ui_role_override) — ตรงกับ Product Catalog
      // V.7.1: ORDER_INTENT_ENABLED → filter by production_mode (V.7.0 taxonomy)
      //        OFF → legacy hierarchy filter (set / single / child / grandchild)
      if (ORDER_INTENT_ENABLED) {
        var pmode = (p.production_mode || '').toLowerCase();
        if (filterType === 'full_set') {
          if (pmode !== 'set_assembled' && pmode !== 'cross_factory_assembly') return false;
        } else if (filterType === 'sub_unit') {
          if (pmode !== 'sub_unit') return false;
        } else if (filterType === 'single_leaf') {
          if (pmode !== 'single' && pmode !== '') return false;
        }
      } else {
        var dt = p._jsDisplayType || at;
        if (filterType === 'set') {
          if (dt !== 'set') return false;
        } else if (filterType === 'single') {
          if (dt !== 'single') return false;
        } else if (filterType === 'child') {
          if (dt !== 'child') return false;
        } else if (filterType === 'grandchild') {
          if (dt !== 'grandchild') return false;
        }
      }

      return true;
    });

    renderProducts(filtered, hier);
  }

  function renderProducts(list, hier) {
    if (!list || !list.length) {
      $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#128270;</div><div>ไม่พบสินค้าที่ค้นหา</div></div>';
      return;
    }
    var csym = getMakerSymbol();
    var html = '<div class="b2f-cat-grid">';
    list.forEach(function(p) {
      // V.5.9: grouping/cart ใช้ _jsType (hierarchy จริง), badge ใช้ _jsDisplayType (respect override)
      var jsType = p._jsType || 'single';
      var jsDisplay = p._jsDisplayType || jsType;
      var isSet = jsType === 'set'; // grouping: ใช้ hierarchy จริง (SET card button ยัง "ดูชุด")
      var inCart = cart[p.sku] ? true : false;
      var qty = cart[p.sku] ? cart[p.sku].qty : 0;

      // V.7.0: production_mode from enriched API (when flag ON)
      var pm = p.production_mode || '';
      var confStatus = p.confirmation_status || '';
      var admDisplay = p.admin_display_mode || 'auto';

      // V.7.0: Card variant logic (when ORDER_INTENT_ENABLED)
      // Skip render if admin_display_mode='as_parts' and has children (ungroup: children render as flat)
      if (ORDER_INTENT_ENABLED && admDisplay === 'as_parts' && p.has_children) {
        return; // skip — children shown as flat instead
      }

      // V.6.5: Virtual SET badge (kept for V.6.6 compat)
      var virtualBadge = '';
      if (p.is_virtual && p.virtual_reason === 'shared_parts_assembled') {
        virtualBadge = '<span class="b2f-cat-virtual-badge" title="SET นี้ประกอบจากชิ้นส่วนที่ใช้ร่วมกับ SET อื่น">&#128279; ประกอบจากชิ้นส่วน</span>';
      }

      var imgInner = p.image_url
        ? '<img src="' + esc(p.image_url) + '" alt="' + esc(p.product_name) + '" loading="lazy" onerror="this.parentElement.innerHTML=\'&#128230;\'">'
        : '&#128230;';
      var imgStyle = p.image_url ? '' : 'font-size:32px;display:flex;align-items:center;justify-content:center;';
      var imgHtml = '<div class="b2f-cat-card-img"' + (imgStyle ? ' style="' + imgStyle + '"' : '') + '>' + virtualBadge + imgInner + '</div>';

      var shipLine = '';
      if ((p.shipping_land && p.shipping_land > 0) || (p.shipping_sea && p.shipping_sea > 0)) {
        shipLine = '<div style="font-size:9px;color:var(--b2f-text-muted);margin-bottom:2px;">ค่าส่ง: รถ \u0E3F' + fmt(p.shipping_land||0) + ' | เรือ \u0E3F' + fmt(p.shipping_sea||0) + '</div>';
      }

      // V.7.0: Type badge — use production_mode when flag ON, else V.6.6 behavior
      var typeBadge = '';
      if (ORDER_INTENT_ENABLED && pm) {
        if (pm === 'set_assembled') {
          var lc = '';
          if (hierarchyMeta[(p.sku||'').toUpperCase()]) lc = hierarchyMeta[(p.sku||'').toUpperCase()].total_leaves || '';
          else if (p._jsChildrenCount) lc = p._jsChildrenCount;
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-set-assembled">\uD83D\uDFE3 ชุดเต็ม' + (lc ? ' ' + lc + ' ชิ้น' : '') + '</span>';
          if (confStatus === 'auto_synced') {
            typeBadge += '<span class="b2f-cat-badge-unconfirmed">\u26A0\uFE0F</span>';
          }
        } else if (pm === 'sub_unit') {
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-sub-unit">\uD83D\uDFE0 แยกชุด</span>';
        } else if (pm === 'cross_factory_assembly') {
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-cross-factory">\uD83D\uDFE0 DINOCO ประกอบ</span>';
        } else {
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-single">\u26AA ชิ้นเดี่ยว</span>';
        }
      } else {
        // V.6.6 fallback badges
        if (jsDisplay === 'set') {
          var leafCount = '';
          if (hierarchyMeta[(p.sku||'').toUpperCase()]) leafCount = hierarchyMeta[(p.sku||'').toUpperCase()].total_leaves || '';
          else if (p._jsChildrenCount) leafCount = p._jsChildrenCount;
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-set">ชุด ' + (leafCount ? leafCount + ' ชิ้น' : '') + '</span>';
        } else if (jsDisplay === 'child') {
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-child">ชิ้นส่วน</span>';
        } else if (jsDisplay === 'grandchild') {
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-grandchild">ชิ้นส่วนย่อย</span>';
        } else if (jsDisplay === 'single') {
          typeBadge = '<span class="b2f-cat-badge b2f-cat-badge-single">เดี่ยว</span>';
        }
      }
      if (p._jsIsOverride) {
        typeBadge += '<span class="b2f-cat-badge-override" title="Admin override: auto=' + jsType + '">&#9995;</span>';
      }

      // Breadcrumb for orphan children/grandchildren
      var breadcrumb = '';
      if ((jsDisplay === 'child' || jsDisplay === 'grandchild') && p.top_parent_name) {
        breadcrumb = '<div class="b2f-cat-breadcrumb">' + esc(p.top_parent_name) + '</div>';
      }

      // Card classes
      var cardClass = 'b2f-cat-card';
