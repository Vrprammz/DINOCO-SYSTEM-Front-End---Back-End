  // Recalculate cost summary in cart modal
  window._b2fRecalcCartSummary = function() {
    var csym = getMakerSymbol();
    var isForeign = getMakerCurrency() !== 'THB';
    var shipMethodEl = document.getElementById('b2fShippingMethod');
    var shipMethod = shipMethodEl ? shipMethodEl.value : '';
    var total = getCartTotal();

    // Calc shipping
    var totalShipping = 0;
    Object.keys(cart).forEach(function(s) {
      var c = cart[s];
      if (shipMethod === 'land') totalShipping += (c.shipping_land||0) * c.qty;
      else if (shipMethod === 'sea') totalShipping += (c.shipping_sea||0) * c.qty;
    });

    if (isForeign) {
      var rateInput = document.getElementById('b2fExchangeRate');
      var rate = parseFloat(rateInput ? rateInput.value : 0) || 0;
      var sumEl = document.getElementById('b2fCostSummary');
      if (rate > 0) {
        sumEl.style.display = 'block';
        document.getElementById('b2fSumForeign').textContent = csym + fmt(total);
        document.getElementById('b2fSumThb').textContent = '\u0E3F' + fmt(total * rate);
        document.getElementById('b2fSumShipping').textContent = '\u0E3F' + fmt(totalShipping);
        document.getElementById('b2fSumGrand').textContent = '\u0E3F' + fmt(total * rate + totalShipping);
        $modalTotal.textContent = csym + fmt(total) + ' (\u2248\u0E3F' + fmt(total * rate + totalShipping) + ')';
      } else {
        sumEl.style.display = 'none';
        $modalTotal.textContent = csym + fmt(total);
      }
    } else {
      // THB
      var thbSummary = document.getElementById('b2fThbShipSummary');
      if (thbSummary) {
        if (totalShipping > 0) {
          thbSummary.innerHTML = 'ค่าส่ง: <strong>\u0E3F' + fmt(totalShipping) + '</strong> | ต้นทุนรวม: <strong>\u0E3F' + fmt(total + totalShipping) + '</strong>';
        } else {
          thbSummary.innerHTML = '';
        }
      }
      $modalTotal.textContent = '\u0E3F' + fmt(total + totalShipping);
    }
  };

  function submitOrder(force) {
    if (submitting) return;
    var items = [];
    Object.keys(cart).forEach(function(s) { items.push({ sku: cart[s].sku, qty: cart[s].qty }); });
    if (!items.length) return toast('ตะกร้าว่าง', 'error');
    if (!selectedMaker) return toast('กรุณาเลือกโรงงาน', 'error');

    // Validate foreign currency fields
    var isForeign = getMakerCurrency() !== 'THB';
    var shipMethodEl = document.getElementById('b2fShippingMethod');
    var shipMethod = shipMethodEl ? shipMethodEl.value : '';
    if (isForeign) {
      var rateInput = document.getElementById('b2fExchangeRate');
      var rate = parseFloat(rateInput ? rateInput.value : 0);
      if (!rate || rate <= 0) return toast('กรุณากรอกอัตราแลกเปลี่ยน', 'error');
      if (!shipMethod) return toast('กรุณาเลือกวิธีส่ง', 'error');
    }

    submitting = true; $submitBtn.disabled = true; $submitBtn.textContent = 'กำลังสร้าง PO...';
    var body = { maker_id: parseInt(selectedMaker), items: items, note: $cartNote.value.trim() || '' };
    if (force) body.force = true;
    // Multi-currency params
    if (isForeign) {
      body.exchange_rate = parseFloat(document.getElementById('b2fExchangeRate').value);
      body.shipping_method = shipMethod;
    } else if (shipMethod) {
      body.shipping_method = shipMethod;
    }

    api('POST', 'create-po', body).then(function(res) {
      submitting = false;
      if (res.success) {
        closeCartModal(); showSuccess(res.po_number, res.po_id, res.warnings);
        cart = {}; updateCartUI(); toast('สร้าง PO สำเร็จ!', 'success');
      } else if (res.code === 'DUPLICATE_PO') {
        $submitBtn.disabled = false; $submitBtn.textContent = 'สั่งซื้อ';
        $dupMsg.textContent = res.error + (res.existing_po ? ' (' + res.existing_po + ')' : '');
        $dupModal.classList.add('show');
      } else {
        toast(res.error || 'เกิดข้อผิดพลาด', 'error');
        $submitBtn.disabled = false; $submitBtn.textContent = 'สั่งซื้อ';
      }
    }).catch(function() {
      submitting = false; $submitBtn.disabled = false; $submitBtn.textContent = 'สั่งซื้อ';
      toast('เชื่อมต่อเซิร์ฟเวอร์ไม่ได้', 'error');
    });
  }

  function showSuccess(poNumber, poId, warnings) {
    document.getElementById('b2fHeader').style.display = 'none';
    $searchWrap.style.display = 'none'; $productArea.style.display = 'none';
    $modelRow.style.display = 'none'; $typeChips.style.display = 'none';
    $cartBar.classList.remove('visible');
    document.getElementById('b2fSuccessPO').textContent = poNumber;
    var warnEl = document.getElementById('b2fSuccessWarnings');
    warnEl.innerHTML = (warnings && warnings.length) ? warnings.map(function(w) { return '&#9888;&#65039; ' + esc(w); }).join('<br>') : '';
    $success.classList.add('show');
    // V.2.6: Auto-close LIFF after 5 seconds
    setTimeout(function() {
      if (typeof liff !== 'undefined' && liff.isInClient && liff.isInClient()) {
        liff.closeWindow();
      } else {
        window.close();
      }
    }, 5000);
  }

  function resetCatalog() {
    $success.classList.remove('show');
    document.getElementById('b2fHeader').style.display = '';
    $productArea.style.display = '';
    $makerSelect.value = ''; selectedMaker = null; cart = {}; $cartNote.value = '';
    filterModel = ''; filterType = '';
    updateCartUI(); loadProducts('');
  }

  function openCartModal() { renderCartModal(); $cartModal.classList.add('show'); }
  function closeCartModal() { $cartModal.classList.remove('show'); }

  // ── Events ──
  $makerSelect.addEventListener('change', function() { loadProducts(this.value); });

  $search.addEventListener('input', function() {
    renderFilteredProducts();
  });

  // Product grid: qty buttons + SET "ดูชุด" button
  $productArea.addEventListener('click', function(e) {
    // SET button
    var setBtn = e.target.closest('.b2f-cat-set-btn');
    if (setBtn) {
      var sku = setBtn.getAttribute('data-setsku');
      if (sku) openSetDetail(sku);
      return;
    }
    // Qty buttons
    var btn = e.target.closest('.b2f-cat-qty-btn');
    if (!btn) return;
    var current = cart[btn.dataset.sku] ? cart[btn.dataset.sku].qty : 0;
    setQty(btn.dataset.sku, btn.dataset.action === 'plus' ? current + 1 : current - 1);
  });

  $productArea.addEventListener('change', function(e) {
    if (e.target.classList.contains('b2f-cat-qty-val')) setQty(e.target.dataset.sku, e.target.value);
  });

  // SET Detail: back button
  document.getElementById('b2fSetDetailBack').addEventListener('click', function() {
    if (history.state && history.state.view === 'b2f-set-detail') {
      history.back();
    } else {
      closeSetDetail();
    }
  });

  // Handle browser back button
  window.addEventListener('popstate', function(e) {
    if ($setDetail.classList.contains('show')) {
      closeSetDetail();
    }
  });

  // SET Detail: "สั่งชุดเต็ม" button
  document.getElementById('b2fSetDetailAddBtn').addEventListener('click', function() {
    if (!setDetailProduct) return;
    var p = setDetailProduct;
    var current = cart[p.sku] ? cart[p.sku].qty : 0;
    setQty(p.sku, current + 1);
    updateSetDetailAddBtn();
    toast('+1 ' + p.product_name.substring(0, 25));
  });

  // SET Detail: child/grandchild qty buttons (event delegation)
  document.getElementById('b2fSetDetailItems').addEventListener('click', function(e) {
    var btn = e.target.closest('[data-childact]');
    if (!btn) return;
    e.stopPropagation();
    var sku = btn.getAttribute('data-childsku');
    var act = btn.getAttribute('data-childact');
    if (act === 'add') {
      setQty(sku, 1);
    } else if (act === 'plus') {
      var cur = cart[sku] ? cart[sku].qty : 0;
      setQty(sku, cur + 1);
    } else if (act === 'minus') {
      var cur2 = cart[sku] ? cart[sku].qty : 0;
      setQty(sku, cur2 - 1);
    }
    renderSetDetailItems();
    updateSetDetailAddBtn();
  });

  document.getElementById('b2fCartOpenBtn').addEventListener('click', openCartModal);
  document.getElementById('b2fCartClose').addEventListener('click', closeCartModal);
  $cartModal.addEventListener('click', function(e) { if (e.target === $cartModal) closeCartModal(); });

  $cartBody.addEventListener('click', function(e) {
    var btn = e.target.closest('.b2f-cat-item-remove');
    if (!btn) return;
    setQty(btn.dataset.sku, 0); renderCartModal();
    if (!Object.keys(cart).length) closeCartModal();
  });

  $submitBtn.addEventListener('click', function() { submitOrder(false); });
  document.getElementById('b2fDupCancel').addEventListener('click', function() { $dupModal.classList.remove('show'); });
  document.getElementById('b2fDupConfirm').addEventListener('click', function() { $dupModal.classList.remove('show'); submitOrder(true); });
  document.getElementById('b2fSuccessNew').addEventListener('click', resetCatalog);

  initAuth();

  // V.5.3+: Debug namespace — inspect state ผ่าน F12 console (window._b2fcat)
  window._b2fcat = {
    get products() { return products; },
    get skuRelations() { return skuRelations; },
    get motoCatalog() { return motoCatalog; },
    get hierarchyMeta() { return hierarchyMeta; },
    get filterModel() { return filterModel; },
    get filterType() { return filterType; },
    parseModels: parseModels,
    collectModelsWithDescendants: collectModelsWithDescendants,
    productMatchesModel: productMatchesModel,
    buildHierarchyLookup: buildHierarchyLookup
  };
})();
</script>
</body>
</html>
