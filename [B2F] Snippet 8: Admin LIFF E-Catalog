  function getMakerCurrency() {
    if (!selectedMakerData) return 'THB';
    return selectedMakerData.currency || 'THB';
  }
  function getMakerSymbol() {
    var c = getMakerCurrency();
    return c === 'CNY' ? '\u00A5' : (c === 'USD' ? '$' : '\u0E3F');
  }

  // ── V.4.0: Parse compatible_models from products or catalog entries ──
  // V.5.1: Normalize object {brand_name, name} → display name string
  //        (Inventory V.42.0 H-11 whitelist เก็บเป็น JSON array ของ objects)
  // V.5.4: รับทั้ง product object (maker-products) + catalog entry (catalogMap) — ใช้ field ชื่อเดียวกัน compatible_models
  function parseModels(p) {
    if (!p || !p.compatible_models) return [];
    var raw = p.compatible_models;
    if (typeof raw === 'string') {
      try { raw = JSON.parse(raw); } catch(e) { return []; }
    }
    if (!Array.isArray(raw)) return [];
    var out = [];
    raw.forEach(function(m) {
      if (!m) return;
      if (typeof m === 'string') out.push(m);
      else if (typeof m === 'object') {
        var name = m.name || m.model_name || m.slug || '';
        if (name) out.push(String(name));
      }
    });
    return out;
  }

  // V.5.4: Lookup SKU ใน catalog source of truth — fallback เวลา maker ไม่ได้ register SKU นี้
  //        เก็บ compatible_models + name + image_url จาก wp_dinoco_products
  function lookupCatalog(skuU) {
    if (!skuU) return null;
    return catalogMap[skuU] || null;
  }

  // V.5.3 / V.5.4 / V.6.1: collect all model strings for a product
  // V.5.3: direct + descendants walk
  // V.5.4: fallback ไป catalogMap (source of truth = wp_dinoco_products)
  // V.6.1: ถ้า SET มี direct models ชัดเจน (admin set ใน Product Catalog) → respect + ไม่ walk descendants
  //        ป้องกัน shared leaves ลาก wrong models เข้ามา
  //        (เช่น DNCSETNX500EIRNB ตั้ง "NX500 E-clutch" ชัดเจน ไม่ควร inherit "NX500" จาก shared leaf IRONB)
  function collectModelsWithDescendants(p, hier) {
    var out = {};
    parseModels(p).forEach(function(m) { out[m] = true; });
    var skuU0 = (p.sku || '').toUpperCase();
    var catSelf = lookupCatalog(skuU0);
    if (catSelf) parseModels(catSelf).forEach(function(m) { out[m] = true; });

    // V.6.1: ถ้ามี direct models แล้ว → respect admin intent, ไม่ walk descendants
    var directKeys = Object.keys(out);
    if (directKeys.length > 0) return directKeys;

    var at = p._jsType || 'single';
    if (at !== 'set' && at !== 'child') return Object.keys(out);

    var walked = {};
    var queue = [skuU0];
    while (queue.length) {
      var cur = queue.shift();
      if (walked[cur]) continue;
      walked[cur] = true;
      var children = skuRelations[cur] || [];
      children.forEach(function(childSku) {
        var childU = String(childSku).toUpperCase();
        // V.5.4: ลองหาใน products ก่อน — ถ้าไม่มี fallback catalogMap
        var cp = (hier && hier.bysku) ? hier.bysku[childU] : null;
        if (cp) {
          parseModels(cp).forEach(function(m) { out[m] = true; });
        } else {
          var catCh = lookupCatalog(childU);
          if (catCh) parseModels(catCh).forEach(function(m) { out[m] = true; });
        }
        if (!walked[childU]) queue.push(childU);
      });
    }
    return Object.keys(out);
  }

  // V.5.3: model filter — match ถ้า product ตัวเอง หรือ descendant ตัวใดตัวหนึ่งมี model ที่เลือก
  function productMatchesModel(p, model, hier) {
    var models = collectModelsWithDescendants(p, hier);
    return models.indexOf(model) >= 0;
  }

  // ── V.4.0 / V.7.2: Get model image from moto_catalog ──
  // V.7.2 FIX (3 bugs aligned with B2B Snippet 4 pattern):
  //   (1) moto_catalog can be keyed object OR array → handle both via Object.values
  //   (2) model field = `name` (not `model_name`)
  //   (3) image field = `image` OR `image_url` (support both — forward compat)
  var _modelImageMap = null;
  function buildModelImageMap() {
    var map = {};
    if (!motoCatalog) return map;
    var brands = Array.isArray(motoCatalog) ? motoCatalog : Object.values(motoCatalog);
    brands.forEach(function(brand) {
      if (!brand || !brand.models) return;
      brand.models.forEach(function(m) {
        if (!m) return;
        var name = m.name || m.model_name || '';
        var img  = m.image || m.image_url || '';
        if (name && img) map[name] = img;
      });
    });
    return map;
  }
  function getModelImage(modelName) {
    if (!_modelImageMap) _modelImageMap = buildModelImageMap();
    return _modelImageMap[modelName] || '';
  }

  // ── V.6.5: Virtual SET filter helpers ──
  // isHiddenVirtual(p): true ถ้า product เป็น virtual top-level SET + toggle OFF
  // - virtual_reason='shared_parts_assembled' → top-level SET ประกอบจากชิ้นส่วน shared (default hide)
  // - virtual_reason='intermediate_sub_set' → sub-SET ที่มี grandparent (จำเป็นต่อ SET Detail, ไม่ซ่อน)
  // - ไม่มี is_virtual → registered product จริง (ไม่ซ่อน)
  function isHiddenVirtual(p) {
    if (!p || !p.is_virtual) return false;
    if (p.virtual_reason !== 'shared_parts_assembled') return false; // intermediate sub-SET → always keep
    return !showVirtualSets;
  }
  // countHiddenVirtuals(): จำนวน virtual SETs ที่ถูกซ่อนอยู่ตอนนี้ (สำหรับแสดงใน toggle pill)
  function countHiddenVirtuals() {
    var n = 0;
    products.forEach(function(p) {
      if (p && p.is_virtual && p.virtual_reason === 'shared_parts_assembled') n++;
    });
    return n;
  }

  // renderVirtualToggle(): แสดง/ซ่อน + update visual state ของ toggle pill
  function renderVirtualToggle() {
    if (!$virtualToggleRow || !$virtualToggle) return;
    var n = countHiddenVirtuals();
    if (n === 0) {
      // ไม่มี virtual SET ใน maker นี้ → ไม่ต้องแสดงปุ่ม
      $virtualToggleRow.style.display = 'none';
      return;
    }
    $virtualToggleRow.style.display = 'block';
    $virtualToggleCount.textContent = n;
    if (showVirtualSets) {
      $virtualToggle.classList.add('active');
      $virtualToggleIcon.innerHTML = '&#9745;'; // ☑
    } else {
      $virtualToggle.classList.remove('active');
      $virtualToggleIcon.innerHTML = '&#9744;'; // ☐
    }
  }

  // ── V.4.4: Build hierarchy lookup using forward lookup + JS-derived types ──
  function buildHierarchyLookup() {
    var lookup = { bysku: {}, setSkus: [], childrenOf: {}, grandchildrenOf: {} };
    products.forEach(function(p) { lookup.bysku[(p.sku || '').toUpperCase()] = p; });
    products.forEach(function(p) {
      var at = p._jsType || 'single';
      if (at === 'set') {
        lookup.setSkus.push((p.sku || '').toUpperCase());
      }
    });
    // V.4.3: Forward lookup จาก skuRelations แทน reverse lookup จาก parent_sku
    // DD-3 shared child: product อาจเป็นลูกของหลาย parent → forward lookup ถูกเสมอ
    Object.keys(skuRelations).forEach(function(parentSku) {
      var childSkus = skuRelations[parentSku] || [];
      childSkus.forEach(function(childSku) {
        var cp = lookup.bysku[childSku];
        if (!cp) return;
        // ถ้า parent เป็น SET (top-level) → childrenOf
        // ถ้า parent มี parent อีกที → grandchildrenOf
        if (!lookup.childrenOf[parentSku]) lookup.childrenOf[parentSku] = [];
        lookup.childrenOf[parentSku].push(cp);
        // Check if parent has a grandparent (= this is grandchild relation)
        Object.keys(skuRelations).forEach(function(gpSku) {
          if ((skuRelations[gpSku] || []).indexOf(parentSku) !== -1) {
            if (!lookup.grandchildrenOf[parentSku]) lookup.grandchildrenOf[parentSku] = [];
            lookup.grandchildrenOf[parentSku].push(cp);
          }
        });
      });
    });
    return lookup;
  }

  function loadProducts(makerId) {
    selectedMaker = makerId;
    // V.7.0: Don't nuke cart if persistence enabled — clear only if different maker
    if (!ORDER_INTENT_ENABLED) { cart = {}; }
    else { cart = {}; } // V.7.0: reset then restore from localStorage after products load
    updateCartUI();
    filterModel = ''; filterType = '';
    makerProfile = null; // V.7.0: reset
    // V.6.6: reload virtual toggle preference for this maker (per-maker localStorage key)
    loadShowVirtualFromStorage();
    selectedMakerData = makerId ? makers.find(function(m){ return String(m.id) === String(makerId); }) : null;
    if (!makerId) {
      $searchWrap.style.display = 'none';
      $modelRow.style.display = 'none';
      $typeChips.style.display = 'none';
      if ($virtualToggleRow) $virtualToggleRow.style.display = 'none';
      var $banner = document.getElementById('b2fMakerBanner');
      if ($banner) $banner.classList.remove('show');
      $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#127981;</div><div>เลือกโรงงานเพื่อดูสินค้า</div></div>';
      return;
    }
    $productArea.innerHTML = '<div class="b2f-cat-loading"><div class="b2f-cat-spinner"></div><div style="color:var(--b2f-text-muted);font-size:13px;">กำลังโหลดสินค้า...</div></div>';
    $searchWrap.style.display = 'block'; $search.value = '';
    if ($virtualToggleRow) $virtualToggleRow.style.display = 'none'; // V.6.5: ซ่อนระหว่างโหลด
    api('GET', 'maker-products/' + makerId + '?include_virtual=1').then(function(res) { // V.5.10: virtual SETs ที่ maker ผลิตได้ (leaves registered)
      if (res.success && res.data) {
        products = res.data.filter(function(p) { return p.status === 'active'; });
        hierarchyMeta = res.hierarchy_meta || {};
        skuRelations = res.sku_relations || {};
        motoCatalog = res.moto_catalog || [];
        _modelImageMap = null; // V.7.2: invalidate image map — rebuild lazy on next getModelImage call
        catalogMap = res.catalog_map || {}; // V.5.4: source of truth data (รวม leaves ที่ maker ไม่ได้ register)

        // V.4.4: JS-side type derivation from sku_relations (source of truth = same as Product Catalog computeProductTypes)
        // V.5.9: _jsType = hierarchy จริง (ใช้สำหรับ grouping/cart/DD-7)
        //        _jsDisplayType = override ?? _jsType (ใช้สำหรับ BADGE เท่านั้น — ตรงกับ Product Catalog V.42.14)
        //        Override ใช้สำหรับ display badge เท่านั้น — ไม่กระทบ grouping เพราะ DD-7 ต้อง expand SET จริงเสมอ
        var _c2p = {};
        Object.keys(skuRelations).forEach(function(pk) {
          (skuRelations[pk] || []).forEach(function(ck) {
            var cu = String(ck).toUpperCase();
            if (!_c2p[cu]) _c2p[cu] = [];
            if (_c2p[cu].indexOf(pk) === -1) _c2p[cu].push(pk);
          });
        });
        var _allowedRoles = ['set', 'child', 'grandchild', 'single'];
        products.forEach(function(p) {
          var su = (p.sku || '').toUpperCase();
          var myChildren = skuRelations[su] || [];
          var isParent = myChildren.length > 0;
          var myParents = _c2p[su] || [];
          var myParent = myParents[0] || null;
          var isLeaf = !isParent;

          if (myParent && isLeaf) p._jsType = 'grandchild';
          else if (myParent && isParent) p._jsType = 'child';
          else if (isParent) p._jsType = 'set';
          else p._jsType = 'single';

          p._jsParents = myParents;
          p._jsChildrenCount = myChildren.length;

          // V.5.9: display type = ui_role_override ถ้า admin ตั้งไว้ (mirror Product Catalog badge)
          var ovr = String(p.ui_role_override || 'auto').toLowerCase();
          if (_allowedRoles.indexOf(ovr) !== -1 && ovr !== p._jsType) {
            p._jsDisplayType = ovr;
            p._jsIsOverride = true;
          } else {
            p._jsDisplayType = p._jsType;
            p._jsIsOverride = false;
          }
        });

        // V.7.0: store maker_profile from enriched API
        makerProfile = res.maker_profile || null;

        renderModelFilter();
        renderVirtualToggle(); // V.6.5: แสดง toggle pill ถ้ามี virtual SETs
        renderTypeChips();
        renderMakerBanner(); // V.7.0: Screen 1 — Maker Banner
        // V.7.0: restore persisted cart from localStorage (after products loaded for validation)
        if (ORDER_INTENT_ENABLED) loadCartFromStorage();
        renderFilteredProducts();
      } else {
        products = []; hierarchyMeta = {}; skuRelations = {}; motoCatalog = [];
        $modelRow.style.display = 'none';
        $typeChips.style.display = 'none';
        if ($virtualToggleRow) $virtualToggleRow.style.display = 'none';
        $productArea.innerHTML = '<div class="b2f-cat-empty"><div class="b2f-cat-empty-icon">&#128230;</div><div>ยังไม่มีสินค้าในโรงงานนี้</div></div>';
      }
    }).catch(function() { toast('โหลดสินค้าไม่สำเร็จ', 'error'); });
  }

  // ── V.4.0 / V.5.3: Model Filter Row ──
