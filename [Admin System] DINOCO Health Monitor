if ( ! function_exists( 'dinoco_smoke_count_audit_writers' ) ) {
    /**
     * Migration coverage: how many distinct event_types written in last 7 days?
     */
    function dinoco_smoke_count_audit_writers() {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_audit_log';
        $exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $exists ) return array( 'count' => 0, 'event_types' => array() );
        $rows = $wpdb->get_col(
            "SELECT DISTINCT event_type FROM {$table}
             WHERE created_at >= NOW() - INTERVAL 7 DAY
             ORDER BY event_type ASC"
        );
        $rows = is_array( $rows ) ? $rows : array();
        return array( 'count' => count( $rows ), 'event_types' => $rows );
    }
}

