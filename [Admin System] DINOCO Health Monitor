add_action( 'init', function() {
    if ( ! function_exists( 'dinoco_register_health_check' ) ) return;

    // 1. Cron heartbeat — any registered cron stale or last-run-error
    dinoco_register_health_check( 'cron_heartbeat', function() {
        $rows = dinoco_get_cron_heartbeat();
        if ( empty( $rows ) ) {
            return array( 'status' => 'ok', 'detail' => 'no_crons_registered' );
        }
        $stale = array();
        $err   = array();
        foreach ( $rows as $r ) {
            if ( $r['health'] === 'warn' ) {
                if ( $r['detail'] === 'last_run_error' ) {
                    $err[] = $r['hook'];
                } else {
                    $stale[] = $r['hook'];
                }
            }
        }
        if ( ! empty( $err ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'crons_with_errors: ' . implode( ', ', $err ),
                'metric' => count( $err ),
            );
        }
        if ( ! empty( $stale ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'stale_crons: ' . implode( ', ', $stale ),
                'metric' => count( $stale ),
            );
        }
        return array(
            'status' => 'ok',
            'detail' => count( $rows ) . '_crons_healthy',
            'metric' => count( $rows ),
        );
    }, array( 'critical' => false, 'label' => 'Cron Heartbeat' ) );

    // 2. DB invariants — basic connectivity smoke test
    dinoco_register_health_check( 'db_invariants', function() {
        global $wpdb;
        $val = $wpdb->get_var( "SELECT 1" );
        if ( $val !== '1' && $val !== 1 ) {
            return array( 'status' => 'fail', 'detail' => 'db_select_1_failed' );
        }
        // Count dinoco_audit_log rows in last 24h (smoke test that audit infra is alive)
        $table = $wpdb->prefix . 'dinoco_audit_log';
        $tbl_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $tbl_exists ) {
            return array(
                'status' => 'warn',
                'detail' => 'audit_log_table_missing (Snippet 15 V.8.9 not synced?)',
            );
        }
        return array( 'status' => 'ok', 'detail' => 'db_responsive' );
    }, array( 'critical' => true, 'label' => 'Database Smoke Test' ) );

    // 3. Flag consistency — Module Registry orphans (snippet disabled but module registered)
    dinoco_register_health_check( 'flag_consistency', function() {
        $errors = isset( $GLOBALS['_dinoco_module_registry_errors'] ) && is_array( $GLOBALS['_dinoco_module_registry_errors'] )
            ? array_unique( $GLOBALS['_dinoco_module_registry_errors'] ) : array();
        if ( ! empty( $errors ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'module_registry_orphans: ' . count( $errors ),
                'metric' => count( $errors ),
            );
        }
        $modules = function_exists( 'dinoco_get_registered_modules' ) ? dinoco_get_registered_modules() : array();
        return array(
            'status' => 'ok',
            'detail' => count( $modules ) . '_modules_clean',
            'metric' => count( $modules ),
        );
    }, array( 'critical' => false, 'label' => 'Module Registry Health' ) );

    // 4. Audit log health — recent write activity (last 24h)
    dinoco_register_health_check( 'audit_log_health', function() {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_audit_log';
        $exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $exists ) {
            return array(
                'status' => 'warn',
                'detail' => 'audit_table_missing',
            );
        }
        $count_24h = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$table} WHERE created_at >= NOW() - INTERVAL 1 DAY"
        );
        $err_24h = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$table} WHERE created_at >= NOW() - INTERVAL 1 DAY AND success=0"
        );
        $total = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$table}" );
        if ( $count_24h > 0 && ( $err_24h / max( 1, $count_24h ) ) > 0.2 ) {
            return array(
                'status' => 'warn',
                'detail' => sprintf( 'high_error_rate_24h: %d/%d', $err_24h, $count_24h ),
                'metric' => $err_24h,
            );
        }
        return array(
            'status' => 'ok',
            'detail' => sprintf( '24h=%d total=%d errors=%d', $count_24h, $total, $err_24h ),
            'metric' => $count_24h,
        );
    }, array( 'critical' => false, 'label' => 'Audit Log Health' ) );

}, 30 ); // priority 30 = after Module Registry (20) + Audit Log (defaults)

