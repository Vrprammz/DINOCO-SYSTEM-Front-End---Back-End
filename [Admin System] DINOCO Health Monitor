add_action( 'rest_api_init', function() {

    // Public top-level health (no auth) — only overall + counts, no internal detail
    register_rest_route( 'dinoco/v1', '/health', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_health_rest',
        'permission_callback' => '__return_true',
        'args'                => array(
            'detail' => array( 'sanitize_callback' => 'absint' ),
        ),
    ) );

    // Manual run a single check (admin only + nonce)
    register_rest_route( 'dinoco/v1', '/health/run-check', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_health_rest_run_check',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
        'args'                => array(
            'key' => array( 'required' => true, 'sanitize_callback' => 'sanitize_text_field' ),
        ),
    ) );

    // Cron heartbeat (admin only)
    register_rest_route( 'dinoco/v1', '/cron/heartbeat', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_cron_rest_heartbeat',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
    ) );
} );

if ( ! function_exists( 'dinoco_health_rest' ) ) {
    function dinoco_health_rest( $request ) {
        $detail = (int) $request->get_param( 'detail' );
        $status = dinoco_get_health_status();

        if ( $detail !== 1 ) {
            // Public response — no internal details (security: don't leak system topology)
            return array(
                'overall'      => $status['overall'],
                'checks_count' => $status['checks_count'],
                'timestamp'    => $status['timestamp'],
            );
        }

        // Detail mode — admin only
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'forbidden', 'detail=1 requires manage_options', array( 'status' => 403 ) );
        }
        return $status;
    }
}

if ( ! function_exists( 'dinoco_health_rest_run_check' ) ) {
    function dinoco_health_rest_run_check( $request ) {
        $key = (string) $request->get_param( 'key' );
        if ( $key === '' ) {
            return new WP_Error( 'invalid_key', 'key required', array( 'status' => 400 ) );
        }
        $result = dinoco_run_health_check( $key );
        if ( function_exists( 'dinoco_audit_log' ) ) {
            dinoco_audit_log( array(
                'event_type'  => 'health_check_manual',
                'target_type' => 'health_check',
                'target_id'   => $key,
                'context'     => array( 'status' => $result['status'], 'detail' => $result['detail'] ?? '' ),
                'success'     => $result['status'] === 'fail' ? 0 : 1,
            ) );
        }
        return $result;
    }
}

if ( ! function_exists( 'dinoco_cron_rest_heartbeat' ) ) {
    function dinoco_cron_rest_heartbeat() {
        $rows = dinoco_get_cron_heartbeat();
        return array(
            'count' => count( $rows ),
            'rows'  => $rows,
        );
    }
}
