if ( ! function_exists( 'dinoco_health_rest' ) ) {
    function dinoco_health_rest( $request ) {
        $detail = (int) $request->get_param( 'detail' );
        $status = dinoco_get_health_status();

        if ( $detail !== 1 ) {
            // Public response — no internal details (security: don't leak system topology)
            return array(
                'overall'      => $status['overall'],
                'checks_count' => $status['checks_count'],
                'timestamp'    => $status['timestamp'],
            );
        }

        // Detail mode — admin only
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'forbidden', 'detail=1 requires manage_options', array( 'status' => 403 ) );
        }
        return $status;
    }
}

if ( ! function_exists( 'dinoco_health_rest_run_check' ) ) {
    function dinoco_health_rest_run_check( $request ) {
        $key = (string) $request->get_param( 'key' );
        if ( $key === '' ) {
            return new WP_Error( 'invalid_key', 'key required', array( 'status' => 400 ) );
        }

        // V.1.5 Round 49: Idempotency-Key wrap. Admin "Run Check" double-click on slow
        // probe (e.g. line_api_health hits LINE API ~2s, flash_v42_health touches Flash
        // routes ~1s) → 2× remote network call + 2× dinoco_audit_log row "health_check_
        // manual" → audit log noise + LINE/Flash quota burn. Body hash = single
        // {key, user_id} — same key from same admin = cached 200 instant; different key
        // mid-retry → 409 catches admin clicking different probe button. user_id scopes
        // per-admin (cross-admin key reuse not a leak — same probe result).
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco/v1::health/run-check';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'key'     => $key,
                'user_id' => (int) get_current_user_id(),
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) {
                $err_data    = $cached->get_error_data();
                $status_code = ( is_array( $err_data ) && isset( $err_data['status'] ) ) ? (int) $err_data['status'] : 409;
                return new WP_Error(
                    'idempotency_conflict',
                    'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                    array( 'status' => $status_code )
                );
            }
            if ( is_array( $cached ) ) {
                $resp = $cached;
                unset( $resp['_idem_code'] );
                return rest_ensure_response( $resp );
            }
        }

        $result = dinoco_run_health_check( $key );
        if ( function_exists( 'dinoco_audit_log' ) ) {
            dinoco_audit_log( array(
                'event_type'  => 'health_check_manual',
                'target_type' => 'health_check',
                'target_id'   => $key,
                'context'     => array( 'status' => $result['status'], 'detail' => $result['detail'] ?? '' ),
                'success'     => $result['status'] === 'fail' ? 0 : 1,
            ) );
        }

        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            $store_resp = is_array( $result ) ? $result : array( 'result' => $result );
            dinoco_idempotency_store(
                $idem_key,
                $idem_namespace,
                $idem_body,
                array_merge( $store_resp, array( '_idem_code' => 200 ) ),
                200
            );
        }

        return $result;
    }
}

