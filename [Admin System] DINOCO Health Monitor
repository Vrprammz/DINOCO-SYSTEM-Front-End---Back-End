            $dnc_claim_format_be = function( $ts ) {
                if ( ! $ts || $ts <= 0 ) return '(never)';
                $dt = wp_date( 'Y-m-d H:i:s', (int) $ts );
                // Buddhist Era — replace AD year with AD+543. Only first 4-digit
                // year token is bumped (the date prefix).
                if ( preg_match( '/^(\d{4})/', $dt, $m ) ) {
                    $be = (int) $m[1] + 543;
                    $dt = $be . substr( $dt, 4 );
                }
                return $dt;
            };
