if ( ! function_exists( 'dinoco_run_full_smoke_test' ) ) {
    /**
     * REST callback: POST /dinoco/v1/smoke-test
     * Executes all health checks + integration probes + migration coverage.
     * Returns comprehensive pass/fail report.
     */
    function dinoco_run_full_smoke_test( WP_REST_Request $request ) {
        // Rate limit
        if ( dinoco_smoke_test_rate_limit() ) {
            return new WP_Error(
                'rate_limit_exceeded',
                'Smoke test rate limit (5/min/user). Please wait.',
                array( 'status' => 429 )
            );
        }

        // V.1.5 Round 49: Idempotency-Key wrap (constant-marker pattern — 7th instance
        // after R30 stock/initialize + R32 manual-flash-test + R39 daily-summary + R40
        // dip-stock/start + R43 invoice/init + R47 stock/sync-missing). Handler takes
        // no params + writes ONE intentional audit_log row "smoke_test" + bumps
        // _dinoco_smoke_cumulative_pass counter on success + 16 health probes + 5
        // integration probes (full ~2-5s). Double-click race writes 2× audit row + 2×
        // counter bump → cached 200 returns first verdict instantly + skips 2-5s
        // re-probe (saves Flash/LINE/DB load). Body shape = constant-marker
        // {action: 'smoke-test', user_id} — user_id scopes per-admin (different admin
        // = different probe scope; cross-admin replay possible but harmless).
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $request ) : '';
        $idem_namespace = 'dinoco/v1::smoke-test';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'action'  => 'smoke-test',
                'user_id' => (int) get_current_user_id(),
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) {
                $err_data    = $cached->get_error_data();
                $status_code = ( is_array( $err_data ) && isset( $err_data['status'] ) ) ? (int) $err_data['status'] : 409;
                return new WP_Error(
                    'idempotency_conflict',
                    'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                    array( 'status' => $status_code )
                );
            }
            if ( is_array( $cached ) ) {
                $resp = $cached;
                unset( $resp['_idem_code'] );
                return rest_ensure_response( $resp );
            }
        }

        $started_at = current_time( 'mysql' );
        $started_ms = microtime( true );

        // 1. Health checks — full registered set
        $health = dinoco_get_health_status();

        // 2. Integration probes — deeper than read-only health checks
        $integration = array(
            'audit_log_writable'      => dinoco_smoke_test_audit_write(),
            'transaction_wrapper'     => dinoco_smoke_test_transaction(),
            'module_registry_count'   => dinoco_smoke_test_modules(),
            'config_layer_responsive' => dinoco_smoke_test_config(),
            'ai_classifier_ready'     => dinoco_smoke_test_ai_classifier(),
        );

        // 3. Migration coverage metrics (Phase 4 adoption signal)
        $audit_writers = dinoco_smoke_count_audit_writers();
        $modules_registered = function_exists( 'dinoco_get_registered_modules' )
            ? count( dinoco_get_registered_modules() )
            : 0;
        $config_registered = 0;
        if ( function_exists( 'dinoco_get_config_schema' ) ) {
            foreach ( dinoco_get_config_schema() as $sect => $keys ) {
                if ( is_array( $keys ) ) $config_registered += count( $keys );
            }
        }

        $migrations = array(
            'audit_event_types_7d'      => $audit_writers['count'],
            'audit_event_type_list'     => $audit_writers['event_types'],
            'cron_registry_adoption'    => dinoco_smoke_count_registered_crons(),
            'module_registry_adoption'  => $modules_registered,
            'config_registrations'      => $config_registered,
        );

        // Aggregate verdict
        $crit_fail = false;
        $any_warn  = false;
        $any_fail  = false;

        // Health check aggregation
        if ( ! empty( $health['checks'] ) && is_array( $health['checks'] ) ) {
            foreach ( $health['checks'] as $c ) {
                if ( ($c['status'] ?? '') === 'fail' ) {
                    $any_fail = true;
                    if ( ! empty( $c['critical'] ) ) $crit_fail = true;
                } elseif ( ($c['status'] ?? '') === 'warn' ) {
                    $any_warn = true;
                }
            }
        }
        // Integration probe aggregation
        foreach ( $integration as $r ) {
            $st = is_array( $r ) && isset( $r['status'] ) ? $r['status'] : 'fail';
            if ( $st === 'fail' ) $any_fail = true;
            elseif ( $st === 'warn' ) $any_warn = true;
        }

        $overall = $crit_fail ? 'fail' : ( $any_fail ? 'warn' : ( $any_warn ? 'warn' : 'ok' ) );

        $elapsed_ms = (int) round( ( microtime( true ) - $started_ms ) * 1000 );

        // Persist last-run summary for UI display
        update_option( '_dinoco_smoke_last_run_ts', time(), false );
        update_option( '_dinoco_smoke_last_run_overall', $overall, false );
        update_option( '_dinoco_smoke_last_run_elapsed_ms', $elapsed_ms, false );
        $cumulative_pass = (int) get_option( '_dinoco_smoke_cumulative_pass', 0 );
        if ( $overall === 'ok' ) {
            update_option( '_dinoco_smoke_cumulative_pass', $cumulative_pass + 1, false );
        }

        $resp = array(
            'started_at'       => $started_at,
            'ended_at'         => current_time( 'mysql' ),
            'elapsed_ms'       => $elapsed_ms,
            'overall'          => $overall,
            'checks'           => array(
                'health'      => $health,
                'integration' => $integration,
                'migrations'  => $migrations,
            ),
            'summary'          => array(
                'health_count'     => isset( $health['checks_count'] ) ? (int) $health['checks_count'] : 0,
                'integration_count'=> count( $integration ),
                'cumulative_pass'  => (int) get_option( '_dinoco_smoke_cumulative_pass', 0 ),
            ),
        );

        // V.1.5 Round 49: store cached replay payload for double-click protection.
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store(
                $idem_key,
                $idem_namespace,
                $idem_body,
                array_merge( $resp, array( '_idem_code' => 200 ) ),
                200
            );
        }

        return $resp;
    }
}
