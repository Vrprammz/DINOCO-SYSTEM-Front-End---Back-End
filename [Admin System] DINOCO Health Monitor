            function fetchJSON(url, opts){
                opts = opts || {};
                opts.headers = opts.headers || {};
                opts.headers['X-WP-Nonce'] = NONCE;
                opts.credentials = 'same-origin';
                return fetch(url, opts).then(function(r){ return r.json(); });
            }

            window._dnchRefresh = function(){
                spinOn();
                fetchJSON(REST + 'health?detail=1').then(function(data){
                    spinOff();
                    if (!data || !data.overall) return;
                    var ov = document.getElementById('dnch-overall');
                    ov.className = 'dnc-h-overall ' + data.overall;
                    ov.innerHTML = '<span class="dot"></span><span>Overall Status: <strong style="text-transform:uppercase">' + data.overall + '</strong></span><span style="margin-left:auto;font-weight:400;font-size:13px">' + data.checks_count + ' checks</span>';
                    last.textContent = 'last: ' + data.timestamp;
                    var grid = document.getElementById('dnch-checks');
                    if (grid && Array.isArray(data.checks)) {
                        grid.innerHTML = data.checks.map(function(c){
                            return '<div class="dnc-h-card" data-check="' + c.key + '">' +
                                '<div class="head"><span class="lbl">' + (c.label || c.key) + '</span><span class="badge ' + c.status + '">' + c.status + '</span></div>' +
                                '<div class="detail">' + (c.detail || '') + '</div>' +
