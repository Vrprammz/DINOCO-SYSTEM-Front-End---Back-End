        $missing_class  = array();
        $missing_method = array();
        foreach ( $required as $class => $methods ) {
            if ( ! class_exists( $class ) ) {
                $missing_class[] = $class;
                continue;
            }
            foreach ( $methods as $m ) {
                if ( ! method_exists( $class, $m ) ) $missing_method[] = $class . '::' . $m;
            }
        }
        if ( $missing_class || $missing_method ) {
            return array(
                'status' => 'fail',
                'detail' => 'missing classes: ' . implode( ', ', $missing_class )
                          . ( $missing_method ? ' | methods: ' . implode( ', ', $missing_method ) : '' ),
