if ( ! function_exists( 'dinoco_register_cron' ) ) {
    /**
     * Register a cron with auto heartbeat tracking.
     *
     * Wraps the callback so each run writes:
     *   _dinoco_cron_<hook>_last_run = unix timestamp
     *   _dinoco_cron_<hook>_last_status = 'ok' | 'error'
     *   _dinoco_cron_<hook>_last_duration_ms = int
     *   _dinoco_cron_<hook>_last_error = string (if any)
     *
     * Idempotent — multiple calls in same request are no-op for action add.
     * wp_schedule_event called only if hook not already scheduled.
     *
     * @param string   $hook
     * @param string   $schedule WP cron schedule slug (hourly|daily|twicedaily|custom)
     * @param callable $callback
     * @param array    $args { interval_seconds: int (override expected interval) }
     * @return true|WP_Error
     */
    function dinoco_register_cron( $hook, $schedule, $callback, $args = array() ) {
        if ( ! is_string( $hook ) || $hook === '' ) {
            return new WP_Error( 'dnc_cron_invalid_hook', 'hook required' );
        }
        if ( ! is_string( $schedule ) || $schedule === '' ) {
            return new WP_Error( 'dnc_cron_invalid_schedule', 'schedule required' );
        }
        if ( ! is_callable( $callback ) ) {
            return new WP_Error( 'dnc_cron_invalid_callback', 'callback not callable' );
        }

        // Track in registry
        if ( ! isset( $GLOBALS['_dinoco_cron_registry'] ) ) $GLOBALS['_dinoco_cron_registry'] = array();
        $intervals      = wp_get_schedules();
        $expected_secs  = isset( $args['interval_seconds'] ) ? (int) $args['interval_seconds']
                          : ( isset( $intervals[ $schedule ]['interval'] ) ? (int) $intervals[ $schedule ]['interval'] : 3600 );
        $GLOBALS['_dinoco_cron_registry'][ $hook ] = array(
            'hook'             => $hook,
            'schedule'         => $schedule,
            'expected_seconds' => $expected_secs,
            'registered_at'    => current_time( 'mysql' ),
        );

        // Wrap callback for heartbeat — only add once
        $wrapper_action_key = '_dinoco_cron_wrapper_added_' . md5( $hook );
        if ( empty( $GLOBALS[ $wrapper_action_key ] ) ) {
            $GLOBALS[ $wrapper_action_key ] = true;
            add_action( $hook, function() use ( $hook, $callback ) {
                $start  = microtime( true );
                $status = 'ok';
                $err    = '';
                try {
                    call_user_func( $callback );
                } catch ( \Throwable $e ) {
                    $status = 'error';
                    $err    = mb_substr( $e->getMessage(), 0, 500 );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( 'error', '[cron] ' . $hook . ' exception', array(
                            'hook' => $hook, 'message' => $e->getMessage(),
                        ) );
                    }
                }
                $elapsed_ms = (int) round( ( microtime( true ) - $start ) * 1000 );
                update_option( '_dinoco_cron_' . $hook . '_last_run', time(), false );
                update_option( '_dinoco_cron_' . $hook . '_last_status', $status, false );
                update_option( '_dinoco_cron_' . $hook . '_last_duration_ms', $elapsed_ms, false );
                update_option( '_dinoco_cron_' . $hook . '_last_error', $err, false );
                if ( function_exists( 'dinoco_audit_log' ) && $status === 'error' ) {
                    dinoco_audit_log( array(
                        'event_type'  => 'cron_error',
                        'actor_type'  => 'cron',
                        'actor_id'    => $hook,
                        'target_type' => 'cron',
                        'target_id'   => $hook,
                        'error_msg'   => $err,
                        'success'     => 0,
                        'context'     => array( 'duration_ms' => $elapsed_ms ),
                    ) );
                }
            } );
        }

        // Schedule if not yet
        if ( ! wp_next_scheduled( $hook ) ) {
            wp_schedule_event( time() + 60, $schedule, $hook );
        }

        return true;
    }
}

if ( ! function_exists( 'dinoco_get_cron_registry' ) ) {
    function dinoco_get_cron_registry() {
        return isset( $GLOBALS['_dinoco_cron_registry'] ) && is_array( $GLOBALS['_dinoco_cron_registry'] )
            ? $GLOBALS['_dinoco_cron_registry'] : array();
    }
}

if ( ! function_exists( 'dinoco_get_cron_heartbeat' ) ) {
    /**
     * Get full heartbeat snapshot for all registered crons.
     */
    function dinoco_get_cron_heartbeat() {
        $registry = dinoco_get_cron_registry();
        $now      = time();
        $rows     = array();
        foreach ( $registry as $hook => $def ) {
            $last_run    = (int) get_option( '_dinoco_cron_' . $hook . '_last_run', 0 );
            $last_status = (string) get_option( '_dinoco_cron_' . $hook . '_last_status', '' );
            $duration    = (int) get_option( '_dinoco_cron_' . $hook . '_last_duration_ms', 0 );
            $error       = (string) get_option( '_dinoco_cron_' . $hook . '_last_error', '' );
            $next_sched  = (int) ( wp_next_scheduled( $hook ) ?: 0 );
            $secs_since  = $last_run > 0 ? ( $now - $last_run ) : null;
            $expected    = (int) $def['expected_seconds'];

            // Stale: never run, OR last_run > 2× expected interval
            if ( $last_run === 0 ) {
                $health = 'warn';
                $detail = 'never_ran';
            } elseif ( $expected > 0 && $secs_since > $expected * 2 ) {
                $health = 'warn';
                $detail = 'stale_' . $secs_since . 's';
            } elseif ( $last_status === 'error' ) {
                $health = 'warn';
                $detail = 'last_run_error';
            } else {
                $health = 'ok';
                $detail = '';
            }

            $rows[] = array(
                'hook'                => $hook,
                'schedule'            => $def['schedule'],
                'expected_seconds'    => $expected,
                'last_run'            => $last_run,
                'last_run_human'      => $last_run > 0 ? wp_date( 'Y-m-d H:i:s', $last_run ) : '(never)',
                'seconds_since'       => $secs_since,
                'last_status'         => $last_status,
                'last_duration_ms'    => $duration,
                'last_error'          => $error,
                'next_scheduled'      => $next_sched,
                'next_scheduled_human'=> $next_sched > 0 ? wp_date( 'Y-m-d H:i:s', $next_sched ) : '(none)',
                'health'              => $health,
                'detail'              => $detail,
            );
        }
        return $rows;
    }
}

/* ============================================================
 * 3. BUILT-IN HEALTH CHECKS
 * ============================================================ */

add_action( 'init', function() {
    if ( ! function_exists( 'dinoco_register_health_check' ) ) return;

    // 1. Cron heartbeat — any registered cron stale or last-run-error
    dinoco_register_health_check( 'cron_heartbeat', function() {
        $rows = dinoco_get_cron_heartbeat();
        if ( empty( $rows ) ) {
            return array( 'status' => 'ok', 'detail' => 'no_crons_registered' );
        }
        $stale = array();
        $err   = array();
        foreach ( $rows as $r ) {
            if ( $r['health'] === 'warn' ) {
                if ( $r['detail'] === 'last_run_error' ) {
                    $err[] = $r['hook'];
                } else {
                    $stale[] = $r['hook'];
                }
            }
        }
        if ( ! empty( $err ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'crons_with_errors: ' . implode( ', ', $err ),
                'metric' => count( $err ),
            );
        }
        if ( ! empty( $stale ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'stale_crons: ' . implode( ', ', $stale ),
                'metric' => count( $stale ),
            );
        }
        return array(
            'status' => 'ok',
            'detail' => count( $rows ) . '_crons_healthy',
            'metric' => count( $rows ),
        );
    }, array( 'critical' => false, 'label' => 'Cron Heartbeat' ) );

    // 2. DB invariants — basic connectivity smoke test
    dinoco_register_health_check( 'db_invariants', function() {
        global $wpdb;
        $val = $wpdb->get_var( "SELECT 1" );
        if ( $val !== '1' && $val !== 1 ) {
            return array( 'status' => 'fail', 'detail' => 'db_select_1_failed' );
        }
        // Count dinoco_audit_log rows in last 24h (smoke test that audit infra is alive)
        $table = $wpdb->prefix . 'dinoco_audit_log';
        $tbl_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $tbl_exists ) {
            return array(
                'status' => 'warn',
                'detail' => 'audit_log_table_missing (Snippet 15 V.8.9 not synced?)',
            );
        }
        return array( 'status' => 'ok', 'detail' => 'db_responsive' );
    }, array( 'critical' => true, 'label' => 'Database Smoke Test' ) );

    // 3. Flag consistency — Module Registry orphans (snippet disabled but module registered)
    dinoco_register_health_check( 'flag_consistency', function() {
        $errors = isset( $GLOBALS['_dinoco_module_registry_errors'] ) && is_array( $GLOBALS['_dinoco_module_registry_errors'] )
            ? array_unique( $GLOBALS['_dinoco_module_registry_errors'] ) : array();
        if ( ! empty( $errors ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'module_registry_orphans: ' . count( $errors ),
                'metric' => count( $errors ),
            );
        }
        $modules = function_exists( 'dinoco_get_registered_modules' ) ? dinoco_get_registered_modules() : array();
        return array(
            'status' => 'ok',
            'detail' => count( $modules ) . '_modules_clean',
            'metric' => count( $modules ),
        );
    }, array( 'critical' => false, 'label' => 'Module Registry Health' ) );

    // 4. Audit log health — recent write activity (last 24h)
    dinoco_register_health_check( 'audit_log_health', function() {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_audit_log';
        $exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $exists ) {
            return array(
                'status' => 'warn',
                'detail' => 'audit_table_missing',
            );
        }
        $count_24h = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$table} WHERE created_at >= NOW() - INTERVAL 1 DAY"
        );
        $err_24h = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$table} WHERE created_at >= NOW() - INTERVAL 1 DAY AND success=0"
        );
        $total = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$table}" );
        if ( $count_24h > 0 && ( $err_24h / max( 1, $count_24h ) ) > 0.2 ) {
            return array(
                'status' => 'warn',
                'detail' => sprintf( 'high_error_rate_24h: %d/%d', $err_24h, $count_24h ),
                'metric' => $err_24h,
            );
        }
        return array(
            'status' => 'ok',
            'detail' => sprintf( '24h=%d total=%d errors=%d', $count_24h, $total, $err_24h ),
            'metric' => $count_24h,
        );
    }, array( 'critical' => false, 'label' => 'Audit Log Health' ) );

    // ────────────────────────────────────────────────────────────────
    // V.1.2 SELF-TEST SUITE — 12 additional checks (foundation + integration)
    // ────────────────────────────────────────────────────────────────

    // 5. Snippet dependencies — required helper functions are loaded
    dinoco_register_health_check( 'snippet_dependencies', function() {
        $required = array(
            'b2b_recalculate_debt'        => 'Snippet 1 (Core Utilities)',
            'b2b_get_product_data'        => 'Snippet 1',
            'b2b_get_product_data_batch'  => 'Snippet 1',
            'dinoco_get_leaf_skus'        => 'Snippet 15 (Inventory)',
            'dinoco_compute_hierarchy_stock' => 'Snippet 15',
            'b2f_get_maker_by_group'      => 'B2F Snippet 0',
            'b2f_currency_symbol'         => 'B2F Snippet 1',
        );
        $missing = array();
        foreach ( $required as $fn => $owner ) {
            if ( ! function_exists( $fn ) ) $missing[] = $fn . ' (' . $owner . ')';
        }
