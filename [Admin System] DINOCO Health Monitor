 * ============================================================
 * Admin runs once via Health Dashboard "Run Full System Test" button
 * or POST /dinoco/v1/smoke-test. Aggregates:
 *   - All registered health checks
 *   - 5 integration probes (deeper than health checks — actively
 *     exercise wrapper/audit/registry/config code paths)
 *   - 5 migration coverage metrics (Phase 4 progress signal)
 *
 * Side effects: ONE audit_log row per run (proof-of-write probe).
 * Other probes are read-only.
 *
 * Rate limit: 5 runs / minute / user (transient counter).
 */

if ( ! function_exists( 'dinoco_smoke_test_audit_write' ) ) {
    /**
     * Probe: write a small audit_log row to verify the write path is healthy.
     * This is the ONE intentional side-effect of smoke test (proof-of-write).
     */
    function dinoco_smoke_test_audit_write() {
        if ( ! function_exists( 'dinoco_audit_log' ) ) {
            return array( 'status' => 'fail', 'detail' => 'audit_helper_missing' );
        }
        $log_id = dinoco_audit_log( array(
            'event_type'  => 'smoke_test',
            'actor_type'  => 'system',
            'target_type' => 'health_monitor',
            'target_id'   => 'self_test',
            'context'     => array(
                'test_run_at' => current_time( 'mysql' ),
                'user_id'     => get_current_user_id(),
            ),
            'success'     => 1,
        ) );
        if ( ! $log_id ) {
            return array(
                'status' => 'fail',
                'detail' => 'insert_returned_false (table missing or DB error)',
            );
        }
        return array(
            'status' => 'ok',
            'detail' => 'audit_row_inserted (log_id=' . (int) $log_id . ')',
            'metric' => (int) $log_id,
        );
    }
}

if ( ! function_exists( 'dinoco_smoke_test_transaction' ) ) {
    /**
     * Probe: execute a no-op transaction wrapper to verify the 5-phase
     * pattern works end-to-end. No DB mutation.
     */
    function dinoco_smoke_test_transaction() {
        if ( ! function_exists( 'dinoco_transaction' ) ) {
            return array( 'status' => 'warn', 'detail' => 'wrapper_not_loaded' );
        }
        $started = microtime( true );
        try {
            $result = dinoco_transaction( 'health_smoke_test', array(
                'validate' => function( $ctx ) {
                    return array( 'validated' => true );
                },
                'mutate'   => function( $ctx ) {
                    // No-op — read only. Returns success array.
                    return array( 'ok' => true, 'noop' => true );
                },
            ), array(
                'lock_key'         => 'dinoco_smoke_test_' . get_current_user_id(),
                'lock_timeout'     => 2,
                'audit_event_type' => 'smoke_test_txn',
                'actor_type'       => 'admin',
                'target_type'      => 'health_monitor',
                'target_id'        => 'smoke_txn',
            ) );
        } catch ( \Throwable $e ) {
            return array(
                'status' => 'fail',
                'detail' => 'exception: ' . $e->getMessage(),
            );
        }
        if ( is_wp_error( $result ) ) {
            return array(
                'status' => 'fail',
                'detail' => 'wp_error: ' . $result->get_error_code() . ' — ' . $result->get_error_message(),
            );
        }
        $elapsed_ms = (int) round( ( microtime( true ) - $started ) * 1000 );
        return array(
            'status' => 'ok',
            'detail' => 'wrapper_executed_clean (' . $elapsed_ms . 'ms)',
            'metric' => $elapsed_ms,
        );
    }
}

