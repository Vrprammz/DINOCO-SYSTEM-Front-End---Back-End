    // 11. Audit log dual-write — recent debt/stock/slip mutations have audit rows
    dinoco_register_health_check( 'audit_log_dual_write', function() {
        global $wpdb;
        if ( ! function_exists( 'dinoco_audit_log' ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'audit_helper_not_loaded',
            );
        }
        $table = $wpdb->prefix . 'dinoco_audit_log';
        $exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $exists ) {
            return array( 'status' => 'warn', 'detail' => 'audit_table_missing' );
        }
        // Look for at least one recent dual-write event from each major domain (24h window).
        $domains = array( 'debt_add', 'debt_subtract', 'stock_add', 'stock_subtract',
                          'payable_add', 'payable_subtract', 'fsm_transition', 'slip_apply' );
        $placeholders = implode( ',', array_fill( 0, count( $domains ), '%s' ) );
        $sql = "SELECT event_type, COUNT(*) AS n FROM {$table}
                WHERE created_at >= NOW() - INTERVAL 7 DAY
                  AND event_type IN ({$placeholders})
                GROUP BY event_type";
        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $domains ), ARRAY_A );
        $found = array();
        if ( is_array( $rows ) ) {
            foreach ( $rows as $r ) $found[ $r['event_type'] ] = (int) $r['n'];
        }
        if ( empty( $found ) ) {
            return array(
                'status' => 'warn',
                'detail' => 'no_dual_write_events_7d — atomic helpers may not be wired',
                'metric' => 0,
            );
        }
        return array(
            'status' => 'ok',
            'detail' => 'domains_active: ' . implode( ',', array_keys( $found ) ),
            'metric' => array_sum( $found ),
        );
    }, array( 'critical' => false, 'label' => 'Audit Dual-Write' ) );

