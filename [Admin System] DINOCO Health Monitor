        <script>
        (function(){
            var REST = <?php echo wp_json_encode( $rest ); ?>;
            var NONCE = <?php echo wp_json_encode( $nonce ); ?>;
            var spin = document.getElementById('dnch-spin');
            var last = document.getElementById('dnch-last');
            var refreshTimer = null;

            function spinOn(){ spin && spin.classList.add('show'); }
            function spinOff(){ spin && spin.classList.remove('show'); }

            function fetchJSON(url, opts){
                opts = opts || {};
                opts.headers = opts.headers || {};
                opts.headers['X-WP-Nonce'] = NONCE;
                opts.credentials = 'same-origin';
                return fetch(url, opts).then(function(r){ return r.json(); });
            }

            window._dnchRefresh = function(){
                spinOn();
                fetchJSON(REST + 'health?detail=1').then(function(data){
                    spinOff();
                    if (!data || !data.overall) return;
                    var ov = document.getElementById('dnch-overall');
                    ov.className = 'dnc-h-overall ' + data.overall;
                    ov.innerHTML = '<span class="dot"></span><span>Overall Status: <strong style="text-transform:uppercase">' + data.overall + '</strong></span><span style="margin-left:auto;font-weight:400;font-size:13px">' + data.checks_count + ' checks</span>';
                    last.textContent = 'last: ' + data.timestamp;
                    var grid = document.getElementById('dnch-checks');
                    if (grid && Array.isArray(data.checks)) {
                        grid.innerHTML = data.checks.map(function(c){
                            return '<div class="dnc-h-card" data-check="' + c.key + '">' +
                                '<div class="head"><span class="lbl">' + (c.label || c.key) + '</span><span class="badge ' + c.status + '">' + c.status + '</span></div>' +
                                '<div class="detail">' + (c.detail || '') + '</div>' +
                                '<div class="meta">' + c.key + ' · ' + (c.elapsed_ms || 0) + 'ms' + (c.critical ? ' · <span style="color:#b45309">critical</span>' : '') + '</div>' +
                                '<button type="button" onclick="window._dnchRunCheck && window._dnchRunCheck(\'' + c.key + '\');">▶ Run check now</button>' +
                                '</div>';
                        }).join('');
                    }
                }).catch(function(e){ spinOff(); console.warn('[health] refresh fail', e); });
            };

            window._dnchRunCheck = function(key){
                spinOn();
                fetchJSON(REST + 'health/run-check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ key: key })
                }).then(function(){
                    window._dnchRefresh();
                }).catch(function(e){ spinOff(); console.warn('[health] run-check fail', e); });
            };

            // Auto-refresh every 30s
            refreshTimer = setInterval(window._dnchRefresh, 30000);

            // Pause when tab hidden (PERF-H3 pattern from Phase 1 audit)
            document.addEventListener('visibilitychange', function(){
                if (document.visibilityState === 'hidden') {
                    if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
                } else if (!refreshTimer) {
                    refreshTimer = setInterval(window._dnchRefresh, 30000);
                }
            });
        })();
        </script>
        <?php
        return ob_get_clean();
