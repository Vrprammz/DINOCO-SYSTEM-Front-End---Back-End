if ( ! function_exists( 'dinoco_register_health_check' ) ) {
    /**
     * Register a health check.
     *
     * @param string   $key Unique slug (^[a-z0-9_]+$).
     * @param callable $callback Returns ['status'=>'ok|warn|fail', 'detail'=>'...', 'metric'=>scalar?]
     * @param array    $args { critical: bool default false, label: string }
     * @return true|WP_Error
     */
    function dinoco_register_health_check( $key, $callback, $args = array() ) {
        if ( ! is_string( $key ) || ! preg_match( '/^[a-z0-9_]+$/', $key ) ) {
            return new WP_Error( 'dnc_health_invalid_key', 'invalid key (a-z 0-9 _)' );
        }
        if ( ! is_callable( $callback ) ) {
            return new WP_Error( 'dnc_health_invalid_callback', 'callback not callable' );
        }
        $defaults = array(
            'critical' => false,
            'label'    => $key,
        );
        $args = array_merge( $defaults, is_array( $args ) ? $args : array() );

        if ( ! isset( $GLOBALS['_dinoco_health_checks'] ) ) $GLOBALS['_dinoco_health_checks'] = array();
        $GLOBALS['_dinoco_health_checks'][ $key ] = array(
            'key'       => $key,
            'callback'  => $callback,
            'critical'  => (bool) $args['critical'],
            'label'     => (string) $args['label'],
        );
        return true;
    }
}

if ( ! function_exists( 'dinoco_get_health_checks' ) ) {
    function dinoco_get_health_checks() {
        return isset( $GLOBALS['_dinoco_health_checks'] ) && is_array( $GLOBALS['_dinoco_health_checks'] )
            ? $GLOBALS['_dinoco_health_checks'] : array();
    }
}

if ( ! function_exists( 'dinoco_run_health_check' ) ) {
    /**
     * Run a single check by key with try/catch protection.
     */
    function dinoco_run_health_check( $key ) {
        $checks = dinoco_get_health_checks();
        if ( ! isset( $checks[ $key ] ) ) {
            return array( 'status' => 'fail', 'detail' => 'check_not_registered' );
        }
        $start = microtime( true );
        try {
            $result = call_user_func( $checks[ $key ]['callback'] );
            if ( ! is_array( $result ) ) {
                $result = array( 'status' => 'fail', 'detail' => 'callback_returned_non_array' );
            }
            if ( ! isset( $result['status'] ) ) $result['status'] = 'fail';
            if ( ! in_array( $result['status'], array( 'ok', 'warn', 'fail' ), true ) ) {
                $result['status'] = 'fail';
            }
        } catch ( \Throwable $e ) {
            $result = array( 'status' => 'fail', 'detail' => 'exception: ' . $e->getMessage() );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'error', '[health] check exception', array(
                    'check' => $key, 'message' => $e->getMessage(),
                ) );
            }
        }
        $result['key']         = $key;
        $result['label']       = $checks[ $key ]['label'];
        $result['critical']    = $checks[ $key ]['critical'];
        $result['elapsed_ms']  = (int) round( ( microtime( true ) - $start ) * 1000 );
        $result['checked_at']  = current_time( 'mysql' );
        return $result;
    }
}

if ( ! function_exists( 'dinoco_get_health_status' ) ) {
    /**
     * Run all registered checks and aggregate to overall status.
     *
     * Aggregation rules:
     *   - any critical=true check status fail → overall fail
     *   - any check fail → overall warn (non-critical)
     *   - any check warn → overall warn
     *   - all ok → overall ok
     */
    function dinoco_get_health_status() {
        $checks  = dinoco_get_health_checks();
        $results = array();
        $overall = 'ok';
        foreach ( $checks as $key => $def ) {
            $r = dinoco_run_health_check( $key );
            $results[] = $r;
            if ( $r['status'] === 'fail' ) {
                $overall = ( $def['critical'] || $overall === 'fail' ) ? 'fail' : 'warn';
            } elseif ( $r['status'] === 'warn' && $overall === 'ok' ) {
                $overall = 'warn';
            }
        }
        return array(
            'overall'     => $overall,
            'checks'      => $results,
            'checks_count'=> count( $results ),
            'timestamp'   => current_time( 'mysql' ),
        );
    }
}

