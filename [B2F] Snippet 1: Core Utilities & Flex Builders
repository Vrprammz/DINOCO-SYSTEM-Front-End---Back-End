if (!function_exists('b2f_build_flex_receipt')) {
    function b2f_build_flex_receipt($rcv_id) {
        $rcv_id = (int) $rcv_id;
        if (!$rcv_id) return null;

        $po_id = (int) get_field('rcv_po_id', $rcv_id);
        $po    = b2f_get_po_data($po_id);
        if (!$po) return null;

        $rcv_number = get_field('rcv_number', $rcv_id) ?: 'RCV-' . $rcv_id;
        $rcv_date   = get_field('rcv_date', $rcv_id);
        $rcv_items  = get_field('rcv_items', $rcv_id) ?: array();
        $inspected  = get_field('rcv_inspected_by', $rcv_id) ?: '-';
        $admin_note = get_field('rcv_admin_note', $rcv_id);

        $items_contents = array();
        $total_received = 0;
        $total_rejected = 0;

        foreach ($rcv_items as $idx => $item) {
            $sku      = isset($item['rcvi_sku']) ? $item['rcvi_sku'] : '';
            $qty_rcv  = isset($item['rcvi_qty_received']) ? (int) $item['rcvi_qty_received'] : 0;
            $qty_rej  = isset($item['rcvi_qty_rejected']) ? (int) $item['rcvi_qty_rejected'] : 0;
            $qc       = isset($item['rcvi_qc_status']) ? $item['rcvi_qc_status'] : 'passed';
            $total_received += $qty_rcv;
            $total_rejected += $qty_rej;

            $qc_color = $qc === 'passed' ? B2F_COLOR_GREEN : ($qc === 'failed' ? B2F_COLOR_RED : B2F_COLOR_YELLOW);

            $items_contents[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'margin'  => 'sm',
                'contents' => array(
                    array(
                        'type'  => 'text',
                        'text'  => ($idx + 1) . '. ' . mb_substr($sku, 0, 20),
                        'size'  => 'xs',
                        'color' => '#333333',
                        'flex'  => 5,
                    ),
                    array(
                        'type'  => 'text',
                        'text'  => 'รับ ' . $qty_rcv . ($qty_rej > 0 ? ' / reject ' . $qty_rej : ''),
                        'size'  => 'xs',
                        'color' => $qc_color,
                        'flex'  => 5,
                        'align' => 'end',
                    ),
                ),
            );
        }

        $body_contents = array_merge(
            array(
                b2f_flex_kv_row('ใบรับของ', $rcv_number),
                b2f_flex_kv_row('เลขที่ PO', $po['po_number']),
                b2f_flex_kv_row('วันที่รับ', b2f_format_date_thai($rcv_date)),
                b2f_flex_separator(),
                array(
                    'type'   => 'text',
                    'text'   => 'รายการที่รับ',
                    'size'   => 'sm',
                    'weight' => 'bold',
                    'color'  => B2F_COLOR_NAVY,
                    'margin' => 'md',
                ),
            ),
            $items_contents,
            array(
                b2f_flex_separator(),
                b2f_flex_kv_row('รับทั้งหมด', $total_received . ' ชิ้น', B2F_COLOR_GREEN),
            )
        );

        if ($total_rejected > 0) {
            $body_contents[] = b2f_flex_kv_row('Reject', $total_rejected . ' ชิ้น', B2F_COLOR_RED);
        }

        $body_contents[] = b2f_flex_kv_row('ผู้ตรวจรับ', $inspected);

        if (!empty($admin_note)) {
            $body_contents[] = b2f_flex_kv_row('หมายเหตุ', mb_substr($admin_note, 0, 50));
        }

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header('ใบรับสินค้า', $rcv_number, B2F_COLOR_GREEN),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '16px',
                'spacing'    => 'sm',
                'contents'   => $body_contents,
            ),
        );

        return array(
            'type'     => 'flex',
            'altText'  => 'ใบรับสินค้า ' . $rcv_number . ' (' . $po['po_number'] . ')',
            'contents' => $bubble,
        );
    }
}

