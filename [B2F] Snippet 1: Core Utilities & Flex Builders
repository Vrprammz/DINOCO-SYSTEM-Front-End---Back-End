// ─────────────────────────────────────────────────────────────
// 100.6 — Flex intent summary (PII-guarded)
// Returns vertical box component summarizing 3 mode buckets for a PO.
// Reads _b2f_order_intent_summary postmeta first; if empty, computes
// on-the-fly from po_items.
// NEVER includes poi_intent_notes (admin-only, not for LINE groups).
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_flex_intent_summary')) {
    function b2f_flex_intent_summary($po_id) {
        $po_id = (int) $po_id;
        if (!$po_id) return null;

        // Prefer cached postmeta
        $summary = get_post_meta($po_id, '_b2f_order_intent_summary', true);
        if (is_string($summary) && $summary !== '') {
            $decoded = json_decode($summary, true);
            if (is_array($decoded)) $summary = $decoded;
        }

        // Fallback: compute from po_items
        if (!is_array($summary) || empty($summary)) {
            $items = get_field('po_items', $po_id);
            if (!is_array($items)) $items = array();
            $counts = array('full_set_count' => 0, 'sub_unit_count' => 0, 'single_leaf_count' => 0, 'total_items' => 0);
            foreach ($items as $it) {
                if (!is_array($it)) continue;
                $mode = isset($it['poi_order_mode']) ? (string) $it['poi_order_mode'] : '';
                $qty  = (int) ($it['poi_qty_ordered'] ?? 0);
                $counts['total_items'] += $qty;
                if ($mode === 'full_set')         $counts['full_set_count']    += $qty;
                elseif ($mode === 'sub_unit')     $counts['sub_unit_count']    += $qty;
                elseif ($mode === 'single_leaf')  $counts['single_leaf_count'] += $qty;
            }
            $summary = $counts;
        }

        // If no breakdown at all → return null (caller shows nothing)
        $total = (int) ($summary['full_set_count'] ?? 0)
               + (int) ($summary['sub_unit_count'] ?? 0)
               + (int) ($summary['single_leaf_count'] ?? 0);
        if ($total <= 0) return null;

        $currency = (string) (get_field('po_currency', $po_id) ?: 'THB');

        $rows = array();
        if (!empty($summary['full_set_count'])) {
            $rows[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'contents' => array(
                    array('type'=>'text','text'=>'🟣 ' . b2f_order_mode_label('full_set', $currency),
                          'size'=>'sm','color'=>'#7c3aed','flex'=>5,'weight'=>'bold'),
                    array('type'=>'text','text'=>number_format((int) $summary['full_set_count']),
                          'size'=>'sm','color'=>'#333','flex'=>2,'align'=>'end'),
                ),
            );
        }
        if (!empty($summary['sub_unit_count'])) {
            $rows[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'contents' => array(
                    array('type'=>'text','text'=>'🟠 ' . b2f_order_mode_label('sub_unit', $currency),
                          'size'=>'sm','color'=>'#f59e0b','flex'=>5,'weight'=>'bold'),
                    array('type'=>'text','text'=>number_format((int) $summary['sub_unit_count']),
                          'size'=>'sm','color'=>'#333','flex'=>2,'align'=>'end'),
                ),
            );
        }
        if (!empty($summary['single_leaf_count'])) {
            $rows[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'contents' => array(
                    array('type'=>'text','text'=>'⚪ ' . b2f_order_mode_label('single_leaf', $currency),
                          'size'=>'sm','color'=>'#6b7280','flex'=>5,'weight'=>'bold'),
                    array('type'=>'text','text'=>number_format((int) $summary['single_leaf_count']),
                          'size'=>'sm','color'=>'#333','flex'=>2,'align'=>'end'),
                ),
            );
        }

        if (empty($rows)) return null;

        // NEVER include intent_notes (defensive — postmeta schema already excludes it)
        return array(
            'type'    => 'box',
            'layout'  => 'vertical',
            'spacing' => 'xs',
            'margin'  => 'md',
            'contents' => $rows,
        );
    }
}


// ─────────────────────────────────────────────────────────────
// 100.7 — MySQL version capability probe (non-blocking)
// CHECK constraints silently ignored on MySQL < 8.0.16 / MariaDB < 10.2.1.
// PHP validator is primary guard — this helper only reports status.
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_audit_check_mysql_version')) {
    function b2f_audit_check_mysql_version() {
        global $wpdb;
        $version = (string) $wpdb->get_var("SELECT VERSION()");
        $lower   = strtolower($version);

        // MariaDB reports "10.x.x-MariaDB" — CHECK constraint enforced since 10.2.1
        if (strpos($lower, 'mariadb') !== false) {
            preg_match('/^(\d+\.\d+\.\d+)/', $version, $m);
            $v = isset($m[1]) ? $m[1] : '10.0.0';
            $supports_check = version_compare($v, '10.2.1', '>=');
        } else {
            // MySQL — CHECK constraint enforced since 8.0.16
            preg_match('/^(\d+\.\d+\.\d+)/', $version, $m);
            $v = isset($m[1]) ? $m[1] : '5.7.0';
            $supports_check = version_compare($v, '8.0.16', '>=');
        }

        if (!$supports_check && function_exists('b2f_log')) {
            b2f_log(sprintf(
                '[B2F V.7.0] MySQL/MariaDB %s does not enforce CHECK constraints. PHP validator is primary guard. (err=%s)',
                $version,
                B2F_ERR_MYSQL_VERSION_TOO_LOW
            ));
        }

        return array(
            'version'                => $version,
            'check_constraints_active' => (bool) $supports_check,
            'php_validator_primary'  => true,
        );
    }
}


// ─────────────────────────────────────────────────────────────
// 100.8 — Infer production_mode from sku_relations (Snippet 0.5 helper)
// Same logic as Phase 4 migration — called by dual-write UPSERT to set
// default production_mode when junction row first created.
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_infer_production_mode_from_relations')) {
    function b2f_infer_production_mode_from_relations($sku, $maker_id) {
        $sku      = strtoupper(trim((string) $sku));
        $maker_id = (int) $maker_id;
        if ($sku === '') return 'single';

        $relations = get_option('dinoco_sku_relations', array());
        if (!is_array($relations)) $relations = array();

        // has_children: this SKU is a key in relations (points to children)
        $has_children = isset($relations[$sku]) && is_array($relations[$sku]) && !empty($relations[$sku]);

        // has_parent: this SKU appears in any children[] array
        $has_parent = false;
        foreach ($relations as $parent => $children) {
            if (!is_array($children)) continue;
            foreach ($children as $c) {
                if (strtoupper((string) $c) === $sku) { $has_parent = true; break 2; }
            }
        }

        // missing_leaves: computed only if has_children — count leaves NOT registered in junction
        $missing_leaves_count = 0;
        if ($has_children && function_exists('dinoco_get_leaf_skus')) {
            $leaves = dinoco_get_leaf_skus($sku);
            if (is_array($leaves) && !empty($leaves)) {
                global $wpdb;
                $table = $wpdb->prefix . 'dinoco_product_makers';
                // Only probe if junction table exists
                $tbl_exists = (int) $wpdb->get_var($wpdb->prepare(
                    "SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES
                     WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s",
                    DB_NAME, $table
                ));
                if ($tbl_exists) {
                    $leaves_u = array_map('strtoupper', $leaves);
                    $placeholders = implode(',', array_fill(0, count($leaves_u), '%s'));
                    $params = array_merge(array($maker_id), $leaves_u);
                    $sql = "SELECT COUNT(*) FROM {$table}
                            WHERE maker_id = %d AND deleted_at IS NULL
                            AND BINARY UPPER(product_sku) IN ({$placeholders})";
                    $registered = (int) $wpdb->get_var($wpdb->prepare($sql, $params));
                    $missing_leaves_count = max(0, count($leaves_u) - $registered);
                }
            }
        }

        // Classification (same branching as Phase 4 migration)
        if ($has_children && $missing_leaves_count > 0) return 'cross_factory_assembly';
        if ($has_children && $has_parent)               return 'sub_unit';
        if ($has_children)                              return 'set_assembled';
        return 'single';
    }
}


// ─────────────────────────────────────────────────────────────
// V.7.0 HIGH-4 — Central cache invalidation listener
// Single source of truth — all mutations fire do_action('b2f_junction_updated',$maker_id).
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_on_junction_updated_invalidate')) {
    function b2f_on_junction_updated_invalidate($maker_id) {
        $maker_id = (int) $maker_id;
        if ($maker_id <= 0) return;
        delete_transient("b2f_maker_products_v11_{$maker_id}");
        delete_transient("b2f_maker_products_source_{$maker_id}");
        // Legacy keys (pre-V.7.0) — invalidate defensively
        delete_transient("b2f_maker_products_{$maker_id}");
    }
    add_action('b2f_junction_updated', 'b2f_on_junction_updated_invalidate', 10, 1);
}


// ═════════════════════════════════════════════════════════════════════
// V.7.1 — HIERARCHY COVERAGE AUTO-SYNC HELPERS
// ═════════════════════════════════════════════════════════════════════
//
// Philosophy — "Coverage Rule":
//   SKU X registered for Maker M ⇔
//     explicit junction row OR (X has children AND ALL children covered for M).
//   Leaves = source of truth. Intermediate sub-units + top SETs auto-derive.
//
// Three consumers:
//   1. b2f_auto_sync_parent_coverage()   — reactive: called by Snippet 0.5 after
//      every dual-write. Walks UP from $child_sku to re-evaluate ancestor coverage.
//   2. b2f_detect_missing_intermediates() — batch: scans entire junction, returns
//      all SKUs that SHOULD be registered per the coverage rule. Used by the
//      /sync-missing-intermediates endpoint for both dry-run + live.
//   3. b2f_insert_auto_sync_junction_row() — primitive: idempotent INSERT via
//      ON DUPLICATE KEY UPDATE id=id. unit_cost=0 (LIFF auto-computes SET cost).
//
// Blacklist: respects b2f_autosync_is_blacklisted() (V.3.2 helper from Audit snippet).
// Migration lock: inserts skipped when b2f_phase4_migration_in_progress option set.
// ─────────────────────────────────────────────────────────────────────

/**
 * Return array of parent SKUs (uppercase) for $sku based on dinoco_sku_relations.
 * DD-3 safe: one SKU may have multiple parents.
 */
if (!function_exists('b2f_get_parents_for_sku')) {
    function b2f_get_parents_for_sku($sku) {
        $sku_u = strtoupper(trim((string) $sku));
        if ($sku_u === '') return array();
        $relations = get_option('dinoco_sku_relations', array());
        if (!is_array($relations)) return array();
        $parents = array();
        foreach ($relations as $parent => $children) {
            if (!is_array($children)) continue;
            $parent_u = strtoupper((string) $parent);
            foreach ($children as $child) {
                if (strtoupper((string) $child) === $sku_u) {
                    $parents[] = $parent_u;
                    break;
                }
            }
        }
        return array_values(array_unique($parents));
    }
}

/**
 * Check if a SKU has a non-deleted junction row for this maker.
 */
if (!function_exists('b2f_is_sku_registered_for_maker')) {
    function b2f_is_sku_registered_for_maker($sku, $maker_id) {
        global $wpdb;
        $sku = strtoupper(trim((string) $sku));
        $maker_id = intval($maker_id);
        if (!$sku || !$maker_id) return false;
        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        return (bool) $wpdb->get_var($wpdb->prepare(
            "SELECT id FROM {$tbl} WHERE UPPER(product_sku) = %s AND maker_id = %d AND deleted_at IS NULL LIMIT 1",
            $sku, $maker_id
        ));
    }
}

/**
 * Check if $sku's children are ALL covered for $maker_id.
 * Coverage: leaf must be explicitly registered; non-leaf covered if all children covered (recursive).
 */
if (!function_exists('b2f_is_coverage_complete')) {
    function b2f_is_coverage_complete($sku, $maker_id, $visited = null) {
        if ($visited === null) $visited = array();
        $sku_u = strtoupper(trim((string) $sku));
        if (!$sku_u || !$maker_id) return false;
        if (isset($visited[$sku_u])) return false;
        $visited[$sku_u] = true;
        $relations = get_option('dinoco_sku_relations', array());
        if (!is_array($relations)) return false;
        $children = null;
        foreach ($relations as $p => $kids) {
            if (strtoupper((string) $p) === $sku_u && is_array($kids)) {
                $children = array_map(function($c) { return strtoupper((string) $c); }, $kids);
                break;
            }
        }
        if ($children === null || empty($children)) {
            // Leaf — covered iff registered
            return b2f_is_sku_registered_for_maker($sku_u, $maker_id);
        }
        foreach ($children as $ch) {
            if (b2f_is_sku_registered_for_maker($ch, $maker_id)) continue;
            $sub_visited = $visited;
            if (!b2f_is_coverage_complete($ch, $maker_id, $sub_visited)) return false;
        }
        return true;
    }
}

/**
 * INSERT a junction row for a coverage-derived SKU. unit_cost=0 (LIFF auto-computes
 * from leaves via b2f_compute_set_costs_v918). confirmation_status='auto_synced'.
 * Fires b2f_junction_updated hook. Returns bool success.
 *
 * Note: b2f_infer_production_mode_from_relations() returns STRING (not array), so we
 * derive admin_display_mode locally — 'as_parts' when production_mode is cross_factory
 * (missing leaves implied), else 'auto'.
 */
if (!function_exists('b2f_insert_auto_sync_junction_row')) {
    function b2f_insert_auto_sync_junction_row($sku, $maker_id) {
        global $wpdb;
        $sku = strtoupper(trim((string) $sku));
        $maker_id = intval($maker_id);
        if (!$sku || !$maker_id) return false;
        if (!get_option('b2f_schema_v10_activated')) return false;
        if (get_option('b2f_phase4_migration_in_progress')) return false;

        $pm = 'single';
        $ad = 'auto';
        if (function_exists('b2f_infer_production_mode_from_relations')) {
            $inferred = b2f_infer_production_mode_from_relations($sku, $maker_id);
            if (is_string($inferred) && $inferred !== '') {
                $pm = $inferred;
                if ($pm === 'cross_factory_assembly') $ad = 'as_parts';
            } elseif (is_array($inferred)) {
                // Forward-compat: if helper later returns array
                if (isset($inferred['production_mode']))    $pm = $inferred['production_mode'];
                if (isset($inferred['admin_display_mode'])) $ad = $inferred['admin_display_mode'];
            }
        }

        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $uid = get_current_user_id();
        $now = current_time('mysql');

        $ok = $wpdb->query($wpdb->prepare(
            "INSERT INTO {$tbl}
                (product_sku, maker_id, unit_cost, moq, lead_time_days,
                 shipping_land, shipping_sea, status, notes,
                 production_mode, confirmation_status, admin_display_mode, missing_leaves_count,
                 legacy_cpt_id, created_by, updated_by, created_at, updated_at, deleted_at)
             VALUES (%s, %d, 0, 1, 7, 0, 0, 'active', 'auto-synced (coverage rule)', %s, 'auto_synced', %s, 0, 0, %d, %d, %s, %s, NULL)
             ON DUPLICATE KEY UPDATE id = id",
            $sku, $maker_id, $pm, $ad, $uid, $uid, $now, $now
        ));
        if ($ok === false) return false;

        do_action('b2f_junction_updated', $maker_id);
        do_action('b2f_auto_sync_parent_added', $maker_id, $sku);
        if (function_exists('b2f_log')) {
            b2f_log('[AutoSync Coverage] added ' . $sku . ' for maker=' . $maker_id);
        }
        return true;
    }
}

/**
 * Reactive: called after any maker-product save. Walks up from $child_sku. For each
 * ancestor not yet registered AND with all-children-covered AND not blacklisted →
 * INSERT. Continues walking until an ancestor fails coverage. Returns array of added SKUs.
 *
 * Depth cap 10 prevents runaway on malformed relations.
 */
if (!function_exists('b2f_auto_sync_parent_coverage')) {
    function b2f_auto_sync_parent_coverage($maker_id, $child_sku, $depth = 0) {
        $added = array();
        if ($depth > 10) return $added;
        $maker_id = intval($maker_id);
        $child_sku = strtoupper(trim((string) $child_sku));
        if (!$maker_id || !$child_sku) return $added;
        $parents = b2f_get_parents_for_sku($child_sku);
        foreach ($parents as $parent_sku) {
            if (function_exists('b2f_autosync_is_blacklisted')
                && b2f_autosync_is_blacklisted($maker_id, $parent_sku)) {
                continue;
            }
            if (b2f_is_sku_registered_for_maker($parent_sku, $maker_id)) {
                // Already there — continue walking up (grandparent may now be coverable)
                $sub = b2f_auto_sync_parent_coverage($maker_id, $parent_sku, $depth + 1);
                $added = array_merge($added, $sub);
                continue;
            }
            if (!b2f_is_coverage_complete($parent_sku, $maker_id)) continue;
            if (b2f_insert_auto_sync_junction_row($parent_sku, $maker_id)) {
                $added[] = $parent_sku;
                $sub = b2f_auto_sync_parent_coverage($maker_id, $parent_sku, $depth + 1);
                $added = array_merge($added, $sub);
            }
        }
        return array_values(array_unique($added));
    }
}

/**
 * Scan all junction data and return list of [{maker_id, sku}] that SHOULD be registered
 * per the coverage rule but currently aren't. Used by /sync-missing-intermediates
 * endpoint for both dry-run preview and live add.
 *
 * $filter_maker_id (int, optional): limit scan to one maker.
 *
 * Loops until stable — adding one ancestor may enable grandparent coverage.
 */
if (!function_exists('b2f_detect_missing_intermediates')) {
    function b2f_detect_missing_intermediates($filter_maker_id = 0) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $filter_maker_id = intval($filter_maker_id);
        $where = $filter_maker_id > 0 ? $wpdb->prepare("AND maker_id = %d", $filter_maker_id) : '';
        $rows = $wpdb->get_results("SELECT maker_id, product_sku FROM {$tbl} WHERE deleted_at IS NULL {$where}", ARRAY_A);
        if (!is_array($rows)) return array();

        // maker_id → { SKU_upper: true }
        $maker_skus = array();
        foreach ($rows as $r) {
            $mid = intval($r['maker_id']);
            $sku_u = strtoupper((string) $r['product_sku']);
            if (!isset($maker_skus[$mid])) $maker_skus[$mid] = array();
            $maker_skus[$mid][$sku_u] = true;
        }

        $relations = get_option('dinoco_sku_relations', array());
        if (!is_array($relations)) return array();
        $rel_upper = array();
        $all_parents = array();
        foreach ($relations as $p => $kids) {
            if (!is_array($kids)) continue;
            $p_u = strtoupper((string) $p);
            $rel_upper[$p_u] = array_map(function($c) { return strtoupper((string) $c); }, $kids);
            $all_parents[] = $p_u;
        }

        // Closure: is $sku_u covered given the current $set?
        $is_covered = function($sku_u, $set, $visited = array()) use (&$is_covered, $rel_upper) {
            if (isset($set[$sku_u])) return true;
            if (isset($visited[$sku_u])) return false;
            $visited[$sku_u] = true;
            if (!isset($rel_upper[$sku_u]) || empty($rel_upper[$sku_u])) return false;
            foreach ($rel_upper[$sku_u] as $ch) {
                if (!$is_covered($ch, $set, $visited)) return false;
            }
            return true;
        };

        $out = array();
        foreach ($maker_skus as $mid => $set) {
            // Loop until stable — ancestor additions may enable grandparent coverage
            $stable = false;
            while (!$stable) {
                $stable = true;
                foreach ($all_parents as $p_u) {
                    if (isset($set[$p_u])) continue;
                    if (function_exists('b2f_autosync_is_blacklisted')
                        && b2f_autosync_is_blacklisted($mid, $p_u)) continue;
                    if ($is_covered($p_u, $set)) {
                        $out[] = array('maker_id' => $mid, 'sku' => $p_u);
                        $set[$p_u] = true;
                        $stable = false;
                    }
                }
            }
        }
        return $out;
    }
}


