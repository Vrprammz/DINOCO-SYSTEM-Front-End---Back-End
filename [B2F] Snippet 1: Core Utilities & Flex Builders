/**
 * 13. Maker command menu -- ดู PO / ส่งของ
 * แสดงเมื่อ Maker @bot ในห้อง LINE
 */
if (!function_exists('b2f_build_flex_command_menu_maker')) {
    function b2f_build_flex_command_menu_maker($maker_id = 0) {
        $maker_id = (int) $maker_id;

        $url_po_list = b2f_liff_url('/b2f-maker-po/', array(
            'maker_id' => $maker_id,
            'action'   => 'list',
        ));
        $url_deliver = b2f_liff_url('/b2f-maker-deliver/', array(
            'maker_id' => $maker_id,
            'action'   => 'deliver',
        ));
        $url_reschedule = b2f_liff_url('/b2f-maker-reschedule/', array(
            'maker_id' => $maker_id,
            'action'   => 'reschedule',
        ));

        // Count pending POs for this maker
        $pending_count = 0;
        if ($maker_id) {
            $query = new WP_Query(array(
                'post_type'      => 'b2f_order',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => array(
                    'relation' => 'AND',
                    array(
                        'key'   => 'po_maker_id',
                        'value' => $maker_id,
                    ),
                    array(
                        'key'     => 'po_status',
                        'value'   => array('submitted', 'confirmed'),
                        'compare' => 'IN',
                    ),
                ),
            ));
            $pending_count = $query->found_posts;
            wp_reset_postdata();
        }

        $subtitle = $pending_count > 0
            ? 'PO ที่รอดำเนินการ: ' . $pending_count . ' ใบ'
            : 'ไม่มี PO ที่รอดำเนินการ';

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header('DINOCO B2F', $subtitle),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '14px',
                'spacing'    => 'sm',
                'contents'   => array(
                    b2f_menu_section('ใบสั่งซื้อ'),
                    b2f_cmd_row_liff(
                        '📋',
                        'ดู PO ที่รอ',
                        $url_po_list,
                        'PO ที่รอยืนยัน/ยืนยันแล้ว'
                    ),
                    b2f_menu_section('ส่งของ'),
                    b2f_cmd_row_liff(
                        '📦',
                        'แจ้งส่งของ',
                        $url_deliver,
                        'แจ้ง DINOCO ว่ามาส่งของแล้ว'
                    ),
                    b2f_menu_section('เลื่อนวันส่ง'),
                    b2f_cmd_row_liff(
                        '📅',
                        'ขอเลื่อนวันส่ง',
                        $url_reschedule,
                        'ขอเลื่อนวันส่งพร้อมเหตุผล'
                    ),
                ),
            ),
        );

        return array(
            'type'     => 'flex',
            'altText'  => 'DINOCO B2F - คำสั่ง Maker',
            'contents' => $bubble,
        );
    }
}

