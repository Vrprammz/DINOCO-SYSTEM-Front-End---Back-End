if (!function_exists('b2f_build_flex_receiving')) {
    function b2f_build_flex_receiving($po_id, $rcv_id) {
        $po = b2f_get_po_data($po_id);
        if (!$po) return null;

        $rcv_number = get_field('rcv_number', $rcv_id) ?: 'RCV-' . $rcv_id;
        $rcv_date   = get_field('rcv_date', $rcv_id) ?: wp_date('Y-m-d');
        $rcv_items  = get_field('rcv_items', $rcv_id) ?: array();
        $rcv_note   = get_field('rcv_admin_note', $rcv_id);

        $total_received = 0;
        $total_rejected = 0;
        $items_contents = array();

        foreach ($rcv_items as $idx => $item) {
            $sku     = isset($item['rcvi_sku']) ? $item['rcvi_sku'] : '-';
            $qty_rcv = isset($item['rcvi_qty_received']) ? (int) $item['rcvi_qty_received'] : 0;
            $qty_rej = isset($item['rcvi_qty_rejected']) ? (int) $item['rcvi_qty_rejected'] : 0;
            $total_received += $qty_rcv;
            $total_rejected += $qty_rej;

            $items_contents[] = array(
                'type'     => 'box',
                'layout'   => 'horizontal',
                'margin'   => 'sm',
                'contents' => array(
                    array('type' => 'text', 'text' => ($idx + 1) . '. ' . mb_substr($sku, 0, 18), 'size' => 'xs', 'color' => '#333333', 'flex' => 5),
                    array('type' => 'text', 'text' => 'รับ ' . $qty_rcv . ($qty_rej > 0 ? ' / reject ' . $qty_rej : ''), 'size' => 'xs', 'color' => $qty_rej > 0 ? B2F_COLOR_RED : B2F_COLOR_GREEN, 'flex' => 5, 'align' => 'end'),
                ),
            );
        }

        $body_contents = array_merge(
            array(
                b2f_flex_kv_row('เลขที่ PO', $po['po_number']),
                b2f_flex_kv_row('ใบรับของ', $rcv_number),
                b2f_flex_kv_row('วันที่รับ', b2f_format_date_thai($rcv_date)),
                b2f_flex_separator(),
                array('type' => 'text', 'text' => 'รายการที่ DINOCO ตรวจรับ', 'size' => 'sm', 'weight' => 'bold', 'color' => B2F_COLOR_NAVY, 'margin' => 'md'),
            ),
            $items_contents,
            array(
                b2f_flex_separator(),
                b2f_flex_kv_row('รับทั้งหมด', $total_received . ' ชิ้น', B2F_COLOR_GREEN),
            )
