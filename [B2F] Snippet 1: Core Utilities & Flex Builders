                            'text'   => 'ฉบับแก้ไขครั้งที่ ' . $version,
                            'size'   => 'sm',
                            'weight' => 'bold',
                            'color'  => B2F_COLOR_AMBER,
                            'align'  => 'center',
                        ),
                    ),
                ),
                b2f_flex_kv_row('เลขที่ PO', $po['po_number']),
                b2f_flex_separator(),
                array(
                    'type'   => 'text',
                    'text'   => 'รายการสินค้า (แก้ไขแล้ว)',
                    'size'   => 'sm',
                    'weight' => 'bold',
                    'color'  => B2F_COLOR_NAVY,
                    'margin' => 'md',
                ),
            ),
            $items_contents,
            array(
                b2f_flex_separator(),
                b2f_flex_kv_row('ยอดรวมราคาทุน', b2f_format_currency($po['total_amount']), B2F_COLOR_NAVY),
            )
        );

        if (!empty($po['admin_note'])) {
            $body_contents[] = b2f_flex_kv_row('หมายเหตุ', mb_substr($po['admin_note'], 0, 50));
        }

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header('ใบสั่งซื้อแก้ไข', $po['po_number'] . ' (v' . $version . ')', B2F_COLOR_AMBER),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '16px',
                'spacing'    => 'sm',
                'contents'   => $body_contents,
            ),
            'footer' => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '12px',
                'spacing'    => 'sm',
                'contents'   => array(
                    b2f_flex_button('ยืนยันวันส่งของ', 'uri', $confirm_url, B2F_COLOR_GREEN),
                    b2f_flex_button('ปฏิเสธ PO', 'postback', 'action=b2f_reject_po&po_id=' . $po['id'], B2F_COLOR_RED),
