/**
 * เรียก Slip2Go API verify สลิป
 * @param string $image_base64 data:image/...;base64,... format
 * @param int    $maker_id     Maker CPT ID
 * @return array {success, code, data, slip_amount, trans_ref, is_duplicate, is_receiver_valid, raw}
 */
if (!function_exists('b2f_verify_slip_image')) {
    function b2f_verify_slip_image($image_base64, $maker_id) {
        $bank = b2f_get_maker_bank_info($maker_id);
        if (!$bank) {
            return array('success' => false, 'code' => 'NO_BANK_INFO', 'error' => 'โรงงานยังไม่มีข้อมูลบัญชีธนาคาร/รหัสธนาคาร');
        }

        $api_url = defined('B2B_SLIP2GO_API_URL') ? B2B_SLIP2GO_API_URL
                 : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';
        $api_key = defined('B2B_SLIP2GO_SECRET_KEY') ? B2B_SLIP2GO_SECRET_KEY : '';

        if (empty($api_key)) {
            return array('success' => false, 'code' => 'NO_API_KEY', 'error' => 'ไม่พบ Slip2Go API key');
        }

        $check_receiver = array(
            array(
                'accountNumber' => preg_replace('/[^0-9]/', '', $bank['bank_account']),
                'accountType'   => $bank['account_type'],
            ),
        );

        $payload = array(
            'payload' => array(
                'imageBase64'    => $image_base64,
                'checkCondition' => array(
                    'checkDuplicate' => true,
                    'checkReceiver'  => $check_receiver,
                ),
            ),
        );

        $response = wp_remote_post($api_url, array(
            'headers' => array(
                'Authorization' => 'Bearer ' . $api_key,
                'Content-Type'  => 'application/json',
            ),
            'body'    => wp_json_encode($payload),
            'timeout' => 30,
        ));

        if (is_wp_error($response)) {
            return array('success' => false, 'code' => 'API_ERROR', 'error' => $response->get_error_message());
        }

        $http_code = wp_remote_retrieve_response_code($response);
        $body      = json_decode(wp_remote_retrieve_body($response), true);

        if ($http_code !== 200 || empty($body)) {
            return array('success' => false, 'code' => 'HTTP_' . $http_code, 'error' => 'Slip2Go API error', 'raw' => $body);
        }

        $api_code  = isset($body['code']) ? $body['code'] : '';
        $data      = isset($body['data']) ? $body['data'] : array();
        $condition = isset($body['conditionResult']) ? $body['conditionResult'] : array();

        $result = array(
            'success'            => in_array($api_code, array('200000', '200200')),
            'code'               => $api_code,
            'slip_amount'        => isset($data['amount']) ? floatval($data['amount']) : 0,
            'trans_ref'          => isset($data['transRef']) ? $data['transRef'] : '',
            'sender_name'        => isset($data['sender']['account']['name']) ? $data['sender']['account']['name'] : '',
            'receiver_name'      => isset($data['receiver']['account']['name']) ? $data['receiver']['account']['name'] : '',
            'is_duplicate'       => !empty($condition['isDuplicate']),
            'is_receiver_valid'  => !empty($condition['isReceiverValid']),
            'raw'                => $body,
        );

        // Interpret error codes
        if ($api_code === '200501') {
            $result['error'] = 'สลิปนี้เคยใช้แล้ว (ซ้ำ)';
        } elseif ($api_code === '200401') {
            $result['error'] = 'บัญชีปลายทางไม่ตรง — สลิปโอนไปบัญชีอื่น';
        } elseif ($api_code === '200404') {
            $result['error'] = 'ไม่ใช่รูปสลิป';
        } elseif (!$result['is_receiver_valid'] && $result['success']) {
            $result['success'] = false;
            $result['error']   = 'บัญชีปลายทางไม่ตรงกับบัญชีโรงงาน';
        }

        return $result;
    }
}

