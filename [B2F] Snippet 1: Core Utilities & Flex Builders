// ─────────────────────────────────────────────────────────────
// 26. Delivered Detail — สรุปรายการที่ Maker ส่งมา (Delivery Form feature)
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_build_flex_delivered_detail')) {
    /**
     * @param int   $po_id
     * @param array $dlv_items  [{sku, qty, name}]
     * @param bool  $is_complete  ส่งครบทุก item?
     * @param bool  $is_additional  ส่งเพิ่ม (partial_received)?
     */
    function b2f_build_flex_delivered_detail($po_id, $dlv_items, $is_complete = true, $is_additional = false) {
        $po = b2f_get_po_data($po_id);
        if (!$po) return null;

        $title = $is_additional ? '📦 ส่งของเพิ่ม' : '🚛 แจ้งส่งของ';
        $header_color = $is_additional ? B2F_COLOR_AMBER : B2F_COLOR_NAVY;
        $badge_text = $is_complete ? '✅ ส่งครบ' : '⏳ ส่งบางส่วน';

        $body = array();
        $body[] = array('type'=>'box','layout'=>'horizontal','contents'=>array(
            array('type'=>'text','text'=>'🏭 โรงงาน','size'=>'xs','color'=>'#64748b','flex'=>2),
            array('type'=>'text','text'=>$po['maker_name'],'size'=>'xs','weight'=>'bold','flex'=>5,'align'=>'end','wrap'=>true)));

        $body[] = array('type'=>'text','text'=>'📦 รายการที่ส่ง','weight'=>'bold','size'=>'sm','margin'=>'md');

        // Item rows
        foreach ($dlv_items as $item) {
            $body[] = array('type'=>'box','layout'=>'horizontal','spacing'=>'sm','margin'=>'md','contents'=>array(
                array('type'=>'text','text'=>($item['name'] ?? $item['sku']),'size'=>'xs','flex'=>4,'wrap'=>true,'color'=>'#1e293b'),
                array('type'=>'text','text'=>'x'.$item['qty'],'size'=>'xs','flex'=>1,'align'=>'center','color'=>'#64748b'),
            ));
        }

        // ส่งครบ/ส่งบางส่วน badge
        $body[] = array('type'=>'separator','margin'=>'md');
        $badge_color = $is_complete ? B2F_COLOR_GREEN : B2F_COLOR_AMBER;
        $body[] = array('type'=>'text','text'=>$badge_text,'size'=>'sm','weight'=>'bold','color'=>$badge_color,'margin'=>'md');

        if (!$is_complete) {
            // แสดงรายการที่เหลือ
            $remaining_items = array();
            foreach ($po['items'] as $pi) {
                $ordered  = intval($pi['poi_qty_ordered'] ?? 0);
                $received = intval($pi['poi_qty_received'] ?? 0);
                $left     = $ordered - $received;
                // ลบ qty ที่กำลังส่งรอบนี้
                foreach ($dlv_items as $di) {
                    if (($di['sku'] ?? '') === ($pi['poi_sku'] ?? '')) {
                        $left -= intval($di['qty'] ?? 0);
                    }
                }
                if ($left > 0) {
                    $remaining_items[] = ($pi['poi_product_name'] ?? $pi['poi_sku']) . ' x' . $left;
                }
            }
            if (!empty($remaining_items)) {
                $body[] = array('type'=>'text','text'=>'ยังเหลือ: ' . implode(', ', array_slice($remaining_items, 0, 3)),'size'=>'xs','color'=>'#854d0e','wrap'=>true);
            }
        }

        $detail_url = b2f_liff_url('/b2f-po-ticket/', array('po_id' => $po_id));

        // V.2.4: เพิ่มปุ่ม "ตรวจรับสินค้า" สำหรับ Admin
        $footer_buttons = array(
            b2f_flex_button('📦 ตรวจรับสินค้า', 'uri', $detail_url, B2F_COLOR_GREEN),
            b2f_flex_button('📋 ดูรายละเอียด', 'uri', $detail_url, B2F_COLOR_NAVY),
        );

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header($title, $po['po_number'], $header_color),
            'body'   => array('type'=>'box','layout'=>'vertical','paddingAll'=>'16px','contents'=>$body),
            'footer' => array('type'=>'box','layout'=>'vertical','paddingAll'=>'12px','spacing'=>'sm','contents'=>$footer_buttons),
        );

        return array(
            'type'     => 'flex',
            'altText'  => $title . ' ' . $po['po_number'] . ' (' . count($dlv_items) . ' รายการ)',
            'contents' => $bubble,
        );
    }
}

