if (!function_exists('b2f_build_flex_command_menu_maker')) {
    function b2f_build_flex_command_menu_maker($maker_id = 0) {
        $maker_id = (int) $maker_id;

        // V.1.3: ใช้ path เดียว /b2f-maker/ + page param
        // เพื่อให้ LIFF router (B2B Snippet 4) redirect ถูก page
        $url_po_list = b2f_liff_url('/b2f-maker/', array(
            'maker_id' => $maker_id,
            'page'     => 'list',
        ));
        $url_deliver = b2f_liff_url('/b2f-maker/', array(
            'maker_id' => $maker_id,
            'page'     => 'deliver',
        ));
        $url_reschedule = b2f_liff_url('/b2f-maker/', array(
            'maker_id' => $maker_id,
            'page'     => 'reschedule',
        ));

        // Count pending POs for this maker
        $pending_count = 0;
        if ($maker_id) {
            $query = new WP_Query(array(
                'post_type'      => 'b2f_order',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => array(
                    'relation' => 'AND',
                    array(
                        'key'   => 'po_maker_id',
                        'value' => $maker_id,
                    ),
                    array(
                        'key'     => 'po_status',
                        'value'   => array('submitted', 'confirmed'),
                        'compare' => 'IN',
                    ),
                ),
            ));
            $pending_count = $query->found_posts;
            wp_reset_postdata();
        }

        $subtitle = $pending_count > 0
            ? 'PO ที่รอดำเนินการ: ' . $pending_count . ' ใบ'
