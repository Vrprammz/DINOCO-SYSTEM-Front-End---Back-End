// ── Helper: load PO data ────────────────────────────────────
if (!function_exists('b2f_get_po_data')) {
    function b2f_get_po_data($po_id) {
        $po_id = (int) $po_id;
        if (!$po_id) return null;

        $post = get_post($po_id);
        if (!$post || $post->post_type !== 'b2f_order') return null;

        $maker_id   = (int) get_field('po_maker_id', $po_id);
        $maker_name = '';
        if ($maker_id) {
            $maker_name = get_field('maker_name', $maker_id);
            if (empty($maker_name)) $maker_name = get_the_title($maker_id);
        }

        return array(
            'id'              => $po_id,
            'po_number'       => get_field('po_number', $po_id) ?: 'PO-' . $po_id,
            'maker_id'        => $maker_id,
            'maker_name'      => $maker_name,
            'status'          => get_field('po_status', $po_id) ?: 'draft',
            'items'           => get_field('po_items', $po_id) ?: array(),
            'total_amount'    => (float) get_field('po_total_amount', $po_id),
            'requested_date'  => get_field('po_requested_date', $po_id),
            'expected_date'   => get_field('po_expected_date', $po_id),
            'actual_date'     => get_field('po_actual_date', $po_id),
            'admin_note'      => get_field('po_admin_note', $po_id),
            'maker_note'      => get_field('po_maker_note', $po_id),
            'item_count'      => (int) get_field('po_item_count', $po_id),
            'amendment_count' => (int) get_field('po_amendment_count', $po_id),
            'version'         => (int) get_field('po_version', $po_id) ?: 1,
            'paid_amount'     => (float) get_field('po_paid_amount', $po_id),
            'payment_status'  => get_field('po_payment_status', $po_id) ?: 'unpaid',
            'maker_group_id'  => $maker_id ? get_field('maker_line_group_id', $maker_id) : '',
        );
    }
}

// ── Helper: format date Thai ────────────────────────────────
if (!function_exists('b2f_format_date_thai')) {
    function b2f_format_date_thai($date_str) {
        if (empty($date_str)) return '-';
        $ts = strtotime($date_str);
        if (!$ts) return $date_str;
        return date('d/m/Y', $ts);
    }
}

// ── Helper: format currency ─────────────────────────────────
if (!function_exists('b2f_format_currency')) {
    function b2f_format_currency($amount) {
        return number_format((float) $amount, 2) . ' B';
    }
}

