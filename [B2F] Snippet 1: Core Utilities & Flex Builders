//                         (full_set | sub_unit | single_leaf)
//
// Error codes (consumed by Snippet 2 + Audit) — see registry below.
//
// Cache strategy:
//   - Per-request static for read helpers (b2f_get_production_mode)
//   - Transient for API responses (b2f_maker_products_v11_{maker_id})
//   - Invalidation via central action hook `b2f_junction_updated`
//     → listener in this snippet below (HIGH-4)
// =====================================================================

// ── V.7.0 Error Code Registry ────────────────────────────────
// Defined ONCE to avoid collision if Snippet 2 / Audit / Snippet 0.5 included via eval()
if (!defined('B2F_ERR_INVALID_ORDER_MODE')) {
    define('B2F_ERR_INVALID_ORDER_MODE',        'invalid_order_mode');        // 400
    define('B2F_ERR_SOURCE_SKU_NOT_ANCESTOR',   'source_sku_not_ancestor');   // 400
    define('B2F_ERR_UNDO_WINDOW_EXPIRED',       'undo_window_expired');       // 410
    define('B2F_ERR_CHECK_CONSTRAINT',          'check_constraint_violation');// 422
    define('B2F_ERR_STALE_JUNCTION_WRITE',      'stale_junction_write');      // 409
    define('B2F_ERR_BULK_LIMIT_EXCEEDED',       'bulk_limit_exceeded');       // 400
    define('B2F_ERR_MYSQL_VERSION_TOO_LOW',     'mysql_version_too_low');     // warning log only
    define('B2F_ERR_MIGRATION_IN_PROGRESS',     'migration_in_progress');     // 503
