        if ($total_rejected > 0) {
            $body_contents[] = b2f_flex_kv_row('Reject', $total_rejected . ' ชิ้น', B2F_COLOR_RED);
        }

        if (!empty($rcv_note)) {
            $body_contents[] = b2f_flex_kv_row('หมายเหตุ', mb_substr($rcv_note, 0, 50));
        }

        $new_status = get_field('po_status', $po_id);
        $body_contents[] = b2f_flex_status_badge($new_status);

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header('DINOCO ตรวจรับสินค้าแล้ว', $rcv_number, '#7c3aed'),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '16px',
                'spacing'    => 'sm',
                'contents'   => $body_contents,
            ),
        );

        return array(
            'type'     => 'flex',
            'altText'  => 'DINOCO ตรวจรับ ' . $po['po_number'] . ' (' . $rcv_number . ')',
