/**
 * Push messages ไป LINE group/user
 * ใช้ B2B_LINE_ACCESS_TOKEN เพราะ Bot ตัวเดียวกัน
 */
if (!function_exists('b2f_line_push')) {
    function b2f_line_push($group_id, $messages) {
        if (defined('B2F_DISABLED') && B2F_DISABLED) return false;
        if (empty($group_id) || empty($messages)) return false;

        $token = defined('B2B_LINE_ACCESS_TOKEN') ? B2B_LINE_ACCESS_TOKEN : '';
        if (empty($token)) {
            error_log('[B2F] LINE push failed: B2B_LINE_ACCESS_TOKEN not defined');
            return false;
        }

        // Ensure messages is array of messages
        if (isset($messages['type'])) {
            $messages = array($messages);
        }

        $body = array(
            'to'       => $group_id,
            'messages' => array_slice($messages, 0, 5), // LINE limit 5 messages
        );

        $response = wp_remote_post('https://api.line.me/v2/bot/message/push', array(
            'headers' => array(
                'Content-Type'  => 'application/json',
                'Authorization' => 'Bearer ' . $token,
            ),
            'body'    => wp_json_encode($body),
            'timeout' => 15,
        ));

        if (is_wp_error($response)) {
            error_log('[B2F] LINE push error: ' . $response->get_error_message());
            return false;
        }

        $code = wp_remote_retrieve_response_code($response);
        if ($code !== 200) {
            $resp_body = wp_remote_retrieve_body($response);
            error_log('[B2F] LINE push HTTP ' . $code . ': ' . $resp_body);
            return false;
        }

        return true;
    }
}

/**
 * Push Flex message ไป LINE group
 */
if (!function_exists('b2f_line_push_flex')) {
    function b2f_line_push_flex($group_id, $flex) {
        if (empty($flex)) return false;

        // Wrap if not already a flex message envelope
        if (!isset($flex['type']) || $flex['type'] !== 'flex') {
            $flex = array(
                'type'     => 'flex',
                'altText'  => isset($flex['altText']) ? $flex['altText'] : 'B2F Notification',
                'contents' => $flex,
            );
        }

        return b2f_line_push($group_id, $flex);
    }
}

/**
 * Reply to LINE webhook event
 */
if (!function_exists('b2f_line_reply_raw')) {
    function b2f_line_reply_raw($reply_token, $messages) {
        if (defined('B2F_DISABLED') && B2F_DISABLED) return false;
        if (empty($reply_token) || empty($messages)) return false;

        $token = defined('B2B_LINE_ACCESS_TOKEN') ? B2B_LINE_ACCESS_TOKEN : '';
        if (empty($token)) return false;

        if (isset($messages['type'])) {
            $messages = array($messages);
        }

        $body = array(
            'replyToken' => $reply_token,
            'messages'   => array_slice($messages, 0, 5),
        );

        $response = wp_remote_post('https://api.line.me/v2/bot/message/reply', array(
            'headers' => array(
                'Content-Type'  => 'application/json',
                'Authorization' => 'Bearer ' . $token,
            ),
            'body'    => wp_json_encode($body),
            'timeout' => 15,
        ));

        if (is_wp_error($response)) {
            error_log('[B2F] LINE reply error: ' . $response->get_error_message());
            return false;
        }

        return wp_remote_retrieve_response_code($response) === 200;
    }
}


