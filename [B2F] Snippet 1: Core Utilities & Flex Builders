/**
 * สร้าง signed LIFF URL ด้วย JWT
 * Reuse DINOCO_JWT class จาก Snippet 15
 *
 * @param string $path   เช่น '/b2f-maker/', '/b2f-confirm/'
 * @param array  $params เช่น ['po_id' => 123, 'maker_id' => 45, 'action' => 'confirm']
 * @param int    $ttl    Token TTL in seconds (default 72 hours)
 * @return string LIFF URL with JWT token
 */
if (!function_exists('b2f_liff_url')) {
    /**
     * สร้าง LIFF URL สำหรับ B2F — ใช้ HMAC sig เหมือน b2b_liff_url()
     * ไม่พึ่ง DINOCO_JWT (ที่เคย crash)
     */
    function b2f_liff_url($path = '', $params = array()) {
        $liff_id = B2F_LIFF_ID;
        if (empty($liff_id)) {
            error_log('[B2F] B2F_LIFF_ID not configured');
            return '#';
        }

        // HMAC signature (เหมือน b2b_liff_url pattern)
        $params['_ts'] = time();
        $secret = defined('B2B_LINE_CHANNEL_SECRET') ? B2B_LINE_CHANNEL_SECRET : wp_salt('auth');
        $sig_data = $path . '|' . implode('|', array_map(function($k, $v) { return $k . '=' . $v; }, array_keys($params), $params));
        $params['_sig'] = substr(hash_hmac('sha256', $sig_data, $secret), 0, 16);

        $url = 'https://liff.line.me/' . $liff_id . '/' . ltrim($path, '/');
        $url .= '?' . http_build_query($params);

        return $url;
    }
}


