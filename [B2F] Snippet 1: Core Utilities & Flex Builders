        }

        $new_status = get_field('po_status', $po_id);
        $body_contents[] = b2f_flex_status_badge($new_status, $cur);

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header(b2f_t('DINOCO ตรวจรับสินค้าแล้ว', 'Goods Received', '验收完成', $cur), $rcv_number, '#7c3aed'),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '16px',
                'spacing'    => 'sm',
                'contents'   => $body_contents,
            ),
        );

        return array(
            'type'     => 'flex',
            'altText'  => b2f_t('DINOCO ตรวจรับ ', 'Goods Received ', '验收完成 ', $cur) . $po['po_number'] . ' (' . $rcv_number . ')',
