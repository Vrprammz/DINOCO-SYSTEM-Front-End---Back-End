// =====================================================================
// SECTION 99: PHASE 1 MIGRATION — FEATURE FLAG HELPERS (V.6.5 + V.7.0)
// =====================================================================
// Phase 1 = observe-only. ทุก flag default=false. Setter endpoint ใน audit
// snippet ล็อค 403 ถึง Phase 2. ใช้ wp_options ธรรมดา (ไม่ต้องสร้าง table)
//
// Allowed flags (whitelist):
//   - b2f_flag_auto_sync_sets       : Phase 2 — auto-register SET เมื่อ leaf ถูก register
//   - b2f_flag_shadow_write         : Phase 2 — dual-write CPT + canonical table
//   - b2f_flag_read_from_junction   : Phase 3 — reads ใช้ canonical table
//   - b2f_flag_v11_explicit_mode    : V.7.0 — backend return production_mode in API response
//   - b2f_flag_order_intent         : V.7.0 — accept order_mode per item + LIFF UI gated
//
// Dependency chain (enforce at flag setter endpoint in Audit):
//   - order_intent=ON ต้องมี v11_explicit_mode=ON ก่อน
//
// V.7.1 (Phase 1 audit BUG-H8): removed orphan flag `b2f_flag_ungroup_auto_hide`.
//   It was declared + UI-toggleable + dependency-checked but never consumed by any business
//   logic. Auto-hide behavior is driven by `admin_display_mode='as_parts'` set by the Phase 4
//   migration when missing_leaves>0 — not a runtime flag.
//
// Usage:
//   if (b2f_is_flag_enabled('b2f_flag_shadow_write')) { ... dual-write ... }
//   $flags = b2f_get_all_flags();
//   b2f_log_flag_change('b2f_flag_shadow_write', false, true, get_current_user_id());
// =====================================================================

if (!function_exists('b2f_is_flag_enabled')) {
    function b2f_is_flag_enabled($flag_name) {
        $allowed = array(
            // Phase 1–3 (existing)
            'b2f_flag_auto_sync_sets',
            'b2f_flag_shadow_write',
            'b2f_flag_read_from_junction',
            // V.7.0 (NEW — Order Intent)
            'b2f_flag_v11_explicit_mode',
            'b2f_flag_order_intent',
        );
        if (!in_array($flag_name, $allowed, true)) return false;
        return (bool) get_option($flag_name, false);
    }
}

if (!function_exists('b2f_get_all_flags')) {
    function b2f_get_all_flags() {
        return array(
            // Phase 1–3 (existing)
            'b2f_flag_auto_sync_sets'     => b2f_is_flag_enabled('b2f_flag_auto_sync_sets'),
            'b2f_flag_shadow_write'       => b2f_is_flag_enabled('b2f_flag_shadow_write'),
            'b2f_flag_read_from_junction' => b2f_is_flag_enabled('b2f_flag_read_from_junction'),
