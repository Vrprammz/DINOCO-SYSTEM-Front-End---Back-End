if (!function_exists('b2f_build_flex_reschedule_request')) {
    function b2f_build_flex_reschedule_request($po_id, $new_date = '', $reason = '') {
        $po = b2f_get_po_data($po_id);
        if (!$po) return null;

        $body_contents = array(
            b2f_flex_kv_row('เลขที่ PO', $po['po_number']),
            b2f_flex_kv_row('โรงงาน', $po['maker_name']),
            b2f_flex_separator(),
            b2f_flex_kv_row('กำหนดส่งเดิม', b2f_format_date_thai($po['expected_date'])),
            b2f_flex_kv_row('ขอเลื่อนเป็น', b2f_format_date_thai($new_date), B2F_COLOR_AMBER),
        );

        if (!empty($reason)) {
            $body_contents[] = array(
                'type'   => 'text',
                'text'   => 'เหตุผล:',
                'size'   => 'sm',
                'weight' => 'bold',
                'color'  => '#333333',
                'margin' => 'md',
            );
            $body_contents[] = array(
                'type'  => 'text',
                'text'  => mb_substr($reason, 0, 100),
                'size'  => 'sm',
                'color' => '#666666',
                'wrap'  => true,
            );
        }

        $old_ts = strtotime($po['expected_date']);
        $new_ts = strtotime($new_date);
        if ($old_ts && $new_ts) {
            $diff_days = (int) round(($new_ts - $old_ts) / 86400);
            if ($diff_days > 0) {
                $body_contents[] = b2f_flex_kv_row('เลื่อนออก', '+' . $diff_days . ' วัน', B2F_COLOR_AMBER);
            }
        }

        $postback_approve = 'action=b2f_approve_reschedule&po_id=' . $po['id'] . '&new_date=' . $new_date;
        $postback_reject  = 'action=b2f_reject_reschedule&po_id=' . $po['id'];

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header('Maker ขอเลื่อนวันส่ง', $po['po_number'], B2F_COLOR_AMBER),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '16px',
                'spacing'    => 'sm',
                'contents'   => $body_contents,
            ),
            'footer' => array(
                'type'       => 'box',
                'layout'     => 'horizontal',
                'paddingAll' => '12px',
                'spacing'    => 'sm',
                'contents'   => array(
                    b2f_flex_button('อนุมัติ', 'postback', $postback_approve, B2F_COLOR_GREEN),
                    b2f_flex_button('ไม่อนุมัติ', 'postback', $postback_reject, B2F_COLOR_RED),
                ),
            ),
        );

        return array(
            'type'     => 'flex',
            'altText'  => 'Maker ขอเลื่อนวันส่ง ' . $po['po_number'],
            'contents' => $bubble,
        );
    }
}


