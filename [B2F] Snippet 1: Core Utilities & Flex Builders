if (!function_exists('b2f_flex_button')) {
    function b2f_flex_button($label, $action_type = 'postback', $data = '', $color = '') {
        if (empty($color)) $color = B2F_COLOR_NAVY;

        $action = array();
        if ($action_type === 'uri') {
            $action = array(
                'type'  => 'uri',
                'label' => mb_substr($label, 0, 20),
                'uri'   => $data,
            );
        } else {
            $action = array(
                'type'        => 'postback',
                'label'       => mb_substr($label, 0, 20),
                'data'        => $data,
                'displayText' => $label,
            );
        }

        return array(
            'type'   => 'button',
            'style'  => 'primary',
            'color'  => $color,
            'height' => 'sm',
            'margin' => 'sm',
            'action' => $action,
        );
    }
}

/**
 * แสดงรายการ SKU + จำนวน + ราคาทุน สำหรับ PO items
 *
 * @param array $items Array of PO items (repeater rows)
 * @return array Flex box contents
 */
if (!function_exists('b2f_flex_po_items_list')) {
    function b2f_flex_po_items_list($items) {
        $contents = array();

        if (empty($items) || !is_array($items)) {
            $contents[] = array(
                'type'  => 'text',
                'text'  => '(ไม่มีรายการ)',
                'size'  => 'sm',
                'color' => B2F_COLOR_GRAY,
            );
            return $contents;
        }

        $idx = 0;
        foreach ($items as $item) {
            $idx++;
            $sku      = isset($item['poi_sku']) ? $item['poi_sku'] : '';
            $name     = isset($item['poi_product_name']) ? $item['poi_product_name'] : $sku;
            $qty      = isset($item['poi_qty_ordered']) ? (int) $item['poi_qty_ordered'] : 0;
            $cost     = isset($item['poi_unit_cost']) ? (float) $item['poi_unit_cost'] : 0;
            $subtotal = $qty * $cost;

            // Item row: number. name
            $contents[] = array(
                'type'   => 'text',
                'text'   => $idx . '. ' . mb_substr($name, 0, 30),
                'size'   => 'sm',
                'weight' => 'bold',
                'color'  => '#333333',
                'margin' => $idx > 1 ? 'md' : 'none',
            );

            // SKU + qty + price row
            $contents[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'margin'  => 'xs',
                'contents' => array(
                    array(
                        'type'  => 'text',
                        'text'  => 'x' . number_format($qty) . ' @' . number_format($cost, 2),
                        'size'  => 'xs',
                        'color' => '#888888',
                        'flex'  => 5,
                    ),
                    array(
                        'type'   => 'text',
                        'text'   => number_format($subtotal, 2) . ' B',
                        'size'   => 'xs',
                        'color'  => '#333333',
                        'weight' => 'bold',
                        'flex'   => 5,
                        'align'  => 'end',
                    ),
                ),
            );
        }

        return $contents;
    }
}

