/**
 * V.6.3 DD-3 Shared Child: Parse parent_breakdown JSON (backward compat)
 *
 * @param array $item PO item row (from po_items repeater)
 * @return array Breakdown entries: [{parent_sku, parent_name, qty}, ...]
 *
 * Behavior:
 * - ถ้า poi_parent_breakdown มีข้อมูล JSON valid → parse และ return
 * - ถ้าไม่มี (PO เก่า) → fallback ใช้ poi_parent_sku + poi_qty_ordered เป็น 1 entry
 * - ถ้า poi_parent_sku ว่างด้วย → return [{parent_sku: '__standalone__', qty: poi_qty_ordered}]
 *
 * Invariant: sum(return.qty) === poi_qty_ordered
 */
if (!function_exists('b2f_get_item_breakdown')) {
    function b2f_get_item_breakdown($item) {
        if (empty($item) || !is_array($item)) return array();
        $qty_ordered = intval($item['poi_qty_ordered'] ?? 0);

        // Try parse JSON first
        $raw = $item['poi_parent_breakdown'] ?? '';
        if (!empty($raw)) {
            $parsed = json_decode($raw, true);
            if (is_array($parsed) && !empty($parsed)) {
                // Validate invariant
                $sum = 0;
                foreach ($parsed as $b) { $sum += intval($b['qty'] ?? 0); }
                if ($sum === $qty_ordered) {
                    return $parsed; // valid breakdown
                }
                // sum mismatch → fallback
                if (function_exists('b2f_log')) {
                    b2f_log(sprintf('b2f_get_item_breakdown: sum mismatch sku=%s sum=%d qty=%d — using fallback',
                        $item['poi_sku'] ?? '', $sum, $qty_ordered));
                }
            }
        }

        // Fallback: PO เก่า หรือ JSON invalid → ใช้ poi_parent_sku เดี่ยว
        $parent_sku = trim($item['poi_parent_sku'] ?? '');
        $parent_name = $item['poi_parent_name'] ?? '';
        return array(
            array(
                'parent_sku'  => !empty($parent_sku) ? $parent_sku : '__standalone__',
                'parent_name' => $parent_name,
                'qty'         => $qty_ordered,
            ),
        );
    }
}

/**
 * V.6.3 DD-3 Shared Child: Build parent_breakdown JSON for saving to ACF
 *
 * @param array $breakdown [{parent_sku, parent_name, qty}, ...]
 * @return string JSON string ready to save to poi_parent_breakdown
 */
if (!function_exists('b2f_build_item_breakdown_json')) {
    function b2f_build_item_breakdown_json($breakdown) {
        if (empty($breakdown) || !is_array($breakdown)) return '';
        $clean = array();
        foreach ($breakdown as $b) {
            if (!is_array($b)) continue;
            $clean[] = array(
                'parent_sku'  => sanitize_text_field($b['parent_sku'] ?? '__standalone__'),
                'parent_name' => sanitize_text_field($b['parent_name'] ?? ''),
                // V.6.6 Issue #1: intermediate parent chain (e.g. "TOP/MID") — empty = 2-level fallback
                'parent_path' => sanitize_text_field($b['parent_path'] ?? ''),
                'qty'         => intval($b['qty'] ?? 0),
            );
        }
        return wp_json_encode($clean);
    }
}

/**
 * V.6.1 Hierarchy: Group PO items by SET parent
 * Returns { sets: { parent_sku => { parent_name, children[] } }, standalone: item[] }
 * PO เก่า (ไม่มี poi_parent_sku) → ทุก item เข้า standalone = backward compat
 */
if (!function_exists('b2f_group_items_by_set')) {
    function b2f_group_items_by_set($items) {
        $sets = array();
        $standalone = array();
        if (empty($items) || !is_array($items)) return array('sets' => $sets, 'standalone' => $standalone);

        foreach ($items as $item) {
            // V.6.4 DD-3: ใช้ parent_breakdown (JSON) เพื่อจัด 1 item ใต้หลาย SET ได้
            $breakdown = function_exists('b2f_get_item_breakdown')
                ? b2f_get_item_breakdown($item)
                : array();

            if (empty($breakdown)) {
                // Fallback: PO เก่าไม่มี breakdown
                $parent = isset($item['poi_parent_sku']) ? trim($item['poi_parent_sku']) : '';
                $breakdown = array(array(
                    'parent_sku'  => !empty($parent) ? $parent : '__standalone__',
                    'parent_name' => isset($item['poi_parent_name']) ? $item['poi_parent_name'] : '',
                    'qty'         => intval($item['poi_qty_ordered'] ?? 0),
                ));
            }

            foreach ($breakdown as $b) {
                $psku = $b['parent_sku'] ?? '__standalone__';
                $pqty = intval($b['qty'] ?? 0);

                if ($psku === '__standalone__' || empty($psku)) {
                    // สินค้าเดี่ยว → แยกออกพร้อม qty ของ breakdown entry
                    $std_copy = $item;
                    $std_copy['poi_qty_ordered'] = $pqty;
                    $std_copy['_breakdown_origin'] = '__standalone__';
                    $standalone[] = $std_copy;
                } else {
                    if (!isset($sets[$psku])) {
                        $sets[$psku] = array(
                            'parent_name' => $b['parent_name'] ?? $psku,
                            'children'    => array(),
                        );
                    }
                    // Clone item สำหรับแต่ละ SET + override qty เฉพาะของ SET นี้
                    $item_copy = $item;
                    $item_copy['poi_qty_ordered'] = $pqty;
                    $item_copy['_breakdown_origin'] = $psku;
                    $sets[$psku]['children'][] = $item_copy;
                }
            }
        }
        return array('sets' => $sets, 'standalone' => $standalone);
    }

    /**
     * V.6.6 Issue #1: 3-level hierarchy grouping (TOP SET → intermediate child → leaves)
     *
     * Parses `poi_parent_path` (slash-separated) per breakdown entry to build nested tree.
     * PO เก่าไม่มี `poi_parent_path` → fallback เรียก `b2f_group_items_by_set()` (2-level)
     *
     * Output shape (3-level):
     * {
     *   sets: {
     *     TOP_SKU: {
     *       parent_name: "ชุด NX500",
     *       children_nodes: {                    // intermediate children (path depth >= 2)
     *         MID_SKU: {
     *           parent_name: "Crash Bar บน",
     *           leaves: [ item_copy, ... ]       // leaf items ใต้ intermediate
     *         }
     *       },
     *       direct_leaves: [ item_copy, ... ]    // leaves ตรงใต้ TOP (path = "TOP" only)
     *     }
     *   },
     *   standalone: [ item_copy, ... ],          // ไม่มี parent
     *   is_3level: bool,                          // true ถ้ามี intermediate node
     *   fallback_used: bool                       // true ถ้าใช้ b2f_group_items_by_set (no paths)
     * }
     *
     * @param array $items PO items (repeater rows)
     * @return array
     */
    function b2f_group_items_by_path($items) {
        $result = array(
            'sets'          => array(),
            'standalone'    => array(),
            'is_3level'     => false,
            'fallback_used' => false,
        );
        if (empty($items) || !is_array($items)) return $result;

        // Probe: มี poi_parent_path ที่ไม่ว่างไหม → ถ้าไม่มีเลย fallback to 2-level
        $has_any_path = false;
        foreach ($items as $it) {
            $pp = isset($it['poi_parent_path']) ? trim((string)$it['poi_parent_path']) : '';
            if ($pp !== '') { $has_any_path = true; break; }
        }
        if (!$has_any_path) {
            // Backward compat: PO เก่า → fallback to 2-level grouping
            $legacy = function_exists('b2f_group_items_by_set')
                ? b2f_group_items_by_set($items)
                : array('sets' => array(), 'standalone' => $items);
            $result['sets']          = $legacy['sets'];
            $result['standalone']    = $legacy['standalone'];
            $result['fallback_used'] = true;
            return $result;
        }

        // 3-level parse using breakdown entries
        foreach ($items as $item) {
            $breakdown = function_exists('b2f_get_item_breakdown')
                ? b2f_get_item_breakdown($item)
                : array();

            if (empty($breakdown)) {
                // Fallback: no breakdown → treat as standalone
                $standalone_copy = $item;
                $standalone_copy['_breakdown_origin'] = '__standalone__';
                $result['standalone'][] = $standalone_copy;
                continue;
            }

            foreach ($breakdown as $b) {
                $psku      = $b['parent_sku'] ?? '__standalone__';
                $pname     = $b['parent_name'] ?? $psku;
                $ppath     = trim((string)($b['parent_path'] ?? ''));
                $bqty      = intval($b['qty'] ?? 0);

                if ($psku === '__standalone__' || empty($psku)) {
                    $std_copy = $item;
                    $std_copy['poi_qty_ordered'] = $bqty;
                    $std_copy['_breakdown_origin'] = '__standalone__';
                    $result['standalone'][] = $std_copy;
                    continue;
                }

                // Parse parent_path — format "TOP/MID1/MID2..." or "TOP" or ""
                // Fallback: if empty path, treat as direct leaf of $psku (2-level)
                if ($ppath === '') {
                    $chain = array($psku);
                } else {
                    $chain = array_values(array_filter(array_map('trim', explode('/', $ppath))));
                    if (empty($chain)) $chain = array($psku);
                }

                $top_sku = $chain[0];

                // Initialize TOP SET bucket
                if (!isset($result['sets'][$top_sku])) {
                    $result['sets'][$top_sku] = array(
                        'parent_name'    => ($top_sku === $psku) ? $pname : $top_sku,
                        'children_nodes' => array(),
                        'direct_leaves'  => array(),
                    );
                }

                // If only 1 node in chain (top only) → leaf is direct under top
                if (count($chain) === 1) {
                    $leaf_copy = $item;
                    $leaf_copy['poi_qty_ordered'] = $bqty;
                    $leaf_copy['_breakdown_origin'] = $psku;
                    $leaf_copy['_parent_path'] = $ppath;
                    $result['sets'][$top_sku]['direct_leaves'][] = $leaf_copy;
                } else {
                    // Chain >= 2 → intermediate node(s). Use LAST intermediate (closest to leaf) as grouping key
                    $result['is_3level'] = true;
                    $mid_sku = end($chain); // last is immediate parent of leaf
                    reset($chain);

                    // Resolve intermediate name — use $pname if $mid_sku === $psku, else fall back to $mid_sku
                    $mid_name = ($mid_sku === $psku) ? $pname : $mid_sku;

                    if (!isset($result['sets'][$top_sku]['children_nodes'][$mid_sku])) {
                        $result['sets'][$top_sku]['children_nodes'][$mid_sku] = array(
                            'parent_name' => $mid_name,
                            'leaves'      => array(),
                        );
                    }

                    $leaf_copy = $item;
                    $leaf_copy['poi_qty_ordered'] = $bqty;
                    $leaf_copy['_breakdown_origin'] = $psku;
                    $leaf_copy['_parent_path'] = $ppath;
                    $result['sets'][$top_sku]['children_nodes'][$mid_sku]['leaves'][] = $leaf_copy;
                }
            }
        }

        return $result;
    }

    /**
     * V.6.4 DD-3: Manufacturing summary — รวม qty ของ leaf ทุก SKU (flat list)
     * ใช้สำหรับ "ยอดรวมผลิต" section ใน PO ticket / image / flex
     *
     * @param array $items PO items
     * @return array [{sku, name, qty_total, breakdown:[{parent_sku, qty}]}, ...]
     */
    function b2f_compute_manufacturing_summary($items) {
        if (empty($items) || !is_array($items)) return array();
        $summary = array();
        foreach ($items as $item) {
            $sku = $item['poi_sku'] ?? '';
            if (empty($sku)) continue;
            $qty = intval($item['poi_qty_ordered'] ?? 0);
            $breakdown = function_exists('b2f_get_item_breakdown') ? b2f_get_item_breakdown($item) : array();

            $summary[] = array(
                'sku'          => $sku,
                'name'         => $item['poi_product_name'] ?? $sku,
                'qty_total'    => $qty,
                'unit_cost'    => floatval($item['poi_unit_cost'] ?? 0),
                'breakdown'    => $breakdown,
                'is_shared'    => count($breakdown) > 1,
                'image_url'    => $item['poi_image_url'] ?? $item['image_url'] ?? '',
            );
        }
        return $summary;
    }
}

/**
 * แสดงรายการ SKU + จำนวน + ราคาทุน สำหรับ PO items
 * V.6.1: Grouped by SET parent
 *
 * @param array $items Array of PO items (repeater rows)
 * @return array Flex box contents
 */
if (!function_exists('b2f_flex_po_items_list')) {
    /**
     * V.6.1 Hierarchy: Group items by SET parent for Flex display
     * V.6.6 Issue #1: 3-level render (SET → intermediate child → leaves) เมื่อ poi_parent_path มีข้อมูล
     * PO เก่า (ไม่มี poi_parent_sku) → flat list เดิม (backward compat via b2f_group_items_by_set)
     * V.7.0: Optional $show_mode_badge param — prepend order_mode icon (🟣/🟠/⚪) per item row
     *        when flag `b2f_flag_order_intent` is ON + item has `poi_order_mode`.
     *        PII guard: NEVER include `poi_intent_notes` in Flex output (admin-only).
     *
     * @param array  $items            Array of PO items (repeater rows)
     * @param string $currency         'THB'|'USD'|'CNY' (or legacy boolean is_eng)
     * @param bool   $show_mode_badge  V.7.0 — prepend mode badge icon to each item row
     * @return array Flex box contents
     */
    function b2f_flex_po_items_list($items, $currency = 'THB', $show_mode_badge = true) {
        // Backward compat: old callers pass boolean $is_eng
        if (is_bool($currency)) {
            $currency = $currency ? 'USD' : 'THB';
        }
        // V.7.0: only show badge when flag ON (gradual rollout)
        $intent_flag_on = function_exists('b2f_is_flag_enabled')
            ? b2f_is_flag_enabled('b2f_flag_order_intent')
            : false;
        $show_mode_badge = (bool) $show_mode_badge && $intent_flag_on;

        // V.7.0: helper to prefix mode icon to name (inline — keep single-string row)
        $mode_icon = function($mode) {
            switch ((string) $mode) {
                case 'full_set':    return '🟣 ';
                case 'sub_unit':    return '🟠 ';
                case 'single_leaf': return '⚪ ';
                default:            return '';
            }
        };

        // V.7.0: PII guard — strip poi_intent_notes from items array before any render
        // (defensive — callers should already gate by capability, but snippet 1 enforces)
        if (is_array($items)) {
            foreach ($items as $__k => $__v) {
                if (is_array($__v) && isset($items[$__k]['poi_intent_notes'])) {
                    unset($items[$__k]['poi_intent_notes']);
                }
            }
            unset($__k, $__v);
        }

        $contents = array();

        if (empty($items) || !is_array($items)) {
            $contents[] = array(
                'type'  => 'text',
                'text'  => b2f_t('(ไม่มีรายการ)', '(No items)', '(无项目)', $currency),
                'size'  => 'sm',
                'color' => B2F_COLOR_GRAY,
            );
            return $contents;
        }

        // V.6.6 Issue #1: try 3-level grouping first — fallback to 2-level if no paths present
        $grouped_3 = function_exists('b2f_group_items_by_path')
            ? b2f_group_items_by_path($items)
            : array('sets' => array(), 'standalone' => $items, 'is_3level' => false, 'fallback_used' => true);

        $sym    = function_exists('b2f_currency_symbol') ? b2f_currency_symbol($currency) : '฿';
        $idx    = 0;
        $is_first_group = true;

        // If 3-level data present — use new render path
        if (!empty($grouped_3['is_3level']) && !empty($grouped_3['sets'])) {
            $top_sets   = $grouped_3['sets'];
            $standalone = $grouped_3['standalone'];

            foreach ($top_sets as $top_sku => $top_group) {
                // Compute TOP SET total = sum(direct_leaves) + sum(children_nodes.leaves)
                $top_total = 0;
                foreach ($top_group['direct_leaves'] as $ch) {
                    $top_total += (float)($ch['poi_unit_cost'] ?? 0) * (int)($ch['poi_qty_ordered'] ?? 0);
                }
                foreach ($top_group['children_nodes'] as $mid) {
                    foreach ($mid['leaves'] as $leaf) {
                        $top_total += (float)($leaf['poi_unit_cost'] ?? 0) * (int)($leaf['poi_qty_ordered'] ?? 0);
                    }
                }

                // TOP SET header (purple)
                $contents[] = array(
                    'type'    => 'box',
                    'layout'  => 'horizontal',
                    'margin'  => $is_first_group ? 'none' : 'lg',
                    'contents' => array(
                        array('type'=>'text','text'=>'🟣 ' . mb_substr($top_group['parent_name'], 0, 25),'size'=>'sm','weight'=>'bold','color'=>'#7c3aed','flex'=>5,'wrap'=>true),
                        array('type'=>'text','text'=>$sym . number_format($top_total, 0),'size'=>'xs','weight'=>'bold','color'=>'#333333','flex'=>3,'align'=>'end'),
                    ),
                );
                $is_first_group = false;

                // Direct leaves under TOP (2-level: TOP → leaf directly)
                foreach ($top_group['direct_leaves'] as $item) {
                    $idx++;
                    $name     = isset($item['poi_product_name']) ? $item['poi_product_name'] : ($item['poi_sku'] ?? '');
                    $qty      = (int)($item['poi_qty_ordered'] ?? 0);
                    $cost     = (float)($item['poi_unit_cost'] ?? 0);
                    $subtotal = $qty * $cost;
                    // V.7.0: mode badge prefix
                    $_badge   = ($show_mode_badge && !empty($item['poi_order_mode'])) ? $mode_icon($item['poi_order_mode']) : '';

                    $contents[] = array(
                        'type'    => 'box',
                        'layout'  => 'horizontal',
                        'margin'  => 'xs',
                        'paddingStart' => '8px',
                        'contents' => array(
                            array('type'=>'text','text'=>'  ' . $idx . '. ' . $_badge . mb_substr($name, 0, 26),'size'=>'xs','color'=>'#555555','flex'=>5,'wrap'=>true),
                            array('type'=>'text','text'=>'x' . number_format($qty) . ' @' . number_format($cost, 2),'size'=>'xxs','color'=>'#888888','flex'=>3),
                            array('type'=>'text','text'=>number_format($subtotal, 0),'size'=>'xxs','weight'=>'bold','color'=>'#333333','flex'=>2,'align'=>'end'),
                        ),
                    );
                }

                // Intermediate children nodes (3-level: TOP → MID → leaves)
                foreach ($top_group['children_nodes'] as $mid_sku => $mid) {
                    // MID header (blue)
                    $mid_total = 0;
                    foreach ($mid['leaves'] as $leaf) {
                        $mid_total += (float)($leaf['poi_unit_cost'] ?? 0) * (int)($leaf['poi_qty_ordered'] ?? 0);
                    }
                    $contents[] = array(
                        'type'    => 'box',
                        'layout'  => 'horizontal',
                        'margin'  => 'sm',
                        'paddingStart' => '8px',
                        'contents' => array(
                            array('type'=>'text','text'=>'🔵 ' . mb_substr($mid['parent_name'], 0, 23),'size'=>'xs','weight'=>'bold','color'=>'#2563eb','flex'=>5,'wrap'=>true),
                            array('type'=>'text','text'=>$sym . number_format($mid_total, 0),'size'=>'xxs','weight'=>'bold','color'=>'#555555','flex'=>3,'align'=>'end'),
                        ),
                    );

                    // Leaves under MID (indent 18px)
                    foreach ($mid['leaves'] as $item) {
                        $idx++;
                        $name     = isset($item['poi_product_name']) ? $item['poi_product_name'] : ($item['poi_sku'] ?? '');
                        $qty      = (int)($item['poi_qty_ordered'] ?? 0);
                        $cost     = (float)($item['poi_unit_cost'] ?? 0);
                        $subtotal = $qty * $cost;
                        // V.7.0: mode badge prefix
                        $_badge   = ($show_mode_badge && !empty($item['poi_order_mode'])) ? $mode_icon($item['poi_order_mode']) : '';

                        $contents[] = array(
                            'type'    => 'box',
                            'layout'  => 'horizontal',
                            'margin'  => 'xs',
                            'paddingStart' => '18px',
                            'contents' => array(
                                array('type'=>'text','text'=>'  ' . $idx . '. ' . $_badge . mb_substr($name, 0, 24),'size'=>'xxs','color'=>'#666666','flex'=>5,'wrap'=>true),
                                array('type'=>'text','text'=>'x' . number_format($qty) . ' @' . number_format($cost, 2),'size'=>'xxs','color'=>'#888888','flex'=>3),
                                array('type'=>'text','text'=>number_format($subtotal, 0),'size'=>'xxs','weight'=>'bold','color'=>'#333333','flex'=>2,'align'=>'end'),
                            ),
                        );
                    }
                }
            }

            // Standalone items (ไม่มี parent = สินค้าเดี่ยว)
            foreach ($standalone as $item) {
                $idx++;
                $name     = isset($item['poi_product_name']) ? $item['poi_product_name'] : ($item['poi_sku'] ?? '');
                $qty      = (int)($item['poi_qty_ordered'] ?? 0);
                $cost     = (float)($item['poi_unit_cost'] ?? 0);
                $subtotal = $qty * $cost;
                // V.7.0: mode badge prefix
                $_badge   = ($show_mode_badge && !empty($item['poi_order_mode'])) ? $mode_icon($item['poi_order_mode']) : '';

                $contents[] = array(
                    'type'   => 'text',
                    'text'   => $idx . '. ' . $_badge . mb_substr($name, 0, 30),
                    'size'   => 'sm',
                    'weight' => 'bold',
                    'color'  => '#333333',
                    'margin' => $idx > 1 ? 'md' : 'none',
                );
                $contents[] = array(
                    'type'    => 'box',
                    'layout'  => 'horizontal',
                    'margin'  => 'xs',
                    'contents' => array(
                        array('type'=>'text','text'=>'x' . number_format($qty) . ' @' . number_format($cost, 2),'size'=>'xs','color'=>'#888888','flex'=>5),
                        array('type'=>'text','text'=>number_format($subtotal, 2) . ' B','size'=>'xs','color'=>'#333333','weight'=>'bold','flex'=>5,'align'=>'end'),
                    ),
                );
            }

            return $contents;
        }

        // ─────────────────────────────────────────────────────────────
        // Fallback: 2-level render (backward compat สำหรับ PO เก่า)
        // ─────────────────────────────────────────────────────────────
        $grouped = function_exists('b2f_group_items_by_set') ? b2f_group_items_by_set($items) : array('sets'=>array(),'standalone'=>$items);
        $set_groups = $grouped['sets'];
        $standalone = $grouped['standalone'];

        // ── Render SET groups ──
        foreach ($set_groups as $parent_sku => $group) {
            // SET header
            $set_total = 0;
            $set_qty   = 0;
            foreach ($group['children'] as $ch) {
                $set_total += (float)($ch['poi_unit_cost'] ?? 0) * (int)($ch['poi_qty_ordered'] ?? 0);
                $set_qty   += (int)($ch['poi_qty_ordered'] ?? 0);
            }
            $contents[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'margin'  => $is_first_group ? 'none' : 'lg',
                'contents' => array(
                    array('type'=>'text','text'=>'🟣 ' . mb_substr($group['parent_name'], 0, 25),'size'=>'sm','weight'=>'bold','color'=>'#7c3aed','flex'=>5,'wrap'=>true),
                    array('type'=>'text','text'=>$sym . number_format($set_total, 0),'size'=>'xs','weight'=>'bold','color'=>'#333333','flex'=>3,'align'=>'end'),
                ),
            );
            $is_first_group = false;

            // SET children
            foreach ($group['children'] as $item) {
                $idx++;
                $name     = isset($item['poi_product_name']) ? $item['poi_product_name'] : ($item['poi_sku'] ?? '');
                $qty      = (int)($item['poi_qty_ordered'] ?? 0);
                $cost     = (float)($item['poi_unit_cost'] ?? 0);
                $subtotal = $qty * $cost;
                // V.7.0: mode badge prefix
                $_badge   = ($show_mode_badge && !empty($item['poi_order_mode'])) ? $mode_icon($item['poi_order_mode']) : '';

                $contents[] = array(
                    'type'    => 'box',
                    'layout'  => 'horizontal',
                    'margin'  => 'xs',
                    'paddingStart' => '8px',
                    'contents' => array(
                        array('type'=>'text','text'=>'  ' . $idx . '. ' . $_badge . mb_substr($name, 0, 26),'size'=>'xs','color'=>'#555555','flex'=>5,'wrap'=>true),
                        array('type'=>'text','text'=>'x' . number_format($qty) . ' @' . number_format($cost, 2),'size'=>'xxs','color'=>'#888888','flex'=>3),
                        array('type'=>'text','text'=>number_format($subtotal, 0),'size'=>'xxs','weight'=>'bold','color'=>'#333333','flex'=>2,'align'=>'end'),
                    ),
                );
            }
        }

        // ── Render standalone items (ไม่มี parent = สินค้าเดี่ยว) ──
        foreach ($standalone as $item) {
            $idx++;
            $name     = isset($item['poi_product_name']) ? $item['poi_product_name'] : ($item['poi_sku'] ?? '');
            $qty      = (int)($item['poi_qty_ordered'] ?? 0);
            $cost     = (float)($item['poi_unit_cost'] ?? 0);
            $subtotal = $qty * $cost;
            // V.7.0: mode badge prefix
            $_badge   = ($show_mode_badge && !empty($item['poi_order_mode'])) ? $mode_icon($item['poi_order_mode']) : '';

            $contents[] = array(
                'type'   => 'text',
                'text'   => $idx . '. ' . $_badge . mb_substr($name, 0, 30),
                'size'   => 'sm',
                'weight' => 'bold',
                'color'  => '#333333',
                'margin' => $idx > 1 ? 'md' : 'none',
            );
            $contents[] = array(
                'type'    => 'box',
                'layout'  => 'horizontal',
                'margin'  => 'xs',
                'contents' => array(
                    array('type'=>'text','text'=>'x' . number_format($qty) . ' @' . number_format($cost, 2),'size'=>'xs','color'=>'#888888','flex'=>5),
                    array('type'=>'text','text'=>number_format($subtotal, 2) . ' B','size'=>'xs','color'=>'#333333','weight'=>'bold','flex'=>5,'align'=>'end'),
                ),
            );
        }

        return $contents;
    }
}

