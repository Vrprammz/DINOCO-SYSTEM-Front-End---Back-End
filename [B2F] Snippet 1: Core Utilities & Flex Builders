// 1. PO ใหม่ส่งไป Maker (รายการ + ยอดรวม + ปุ่มยืนยัน/ปฏิเสธ)
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_build_flex_new_po')) {
    function b2f_build_flex_new_po($po_id) {
        $po = b2f_get_po_data($po_id);
        if (!$po) return null;

        $items_contents = b2f_flex_po_items_list($po['items']);

        // BUG-1 fix: ใช้ datetimepicker params (postback) ไม่ใช่ URI+HMAC
        $tomorrow = wp_date( 'Y-m-d', strtotime( '+1 day' ) );
        $max_date = wp_date( 'Y-m-d', strtotime( '+90 days' ) );
        $initial  = $po['expected_date'] ?: wp_date( 'Y-m-d', strtotime( '+7 days' ) );

        $reject_url = b2f_liff_url('/b2f-maker/', array(
            'po_id'    => $po['id'],
            'maker_id' => $po['maker_id'],
            'action'   => 'reject',
        ));

        $body_contents = array_merge(
            array(
                array(
                    'type'   => 'text',
                    'text'   => 'ใบสั่งซื้อจาก DINOCO',
                    'size'   => 'md',
                    'weight' => 'bold',
                    'color'  => '#333333',
                ),
                b2f_flex_kv_row('เลขที่ PO', $po['po_number']),
                b2f_flex_separator(),
                array(
                    'type'   => 'text',
                    'text'   => 'รายการสินค้า',
                    'size'   => 'sm',
                    'weight' => 'bold',
                    'color'  => B2F_COLOR_NAVY,
                    'margin' => 'md',
                ),
            ),
            $items_contents,
            array(
                b2f_flex_separator(),
                b2f_flex_kv_row('ยอดรวมราคาทุน', b2f_format_currency($po['total_amount']), B2F_COLOR_NAVY),
            )
        );

        if (!empty($po['requested_date'])) {
            $body_contents[] = b2f_flex_kv_row('ต้องการรับภายใน', b2f_format_date_thai($po['requested_date']));
        }

        if (!empty($po['admin_note'])) {
            $body_contents[] = b2f_flex_kv_row('หมายเหตุ', mb_substr($po['admin_note'], 0, 50));
        }

        $bubble = array(
            'type'   => 'bubble',
            'size'   => 'mega',
            'header' => b2f_flex_header('B2F ใบสั่งซื้อใหม่', $po['po_number']),
            'body'   => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '16px',
                'spacing'    => 'sm',
                'contents'   => $body_contents,
            ),
            'footer' => array(
                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '12px',
                'spacing'    => 'sm',
                'contents'   => array(
                    array( 'type' => 'button', 'style' => 'primary', 'color' => B2F_COLOR_GREEN, 'height' => 'sm',
                        'action' => array( 'type' => 'datetimepicker', 'label' => '✅ ยืนยัน + เลือกวันส่ง',
                            'data' => 'action=b2f_maker_confirm&po_id=' . $po['id'], 'mode' => 'date',
                            'initial' => $initial, 'min' => $tomorrow, 'max' => $max_date ) ),
                    b2f_flex_button('ปฏิเสธ PO', 'uri', $reject_url, B2F_COLOR_RED),
                ),
            ),
        );

        return array(
            'type'     => 'flex',
            'altText'  => 'ใบสั่งซื้อใหม่ ' . $po['po_number'],
            'contents' => $bubble,
        );
    }
