// ─────────────────────────────────────────────────────────────
// 100.1 — Read production_mode from junction table
// Per-request static cache; reads wp_dinoco_product_makers.
// Returns NULL if row missing, v11 flag off, or table not yet activated.
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_get_production_mode')) {
    function b2f_get_production_mode($sku, $maker_id) {
        static $cache = array();

        $sku = trim((string) $sku);
        $maker_id = (int) $maker_id;
        if ($sku === '' || $maker_id <= 0) return null;

        // V.7.0 gate: only read new column when flag ON
        if (!function_exists('b2f_is_flag_enabled') || !b2f_is_flag_enabled('b2f_flag_v11_explicit_mode')) {
            return null;
        }

        $key = strtoupper($sku) . ':' . $maker_id;
        if (array_key_exists($key, $cache)) return $cache[$key];

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_product_makers';

        // Column existence probe — if schema not activated yet, return null
        $col_exists = $wpdb->get_var($wpdb->prepare(
            "SELECT COUNT(*) FROM INFORMATION_SCHEMA.COLUMNS
             WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s AND COLUMN_NAME = 'production_mode'",
            DB_NAME, $table
        ));
        if (!(int) $col_exists) {
            $cache[$key] = null;
            return null;
        }

        $row = $wpdb->get_var($wpdb->prepare(
            "SELECT production_mode FROM {$table}
             WHERE BINARY UPPER(product_sku) = UPPER(%s) AND maker_id = %d AND deleted_at IS NULL
             LIMIT 1",
            $sku, $maker_id
        ));

        $cache[$key] = ($row === null || $row === '') ? null : (string) $row;
        return $cache[$key];
    }
}


// ─────────────────────────────────────────────────────────────
// 100.2 — Infer legacy order_mode (display-only fallback)
// For PO created before V.7.0 with no poi_order_mode sub-field.
// NEVER writes DB. Returns best-guess string for UI label.
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_infer_legacy_order_mode')) {
    function b2f_infer_legacy_order_mode($item) {
        if (!is_array($item)) return 'full_set';

        $parent_sku = trim((string) ($item['poi_parent_sku'] ?? ''));
        $qty        = (int) ($item['poi_qty_ordered'] ?? 0);

        // No parent → legacy raw_parts (kept as label-only; V.7.0 calls this sub_unit)
        if ($parent_sku === '' && $qty >= 2) {
            return 'raw_parts';
        }

        // Has parent + qty lower than expected leaves → partial_replenish (legacy)
        if ($parent_sku !== '' && $qty >= 1) {
            // Best-effort: if the parent has >1 leaf and this row's qty < leaves_count → partial
            if (function_exists('dinoco_get_leaf_skus')) {
                $leaves = dinoco_get_leaf_skus($parent_sku);
                $leaves_count = is_array($leaves) ? count($leaves) : 0;
                if ($leaves_count > 1 && $qty < $leaves_count) {
                    return 'partial_replenish';
                }
            }
            return 'full_set';
        }

        return 'full_set';
    }
}


// ─────────────────────────────────────────────────────────────
// 100.3 — Validate source_sku in ancestor chain (anti-malicious)
// source_sku MUST be the clicked SKU OR an ancestor of the expanded leaf.
// Uses dinoco_get_ancestor_skus() from [B2B] Snippet 15.
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_validate_source_sku_in_ancestors')) {
    function b2f_validate_source_sku_in_ancestors($leaf_sku, $source_sku) {
        $leaf_sku   = strtoupper(trim((string) $leaf_sku));
        $source_sku = strtoupper(trim((string) $source_sku));

        if ($leaf_sku === '' || $source_sku === '') {
            return new WP_Error(
                B2F_ERR_SOURCE_SKU_NOT_ANCESTOR,
                'leaf_sku and source_sku are required',
                array('status' => 400)
            );
        }

        // Short-circuit: admin clicked SKU directly == leaf (common case for single leaf)
        if ($source_sku === $leaf_sku) return true;

        if (!function_exists('dinoco_get_ancestor_skus')) {
            // Defensive: if Snippet 15 not loaded, allow (legacy PO paths)
            return true;
        }

        $ancestors = dinoco_get_ancestor_skus($leaf_sku);
        if (!is_array($ancestors)) $ancestors = array();

        // dinoco_get_ancestor_skus returns uppercase SKUs already (per Snippet 15 V.7.0)
        foreach ($ancestors as $anc) {
            if (strtoupper((string) $anc) === $source_sku) return true;
        }

        return new WP_Error(
            B2F_ERR_SOURCE_SKU_NOT_ANCESTOR,
            sprintf('source_sku "%s" is not an ancestor of leaf "%s"', $source_sku, $leaf_sku),
            array('status' => 400, 'leaf_sku' => $leaf_sku, 'source_sku' => $source_sku)
        );
    }
}


// ─────────────────────────────────────────────────────────────
// 100.4 — Atomic UPDATE classification (junction table)
// START TRANSACTION + FOR UPDATE.
// Whitelist 3 fields: production_mode, admin_display_mode, confirmation_status.
// Auto-flip: cross_factory_assembly + admin_display_mode not explicit → 'as_parts'.
// Auto-set confirmed_by + confirmed_at on transition → 'confirmed'.
// Fires central hook: do_action('b2f_junction_updated', $maker_id).
// Audit: insert to observations table (source='classification_change').
// ─────────────────────────────────────────────────────────────
if (!function_exists('b2f_junction_update_classification')) {
    function b2f_junction_update_classification($sku, $maker_id, $fields, $actor_id) {
        global $wpdb;

        $sku       = trim((string) $sku);
        $maker_id  = (int) $maker_id;
        $actor_id  = (int) $actor_id;
        if ($sku === '' || $maker_id <= 0) {
            return new WP_Error('invalid_args', 'sku and maker_id required', array('status' => 400));
        }
        if (!is_array($fields) || empty($fields)) {
            return new WP_Error('invalid_field', 'fields payload empty', array('status' => 400));
        }

        // Enum registry
        $enum_production_mode = array('set_assembled', 'sub_unit', 'single', 'cross_factory_assembly');
        $enum_admin_display   = array('auto', 'as_set', 'as_parts');
        $enum_confirmation    = array('confirmed', 'auto_synced');

        // Whitelist + validate enums
        $set = array();
        $formats = array();
        foreach ($fields as $k => $v) {
            switch ($k) {
                case 'production_mode':
                    if (!in_array($v, $enum_production_mode, true)) {
                        return new WP_Error('invalid_enum_value',
                            'production_mode invalid: ' . (string) $v,
                            array('status' => 400, 'field' => 'production_mode'));
                    }
                    $set['production_mode'] = (string) $v;
                    break;
                case 'admin_display_mode':
                    if (!in_array($v, $enum_admin_display, true)) {
                        return new WP_Error('invalid_enum_value',
                            'admin_display_mode invalid: ' . (string) $v,
                            array('status' => 400, 'field' => 'admin_display_mode'));
                    }
                    $set['admin_display_mode'] = (string) $v;
                    break;
                case 'confirmation_status':
                    if (!in_array($v, $enum_confirmation, true)) {
                        return new WP_Error('invalid_enum_value',
                            'confirmation_status invalid: ' . (string) $v,
                            array('status' => 400, 'field' => 'confirmation_status'));
                    }
                    $set['confirmation_status'] = (string) $v;
                    break;
                // unknown fields silently ignored (defensive whitelist)
            }
        }
        if (empty($set)) {
            return new WP_Error('invalid_field',
                'no whitelisted field provided',
                array('status' => 400));
        }

        $table  = $wpdb->prefix . 'dinoco_product_makers';
        $obs    = $wpdb->prefix . 'dinoco_maker_product_observations';

        // Atomic TX
        $wpdb->query('START TRANSACTION');
        try {
            // Lock row
            $row = $wpdb->get_row($wpdb->prepare(
                "SELECT * FROM {$table}
                 WHERE BINARY UPPER(product_sku) = UPPER(%s) AND maker_id = %d AND deleted_at IS NULL
                 LIMIT 1 FOR UPDATE",
                $sku, $maker_id
            ), ARRAY_A);

            if (!$row) {
                $wpdb->query('ROLLBACK');
                return new WP_Error('row_not_found',
                    'junction row not found',
                    array('status' => 404));
            }

            $row_id  = (int) $row['id'];
            $old     = array(
                'production_mode'     => $row['production_mode'] ?? null,
                'admin_display_mode'  => $row['admin_display_mode'] ?? null,
                'confirmation_status' => $row['confirmation_status'] ?? null,
            );

            // Auto-flip: cross_factory_assembly → as_parts if display not explicit
            $target_prod_mode = $set['production_mode']    ?? $old['production_mode'];
            $explicit_display = array_key_exists('admin_display_mode', $set);
            if ($target_prod_mode === 'cross_factory_assembly' && !$explicit_display) {
                $set['admin_display_mode'] = 'as_parts';
            }

            // PHP validator (MySQL CHECK constraint is secondary — see CRIT-2)
            $final_prod_mode = $set['production_mode']    ?? $old['production_mode'];
            $final_display   = $set['admin_display_mode'] ?? $old['admin_display_mode'];
            if ($final_prod_mode === 'single' && $final_display === 'as_parts') {
                $wpdb->query('ROLLBACK');
                return new WP_Error(B2F_ERR_CHECK_CONSTRAINT,
                    'production_mode=single cannot pair with admin_display_mode=as_parts',
                    array('status' => 422));
            }

            // Auto-set confirmed_by + confirmed_at on transition → 'confirmed'
            $now = current_time('mysql');
            if (isset($set['confirmation_status']) && $set['confirmation_status'] === 'confirmed'
                && $old['confirmation_status'] !== 'confirmed') {
                $set['confirmed_by'] = $actor_id > 0 ? $actor_id : null;
                $set['confirmed_at'] = $now;
            }
            // Always bump updated_at + updated_by
            $set['updated_by'] = $actor_id > 0 ? $actor_id : null;
            $set['updated_at'] = $now;

            // Build UPDATE
            $upd_parts = array();
            $upd_vals  = array();
            foreach ($set as $col => $val) {
                if ($val === null) {
                    $upd_parts[] = "`{$col}` = NULL";
                } else {
                    $upd_parts[] = "`{$col}` = %s";
                    $upd_vals[] = $val;
                }
            }
            $upd_vals[] = $row_id;
            $sql = "UPDATE {$table} SET " . implode(', ', $upd_parts) . " WHERE id = %d";
            $res = $wpdb->query($wpdb->prepare($sql, $upd_vals));
            if ($res === false) {
                $wpdb->query('ROLLBACK');
                return new WP_Error('db_error',
                    'UPDATE failed: ' . $wpdb->last_error,
                    array('status' => 500));
            }

            // Build new values snapshot
            $new = array(
                'production_mode'     => $set['production_mode']     ?? $old['production_mode'],
                'admin_display_mode'  => $set['admin_display_mode']  ?? $old['admin_display_mode'],
                'confirmation_status' => $set['confirmation_status'] ?? $old['confirmation_status'],
            );

            // Audit: observations table (source='classification_change')
            // Insert one row per changed field for searchability
            $observations_id = 0;
            $obs_exists = (int) $wpdb->get_var($wpdb->prepare(
                "SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES
                 WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s",
                DB_NAME, $obs
            ));
            if ($obs_exists) {
                foreach ($new as $field_name => $new_val) {
                    $old_val = $old[$field_name] ?? null;
                    if ((string) $old_val === (string) $new_val) continue;
                    $wpdb->insert(
                        $obs,
                        array(
                            'observed_at'    => $now,
                            'source'         => 'classification_change',
                            'sku'            => strtoupper($sku),
                            'maker_id'       => $maker_id,
                            'field_name'     => $field_name,
                            'cpt_value'      => (string) ($old_val ?? ''),
                            'junction_value' => (string) ($new_val ?? ''),
                            'diff_detected'  => 1,
                        ),
                        array('%s','%s','%s','%d','%s','%s','%s','%d')
                    );
                    if (!$observations_id) $observations_id = (int) $wpdb->insert_id;
                }
            }

            $wpdb->query('COMMIT');

            // Fire central hook (HIGH-4) — listener invalidates transients
            do_action('b2f_junction_updated', $maker_id);

            return array(
                'success'          => true,
                'row_id'           => $row_id,
                'old'              => $old,
                'new'              => $new,
                'observations_id'  => $observations_id,
            );
        } catch (Exception $e) {
            $wpdb->query('ROLLBACK');
            if (function_exists('b2f_log')) {
                b2f_log('[b2f_junction_update_classification] exception: ' . $e->getMessage());
            }
            return new WP_Error('exception',
                $e->getMessage(),
                array('status' => 500));
        }
    }
}


