                b2f_flex_separator(),
                array('type' => 'text', 'text' => b2f_t('รายการที่ DINOCO ตรวจรับ', 'Items inspected by DINOCO', 'DINOCO 验收项目', $cur), 'size' => 'sm', 'weight' => 'bold', 'color' => B2F_COLOR_NAVY, 'margin' => 'md'),
            ),
            $items_contents,
            array(
                b2f_flex_separator(),
                b2f_flex_kv_row(b2f_t('รับทั้งหมด', 'Received', '已收', $cur), $total_received . (b2f_t(' ชิ้น', ' items', '件', $cur)), B2F_COLOR_GREEN),
            )
        );

        if ($total_rejected > 0) {
            $body_contents[] = b2f_flex_kv_row(b2f_t('Reject', 'Rejected', '拒收', $cur), $total_rejected . (b2f_t(' ชิ้น', ' items', '件', $cur)), B2F_COLOR_RED);
