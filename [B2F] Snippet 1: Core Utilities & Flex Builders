                'type'       => 'box',
                'layout'     => 'vertical',
                'paddingAll' => '12px',
                'spacing'    => 'sm',
                'contents'   => array(
                    b2f_flex_button('ยืนยันวันส่งของ', 'uri', $confirm_url, B2F_COLOR_GREEN),
                    b2f_flex_button('ปฏิเสธ PO', 'uri', $reject_url, B2F_COLOR_RED),
