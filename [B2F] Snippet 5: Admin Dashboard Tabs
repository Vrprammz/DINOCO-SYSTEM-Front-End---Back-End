            draft:'แบบร่าง', submitted:'รอโรงงานยืนยัน', confirmed:'รอผลิต', amended:'แก้ไขใบสั่งซื้อ',
            rejected:'โรงงานปฏิเสธ', delivering:'โรงงานจัดส่ง', received:'รับของครบ', partial_received:'รับบางส่วน',
