        /* ── Submit Payment ── */
        function submitPayment() {
            var amount = parseFloat(document.getElementById('b2f-pay-amount').value);
            var date = document.getElementById('b2f-pay-date').value;
            var method = document.getElementById('b2f-pay-method').value;
            if (!amount || amount <= 0) { toast('กรุณากรอกจำนวนเงิน', 'error'); return; }
            if (!date) { toast('กรุณาเลือกวันที่จ่าย', 'error'); return; }

            var btn = document.getElementById('b2f-pay-submit');
            setLoading(btn, true);

            var fd = new FormData();
            fd.append('po_id', _currentPOId);
            fd.append('amount', amount);
            fd.append('date', date);
            fd.append('method', method);
            fd.append('reference', document.getElementById('b2f-pay-ref').value.trim());
            fd.append('note', document.getElementById('b2f-pay-note').value.trim());
            var slipFile = document.getElementById('b2f-pay-slip').files[0];
            if (slipFile) fd.append('slip_image', slipFile);

            api('POST', 'record-payment', fd, true).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast('บันทึกจ่ายเงินสำเร็จ', 'success');
                    closeModal('b2f-modal-payment');
                    loadStats();
                    loadOrders();
                } else {
                    toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
                }
            }).catch(function() { setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

