        function removePriceItem(sku) {
            delete _pickerSelected[sku];
            // ลบแค่ row นั้น ไม่ render ใหม่ทั้งหน้า (ป้องกันค่าที่กรอกไว้หาย)
            var row = document.getElementById('b2f-price-row-' + sku);
            if (row) row.remove();
            // ถ้าไม่เหลือรายการ → กลับ picker
            if (!Object.keys(_pickerSelected).length) {
                backToPicker();
                toast('ไม่มีรายการที่เลือก', 'info');
            }
        }

        function backToPicker() {
            document.getElementById('b2f-price-form').style.display = 'none';
            document.getElementById('b2f-product-picker').style.display = 'block';
        }

        // ── Submit ทั้งหมด ──
        function submitSelectedProducts() {
            var inputs = document.querySelectorAll('.b2f-price-input');
            var promises = [];
            var hasError = false;

            inputs.forEach(function(inp) {
                var cost = parseFloat(inp.value);
                if (!cost || cost <= 0) { hasError = true; inp.style.borderColor = '#dc2626'; return; }
                inp.style.borderColor = '#d1d5db';

                var sku = inp.dataset.sku;
                var name = inp.dataset.name || '';
                var moqInput = document.querySelector('.b2f-moq-input[data-sku="' + sku + '"]');
                var leadInput = document.querySelector('.b2f-lead-input[data-sku="' + sku + '"]');
                var leadLandInput = document.querySelector('.b2f-lead-land-input[data-sku="' + sku + '"]');
                var leadSeaInput = document.querySelector('.b2f-lead-sea-input[data-sku="' + sku + '"]');
                var shipLandInput = document.querySelector('.b2f-ship-land-input[data-sku="' + sku + '"]');
                var shipSeaInput = document.querySelector('.b2f-ship-sea-input[data-sku="' + sku + '"]');

                promises.push(api('POST', 'maker-product', {
                    mp_maker_id:       _currentMakerId,
                    mp_product_sku:    sku,
                    mp_product_name:   name,
                    mp_unit_cost:      cost,
                    mp_moq:            parseInt(moqInput ? moqInput.value : 1) || 1,
                    mp_lead_time_days: parseInt(leadInput ? leadInput.value : 7) || 7,
                    mp_lead_land:      parseInt(leadLandInput ? leadLandInput.value : 7) || 0,
                    mp_lead_sea:       parseInt(leadSeaInput ? leadSeaInput.value : 14) || 0,
                    mp_shipping_land:  parseFloat(shipLandInput ? shipLandInput.value : 0) || 0,
                    mp_shipping_sea:   parseFloat(shipSeaInput ? shipSeaInput.value : 0) || 0
                }));
            });

            if (hasError) { toast('กรุณากรอกราคาทุนทุกรายการ', 'error'); return; }

            Promise.all(promises).then(function(results) {
                var ok = results.filter(function(r){ return r.success; }).length;
                var fail = results.length - ok;
                if (fail > 0) {
                    toast('บันทึกสำเร็จ ' + ok + ' รายการ, ไม่สำเร็จ ' + fail + ' รายการ', 'warning');
                } else {
                    toast('บันทึก ' + ok + ' รายการสำเร็จ', 'success');
                }
                document.getElementById('b2f-price-form').style.display = 'none';
                _pickerSelected = {};
                loadProducts(_currentMakerId);
            });
        }

        // V.9.2: Quick-add missing leaves for a SET
        // V.7.8 UX-C2: migrate to dinocoModal (fallback to native)
        async function addMissingLeaves(topSku) {
            var meta = _lastHierarchyMeta[topSku];
            if (!meta || !meta.missing_leaves || !meta.missing_leaves.length) {
                toast('ไม่มีสินค้าที่ขาด', 'info');
                return;
            }
            var ok;
            try {
                ok = await window.dinocoModal.confirm({
                    title: 'เพิ่ม SKU ที่ขาด',
                    message: 'เพิ่ม ' + meta.missing_leaves.length + ' SKU ที่ขาด?\n\n' + meta.missing_leaves.join('\n') + '\n\nระบบจะเปิดฟอร์มกรอกราคาทุน',
                    confirmText: 'เพิ่ม SKU',
                    cancelText: 'ยกเลิก'
                });
            } catch (e) { ok = confirm('เพิ่ม ' + meta.missing_leaves.length + ' SKU ที่ขาด?\n\n' + meta.missing_leaves.join('\n') + '\n\nระบบจะเปิดฟอร์มกรอกราคาทุน'); }
            if (!ok) return;

            // Pre-select missing leaves — ใช้ missing_details จาก API (V.9.3: มีชื่อ+รูป)
            _pickerSelected = {};
            var details = meta.missing_details || [];
            meta.missing_leaves.forEach(function(sku, i) {
                var d = details[i] || {};
                _pickerSelected[sku] = { name: d.name || sku, img: d.image_url || '' };
            });

            // Skip picker, go directly to price form
            document.getElementById('b2f-product-picker').style.display = 'none';
            document.getElementById('b2f-price-form').style.display = 'block';
            renderPriceForm();
        }

        // ── Legacy single add (keep for backward compat) ──
        function addProductRow() { openProductPicker(); }

        /* ── Inline Edit: Dirty tracking ── */
        function checkDirty(inp) {
            var isDirty = inp.value !== inp.dataset.original;
            inp.style.borderColor = isDirty ? '#d97706' : '#e2e8f0';
            inp.style.background = isDirty ? '#fffbeb' : '#fff';
            updateDirtyCount();
        }

        function updateDirtyCount() {
            var allInp = document.querySelectorAll('.sku-inp');
            var dirtyPids = new Set();
            allInp.forEach(function(i) {
                if (i.value !== i.dataset.original) {
                    // V.7.2: SET header also counts (.b2f-set-header[data-pid])
                    var row = i.closest('.b2f-sku-row, .b2f-set-header[data-pid]');
                    // V.5.0 DD-3: ข้าม readonly secondary rows
                    if (row && row.getAttribute('data-readonly') !== '1') dirtyPids.add(row.dataset.pid);
                }
            });
            var count = dirtyPids.size;
            var el = document.getElementById('b2f-dirty-count');
            var bar = document.getElementById('b2f-batch-save-bar');
            if (el) { el.textContent = 'แก้ไข: ' + count + ' รายการ'; el.style.display = count ? 'inline' : 'none'; }
            if (bar) bar.style.display = count ? 'flex' : 'none';
            var btn = bar ? bar.querySelector('button') : null;
            if (btn) btn.textContent = '💾 บันทึกทั้งหมด (' + count + ' รายการ)';
        }

        /* ── Quick Shipping Update ── */
        /* V.7.8 UX-C2: migrate to dinocoModal.prompt (fallback to native) */
        async function quickShipping(type) {
            var label = type === 'sea' ? 'ค่าส่ง/เรือ' : 'ค่าส่ง/รถ';
            var val;
            try {
                val = await window.dinocoModal.prompt({
                    title: 'ตั้ง' + label + 'ให้ทุก SKU',
                    message: label + ' ใหม่ (฿) สำหรับทุก SKU:',
                    placeholder: '0.00',
                    required: true,
                    maxLength: 20,
                    confirmText: 'บันทึก',
                    cancelText: 'ยกเลิก'
                });
            } catch (e) { val = prompt(label + ' ใหม่ (฿) สำหรับทุก SKU:'); }
            if (val === null) return;
            var num = parseFloat(val);
            if (isNaN(num) || num < 0) { toast('กรุณากรอกตัวเลข', 'error'); return; }
            var cls = type === 'sea' ? 'shipping_sea' : 'shipping_land';
            document.querySelectorAll('.sku-inp[data-field="' + cls + '"]').forEach(function(inp) {
                inp.value = num;
                checkDirty(inp);
            });
            toast('อัพเดท ' + label + ' ทุก SKU = ฿' + num, 'success');
        }

        /* ── Batch Save ── */
        function batchSaveProducts() {
            // V.7.2: include SET header rows (.b2f-set-header[data-pid]) — SET-level inputs now editable
            var rows = document.querySelectorAll('.b2f-sku-row, .b2f-set-header[data-pid]');
            var promises = [];
            var dedupPids = new Set(); // V.5.0: prevent double-save shared product
            rows.forEach(function(row) {
                // V.5.0 DD-3: skip readonly secondary rows
                if (row.getAttribute('data-readonly') === '1') return;
                var pid = row.dataset.pid;
                if (dedupPids.has(pid)) return; // same product appears in multiple SETs
                dedupPids.add(pid);
                var inputs = row.querySelectorAll('.sku-inp');
                var hasDirty = false;
                inputs.forEach(function(i) { if (i.value !== i.dataset.original) hasDirty = true; });
                if (!hasDirty) return;

                var data = { id: parseInt(pid), mp_maker_id: _currentMakerId };
                var fieldMap = { unit_cost:'mp_unit_cost', moq:'mp_moq', lead_time_days:'mp_lead_time_days',
                                lead_land:'mp_lead_land', lead_sea:'mp_lead_sea',
                                shipping_land:'mp_shipping_land', shipping_sea:'mp_shipping_sea' };
                inputs.forEach(function(i) {
                    var f = i.dataset.field;
                    if (fieldMap[f]) {
                        data[fieldMap[f]] = (f === 'moq' || f.indexOf('lead') === 0) ? (parseInt(i.value)||0) : (parseFloat(i.value)||0);
                    }
                });
                data.mp_product_sku = row.dataset.sku || '';
                data.mp_product_name = row.dataset.name || '';
                promises.push(api('POST', 'maker-product', data));
            });

            if (!promises.length) { toast('ไม่มีรายการที่แก้ไข', 'info'); return; }

            var btn = document.querySelector('#b2f-batch-save-bar button');
            if (btn) { btn.disabled = true; btn.textContent = '💾 กำลังบันทึก...'; }

            Promise.all(promises).then(function(results) {
                var ok = results.filter(function(r){ return r.success; }).length;
                var fail = results.length - ok;
                toast('บันทึก ' + ok + '/' + (ok+fail) + ' รายการ' + (fail ? ' (ล้มเหลว ' + fail + ')' : ''), ok ? 'success' : 'error');
                loadProducts(_currentMakerId);
            }).catch(function() {
                if (btn) { btn.disabled = false; }
                toast('เกิดข้อผิดพลาด', 'error');
            });
        }

        async function deleteProduct(productId, sku) {
            // V.7.8 UX-C2: migrate to dinocoModal (fallback to native)
            var ok;
            try {
                ok = await window.dinocoModal.confirm({
                    title: 'ลบ SKU',
                    message: 'ยืนยันลบ SKU: ' + sku + '?\n\n⚠️ การลบนี้จะลบ product-maker relationship (soft delete)',
                    confirmText: 'ลบ SKU',
                    cancelText: 'ยกเลิก',
                    danger: true
                });
            } catch (e) { ok = confirm('ยืนยันลบ SKU: ' + sku + '?'); }
            if (!ok) return;
            api('POST', 'maker-product/delete', { product_id: productId }).then(function(res) {
                if (res.success) {
                    toast('ลบสำเร็จ', 'success');
                    loadProducts(_currentMakerId);
                } else {
                    toast(res.error || 'ลบไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── Backdrop click ── */
        document.querySelectorAll('#b2f-modal-maker, #b2f-modal-products').forEach(function(bd) {
            bd.addEventListener('click', function(e) { if (e.target === bd) bd.classList.remove('open'); });
        });

        /* ── V.8.1 UX-H3: Event Delegation (replaces inline onclick on static Makers buttons/chips) ──
         * Single delegated click listener. Routes by data-action.
         * Targets: makers-source-chip, makers-picker-type, makers-view-mode, makers-quick-shipping,
         *          makers-open-create-modal, makers-save-settings, makers-submit-maker,
         *          makers-open-bulk-delete, makers-open-blacklist, makers-batch-save,
         *          makers-open-product-picker, makers-close-picker, makers-confirm-picker,
         *          makers-back-to-picker, makers-submit-selected, makers-execute-bulk-delete.
         * Idempotent guard `_b2fMakersDelegationBound`. Calls existing functions — same UX.
         */
        if (!window._b2fMakersDelegationBound) {
            window._b2fMakersDelegationBound = true;
            /* V.8.5 UX-H3 Phase 5: helper for dynamic maker card actions.
             * Reads m.id + m.name + m.currency from .b2f-maker-card[data-mid] ancestor. */
            function _readMakerFromCard(target) {
                var card = target.closest('.b2f-maker-card[data-mid]');
                if (!card) return null;
                var mid = parseInt(card.getAttribute('data-mid') || '0', 10);
                if (!mid) return null;
                return {
                    id: mid,
                    name: card.getAttribute('data-mname') || '',
                    currency: card.getAttribute('data-mcurrency') || 'THB'
                };
            }
            document.addEventListener('click', function(e) {
                var el = e.target.closest('[data-action]');
                if (!el) return;
                var action = el.getAttribute('data-action');
                var arg;
                if (action === 'makers-source-chip') {
                    arg = el.getAttribute('data-src');
                    if (arg) setSourceFilter(arg);
                } else if (action === 'makers-picker-type') {
                    arg = el.getAttribute('data-type');
                    if (arg) setPickerType(arg);
                } else if (action === 'makers-view-mode') {
                    arg = el.getAttribute('data-mode');
                    if (arg && window.B2F_Makers && typeof window.B2F_Makers.setViewMode === 'function') {
                        window.B2F_Makers.setViewMode(arg);
                    }
                } else if (action === 'makers-quick-shipping') {
                    arg = el.getAttribute('data-shipping');
                    if (arg) quickShipping(arg);
                } else if (action === 'makers-open-create-modal') {
                    openCreateModal();
                } else if (action === 'makers-save-settings') {
                    saveSettings();
                } else if (action === 'makers-submit-maker') {
                    submitMaker();
                } else if (action === 'makers-open-bulk-delete') {
                    openBulkDeleteConfirm();
                } else if (action === 'makers-open-blacklist') {
                    openBlacklistViewer();
                } else if (action === 'makers-batch-save') {
                    batchSaveProducts();
                } else if (action === 'makers-open-product-picker') {
                    openProductPicker();
                } else if (action === 'makers-close-picker') {
                    closePicker();
                } else if (action === 'makers-confirm-picker') {
                    confirmPicker();
                } else if (action === 'makers-back-to-picker') {
                    backToPicker();
                } else if (action === 'makers-submit-selected') {
                    submitSelectedProducts();
                } else if (action === 'makers-execute-bulk-delete') {
                    executeBulkDelete();
                /* ── V.8.5 UX-H3 Phase 5: maker card row actions (read m.id/m.name/m.currency from ancestor) ── */
                } else if (action === 'makers-card-edit') {
                    var mk = _readMakerFromCard(el); if (mk) openEdit(mk.id);
                } else if (action === 'makers-card-products') {
                    var mk2 = _readMakerFromCard(el); if (mk2) openProducts(mk2.id, mk2.name, mk2.currency);
                } else if (action === 'makers-card-delete') {
                    var mk3 = _readMakerFromCard(el); if (mk3) deleteMaker(mk3.id, mk3.name);
                /* ── V.8.5 UX-H3 Phase 5: dynamic SKU/SET row + blacklist actions ── */
                } else if (action === 'makers-confirm-all') {
                    var mid = parseInt(el.getAttribute('data-mid') || '0', 10);
                    if (mid) confirmAllUnconfirmed(mid, el);
                } else if (action === 'makers-confirm-sku') {
                    var midC = parseInt(el.getAttribute('data-mid') || '0', 10);
                    var skuC = el.getAttribute('data-sku') || '';
                    if (midC && skuC) confirmSku(midC, skuC, el);
                } else if (action === 'makers-jump-to-primary') {
                    var jumpId = el.getAttribute('data-jump-id') || '';
                    var skuJ = el.getAttribute('data-sku') || '';
                    if (jumpId && skuJ && window.B2F_Makers && typeof window.B2F_Makers.jumpToPrimary === 'function') {
                        window.B2F_Makers.jumpToPrimary(jumpId, skuJ);
                    }
                } else if (action === 'makers-delete-product') {
                    var pid = parseInt(el.getAttribute('data-pid') || '0', 10);
                    var skuD = el.getAttribute('data-sku') || '';
                    if (pid && skuD) deleteProduct(pid, skuD);
                } else if (action === 'makers-add-missing-leaves') {
                    var topSku = el.getAttribute('data-top-sku') || '';
                    if (topSku) addMissingLeaves(topSku);
                } else if (action === 'makers-remove-price-item') {
                    var skuR = el.getAttribute('data-sku') || '';
                    if (skuR) removePriceItem(skuR);
                } else if (action === 'makers-remove-blacklist') {
                    /* Reads from .bl-item[data-mid][data-sku] ancestor (already on row). */
                    var blItem = el.closest('.bl-item[data-mid][data-sku]');
                    if (!blItem) return;
                    var blMid = parseInt(blItem.getAttribute('data-mid') || '0', 10);
                    var blSku = blItem.getAttribute('data-sku') || '';
                    if (blMid && blSku) removeBlacklistEntry(blMid, blSku, el);
                } else if (action === 'modal-close') {
                    /* V.8.3 UX-H3 Phase 3: Handles close buttons inside Makers-owned modals only.
                     * Scoped via .closest('.b2f-modal-backdrop') ID match — prevents cross-module fire.
                     * Behavior preservation: identical to legacy onclick="B2F_Makers.closeModal('id')" (DOM removeClass 'open'). */
                    var target = el.getAttribute('data-modal-target');
                    var ownerBackdrop = el.closest('.b2f-modal-backdrop');
                    var makersIds = ['b2f-modal-maker','b2f-modal-products','b2f-modal-bulk-audit-delete','b2f-modal-blacklist-viewer'];
                    if (target && ownerBackdrop && makersIds.indexOf(ownerBackdrop.id) !== -1 && ownerBackdrop.id === target) {
                        closeModal(target);
                    }
                /* ── V.8.6 UX-H3 Phase 6: SET header accordion expand/collapse ──
                 * Replaces onclick="B2F_Makers.toggleSet('setId',this,event)" inline call.
                 * Defense: bail if click originated inside a `.b2f-set-inputs` wrapper or `.sku-inp`
                 * input — those have their own handlers (inputs should not toggle the accordion).
                 * Also bail when click hits the auto-set delete button (existing legacy guard;
                 * delete button now uses .b2f-auto-set-delete + ev.stopPropagation programmatic). */
                } else if (action === 'makers-toggle-set') {
                    /* If click bubbled up from an interactive child (input/button/inputs wrapper),
                     * do NOT toggle accordion — admin is editing inline fields. */
                    if (e.target && e.target.closest) {
                        if (e.target.closest('.b2f-set-inputs')) return;
                        if (e.target.closest('.sku-inp')) return;
                        if (e.target.closest('.b2f-auto-set-delete')) return;
                    }
                    var setId = el.getAttribute('data-set-id') || '';
                    if (!setId) return;
                    var children = document.getElementById(setId);
                    var icon = document.getElementById(setId + '-icon');
                    if (!children) return;
                    children.classList.toggle('collapsed');
                    if (icon) icon.innerHTML = children.classList.contains('collapsed') ? '&#9654;' : '&#9660;';
                }
            });
        }

        /* ── V.8.6 UX-H3 Phase 6: Makers delegated change + input listeners ──
         * Routes (change): makers-load-makers / makers-toggle-select-all / makers-toggle-picker-item.
         * Routes (input):  makers-debounce-search / makers-filter-picker / makers-check-dirty.
         * Replaces inline onchange/oninput on static filter row + dynamic SKU input rows + picker checkboxes.
         * Idempotent guard `_b2fMakersChangeBound`.
         */
        if (!window._b2fMakersChangeBound) {
            window._b2fMakersChangeBound = true;
            document.addEventListener('change', function(e) {
                var el = e.target;
                if (!el || !el.getAttribute) return;
                var action = el.getAttribute('data-change');
                if (!action) return;
                if (action === 'makers-load-makers') {
                    loadMakers();
                } else if (action === 'makers-toggle-select-all') {
                    toggleSelectAll(!!el.checked);
                } else if (action === 'makers-toggle-picker-item') {
                    /* Picker checkbox: read sku/name/img from data-attrs (set when row rendered).
                     * togglePickerItem(sku, name, img, checkboxEl) — preserved signature. */
                    var sku = el.getAttribute('data-sku') || '';
                    var name = el.getAttribute('data-name') || '';
                    var img = el.getAttribute('data-img') || '';
                    if (sku) togglePickerItem(sku, name, img, el);
                }
            });
            document.addEventListener('input', function(e) {
                var el = e.target;
                if (!el || !el.getAttribute) return;
                var action = el.getAttribute('data-input');
                if (!action) return;
                if (action === 'makers-debounce-search') debounceSearch();
                else if (action === 'makers-filter-picker') filterPicker();
                else if (action === 'makers-check-dirty') checkDirty(el);
            });
        }

        /* ── V.8.6 UX-H3 Phase 6: NOTE on dynamic .b2f-set-inputs[data-stop-prop="1"] ──
         * The SET inputs wrapper now uses data-stop-prop="1" purely as a semantic marker
         * (matches V.8.4 static modal pattern for consistency). Element-level stop is NOT
         * required here because the toggle accordion handler (`makers-toggle-set` above) is
         * document-level delegated — it explicitly bails when click target is inside
         * `.b2f-set-inputs` or `.sku-inp` (defense-in-depth). Element-level stopProp would
         * only affect element-bound ancestor handlers, but no such handlers exist on the
         * SET header anymore (legacy inline onclick removed). Marker kept for future code
         * that might programmatically scan for stop-prop elements.
         */

        function debounceSearch() {
            clearTimeout(_searchTimer);
            _searchTimer = setTimeout(function(){ loadMakers(); }, 400);
        }

        /* ── Init ── */
        function init() { loadMakers(); }

        /* ── Save B2F Settings (shipping destinations) ── */
        function saveSettings() {
            var destLand = document.getElementById('b2f-setting-dest-land').value.trim();
            var destSea  = document.getElementById('b2f-setting-dest-sea').value.trim();
            var btn = document.getElementById('b2f-setting-save');
            setLoading(btn, true);
            api('POST', 'settings', { b2f_shipping_dest_land: destLand, b2f_shipping_dest_sea: destSea }).then(function(res) {
                setLoading(btn, false);
                if (res.success) toast('บันทึกตั้งค่าสำเร็จ', 'success');
                else toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
            }).catch(function(){ setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

        async function deleteMaker(id, name) {
            // V.7.8 UX-C2: migrate to dinocoModal (fallback to native)
            var ok;
            try {
                ok = await window.dinocoModal.confirm({
                    title: 'ลบโรงงาน',
                    message: 'ต้องการลบโรงงาน "' + name + '" จริงหรือไม่?\n\n(จะเปลี่ยนสถานะเป็น Inactive — ไม่สามารถสร้าง PO ใหม่ได้)',
                    confirmText: 'ลบโรงงาน',
                    cancelText: 'ยกเลิก',
                    danger: true
                });
            } catch (e) { ok = confirm('ต้องการลบโรงงาน "' + name + '" จริงหรือไม่?\n\n(จะเปลี่ยนสถานะเป็น Inactive)'); }
            if (!ok) return;
            api('POST', 'maker/delete', { id: id }).then(function(res) {
                if (res.success) {
                    toast('ลบโรงงาน ' + name + ' สำเร็จ', 'success');
                    loadMakers();
                } else {
                    toast(res.error || 'ลบไม่สำเร็จ', 'error');
                }
            }).catch(function(){ toast('เกิดข้อผิดพลาด', 'error'); });
        }

        // ── V.7.1: Classification confirmation helpers (reuse auditApi from V.6.3) ──
        var _rateLimitUntil = 0;

        function confirmSku(makerId, sku, btn) {
            if (Date.now() < _rateLimitUntil) { toast('รอ rate limit หายก่อน', 'error'); return; }
            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'; }
            auditApi('POST', 'junction-confirm-classification', { maker_id: makerId, skus: [sku.toUpperCase()] })
                .then(function(res) {
                    if (res && res.success) {
                        toast('ยืนยัน ' + sku + ' สำเร็จ', 'success');
                        // Remove warning + pill from DOM
                        if (btn) {
                            var row = btn.closest('.b2f-sku-row');
                            if (row) {
                                var warn = row.querySelector('.b2f-confirmation-warning');
                                if (warn) warn.remove();
                                btn.remove();
                            }
                        }
                        // Update banner count
                        var banner = document.getElementById('b2f-confirm-banner-' + makerId);
                        if (banner) {
                            var b = banner.querySelector('b');
                            if (b) {
                                var cnt = parseInt(b.textContent || 0) - 1;
                                if (cnt <= 0) { banner.remove(); }
                                else { b.textContent = cnt; }
                            }
                        }
                    } else {
                        toast(res && res.error || 'ยืนยันไม่สำเร็จ', 'error');
                        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> ยืนยัน'; }
                    }
                }).catch(function(e) {
                    var msg = (e && e.message && e.message.indexOf('429') !== -1) ? 'คำสั่งถี่เกินไป — รอสักครู่' : 'เกิดข้อผิดพลาด';
                    toast(msg, 'error');
                    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> ยืนยัน'; }
                });
        }

        // V.7.9 (Wave 4 MED-M9): idempotency_key — UUID-like key generated on click
        //   prevents double-click from running second transaction. Backend dedups
        //   for 5min via transient (mirror /junction-bulk-update-display pattern).
        function _b2fGenIdemKey() {
            try {
                if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                    return window.crypto.randomUUID();
                }
            } catch (e) {}
            // Fallback: timestamp + random suffix (sufficient for 5min dedup window)
            return 'idem_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 12);
        }

        // V.7.8 UX-C2: migrate to dinocoModal (fallback to native)
        // V.7.9 Wave 4 MED-M9: idempotency_key for double-click safety
        async function confirmAllUnconfirmed(makerId, btn) {
            if (Date.now() < _rateLimitUntil) { toast('รอ rate limit หายก่อน', 'error'); return; }
            // Collect all unconfirmed SKUs from DOM
            var warns = document.querySelectorAll('#b2f-products-list .b2f-confirmation-warning');
            var skus = [];
            warns.forEach(function(w) {
                var row = w.closest('.b2f-sku-row');
                if (row) {
                    var s = row.getAttribute('data-sku');
                    if (s) skus.push(s.toUpperCase());
                }
            });
            if (!skus.length) { toast('ไม่มี SKU ที่ต้องยืนยัน', 'success'); return; }
            var ok;
            try {
                ok = await window.dinocoModal.confirm({
                    title: 'ยืนยัน classification',
                    message: 'ยืนยัน classification ทั้ง ' + skus.length + ' SKU?',
                    confirmText: 'ยืนยันทั้งหมด',
                    cancelText: 'ยกเลิก'
                });
            } catch (e) { ok = confirm('ยืนยัน classification ทั้ง ' + skus.length + ' SKU?'); }
            if (!ok) return;
            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังยืนยัน...'; }
            // V.7.9: Generate idempotency_key on click (UUID v4 preferred, fallback to ts+rand)
            var idemKey = _b2fGenIdemKey();
            auditApi('POST', 'junction-confirm-classification', {
                    maker_id: makerId,
                    skus: skus,
                    idempotency_key: idemKey
                })
                .then(function(res) {
                    if (res && res.success) {
                        var msg = 'ยืนยันทั้งหมด ' + (res.confirmed_count || skus.length) + ' SKU สำเร็จ';
                        if (res.cached) { msg += ' (ใช้ cached result — กดซ้ำ)'; }
                        toast(msg, 'success');
                        // Reload products to reflect changes
                        loadProducts(makerId);
                    } else {
                        toast(res && res.error || 'ยืนยันไม่สำเร็จ', 'error');
                        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check-double"></i> ยืนยันทั้งหมด'; }
                    }
                }).catch(function() {
                    toast('เกิดข้อผิดพลาด', 'error');
                    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check-double"></i> ยืนยันทั้งหมด'; }
                });
        }

        window.B2F_Makers = {
            init: init,
            loadMakers: loadMakers,
            debounceSearch: debounceSearch,
            openCreateModal: openCreateModal,
            openEdit: openEdit,
            submitMaker: submitMaker,
            closeModal: closeModal,
            openProducts: openProducts,
            addProductRow: addProductRow,
            openProductPicker: openProductPicker,
            filterPicker: filterPicker,
            setPickerType: setPickerType, // V.6.0
            togglePickerItem: togglePickerItem,
            closePicker: closePicker,
            confirmPicker: confirmPicker,
            backToPicker: backToPicker,
            removePriceItem: removePriceItem,
            submitSelectedProducts: submitSelectedProducts,
            checkDirty: checkDirty,
            quickShipping: quickShipping,
            batchSaveProducts: batchSaveProducts,
            deleteProduct: deleteProduct,
            addMissingLeaves: addMissingLeaves,
            deleteMaker: deleteMaker,
            saveSettings: saveSettings,
            // V.3.7 Hierarchy: accordion toggle
            // V.6.5: optional `ev` param — ignore click ที่มา จาก .b2f-auto-set-delete (กัน expand/collapse เวลากดปุ่มลบ)
            toggleSet: function(setId, headerEl, ev) {
                if (ev && ev.target) {
                    var t = ev.target;
                    // walk up ~3 levels to check if click originated from delete button
                    for (var i = 0; i < 3 && t; i++) {
                        if (t.classList && t.classList.contains('b2f-auto-set-delete')) return;
                        t = t.parentElement;
                    }
                }
                var children = document.getElementById(setId);
                var icon = document.getElementById(setId + '-icon');
                if (!children) return;
                children.classList.toggle('collapsed');
                if (icon) icon.innerHTML = children.classList.contains('collapsed') ? '&#9654;' : '&#9660;';
            },
            // V.6.3: Option F — source filter + bulk delete + blacklist
            setSourceFilter: setSourceFilter,
            toggleSelectAll: toggleSelectAll,
            openBulkDeleteConfirm: openBulkDeleteConfirm,
            executeBulkDelete: executeBulkDelete,
            openBlacklistViewer: openBlacklistViewer,
            removeBlacklistEntry: removeBlacklistEntry,
            // V.6.4: Auto-synced flat-list mode (expose for debug verification)
            renderAutoFlatList: renderAutoFlatList,
            // V.6.5: Per-SET delete handler (Auto-synced SET accordion headers)
            deleteAutoSet: deleteAutoSet,
            // V.7.1: Classification confirmation
            confirmSku: confirmSku,
            confirmAllUnconfirmed: confirmAllUnconfirmed,
            // V.6.6: View mode toggle (flat vs set) — persist per-user ใน localStorage
            setViewMode: function(mode) {
                if (mode !== 'flat' && mode !== 'set') return;
                if (mode === _viewMode) return; // no-op
                _persistViewMode(mode);
                if (_currentMakerId) loadProducts(_currentMakerId); // re-render
            },
            _version: 'V.7.1',
            // V.5.0 DD-3: Jump to primary SET + highlight the shared product row
            jumpToPrimary: function(setId, sku) {
                var setEl = document.getElementById(setId);
                var headerEl = setEl ? setEl.previousElementSibling : null;
                if (setEl && setEl.classList.contains('collapsed')) {
                    setEl.classList.remove('collapsed');
                    var iconEl = document.getElementById(setId + '-icon');
                    if (iconEl) iconEl.innerHTML = '&#9660;';
                }
                // Find primary row by data-sku matching + not readonly
                var rows = document.querySelectorAll('#b2f-products-list .b2f-sku-row[data-sku="' + sku + '"]');
                var primaryRow = null;
                rows.forEach(function(r) {
                    if (r.getAttribute('data-readonly') !== '1') primaryRow = r;
                });
                if (primaryRow) {
                    primaryRow.scrollIntoView({behavior:'smooth', block:'center'});
                    primaryRow.style.transition = 'background 0.3s';
                    var orig = primaryRow.style.background;
                    primaryRow.style.background = '#fef3c7';
                    setTimeout(function(){ primaryRow.style.background = orig; }, 2000);
                }
            }
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

    })();
    </script>
