        /* ── Bulk Cancel: Execute sequential cancel ── */
        function executeBulkCancel() {
            var reason = document.getElementById('b2f-bulk-cancel-reason').value.trim();
            if (!reason) { toast('กรุณากรอกเหตุผลที่ลบ', 'error'); return; }

            var selected = getSelectedPOs();
            if (!selected.length) { toast('ไม่มี PO ที่เลือก', 'error'); return; }

            var btn = document.getElementById('b2f-bulk-cancel-submit');
            btn.disabled = true;
            btn.innerHTML = '<div class="spinner" style="width:14px;height:14px;border-width:2px;display:inline-block;vertical-align:middle;"></div> กำลังยกเลิก...';

            var progressWrap = document.getElementById('b2f-bulk-progress');
            var progressFill = document.getElementById('b2f-bulk-progress-fill');
            var progressText = document.getElementById('b2f-bulk-progress-text');
            progressWrap.style.display = 'block';
            progressFill.style.width = '0%';

            var total = selected.length;
            var done = 0;
            var successCount = 0;
            var failCount = 0;
            var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;

            function cancelNext() {
                if (done >= total) {
                    // Finish
                    closeModal('b2f-modal-bulk-cancel');
                    // Uncheck all
                    document.querySelectorAll('.b2f-po-checkbox:checked').forEach(function(cb) { cb.checked = false; });
                    updateBulkBar();
                    loadStats();
                    loadOrders();
                    toast('ลบสำเร็จ ' + successCount + '/' + total + ' รายการ' + (failCount > 0 ? ' (ล้มเหลว ' + failCount + ')' : ''), successCount > 0 ? 'success' : 'error');
                    return;
                }

                var po = selected[done];
                progressText.textContent = (done + 1) + ' / ' + total + ' — ' + po.po_number;
                progressFill.style.width = Math.round(((done + 1) / total) * 100) + '%';

                api('POST', 'po-cancel', { po_id: po.id, reason: reason }).then(function(res) {
                    if (res.success) { successCount++; } else { failCount++; }
                    done++;
                    _st(cancelNext, 300);
                }).catch(function() {
                    failCount++;
                    done++;
                    _st(cancelNext, 300);
                });
            }

            cancelNext();
        }

