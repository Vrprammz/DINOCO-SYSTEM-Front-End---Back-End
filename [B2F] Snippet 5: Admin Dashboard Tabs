                    var setId = 'b2f-set-' + topSku.replace(/[^A-Z0-9]/g, '_');

                    // V.9.2: Check hierarchy_meta for missing children
                    var hMeta = hierarchyMeta[topSku];
                    var missingCount = hMeta ? hMeta.missing_leaves.length : 0;
                    var totalLeaves = hMeta ? hMeta.total_leaves : 0;

                    // SET header (แม่) — สีม่วง
                    // V.6.5: data-sku attribute เพื่อให้ applySourceMeta() หา SET header เจอ (Auto badge + delete btn)
                    // V.7.2: เพิ่ม inline inputs (unit_cost / moq / lead_time_days) เพื่อให้ admin แก้ราคา SET ได้
                    //        (ก่อนหน้านี้ไม่มี input → admin ต้องแก้ผ่าน DB หรือ auto-compute เท่านั้น)
                    //        ใช้ data-pid + data-name เพื่อให้ batchSaveProducts() เจอ row นี้
                    var _sp = g.setProduct; // SET's registered product row (may be null if unregistered SET)
                    html += '<div class="b2f-set-group">';
                    var _setHeaderAttrs = 'data-sku="' + esc(g.sku) + '"';
                    if (_sp) {
                        _setHeaderAttrs += ' data-pid="' + _sp.id + '" data-name="' + esc(_sp.product_name || g.name) + '" data-readonly="0"';
                    }
                    html += '<div class="b2f-set-header" ' + _setHeaderAttrs + ' data-action="makers-toggle-set" data-set-id="' + setId + '">';
                    html += '<span class="b2f-set-expand" id="' + setId + '-icon">&#9660;</span>';
                    html += '<div class="b2f-set-title">' + esc(g.name) + ' <span style="font-size:10px;font-weight:400;color:#a78bfa;">' + esc(g.sku) + '</span></div>';
                    html += '<span class="b2f-set-badge">' + totalItems + (totalLeaves > 0 ? ' / ' + totalLeaves : '') + ' ชิ้น</span>';
                    // V.9.2: Warning badge ถ้าลงทะเบียนไม่ครบ
                    if (missingCount > 0) {
                        html += '<span style="display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:600;background:#fef3c7;color:#92400e;margin-left:8px;" title="ยังไม่ได้ลงทะเบียน: ' + esc(hMeta.missing_leaves.join(', ')) + '">';
                        html += '<i class="fa-solid fa-triangle-exclamation"></i> ขาด ' + missingCount + ' SKU</span>';
                    }
                    // V.7.3: SET price = sum(leaves.unit_cost) — read-only display, no input.
                    //         User feedback: SET ต้องเป็น auto sum of children (3500+1500=5000).
                    //         V.7.2 had manual input but that's wrong design — SET is an
                    //         aggregate of its parts, admin edits only leaves.
                    //         Backend: Snippet 2 V.11.3 compute_set_costs_v918 always runs.
                    //         unit_cost_computed flag = true + unit_cost_complete indicates
                    //         all leaves registered. If incomplete (some leaves missing cost)
                    //         show warning — user can edit individual leaves to fix.
                    //         MOQ/lead still editable on SET (these are NOT derivable).
                    if (_sp) {
                        var _isComputed  = !!_sp.unit_cost_computed;
                        var _isComplete  = _isComputed && (_sp.unit_cost_complete !== false);
                        var _leafCount   = parseInt(_sp.unit_cost_leaf_count || 0) || 0;
                        var _displayCost = parseFloat(_sp.unit_cost || 0);
                        var _missingLeaves = Array.isArray(_sp.unit_cost_missing) ? _sp.unit_cost_missing : [];
                        var _setMoq  = String(_sp.moq || 1);
                        var _setLead = String(_sp.lead_time_days || 7);
                        // V.8.6 UX-H3 Phase 6: replace inline onclick stopProp + oninput with delegated patterns.
                        //   - data-input="makers-check-dirty"  → delegated input handler (covers .sku-inp + SET inputs)
                        //   - data-stop-prop="1" on wrapper    → applied via post-render rebind in loadProducts() so
                        //     toggleSet() doesn't fire when admin edits SET MOQ/lead inline.
                        //   Defense-in-depth: makers-toggle-set delegation also bails when click target is inside
                        //   .b2f-set-inputs / .sku-inp (covers any future stopProp gap).
                        var _setInpAttrs = 'data-input="makers-check-dirty"';
                        var _priceDisplay = '฿' + _displayCost.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                        var _priceHint = _isComputed
                            ? (_isComplete ? 'คำนวณจากราคาลูก ' + _leafCount + ' ชิ้น' : 'คำนวณได้บางส่วน — ขาดราคาของ: ' + _missingLeaves.join(', '))
                            : 'ยังไม่มีลูกที่ลงราคา — แก้ราคาลูกเพื่อคำนวณ SET';
                        var _priceBg = _isComputed ? (_isComplete ? '#f0fdf4' : '#fef3c7') : '#fee2e2';
                        var _priceColor = _isComputed ? (_isComplete ? '#166534' : '#92400e') : '#991b1b';
                        var _priceIcon = _isComputed ? (_isComplete ? '&#10003;' : '&#9888;') : '&#9888;';
                        html += '<div class="b2f-set-inputs" data-stop-prop="1" style="display:flex;gap:6px;align-items:center;margin-left:auto;">';
                        html += '<div class="b2f-set-price-ro" title="' + esc(_priceHint) + '" style="padding:6px 10px;border:1px solid ' + _priceColor + ';border-radius:6px;font-size:12px;font-weight:700;background:' + _priceBg + ';color:' + _priceColor + ';white-space:nowrap;display:inline-flex;align-items:center;gap:4px;">' + _priceIcon + ' ' + esc(_priceDisplay) + '</div>';
                        html += '<input class="sku-inp" type="number" data-field="moq" data-original="' + _setMoq + '" value="' + _setMoq + '" min="1" title="MOQ" style="width:50px;padding:6px 8px;border:1px solid #c4b5fd;border-radius:6px;font-size:12px;text-align:center;background:#fff;" ' + _setInpAttrs + '>';
                        html += '<input class="sku-inp" type="number" data-field="lead_time_days" data-original="' + _setLead + '" value="' + _setLead + '" min="1" title="Lead time (days)" style="width:50px;padding:6px 8px;border:1px solid #c4b5fd;border-radius:6px;font-size:12px;text-align:center;background:#fff;" ' + _setInpAttrs + '>';
                        html += '</div>';
                    }
                    html += '</div>';
                    html += '<div class="b2f-set-children" id="' + setId + '">';

                    // V.9.2: Missing leaves info bar (clickable to quick-add)
                    if (missingCount > 0) {
                        html += '<div style="margin:4px 0 8px 0;padding:8px 12px;background:#fffbeb;border:1px solid #fde68a;border-radius:8px;font-size:11px;color:#92400e;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">';
                        html += '<i class="fa-solid fa-info-circle"></i><span>ยังไม่ได้ลงทะเบียน: <b>' + esc(hMeta.missing_leaves.join(', ')) + '</b></span>';
                        html += '<button class="b2f-btn" style="padding:2px 10px;font-size:10px;background:#d97706;color:white;border:none;border-radius:6px;cursor:pointer;" data-action="makers-add-missing-leaves" data-top-sku="' + esc(topSku) + '"><i class="fa-solid fa-plus" style="margin-right:4px;"></i>เพิ่มทั้งหมด</button>';
                        html += '</div>';
                    }

                    // V.4.3: Interleave children + grandchildren — ลูกแต่ละตัว + หลานทันทีใต้ลูก
                    // V.5.0 DD-3: pass topSku สำหรับ primary/secondary detection
                    g.directLeaves.forEach(function(child) {
                        html += renderSkuRow(child, 'b2f-sku-child', topSku);
                        var childSku = (child.sku || '').toUpperCase();
                        var childGc = g.midGroups[childSku];
                        if (childGc) {
                            childGc.items.forEach(function(gc) {
                                html += renderSkuRow(gc, 'b2f-sku-gc', topSku);
                            });
                            childGc._rendered = true;
                        }
                    });

                    Object.keys(g.midGroups).forEach(function(midSku) {
                        var mid = g.midGroups[midSku];
                        if (mid._rendered) return;
                        html += '<div style="margin:6px 0 2px 28px;padding:6px 12px;background:#eff6ff;border-left:3px solid #3b82f6;border-radius:0 8px 8px 0;font-size:12px;font-weight:600;color:#2563eb;">';
                        html += '<i class="fa-solid fa-puzzle-piece" style="margin-right:6px;"></i>' + esc(mid.name) + ' <span style="font-size:9px;font-weight:400;color:#93c5fd;">' + esc(midSku) + '</span>';
                        html += ' <span style="font-weight:400;color:#64748b;">(' + mid.items.length + ' ชิ้น)</span></div>';
                        mid.items.forEach(function(gc) {
                            html += renderSkuRow(gc, 'b2f-sku-gc', topSku);
                        });
                    });

                    html += '</div></div>';
                });

                // Standalone products (ไม่มี parent, ไม่ shared)
                standalone.forEach(function(p) {
                    html += renderSkuRow(p, '', null);
                });
                listEl.innerHTML = html;
                updateDirtyCount();
                // V.6.3: re-apply source badges + checkboxes (if source data already loaded)
                if (_sourceMap && Object.keys(_sourceMap).length) applySourceMeta();
            });
        }

        var _b2bProducts = null;
        var _lastHierarchyMeta = {}; // V.9.2: hierarchy_meta from last loadProducts response
        var _pickerSelected = {};  // { sku: { name, img } }
        var _existingSkus = [];    // SKU ที่เพิ่มในโรงงานนี้แล้ว
        var _pickerTypeFilter = 'all'; // V.6.0: 'all' | 'set' | 'single' | 'child' | 'grandchild'

        // ── Step 1: เปิด Product Picker (grid cards + รูป + checkbox) ──
        function openProductPicker() {
            // เก็บ SKU ที่เพิ่มแล้วจาก products list (uppercase เพื่อ match)
            _existingSkus = [];
            document.querySelectorAll('#b2f-products-list .b2f-sku-row[data-sku]').forEach(function(el) {
                var sk = (el.getAttribute('data-sku') || '').toUpperCase();
                if (sk) _existingSkus.push(sk);
            });
            document.getElementById('b2f-product-picker').style.display = 'block';
            document.getElementById('b2f-price-form').style.display = 'none';
            _pickerSelected = {};
            _pickerTypeFilter = 'all'; // V.6.0: reset chip each open
            syncPickerChipUI();
            updatePickerCount();

            if (_b2bProducts) { renderPickerGrid(_b2bProducts); return; }

            var gridEl = document.getElementById('b2f-picker-grid');
            gridEl.innerHTML = '<div style="text-align:center;padding:20px;color:#9ca3af;grid-column:1/-1;"><div class="spinner"></div><br>กำลังโหลดสินค้า...</div>';

            // V.3.6: เปลี่ยนจาก b2b/v1/products (ถูกลบ V.35.0) → dinoco-stock/v1/stock/list
            var stockUrl = '<?php echo esc_url( rest_url( "dinoco-stock/v1/stock/list" ) ); ?>?per_page=500';
            fetch(stockUrl, { headers: { 'X-WP-Nonce': NONCE } }).then(function(r){ return r.json(); }).then(function(res) {
                // V.4.8: Re-derive product types from sku_relations (JS = source of truth)
                var items = res.data || res.products || res || [];
                var pickerRel = res.sku_relations || {};
                var pickerChildToParents = {};
                Object.keys(pickerRel).forEach(function(pk) {
                    (pickerRel[pk] || []).forEach(function(ck) {
                        var cu = String(ck).toUpperCase();
                        if (!pickerChildToParents[cu]) pickerChildToParents[cu] = [];
                        if (pickerChildToParents[cu].indexOf(pk) === -1) pickerChildToParents[cu].push(pk);
                    });
                });

                // V.6.1: _pickerAllowedRoles — whitelist override values
                var _pickerAllowedRoles = ['set', 'child', 'grandchild', 'single'];
                _b2bProducts = items.map(function(p) {
                    var su = (p.sku || '').toUpperCase();
                    var myChildren = pickerRel[su] || [];
                    var isParent = myChildren.length > 0;
                    var myParents = pickerChildToParents[su] || [];
                    var myParent = myParents[0] || null;
                    var isLeaf = !isParent;

                    var autoType;
                    if (myParent && isLeaf) autoType = 'grandchild';
                    else if (myParent && isParent) autoType = 'child';
                    else if (isParent) autoType = 'set';
                    else autoType = 'single';

                    // V.6.1: respect ui_role_override — display type = override (badge + picker filter)
                    var ovr = String(p.ui_role_override || 'auto').toLowerCase();
                    var displayType = (_pickerAllowedRoles.indexOf(ovr) !== -1 && ovr !== autoType) ? ovr : autoType;
                    var isOverride = (displayType !== autoType);

                    var gpSku = '';
                    if (myParent) {
                        var gpCandidates = pickerChildToParents[String(myParent).toUpperCase()] || [];
                        gpSku = gpCandidates[0] || '';
                    }

                    return {
                        product_sku: p.sku || '',
                        product_name: p.name || p.product_name || '',
                        sku: p.sku || '',
                        name: p.name || p.product_name || '',
                        image_url: p.image_url || '',
                        product_type: displayType,  // V.6.1: display type (respect override)
                        auto_type: autoType,         // V.6.1: preserve hierarchy truth (for grouping if needed)
                        is_override: isOverride,
                        is_set: isParent,
                        is_leaf: isLeaf,
                        children_count: myChildren.length,
                        parent_sku: myParent || '',
                        grandparent_sku: gpSku,
                    };
                });
                renderPickerGrid(_b2bProducts);
            }).catch(function(err) {
                console.error('Product picker load error:', err);
                gridEl.innerHTML = '<div style="text-align:center;padding:20px;color:#dc2626;grid-column:1/-1;">โหลดสินค้าไม่สำเร็จ</div>';
            });
        }

        // V.6.0: Render picker grid — รองรับ filter chips ทั้งหมด/ชุด SET/เดี่ยว/ลูกชิ้นส่วน/ชิ้นส่วนย่อย
        //        + count badges + hide empty chips + labels + colors ตรงกับ Inventory V.43.6
        function renderPickerGrid(products) {
            var gridEl = document.getElementById('b2f-picker-grid');
            var search = (document.getElementById('b2f-picker-search').value || '').toLowerCase();

            // Base pool — apply search + hide-registered + hide-descendant-of-registered
            // (ยังไม่ filter ตาม type เพื่อให้ count ถูกต้องสำหรับ chips)
            var basePool = products.filter(function(p) {
                var sku = (p.sku || '').toUpperCase();

                // 1. ตัด SKU ที่เพิ่มแล้ว
                if (_existingSkus.indexOf(sku) !== -1) return false;

                // 2. ตัด descendant ของ SKU ที่เพิ่มแล้ว (parent หรือ grandparent ใน list)
                if (p.parent_sku && _existingSkus.indexOf(p.parent_sku) !== -1) return false;
                if (p.grandparent_sku && _existingSkus.indexOf(p.grandparent_sku) !== -1) return false;

                // 3. Search filter
                if (!search) return true;
                var skuLow = sku.toLowerCase();
                var name = (p.product_name || p.name || '').toLowerCase();
                return skuLow.indexOf(search) !== -1 || name.indexOf(search) !== -1;
            });

            // V.6.0: นับ count per type จาก basePool (ก่อน type filter) — ใช้อัพเดท chips
            var counts = { all: 0, set: 0, single: 0, child: 0, grandchild: 0 };
            basePool.forEach(function(p) {
                counts.all++;
                var t = p.product_type || 'single';
                if (counts[t] !== undefined) counts[t]++;
            });
            updatePickerChipCounts(counts);

            // V.6.0: type filter (_pickerTypeFilter) — ถ้า 'all' ไม่ filter
            var filtered = basePool.filter(function(p) {
                if (_pickerTypeFilter === 'all') return true;
                return (p.product_type || 'single') === _pickerTypeFilter;
            });

            // V.6.0: Sort ตาม Inventory: set → single → child → grandchild
            var typeOrder = { set: 0, single: 1, child: 2, grandchild: 3 };
            filtered.sort(function(a, b) {
                var ta = typeOrder[a.product_type] !== undefined ? typeOrder[a.product_type] : 1;
                var tb = typeOrder[b.product_type] !== undefined ? typeOrder[b.product_type] : 1;
                if (ta !== tb) return ta - tb;
                return (a.sku || '').localeCompare(b.sku || '');
            });

            if (!filtered.length) {
                var emptyMsg = _pickerTypeFilter === 'all'
                    ? (search ? 'ไม่พบสินค้าที่ค้นหา' : 'ไม่มีสินค้าให้เลือก (ทุก SKU ถูกเพิ่มแล้ว)')
                    : 'ไม่มีสินค้าประเภทนี้';
                gridEl.innerHTML = '<div style="text-align:center;padding:20px;color:#9ca3af;grid-column:1/-1;">' + emptyMsg + '</div>';
                return;
            }

            var html = '';
            filtered.forEach(function(p) {
                var sku = p.product_sku || p.sku || '';
                var name = p.title || p.product_name || p.name || sku;
                var img = p.img || p.image_url || p.thumbnail || '';
                var isChecked = _pickerSelected[sku] ? 'checked' : '';
                var borderStyle = _pickerSelected[sku] ? 'border-color:#d97706;background:#fffbeb;' : '';

                // V.6.0: type-based tint (subtle purple/blue/green/gray)
                var ptype = p.product_type || 'single';
                var typeStyle = '';
                if (ptype === 'set') typeStyle = 'border-color:#c4b5fd;background:#faf8ff;';
                else if (ptype === 'child') typeStyle = 'border-color:#bfdbfe;';
                else if (ptype === 'grandchild') typeStyle = 'border-color:#a7f3d0;';

                html += '<label class="b2f-picker-card" style="display:flex;flex-direction:column;border:1px solid #e5e7eb;border-radius:8px;padding:8px;cursor:pointer;transition:all 0.2s;' + typeStyle + borderStyle + '" data-sku="' + esc(sku) + '" data-ptype="' + esc(ptype) + '">';
                if (img) {
                    html += '<img src="' + esc(img) + '" style="width:100%;height:80px;object-fit:contain;border-radius:6px;margin-bottom:6px;background:#f9fafb;" onerror="this.style.display=\'none\'">';
                } else {
                    html += '<div style="width:100%;height:80px;display:flex;align-items:center;justify-content:center;background:#f3f4f6;border-radius:6px;margin-bottom:6px;color:#9ca3af;font-size:24px;"><i class="fa-solid fa-box"></i></div>';
                }
                html += '<div style="display:flex;align-items:flex-start;gap:6px;">';
                html += '<input type="checkbox" ' + isChecked + ' data-change="makers-toggle-picker-item" data-sku="' + esc(sku) + '" data-name="' + esc(name) + '" data-img="' + esc(img) + '" style="margin-top:2px;flex-shrink:0;width:16px;height:16px;">';
                html += '<div style="min-width:0;">';

                // V.6.0: Type badge — labels + colors ตรง Inventory ("ชุด SET"/"ชิ้นส่วน"/"ชิ้นส่วนย่อย"/"เดี่ยว")
                var badgeHtml = '';
                if (ptype === 'set')             badgeHtml = '<span class="b2f-pf-badge type-set"><i class="fa-solid fa-boxes-stacked"></i> ชุด SET</span>';
                else if (ptype === 'child')      badgeHtml = '<span class="b2f-pf-badge type-child"><i class="fa-solid fa-puzzle-piece"></i> ชิ้นส่วน</span>';
                else if (ptype === 'grandchild') badgeHtml = '<span class="b2f-pf-badge type-grandchild"><i class="fa-solid fa-gear"></i> ชิ้นส่วนย่อย</span>';
                else                              badgeHtml = '<span class="b2f-pf-badge type-single"><i class="fa-solid fa-cube"></i> เดี่ยว</span>';

                html += '<div style="font-size:11px;font-weight:600;color:#374151;word-break:break-all;">' + badgeHtml + esc(sku) + '</div>';
                html += '<div style="font-size:10px;color:#6b7280;word-break:break-word;line-height:1.3;">' + esc(name) + '</div>';
                html += '</div></div></label>';
            });
            gridEl.innerHTML = html;
        }

        // V.6.0: update count badges + hide empty chips (keep 'all' always visible)
        function updatePickerChipCounts(counts) {
            var map = { all: 'b2f-pf-count-all', set: 'b2f-pf-count-set', single: 'b2f-pf-count-single', child: 'b2f-pf-count-child', grandchild: 'b2f-pf-count-grandchild' };
            Object.keys(map).forEach(function(k) {
                var el = document.getElementById(map[k]);
                if (el) el.textContent = counts[k] || 0;
                var chip = document.querySelector('#b2f-picker-filter-bar .b2f-pf-chip[data-type="' + k + '"]');
                if (chip) {
                    if (k === 'all') { chip.classList.remove('is-hidden'); return; }
                    // ซ่อน chip ถ้า count = 0 (ยกเว้น chip ที่ active ต้องแสดงเสมอเพื่อให้ user กดกลับ)
                    if ((counts[k] || 0) === 0 && _pickerTypeFilter !== k) chip.classList.add('is-hidden');
                    else chip.classList.remove('is-hidden');
                }
            });
        }

        // V.6.0: sync active state ของ chips ตาม _pickerTypeFilter
        function syncPickerChipUI() {
            var chips = document.querySelectorAll('#b2f-picker-filter-bar .b2f-pf-chip');
            chips.forEach(function(c) {
                if (c.getAttribute('data-type') === _pickerTypeFilter) c.classList.add('active');
                else c.classList.remove('active');
            });
        }

        // V.6.0: handler สำหรับ chip click
        function setPickerType(type) {
            _pickerTypeFilter = type || 'all';
            syncPickerChipUI();
            if (_b2bProducts) renderPickerGrid(_b2bProducts);
        }

        function filterPicker() { if (_b2bProducts) renderPickerGrid(_b2bProducts); }

        function togglePickerItem(sku, name, img, checkbox) {
            if (checkbox.checked) {
                _pickerSelected[sku] = { name: name, img: img };
            } else {
                delete _pickerSelected[sku];
            }

            // V.9.2: Auto-expand SET — เมื่อเลือก SET parent → auto-select leaf ทุกตัวด้วย
            if (checkbox.checked && _b2bProducts) {
                var matched = _b2bProducts.find(function(p) { return (p.product_sku || p.sku || '') === sku; });
                if (matched && (matched.is_set || matched.product_type === 'set')) {
                    // หา leaf children จาก _b2bProducts (child/grandchild ที่มี top_parent = sku นี้)
                    // แต่ _b2bProducts จาก stock/list ไม่มี top_parent_sku → ใช้วิธีอื่น
                    // ใช้ product_type: หา child/grandchild ที่ parent_sku หรือ grandparent_sku = sku
                    // stock/list ไม่ return parent_sku → fallback: toast แจ้ง admin ให้เพิ่มลูกเอง
                    toast('เลือกชุด "' + (name || sku) + '" แล้ว — กรุณาเลือกชิ้นส่วนย่อยด้วย (ถ้ามี)', 'info');
                }
            }

            updatePickerCount();
            // Update card style
            var card = checkbox.closest('.b2f-picker-card');
            if (card) {
                card.style.borderColor = checkbox.checked ? '#d97706' : '#e5e7eb';
                card.style.background = checkbox.checked ? '#fffbeb' : '';
            }
        }

        function updatePickerCount() {
            var el = document.getElementById('b2f-picker-count');
            if (el) el.textContent = Object.keys(_pickerSelected).length;
        }

        function closePicker() {
            document.getElementById('b2f-product-picker').style.display = 'none';
