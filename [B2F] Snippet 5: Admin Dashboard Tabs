        }

        /* ── Backdrop click to close ── */
        document.querySelectorAll('.b2f-modal-backdrop').forEach(function(bd) {
            bd.addEventListener('click', function(e) {
                if (e.target === bd) bd.classList.remove('open');
            });
        });
        /* ── V.8.4 UX-H3 Phase 4: Static stopPropagation initializer ──
         * Replaces inline onclick="event.stopPropagation()" on static modal containers
         * (11 sites across Orders/Makers/Credit) with element-level click handler. Required
         * because static modal content needs to stop bubble-phase clicks BEFORE the backdrop
         * handler above runs (otherwise backdrop check `e.target === bd` would still fail
         * when click target is a button inside modal — but defense-in-depth keeps existing
         * semantics for nested handlers/3rd-party listeners). Idempotent guard scoped per
         * page-load. Element-level (not document-delegated) because document-level capture
         * would prevent ALL nested click handlers from firing. */
        if (!window._b2fStopPropBound) {
            window._b2fStopPropBound = true;
            document.querySelectorAll('[data-stop-prop="1"]').forEach(function(el) {
                el.addEventListener('click', function(e) { e.stopPropagation(); });
            });
        }
        /* ── N6/M8 — Audit fix: ESC closes top modal, bound once per page load ── */
        if (!window._b2fEscBound) {
            window._b2fEscBound = true;
            document.addEventListener('keydown', function(e) {
                if (e.key !== 'Escape' && e.keyCode !== 27) return;
                var opens = document.querySelectorAll('.b2f-modal-backdrop.open');
                if (!opens.length) return;
                opens[opens.length - 1].classList.remove('open');
            });
        }

        /* ── V.8.1 UX-H3: Event Delegation (replaces inline onclick on static chips/tabs/KPI) ──
         * Single click listener on document — routes by data-action.
         * Targets: orders-filter-tab (status tabs + KPI cards) + orders-mode-chip.
         * Behavior preservation: calls existing filterByTab/setModeFilter — same UX, no inline JS.
         * Idempotent guard prevents double-binding when shortcode rendered multiple times.
         */
        if (!window._b2fOrdersDelegationBound) {
            window._b2fOrdersDelegationBound = true;
            /* V.8.4 UX-H3 Phase 4: Function whitelist for orders-close-and-call delegation.
             * Compound onclick="closeModal(...);B2F_Orders.fn(args)" sites in detail modal action buttons
             * (8 sites: editPO/resubmitPO/openReceive/openPayment/rejectLot/completePO/cancelPO/reorderPO)
             * are delegated via data-fn + data-args (JSON-encoded). Whitelist prevents arbitrary fn dispatch.
             * Args parsed via JSON.parse → safe for Thai/special chars. closeModal runs FIRST then dispatches fn,
             * preserving exact legacy behavior. */
            var _ORDERS_CLOSE_AND_CALL_FNS = {
                editPO: 1, resubmitPO: 1, openReceive: 1, openPayment: 1,
                rejectLot: 1, completePO: 1, cancelPO: 1, reorderPO: 1
            };
            /* V.8.5 UX-H3 Phase 5: helper for dynamic PO card actions.
             * Reads po.id + po.po_number from .b2f-po-card[data-po-id][data-po-number] ancestor.
             * Avoids inline JS encoding of Thai PO numbers + replace(/'/g,"\\'") escapes. */
            function _readPoFromCard(target) {
                var card = target.closest('.b2f-po-card[data-po-id]');
                if (!card) return null;
                var poId = parseInt(card.getAttribute('data-po-id') || '0', 10);
                if (!poId) return null;
                return { id: poId, number: card.getAttribute('data-po-number') || '' };
            }
            document.addEventListener('click', function(e) {
                var el = e.target.closest('[data-action]');
                if (!el) return;
                var action = el.getAttribute('data-action');
                if (action === 'orders-filter-tab') {
                    var status = el.getAttribute('data-status');
                    if (status) filterByTab(status);
                } else if (action === 'orders-mode-chip') {
                    var mode = el.getAttribute('data-mode');
                    if (mode) setModeFilter(mode);
                } else if (action === 'orders-close-and-call') {
                    /* V.8.4 UX-H3 Phase 4: closeModal(target) then dispatch B2F_Orders.fn(args).
                     * Whitelist gate prevents dispatching arbitrary functions. JSON parse failure → silently abort. */
                    var modalTarget = el.getAttribute('data-modal-target');
                    var fnName = el.getAttribute('data-fn');
                    var argsJson = el.getAttribute('data-args');
                    if (!modalTarget || !fnName || !_ORDERS_CLOSE_AND_CALL_FNS[fnName]) return;
                    var args;
                    try { args = argsJson ? JSON.parse(argsJson) : []; } catch (err) { return; }
                    if (!Array.isArray(args)) return;
                    closeModal(modalTarget);
                    var fn = window.B2F_Orders && window.B2F_Orders[fnName];
                    if (typeof fn === 'function') {
                        try { fn.apply(window.B2F_Orders, args); } catch (err2) { /* swallow — fn-level err handling owns this */ }
                    }
                /* ── V.8.5 UX-H3 Phase 5: static page-level buttons ── */
                } else if (action === 'orders-open-create-modal') {
                    openModal('b2f-modal-create-po');
                } else if (action === 'orders-bulk-select-all') {
                    bulkSelectAll();
                } else if (action === 'orders-open-bulk-cancel-modal') {
                    openBulkCancelModal();
                } else if (action === 'orders-submit-create-po') {
                    submitCreatePO();
                } else if (action === 'orders-submit-receive') {
                    submitReceive();
                } else if (action === 'orders-submit-payment') {
                    submitPayment();
                } else if (action === 'orders-execute-bulk-cancel') {
                    executeBulkCancel();
                } else if (action === 'orders-page') {
                    var page = parseInt(el.getAttribute('data-page') || '0', 10);
                    if (page > 0) goPage(page);
                } else if (action === 'orders-adjust-qty') {
                    var delta = parseInt(el.getAttribute('data-delta') || '0', 10);
                    if (delta) adjustQty(el, delta);
                /* ── V.8.5 UX-H3 Phase 5: PO card row actions (read po.id/po.number from card ancestor) ── */
                } else if (action === 'orders-go-to-ticket') {
                    /* Outer card click — only fires if user clicked NOT on a child data-action element
                     * (closest('[data-action]') walks UP from target, child action wins automatically). */
                    var poId = parseInt(el.getAttribute('data-po-id') || '0', 10);
                    if (poId) goToTicket(poId);
                } else if (action === 'orders-card-checkbox') {
                    /* Checkbox click — change event still fires natively, just ensure card click skipped. */
                    updateBulkBar();
                } else if (action === 'orders-stop-prop-noop') {
                    /* No-op handler on .b2f-po-actions wrapper — just ensures clicks on padding/gap
                     * don't bubble up to outer card's orders-go-to-ticket handler. */
                    return;
                } else if (action === 'orders-card-detail') {
                    var p = _readPoFromCard(el); if (p) openDetail(p.id);
                } else if (action === 'orders-card-cancel') {
                    var p2 = _readPoFromCard(el); if (p2) cancelPO(p2.id, p2.number);
                } else if (action === 'orders-card-edit') {
                    var p3 = _readPoFromCard(el); if (p3) editPO(p3.id);
                } else if (action === 'orders-card-resubmit') {
                    var p4 = _readPoFromCard(el); if (p4) resubmitPO(p4.id, p4.number);
                } else if (action === 'orders-card-receive') {
                    var p5 = _readPoFromCard(el); if (p5) openReceive(p5.id);
                } else if (action === 'orders-card-reject-lot') {
                    var p6 = _readPoFromCard(el); if (p6) rejectLot(p6.id, p6.number);
                } else if (action === 'orders-card-pay') {
                    var p7 = _readPoFromCard(el); if (p7) openPayment(p7.id);
                } else if (action === 'orders-card-complete') {
                    var p8 = _readPoFromCard(el); if (p8) completePO(p8.id, p8.number);
                } else if (action === 'orders-card-reorder') {
                    var p9 = _readPoFromCard(el); if (p9) reorderPO(p9.id);
                } else if (action === 'modal-close') {
                    /* V.8.3 UX-H3 Phase 3: Handles close buttons inside ANY modal owned by this module.
                     * Scoped via .closest('.b2f-modal-backdrop') ID match — only fires for Orders modals.
                     * Behavior preservation: identical to legacy onclick="B2F_Orders.closeModal('id')" (DOM removeClass 'open'). */
                    var target = el.getAttribute('data-modal-target');
                    var ownerBackdrop = el.closest('.b2f-modal-backdrop');
                    var ordersIds = ['b2f-modal-create-po','b2f-modal-receive','b2f-modal-payment','b2f-modal-detail','b2f-modal-bulk-cancel'];
                    if (target && ownerBackdrop && ordersIds.indexOf(ownerBackdrop.id) !== -1 && ownerBackdrop.id === target) {
                        closeModal(target);
                    }
                }
            });
        }

        /* ── V.8.6 UX-H3 Phase 6: delegated change + input listeners (replaces inline onchange/oninput) ──
         * Routes: orders-apply-filters / orders-load-maker-products / orders-recalc-total /
         *         orders-debounce-search.
         * Scoped to elements with data-change=* (change event) or data-input=* (input event).
         * Idempotent guard `_b2fOrdersChangeBound`.
         */
        if (!window._b2fOrdersChangeBound) {
            window._b2fOrdersChangeBound = true;
            document.addEventListener('change', function(e) {
                var el = e.target;
                if (!el || !el.getAttribute) return;
                var action = el.getAttribute('data-change');
                if (!action) return;
                if (action === 'orders-apply-filters') applyFilters();
                else if (action === 'orders-load-maker-products') loadMakerProducts();
                else if (action === 'orders-recalc-total') recalcTotal();
            });
            document.addEventListener('input', function(e) {
                var el = e.target;
                if (!el || !el.getAttribute) return;
                var action = el.getAttribute('data-input');
                if (!action) return;
                if (action === 'orders-recalc-total') recalcTotal();
                else if (action === 'orders-debounce-search') debounceSearch();
            });
        }

        /* ── Init ── */
        function init() {
            loadMakers();
            loadStats();
            loadOrders();
            startRefresh();
        }

        /* ── Go to PO Ticket View (LIFF or browser) ── */
        function goToTicket(poId) {
            var url = TICKET_BASE + '?po_id=' + poId;
            window.open(url, '_blank');
        }

        /* ── Public API ── */
        window.B2F_Orders = {
            goToTicket: goToTicket,
            init: init,
            filterByTab: filterByTab,
            applyFilters: applyFilters,
            debounceSearch: debounceSearch,
            goPage: goPage,
            openCreateModal: function(){ openModal('b2f-modal-create-po'); },
            closeModal: closeModal,
            loadMakerProducts: loadMakerProducts,
            adjustQty: adjustQty,
            recalcTotal: recalcTotal,
            submitCreatePO: submitCreatePO,
            openReceive: openReceive,
            submitReceive: submitReceive,
            openPayment: openPayment,
            submitPayment: submitPayment,
            openDetail: openDetail,
            cancelPO: cancelPO,
            reorderPO: reorderPO,
            editPO: editPO,
            resubmitPO: resubmitPO,
            rejectLot: rejectLot,
            completePO: completePO,
            updateBulkBar: updateBulkBar,
            bulkSelectAll: bulkSelectAll,
            openBulkCancelModal: openBulkCancelModal,
            executeBulkCancel: executeBulkCancel,
            setModeFilter: setModeFilter
        };

        // Auto-init when visible
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

    })();
    /* V.7.5 Phase 3 Group H — UX-H7 + UX-H8: ESC-to-close + focus trap (shared helper, idempotent) */
    (function dinocoModalA11y(){
      if (window.__dncModalA11y) return; window.__dncModalA11y=true;
      function isVisible(el){return !!(el && el.offsetParent !== null);}
      function getOpenModal(){
        var sels=['.b2f-modal-backdrop.open','.b2b-bo-modal-backdrop.show','.b2b-cat-modal.show','.b2b-cat-modal.open','.b2f-cat-modal.show','.b2f-cat-modal.open','.liff-ai-modal.open','.b2b-modal.open','.b2f-modal.open','[data-open="1"]'];
        for(var i=0;i<sels.length;i++){var m=document.querySelector(sels[i]); if(isVisible(m)) return m;}
        return null;
      }
      document.addEventListener('keydown',function(e){
        if(e.key!=='Escape' && e.key!=='Esc') return;
        var m=getOpenModal(); if(!m) return;
        var closer=m.querySelector('[data-modal-close],.modal-close,.cat-close,.close-x,.b2b-cat-modal-close,.b2f-cat-modal-close,.cpay-close,.liff-ai-chat-close,.b2f-modal-close,.b2b-bo-modal .close');
        if(closer){try{closer.click();}catch(err){} return;}
        m.classList.remove('open'); m.classList.remove('show'); m.removeAttribute('data-open');
      });
      document.addEventListener('keydown',function(e){
        if(e.key!=='Tab') return;
        var m=getOpenModal(); if(!m) return;
        var nodes=m.querySelectorAll('a[href],button:not([disabled]),input:not([disabled]),select:not([disabled]),textarea:not([disabled]),[tabindex]:not([tabindex="-1"])');
        var focusable=[]; for(var i=0;i<nodes.length;i++){ if(isVisible(nodes[i])) focusable.push(nodes[i]); }
        if(!focusable.length) return;
        var first=focusable[0], last=focusable[focusable.length-1];
        if(e.shiftKey && document.activeElement===first){e.preventDefault(); last.focus();}
        else if(!e.shiftKey && document.activeElement===last){e.preventDefault(); first.focus();}
      });
    })();
