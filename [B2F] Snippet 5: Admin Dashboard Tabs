                document.getElementById('b2f-maker-email').value = m.email || '';
                document.getElementById('b2f-maker-address').value = m.address || '';
                document.getElementById('b2f-maker-tax-id').value = m.tax_id || '';
                document.getElementById('b2f-maker-bank-name').value = m.bank_name || '';
                document.getElementById('b2f-maker-bank-account').value = m.bank_account || '';
                document.getElementById('b2f-maker-bank-holder').value = m.bank_holder || '';
                document.getElementById('b2f-maker-credit-limit').value = m.credit_limit || 0;
