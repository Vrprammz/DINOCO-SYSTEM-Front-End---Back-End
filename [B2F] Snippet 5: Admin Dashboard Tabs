    <script>
    (function(){
        'use strict';

        var API_BASE    = '<?php echo esc_url( rest_url( 'b2f/v1/' ) ); ?>';
        var NONCE       = '<?php echo $nonce; ?>';
        var TICKET_BASE = '<?php echo esc_url( $ticket_base ); ?>';
        var PER_PAGE = 20;
        var _searchTimer = null;
        var _refreshTimer = null;
        var _currentPage = 1;
        var _currentTab  = 'all';
        var _currentPOId = null;
        var _allMakers = [];
        var _createMakerCurrency = 'THB';
        var _createMakerCurrencySymbol = '\u0E3F';
        var _createMakerProducts = [];  // products loaded for current maker
        var _modeFilter = 'all';  // V.7.1: order mode filter (all/full_set/sub_unit/single_leaf/legacy)

        /* ── Status label map ── */
        var STATUS_LABELS = {
            draft:'แบบร่าง', submitted:'รอโรงงานยืนยัน', confirmed:'รอผลิต', amended:'แก้ไขใบสั่งซื้อ',
            rejected:'โรงงานปฏิเสธ', delivering:'โรงงานจัดส่ง', received:'รับของครบ', partial_received:'รับบางส่วน',
            paid:'ชำระครบ', partial_paid:'ชำระบางส่วน', completed:'ปิดใบสั่งซื้อ', cancelled:'ยกเลิก'
        };
        var STATUS_BADGE = {
            draft:'b2f-badge-gray', submitted:'b2f-badge-blue', confirmed:'b2f-badge-teal', amended:'b2f-badge-purple',
            rejected:'b2f-badge-red', delivering:'b2f-badge-cyan', received:'b2f-badge-emerald', partial_received:'b2f-badge-amber',
            paid:'b2f-badge-green', partial_paid:'b2f-badge-amber', completed:'b2f-badge-slate', cancelled:'b2f-badge-red'
        };

        /* ── API helper ── */
        function api(method, endpoint, body, isFormData) {
            var opts = { method: method, headers: { 'X-WP-Nonce': NONCE } };
            if (body) {
                if (isFormData) {
                    opts.body = body;
                } else {
                    opts.headers['Content-Type'] = 'application/json';
                    opts.body = JSON.stringify(body);
                }
            }
            return fetch(API_BASE + endpoint, opts).then(function(r){
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            });
        }

        function fmt(n) {
            return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n || 0);
        }

        function fmtDate(d) {
            if (!d) return '-';
            var dt = new Date(d);
            return dt.toLocaleDateString('th-TH', { day:'2-digit', month:'2-digit', year:'numeric' });
        }

        function toast(msg, type) {
            var el = document.getElementById('b2f-toast');
            el.textContent = msg;
            el.className = 'b2f-toast ' + (type || 'info') + ' show';
            var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
            _st(function(){ el.classList.remove('show'); }, 3500);
        }

        function setLoading(btn, loading) {
            if (!btn) return;
            if (loading) {
                btn.disabled = true;
                btn.dataset.origText = btn.innerHTML;
                btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;"></div> กำลังดำเนินการ...';
            } else {
                btn.disabled = false;
                btn.innerHTML = btn.dataset.origText || btn.innerHTML;
            }
        }

        /* ── Load Makers dropdown ── */
        function loadMakers() {
            api('GET', 'makers').then(function(res) {
                if (!res.success) return;
                _allMakers = res.data || [];
                var filterSel = document.getElementById('b2f-filter-maker');
                var createSel = document.getElementById('b2f-create-maker');
                var html = '<option value="">ทุกโรงงาน</option>';
                var html2 = '<option value="">-- เลือกโรงงาน --</option>';
                _allMakers.forEach(function(m) {
                    if (m.status !== 'active') return;
                    html  += '<option value="' + m.id + '">' + esc(m.name) + '</option>';
                    html2 += '<option value="' + m.id + '">' + esc(m.name) + '</option>';
                });
                if (filterSel) filterSel.innerHTML = html;
                if (createSel) createSel.innerHTML = html2;
            });
        }

        function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML.replace(/'/g,"&#39;").replace(/"/g,"&quot;"); }

        /* ── Load KPI stats ── */
        function loadStats() {
            api('GET', 'dashboard-stats').then(function(res) {
                if (!res.success && !res.pending_confirm) return;
                var d = res.success ? res.data : res;
                setText('b2f-kpi-pending', d.pending_confirm || 0);
                setText('b2f-kpi-confirmed', d.confirmed || 0);
                setText('b2f-kpi-overdue', d.overdue || 0);
                setText('b2f-kpi-payable', '\u0E3F' + fmt(d.total_payable));
            });
        }

        function setText(id, v) { var el = document.getElementById(id); if (el) el.textContent = v; }

        /* ── Load PO list ── */
        function loadOrders() {
            var params = 'page=' + _currentPage + '&per_page=' + PER_PAGE;
            if (_currentTab && _currentTab !== 'all') {
                if (_currentTab === 'unpaid') {
                    params += '&status=received,partial_received,partial_paid';
                } else if (_currentTab === 'overdue') {
                    params += '&overdue=1';
                } else {
                    params += '&status=' + _currentTab;
                }
            }
            var maker = document.getElementById('b2f-filter-maker');
            if (maker && maker.value) params += '&maker_id=' + maker.value;
            var from = document.getElementById('b2f-filter-from');
            if (from && from.value) params += '&date_from=' + from.value;
            var to = document.getElementById('b2f-filter-to');
            if (to && to.value) params += '&date_to=' + to.value;
            var search = document.getElementById('b2f-filter-search');
            if (search && search.value) params += '&search=' + encodeURIComponent(search.value);

            document.getElementById('b2f-po-list').innerHTML = '<div class="b2f-loading"><div class="spinner"></div><br>กำลังโหลด...</div>';

            api('GET', 'po-history?' + params).then(function(res) {
                if (!res.success) {
                    document.getElementById('b2f-po-list').innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-circle-exclamation"></i>โหลดข้อมูลไม่สำเร็จ</div>';
                    return;
                }
                var list = res.data || [];
                var counts = res.counts || {};
                updateTabCounts(counts);

                if (!list.length) {
                    document.getElementById('b2f-po-list').innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-inbox"></i>ไม่พบ PO ที่ตรงตามเงื่อนไข</div>';
                    document.getElementById('b2f-orders-pagination').innerHTML = '';
                    return;
                }
                renderPOList(list);
                renderPagination(res.total || list.length, res.total_pages || 1);
            }).catch(function() {
                document.getElementById('b2f-po-list').innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-circle-exclamation"></i>เกิดข้อผิดพลาด</div>';
            });
        }

        function updateTabCounts(c) {
            setText('b2f-cnt-all', c.all || 0);
            setText('b2f-cnt-submitted', c.submitted || 0);
            setText('b2f-cnt-confirmed', c.confirmed || 0);
            setText('b2f-cnt-rejected', c.rejected || 0);
            setText('b2f-cnt-delivering', c.delivering || 0);
            setText('b2f-cnt-partial_received', c.partial_received || 0);
            setText('b2f-kpi-partial', c.partial_received || 0);
            setText('b2f-cnt-unpaid', c.unpaid || 0);
            setText('b2f-cnt-completed', c.completed || 0);
            setText('b2f-cnt-cancelled', c.cancelled || 0);
        }

        /* ── Cancellable statuses for bulk ── */
        // ลบได้ทุกสถานะยกเว้น cancelled
        var DELETABLE = ['draft','submitted','confirmed','amended','rejected','delivering','partial_received','received','partial_paid','paid','completed'];

        /* ── V.7.1: Order mode summary + filter helper ── */
        // Read `_b2f_order_intent_summary` passthrough from API (if V.11.0 enriched) OR derive from items[].poi_order_mode
        // Response shape: po.order_intent_summary = { full_set_count, sub_unit_count, single_leaf_count, total_items, dominant_mode? }
        function getModeSummaryForPO(po) {
            var s = po.order_intent_summary || po.mode_summary || null;
            if (s && typeof s === 'object') {
                var full = parseInt(s.full_set_count || 0);
                var sub  = parseInt(s.sub_unit_count || 0);
                var sgl  = parseInt(s.single_leaf_count || 0);
                var tot  = parseInt(s.total_items || (full + sub + sgl));
                var dominant = s.dominant_mode || '';
                if (!dominant) {
                    if (full >= sub && full >= sgl && full > 0) dominant = 'full_set';
                    else if (sub >= sgl && sub > 0) dominant = 'sub_unit';
                    else if (sgl > 0) dominant = 'single_leaf';
                    else dominant = 'legacy';
                }
                return { full_set: full, sub_unit: sub, single_leaf: sgl, total: tot, dominant: dominant, is_legacy: (tot === 0) };
            }
            return { full_set: 0, sub_unit: 0, single_leaf: 0, total: 0, dominant: 'legacy', is_legacy: true };
        }

        function renderModeSummaryBadge(summary) {
            if (!summary || summary.is_legacy) {
                return '<span class="b2f-mode-summary" title="PO เก่าไม่มี order_mode — Legacy"><i class="fa-solid fa-clock-rotate-left"></i> <span class="mode-chip legacy">Legacy</span></span>';
            }
            var parts = [];
            var dominantLbl = '';
            if (summary.full_set > 0)    parts.push('<span class="mode-chip full-set" title="ครบชุด: ' + summary.full_set + '">🟣 ' + summary.full_set + '</span>');
            if (summary.sub_unit > 0)    parts.push('<span class="mode-chip sub-unit" title="แยกชุด: ' + summary.sub_unit + '">🟠 ' + summary.sub_unit + '</span>');
            if (summary.single_leaf > 0) parts.push('<span class="mode-chip single" title="ชิ้นเดี่ยว: ' + summary.single_leaf + '">⚪ ' + summary.single_leaf + '</span>');
            if (!parts.length) return '<span class="b2f-mode-summary"><span class="mode-chip legacy">–</span></span>';
            if (parts.length === 1) {
                if (summary.dominant === 'full_set')    dominantLbl = '🟣 ครบชุด';
                else if (summary.dominant === 'sub_unit')   dominantLbl = '🟠 แยกชุด';
                else if (summary.dominant === 'single_leaf') dominantLbl = '⚪ ชิ้นเดี่ยว';
                return '<span class="b2f-mode-summary" title="โหมด: ' + esc(dominantLbl) + '">' + parts.join('') + '</span>';
            }
            return '<span class="b2f-mode-summary" title="ผสม ' + parts.length + ' โหมด">' + parts.join('') + '</span>';
        }

        /* ── V.7.1: Mode filter — client-side filter by dominant_mode ── */
        function setModeFilter(mode) {
            _modeFilter = mode || 'all';
            // Update chip active state
            document.querySelectorAll('.b2f-mf-chip').forEach(function(c) {
                c.classList.toggle('active', c.getAttribute('data-mode') === _modeFilter);
            });
            // Re-render current list
            applyFilters();
        }

        /* ── Render PO Cards ── */
        function renderPOList(list) {
            // V.7.1: apply client-side mode filter
            if (_modeFilter && _modeFilter !== 'all') {
                list = list.filter(function(po){
                    var s = getModeSummaryForPO(po);
                    if (_modeFilter === 'legacy') return s.is_legacy;
                    if (_modeFilter === 'full_set')    return s.full_set > 0;
                    if (_modeFilter === 'sub_unit')    return s.sub_unit > 0;
                    if (_modeFilter === 'single_leaf') return s.single_leaf > 0;
                    return true;
                });
                if (!list.length) {
                    document.getElementById('b2f-po-list').innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-filter"></i>ไม่พบ PO ในโหมด "' + esc(_modeFilter) + '" สำหรับ filter ปัจจุบัน</div>';
                    return;
                }
            }

            var html = '';
            list.forEach(function(po) {
                var status = po.status || 'draft';
                var badgeCls = STATUS_BADGE[status] || 'b2f-badge-gray';
                var label = STATUS_LABELS[status] || status;
                var isOverdue = po.is_overdue;
                var canCancel = DELETABLE.indexOf(status) !== -1;
                var modeSum = getModeSummaryForPO(po);

                /* V.8.5 UX-H3 Phase 5: outer card uses data-action="orders-go-to-ticket".
                 * Inner action buttons each have their own data-action — closest('[data-action]')
                 * walks UP from target so child buttons match first (their data-action wins),
                 * outer card's handler only fires for clicks on non-action areas (number, badges, meta).
                 * Checkbox + cancel-btn given own data-action so click never reaches outer card. */
                html += '<div class="b2f-po-card" data-po-id="' + po.id + '" data-po-number="' + esc(po.po_number||'') + '" data-po-status="' + esc(status) + '" data-po-maker="' + esc(po.maker_name||'') + '" data-po-mode="' + esc(modeSum.dominant) + '" data-po-legacy="' + (modeSum.is_legacy?'1':'0') + '" data-cancellable="' + (canCancel?'1':'0') + '" style="cursor:pointer;' + (isOverdue ? 'border-left:3px solid #ef4444;' : '') + '" data-action="orders-go-to-ticket">';
                html += '<div class="b2f-po-card-header has-checkbox">';
                if (canCancel) {
                    html += '<input type="checkbox" class="b2f-po-checkbox" data-po-id="' + po.id + '" data-action="orders-card-checkbox" title="เลือกเพื่อลบ">';
                }
                html += '<span class="b2f-po-number" style="flex:1">' + esc(po.po_number || '-') + '</span>';
                html += '<div style="display:flex;align-items:center;gap:8px;">';
                if (canCancel) {
                    html += '<button class="b2f-cancel-btn" data-action="orders-card-cancel" title="ยกเลิก"><i class="fa-regular fa-trash-can"></i></button>';
                }
                html += '<span class="b2f-badge ' + badgeCls + '">' + label + '</span>';
                html += '</div>';
                html += '</div>';
                html += '<div class="b2f-po-meta">';
                html += '<span><i class="fa-solid fa-industry"></i> ' + esc(po.maker_name || '-') + '</span>';
                html += '<span><i class="fa-solid fa-boxes-stacked"></i> ' + (po.item_count || 0) + ' รายการ</span>';
                var poSym = po.currency_symbol || '\u0E3F';
                var poRate = parseFloat(po.exchange_rate) || 1;
                var amtDisplay = poSym + fmt(po.total_amount);
                if (poRate !== 1 && po.total_amount_thb) amtDisplay += ' (\u2248\u0E3F' + fmt(po.total_amount_thb) + ')';
                html += '<span><i class="fa-solid fa-coins"></i> ' + amtDisplay + '</span>';
                if (po.expected_date) {
                    html += '<span><i class="fa-solid fa-calendar-day"></i> กำหนดส่ง: ' + fmtDate(po.expected_date) + '</span>';
                }
                if (isOverdue) {
                    html += '<span style="color:#dc2626;font-weight:600;"><i class="fa-solid fa-circle-exclamation"></i> ล่าช้า ' + (po.overdue_days || '') + ' วัน</span>';
                }
                // V.7.1: Mode Summary badge row
                html += '<div style="padding:2px 14px 6px;display:flex;align-items:center;gap:6px;">';
                html += '<span style="font-size:11px;color:#94a3b8;">โหมด:</span> ' + renderModeSummaryBadge(modeSum);
                html += '</div>';
                html += '</div>';
                /* V.8.5 UX-H3 Phase 5: each action button has its own data-action.
                 * closest('[data-action]') matches the button (NOT outer card) so card's
                 * goToTicket handler doesn't fire. The wrapper still has stopPropagation
                 * as defense-in-depth (if a future button is added without data-action). */
                html += '<div class="b2f-po-actions" data-action="orders-stop-prop-noop">';
                html += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-card-detail"><i class="fa-solid fa-eye"></i> ดูรายละเอียด</button>';

                // Action buttons per FSM state (G-01~G-06 fix: ปุ่มครบทุก status)

                // แก้ไข PO (G-01: submitted, confirmed, rejected)
                if (['submitted','confirmed','rejected'].indexOf(status) !== -1) {
                    html += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-card-edit"><i class="fa-solid fa-pen-to-square"></i> แก้ไข</button>';
                }

                // ส่ง PO ใหม่ (G-02: rejected → submitted โดยไม่แก้ไข)
                if (status === 'rejected') {
                    html += '<button class="b2f-btn b2f-btn-primary" data-action="orders-card-resubmit"><i class="fa-solid fa-paper-plane"></i> ส่งใหม่</button>';
                }

                // ตรวจรับ (delivering เท่านั้น — ต้องรอ Maker แจ้งส่งก่อน, ISSUE-3 fix)
                if (status === 'delivering') {
                    html += '<button class="b2f-btn b2f-btn-success" data-action="orders-card-receive"><i class="fa-solid fa-clipboard-check"></i> ตรวจรับ</button>';
                }

                // Reject ทั้ง Lot (G-04: delivering → confirmed)
                if (status === 'delivering') {
                    html += '<button class="b2f-btn" style="color:#dc2626;border-color:#dc2626;" data-action="orders-card-reject-lot"><i class="fa-solid fa-ban"></i> Reject Lot</button>';
                }

                // จ่ายเงิน (received, partial_paid — ต้องรับครบก่อนจ่าย, BUG-3 fix)
                if (['received','partial_paid'].indexOf(status) !== -1) {
                    html += '<button class="b2f-btn b2f-btn-primary" data-action="orders-card-pay"><i class="fa-solid fa-money-bill-transfer"></i> จ่ายเงิน</button>';
                }

                // ปิด PO ไม่จ่ายเงิน (G-05: received → completed สำหรับของฟรี/sample)
                if (status === 'received') {
                    html += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-card-complete"><i class="fa-solid fa-circle-check"></i> ปิด PO</button>';
                }

                // สั่งซ้ำ — PO ที่ completed/cancelled
                if (['completed','cancelled'].indexOf(status) !== -1) {
                    html += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-card-reorder"><i class="fa-solid fa-rotate"></i> สั่งซ้ำ</button>';
                }
                html += '</div></div>';
            });
            document.getElementById('b2f-po-list').innerHTML = html;
        }

        /* ── Pagination ── */
        function renderPagination(total, totalPages) {
            if (totalPages <= 1) { document.getElementById('b2f-orders-pagination').innerHTML = ''; return; }
            var html = '';
            if (_currentPage > 1) html += '<button class="b2f-page-btn" data-action="orders-page" data-page="' + (_currentPage-1) + '">&laquo;</button>';
            for (var i = 1; i <= totalPages; i++) {
                if (totalPages > 7 && Math.abs(i - _currentPage) > 2 && i !== 1 && i !== totalPages) {
                    if (i === 2 || i === totalPages - 1) html += '<span class="b2f-page-info">...</span>';
                    continue;
                }
                html += '<button class="b2f-page-btn' + (i === _currentPage ? ' active' : '') + '" data-action="orders-page" data-page="' + i + '">' + i + '</button>';
            }
            if (_currentPage < totalPages) html += '<button class="b2f-page-btn" data-action="orders-page" data-page="' + (_currentPage+1) + '">&raquo;</button>';
            document.getElementById('b2f-orders-pagination').innerHTML = html;
        }

        /* ── Create PO: Load maker products ── */
        // B-03/B-04 fix: return Promise เพื่อให้ editPO/reorderPO .then() ได้
        function loadMakerProducts() {
            var makerId = document.getElementById('b2f-create-maker').value;
            var catalogDiv = document.getElementById('b2f-create-catalog');
            var condDiv = document.getElementById('b2f-create-conditions');
            var listDiv = document.getElementById('b2f-create-sku-list');
            var infoDiv = document.getElementById('b2f-create-maker-info');
            if (!makerId) { catalogDiv.style.display='none'; condDiv.style.display='none'; infoDiv.style.display='none'; return Promise.resolve(); }

            catalogDiv.style.display = 'block';
            condDiv.style.display = 'block';
            listDiv.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:#94a3b8;">กำลังโหลดสินค้า...</td></tr>';

            // แสดงข้อมูล Maker
            api('GET', 'makers').then(function(res) {
                if (!res.success || !res.data) return;
                var mk = res.data.find(function(m){ return m.id == makerId; });
                if (mk && infoDiv) {
                    infoDiv.style.display = 'block';
                    _createMakerCurrency = mk.currency || 'THB';
                    _createMakerCurrencySymbol = _createMakerCurrency === 'CNY' ? '\u00A5' : (_createMakerCurrency === 'USD' ? '$' : '\u0E3F');
                    var info = '<strong>' + esc(mk.name) + '</strong>';
                    if (_createMakerCurrency !== 'THB') info += ' <span class="b2f-badge b2f-badge-blue">' + _createMakerCurrency + '</span>';
                    if (mk.contact) info += '<br>ผู้ติดต่อ: ' + esc(mk.contact);
                    if (mk.phone) info += ' | ' + esc(mk.phone);
                    info += '<br>เครดิต: ' + (mk.credit_term_days||30) + ' วัน';
                    if (mk.current_debt > 0) info += '<br>ค้างจ่าย: <span style="color:#dc2626;font-weight:600;">\u0E3F' + fmt(mk.current_debt) + '</span>';
                    if (mk.credit_hold) info += '<br><span style="color:#dc2626;font-weight:700;">CREDIT HOLD</span>';
                    infoDiv.innerHTML = info;
                    // Auto-set credit term
                    var termSel = document.getElementById('b2f-create-credit-term');
                    if (termSel && mk.credit_term_days) termSel.value = String(mk.credit_term_days);

                    // Show/hide currency section
                    var curSection = document.getElementById('b2f-create-currency-section');
                    var thbShipSection = document.getElementById('b2f-create-thb-shipping');
                    if (_createMakerCurrency !== 'THB') {
                        curSection.style.display = 'block';
                        thbShipSection.style.display = 'none';
                        document.getElementById('b2f-create-currency-code').textContent = _createMakerCurrency;
                        document.querySelectorAll('.b2f-csum-cur').forEach(function(el){ el.textContent = _createMakerCurrency; });
                        // Hint: ดึง rate จาก PO ล่าสุดของ maker
                        api('GET', 'po-history?maker_id=' + makerId + '&per_page=1').then(function(r2) {
                            if (r2.success && r2.data && r2.data.length && r2.data[0].exchange_rate && parseFloat(r2.data[0].exchange_rate) !== 1) {
                                var lastRate = parseFloat(r2.data[0].exchange_rate);
                                var hintEl = document.getElementById('b2f-create-rate-hint');
                                hintEl.textContent = 'PO ล่าสุด (' + (r2.data[0].po_number||'') + '): ' + lastRate;
                                hintEl.style.display = 'block';
                                var rateInput = document.getElementById('b2f-create-exchange-rate');
                                if (!rateInput.value) rateInput.placeholder = lastRate;
                            }
                        });
                    } else {
                        curSection.style.display = 'none';
                    }
                }
            });

            // โหลดสินค้าของ Maker — return Promise เพื่อ chain
            return api('GET', 'maker-products/' + makerId).then(function(res) {
                if (!res.success || !res.data || !res.data.length) {
                    listDiv.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:#94a3b8;">โรงงานนี้ยังไม่มีสินค้า</td></tr>';
                    return;
                }
                // V.6.2 (Issue #3): defensively filter out virtual SETs (from b2f_inject_virtual_all_sets_v920)
                // Admin Makers order modal ควรโชว์เฉพาะสินค้าที่ Maker register จริง (not virtual injected intermediates)
                _createMakerProducts = res.data.filter(function(p){ return p.status !== 'discontinued' && p.is_virtual !== true; });
                var csym = _createMakerCurrencySymbol;
                var html = '';
                _createMakerProducts.forEach(function(p, idx) {
                    var bg = idx % 2 === 0 ? '' : 'background:#f8fafc;';
                    var shipInfo = '';
                    if (p.shipping_land || p.shipping_sea) {
                        shipInfo = '<div style="font-size:10px;color:#94a3b8;">ค่าส่ง: รถ \u0E3F' + fmt(p.shipping_land||0) + ' | เรือ \u0E3F' + fmt(p.shipping_sea||0) + '</div>';
                    }
                    html += '<tr class="b2f-sku-row" data-sku="' + esc(p.sku) + '" data-name="' + esc(p.product_name||'') + '" data-cost="' + p.unit_cost + '" data-ship-land="' + (p.shipping_land||0) + '" data-ship-sea="' + (p.shipping_sea||0) + '" style="' + bg + '">';
                    html += '<td style="padding:8px;text-align:center;"><input type="checkbox" data-change="orders-recalc-total" style="width:16px;height:16px;"></td>';
                    html += '<td style="padding:8px;font-size:12px;font-weight:600;">' + esc(p.sku) + '</td>';
                    html += '<td style="padding:8px;font-size:12px;color:#64748b;">' + esc(p.product_name || p.sku) + shipInfo + '</td>';
                    html += '<td style="padding:8px;text-align:right;font-weight:600;color:var(--accent-b2f);">' + csym + fmt(p.unit_cost) + '</td>';
                    html += '<td style="padding:8px;text-align:center;">';
                    html += '<div style="display:flex;align-items:center;justify-content:center;gap:4px;">';
                    html += '<button type="button" data-action="orders-adjust-qty" data-delta="-1" style="width:28px;height:28px;border:1px solid #d1d5db;border-radius:6px;background:#fff;cursor:pointer;font-weight:700;">\u2212</button>';
                    html += '<input type="number" min="0" value="0" data-change="orders-recalc-total" data-input="orders-recalc-total" style="width:50px;text-align:center;padding:4px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;">';
                    html += '<button type="button" data-action="orders-adjust-qty" data-delta="1" style="width:28px;height:28px;border:1px solid #d1d5db;border-radius:6px;background:#fff;cursor:pointer;font-weight:700;">+</button>';
                    html += '</div></td>';
                    html += '<td style="padding:8px;text-align:right;font-weight:600;" class="b2f-row-subtotal">' + csym + '0.00</td>';
                    html += '</tr>';
                });
                listDiv.innerHTML = html;

                // Show THB shipping section if THB maker has products with shipping
                if (_createMakerCurrency === 'THB') {
                    var hasShipping = _createMakerProducts.some(function(p){ return (p.shipping_land||0) > 0 || (p.shipping_sea||0) > 0; });
                    var thbShipSection = document.getElementById('b2f-create-thb-shipping');
                    if (hasShipping) thbShipSection.style.display = 'block';
                    else thbShipSection.style.display = 'none';
                }
                recalcTotal();
            });
        }

        function adjustQty(btn, delta) {
            var inp = btn.parentElement.querySelector('input');
            var v = parseInt(inp.value) || 0;
            inp.value = Math.max(0, v + delta);
            recalcTotal();
        }

        function recalcTotal() {
            var total = 0;
            var count = 0;
            var csym = _createMakerCurrencySymbol;
            var isForeign = _createMakerCurrency !== 'THB';
            var rate = parseFloat(document.getElementById('b2f-create-exchange-rate').value) || 0;

            // Determine shipping method for shipping calc
            var shipMethod = '';
            if (isForeign) {
                shipMethod = document.getElementById('b2f-create-shipping-method').value || '';
            } else {
                shipMethod = document.getElementById('b2f-create-thb-shipping-method').value || '';
            }

            var totalShipping = 0;

            document.querySelectorAll('#b2f-create-sku-list .b2f-sku-row').forEach(function(el) {
                var cost = parseFloat(el.dataset.cost) || 0;
                var inp = el.querySelector('input[type="number"]');
                var cb = el.querySelector('input[type="checkbox"]');
                var qty = parseInt(inp.value) || 0;
                // Auto-check ถ้ากรอกจำนวน > 0
                if (qty > 0 && cb) cb.checked = true;
                if (qty === 0 && cb) cb.checked = false;
                var sub = cost * qty;
                var subEl = el.querySelector('.b2f-row-subtotal');
                if (subEl) subEl.textContent = csym + fmt(sub);
                if (qty > 0) {
                    total += sub;
                    count++;
                    // calc shipping per unit
                    if (shipMethod === 'land') totalShipping += (parseFloat(el.dataset.shipLand) || 0) * qty;
                    else if (shipMethod === 'sea') totalShipping += (parseFloat(el.dataset.shipSea) || 0) * qty;
                }
            });

            document.getElementById('b2f-create-total').textContent = csym + fmt(total);

            // Foreign currency summary
            if (isForeign) {
                var costSummary = document.getElementById('b2f-create-cost-summary');
                if (count > 0 && rate > 0) {
                    costSummary.style.display = 'block';
                    var thbAmount = total * rate;
                    document.getElementById('b2f-csum-foreign').textContent = csym + fmt(total);
                    document.getElementById('b2f-csum-thb').textContent = '\u0E3F' + fmt(thbAmount);
                    document.getElementById('b2f-csum-shipping').textContent = '\u0E3F' + fmt(totalShipping);
                    document.getElementById('b2f-csum-grand').textContent = '\u0E3F' + fmt(thbAmount + totalShipping);
                } else {
                    costSummary.style.display = count > 0 ? 'block' : 'none';
                    if (count > 0) {
                        document.getElementById('b2f-csum-foreign').textContent = csym + fmt(total);
                        document.getElementById('b2f-csum-thb').textContent = rate > 0 ? '\u0E3F' + fmt(total * rate) : '(กรอก rate)';
                        document.getElementById('b2f-csum-shipping').textContent = '\u0E3F' + fmt(totalShipping);
                        document.getElementById('b2f-csum-grand').textContent = '(กรอก rate)';
                    }
                }
            }

            // THB shipping summary
            if (!isForeign && totalShipping > 0) {
                var thbShipSummary = document.getElementById('b2f-create-thb-shipping-summary');
                if (thbShipSummary) thbShipSummary.innerHTML = 'ค่าส่ง: <strong>\u0E3F' + fmt(totalShipping) + '</strong> | ต้นทุนรวม: <strong>\u0E3F' + fmt(total + totalShipping) + '</strong>';
            }

            // Summary
            var sumEl = document.getElementById('b2f-create-summary');
            if (sumEl) {
                if (count > 0) {
                    var sumText = count + ' รายการ \u00B7 ' + csym + fmt(total);
                    if (isForeign && rate > 0) sumText += ' (\u2248\u0E3F' + fmt(total * rate + totalShipping) + ')';
                    else if (!isForeign && totalShipping > 0) sumText += ' + ค่าส่ง \u0E3F' + fmt(totalShipping);
                    sumEl.textContent = sumText;
                } else {
                    sumEl.textContent = '';
                }
            }
        }

        /* ── Submit Create PO ── */
        function submitCreatePO() {
            var makerId = document.getElementById('b2f-create-maker').value;
            if (!makerId) { toast('กรุณาเลือกโรงงาน', 'error'); return; }

            var items = [];
            document.querySelectorAll('#b2f-create-sku-list .b2f-sku-row').forEach(function(el) {
                var qty = parseInt(el.querySelector('input[type="number"]').value) || 0;
                if (qty > 0) {
                    items.push({ sku: el.dataset.sku, qty: qty });
                }
            });
            if (!items.length) { toast('กรุณาเลือกสินค้าอย่างน้อย 1 รายการ', 'error'); return; }

            var btn = document.getElementById('b2f-create-submit');
            setLoading(btn, true);

            var payload = { maker_id: parseInt(makerId), items: items };
            var dateVal = document.getElementById('b2f-create-date').value;
            if (dateVal) payload.requested_date = dateVal;
            var noteVal = document.getElementById('b2f-create-note').value.trim();
            if (noteVal) payload.note = noteVal;

            // Multi-Currency: exchange_rate + shipping_method
            if (_createMakerCurrency !== 'THB') {
                var exRate = parseFloat(document.getElementById('b2f-create-exchange-rate').value);
                var shipMethod = document.getElementById('b2f-create-shipping-method').value;
                if (!exRate || exRate <= 0) { toast('กรุณากรอกอัตราแลกเปลี่ยน', 'error'); setLoading(btn, false); return; }
                if (!shipMethod) { toast('กรุณาเลือกวิธีส่ง', 'error'); setLoading(btn, false); return; }
                payload.exchange_rate = exRate;
                payload.shipping_method = shipMethod;
            } else {
                var thbShipMethod = document.getElementById('b2f-create-thb-shipping-method').value;
                if (thbShipMethod) payload.shipping_method = thbShipMethod;
            }

            // G-01: ถ้าเป็น edit mode ส่ง po-update แทน create-po
            var editPoId = btn.dataset.editPoId;
            var endpoint = editPoId ? 'po-update' : 'create-po';
            if (editPoId) payload.po_id = parseInt(editPoId);

            api('POST', endpoint, payload).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast(editPoId ? 'แก้ไข PO สำเร็จ' : 'สร้าง PO ' + (res.po_number || '') + ' สำเร็จ', 'success');
                    closeModal('b2f-modal-create-po');
                    resetCreateForm();
                    loadStats();
                    loadOrders();
                } else {
                    toast(res.error || (editPoId ? 'แก้ไขไม่สำเร็จ' : 'สร้าง PO ไม่สำเร็จ'), 'error');
                }
            }).catch(function() { setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

