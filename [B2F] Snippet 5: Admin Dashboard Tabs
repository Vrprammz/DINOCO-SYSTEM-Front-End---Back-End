                /* V.8.4 UX-H3 Phase 4: Compound close-and-call delegation
                 * data-action="orders-close-and-call" + data-modal-target + data-fn + data-args (JSON array).
                 * Delegated handler in IIFE bottom: closeModal(target) → window.B2F_Orders[fnName].apply(args).
                 * Function whitelist enforced (8 allowed: editPO/resubmitPO/openReceive/openPayment/rejectLot/completePO/cancelPO/reorderPO).
                 * po.po_number passed via JSON.stringify → safe for Thai/special chars; esc() HTML-encodes attribute. */
                var poIdJson  = JSON.stringify([po.id]);
                var poFullJson = JSON.stringify([po.id, po.po_number || '']);
                if (['submitted','confirmed','rejected'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="editPO" data-args="' + esc(poIdJson) + '"><i class="fa-solid fa-pen-to-square"></i> แก้ไข PO</button>';
                }
                if (st === 'rejected') {
                    actions += '<button class="b2f-btn b2f-btn-primary" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="resubmitPO" data-args="' + esc(poFullJson) + '"><i class="fa-solid fa-paper-plane"></i> ส่งใหม่</button>';
                }
                if (st === 'delivering') {
                    actions += '<button class="b2f-btn b2f-btn-success" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="openReceive" data-args="' + esc(poIdJson) + '"><i class="fa-solid fa-clipboard-check"></i> ตรวจรับ</button>';
                }
                if (['received','partial_paid'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-primary" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="openPayment" data-args="' + esc(poIdJson) + '"><i class="fa-solid fa-money-bill-transfer"></i> จ่ายเงิน</button>';
                }
                // U-01: Reject Lot ใน detail modal
                if (st === 'delivering') {
                    actions += '<button class="b2f-btn" style="color:#dc2626;border-color:#dc2626;" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="rejectLot" data-args="' + esc(poFullJson) + '"><i class="fa-solid fa-ban"></i> Reject Lot</button>';
                }
                // U-02: Complete PO ใน detail modal
                if (st === 'received') {
                    actions += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="completePO" data-args="' + esc(poFullJson) + '"><i class="fa-solid fa-circle-check"></i> ปิด PO</button>';
                }
                if (['draft','submitted','confirmed','rejected','partial_received'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-danger" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="cancelPO" data-args="' + esc(poFullJson) + '"><i class="fa-regular fa-trash-can"></i> ลบ</button>';
                }
                // U-03: Reorder ใน detail modal
                if (['completed','cancelled'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-secondary" data-action="orders-close-and-call" data-modal-target="b2f-modal-detail" data-fn="reorderPO" data-args="' + esc(poIdJson) + '"><i class="fa-solid fa-rotate"></i> สั่งซ้ำ</button>';
                }
                actions += '</div>';
                html += actions;

                body.innerHTML = html;
            });
        }

        /* ── Delete PO ── */
