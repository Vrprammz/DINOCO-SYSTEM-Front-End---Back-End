                if (ptype === 'set') badgeHtml = '<span style="display:inline-block;padding:0 4px;border-radius:3px;font-size:8px;font-weight:700;background:#ede9fe;color:#7c3aed;">ชุด</span> ';
                else if (ptype === 'child') badgeHtml = '<span style="display:inline-block;padding:0 4px;border-radius:3px;font-size:8px;font-weight:700;background:#dbeafe;color:#2563eb;">ชิ้นส่วน</span> ';
                else if (ptype === 'grandchild') badgeHtml = '<span style="display:inline-block;padding:0 4px;border-radius:3px;font-size:8px;font-weight:700;background:#dcfce7;color:#16a34a;">ย่อย</span> ';
                html += '<div style="font-size:11px;font-weight:600;color:#374151;word-break:break-all;">' + badgeHtml + esc(sku) + '</div>';
                html += '<div style="font-size:11px;color:#6b7280;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;" title="' + esc(name) + '">' + esc(name) + '</div>';
                html += '</div></div></label>';
            });
            gridEl.innerHTML = html;
        }

        function filterPicker() { if (_b2bProducts) renderPickerGrid(_b2bProducts); }

