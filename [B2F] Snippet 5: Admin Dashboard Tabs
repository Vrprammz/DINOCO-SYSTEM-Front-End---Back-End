    <!-- Toast -->
    <div class="b2f-toast" id="b2f-credit-toast"></div>

    <script>
    (function(){
        'use strict';

        var API_BASE = '<?php echo esc_url( rest_url( 'b2f/v1/' ) ); ?>';
        var NONCE    = '<?php echo $nonce; ?>';
        var _currentMakerId = null;

        function api(method, endpoint, body, isFormData) {
            var opts = { method: method, headers: { 'X-WP-Nonce': NONCE } };
            if (body) {
                if (isFormData) { opts.body = body; }
                else { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
            }
            return fetch(API_BASE + endpoint, opts).then(function(r){ return r.json(); });
        }
        function fmt(n) { return new Intl.NumberFormat('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n||0); }
        function esc(s) { var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
        function fmtDate(d) { if(!d)return'-'; return new Date(d).toLocaleDateString('th-TH',{day:'2-digit',month:'2-digit',year:'numeric'}); }
        function toast(msg, type) {
            var el = document.getElementById('b2f-credit-toast');
            el.textContent = msg; el.className = 'b2f-toast ' + (type||'info') + ' show';
            var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
            _st(function(){ el.classList.remove('show'); }, 3500);
        }
        function setLoading(btn, loading) {
            if (!btn) return;
            if (loading) { btn.disabled=true; btn.dataset.origText=btn.innerHTML; btn.innerHTML='<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;"></div>'; }
            else { btn.disabled=false; btn.innerHTML=btn.dataset.origText||btn.innerHTML; }
        }
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }
        function setText(id, v) { var el=document.getElementById(id); if(el) el.textContent=v; }

        /* ── Load Credit Data ── */
        function loadCredit() {
            // Load stats
            api('GET', 'dashboard-stats').then(function(res) {
                var d = res.success ? res.data : res;
                setText('b2f-credit-total-debt', '\u0E3F' + fmt(d.total_payable));
                setText('b2f-credit-overdue', '\u0E3F' + fmt(d.overdue_payable));
            });

            // Load makers with credit info
            var listEl = document.getElementById('b2f-credit-list');
            listEl.innerHTML = '<div class="b2f-loading"><div class="spinner"></div><br>กำลังโหลด...</div>';

            api('GET', 'makers').then(function(res) {
                if (!res.success) { listEl.innerHTML = '<div class="b2f-empty">โหลดไม่สำเร็จ</div>'; return; }
                var makers = (res.data || []).filter(function(m){ return m.status === 'active'; });
                if (!makers.length) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-building"></i>ไม่มีโรงงานที่ active</div>'; return; }

                var html = '<div style="display:flex;flex-direction:column;gap:12px;">';
                makers.forEach(function(m) {
                    var limit = m.credit_limit || 0;
                    var debt = m.current_debt || 0;
                    var pct = limit > 0 ? Math.min(100, Math.round(debt / limit * 100)) : 0;
                    var progressClass = pct >= 90 ? 'b2f-progress-danger' : (pct >= 60 ? 'b2f-progress-warn' : 'b2f-progress-safe');
                    var isHold = m.credit_hold;
                    var termDays = m.credit_term_days || 30;

                    html += '<div class="b2f-credit-card">';
                    html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">';
                    html += '<span style="font-weight:700;font-size:15px;">' + esc(m.name) + '</span>';
                    html += '<div>';
                    if (isHold) html += '<span class="b2f-badge b2f-badge-red">Credit Hold</span> ';
                    html += '</div></div>';

                    html += '<div style="font-size:13px;color:var(--c-text-dim);margin-bottom:6px;">';
                    html += 'วงเงิน: <strong>\u0E3F' + fmt(limit) + '</strong> | ';
                    html += 'ค้างจ่าย: <strong style="color:' + (debt > 0 ? '#dc2626' : 'inherit') + ';">\u0E3F' + fmt(debt) + '</strong>';
                    if (limit > 0) html += ' (' + pct + '%)';
                    html += '</div>';

                    if (limit > 0) {
                        html += '<div class="b2f-progress-bar"><div class="b2f-progress-fill ' + progressClass + '" style="width:' + pct + '%;"></div></div>';
                    }

                    html += '<div style="font-size:12px;color:var(--c-text-dim);margin-bottom:10px;">';
                    html += 'เครดิต: ' + termDays + ' วัน';
                    if (m.overdue_po_count) html += ' | <span style="color:#dc2626;font-weight:600;">ใกล้/เลยกำหนด: ' + m.overdue_po_count + ' PO</span>';
                    html += '</div>';

                    html += '<div style="display:flex;flex-wrap:wrap;gap:8px;">';
                    html += '<button class="b2f-btn b2f-btn-secondary" onclick="B2F_Credit.openHistory(' + m.id + ',\'' + esc(m.name).replace(/'/g,"\\'") + '\')"><i class="fa-solid fa-clock-rotate-left"></i> ดูประวัติ</button>';
                    html += '<button class="b2f-btn b2f-btn-primary" onclick="B2F_Credit.openPayment(' + m.id + ',\'' + esc(m.name).replace(/'/g,"\\'") + '\',' + debt + ')"><i class="fa-solid fa-money-bill-transfer"></i> บันทึกจ่ายเงิน</button>';
                    if (isHold) {
                        html += '<button class="b2f-btn b2f-btn-success" onclick="B2F_Credit.unlockCredit(' + m.id + ',\'' + esc(m.name).replace(/'/g,"\\'") + '\')"><i class="fa-solid fa-lock-open"></i> ปลดล็อก</button>';
                    } else {
                        // W-06: เพิ่มปุ่ม Manual Hold
                        html += '<button class="b2f-btn" style="color:#dc2626;border-color:#dc2626;" onclick="B2F_Credit.holdCredit(' + m.id + ',\'' + esc(m.name).replace(/'/g,"\\'") + '\')"><i class="fa-solid fa-lock"></i> ระงับเครดิต</button>';
                    }
                    html += '</div></div>';
                });
                html += '</div>';
                listEl.innerHTML = html;
            });
        }

        /* ── Payment History ── */
        function openHistory(makerId, makerName) {
            _currentMakerId = makerId;
            setText('b2f-credit-hist-name', makerName);
            openModal('b2f-modal-credit-history');
            var body = document.getElementById('b2f-credit-hist-body');
            body.innerHTML = '<div class="b2f-loading"><div class="spinner"></div></div>';

            api('GET', 'po-history?maker_id=' + makerId + '&status=received,partial_received,paid,partial_paid,completed&per_page=50').then(function(res) {
                if (!res.success || !(res.data || []).length) {
                    body.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-inbox"></i>ไม่มีประวัติ</div>';
                    return;
                }
                var html = '<table style="width:100%;border-collapse:collapse;font-size:13px;">';
                html += '<thead><tr style="background:var(--c-bg);"><th style="padding:8px;text-align:left;">PO</th><th style="padding:8px;text-align:right;">ยอดรวม</th><th style="padding:8px;text-align:right;">จ่ายแล้ว</th><th style="padding:8px;text-align:right;">คงเหลือ</th><th style="padding:8px;">สถานะ</th></tr></thead><tbody>';
                (res.data || []).forEach(function(po) {
                    var remaining = (po.total_amount || 0) - (po.paid_amount || 0);
                    var STATUS_LABELS_LOCAL = { received:'รับครบแล้ว', partial_received:'รับบางส่วน', paid:'จ่ายแล้ว', partial_paid:'จ่ายบางส่วน', completed:'เสร็จสิ้น' };
                    html += '<tr style="border-bottom:1px solid var(--c-border);">';
                    html += '<td style="padding:8px;"><strong>' + esc(po.po_number) + '</strong><br><span style="font-size:11px;color:var(--c-text-dim);">' + fmtDate(po.created_date) + '</span></td>';
                    html += '<td style="padding:8px;text-align:right;">\u0E3F' + fmt(po.total_amount) + '</td>';
                    html += '<td style="padding:8px;text-align:right;">\u0E3F' + fmt(po.paid_amount) + '</td>';
                    html += '<td style="padding:8px;text-align:right;font-weight:600;color:' + (remaining > 0 ? '#dc2626' : '#16a34a') + ';">\u0E3F' + fmt(remaining) + '</td>';
                    html += '<td style="padding:8px;text-align:center;">' + (STATUS_LABELS_LOCAL[po.status] || po.status) + '</td>';
                    html += '</tr>';
                });
                html += '</tbody></table>';
                body.innerHTML = html;
            });
        }

        /* ── Quick Payment ── */
        function openCreditPayment(makerId, makerName, debt) {
            _currentMakerId = makerId;
            setText('b2f-credit-pay-name', makerName);
            setText('b2f-credit-pay-debt', '\u0E3F' + fmt(debt));

            // Set today's date
            var today = new Date();
            document.getElementById('b2f-credit-pay-date').value = today.toISOString().slice(0, 10);
            document.getElementById('b2f-credit-pay-amount').value = '';
            document.getElementById('b2f-credit-pay-ref').value = '';
            document.getElementById('b2f-credit-pay-note').value = '';

            // Load unpaid POs for this maker
            var poSel = document.getElementById('b2f-credit-pay-po');
            poSel.innerHTML = '<option value="">กำลังโหลด...</option>';

            api('GET', 'po-history?maker_id=' + makerId + '&status=received,partial_received,partial_paid&per_page=50').then(function(res) {
                var html = '<option value="">-- เลือก PO --</option>';
                if (res.success && res.data) {
                    res.data.forEach(function(po) {
                        var rem = (po.total_amount||0) - (po.paid_amount||0);
                        html += '<option value="' + po.id + '">' + esc(po.po_number) + ' (คงเหลือ \u0E3F' + fmt(rem) + ')</option>';
                    });
                }
                poSel.innerHTML = html;
            });

            openModal('b2f-modal-credit-pay');
        }

        /* ── Submit Credit Payment ── */
        function submitCreditPayment() {
            var poId = document.getElementById('b2f-credit-pay-po').value;
            if (!poId) { toast('กรุณาเลือก PO', 'error'); return; }
            var amount = parseFloat(document.getElementById('b2f-credit-pay-amount').value);
            if (!amount || amount <= 0) { toast('กรุณากรอกจำนวนเงิน', 'error'); return; }
            var date = document.getElementById('b2f-credit-pay-date').value;
            if (!date) { toast('กรุณาเลือกวันที่', 'error'); return; }

            var btn = document.getElementById('b2f-credit-pay-submit');
            setLoading(btn, true);

            api('POST', 'record-payment', {
                po_id: parseInt(poId),
                amount: amount,
                date: date,
                method: document.getElementById('b2f-credit-pay-method').value,
                reference: document.getElementById('b2f-credit-pay-ref').value.trim(),
                note: document.getElementById('b2f-credit-pay-note').value.trim()
            }).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast('บันทึกจ่ายเงินสำเร็จ', 'success');
                    closeModal('b2f-modal-credit-pay');
                    loadCredit();
                } else {
                    toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
                }
            }).catch(function(){ setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

        /* ── Unlock Credit ── */
        function unlockCredit(makerId, makerName) {
            if (!confirm('ยืนยันปลดล็อกเครดิต ' + makerName + '?')) return;
            api('POST', 'maker', {
                maker_id: makerId,
                maker_credit_hold: false,
                maker_credit_hold_reason: ''
            }).then(function(res) {
                if (res.success) {
                    toast('ปลดล็อกเครดิตสำเร็จ', 'success');
                    loadCredit();
                } else {
                    toast(res.error || 'ปลดล็อกไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── W-06: Manual Credit Hold ── */
        function holdCredit(makerId, makerName) {
            if (!confirm('ยืนยันระงับเครดิต ' + makerName + '?\nPO ใหม่จะไม่สามารถสร้างได้จนกว่าจะปลดล็อก')) return;
            api('POST', 'maker', {
                maker_id: makerId,
                maker_credit_hold: true,
                maker_credit_hold_reason: 'manual'
            }).then(function(res) {
                if (res.success) {
                    toast('ระงับเครดิตสำเร็จ', 'success');
                    loadCredit();
                } else {
                    toast(res.error || 'ระงับไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── Backdrop click ── */
        document.querySelectorAll('#b2f-modal-credit-history, #b2f-modal-credit-pay').forEach(function(bd) {
            bd.addEventListener('click', function(e) { if (e.target === bd) bd.classList.remove('open'); });
        });

        /* ── Init ── */
        function init() { loadCredit(); }

        window.B2F_Credit = {
            init: init,
            loadCredit: loadCredit,
            openHistory: openHistory,
            openPayment: openCreditPayment,
            submitPayment: submitCreditPayment,
            unlockCredit: unlockCredit,
            holdCredit: holdCredit,
            closeModal: closeModal
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

    })();
    </script>
    <?php
    return ob_get_clean();
});
