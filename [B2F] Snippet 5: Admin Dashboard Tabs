        /* ── Submit Receive ── */
        function submitReceive() {
            var body = document.getElementById('b2f-receive-body');
            var items = [];
            body.querySelectorAll('.b2f-qc-item').forEach(function(el, idx) {
                var sku = el.dataset.sku;
                var qtyRcv = parseInt(el.querySelector('.rcv-qty').value) || 0;
                var qcRadio = el.querySelector('input[name="qc_' + idx + '"]:checked');
                var qcStatus = qcRadio ? qcRadio.value : 'passed';
                var rejectQty = 0, rejectReason = '';
                if (qcStatus === 'failed') {
                    rejectQty = parseInt(el.querySelector('.rcv-reject').value) || 0;
                    rejectReason = el.querySelector('.rcv-reject-reason').value.trim();
                }
                items.push({
                    sku: sku, qty_received: qtyRcv, qc_status: qcStatus,
                    reject_qty: rejectQty, reject_reason: rejectReason
                });
            });

            var inspector = document.getElementById('b2f-rcv-inspector').value.trim();
            var note = document.getElementById('b2f-rcv-note').value.trim();

            var btn = document.getElementById('b2f-receive-submit');
            setLoading(btn, true);

            api('POST', 'receive-goods', {
                po_id: _currentPOId, items: items, inspected_by: inspector, note: note
            }).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast('ตรวจรับสำเร็จ ' + (res.rcv_number || ''), 'success');
