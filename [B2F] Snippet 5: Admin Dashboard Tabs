    <!-- Toast -->
    <div class="b2f-toast" id="b2f-makers-toast"></div>

    <script>
    (function(){
        'use strict';

        var API_BASE = '<?php echo esc_url( rest_url( 'b2f/v1/' ) ); ?>';
        var AUDIT_BASE = '<?php echo esc_url( rest_url( 'dinoco-b2f-audit/v1/' ) ); ?>';
        var NONCE    = '<?php echo $nonce; ?>';
        var _searchTimer = null;
        var _currentMakerId = null;
        var _currentMakerName = '';
        var _curMakerCurrency = 'THB';
        var _curMakerSymbol = '\u0E3F';

        // V.6.3: Option F — source/selection state per maker load
        var _sourceMap = {};          // sku (upper) → 'cpt' | 'auto'
        var _sourceData = {};         // V.6.4: sku (upper) → full junction row {id, unit_cost, moq, status, notes, source, is_blacklisted, ...}
        var _productNameMap = {};     // V.6.4: sku (upper) → product_name (cached from loadProducts — enrich flat list)
        var _blacklistForMaker = [];  // uppercase SKUs in blacklist for current maker
        var _sourceFilter = 'all';    // 'all' | 'cpt' | 'auto'
        var _selectedForDelete = {};  // sku (upper) → true
        var _sourceSummary = { total: 0, cpt: 0, auto: 0, blacklisted: 0 };

        // V.6.6: View mode — 'flat' (รายชิ้น, default) vs 'set' (accordion ตาม SET)
        //   Flat mode = 1 row per Maker-registered SKU + "ใช้ใน N SET" badge (shared info)
        //   Set mode  = existing accordion (SET header + children) — DD-3 shared = duplicate rows
        //   Default flat เพราะ Maker จัดการ parts ที่ตัวเองผลิต ไม่ใช่ SET composition
        //   Persist preference per-user ผ่าน localStorage key 'b2f_makers_view_mode'
        var _viewMode = 'flat';
        try {
            var _vmStored = localStorage.getItem('b2f_makers_view_mode');
            if (_vmStored === 'set' || _vmStored === 'flat') _viewMode = _vmStored;
        } catch(e) {}
        function _persistViewMode(mode) {
            _viewMode = mode;
            try { localStorage.setItem('b2f_makers_view_mode', mode); } catch(e) {}
        }

        function api(method, endpoint, body) {
            var opts = { method: method, headers: { 'X-WP-Nonce': NONCE } };
            if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
            return fetch(API_BASE + endpoint, opts).then(function(r){
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            });
        }

        // V.6.3: Option F — audit API wrapper (different namespace)
        function auditApi(method, endpoint, body) {
            var opts = { method: method, headers: { 'X-WP-Nonce': NONCE } };
            if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
            return fetch(AUDIT_BASE + endpoint, opts).then(function(r){
                return r.json().then(function(j){
                    if (!r.ok) { throw new Error((j && j.message) || ('HTTP ' + r.status)); }
                    return j;
                });
            });
        }
        function fmt(n) { return new Intl.NumberFormat('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n||0); }
        function esc(s) { var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
        function toast(msg, type) {
            var el = document.getElementById('b2f-makers-toast');
            el.textContent = msg; el.className = 'b2f-toast ' + (type||'info') + ' show';
            var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
            _st(function(){ el.classList.remove('show'); }, 3500);
        }
        function setLoading(btn, loading) {
            if (!btn) return;
            if (loading) { btn.disabled=true; btn.dataset.origText=btn.innerHTML; btn.innerHTML='<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;"></div> บันทึก...'; }
            else { btn.disabled=false; btn.innerHTML=btn.dataset.origText||btn.innerHTML; }
        }
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        /* ── Load Makers ── */
        function loadMakers() {
            var listEl = document.getElementById('b2f-maker-list');
            listEl.innerHTML = '<div class="b2f-loading"><div class="spinner"></div><br>กำลังโหลด...</div>';

            api('GET', 'makers').then(function(res) {
                if (!res.success) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-circle-exclamation"></i>โหลดไม่สำเร็จ</div>'; return; }
                var makers = res.data || [];

                // Apply filters
                var search = (document.getElementById('b2f-maker-search').value || '').toLowerCase();
                var statusFilter = document.getElementById('b2f-maker-status-filter').value;
                makers = makers.filter(function(m) {
                    if (statusFilter && m.status !== statusFilter) return false;
                    if (search && (m.name || '').toLowerCase().indexOf(search) === -1) return false;
                    return true;
                });

                if (!makers.length) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-building"></i>ไม่พบโรงงาน</div>'; return; }

                var html = '';
                makers.forEach(function(m) {
                    var statusBadge = m.status === 'active'
                        ? '<span class="b2f-badge b2f-badge-green">Active</span>'
                        : '<span class="b2f-badge b2f-badge-gray">Inactive</span>';
                    var holdBadge = m.credit_hold ? ' <span class="b2f-badge b2f-badge-red">Credit Hold</span>' : '';

                    /* V.8.5 UX-H3 Phase 5: maker card root carries data-mid + data-mname + data-mcurrency
                     * — child action buttons read from .b2f-maker-card[data-mid] ancestor instead of
                     * inline-encoded args. Avoids esc()/replace escaping for Thai maker names. */
                    html += '<div class="b2f-maker-card" data-mid="' + m.id + '" data-mname="' + esc(m.name) + '" data-mcurrency="' + esc(m.currency || 'THB') + '">';
                    var curBadge = (m.currency && m.currency !== 'THB') ? ' <span class="b2f-badge" style="background:#dbeafe;color:#1d4ed8;font-size:10px;padding:1px 6px;">' + esc(m.currency) + '</span>' : '';
                    html += '<div class="b2f-maker-card-header"><span class="b2f-maker-name">' + esc(m.name) + curBadge + '</span><div>' + statusBadge + holdBadge + '</div></div>';
                    html += '<div class="b2f-maker-info">';
                    html += 'สินค้า: <strong>' + (m.product_count || 0) + '</strong> SKU | PO: <strong>' + (m.po_count || 0) + '</strong> ใบ<br>';
                    html += 'ค้างจ่าย: <strong style="color:' + ((m.current_debt||0) > 0 ? '#dc2626' : 'inherit') + ';">\u0E3F' + fmt(m.current_debt) + '</strong>';
                    if (m.contact) html += ' | ติดต่อ: ' + esc(m.contact);
                    html += '</div>';
                    html += '<div class="b2f-maker-actions">';
                    html += '<button class="b2f-btn b2f-btn-secondary" data-action="makers-card-edit"><i class="fa-solid fa-pen"></i> แก้ไข</button>';
                    html += '<button class="b2f-btn b2f-btn-secondary" data-action="makers-card-products"><i class="fa-solid fa-boxes-stacked"></i> จัดการสินค้า+ราคาทุน</button>';
                    html += '<button class="b2f-btn" style="color:#dc2626;border-color:#dc2626;" data-action="makers-card-delete"><i class="fa-solid fa-trash"></i> ลบ</button>';
                    html += '</div></div>';
                });
                listEl.innerHTML = html;
            });
        }

        /* ── Open Create Modal ── */
        function openCreateModal() {
            document.getElementById('b2f-maker-edit-id').value = '';
            document.getElementById('b2f-maker-modal-title').innerHTML = '<i class="fa-solid fa-building" style="color:var(--accent-b2f);margin-right:8px;"></i>เพิ่มโรงงานใหม่';
            clearMakerForm();
            openModal('b2f-modal-maker');
        }

        function clearMakerForm() {
            ['b2f-maker-name','b2f-maker-contact','b2f-maker-phone','b2f-maker-email','b2f-maker-address',
             'b2f-maker-tax-id','b2f-maker-bank-name','b2f-maker-bank-account','b2f-maker-bank-holder',
             'b2f-maker-line-gid','b2f-maker-notes'].forEach(function(id) {
                var el = document.getElementById(id); if (el) el.value = '';
            });
            document.getElementById('b2f-maker-currency').value = 'THB';
            document.getElementById('b2f-maker-credit-limit').value = '0';
            document.getElementById('b2f-maker-credit-term').value = '30';
            document.getElementById('b2f-maker-status').value = 'active';
        }

        /* ── Open Edit Modal ── */
        function openEdit(makerId) {
            document.getElementById('b2f-maker-modal-title').innerHTML = '<i class="fa-solid fa-pen" style="color:var(--accent-b2f);margin-right:8px;"></i>แก้ไขโรงงาน';
            clearMakerForm();

            api('GET', 'makers').then(function(res) {
                if (!res.success) return;
                var m = (res.data || []).find(function(x){ return x.id === makerId; });
                if (!m) { toast('ไม่พบโรงงาน', 'error'); return; }

                document.getElementById('b2f-maker-edit-id').value = m.id;
                document.getElementById('b2f-maker-name').value = m.name || '';
                document.getElementById('b2f-maker-contact').value = m.contact || '';
                document.getElementById('b2f-maker-phone').value = m.phone || '';
                document.getElementById('b2f-maker-email').value = m.email || '';
                document.getElementById('b2f-maker-address').value = m.address || '';
                document.getElementById('b2f-maker-tax-id').value = m.tax_id || '';
                document.getElementById('b2f-maker-bank-name').value = m.bank_name || '';
                document.getElementById('b2f-maker-bank-account').value = m.bank_account || '';
                document.getElementById('b2f-maker-bank-holder').value = m.bank_holder || '';
                document.getElementById('b2f-maker-bank-code').value = m.bank_code || '';
                document.getElementById('b2f-maker-currency').value = m.currency || 'THB';
                document.getElementById('b2f-maker-credit-limit').value = m.credit_limit || 0;
                document.getElementById('b2f-maker-credit-term').value = m.credit_term_days || 30;
                document.getElementById('b2f-maker-line-gid').value = m.line_group_id || '';
                document.getElementById('b2f-maker-status').value = m.status || 'active';
                document.getElementById('b2f-maker-notes').value = m.notes || '';

                openModal('b2f-modal-maker');
            });
        }

        /* ── Submit Maker ── */
        function submitMaker() {
            var name = document.getElementById('b2f-maker-name').value.trim();
            if (!name) { toast('กรุณากรอกชื่อโรงงาน', 'error'); return; }

            var btn = document.getElementById('b2f-maker-submit');
            setLoading(btn, true);

            var payload = {
                maker_name:    name,
                maker_contact: document.getElementById('b2f-maker-contact').value.trim(),
                maker_phone:   document.getElementById('b2f-maker-phone').value.trim(),
                maker_email:   document.getElementById('b2f-maker-email').value.trim(),
                maker_address: document.getElementById('b2f-maker-address').value.trim(),
                maker_tax_id:  document.getElementById('b2f-maker-tax-id').value.trim(),
                maker_bank_name:    document.getElementById('b2f-maker-bank-name').value.trim(),
                maker_bank_account: document.getElementById('b2f-maker-bank-account').value.trim(),
                maker_bank_holder:  document.getElementById('b2f-maker-bank-holder').value.trim(),
                maker_bank_code:    document.getElementById('b2f-maker-bank-code').value,
                maker_currency:     document.getElementById('b2f-maker-currency').value || 'THB',
                maker_credit_limit: parseFloat(document.getElementById('b2f-maker-credit-limit').value) || 0,
                maker_credit_term_days: parseInt(document.getElementById('b2f-maker-credit-term').value) || 30,
                maker_line_group_id: document.getElementById('b2f-maker-line-gid').value.trim(),
                maker_status:   document.getElementById('b2f-maker-status').value,
                maker_notes:    document.getElementById('b2f-maker-notes').value.trim()
            };

            var editId = document.getElementById('b2f-maker-edit-id').value;
            if (editId) payload.id = parseInt(editId);

            api('POST', 'maker', payload).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast(editId ? 'แก้ไขโรงงานสำเร็จ' : 'เพิ่มโรงงานสำเร็จ', 'success');
                    closeModal('b2f-modal-maker');
                    loadMakers();
                } else {
                    toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
                }
            }).catch(function(){ setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

        /* ── Products Management ── */
        function openProducts(makerId, makerName, makerCurrency) {
            _currentMakerId = makerId;
            _currentMakerName = makerName || '';
            _curMakerCurrency = makerCurrency || 'THB';
            _curMakerSymbol = {THB:'\u0E3F',CNY:'\u00A5',USD:'$'}[_curMakerCurrency] || _curMakerCurrency;
            document.getElementById('b2f-products-maker-name').textContent = makerName + (_curMakerCurrency !== 'THB' ? ' (' + _curMakerCurrency + ')' : '');
            // V.6.0: invalidate picker cache เมื่อเปลี่ยน maker (หลีกเลี่ยง existingSkus จาก maker เก่า)
            _b2bProducts = null;
            // V.6.3: reset audit state
            _sourceMap = {};
            _sourceData = {};           // V.6.4
            _productNameMap = {};       // V.6.4
            _blacklistForMaker = [];
            _sourceFilter = 'all';
            _selectedForDelete = {};
            _sourceSummary = { total: 0, cpt: 0, auto: 0, blacklisted: 0 };
            var tb = document.getElementById('b2f-audit-toolbar'); if (tb) tb.style.display = 'none';
            openModal('b2f-modal-products');
            loadProducts(makerId);
            // V.6.3: load source data in parallel (non-blocking — UI degrades gracefully if endpoint 404)
            loadSourceData(makerId);
        }

        // V.6.3: Option F — fetch junction source map for current maker
        // V.6.4: also cache full row payload (_sourceData) for flat list mode
        function loadSourceData(makerId) {
            auditApi('GET', 'maker-products-with-source/' + makerId).then(function(res) {
                if (!res || !res.success) return;
                var rows = res.data || [];
                _sourceMap = {};
                _sourceData = {}; // V.6.4
                rows.forEach(function(r){
                    var sk = String(r.product_sku || '').toUpperCase();
                    if (!sk) return;
                    _sourceMap[sk] = r.source || 'cpt';
                    _sourceData[sk] = r; // V.6.4: keep full row for flat list render
                });
                _blacklistForMaker = (res.blacklist_for_maker || []).map(function(s){ return String(s).toUpperCase(); });
                _sourceSummary = res.summary || { total: rows.length, cpt: 0, auto: 0, blacklisted: 0 };
                applySourceMeta();
            }).catch(function(err){
                // Silent fail — audit snippet may not be active. Toolbar stays hidden.
                if (window.console && console.warn) console.warn('[B2F Audit] source fetch failed:', err);
            });
        }

        // V.6.3: Stamp source badges + show toolbar + wire filter
        function applySourceMeta() {
            var tb = document.getElementById('b2f-audit-toolbar');
            if (!tb) return;
            if (_sourceSummary.total === 0) { tb.style.display = 'none'; return; }
            tb.style.display = 'flex';
            var summary = '📦 ' + (_sourceSummary.cpt||0) + ' registered + ✨ ' + (_sourceSummary.auto||0) + ' auto-synced';
            if (_blacklistForMaker.length) summary += '  <em>· blacklist: ' + _blacklistForMaker.length + '</em>';
            var se = document.getElementById('b2f-audit-summary'); if (se) se.innerHTML = summary;
            var ca = document.getElementById('b2f-audit-count-all'); if (ca) ca.textContent = _sourceSummary.total || 0;
            var cc = document.getElementById('b2f-audit-count-cpt'); if (cc) cc.textContent = _sourceSummary.cpt || 0;
            var cv = document.getElementById('b2f-audit-count-auto'); if (cv) cv.textContent = _sourceSummary.auto || 0;

            // Decorate each existing product row
            var rows = document.querySelectorAll('#b2f-products-list .b2f-sku-row[data-sku]');
            rows.forEach(function(row){
                var sk = (row.getAttribute('data-sku') || '').toUpperCase();
                var src = _sourceMap[sk] || null;
                // Remove previous badge + checkbox
                var oldBadge = row.querySelector('.b2f-src-badge'); if (oldBadge) oldBadge.remove();
                var oldCb = row.querySelector('.b2f-row-checkbox'); if (oldCb) oldCb.remove();

                if (!src) {
                    // Row not present in junction (CPT-only, pre-dual-write). Skip stamping.
                    row.setAttribute('data-src', 'unknown');
                    return;
                }
                row.setAttribute('data-src', src);
                // Insert source badge next to sku code
                var codeEl = row.querySelector('.sku-code');
                if (codeEl) {
                    var b = document.createElement('span');
                    b.className = 'b2f-src-badge src-' + src + (_blacklistForMaker.indexOf(sk) !== -1 ? ' bl' : '');
                    b.innerHTML = src === 'cpt' ? '<i class="fa-solid fa-box"></i> CPT' : '<i class="fa-solid fa-wand-magic-sparkles"></i> Auto';
                    if (_blacklistForMaker.indexOf(sk) !== -1) b.title = 'อยู่ใน blacklist';
                    codeEl.appendChild(b);
                }
                // Insert checkbox prefix in sku-info block (before thumb)
                var info = row.querySelector('.sku-info');
                if (info) {
                    var cb = document.createElement('input');
                    cb.type = 'checkbox'; cb.className = 'b2f-row-checkbox';
                    cb.setAttribute('data-sku', sk);
                    cb.setAttribute('data-src', src);
                    if (src !== 'auto') {
                        // Only auto-synced rows are bulk-deletable. CPT rows get disabled checkbox.
                        cb.disabled = true;
                        cb.title = 'CPT-registered — ลบผ่าน UI เดิม (ปุ่มถังขยะ)';
                    }
                    cb.addEventListener('change', function(){
                        if (this.checked) _selectedForDelete[sk] = true;
                        else delete _selectedForDelete[sk];
                        row.classList.toggle('src-selected', this.checked);
                        refreshBulkButton();
                    });
                    info.insertBefore(cb, info.firstChild);
                }
            });

            // V.6.5: Decorate SET accordion headers (Auto-synced SETs get 🗑️ ลบ SET button)
            //   SET header ใช้ class .b2f-set-header[data-sku] (NOT .b2f-sku-row[data-sku])
            //   เฉพาะ header ที่ _sourceMap[sku]==='auto' ได้ปุ่มลบ (CPT SET ไม่มีปุ่ม — ลบผ่าน WP admin)
            var setHeaders = document.querySelectorAll('#b2f-products-list .b2f-set-header[data-sku]');
            setHeaders.forEach(function(header){
                var sk = (header.getAttribute('data-sku') || '').toUpperCase();
                var src = _sourceMap[sk] || null;
                // Remove previous decoration
                var oldSetBadge = header.querySelector('.b2f-src-badge'); if (oldSetBadge) oldSetBadge.remove();
                var oldSetBtn = header.querySelector('.b2f-auto-set-delete'); if (oldSetBtn) oldSetBtn.remove();

                if (!src) {
                    header.setAttribute('data-src', 'unknown');
                    return;
                }
                header.setAttribute('data-src', src);
                // Insert source badge next to SET title (SKU code area)
                var titleEl = header.querySelector('.b2f-set-title');
                if (titleEl) {
                    var sb = document.createElement('span');
                    sb.className = 'b2f-src-badge src-' + src + (_blacklistForMaker.indexOf(sk) !== -1 ? ' bl' : '');
                    sb.innerHTML = src === 'cpt' ? '<i class="fa-solid fa-box"></i> CPT' : '<i class="fa-solid fa-wand-magic-sparkles"></i> Auto';
                    if (_blacklistForMaker.indexOf(sk) !== -1) sb.title = 'อยู่ใน blacklist';
                    titleEl.appendChild(document.createTextNode(' '));
                    titleEl.appendChild(sb);
                }
                // Insert 🗑️ ลบ SET button at the END of header (margin-left:auto pushes right)
                if (src === 'auto') {
                    var btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'b2f-auto-set-delete';
                    btn.setAttribute('data-sku', sk);
                    btn.title = 'ลบ SET ' + sk + ' (Auto-synced) + เพิ่ม blacklist';
                    btn.innerHTML = '<i class="fa-solid fa-trash"></i> ลบ SET';
                    btn.addEventListener('click', function(ev){
                        ev.stopPropagation(); // prevent toggleSet expand/collapse
                        ev.preventDefault();
                        deleteAutoSet(sk);
                    });
                    header.appendChild(btn);
                }
            });

            setSourceFilter(_sourceFilter); // re-apply filter visibility
            refreshBulkButton();
        }

        // V.6.5: Per-SET delete handler — 1-click UX for Auto-synced SET accordion headers.
        //   Reuses /junction-bulk-delete endpoint with single SKU + add_to_blacklist=true.
        //   Confirm dialog + toast + reload (products + source data).
        async function deleteAutoSet(sku) {
            sku = String(sku || '').toUpperCase();
            if (!sku) return;
            var makerLabel = (_currentMakerName || 'โรงงาน') + ' (ID ' + _currentMakerId + ')';
            var confirmMsg = 'ยืนยันลบ SET "' + sku + '" (Auto-synced)?\n\n' +
                             'โรงงาน: ' + makerLabel + '\n' +
                             '☑️ จะเพิ่ม SKU นี้เข้า blacklist (ป้องกัน auto-sync re-add ตอน backfill ครั้งต่อไป)\n\n' +
                             'กด OK เพื่อยืนยัน';
            // V.7.8 UX-C2: migrate to dinocoModal (fallback to native)
            var ok;
            try {
                ok = await window.dinocoModal.confirm({
                    title: 'ลบ SET (Auto-synced)',
                    message: confirmMsg,
                    confirmText: 'ลบ + blacklist',
                    cancelText: 'ยกเลิก',
                    danger: true
                });
            } catch (e) { ok = confirm(confirmMsg); }
            if (!ok) return;

            auditApi('POST', 'junction-bulk-delete', {
                maker_id: _currentMakerId,
                skus: [sku],
                add_to_blacklist: true,
                only_auto_synced: true,
                confirm: true
            }).then(function(res){
                if (!res || !res.success) {
                    toast('ลบไม่สำเร็จ: ' + ((res && res.message) || 'unknown'), 'error');
                    return;
                }
                var d = res.data || {};
                var msg = 'ลบ ' + sku + ' สำเร็จ';
                if (d.blacklisted) msg += ' + blacklist';
                if (d.skipped_cpt_protected) msg += ' (CPT ป้องกัน ' + d.skipped_cpt_protected + ')';
                toast(msg, 'success');
                // Reload products + source (auto count decrements, SET row disappears)
                _selectedForDelete = {};
                loadProducts(_currentMakerId);
                loadSourceData(_currentMakerId);
            }).catch(function(err){
                toast('ลบไม่สำเร็จ: ' + (err.message || err), 'error');
            });
        }

        // V.6.4: filter "auto" switches to flat list mode (every row has visible checkbox).
        //   filter "cpt" or "all" restore accordion (existing behavior) via loadProducts re-render.
        //   Fix bug V.6.3: SET accordion header ไม่ match `.b2f-sku-row[data-sku]` → checkbox ไม่ถูก insert.
        function setSourceFilter(src) {
            var prev = _sourceFilter;
            _sourceFilter = src || 'all';
            // Update chip active state
            document.querySelectorAll('.b2f-audit-chip').forEach(function(c){
                c.classList.toggle('active', c.getAttribute('data-src') === _sourceFilter);
            });
            // Reset select-all + selections when switching modes
            var sa = document.getElementById('b2f-audit-select-all'); if (sa) sa.checked = false;
            _selectedForDelete = {};

            if (_sourceFilter === 'auto') {
                // Flat list mode — render checkbox per Auto junction row (source='auto')
                renderAutoFlatList();
            } else {
                // Accordion mode — if coming from 'auto' flat list, re-render accordion via loadProducts
                if (prev === 'auto' && _currentMakerId) {
                    loadProducts(_currentMakerId); // re-render accordion; applySourceMeta will re-stamp badges
                } else {
                    // Already in accordion DOM — just hide/show sku rows
                    var rows = document.querySelectorAll('#b2f-products-list .b2f-sku-row[data-sku]');
                    rows.forEach(function(row){
                        var rs = row.getAttribute('data-src') || 'unknown';
                        var show = (_sourceFilter === 'all') || (rs === _sourceFilter);
                        row.classList.toggle('src-hidden', !show);
                    });
                }
            }
            refreshBulkButton();
        }

        // V.6.4: render Auto-synced rows as flat list with visible checkbox + badge + cost
        //   Data source: _sourceData (cached from loadSourceData API call).
        //   Enrich product_name via _productNameMap (cached from loadProducts).
        //   Bulk delete confirm/execute flow reused from V.6.3.
        function renderAutoFlatList() {
            var listEl = document.getElementById('b2f-products-list');
            if (!listEl) return;
            var autoSkus = Object.keys(_sourceData).filter(function(sk){
                return (_sourceData[sk] && _sourceData[sk].source === 'auto');
            });
            autoSkus.sort(); // alphabetical — deterministic order

            if (!autoSkus.length) {
                listEl.innerHTML = '<div class="b2f-auto-flat-empty"><i class="fa-solid fa-circle-check" style="font-size:28px;color:#16a34a;display:block;margin-bottom:8px;"></i>ไม่มีสินค้าที่ auto-synced จาก backfill สำหรับโรงงานนี้</div>';
                // Hide dirty/batch save bars (not relevant in Auto mode)
                var quickBar = document.getElementById('b2f-quick-bar'); if (quickBar) quickBar.style.display = 'none';
                var batchBar = document.getElementById('b2f-batch-save-bar'); if (batchBar) batchBar.style.display = 'none';
                return;
            }

            var sym = _curMakerSymbol || '\u0E3F';
            var hasNameCache = Object.keys(_productNameMap).length > 0;
            var html = '';
            html += '<div class="b2f-auto-flat-hint"><i class="fa-solid fa-wand-magic-sparkles"></i>';
            html += '<span><b>Auto-synced (' + autoSkus.length + ')</b> — SKUs ที่ Phase 2 backfill เพิ่มเข้า junction โดยอัตโนมัติ (orphan SET ที่ descendants register แต่ตัว SET ยังไม่ register). ติ๊กช่องเพื่อเลือกลบ + บันทึก blacklist ป้องกัน re-add.</span>';
            html += '</div>';
            html += '<div class="b2f-auto-flat-list">';
            autoSkus.forEach(function(sk){
                var r = _sourceData[sk] || {};
                var isBl = _blacklistForMaker.indexOf(sk) !== -1;
                var cost = parseFloat(r.unit_cost || 0);
                var moq = parseInt(r.moq || 1, 10);
                var name = (hasNameCache && _productNameMap[sk]) ? _productNameMap[sk] : '';
                var rowCls = 'b2f-auto-flat-row';
                if (_selectedForDelete[sk]) rowCls += ' src-selected';
                html += '<div class="' + rowCls + '" data-sku="' + esc(sk) + '" data-src="auto">';
                html += '<input type="checkbox" class="b2f-row-checkbox" data-sku="' + esc(sk) + '" data-src="auto"' + (_selectedForDelete[sk] ? ' checked' : '') + '>';
                html += '<span class="b2f-src-badge src-auto' + (isBl ? ' bl' : '') + '"><i class="fa-solid fa-wand-magic-sparkles"></i> Auto</span>';
                html += '<span class="af-sku">' + esc(sk) + '</span>';
                html += '<span class="af-name">' + esc(name || '(ไม่มีชื่อใน catalog)') + '</span>';
                html += '<span class="af-cost">' + esc(sym) + ' ' + cost.toFixed(2) + '</span>';
                html += '<span class="af-moq">MOQ ' + moq + '</span>';
                if (isBl) html += '<span class="af-bl" title="อยู่ใน blacklist">BL</span>';
                html += '<button class="af-del-btn" data-sku="' + esc(sk) + '" data-pid="' + (r.id || 0) + '"><i class="fa-solid fa-trash"></i> ลบ</button>';
                html += '</div>';
            });
            html += '</div>';
            listEl.innerHTML = html;

            // Hide dirty/batch save bars — not editable fields in flat list
            var quickBar = document.getElementById('b2f-quick-bar'); if (quickBar) quickBar.style.display = 'none';
            var batchBar = document.getElementById('b2f-batch-save-bar'); if (batchBar) batchBar.style.display = 'none';

            // Wire checkbox change events
            listEl.querySelectorAll('.b2f-row-checkbox').forEach(function(cb){
                cb.addEventListener('change', function(){
                    var sk = String(this.getAttribute('data-sku') || '').toUpperCase();
                    if (!sk) return;
                    if (this.checked) _selectedForDelete[sk] = true;
                    else delete _selectedForDelete[sk];
                    var row = this.closest('.b2f-auto-flat-row');
                    if (row) row.classList.toggle('src-selected', this.checked);
                    refreshBulkButton();
                });
            });
            // Wire per-row delete button (single SKU → reuse bulk-delete flow with 1 entry)
            listEl.querySelectorAll('.af-del-btn').forEach(function(btn){
                btn.addEventListener('click', function(){
                    var sk = String(this.getAttribute('data-sku') || '').toUpperCase();
                    if (!sk) return;
                    _selectedForDelete = {};
                    _selectedForDelete[sk] = true;
                    openBulkDeleteConfirm();
                });
            });
        }

        function toggleSelectAll(checked) {
            // V.6.4: support both flat list (.b2f-auto-flat-row) AND accordion (.b2f-sku-row) modes.
            //   Only auto-synced + visible rows (CPT rows stay protected by data-src attribute).
            var cbs = document.querySelectorAll('#b2f-products-list .b2f-row-checkbox[data-src="auto"]');
            cbs.forEach(function(cb){
                var row = cb.closest('.b2f-auto-flat-row') || cb.closest('.b2f-sku-row');
                if (row && !row.classList.contains('src-hidden')) {
                    cb.checked = checked;
                    var sk = String(cb.getAttribute('data-sku') || '').toUpperCase();
                    if (checked) _selectedForDelete[sk] = true;
                    else delete _selectedForDelete[sk];
                    row.classList.toggle('src-selected', checked);
                }
            });
            refreshBulkButton();
        }

        function refreshBulkButton() {
            var count = Object.keys(_selectedForDelete).length;
            var btn = document.getElementById('b2f-audit-bulk-btn');
            var cEl = document.getElementById('b2f-audit-selected-count');
            if (cEl) cEl.textContent = count;
            if (btn) btn.disabled = (count === 0);
        }

        function openBulkDeleteConfirm() {
            var skus = Object.keys(_selectedForDelete);
            if (skus.length === 0) return;
            var mkEl = document.getElementById('b2f-audit-del-maker');
            var cnEl = document.getElementById('b2f-audit-del-count');
            var lsEl = document.getElementById('b2f-audit-del-list');
            if (mkEl) mkEl.textContent = _currentMakerName + ' (ID ' + _currentMakerId + ')';
            if (cnEl) cnEl.textContent = skus.length;
            if (lsEl) lsEl.innerHTML = '<ul style="margin:0;padding-left:20px;">' + skus.map(function(s){ return '<li>' + esc(s) + '</li>'; }).join('') + '</ul>';
            var addBl = document.getElementById('b2f-audit-del-add-bl'); if (addBl) addBl.checked = true;
            openModal('b2f-modal-bulk-audit-delete');
        }

        function executeBulkDelete() {
            var skus = Object.keys(_selectedForDelete);
            if (skus.length === 0) return;
            var addBl = document.getElementById('b2f-audit-del-add-bl');
            var btn = document.getElementById('b2f-audit-del-confirm-btn');
            setLoading(btn, true);
            auditApi('POST', 'junction-bulk-delete', {
                maker_id: _currentMakerId,
                skus: skus,
                add_to_blacklist: !!(addBl && addBl.checked),
                only_auto_synced: true,
                confirm: true
            }).then(function(res){
                setLoading(btn, false);
                if (!res || !res.success) { toast('ลบไม่สำเร็จ: ' + ((res && res.message) || 'unknown'), 'error'); return; }
                var d = res.data || {};
                var msg = 'ลบ ' + (d.deleted || 0) + ' รายการ';
                if (d.blacklisted) msg += ' + blacklist ' + d.blacklisted + ' SKUs';
                if (d.skipped_cpt_protected) msg += ' (CPT ป้องกัน ' + d.skipped_cpt_protected + ')';
                toast(msg, 'success');
                closeModal('b2f-modal-bulk-audit-delete');
                // Reload products + source
                _selectedForDelete = {};
                loadProducts(_currentMakerId);
                loadSourceData(_currentMakerId);
            }).catch(function(err){
                setLoading(btn, false);
                toast('ลบไม่สำเร็จ: ' + (err.message || err), 'error');
            });
        }

        function openBlacklistViewer() {
            var body = document.getElementById('b2f-audit-bl-body');
            var meta = document.getElementById('b2f-audit-bl-meta');
            if (body) body.innerHTML = '<div class="b2f-loading"><div class="spinner"></div></div>';
            if (meta) meta.textContent = '';
            openModal('b2f-modal-blacklist-viewer');
            auditApi('GET', 'autosync-blacklist').then(function(res){
                if (!res || !res.success) { if (body) body.innerHTML = '<div class="b2f-empty">โหลดไม่สำเร็จ</div>'; return; }
                var d = res.data || {};
                renderBlacklistViewer(d);
            }).catch(function(err){
                if (body) body.innerHTML = '<div class="b2f-empty">' + esc(err.message || 'error') + '</div>';
            });
        }

        function renderBlacklistViewer(d) {
            var body = document.getElementById('b2f-audit-bl-body');
            var meta = document.getElementById('b2f-audit-bl-meta');
            if (meta) meta.textContent = 'ขนาด: ' + (d.size_bytes || 0) + ' / ' + (d.cap_bytes || 102400) + ' bytes';
            var enriched = d.enriched || [];
            if (!enriched.length) { if (body) body.innerHTML = '<div class="b2f-empty" style="padding:20px;text-align:center;color:#64748b;"><i class="fa-solid fa-circle-check" style="font-size:32px;color:#16a34a;margin-bottom:8px;"></i><br>ยังไม่มีรายการใน blacklist</div>'; return; }
            var html = '';
            enriched.forEach(function(m){
                html += '<div class="bl-maker-title">' + esc(m.maker_name || ('Maker ' + m.maker_id)) + ' <span style="color:#64748b;font-weight:500;font-size:11px;">(' + m.count + ' SKUs)</span></div>';
                (m.skus || []).forEach(function(sk){
                    html += '<div class="bl-item" data-mid="' + m.maker_id + '" data-sku="' + esc(sk) + '">';
                    html += '<span class="sku">' + esc(sk) + '</span>';
                    html += '<button data-action="makers-remove-blacklist">ปลด blacklist</button>';
                    html += '</div>';
                });
            });
            if (body) body.innerHTML = html;
        }

        function removeBlacklistEntry(makerId, sku, btn) {
            if (btn) { btn.disabled = true; btn.textContent = 'กำลังปลด...'; }
            auditApi('POST', 'autosync-blacklist', {
                maker_id: makerId, sku: sku, action: 'remove'
            }).then(function(res){
                if (!res || !res.success) { toast('ปลดไม่สำเร็จ', 'error'); if (btn) { btn.disabled=false; btn.textContent='ปลด blacklist'; } return; }
                toast('ปลด blacklist ' + sku + ' สำเร็จ', 'success');
                openBlacklistViewer(); // re-render
                // If we're viewing this maker, refresh source data so badge "bl" marker clears
                if (makerId === _currentMakerId) loadSourceData(_currentMakerId);
            }).catch(function(err){
                toast('ปลดไม่สำเร็จ: ' + (err.message || err), 'error');
                if (btn) { btn.disabled=false; btn.textContent='ปลด blacklist'; }
            });
        }

        function loadProducts(makerId) {
            var listEl = document.getElementById('b2f-products-list');
            listEl.innerHTML = '<div class="b2f-loading"><div class="spinner"></div></div>';
            var quickBar = document.getElementById('b2f-quick-bar');
            var batchBar = document.getElementById('b2f-batch-save-bar');
            if (quickBar) quickBar.style.display = 'none';
            if (batchBar) batchBar.style.display = 'none';

            api('GET', 'maker-products/' + makerId).then(function(res) {
                if (!res.success) { listEl.innerHTML = '<div class="b2f-empty">โหลดไม่สำเร็จ</div>'; return; }
                // V.6.2 (Issue #3): defensively filter out virtual SETs — Admin Makers tab ต้องโชว์เฉพาะ register จริง
                var products = (res.data || []).filter(function(p){ return p.is_virtual !== true; });
                _lastHierarchyMeta = res.hierarchy_meta || {}; // V.9.2: store for addMissingLeaves
