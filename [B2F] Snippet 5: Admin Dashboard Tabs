    <!-- Toast -->
    <div class="b2f-toast" id="b2f-makers-toast"></div>

    <script>
    (function(){
        'use strict';

        var API_BASE = '<?php echo esc_url( rest_url( 'b2f/v1/' ) ); ?>';
        var NONCE    = '<?php echo $nonce; ?>';
        var _searchTimer = null;
        var _currentMakerId = null;
        var _curMakerCurrency = 'THB';
        var _curMakerSymbol = '\u0E3F';

        function api(method, endpoint, body) {
            var opts = { method: method, headers: { 'X-WP-Nonce': NONCE } };
            if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
            return fetch(API_BASE + endpoint, opts).then(function(r){
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            });
        }
        function fmt(n) { return new Intl.NumberFormat('th-TH',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n||0); }
        function esc(s) { var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }
        function toast(msg, type) {
            var el = document.getElementById('b2f-makers-toast');
            el.textContent = msg; el.className = 'b2f-toast ' + (type||'info') + ' show';
            var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
            _st(function(){ el.classList.remove('show'); }, 3500);
        }
        function setLoading(btn, loading) {
            if (!btn) return;
            if (loading) { btn.disabled=true; btn.dataset.origText=btn.innerHTML; btn.innerHTML='<div class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;"></div> บันทึก...'; }
            else { btn.disabled=false; btn.innerHTML=btn.dataset.origText||btn.innerHTML; }
        }
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        /* ── Load Makers ── */
        function loadMakers() {
            var listEl = document.getElementById('b2f-maker-list');
            listEl.innerHTML = '<div class="b2f-loading"><div class="spinner"></div><br>กำลังโหลด...</div>';

            api('GET', 'makers').then(function(res) {
                if (!res.success) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-circle-exclamation"></i>โหลดไม่สำเร็จ</div>'; return; }
                var makers = res.data || [];

                // Apply filters
                var search = (document.getElementById('b2f-maker-search').value || '').toLowerCase();
                var statusFilter = document.getElementById('b2f-maker-status-filter').value;
                makers = makers.filter(function(m) {
                    if (statusFilter && m.status !== statusFilter) return false;
                    if (search && (m.name || '').toLowerCase().indexOf(search) === -1) return false;
                    return true;
                });

                if (!makers.length) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-building"></i>ไม่พบโรงงาน</div>'; return; }

                var html = '';
                makers.forEach(function(m) {
                    var statusBadge = m.status === 'active'
                        ? '<span class="b2f-badge b2f-badge-green">Active</span>'
                        : '<span class="b2f-badge b2f-badge-gray">Inactive</span>';
                    var holdBadge = m.credit_hold ? ' <span class="b2f-badge b2f-badge-red">Credit Hold</span>' : '';

                    html += '<div class="b2f-maker-card">';
                    var curBadge = (m.currency && m.currency !== 'THB') ? ' <span class="b2f-badge" style="background:#dbeafe;color:#1d4ed8;font-size:10px;padding:1px 6px;">' + esc(m.currency) + '</span>' : '';
                    html += '<div class="b2f-maker-card-header"><span class="b2f-maker-name">' + esc(m.name) + curBadge + '</span><div>' + statusBadge + holdBadge + '</div></div>';
                    html += '<div class="b2f-maker-info">';
                    html += 'สินค้า: <strong>' + (m.product_count || 0) + '</strong> SKU | PO: <strong>' + (m.po_count || 0) + '</strong> ใบ<br>';
                    html += 'ค้างจ่าย: <strong style="color:' + ((m.current_debt||0) > 0 ? '#dc2626' : 'inherit') + ';">\u0E3F' + fmt(m.current_debt) + '</strong>';
                    if (m.contact) html += ' | ติดต่อ: ' + esc(m.contact);
                    html += '</div>';
                    html += '<div class="b2f-maker-actions">';
                    html += '<button class="b2f-btn b2f-btn-secondary" onclick="B2F_Makers.openEdit(' + m.id + ')"><i class="fa-solid fa-pen"></i> แก้ไข</button>';
                    html += '<button class="b2f-btn b2f-btn-secondary" onclick="B2F_Makers.openProducts(' + m.id + ',\'' + esc(m.name).replace(/'/g,"\\'") + '\',\'' + esc(m.currency || 'THB') + '\')"><i class="fa-solid fa-boxes-stacked"></i> จัดการสินค้า+ราคาทุน</button>';
                    html += '<button class="b2f-btn" style="color:#dc2626;border-color:#dc2626;" onclick="B2F_Makers.deleteMaker(' + m.id + ',\'' + esc(m.name).replace(/'/g,"\\'") + '\')"><i class="fa-solid fa-trash"></i> ลบ</button>';
                    html += '</div></div>';
                });
                listEl.innerHTML = html;
            });
        }

        /* ── Open Create Modal ── */
        function openCreateModal() {
            document.getElementById('b2f-maker-edit-id').value = '';
            document.getElementById('b2f-maker-modal-title').innerHTML = '<i class="fa-solid fa-building" style="color:var(--accent-b2f);margin-right:8px;"></i>เพิ่มโรงงานใหม่';
            clearMakerForm();
            openModal('b2f-modal-maker');
        }

        function clearMakerForm() {
            ['b2f-maker-name','b2f-maker-contact','b2f-maker-phone','b2f-maker-email','b2f-maker-address',
             'b2f-maker-tax-id','b2f-maker-bank-name','b2f-maker-bank-account','b2f-maker-bank-holder',
             'b2f-maker-line-gid','b2f-maker-notes'].forEach(function(id) {
                var el = document.getElementById(id); if (el) el.value = '';
            });
            document.getElementById('b2f-maker-currency').value = 'THB';
            document.getElementById('b2f-maker-credit-limit').value = '0';
            document.getElementById('b2f-maker-credit-term').value = '30';
            document.getElementById('b2f-maker-status').value = 'active';
        }

        /* ── Open Edit Modal ── */
        function openEdit(makerId) {
            document.getElementById('b2f-maker-modal-title').innerHTML = '<i class="fa-solid fa-pen" style="color:var(--accent-b2f);margin-right:8px;"></i>แก้ไขโรงงาน';
            clearMakerForm();

            api('GET', 'makers').then(function(res) {
                if (!res.success) return;
                var m = (res.data || []).find(function(x){ return x.id === makerId; });
                if (!m) { toast('ไม่พบโรงงาน', 'error'); return; }

                document.getElementById('b2f-maker-edit-id').value = m.id;
                document.getElementById('b2f-maker-name').value = m.name || '';
                document.getElementById('b2f-maker-contact').value = m.contact || '';
                document.getElementById('b2f-maker-phone').value = m.phone || '';
                document.getElementById('b2f-maker-email').value = m.email || '';
                document.getElementById('b2f-maker-address').value = m.address || '';
                document.getElementById('b2f-maker-tax-id').value = m.tax_id || '';
                document.getElementById('b2f-maker-bank-name').value = m.bank_name || '';
                document.getElementById('b2f-maker-bank-account').value = m.bank_account || '';
                document.getElementById('b2f-maker-bank-holder').value = m.bank_holder || '';
                document.getElementById('b2f-maker-bank-code').value = m.bank_code || '';
                document.getElementById('b2f-maker-currency').value = m.currency || 'THB';
                document.getElementById('b2f-maker-credit-limit').value = m.credit_limit || 0;
                document.getElementById('b2f-maker-credit-term').value = m.credit_term_days || 30;
                document.getElementById('b2f-maker-line-gid').value = m.line_group_id || '';
                document.getElementById('b2f-maker-status').value = m.status || 'active';
                document.getElementById('b2f-maker-notes').value = m.notes || '';

                openModal('b2f-modal-maker');
            });
        }

        /* ── Submit Maker ── */
        function submitMaker() {
            var name = document.getElementById('b2f-maker-name').value.trim();
            if (!name) { toast('กรุณากรอกชื่อโรงงาน', 'error'); return; }

            var btn = document.getElementById('b2f-maker-submit');
            setLoading(btn, true);

            var payload = {
                maker_name:    name,
                maker_contact: document.getElementById('b2f-maker-contact').value.trim(),
                maker_phone:   document.getElementById('b2f-maker-phone').value.trim(),
                maker_email:   document.getElementById('b2f-maker-email').value.trim(),
                maker_address: document.getElementById('b2f-maker-address').value.trim(),
                maker_tax_id:  document.getElementById('b2f-maker-tax-id').value.trim(),
                maker_bank_name:    document.getElementById('b2f-maker-bank-name').value.trim(),
                maker_bank_account: document.getElementById('b2f-maker-bank-account').value.trim(),
                maker_bank_holder:  document.getElementById('b2f-maker-bank-holder').value.trim(),
                maker_bank_code:    document.getElementById('b2f-maker-bank-code').value,
                maker_currency:     document.getElementById('b2f-maker-currency').value || 'THB',
                maker_credit_limit: parseFloat(document.getElementById('b2f-maker-credit-limit').value) || 0,
                maker_credit_term_days: parseInt(document.getElementById('b2f-maker-credit-term').value) || 30,
                maker_line_group_id: document.getElementById('b2f-maker-line-gid').value.trim(),
                maker_status:   document.getElementById('b2f-maker-status').value,
                maker_notes:    document.getElementById('b2f-maker-notes').value.trim()
            };

            var editId = document.getElementById('b2f-maker-edit-id').value;
            if (editId) payload.id = parseInt(editId);

            api('POST', 'maker', payload).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast(editId ? 'แก้ไขโรงงานสำเร็จ' : 'เพิ่มโรงงานสำเร็จ', 'success');
                    closeModal('b2f-modal-maker');
                    loadMakers();
                } else {
                    toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
                }
            }).catch(function(){ setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

        /* ── Products Management ── */
        function openProducts(makerId, makerName, makerCurrency) {
            _currentMakerId = makerId;
            _curMakerCurrency = makerCurrency || 'THB';
            _curMakerSymbol = {THB:'\u0E3F',CNY:'\u00A5',USD:'$'}[_curMakerCurrency] || _curMakerCurrency;
            document.getElementById('b2f-products-maker-name').textContent = makerName + (_curMakerCurrency !== 'THB' ? ' (' + _curMakerCurrency + ')' : '');
            openModal('b2f-modal-products');
            loadProducts(makerId);
        }

        function loadProducts(makerId) {
            var listEl = document.getElementById('b2f-products-list');
            listEl.innerHTML = '<div class="b2f-loading"><div class="spinner"></div></div>';
            var quickBar = document.getElementById('b2f-quick-bar');
            var batchBar = document.getElementById('b2f-batch-save-bar');
            if (quickBar) quickBar.style.display = 'none';
            if (batchBar) batchBar.style.display = 'none';

            api('GET', 'maker-products/' + makerId).then(function(res) {
                if (!res.success) { listEl.innerHTML = '<div class="b2f-empty">โหลดไม่สำเร็จ</div>'; return; }
                var products = res.data || [];
                if (!products.length) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-box-open"></i>ยังไม่มีสินค้า -- กด "เพิ่มสินค้า" เพื่อเริ่มต้น</div>'; return; }

                // Show quick bar
                if (quickBar) quickBar.style.display = 'flex';

                var sym = _curMakerSymbol || '\u0E3F';
                // Column headers
                var html = '<div class="b2f-sku-header">';
                html += '<span style="flex:1;min-width:200px;">สินค้า</span>';
                html += '<span style="width:65px;text-align:center;">ราคาทุน (' + esc(sym) + ')</span>';
                html += '<span style="width:50px;text-align:center;">MOQ</span>';
                html += '<span style="width:55px;text-align:center;">ผลิต</span>';
                html += '<span style="width:55px;text-align:center;">รถ (วัน)</span>';
                html += '<span style="width:55px;text-align:center;">เรือ (วัน)</span>';
                html += '<span style="width:65px;text-align:center;">ค่าส่ง/รถ</span>';
                html += '<span style="width:65px;text-align:center;">ค่าส่ง/เรือ</span>';
                html += '<span style="width:30px;"></span>';
                html += '</div>';

                products.forEach(function(p) {
                    var cost = String(p.unit_cost || 0);
                    var moq = String(p.moq || 1);
                    var leadProd = String(p.lead_time_days || 7);
                    var leadLand = String(p.lead_land || 0);
                    var leadSea = String(p.lead_sea || 0);
                    var shipLand = String(p.shipping_land || 0);
                    var shipSea = String(p.shipping_sea || 0);
                    var img = p.image_url || p.thumbnail || '';
                    var skuEsc = esc(p.sku || '');
                    var nameEsc = esc(p.product_name || '');

                    html += '<div class="b2f-sku-row" data-pid="' + p.id + '" data-sku="' + skuEsc + '" data-name="' + nameEsc + '">';
                    html += '<div class="sku-info">';
                    if (img) {
                        html += '<img class="sku-thumb" src="' + esc(img) + '" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">';
                        html += '<div class="sku-thumb-placeholder" style="display:none;"><i class="fa-solid fa-box"></i></div>';
                    } else {
                        html += '<div class="sku-thumb-placeholder"><i class="fa-solid fa-box"></i></div>';
                    }
                    // V.3.6 Hierarchy: product type badge
                    var ptBadge = '';
                    if (p.product_type === 'set') ptBadge = '<span style="display:inline-block;padding:0 5px;border-radius:4px;font-size:9px;font-weight:700;background:#ede9fe;color:#7c3aed;margin-left:6px;">ชุด ' + (p.children_count||'') + ' ชิ้น</span>';
                    else if (p.product_type === 'child') ptBadge = '<span style="display:inline-block;padding:0 5px;border-radius:4px;font-size:9px;font-weight:700;background:#dbeafe;color:#2563eb;margin-left:6px;">ชิ้นส่วน</span>';
                    else if (p.product_type === 'grandchild') ptBadge = '<span style="display:inline-block;padding:0 5px;border-radius:4px;font-size:9px;font-weight:700;background:#dcfce7;color:#16a34a;margin-left:6px;">ชิ้นส่วนย่อย</span>';
                    html += '<div><div class="sku-code">' + skuEsc + ptBadge + '</div>';
                    html += '<div class="sku-name" title="' + nameEsc + '">' + nameEsc + '</div></div>';
                    html += '</div>';
                    html += '<input class="sku-inp" type="number" data-field="unit_cost" data-original="' + cost + '" value="' + cost + '" step="0.01" min="0" oninput="B2F_Makers.checkDirty(this)">';
