                if (['completed','cancelled'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-secondary" onclick="closeModal(\'b2f-modal-detail\');B2F_Orders.reorderPO(' + po.id + ')"><i class="fa-solid fa-rotate"></i> สั่งซ้ำ</button>';
                }
                actions += '</div>';
                html += actions;

                body.innerHTML = html;
            });
        }

        /* ── Delete PO ── */
        function cancelPO(poId, poNumber) {
            if (!confirm('ยืนยันลบใบสั่งซื้อ ' + poNumber + ' ออกจากระบบ?\n\n⚠️ ลบแล้วกู้คืนไม่ได้')) return;
            var reason = prompt('เหตุผลที่ลบ:');
            if (reason === null) return;

            api('POST', 'po-cancel', { po_id: poId, reason: reason }).then(function(res) {
                if (res.success) {
                    toast('ลบ ' + (res.po_number || poNumber) + ' สำเร็จ — แจ้งโรงงานแล้ว', 'success');
                    loadStats();
                    loadOrders();
                } else {
                    toast(res.error || 'ลบไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── G-01: Edit PO (แก้ไข → amend → auto-resubmit) ── */
        function editPO(poId) {
            api('GET', 'po-detail/' + poId).then(function(res) {
                if (!res.success || !res.data) { toast('โหลดข้อมูลไม่สำเร็จ', 'error'); return; }
                var po = res.data;
                openModal('b2f-modal-create-po');
                var makerSel = document.getElementById('b2f-create-maker');
                if (makerSel && po.maker_id) {
                    makerSel.value = String(po.maker_id);
                    // B-03 fix: ใช้ .then() แทน setTimeout — รอ products load เสร็จจริง
                    loadMakerProducts().then(function() {
                        if (po.items && po.items.length) {
                            po.items.forEach(function(item) {
                                var rows = document.querySelectorAll('#b2f-create-sku-list .b2f-sku-row');
                                rows.forEach(function(row) {
                                    if (row.dataset.sku === item.sku) {
                                        var inp = row.querySelector('input[type="number"]');
                                        if (inp) inp.value = item.qty_ordered || 0;
                                    }
                                });
                            });
                            recalcTotal();
                        }
                        var submitBtn = document.getElementById('b2f-create-submit');
                        if (submitBtn) {
                            submitBtn.textContent = '💾 บันทึกการแก้ไข';
                            submitBtn.dataset.editPoId = poId;
                        }
                        var noteInput = document.getElementById('b2f-create-note');
                        if (noteInput && po.admin_note) noteInput.value = po.admin_note;
                    });
                }
            });
        }

        /* ── G-02: Resubmit rejected PO (ส่งใหม่โดยไม่แก้ไข) ── */
        function resubmitPO(poId, poNumber) {
            if (!confirm('ส่ง PO ' + poNumber + ' ไป Maker ใหม่?')) return;
            api('POST', 'po-update', { po_id: poId, resubmit_only: true }).then(function(res) {
                if (res.success) {
                    toast('ส่ง PO ใหม่สำเร็จ', 'success');
                    loadStats(); loadOrders();
                } else {
                    toast(res.error || 'ส่งใหม่ไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── G-04: Reject Lot (delivering → confirmed) ── */
        function rejectLot(poId, poNumber) {
            if (!confirm('ปฏิเสธสินค้าทั้ง lot ของ ' + poNumber + '?\nMaker จะต้องจัดส่งใหม่')) return;
            var reason = prompt('เหตุผลที่ reject:');
            if (reason === null) return;

            api('POST', 'reject-lot', { po_id: poId, reason: reason }).then(function(res) {
                if (res.success) {
                    toast('Reject Lot สำเร็จ — PO กลับสถานะ confirmed', 'success');
                    loadStats(); loadOrders();
                } else {
                    toast(res.error || 'Reject ไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── G-05: Complete PO (received → completed, ของฟรี/sample) ── */
        function completePO(poId, poNumber) {
            if (!confirm('ปิด PO ' + poNumber + ' โดยไม่จ่ายเงิน?\n(สำหรับสินค้าตัวอย่าง/ของฟรี)')) return;
            var note = prompt('หมายเหตุ (optional):') || 'ปิด PO — ไม่ต้องชำระ';

            api('POST', 'po-complete', { po_id: poId, note: note }).then(function(res) {
                if (res.success) {
                    toast('ปิด PO สำเร็จ', 'success');
                    loadStats(); loadOrders();
                } else {
                    toast(res.error || 'ปิด PO ไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── Reorder (สั่งซ้ำ) ── */
        function reorderPO(poId) {
            // ดึงข้อมูล PO เดิม แล้วเปิด form สร้าง PO ใหม่ pre-fill
            api('GET', 'po-detail/' + poId).then(function(res) {
                if (!res.success || !res.data) { toast('โหลดข้อมูล PO ไม่สำเร็จ', 'error'); return; }
                var po = res.data;
                // เปิด form สร้าง PO
                openModal('b2f-modal-create-po');
                // Pre-fill maker
                var makerSel = document.getElementById('b2f-create-maker');
                if (makerSel && po.maker_id) {
                    makerSel.value = String(po.maker_id);
                    // B-04 fix: ใช้ .then() แทน setTimeout
                    loadMakerProducts().then(function() {
                        if (po.items && po.items.length) {
                            po.items.forEach(function(item) {
                                var rows = document.querySelectorAll('#b2f-create-sku-list .b2f-sku-row');
                                rows.forEach(function(row) {
                                    if (row.dataset.sku === item.sku) {
                                        var inp = row.querySelector('input[type="number"]');
                                        if (inp) inp.value = item.qty_ordered || item.qty || 0;
                                    }
                                });
                            });
                            recalcTotal();
                            toast('โหลดรายการจาก ' + (po.po_number || 'PO เดิม') + ' แล้ว — ตรวจสอบจำนวน+ราคาก่อนสั่ง', 'info');
                        }
                    });
                }
            }).catch(function() { toast('โหลดข้อมูลไม่สำเร็จ', 'error'); });
        }

        /* ── Bulk Cancel: Update action bar ── */
        function updateBulkBar() {
            var checked = document.querySelectorAll('.b2f-po-checkbox:checked');
            var bar = document.getElementById('b2f-bulk-bar');
            var countEl = document.getElementById('b2f-bulk-count');
            var toggleBtn = document.getElementById('b2f-bulk-toggle');
            if (checked.length > 0) {
                bar.classList.add('show');
                countEl.textContent = 'เลือก ' + checked.length + ' รายการ';
                var allCheckboxes = document.querySelectorAll('.b2f-po-checkbox');
                var allChecked = checked.length === allCheckboxes.length;
                toggleBtn.innerHTML = allChecked
                    ? '<i class="fa-solid fa-times"></i> ยกเลิกทั้งหมด'
                    : '<i class="fa-solid fa-check-double"></i> เลือกทั้งหมด';
            } else {
                bar.classList.remove('show');
            }
        }

        /* ── Bulk Cancel: Select/Deselect all ── */
        function bulkSelectAll() {
            var allCheckboxes = document.querySelectorAll('.b2f-po-checkbox');
            var checked = document.querySelectorAll('.b2f-po-checkbox:checked');
            var shouldCheck = checked.length < allCheckboxes.length;
            allCheckboxes.forEach(function(cb) { cb.checked = shouldCheck; });
            updateBulkBar();
        }

        /* ── Bulk Cancel: Get selected PO data ── */
        function getSelectedPOs() {
            var selected = [];
            document.querySelectorAll('.b2f-po-checkbox:checked').forEach(function(cb) {
                var card = cb.closest('.b2f-po-card');
                if (card) {
                    selected.push({
                        id: parseInt(card.dataset.poId),
                        po_number: card.dataset.poNumber || '-',
                        status: card.dataset.poStatus || '-',
                        maker: card.dataset.poMaker || '-'
                    });
                }
            });
            return selected;
        }

        /* ── Bulk Cancel: Open confirmation modal ── */
        function openBulkCancelModal() {
            var selected = getSelectedPOs();
            if (!selected.length) { toast('กรุณาเลือก PO อย่างน้อย 1 รายการ', 'error'); return; }

            var listEl = document.getElementById('b2f-bulk-cancel-list');
            var html = '';
            selected.forEach(function(po) {
                var badgeCls = STATUS_BADGE[po.status] || 'b2f-badge-gray';
                var label = STATUS_LABELS[po.status] || po.status;
                html += '<div class="b2f-bulk-cancel-item">';
                html += '<div><strong>' + esc(po.po_number) + '</strong><span style="margin-left:8px;color:var(--c-text-dim,#64748b);font-size:12px;">' + esc(po.maker) + '</span></div>';
                html += '<span class="b2f-badge ' + badgeCls + '">' + label + '</span>';
                html += '</div>';
            });
            listEl.innerHTML = html;

            document.getElementById('b2f-bulk-cancel-reason').value = '';
            document.getElementById('b2f-bulk-progress').style.display = 'none';
            document.getElementById('b2f-bulk-cancel-submit').disabled = false;
            document.getElementById('b2f-bulk-cancel-submit-text').textContent = 'ยืนยันลบ ' + selected.length + ' รายการ';

            openModal('b2f-modal-bulk-cancel');
        }

        /* ── Bulk Cancel: Execute sequential cancel ── */
        function executeBulkCancel() {
            var reason = document.getElementById('b2f-bulk-cancel-reason').value.trim();
            if (!reason) { toast('กรุณากรอกเหตุผลที่ลบ', 'error'); return; }

            var selected = getSelectedPOs();
            if (!selected.length) { toast('ไม่มี PO ที่เลือก', 'error'); return; }

            var btn = document.getElementById('b2f-bulk-cancel-submit');
            btn.disabled = true;
            btn.innerHTML = '<div class="spinner" style="width:14px;height:14px;border-width:2px;display:inline-block;vertical-align:middle;"></div> กำลังยกเลิก...';

            var progressWrap = document.getElementById('b2f-bulk-progress');
            var progressFill = document.getElementById('b2f-bulk-progress-fill');
            var progressText = document.getElementById('b2f-bulk-progress-text');
            progressWrap.style.display = 'block';
            progressFill.style.width = '0%';

            var total = selected.length;
            var done = 0;
            var successCount = 0;
            var failCount = 0;
            var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;

            function cancelNext() {
                if (done >= total) {
                    // Finish
                    closeModal('b2f-modal-bulk-cancel');
                    // Uncheck all
                    document.querySelectorAll('.b2f-po-checkbox:checked').forEach(function(cb) { cb.checked = false; });
                    updateBulkBar();
                    loadStats();
                    loadOrders();
                    toast('ลบสำเร็จ ' + successCount + '/' + total + ' รายการ' + (failCount > 0 ? ' (ล้มเหลว ' + failCount + ')' : ''), successCount > 0 ? 'success' : 'error');
                    return;
                }

                var po = selected[done];
                progressText.textContent = (done + 1) + ' / ' + total + ' — ' + po.po_number;
                progressFill.style.width = Math.round(((done + 1) / total) * 100) + '%';

                api('POST', 'po-cancel', { po_id: po.id, reason: reason }).then(function(res) {
                    if (res.success) { successCount++; } else { failCount++; }
                    done++;
                    _st(cancelNext, 300);
                }).catch(function() {
                    failCount++;
                    done++;
                    _st(cancelNext, 300);
                });
            }

            cancelNext();
        }

        /* ── Modal helpers ── */
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        /* ── Tab filter ── */
        function filterByTab(status) {
            _currentTab = status;
            _currentPage = 1;
            document.querySelectorAll('.b2f-status-tab').forEach(function(t) {
                t.classList.toggle('active', t.dataset.status === status);
            });
            loadOrders();
        }

        function applyFilters() {
            _currentPage = 1;
            loadOrders();
        }

        function debounceSearch() {
            clearTimeout(_searchTimer);
            _searchTimer = setTimeout(function(){ applyFilters(); }, 400);
        }

        function goPage(p) { _currentPage = p; loadOrders(); }

        /* ── Auto-refresh ── */
        function startRefresh() {
            _refreshTimer = setInterval(function() {
                loadStats();
                loadOrders();
            }, 60000);
        }

        /* ── Backdrop click to close ── */
        document.querySelectorAll('.b2f-modal-backdrop').forEach(function(bd) {
            bd.addEventListener('click', function(e) {
                if (e.target === bd) bd.classList.remove('open');
            });
        });
        /* ── N6/M8 — Audit fix: ESC closes top modal, bound once per page load ── */
        if (!window._b2fEscBound) {
            window._b2fEscBound = true;
            document.addEventListener('keydown', function(e) {
                if (e.key !== 'Escape' && e.keyCode !== 27) return;
                var opens = document.querySelectorAll('.b2f-modal-backdrop.open');
                if (!opens.length) return;
                opens[opens.length - 1].classList.remove('open');
            });
        }

        /* ── Init ── */
        function init() {
            loadMakers();
            loadStats();
            loadOrders();
            startRefresh();
        }

        /* ── Go to PO Ticket View (LIFF or browser) ── */
        function goToTicket(poId) {
            var url = TICKET_BASE + '?po_id=' + poId;
            window.open(url, '_blank');
        }

        /* ── Public API ── */
        window.B2F_Orders = {
            goToTicket: goToTicket,
            init: init,
            filterByTab: filterByTab,
            applyFilters: applyFilters,
            debounceSearch: debounceSearch,
            goPage: goPage,
            openCreateModal: function(){ openModal('b2f-modal-create-po'); },
            closeModal: closeModal,
            loadMakerProducts: loadMakerProducts,
            adjustQty: adjustQty,
            recalcTotal: recalcTotal,
            submitCreatePO: submitCreatePO,
            openReceive: openReceive,
            submitReceive: submitReceive,
            openPayment: openPayment,
            submitPayment: submitPayment,
            openDetail: openDetail,
            cancelPO: cancelPO,
            reorderPO: reorderPO,
            editPO: editPO,
            resubmitPO: resubmitPO,
            rejectLot: rejectLot,
            completePO: completePO,
            updateBulkBar: updateBulkBar,
            bulkSelectAll: bulkSelectAll,
            openBulkCancelModal: openBulkCancelModal,
            executeBulkCancel: executeBulkCancel
        };

        // Auto-init when visible
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

    })();
    </script>
    <?php
    return ob_get_clean();
});


