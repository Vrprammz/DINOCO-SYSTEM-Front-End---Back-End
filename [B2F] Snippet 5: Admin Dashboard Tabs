        /* ── Submit Maker ── */
        function submitMaker() {
            var name = document.getElementById('b2f-maker-name').value.trim();
            if (!name) { toast('กรุณากรอกชื่อโรงงาน', 'error'); return; }

            var btn = document.getElementById('b2f-maker-submit');
            setLoading(btn, true);

            var payload = {
                maker_name:    name,
                maker_contact: document.getElementById('b2f-maker-contact').value.trim(),
                maker_phone:   document.getElementById('b2f-maker-phone').value.trim(),
                maker_email:   document.getElementById('b2f-maker-email').value.trim(),
                maker_address: document.getElementById('b2f-maker-address').value.trim(),
                maker_tax_id:  document.getElementById('b2f-maker-tax-id').value.trim(),
                maker_bank_name:    document.getElementById('b2f-maker-bank-name').value.trim(),
                maker_bank_account: document.getElementById('b2f-maker-bank-account').value.trim(),
                maker_bank_holder:  document.getElementById('b2f-maker-bank-holder').value.trim(),
                maker_credit_limit: parseFloat(document.getElementById('b2f-maker-credit-limit').value) || 0,
                maker_credit_term_days: parseInt(document.getElementById('b2f-maker-credit-term').value) || 30,
                maker_line_group_id: document.getElementById('b2f-maker-line-gid').value.trim(),
                maker_status:   document.getElementById('b2f-maker-status').value,
                maker_notes:    document.getElementById('b2f-maker-notes').value.trim()
            };

            var editId = document.getElementById('b2f-maker-edit-id').value;
            if (editId) payload.id = parseInt(editId);

            api('POST', 'maker', payload).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast(editId ? 'แก้ไขโรงงานสำเร็จ' : 'เพิ่มโรงงานสำเร็จ', 'success');
                    closeModal('b2f-modal-maker');
                    loadMakers();
                } else {
                    toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
                }
            }).catch(function(){ setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

        /* ── Products Management ── */
        function openProducts(makerId, makerName) {
            _currentMakerId = makerId;
            document.getElementById('b2f-products-maker-name').textContent = makerName;
            openModal('b2f-modal-products');
            loadProducts(makerId);
        }

        function loadProducts(makerId) {
            var listEl = document.getElementById('b2f-products-list');
            listEl.innerHTML = '<div class="b2f-loading"><div class="spinner"></div></div>';

            api('GET', 'maker-products/' + makerId).then(function(res) {
                if (!res.success) { listEl.innerHTML = '<div class="b2f-empty">โหลดไม่สำเร็จ</div>'; return; }
                var products = res.data || [];
                if (!products.length) { listEl.innerHTML = '<div class="b2f-empty"><i class="fa-solid fa-box-open"></i>ยังไม่มีสินค้า -- กด "เพิ่ม SKU" เพื่อเริ่มต้น</div>'; return; }

                var html = '';
                products.forEach(function(p) {
                    html += '<div class="b2f-sku-item" data-product-id="' + p.id + '">';
                    html += '<div class="sku-info"><div class="sku-code">' + esc(p.sku) + '</div>';
                    html += '<div class="sku-name">' + esc(p.product_name || '') + '</div></div>';
                    html += '<div class="sku-cost">\u0E3F' + fmt(p.unit_cost) + '</div>';
                    html += '<div style="font-size:12px;color:var(--c-text-dim);white-space:nowrap;">MOQ:' + (p.moq||1) + ' | Lead:' + (p.lead_time_days||7) + 'วัน</div>';
                    html += '<div style="display:flex;gap:6px;">';
                    html += '<button class="b2f-btn b2f-btn-secondary" style="padding:4px 10px;font-size:11px;" onclick="B2F_Makers.editProduct(' + p.id + ')"><i class="fa-solid fa-pen"></i></button>';
                    html += '<button class="b2f-btn b2f-btn-danger" style="padding:4px 10px;font-size:11px;" onclick="B2F_Makers.deleteProduct(' + p.id + ',\'' + esc(p.sku).replace(/'/g,"\\'") + '\')"><i class="fa-solid fa-trash"></i></button>';
                    html += '</div></div>';
                });
                listEl.innerHTML = html;
            });
        }

        var _b2bProducts = null;
        var _pickerSelected = {};  // { sku: { name, img } }
        var _existingSkus = [];    // SKU ที่เพิ่มในโรงงานนี้แล้ว

        // ── Step 1: เปิด Product Picker (grid cards + รูป + checkbox) ──
        function openProductPicker() {
            // เก็บ SKU ที่เพิ่มแล้วจาก products list
            _existingSkus = [];
            document.querySelectorAll('#b2f-products-list .sku-code').forEach(function(el) {
                _existingSkus.push(el.textContent.trim());
            });
            document.getElementById('b2f-product-picker').style.display = 'block';
            document.getElementById('b2f-price-form').style.display = 'none';
            _pickerSelected = {};
            updatePickerCount();

            if (_b2bProducts) { renderPickerGrid(_b2bProducts); return; }

            var gridEl = document.getElementById('b2f-picker-grid');
            gridEl.innerHTML = '<div style="text-align:center;padding:20px;color:#9ca3af;grid-column:1/-1;"><div class="spinner"></div><br>กำลังโหลดสินค้า...</div>';

            var b2bUrl = '<?php echo esc_url( rest_url( "b2b/v1/products" ) ); ?>';
            fetch(b2bUrl, { headers: { 'X-WP-Nonce': NONCE } }).then(function(r){ return r.json(); }).then(function(res) {
                _b2bProducts = res.data || res.products || res || [];
                renderPickerGrid(_b2bProducts);
            }).catch(function() {
                gridEl.innerHTML = '<div style="text-align:center;padding:20px;color:#dc2626;grid-column:1/-1;">โหลดสินค้าไม่สำเร็จ</div>';
            });
        }

        function renderPickerGrid(products) {
            var gridEl = document.getElementById('b2f-picker-grid');
            var search = (document.getElementById('b2f-picker-search').value || '').toLowerCase();

            var filtered = products.filter(function(p) {
                var sku = p.product_sku || p.sku || '';
                // ตัด SKU ที่เพิ่มในโรงงานนี้แล้วออก
                if (_existingSkus.indexOf(sku) !== -1) return false;
                if (!search) return true;
                var skuLow = sku.toLowerCase();
                var name = (p.product_name || p.name || '').toLowerCase();
                return skuLow.indexOf(search) !== -1 || name.indexOf(search) !== -1;
            });

            if (!filtered.length) {
                gridEl.innerHTML = '<div style="text-align:center;padding:20px;color:#9ca3af;grid-column:1/-1;">ไม่พบสินค้าที่ค้นหา</div>';
                return;
            }

            var html = '';
            filtered.forEach(function(p) {
                var sku = p.product_sku || p.sku || '';
                var name = p.title || p.product_name || p.name || sku;
                var img = p.img || p.image_url || p.thumbnail || '';
                var isChecked = _pickerSelected[sku] ? 'checked' : '';
                var borderStyle = _pickerSelected[sku] ? 'border-color:#d97706;background:#fffbeb;' : '';

                html += '<label class="b2f-picker-card" style="display:flex;flex-direction:column;border:2px solid #e5e7eb;border-radius:10px;padding:10px;cursor:pointer;transition:all 0.2s;' + borderStyle + '" data-sku="' + esc(sku) + '">';
                if (img) {
                    html += '<img src="' + esc(img) + '" style="width:100%;height:80px;object-fit:contain;border-radius:6px;margin-bottom:6px;background:#f9fafb;" onerror="this.style.display=\'none\'">';
                } else {
                    html += '<div style="width:100%;height:80px;display:flex;align-items:center;justify-content:center;background:#f3f4f6;border-radius:6px;margin-bottom:6px;color:#9ca3af;font-size:24px;"><i class="fa-solid fa-box"></i></div>';
                }
                html += '<div style="display:flex;align-items:flex-start;gap:6px;">';
                html += '<input type="checkbox" ' + isChecked + ' onchange="B2F_Makers.togglePickerItem(\'' + esc(sku).replace(/'/g,"\\'") + '\',\'' + esc(name).replace(/'/g,"\\'") + '\',\'' + esc(img).replace(/'/g,"\\'") + '\', this)" style="margin-top:2px;flex-shrink:0;width:16px;height:16px;">';
                html += '<div style="min-width:0;">';
                html += '<div style="font-size:11px;font-weight:600;color:#374151;word-break:break-all;">' + esc(sku) + '</div>';
                html += '<div style="font-size:11px;color:#6b7280;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;" title="' + esc(name) + '">' + esc(name) + '</div>';
                html += '</div></div></label>';
            });
            gridEl.innerHTML = html;
        }

        function filterPicker() { if (_b2bProducts) renderPickerGrid(_b2bProducts); }

        function togglePickerItem(sku, name, img, checkbox) {
            if (checkbox.checked) {
                _pickerSelected[sku] = { name: name, img: img };
            } else {
                delete _pickerSelected[sku];
            }
            updatePickerCount();
            // Update card style
            var card = checkbox.closest('.b2f-picker-card');
            if (card) {
                card.style.borderColor = checkbox.checked ? '#d97706' : '#e5e7eb';
                card.style.background = checkbox.checked ? '#fffbeb' : '';
            }
        }

        function updatePickerCount() {
            var el = document.getElementById('b2f-picker-count');
            if (el) el.textContent = Object.keys(_pickerSelected).length;
        }

        function closePicker() {
            document.getElementById('b2f-product-picker').style.display = 'none';
            _pickerSelected = {};
        }

        // ── Step 2: กรอกราคาทุน ──
        function confirmPicker() {
            var skus = Object.keys(_pickerSelected);
            if (!skus.length) { toast('กรุณาเลือกสินค้าอย่างน้อย 1 รายการ', 'error'); return; }

            document.getElementById('b2f-product-picker').style.display = 'none';
            document.getElementById('b2f-price-form').style.display = 'block';

            renderPriceForm();
        }

        function renderPriceForm() {
            var skus = Object.keys(_pickerSelected);
            if (!skus.length) {
                // ไม่เหลือรายการ → กลับไป picker
                backToPicker();
                toast('ไม่มีรายการที่เลือก', 'info');
                return;
            }

            var html = '';
            skus.forEach(function(sku) {
                var item = _pickerSelected[sku];
                html += '<div id="b2f-price-row-' + esc(sku) + '" style="display:flex;gap:12px;align-items:center;padding:12px;border:1px solid #e5e7eb;border-radius:10px;margin-bottom:8px;background:white;">';
                // ปุ่มลบ X
                html += '<button onclick="B2F_Makers.removePriceItem(\'' + esc(sku).replace(/'/g,"\\'") + '\')" style="background:none;border:none;color:#dc2626;cursor:pointer;font-size:18px;padding:4px 8px;flex-shrink:0;border-radius:6px;" title="ลบรายการนี้" onmouseover="this.style.background=\'#fef2f2\'" onmouseout="this.style.background=\'none\'"><i class="fa-solid fa-xmark"></i></button>';
                if (item.img) {
                    html += '<img src="' + esc(item.img) + '" style="width:50px;height:50px;object-fit:contain;border-radius:6px;flex-shrink:0;background:#f9fafb;" onerror="this.style.display=\'none\'">';
                } else {
                    html += '<div style="width:50px;height:50px;display:flex;align-items:center;justify-content:center;background:#f3f4f6;border-radius:6px;flex-shrink:0;color:#9ca3af;"><i class="fa-solid fa-box"></i></div>';
                }
                html += '<div style="flex:1;min-width:0;">';
                html += '<div style="font-weight:600;font-size:12px;color:#374151;word-break:break-all;">' + esc(sku) + '</div>';
                html += '<div style="font-size:11px;color:#6b7280;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + esc(item.name) + '</div>';
                html += '</div>';
                html += '<div style="display:flex;gap:6px;flex-shrink:0;">';
                html += '<div><div style="font-size:10px;font-weight:600;color:#374151;">ราคาทุน *</div><input type="number" class="b2f-price-input" data-sku="' + esc(sku) + '" data-name="' + esc(item.name) + '" step="0.01" min="0.01" placeholder="0.00" style="width:90px;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></div>';
                html += '<div><div style="font-size:10px;font-weight:600;color:#374151;">MOQ</div><input type="number" class="b2f-moq-input" data-sku="' + esc(sku) + '" value="1" min="1" style="width:60px;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></div>';
                html += '<div><div style="font-size:10px;font-weight:600;color:#374151;">Lead (วัน)</div><input type="number" class="b2f-lead-input" data-sku="' + esc(sku) + '" value="7" min="1" style="width:60px;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></div>';
                html += '</div></div>';
            });

            // สรุปจำนวน
            html += '<div style="text-align:right;font-size:12px;color:#6b7280;margin-top:4px;">รวม ' + skus.length + ' รายการ</div>';
            document.getElementById('b2f-price-items').innerHTML = html;
        }

        function removePriceItem(sku) {
            delete _pickerSelected[sku];
            // ลบแค่ row นั้น ไม่ render ใหม่ทั้งหน้า (ป้องกันค่าที่กรอกไว้หาย)
            var row = document.getElementById('b2f-price-row-' + sku);
            if (row) row.remove();
            // ถ้าไม่เหลือรายการ → กลับ picker
            if (!Object.keys(_pickerSelected).length) {
                backToPicker();
                toast('ไม่มีรายการที่เลือก', 'info');
            }
        }

        function backToPicker() {
            document.getElementById('b2f-price-form').style.display = 'none';
            document.getElementById('b2f-product-picker').style.display = 'block';
        }

        // ── Submit ทั้งหมด ──
        function submitSelectedProducts() {
            var inputs = document.querySelectorAll('.b2f-price-input');
            var promises = [];
            var hasError = false;

            inputs.forEach(function(inp) {
                var cost = parseFloat(inp.value);
                if (!cost || cost <= 0) { hasError = true; inp.style.borderColor = '#dc2626'; return; }
                inp.style.borderColor = '#d1d5db';

                var sku = inp.dataset.sku;
                var name = inp.dataset.name || '';
                var moqInput = document.querySelector('.b2f-moq-input[data-sku="' + sku + '"]');
                var leadInput = document.querySelector('.b2f-lead-input[data-sku="' + sku + '"]');

                promises.push(api('POST', 'maker-product', {
                    mp_maker_id:       _currentMakerId,
                    mp_product_sku:    sku,
                    mp_product_name:   name,
                    mp_unit_cost:      cost,
                    mp_moq:            parseInt(moqInput ? moqInput.value : 1) || 1,
                    mp_lead_time_days: parseInt(leadInput ? leadInput.value : 7) || 7
                }));
            });

            if (hasError) { toast('กรุณากรอกราคาทุนทุกรายการ', 'error'); return; }

            Promise.all(promises).then(function(results) {
                var ok = results.filter(function(r){ return r.success; }).length;
                var fail = results.length - ok;
                if (fail > 0) {
                    toast('บันทึกสำเร็จ ' + ok + ' รายการ, ไม่สำเร็จ ' + fail + ' รายการ', 'warning');
                } else {
                    toast('บันทึก ' + ok + ' รายการสำเร็จ', 'success');
                }
                document.getElementById('b2f-price-form').style.display = 'none';
                _pickerSelected = {};
                loadProducts(_currentMakerId);
            });
        }

        // ── Legacy single add (keep for backward compat) ──
        function addProductRow() { openProductPicker(); }

        function editProduct(productId) {
            var cost = prompt('ราคาทุนใหม่ (บาท):');
            if (!cost || parseFloat(cost) <= 0) return;

            api('POST', 'maker-product', {
                product_id: productId,
                mp_maker_id: _currentMakerId,
                mp_unit_cost: parseFloat(cost)
            }).then(function(res) {
                if (res.success) {
                    toast('แก้ไขราคาทุนสำเร็จ', 'success');
                    loadProducts(_currentMakerId);
                } else {
                    toast(res.error || 'แก้ไขไม่สำเร็จ', 'error');
                }
            });
        }

        function deleteProduct(productId, sku) {
            if (!confirm('ยืนยันลบ SKU: ' + sku + '?')) return;
            api('POST', 'maker-product/delete', { product_id: productId }).then(function(res) {
                if (res.success) {
                    toast('ลบสำเร็จ', 'success');
                    loadProducts(_currentMakerId);
                } else {
                    toast(res.error || 'ลบไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── Backdrop click ── */
