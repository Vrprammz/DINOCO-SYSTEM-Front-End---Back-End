                    html += '<div class="b2f-form-group qc-reject-fields" style="display:none;margin-bottom:8px;">';
                    html += '<label class="b2f-form-label">จำนวน reject</label>';
                    html += '<input type="number" class="b2f-form-input rcv-reject" min="0" value="0">';
                    html += '<label class="b2f-form-label" style="margin-top:8px;">เหตุผล</label>';
                    html += '<textarea class="b2f-form-textarea rcv-reject-reason" rows="2"></textarea>';
                    html += '</div></div>';
