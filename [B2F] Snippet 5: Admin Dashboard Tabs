/* ================================================================
   REST: POST /b2f/v1/settings — Save B2F settings (admin only)
   ================================================================ */
add_action( 'rest_api_init', function() {
    // N1 — Audit fix: permission declared in permission_callback (not hidden inside callback)
    register_rest_route( 'b2f/v1', '/settings', array(
        'methods'  => 'POST',
        'callback' => function( $req ) {
            $params = $req->get_json_params();
            $allowed = array( 'b2f_shipping_dest_land', 'b2f_shipping_dest_sea' );
            $updated = 0;
            foreach ( $allowed as $key ) {
                if ( isset( $params[ $key ] ) ) {
                    update_option( $key, sanitize_textarea_field( $params[ $key ] ) );
                    $updated++;
                }
            }
            return array( 'success' => true, 'updated' => $updated );
        },
        'permission_callback' => function( $req ) {
            $nonce = $req->get_header( 'X-WP-Nonce' );
            return $nonce && wp_verify_nonce( $nonce, 'wp_rest' ) && current_user_can( 'manage_options' );
        },
    ) );
} );

