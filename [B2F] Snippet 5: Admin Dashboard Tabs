        /* ── Submit Receive ── */
        function submitReceive() {
            var body = document.getElementById('b2f-receive-body');
            var items = [];
            body.querySelectorAll('.b2f-qc-item').forEach(function(el, idx) {
                var sku = el.dataset.sku;
                var qtyRcv = parseInt(el.querySelector('.rcv-qty').value) || 0;
                var qcRadio = el.querySelector('input[name="qc_' + idx + '"]:checked');
                var qcStatus = qcRadio ? qcRadio.value : 'passed';
                var rejectQty = 0, rejectReason = '';
                if (qcStatus === 'failed') {
                    rejectQty = parseInt(el.querySelector('.rcv-reject').value) || 0;
                    rejectReason = el.querySelector('.rcv-reject-reason').value.trim();
                }
                items.push({
                    sku: sku, qty_received: qtyRcv, qc_status: qcStatus,
                    reject_qty: rejectQty, reject_reason: rejectReason
                });
            });

            var inspector = document.getElementById('b2f-rcv-inspector').value.trim();
            var note = document.getElementById('b2f-rcv-note').value.trim();

            var btn = document.getElementById('b2f-receive-submit');
            setLoading(btn, true);

            api('POST', 'receive-goods', {
                po_id: _currentPOId, items: items, inspected_by: inspector, note: note
            }).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    toast('ตรวจรับสำเร็จ ' + (res.rcv_number || ''), 'success');
                    closeModal('b2f-modal-receive');
                    loadStats();
                    loadOrders();
                } else {
                    toast(res.error || 'ตรวจรับไม่สำเร็จ', 'error');
                }
            }).catch(function() { setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

        /* ── Open Payment Modal ── */
        function openPayment(poId) {
            _currentPOId = poId;
            // Set today's date as default
            var today = new Date();
            var dd = String(today.getDate()).padStart(2,'0');
            var mm = String(today.getMonth()+1).padStart(2,'0');
            var yyyy = today.getFullYear();
            document.getElementById('b2f-pay-date').value = yyyy + '-' + mm + '-' + dd;
            document.getElementById('b2f-pay-amount').value = '';
            document.getElementById('b2f-pay-ref').value = '';
            document.getElementById('b2f-pay-note').value = '';
            document.getElementById('b2f-pay-slip').value = '';

            api('GET', 'po-detail/' + poId).then(function(res) {
                if (!res.success) { toast('โหลดข้อมูลไม่สำเร็จ', 'error'); return; }
                var po = res.data;
                var remaining = (po.total_amount || 0) - (po.paid_amount || 0);
                setText('b2f-pay-po-number', po.po_number || '-');
                setText('b2f-pay-total', '\u0E3F' + fmt(po.total_amount));
                setText('b2f-pay-paid', '\u0E3F' + fmt(po.paid_amount));
                setText('b2f-pay-remaining', '\u0E3F' + fmt(remaining));
                document.getElementById('b2f-pay-amount').max = remaining;
                document.getElementById('b2f-pay-amount').placeholder = fmt(remaining);
                openModal('b2f-modal-payment');
            });
        }

        /* ── Submit Payment ── */
        function submitPayment() {
            var amount = parseFloat(document.getElementById('b2f-pay-amount').value);
            var date = document.getElementById('b2f-pay-date').value;
            var method = document.getElementById('b2f-pay-method').value;
            if (!amount || amount <= 0) { toast('กรุณากรอกจำนวนเงิน', 'error'); return; }
            if (!date) { toast('กรุณาเลือกวันที่จ่าย', 'error'); return; }

            var btn = document.getElementById('b2f-pay-submit');
            setLoading(btn, true);

            var fd = new FormData();
            fd.append('po_id', _currentPOId);
            fd.append('amount', amount);
            fd.append('date', date);
            fd.append('method', method);
            fd.append('reference', document.getElementById('b2f-pay-ref').value.trim());
            fd.append('note', document.getElementById('b2f-pay-note').value.trim());
            var slipFile = document.getElementById('b2f-pay-slip').files[0];
            if (slipFile) fd.append('slip_image', slipFile);

            api('POST', 'record-payment', fd, true).then(function(res) {
                setLoading(btn, false);
                if (res.success) {
                    var slipMsg = 'บันทึกจ่ายเงินสำเร็จ';
                    if (res.slip_status === 'verified') slipMsg += ' — สลิปตรวจผ่าน ✓';
                    else if (res.slip_status === 'rejected') slipMsg += ' — สลิปไม่ผ่าน: ' + (res.slip_error || '');
                    else if (res.slip_status === 'pending') slipMsg += ' — สลิปรอตรวจ (ยังไม่มีรหัสธนาคาร)';
                    toast(slipMsg, res.slip_status === 'rejected' ? 'warning' : 'success');
                    closeModal('b2f-modal-payment');
                    loadStats();
                    loadOrders();
                } else {
                    toast(res.error || 'บันทึกไม่สำเร็จ', 'error');
                }
            }).catch(function() { setLoading(btn, false); toast('เกิดข้อผิดพลาด', 'error'); });
        }

