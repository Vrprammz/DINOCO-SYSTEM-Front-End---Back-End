                // U-01: Reject Lot ใน detail modal
                if (st === 'delivering') {
                    actions += '<button class="b2f-btn" style="color:#dc2626;border-color:#dc2626;" onclick="closeModal(\'b2f-modal-detail\');B2F_Orders.rejectLot(' + po.id + ',\'' + esc(po.po_number) + '\')"><i class="fa-solid fa-ban"></i> Reject Lot</button>';
                }
                // U-02: Complete PO ใน detail modal
                if (st === 'received') {
                    actions += '<button class="b2f-btn b2f-btn-secondary" onclick="closeModal(\'b2f-modal-detail\');B2F_Orders.completePO(' + po.id + ',\'' + esc(po.po_number) + '\')"><i class="fa-solid fa-circle-check"></i> ปิด PO</button>';
                }
                if (['draft','submitted','confirmed','rejected','partial_received'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-danger" onclick="closeModal(\'b2f-modal-detail\');B2F_Orders.cancelPO(' + po.id + ',\'' + esc(po.po_number) + '\')"><i class="fa-solid fa-xmark"></i> ยกเลิก</button>';
                }
                // U-03: Reorder ใน detail modal
                if (['completed','cancelled'].indexOf(st) !== -1) {
                    actions += '<button class="b2f-btn b2f-btn-secondary" onclick="closeModal(\'b2f-modal-detail\');B2F_Orders.reorderPO(' + po.id + ')"><i class="fa-solid fa-rotate"></i> สั่งซ้ำ</button>';
                }
                actions += '</div>';
                html += actions;

                body.innerHTML = html;
            });
        }

        /* ── Cancel PO ── */
        function cancelPO(poId, poNumber) {
            if (!confirm('ยืนยันยกเลิก PO ' + poNumber + '?')) return;
            var reason = prompt('เหตุผลที่ยกเลิก:');
            if (reason === null) return;

            api('POST', 'po-cancel', { po_id: poId, reason: reason }).then(function(res) {
                if (res.success) {
                    toast('ยกเลิก PO สำเร็จ', 'success');
                    loadStats();
                    loadOrders();
                } else {
                    toast(res.error || 'ยกเลิกไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── G-01: Edit PO (แก้ไข → amend → auto-resubmit) ── */
        function editPO(poId) {
            api('GET', 'po-detail/' + poId).then(function(res) {
                if (!res.success || !res.data) { toast('โหลดข้อมูลไม่สำเร็จ', 'error'); return; }
                var po = res.data;
                openModal('b2f-modal-create-po');
                var makerSel = document.getElementById('b2f-create-maker');
                if (makerSel && po.maker_id) {
                    makerSel.value = String(po.maker_id);
                    // B-03 fix: ใช้ .then() แทน setTimeout — รอ products load เสร็จจริง
                    loadMakerProducts().then(function() {
                        if (po.items && po.items.length) {
                            po.items.forEach(function(item) {
                                var rows = document.querySelectorAll('#b2f-create-sku-list .b2f-sku-row');
                                rows.forEach(function(row) {
                                    if (row.dataset.sku === item.sku) {
                                        var inp = row.querySelector('input[type="number"]');
                                        if (inp) inp.value = item.qty_ordered || 0;
                                    }
                                });
                            });
                            recalcTotal();
                        }
                        var submitBtn = document.getElementById('b2f-create-submit');
                        if (submitBtn) {
                            submitBtn.textContent = '💾 บันทึกการแก้ไข';
                            submitBtn.dataset.editPoId = poId;
                        }
                        var noteInput = document.getElementById('b2f-create-note');
                        if (noteInput && po.admin_note) noteInput.value = po.admin_note;
                    });
                }
            });
        }

        /* ── G-02: Resubmit rejected PO (ส่งใหม่โดยไม่แก้ไข) ── */
        function resubmitPO(poId, poNumber) {
            if (!confirm('ส่ง PO ' + poNumber + ' ไป Maker ใหม่?')) return;
            api('POST', 'po-update', { po_id: poId, resubmit_only: true }).then(function(res) {
                if (res.success) {
                    toast('ส่ง PO ใหม่สำเร็จ', 'success');
                    loadStats(); loadOrders();
                } else {
                    toast(res.error || 'ส่งใหม่ไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── G-04: Reject Lot (delivering → confirmed) ── */
        function rejectLot(poId, poNumber) {
            if (!confirm('ปฏิเสธสินค้าทั้ง lot ของ ' + poNumber + '?\nMaker จะต้องจัดส่งใหม่')) return;
            var reason = prompt('เหตุผลที่ reject:');
            if (reason === null) return;

            api('POST', 'reject-lot', { po_id: poId, reason: reason }).then(function(res) {
                if (res.success) {
                    toast('Reject Lot สำเร็จ — PO กลับสถานะ confirmed', 'success');
                    loadStats(); loadOrders();
                } else {
                    toast(res.error || 'Reject ไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── G-05: Complete PO (received → completed, ของฟรี/sample) ── */
        function completePO(poId, poNumber) {
            if (!confirm('ปิด PO ' + poNumber + ' โดยไม่จ่ายเงิน?\n(สำหรับสินค้าตัวอย่าง/ของฟรี)')) return;
            var note = prompt('หมายเหตุ (optional):') || 'ปิด PO — ไม่ต้องชำระ';

            api('POST', 'po-complete', { po_id: poId, note: note }).then(function(res) {
                if (res.success) {
                    toast('ปิด PO สำเร็จ', 'success');
                    loadStats(); loadOrders();
                } else {
                    toast(res.error || 'ปิด PO ไม่สำเร็จ', 'error');
                }
            });
        }

        /* ── Reorder (สั่งซ้ำ) ── */
        function reorderPO(poId) {
            // ดึงข้อมูล PO เดิม แล้วเปิด form สร้าง PO ใหม่ pre-fill
            api('GET', 'po-detail/' + poId).then(function(res) {
                if (!res.success || !res.data) { toast('โหลดข้อมูล PO ไม่สำเร็จ', 'error'); return; }
                var po = res.data;
                // เปิด form สร้าง PO
                openModal('b2f-modal-create-po');
                // Pre-fill maker
                var makerSel = document.getElementById('b2f-create-maker');
                if (makerSel && po.maker_id) {
                    makerSel.value = String(po.maker_id);
                    // B-04 fix: ใช้ .then() แทน setTimeout
                    loadMakerProducts().then(function() {
                        if (po.items && po.items.length) {
                            po.items.forEach(function(item) {
                                var rows = document.querySelectorAll('#b2f-create-sku-list .b2f-sku-row');
                                rows.forEach(function(row) {
                                    if (row.dataset.sku === item.sku) {
                                        var inp = row.querySelector('input[type="number"]');
                                        if (inp) inp.value = item.qty_ordered || item.qty || 0;
                                    }
                                });
                            });
                            recalcTotal();
                            toast('โหลดรายการจาก ' + (po.po_number || 'PO เดิม') + ' แล้ว — ตรวจสอบจำนวน+ราคาก่อนสั่ง', 'info');
                        }
                    });
                }
            }).catch(function() { toast('โหลดข้อมูลไม่สำเร็จ', 'error'); });
        }

        /* ── Modal helpers ── */
        function openModal(id) { document.getElementById(id).classList.add('open'); }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); }

        /* ── Tab filter ── */
        function filterByTab(status) {
            _currentTab = status;
            _currentPage = 1;
            document.querySelectorAll('.b2f-status-tab').forEach(function(t) {
                t.classList.toggle('active', t.dataset.status === status);
            });
            loadOrders();
        }

        function applyFilters() {
            _currentPage = 1;
            loadOrders();
        }

        function debounceSearch() {
            clearTimeout(_searchTimer);
            _searchTimer = setTimeout(function(){ applyFilters(); }, 400);
        }

        function goPage(p) { _currentPage = p; loadOrders(); }

        /* ── Auto-refresh ── */
        function startRefresh() {
            _refreshTimer = setInterval(function() {
                loadStats();
                loadOrders();
            }, 60000);
        }

        /* ── Backdrop click to close ── */
        document.querySelectorAll('.b2f-modal-backdrop').forEach(function(bd) {
            bd.addEventListener('click', function(e) {
                if (e.target === bd) bd.classList.remove('open');
            });
        });

        /* ── Init ── */
        function init() {
            loadMakers();
            loadStats();
            loadOrders();
            startRefresh();
        }

        /* ── Public API ── */
        window.B2F_Orders = {
            init: init,
            filterByTab: filterByTab,
            applyFilters: applyFilters,
            debounceSearch: debounceSearch,
            goPage: goPage,
            openCreateModal: function(){ openModal('b2f-modal-create-po'); },
            closeModal: closeModal,
            loadMakerProducts: loadMakerProducts,
            adjustQty: adjustQty,
            recalcTotal: recalcTotal,
            submitCreatePO: submitCreatePO,
            openReceive: openReceive,
            submitReceive: submitReceive,
            openPayment: openPayment,
            submitPayment: submitPayment,
            openDetail: openDetail,
            cancelPO: cancelPO,
            reorderPO: reorderPO,
            editPO: editPO,
            resubmitPO: resubmitPO,
            rejectLot: rejectLot,
            completePO: completePO
        };

        // Auto-init when visible
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }

    })();
    </script>
