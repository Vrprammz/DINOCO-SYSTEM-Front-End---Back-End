    /* ── Status Tabs ── */
    .b2f-status-tabs { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:16px; }
    .b2f-status-tab { padding:6px 14px; border-radius:20px; font-size:13px; font-weight:500; background:var(--c-bg,#f1f5f9); color:var(--c-text-dim,#64748b); border:1px solid transparent; cursor:pointer; transition:all .15s; white-space:nowrap; }
    .b2f-status-tab:hover { background:#fef3c7; color:#92400e; }
    .b2f-status-tab.active { background:#fef3c7; color:#92400e; border-color:#d97706; font-weight:600; }
    .b2f-tab-count { display:inline-block; margin-left:4px; background:rgba(0,0,0,.08); border-radius:10px; padding:1px 7px; font-size:11px; }
    .b2f-status-tab.active .b2f-tab-count { background:rgba(146,64,14,.15); }

    /* ── Filters ── */
    .b2f-filters { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:16px; align-items:center; }
    .b2f-filter-select, .b2f-filter-input, .b2f-filter-date { padding:7px 12px; border:1px solid var(--c-border,#e2e8f0); border-radius:8px; font-size:13px; background:var(--c-surface,#fff); color:var(--c-text,#334155); min-width:140px; }
    .b2f-filter-input { min-width:200px; }

    /* ── PO Cards ── */
    .b2f-po-list { display:flex; flex-direction:column; gap:12px; }
    .b2f-po-card { background:var(--c-surface,#fff); border:1px solid var(--c-border,#e2e8f0); border-radius:12px; padding:16px 18px; transition:box-shadow .15s; }
    .b2f-po-card:hover { box-shadow:0 4px 12px rgba(0,0,0,.06); }
    .b2f-po-card-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; margin-bottom:8px; }
    .b2f-po-number { font-weight:700; font-size:15px; color:var(--c-heading,#0f172a); }
    .b2f-po-meta { display:flex; flex-wrap:wrap; gap:6px 16px; font-size:13px; color:var(--c-text-dim,#64748b); margin-bottom:10px; }
    .b2f-po-meta i { width:16px; text-align:center; margin-right:2px; }
    .b2f-po-actions { display:flex; flex-wrap:wrap; gap:8px; }
    .b2f-po-actions .b2f-btn { font-size:12px; padding:5px 12px; }

    /* ── Buttons ── */
    .b2f-btn { display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:8px; font-size:13px; font-weight:500; border:none; cursor:pointer; transition:all .15s; white-space:nowrap; }
    .b2f-btn-primary { background:#d97706; color:#fff; }
    .b2f-btn-primary:hover { background:#b45309; }
    .b2f-btn-secondary { background:var(--c-bg,#f1f5f9); color:var(--c-text,#334155); border:1px solid var(--c-border,#e2e8f0); }
    .b2f-btn-secondary:hover { background:#e2e8f0; }
    .b2f-btn-danger { background:#fee2e2; color:#dc2626; }
    .b2f-btn-danger:hover { background:#fecaca; }
    .b2f-btn-success { background:#dcfce7; color:#16a34a; }
    .b2f-btn-success:hover { background:#bbf7d0; }
    .b2f-btn:disabled { opacity:.5; cursor:not-allowed; pointer-events:none; }

    /* ── Maker Cards ── */
    .b2f-maker-list { display:grid; grid-template-columns:1fr; gap:12px; }
    @media(min-width:900px){ .b2f-maker-list { grid-template-columns:repeat(2,1fr); } }
    .b2f-maker-card { background:var(--c-surface,#fff); border:1px solid var(--c-border,#e2e8f0); border-radius:12px; padding:16px 18px; }
    .b2f-maker-card:hover { box-shadow:0 4px 12px rgba(0,0,0,.06); }
    .b2f-maker-card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
    .b2f-maker-name { font-weight:700; font-size:15px; color:var(--c-heading,#0f172a); }
    .b2f-maker-info { font-size:13px; color:var(--c-text-dim,#64748b); margin-bottom:10px; line-height:1.7; }
    .b2f-maker-actions { display:flex; flex-wrap:wrap; gap:8px; }

    /* ── Credit Cards ── */
    .b2f-credit-summary { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; margin-bottom:20px; }
    .b2f-credit-card { background:var(--c-surface,#fff); border:1px solid var(--c-border,#e2e8f0); border-radius:12px; padding:16px 18px; }
    .b2f-credit-card:hover { box-shadow:0 4px 12px rgba(0,0,0,.06); }
    .b2f-progress-bar { height:8px; background:#e2e8f0; border-radius:4px; overflow:hidden; margin:8px 0; }
    .b2f-progress-fill { height:100%; border-radius:4px; transition:width .3s; }
    .b2f-progress-safe   { background:#22c55e; }
    .b2f-progress-warn   { background:#f59e0b; }
    .b2f-progress-danger { background:#ef4444; }

    /* ── Modals ── */
    .b2f-modal-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:99999; display:flex; align-items:center; justify-content:center; padding:20px; opacity:0; visibility:hidden; transition:all .2s; }
    .b2f-modal-backdrop.open { opacity:1; visibility:visible; }
    .b2f-modal { background:var(--c-surface,#fff); border-radius:16px; width:100%; max-width:680px; max-height:90vh; overflow-y:auto; box-shadow:0 20px 60px rgba(0,0,0,.2); }
    .b2f-modal-header { display:flex; align-items:center; justify-content:space-between; padding:18px 22px; border-bottom:1px solid var(--c-border,#e2e8f0); position:sticky; top:0; background:var(--c-surface,#fff); border-radius:16px 16px 0 0; z-index:2; }
    .b2f-modal-header h3 { margin:0; font-size:17px; font-weight:700; }
    .b2f-modal-close { width:44px; height:44px; min-width:44px; min-height:44px; border-radius:50%; border:none; background:var(--c-bg,#f1f5f9); cursor:pointer; font-size:22px; line-height:1; display:flex; align-items:center; justify-content:center; color:var(--c-text-dim,#64748b); }
    .b2f-modal-close:hover { background:#e2e8f0; }
    /* V.7.5 Phase 3 Group H: sr-only utility (UX-H15) */
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}
    .b2f-modal-body { padding:22px; }
    .b2f-modal-footer { padding:14px 22px; border-top:1px solid var(--c-border,#e2e8f0); display:flex; justify-content:flex-end; gap:10px; position:sticky; bottom:0; background:var(--c-surface,#fff); border-radius:0 0 16px 16px; }

    /* ── Form Elements ── */
    .b2f-form-group { margin-bottom:16px; }
    .b2f-form-label { display:block; font-size:13px; font-weight:600; color:var(--c-text,#334155); margin-bottom:6px; }
    .b2f-form-label .required { color:#dc2626; margin-left:2px; }
    .b2f-form-input, .b2f-form-select, .b2f-form-textarea { width:100%; padding:9px 12px; border:1px solid var(--c-border,#e2e8f0); border-radius:8px; font-size:13px; background:var(--c-surface,#fff); color:var(--c-text,#334155); box-sizing:border-box; }
    .b2f-form-input:focus, .b2f-form-select:focus, .b2f-form-textarea:focus { outline:none; border-color:#d97706; box-shadow:0 0 0 3px rgba(217,119,6,.15); }
    .b2f-form-textarea { resize:vertical; min-height:60px; }
    .b2f-form-hint { font-size:11px; color:var(--c-text-xdim,#94a3b8); margin-top:4px; }

    /* ── SKU Inline Editable Table ── */
    .b2f-sku-row { display:flex; align-items:center; gap:6px; padding:8px 10px; border:none; border-bottom:1px solid #f1f5f9; margin-bottom:0; background:#fff; flex-wrap:wrap; }
    .b2f-sku-row .sku-info { flex:1; min-width:200px; display:flex; align-items:center; gap:8px; }
    .b2f-sku-row .sku-thumb { width:36px; height:36px; object-fit:contain; border-radius:6px; background:#f9fafb; flex-shrink:0; }
    .b2f-sku-row .sku-thumb-placeholder { width:36px; height:36px; display:flex; align-items:center; justify-content:center; background:#f3f4f6; border-radius:6px; flex-shrink:0; color:#9ca3af; font-size:14px; }
    .b2f-sku-row .sku-code { font-weight:600; font-size:12px; }
    .b2f-sku-row .sku-name { font-size:11px; color:#6b7280; word-break:break-word; }
    /* V.3.7 Hierarchy: Accordion tree view (Stock Mgmt pattern) */
    .b2f-set-group { margin-bottom:4px; }
    .b2f-set-header { display:flex; align-items:center; gap:10px; padding:10px 14px; background:#f8f7ff; border:1px solid #c4b5fd; border-left:4px solid #7c3aed; border-radius:10px; cursor:pointer; transition:background .15s; margin-bottom:2px; }
    .b2f-set-header:hover { background:#f0eeff; }
    .b2f-set-expand { width:28px; height:28px; border-radius:6px; border:1.5px solid #d4d0f0; background:#ede9fe; color:#7c3aed; display:inline-flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0; transition:.2s; }
    .b2f-set-header:hover .b2f-set-expand { background:#ddd6fe; border-color:#7c3aed; }
    .b2f-set-title { font-weight:700; font-size:13px; color:#7c3aed; flex:1; }
    .b2f-set-badge { padding:2px 8px; border-radius:6px; font-size:10px; font-weight:700; background:#ede9fe; color:#7c3aed; white-space:nowrap; }
    .b2f-set-children { overflow:hidden; transition:max-height .3s ease; }
    .b2f-set-children.collapsed { max-height:0 !important; }
    .b2f-sku-row.b2f-sku-child { margin-left:28px; border:none; border-left:3px solid #3b82f6; background:#f0f7ff; border-radius:0 8px 8px 0; padding:8px 10px; }
    .b2f-sku-row.b2f-sku-child:hover { background:#e8f1ff; }
    .b2f-sku-row.b2f-sku-gc { margin-left:52px; border:none; border-left:3px solid #f59e0b; background:#fffbeb; border-radius:0 8px 8px 0; padding:8px 10px; }
    .b2f-sku-row.b2f-sku-gc:hover { background:#fef3c7; }
    /* V.5.0 DD-3: readonly secondary row */
    .b2f-sku-row.b2f-sku-readonly { opacity:0.85; background-image:linear-gradient(135deg,transparent 0%,transparent 49%,#f1f5f9 49%,#f1f5f9 51%,transparent 51%,transparent 100%); background-size:8px 8px; }
    .b2f-sku-row.b2f-sku-readonly .sku-inp { pointer-events:none; }
    .b2f-shared-badge:hover { background:#fde68a !important; }
    .b2f-shared-badge-ro:hover { background:#bae6fd !important; }
    .sku-inp { width:80px; padding:5px 6px; border:1px solid #e2e8f0; border-radius:4px; font-size:13px; text-align:right; transition:all .15s; background:#fff; }
    .sku-inp:focus { border-color:var(--accent-b2f,#2563eb); outline:none; box-shadow:0 0 0 1.5px rgba(37,99,235,0.12); }
    .b2f-field-label { font-size:9px; color:#94a3b8; text-align:center; white-space:nowrap; }
    .b2f-quick-bar { display:flex; gap:8px; align-items:center; margin-bottom:12px; flex-wrap:wrap; }
    .b2f-quick-bar button { font-size:12px; padding:6px 12px; border:1px solid #d1d5db; border-radius:8px; background:#fff; cursor:pointer; white-space:nowrap; }
    .b2f-quick-bar button:hover { background:#f1f5f9; }
    #b2f-batch-save-bar { display:none; justify-content:flex-end; padding:12px 0; border-top:1px solid #e5e7eb; margin-top:8px; }
    #b2f-batch-save-bar button { padding:10px 24px; background:var(--accent-b2f,#1a3a5c); color:#fff; border:none; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer; }
    #b2f-batch-save-bar button:disabled { opacity:0.5; cursor:not-allowed; }
    .b2f-sku-header { display:flex; gap:8px; padding:4px 12px; font-size:9px; color:#94a3b8; font-weight:600; flex-wrap:wrap; }
    .b2f-sku-qty { display:flex; align-items:center; gap:6px; }
    .b2f-sku-qty input { width:60px; text-align:center; padding:6px; border:1px solid var(--c-border,#e2e8f0); border-radius:6px; font-size:13px; }
    .b2f-sku-qty button { width:28px; height:28px; border-radius:6px; border:1px solid var(--c-border,#e2e8f0); background:var(--c-bg,#f1f5f9); cursor:pointer; font-size:14px; display:flex; align-items:center; justify-content:center; }
    .b2f-sku-subtotal { font-weight:600; font-size:13px; min-width:80px; text-align:right; }

    /* ── QC Form ── */
    .b2f-qc-item { border:1px solid var(--c-border,#e2e8f0); border-radius:10px; padding:14px; margin-bottom:10px; }
    .b2f-qc-item .qc-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
    .b2f-qc-radio-group { display:flex; gap:12px; }
    .b2f-qc-radio-group label { display:flex; align-items:center; gap:4px; font-size:13px; cursor:pointer; }

    /* ── Timeline ── */
    .b2f-timeline { position:relative; padding-left:24px; }
    .b2f-timeline::before { content:''; position:absolute; left:7px; top:4px; bottom:4px; width:2px; background:var(--c-border,#e2e8f0); }
    .b2f-timeline-item { position:relative; margin-bottom:16px; }
    .b2f-timeline-item::before { content:''; position:absolute; left:-20px; top:5px; width:10px; height:10px; border-radius:50%; background:#d97706; border:2px solid #fff; box-shadow:0 0 0 2px #d97706; }
    .b2f-timeline-item .tl-date { font-size:11px; color:var(--c-text-xdim,#94a3b8); }
    .b2f-timeline-item .tl-text { font-size:13px; color:var(--c-text,#334155); }

    /* ── Pagination ── */
    .b2f-pagination { display:flex; align-items:center; justify-content:center; gap:6px; margin-top:20px; }
    .b2f-page-btn { width:36px; height:36px; border-radius:8px; border:1px solid var(--c-border,#e2e8f0); background:var(--c-surface,#fff); cursor:pointer; font-size:13px; display:flex; align-items:center; justify-content:center; }
    .b2f-page-btn.active { background:#d97706; color:#fff; border-color:#d97706; }
    .b2f-page-btn:hover:not(.active) { background:var(--c-bg,#f1f5f9); }
    .b2f-page-info { font-size:13px; color:var(--c-text-dim,#64748b); margin:0 8px; }

    /* ── Loading / Empty ── */
    .b2f-loading { text-align:center; padding:40px; color:var(--c-text-dim,#64748b); }
    .b2f-loading .spinner { display:inline-block; width:28px; height:28px; border:3px solid #e2e8f0; border-top-color:#d97706; border-radius:50%; animation:b2f-spin .7s linear infinite; }
    @keyframes b2f-spin { to { transform:rotate(360deg); } }
    .b2f-empty { text-align:center; padding:40px; color:var(--c-text-dim,#64748b); font-size:14px; }
    .b2f-empty i { font-size:32px; display:block; margin-bottom:10px; opacity:.4; }

    /* ── Toast ── */
    .b2f-toast { position:fixed; bottom:20px; right:20px; z-index:100000; padding:12px 20px; border-radius:10px; font-size:13px; font-weight:500; color:#fff; box-shadow:0 4px 16px rgba(0,0,0,.2); transform:translateY(100px); opacity:0; transition:all .3s; pointer-events:none; }
    .b2f-toast.show { transform:translateY(0); opacity:1; }
    .b2f-toast.success { background:#16a34a; }
    .b2f-toast.error { background:#dc2626; }
    .b2f-toast.info { background:#2563eb; }

    /* ── Bulk Action Bar ── */
    .b2f-bulk-bar { display:none; align-items:center; gap:12px; padding:10px 16px; background:#fef3c7; border:1px solid #fcd34d; border-radius:10px; margin-bottom:14px; flex-wrap:wrap; }
    .b2f-bulk-bar.show { display:flex; }
    .b2f-bulk-bar .bulk-count { font-size:13px; font-weight:600; color:#92400e; white-space:nowrap; }
    .b2f-bulk-bar .bulk-actions { display:flex; gap:8px; flex-wrap:wrap; margin-left:auto; }

    /* ── PO Card Checkbox ── */
    .b2f-po-checkbox { width:16px; height:16px; cursor:pointer; accent-color:#dc2626; flex-shrink:0; }
    .b2f-po-card-header.has-checkbox { display:flex; align-items:center; gap:8px; }
    .b2f-cancel-btn { background:none; border:none; color:#94a3b8; cursor:pointer; padding:4px; border-radius:6px; font-size:14px; transition:all .15s; }
    .b2f-cancel-btn:hover { color:#dc2626; background:#fee2e2; }

    /* ── Bulk Cancel Modal ── */
    .b2f-bulk-cancel-list { max-height:240px; overflow-y:auto; border:1px solid var(--c-border,#e2e8f0); border-radius:8px; margin-bottom:16px; }
    .b2f-bulk-cancel-item { display:flex; align-items:center; justify-content:space-between; padding:8px 14px; border-bottom:1px solid var(--c-border,#e2e8f0); font-size:13px; }
    .b2f-bulk-cancel-item:last-child { border-bottom:none; }
    .b2f-bulk-progress { margin-top:12px; }
    .b2f-bulk-progress-bar { height:8px; background:#e2e8f0; border-radius:4px; overflow:hidden; }
    .b2f-bulk-progress-fill { height:100%; background:#d97706; border-radius:4px; transition:width .3s; width:0; }
    .b2f-bulk-progress-text { font-size:12px; color:var(--c-text-dim,#64748b); margin-top:4px; }

    /* ── V.6.0: Product Picker filter chips (match Inventory V.43.6 labels/UX) ── */
    .b2f-picker-filter-bar { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:10px; align-items:center; }
    .b2f-picker-filter-bar > .b2f-pf-lead { font-size:0.78rem; color:#64748b; font-weight:600; margin-right:4px; }
    .b2f-pf-chip { padding:5px 12px; border-radius:20px; border:1.5px solid #e2e8f0; background:#fff; color:#64748b; font-size:0.78rem; font-weight:600; cursor:pointer; transition:.2s; display:inline-flex; align-items:center; gap:6px; white-space:nowrap; }
    .b2f-pf-chip:hover { border-color:#94a3b8; color:#334155; background:#f8fafc; }
    .b2f-pf-chip.active { background:#0f172a; color:#fff; border-color:#0f172a; }
    .b2f-pf-chip[data-type="set"] { border-color:#ddd6fe; }
    .b2f-pf-chip[data-type="child"] { border-color:#bfdbfe; }
    .b2f-pf-chip[data-type="grandchild"] { border-color:#a7f3d0; }
    .b2f-pf-chip[data-type="single"] { border-color:#cbd5e1; }
    .b2f-pf-chip .b2f-pf-count { background:rgba(0,0,0,.1); padding:1px 7px; border-radius:10px; font-size:0.7rem; font-weight:700; }
    .b2f-pf-chip.active .b2f-pf-count { background:rgba(255,255,255,.2); }
    .b2f-pf-chip.is-hidden { display:none; }

    /* V.6.0: Picker type badges (match Inventory purple/blue/green/gray convention) */
    .b2f-pf-badge { display:inline-block; padding:1px 6px; border-radius:4px; font-size:9px; font-weight:700; margin-right:4px; vertical-align:middle; }
    .b2f-pf-badge.type-set        { background:#ede9fe; color:#7c3aed; }
    .b2f-pf-badge.type-child      { background:#dbeafe; color:#2563eb; }
    .b2f-pf-badge.type-grandchild { background:#dcfce7; color:#16a34a; }
    .b2f-pf-badge.type-single     { background:#f1f5f9; color:#64748b; }

    /* V.6.0: Accordion row type badges (small, right after SKU code) */
    .b2f-row-type-badge { display:inline-block; padding:1px 6px; border-radius:4px; font-size:9px; font-weight:700; margin-left:6px; vertical-align:middle; }
    .b2f-row-type-badge.type-set        { background:#ede9fe; color:#7c3aed; }
    .b2f-row-type-badge.type-child      { background:#dbeafe; color:#2563eb; }
    .b2f-row-type-badge.type-grandchild { background:#dcfce7; color:#16a34a; }
    .b2f-row-type-badge.type-single     { background:#f1f5f9; color:#64748b; }

    /* V.6.3: Option F — source badges + audit toolbar */
    .b2f-src-badge { display:inline-block; padding:2px 8px; border-radius:10px; font-size:10px; font-weight:700; line-height:1.4; white-space:nowrap; margin-left:6px; vertical-align:middle; }
    .b2f-src-badge.src-cpt  { background:#dbeafe; color:#2563eb; }
    .b2f-src-badge.src-auto { background:#fef3c7; color:#d97706; }
    .b2f-src-badge.src-auto.bl { background:#fee2e2; color:#dc2626; }
    .b2f-audit-toolbar { display:flex; flex-wrap:wrap; gap:8px; align-items:center; padding:10px 14px; margin:8px 0 10px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; font-size:13px; color:#334155; }
    .b2f-audit-toolbar .summary { font-weight:600; color:#0f172a; }
    .b2f-audit-toolbar .summary em { color:#64748b; font-weight:500; font-style:normal; }
    .b2f-audit-chip { padding:4px 11px; border-radius:16px; border:1.5px solid #e2e8f0; background:#fff; color:#64748b; font-size:12px; font-weight:600; cursor:pointer; transition:.15s; display:inline-flex; align-items:center; gap:5px; white-space:nowrap; }
    .b2f-audit-chip:hover { border-color:#94a3b8; color:#334155; background:#f1f5f9; }
    .b2f-audit-chip.active { background:#0f172a; color:#fff; border-color:#0f172a; }
    .b2f-audit-chip[data-src="cpt"].active { background:#2563eb; border-color:#2563eb; }
    .b2f-audit-chip[data-src="auto"].active { background:#d97706; border-color:#d97706; }
