        // ── Submit ทั้งหมด ──
        function submitSelectedProducts() {
            var inputs = document.querySelectorAll('.b2f-price-input');
            var promises = [];
            var hasError = false;

            inputs.forEach(function(inp) {
                var cost = parseFloat(inp.value);
                if (!cost || cost <= 0) { hasError = true; inp.style.borderColor = '#dc2626'; return; }
                inp.style.borderColor = '#d1d5db';

                var sku = inp.dataset.sku;
                var name = inp.dataset.name || '';
                var moqInput = document.querySelector('.b2f-moq-input[data-sku="' + sku + '"]');
                var leadInput = document.querySelector('.b2f-lead-input[data-sku="' + sku + '"]');
                var leadLandInput = document.querySelector('.b2f-lead-land-input[data-sku="' + sku + '"]');
                var leadSeaInput = document.querySelector('.b2f-lead-sea-input[data-sku="' + sku + '"]');
                var shipLandInput = document.querySelector('.b2f-ship-land-input[data-sku="' + sku + '"]');
                var shipSeaInput = document.querySelector('.b2f-ship-sea-input[data-sku="' + sku + '"]');

                promises.push(api('POST', 'maker-product', {
                    mp_maker_id:       _currentMakerId,
                    mp_product_sku:    sku,
                    mp_product_name:   name,
                    mp_unit_cost:      cost,
                    mp_moq:            parseInt(moqInput ? moqInput.value : 1) || 1,
                    mp_lead_time_days: parseInt(leadInput ? leadInput.value : 7) || 7,
                    mp_lead_land:      parseInt(leadLandInput ? leadLandInput.value : 7) || 0,
                    mp_lead_sea:       parseInt(leadSeaInput ? leadSeaInput.value : 14) || 0,
                    mp_shipping_land:  parseFloat(shipLandInput ? shipLandInput.value : 0) || 0,
                    mp_shipping_sea:   parseFloat(shipSeaInput ? shipSeaInput.value : 0) || 0
                }));
            });

            if (hasError) { toast('กรุณากรอกราคาทุนทุกรายการ', 'error'); return; }

            Promise.all(promises).then(function(results) {
                var ok = results.filter(function(r){ return r.success; }).length;
                var fail = results.length - ok;
                if (fail > 0) {
                    toast('บันทึกสำเร็จ ' + ok + ' รายการ, ไม่สำเร็จ ' + fail + ' รายการ', 'warning');
                } else {
                    toast('บันทึก ' + ok + ' รายการสำเร็จ', 'success');
                }
                document.getElementById('b2f-price-form').style.display = 'none';
                _pickerSelected = {};
                loadProducts(_currentMakerId);
            });
        }

        // ── Legacy single add (keep for backward compat) ──
        function addProductRow() { openProductPicker(); }

        /* ── Inline Edit: Dirty tracking ── */
        function checkDirty(inp) {
            var isDirty = inp.value !== inp.dataset.original;
            inp.style.borderColor = isDirty ? '#d97706' : '#e2e8f0';
            inp.style.background = isDirty ? '#fffbeb' : '#fff';
            updateDirtyCount();
        }

        function updateDirtyCount() {
            var allInp = document.querySelectorAll('.sku-inp');
            var dirtyPids = new Set();
            allInp.forEach(function(i) {
                if (i.value !== i.dataset.original) {
                    var row = i.closest('.b2f-sku-row');
                    if (row) dirtyPids.add(row.dataset.pid);
                }
            });
            var count = dirtyPids.size;
            var el = document.getElementById('b2f-dirty-count');
            var bar = document.getElementById('b2f-batch-save-bar');
            if (el) { el.textContent = 'แก้ไข: ' + count + ' รายการ'; el.style.display = count ? 'inline' : 'none'; }
            if (bar) bar.style.display = count ? 'flex' : 'none';
            var btn = bar ? bar.querySelector('button') : null;
            if (btn) btn.textContent = '💾 บันทึกทั้งหมด (' + count + ' รายการ)';
        }

        /* ── Quick Shipping Update ── */
        function quickShipping(type) {
            var label = type === 'sea' ? 'ค่าส่ง/เรือ' : 'ค่าส่ง/รถ';
            var val = prompt(label + ' ใหม่ (฿) สำหรับทุก SKU:');
            if (val === null) return;
            var num = parseFloat(val);
            if (isNaN(num) || num < 0) { toast('กรุณากรอกตัวเลข', 'error'); return; }
            var cls = type === 'sea' ? 'shipping_sea' : 'shipping_land';
            document.querySelectorAll('.sku-inp[data-field="' + cls + '"]').forEach(function(inp) {
                inp.value = num;
                checkDirty(inp);
            });
            toast('อัพเดท ' + label + ' ทุก SKU = ฿' + num, 'success');
        }

        /* ── Batch Save ── */
        function batchSaveProducts() {
            var rows = document.querySelectorAll('.b2f-sku-row');
            var promises = [];
            rows.forEach(function(row) {
                var inputs = row.querySelectorAll('.sku-inp');
                var hasDirty = false;
                inputs.forEach(function(i) { if (i.value !== i.dataset.original) hasDirty = true; });
                if (!hasDirty) return;

                var pid = row.dataset.pid;
                var data = { id: parseInt(pid), mp_maker_id: _currentMakerId };
                var fieldMap = { unit_cost:'mp_unit_cost', moq:'mp_moq', lead_time_days:'mp_lead_time_days',
                                lead_land:'mp_lead_land', lead_sea:'mp_lead_sea',
                                shipping_land:'mp_shipping_land', shipping_sea:'mp_shipping_sea' };
                inputs.forEach(function(i) {
                    var f = i.dataset.field;
                    if (fieldMap[f]) {
                        data[fieldMap[f]] = (f === 'moq' || f.indexOf('lead') === 0) ? (parseInt(i.value)||0) : (parseFloat(i.value)||0);
                    }
                });
                data.mp_product_sku = row.dataset.sku || '';
                data.mp_product_name = row.dataset.name || '';
                promises.push(api('POST', 'maker-product', data));
            });

            if (!promises.length) { toast('ไม่มีรายการที่แก้ไข', 'info'); return; }

            var btn = document.querySelector('#b2f-batch-save-bar button');
            if (btn) { btn.disabled = true; btn.textContent = '💾 กำลังบันทึก...'; }

            Promise.all(promises).then(function(results) {
                var ok = results.filter(function(r){ return r.success; }).length;
                var fail = results.length - ok;
                toast('บันทึก ' + ok + '/' + (ok+fail) + ' รายการ' + (fail ? ' (ล้มเหลว ' + fail + ')' : ''), ok ? 'success' : 'error');
                loadProducts(_currentMakerId);
            }).catch(function() {
                if (btn) { btn.disabled = false; }
                toast('เกิดข้อผิดพลาด', 'error');
            });
        }

        function deleteProduct(productId, sku) {
            if (!confirm('ยืนยันลบ SKU: ' + sku + '?')) return;
            api('POST', 'maker-product/delete', { product_id: productId }).then(function(res) {
                if (res.success) {
                    toast('ลบสำเร็จ', 'success');
                    loadProducts(_currentMakerId);
                } else {
                    toast(res.error || 'ลบไม่สำเร็จ', 'error');
                }
            });
        }

