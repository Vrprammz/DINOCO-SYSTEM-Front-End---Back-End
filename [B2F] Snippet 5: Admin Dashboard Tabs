                html += '<div><div style="font-size:10px;font-weight:600;color:#374151;">ค่าส่ง/รถ (฿)</div><input type="number" class="b2f-ship-land-input" data-sku="' + esc(sku) + '" value="0" min="0" step="0.01" style="width:80px;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></div>';
                html += '<div><div style="font-size:10px;font-weight:600;color:#374151;">ค่าส่ง/เรือ (฿)</div><input type="number" class="b2f-ship-sea-input" data-sku="' + esc(sku) + '" value="0" min="0" step="0.01" style="width:80px;padding:6px 8px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;"></div>';
