// ═══════════════════════════════════════════════════════════════
// V.25: REMOTE COMMAND CHANNEL — Admin → RPi via poll response
// Allowed commands: restart_service, reboot, update_client, logs
// ═══════════════════════════════════════════════════════════════

/**
 * POST /b2b/v1/rpi-command — Admin queues a command for RPi to execute.
 */
function b2b_rest_rpi_command( WP_REST_Request $request ) {
    $is_admin = wp_verify_nonce($request->get_header('X-WP-Nonce'), 'wp_rest') && current_user_can('manage_options');
    if ( !$is_admin )
        return new WP_REST_Response(array('success'=>false,'message'=>'Unauthorized'), 403);

    $command = sanitize_text_field($request->get_param('command') ?: '');
    $allowed = array('restart_service', 'reboot', 'update_client', 'get_logs');
    if ( !in_array($command, $allowed, true) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Unknown command: '.$command.'. Allowed: '.implode(', ',$allowed)), 400);

    $cmd_id = 'cmd_' . time() . '_' . wp_rand(1000, 9999);
    $pending = get_option('b2b_rpi_pending_commands', array());
    $pending[] = array(
        'id'        => $cmd_id,
        'command'   => $command,
        'params'    => $request->get_param('params') ?: array(),
        'queued_at' => time(),
        'queued_by' => wp_get_current_user()->user_login,
    );
    update_option('b2b_rpi_pending_commands', $pending, false);

    $labels = array(
        'restart_service' => 'รีสตาร์ท print service',
        'reboot'          => 'รีบูท RPi',
        'update_client'   => 'อัปเดต print client',
        'get_logs'        => 'ดึง log ล่าสุด',
    );
    b2b_log('[RPi Command] Queued: ' . $command . ' (id: ' . $cmd_id . ')');
    return new WP_REST_Response(array(
        'success' => true,
        'cmd_id'  => $cmd_id,
        'message' => 'ส่งคำสั่ง "' . $labels[$command] . '" แล้ว — RPi จะรับภายใน 10 วินาที',
    ), 200);
}

/**
 * POST /b2b/v1/rpi-command-ack — RPi reports command execution result.
 */
function b2b_rest_rpi_command_ack( WP_REST_Request $request ) {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $cmd_id = sanitize_text_field($request->get_param('cmd_id') ?: '');
    $status = sanitize_text_field($request->get_param('status') ?: ''); // 'done' or 'error'
    $output = sanitize_text_field($request->get_param('output') ?: '');

    if ( !$cmd_id || !in_array($status, array('done','error'), true) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid params'), 400);

    // Remove from pending
    $pending = get_option('b2b_rpi_pending_commands', array());
    $cmd_info = null;
    $pending = array_values(array_filter($pending, function($c) use ($cmd_id, &$cmd_info) {
        if ($c['id'] === $cmd_id) { $cmd_info = $c; return false; }
        return true;
    }));
    update_option('b2b_rpi_pending_commands', $pending, false);

    // Store result for admin panel to display
    $history = get_option('b2b_rpi_command_history', array());
    array_unshift($history, array(
        'id'          => $cmd_id,
        'command'     => $cmd_info ? $cmd_info['command'] : 'unknown',
        'status'      => $status,
        'output'      => $output,
        'completed_at'=> time(),
    ));
    // Keep last 20 results
    $history = array_slice($history, 0, 20);
    update_option('b2b_rpi_command_history', $history, false);

    $emoji = $status === 'done' ? '✅' : '❌';
    $cmd_label = $cmd_info ? $cmd_info['command'] : $cmd_id;
    b2b_log("[RPi Command] Ack: {$cmd_label} — {$status}" . ($output ? ": {$output}" : ''));

    // Notify admin on error
    if ( $status === 'error' && function_exists('b2b_push_to_admin') ) {
        b2b_push_to_admin("{$emoji} RPi command failed: {$cmd_label}\n{$output}");
    }

    return new WP_REST_Response(array('success'=>true), 200);
}

// ═══════════════════════════════════════════════════════════════
// V.26: RPi DASHBOARD — Summary data for kiosk screen
// ═══════════════════════════════════════════════════════════════
function b2b_rest_rpi_dashboard( WP_REST_Request $request ) {
    try {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $today     = date('Y-m-d');
    $month_start = date('Y-m-01');

    // ── Today's orders (non-cancelled) ──
    $today_args = array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => -1,
        'post_status'    => 'publish',
        'fields'         => 'ids',
        'date_query'     => array( array( 'after' => $today . ' 00:00:00', 'before' => $today . ' 23:59:59', 'inclusive' => true ) ),
        'meta_query'     => array( array( 'key' => 'order_status', 'value' => 'cancelled', 'compare' => '!=' ) ),
    );
    $today_ids = get_posts( $today_args );

    $today_orders  = count( $today_ids );
    $today_revenue = 0;
    $shipped       = 0;
    $shipped_amount = 0;
    $paid          = 0;
    $paid_amount   = 0;

    foreach ( $today_ids as $oid ) {
        $amount = floatval( get_field('total_amount', $oid) );
        $today_revenue += $amount;

        // Shipped today
        if ( get_field('shipped_date', $oid) === $today ) {
            $shipped++;
            $shipped_amount += $amount;
        }

        // Paid today — check status history for 'paid' transition today
        $history = get_field('_b2b_status_history', $oid);
        if ( is_array($history) ) {
            foreach ( $history as $entry ) {
                if ( isset($entry['status']) && $entry['status'] === 'paid'
                     && isset($entry['time']) && strpos($entry['time'], $today) === 0 ) {
                    $paid++;
                    $paid_amount += $amount;
                    break;
                }
            }
        }
    }

    // ── Pipeline — count by status ──
    $pipeline_map = array(
        'checking_stock'   => 'เช็คสต็อก',
        'awaiting_confirm' => 'รอยืนยัน',
        'awaiting_payment' => 'รอชำระเงิน',
        'paid'             => 'ชำระแล้ว',
        'shipped'          => 'จัดส่งแล้ว',
    );
    $pipeline = array();
    foreach ( $pipeline_map as $status_key => $label ) {
        $p = get_posts(array(
            'post_type'      => 'b2b_order',
            'posts_per_page' => -1,
            'post_status'    => 'publish',
            'fields'         => 'ids',
            'meta_query'     => array( array( 'key' => 'order_status', 'value' => $status_key ) ),
        ));
        $amount = 0;
        foreach ( $p as $pid ) {
            $amount += floatval( get_field('total_amount', $pid) );
        }
        $pipeline[] = array(
            'status' => $status_key,
            'label'  => $label,
            'count'  => count($p),
            'amount' => $amount,
        );
    }

    // ── MTD revenue (non-cancelled, from 1st of month) ──
    $mtd_ids = get_posts(array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => -1,
        'post_status'    => 'publish',
        'fields'         => 'ids',
        'date_query'     => array( array( 'after' => $month_start . ' 00:00:00', 'before' => $today . ' 23:59:59', 'inclusive' => true ) ),
        'meta_query'     => array( array( 'key' => 'order_status', 'value' => 'cancelled', 'compare' => '!=' ) ),
    ));
    $mtd_revenue = 0;
    foreach ( $mtd_ids as $mid ) {
        $mtd_revenue += floatval( get_field('total_amount', $mid) );
    }

    // ── Outstanding debt across all distributors ──
    $dist_ids = get_posts(array(
        'post_type'      => 'b2b_dist',
        'posts_per_page' => -1,
        'post_status'    => 'publish',
        'fields'         => 'ids',
    ));
    $outstanding = 0;
    foreach ( $dist_ids as $did ) {
        $outstanding += floatval( get_field('current_debt', $did) );
    }

    // ── Recent orders (last 5) ──
    $recent_posts = get_posts(array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => 5,
        'post_status'    => 'publish',
        'orderby'        => 'date',
        'order'          => 'DESC',
    ));
    $recent_orders = array();
    foreach ( $recent_posts as $rp ) {
        $gid  = get_field('source_group_id', $rp->ID);
        $dist = $gid ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? get_the_title($dist->ID) : '—';
        $recent_orders[] = array(
            'id'     => $rp->ID,
            'shop'   => $shop,
            'total'  => floatval( get_field('total_amount', $rp->ID) ),
            'status' => get_field('order_status', $rp->ID) ?: '',
            'time'   => date('H:i', strtotime($rp->post_date)),
        );
    }

    // ── Pending stock check orders ──
    $stock_posts = get_posts(array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => 20,
        'post_status'    => 'publish',
        'orderby'        => 'date',
        'order'          => 'ASC',
        'meta_query'     => array( array( 'key' => 'order_status', 'value' => 'checking_stock' ) ),
    ));
    $pending_stock_check = array();
    foreach ( $stock_posts as $sp ) {
        $gid  = get_field('source_group_id', $sp->ID);
        $dist = $gid ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? get_the_title($dist->ID) : '—';

        $items_raw = get_field('order_items', $sp->ID) ?: '';
        $items = array();
        if ( preg_match_all('/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)\s*=\s*฿?([\d,.]+)/mu', $items_raw, $m, PREG_SET_ORDER) ) {
            foreach ( $m as $match ) {
                $items[] = array(
                    'name' => trim($match[1]),
                    'sku'  => $match[2],
                    'qty'  => intval($match[3]),
                    'price'=> floatval(str_replace(',', '', $match[4])),
                );
            }
        }

        $pending_stock_check[] = array(
            'id'         => $sp->ID,
            'shop'       => $shop,
            'items'      => $items,
            'total'      => floatval( get_field('total_amount', $sp->ID) ),
            'created_at' => date('H:i', strtotime($sp->post_date)),
        );
    }

    return new WP_REST_Response(array(
        'today' => array(
            'orders'         => $today_orders,
            'revenue'        => $today_revenue,
            'shipped'        => $shipped,
            'shipped_amount' => $shipped_amount,
            'paid'           => $paid,
            'paid_amount'    => $paid_amount,
        ),
        'pipeline'            => $pipeline,
        'mtd_revenue'         => $mtd_revenue,
        'outstanding'         => $outstanding,
        'recent_orders'       => $recent_orders,
        'pending_stock_check' => $pending_stock_check,
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[RPiDashboard] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════════════════════════════
// V.26: RPi ACCEPT ORDER — Move order from checking_stock → awaiting_confirm
// ═══════════════════════════════════════════════════════════════
function b2b_rest_rpi_accept_order( WP_REST_Request $request ) {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $tid = intval($request->get_param('ticket_id'));
    if ( !$tid || get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Ticket not found'), 404);

    $current_status = get_field('order_status', $tid) ?: '';
    if ( $current_status !== 'checking_stock' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Order not in checking_stock status'), 400);

    if ( function_exists('b2b_set_order_status') ) {
        b2b_set_order_status( $tid, 'awaiting_confirm' );
    } else {
        update_field('order_status', 'awaiting_confirm', $tid);
    }
    b2b_log('[RPi] Order #' . $tid . ' accepted from kiosk screen');

    return new WP_REST_Response(array('success'=>true,'message'=>'Order accepted'), 200);
}

// ═══════════════════════════════════════════════════════════════
// V.33: PNO LOOKUP — Find ticket by Flash tracking number
// ═══════════════════════════════════════════════════════════════
function b2b_rest_pno_lookup( WP_REST_Request $request ) {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $pno = sanitize_text_field($request->get_param('pno'));
    if ( !$pno || strlen($pno) < 10 )
        return new WP_REST_Response(array('success'=>false,'error'=>'Invalid PNO'), 400);

    // Search _flash_tracking_numbers meta (serialized array containing PNO)
    global $wpdb;
    $ticket_id = $wpdb->get_var( $wpdb->prepare(
        "SELECT post_id FROM {$wpdb->postmeta}
         WHERE meta_key = '_flash_tracking_numbers' AND meta_value LIKE %s
         ORDER BY post_id DESC LIMIT 1",
        '%' . $wpdb->esc_like($pno) . '%'
    ) );

    if ( !$ticket_id || get_post_type($ticket_id) !== 'b2b_order' ) {
        // V.38: Fallback — check manual shipments
        $manual = b2b_manual_pno_lookup( $pno );
        if ( $manual ) return new WP_REST_Response( $manual, 200 );
        return new WP_REST_Response(array('success'=>false,'error'=>'ไม่พบ Ticket สำหรับ PNO: '.$pno), 404);
    }

    // Reuse ticket-lookup by faking the request param
    $request->set_param('ticket_id', $ticket_id);
    return b2b_rest_ticket_lookup($request);
}

// V.38: Manual PNO lookup — search wp_options manual shipments
function b2b_manual_pno_lookup( $pno ) {
    // Search current + 5 previous months
    $months = array();
    for ( $i = 0; $i < 6; $i++ ) {
        $months[] = date( 'Y_m', strtotime( '-' . $i . ' month' ) );
    }
    foreach ( $months as $m ) {
        $shipments = get_option( 'b2b_manual_shipments_' . $m, array() );
        foreach ( $shipments as $s ) {
            if ( isset( $s['pno'] ) && $s['pno'] === $pno ) {
                return array(
                    'id'              => 0,
                    'is_manual'       => true,
                    'shop'            => $s['dst_name'],
                    'total'           => 0,
                    'status'          => $s['status'] ?? 'created',
                    'status_label'    => 'Manual Ship',
                    'ship_method'     => 'flash',
                    'tracking'        => $pno,
                    'carrier'         => 'Flash',
                    'total_boxes'     => 1,
                    'items'           => array( array(
                        'name' => $s['item_desc'] ?: $s['remark'] ?: 'Manual Shipment',
                        'sku'  => $s['out_trade_no'] ?? '',
                        'qty'  => 1,
                    ) ),
                    'created_at'      => $s['created_at'] ?? '',
                    'flash_packing'   => ( $s['status'] === 'created' ) ? 'ready_to_ship' : $s['status'],
                    'print_status'    => 'done',
                    'dst_address'     => $s['dst_address'] ?? '',
                );
            }
        }
    }
    return null;
}

// ═══════════════════════════════════════════════════════════════
// V.30: TICKET LOOKUP — RPi Scanner QR code lookup
// ═══════════════════════════════════════════════════════════════
function b2b_rest_ticket_lookup( WP_REST_Request $request ) {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $tid = intval($request->get_param('ticket_id'));
    if ( !$tid || get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'error'=>'Ticket not found'), 404);

    $status = get_field('order_status', $tid) ?: get_field('b2b_order_status', $tid) ?: 'unknown';
    $labels = array(
        'draft'=>'Draft','checking_stock'=>'เช็คสต็อก','awaiting_confirm'=>'รอยืนยัน',
        'awaiting_payment'=>'รอชำระเงิน','paid'=>'ชำระแล้ว','packed'=>'แพ็คแล้ว รอส่ง',
        'shipped'=>'จัดส่งแล้ว','completed'=>'เสร็จสิ้น','backorder'=>'Backorder',
        'cancelled'=>'ยกเลิก','cancel_requested'=>'ขอยกเลิก',
    );

    // Get distributor shop name
    $group_id = get_field('source_group_id', $tid);
    $shop = '';
    if ( $group_id && function_exists('b2b_get_dist_by_group') ) {
        $dist = b2b_get_dist_by_group($group_id);
        if ($dist) $shop = get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID);
    }
    if ( !$shop ) $shop = get_field('dist_name', $tid) ?: '';

    // Parse items from order_items text
    $items_raw = get_field('order_items', $tid) ?: '';
    $items = array();
    if ( preg_match_all('/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)\s*=\s*฿?([\d,.]+)/mu', $items_raw, $matches, PREG_SET_ORDER) ) {
        foreach ($matches as $m) {
            $items[] = array('name'=>trim($m[1]), 'sku'=>$m[2], 'qty'=>intval($m[3]), 'price'=>floatval(str_replace(',','',$m[4])));
        }
    }

    // Box count
    $total_boxes = function_exists('b2b_calculate_total_boxes') ? b2b_calculate_total_boxes($tid) : 0;

    $ship_method = get_post_meta($tid, '_ship_method', true) ?: '';
    $tracking    = get_field('tracking_number', $tid) ?: '';
    $carrier     = get_field('shipping_provider', $tid) ?: '';
    $flash_ps    = get_post_meta($tid, '_flash_packing_status', true) ?: '';
    $print_st    = get_field('print_status', $tid) ?: '';

    return new WP_REST_Response(array(
        'id'              => $tid,
        'shop'            => $shop,
        'total'           => floatval(get_field('total_amount', $tid)),
        'status'          => $status,
        'status_label'    => isset($labels[$status]) ? $labels[$status] : $status,
        'ship_method'     => $ship_method,
        'tracking'        => $tracking,
        'carrier'         => $carrier,
        'total_boxes'     => $total_boxes,
        'items'           => $items,
        'created_at'      => get_the_date('Y-m-d H:i', $tid),
        'flash_packing'   => $flash_ps,
        'print_status'    => $print_st,
    ), 200);
}

/**
 * POST /b2b/v1/rpi-flash-ready — RPi scan triggers ready-to-ship + call courier.
 *
 * V.35 REWRITE — "สแกนปุ๊บจบ ระบบจัดการเอง"
 *
 * Flash /notify = per-warehouse (1 call = 1 คูเรียร์มารับทุกพัสดุที่คลัง)
 * - ถ้ามี active pickup อยู่แล้ว → ใช้ข้อมูลเดิม ไม่เรียกซ้ำ
 * - ถ้ายังไม่มี → เรียก notify 1 ครั้ง, cache ผลไว้ใน transient
 * - ถ้า Flash reject "มีนัดรับ" → ดึง /notifications, treat as success
 * - ห้าม cancel pickup! (คูเรียร์กำลังมา)
 * - ส่ง Flex ลูกค้าเมื่อ webhook state=2 (รับพัสดุแล้ว) ไม่ใช่ตอนเรียกรถ
 */
function b2b_rest_rpi_flash_ready( WP_REST_Request $request ) {
    if ( ! b2b_verify_print_key( $request ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Invalid API key' ), 403 );

    $tid = intval( $request->get_param( 'ticket_id' ) );
    if ( ! $tid || get_post_type( $tid ) !== 'b2b_order' )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Ticket not found' ), 404 );

    $packing = get_post_meta( $tid, '_flash_packing_status', true );

    // ── Already past courier stage → return current info, no re-call ──
    if ( in_array( $packing, array( 'courier_called', 'picked_up', 'in_transit', 'delivered' ), true ) ) {
        $cached = get_post_meta( $tid, '_flash_courier_info', true );
        $info_text = '';
        if ( is_array( $cached ) && ! empty( $cached['name'] ) ) {
            $info_text = 'คูเรียร์: ' . $cached['name'] . ' ' . ( $cached['phone'] ?? '' ) . ' (เรียกแล้ว)';
        }
        return new WP_REST_Response( array(
            'success'        => true,
            'queued'         => false,
            'message'        => 'เรียกรถไปแล้ว — ไม่ต้องเรียกซ้ำ',
            'courier_info'   => $info_text,
            'packing_status' => $packing,
        ), 200 );
    }

    // ── Validate packing status allows courier call ──
    $allowed = array( 'flash_created', 'print_queued', 'print_done', 'packed', 'ready_to_ship', 'notify_error' );
    if ( ! in_array( $packing, $allowed, true ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'สถานะไม่พร้อม: ' . $packing ), 400 );
    }

    // ── V.37: Multi-box guard — if >1 box, require per-box scan first ──
    $pnos = get_post_meta( $tid, '_flash_tracking_numbers', true );
    $total_parcels = is_array( $pnos ) ? count( $pnos ) : 1;
    if ( $total_parcels > 1 ) {
        $pno_statuses = get_post_meta( $tid, '_flash_pno_statuses', true );
        if ( is_array( $pno_statuses ) ) {
            $all_packed = true;
            foreach ( $pno_statuses as $pno => $info ) {
                $s = is_array( $info ) ? ( $info['status'] ?? 'created' ) : 'created';
                if ( $s === 'cancelled' || $s === 'hold_pending' ) continue; // skip cancelled/held
                $pa = is_array( $info ) ? ( $info['packed_at'] ?? null ) : null;
                if ( ! $pa ) { $all_packed = false; break; }
            }
            if ( ! $all_packed ) {
                // Multi-box not fully packed → tell kiosk to use per-box scan
                return new WP_REST_Response( array(
                    'success'        => false,
                    'message'        => 'ออเดอร์มี ' . $total_parcels . ' กล่อง — สแกน barcode Flash ทีละกล่อง',
                    'multi_box'      => true,
                    'total_boxes'    => $total_parcels,
                    'pno_statuses'   => $pno_statuses,
                    'packing_status' => $packing,
                ), 200 );
            }
        }
    }

    // ── Mark order as ready (fast — return to kiosk ASAP) ──
    update_post_meta( $tid, '_flash_packing_status', 'ready_to_ship' );
    b2b_add_audit_log( $tid, 'flash_ready', 'ของพร้อมส่ง (RPi scan)' );

    // ── Check active pickup in transient cache ──
    $active_pickup = get_transient( 'b2b_flash_active_pickup' );

    if ( is_array( $active_pickup ) && ! empty( $active_pickup['pickup_id'] ) ) {
        // ─── Active pickup exists → use cached info, don't call Flash again ───
        $active_pickup['parcel_count'] = intval( $active_pickup['parcel_count'] ?? 0 ) + $total_parcels;
        if ( ! is_array( $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'] = array();
        if ( ! in_array( $tid, $active_pickup['ticket_ids'] ) ) {
            $active_pickup['ticket_ids'][] = $tid;
        }
        set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );

        // Link this order to the active pickup
        update_post_meta( $tid, '_flash_packing_status', 'courier_called' );
        update_post_meta( $tid, '_flash_pickup_id', $active_pickup['pickup_id'] );
        update_post_meta( $tid, '_flash_courier_info', array(
            'name'  => $active_pickup['staff_name'],
            'phone' => $active_pickup['staff_phone'],
        ) );

        // V.37: Admin Flex: เพิ่ม order เข้า pickup เดิม (Flex Card แทน text)
        if ( function_exists( 'b2b_build_flex_pickup_added' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
            $flex = b2b_build_flex_pickup_added( $tid, $active_pickup );
            b2b_push_raw_to_admin( array( $flex ) );
        } elseif ( function_exists( 'b2b_push_to_admin' ) ) {
            $dist_name = get_field( 'dist_name', $tid ) ?: '';
            b2b_push_to_admin( '📦 เพิ่ม #' . $tid . ' ' . $dist_name . ' เข้า pickup — รวม '
                . $active_pickup['parcel_count'] . ' กล่อง (คูเรียร์: '
                . $active_pickup['staff_name'] . ' กำลังมา)' );
        }

        b2b_log( '[Flash] #' . $tid . ' added to existing pickup ' . $active_pickup['pickup_id'] );

        return new WP_REST_Response( array(
            'success'        => true,
            'queued'         => false,
            'message'        => 'เพิ่มเข้า pickup เดิม — คูเรียร์กำลังมา',
            'courier_info'   => 'คูเรียร์: ' . $active_pickup['staff_name'] . ' ' . $active_pickup['staff_phone'],
            'packing_status' => 'courier_called',
        ), 200 );
    }

    // ─── No active pickup → call Flash /notify ───
    $courier_ok  = false;
    $courier_msg = '';
    $pickup_data = null;

    if ( function_exists( 'b2b_flash_notify_courier_from_warehouse' ) ) {
        $courier_result = b2b_flash_notify_courier_from_warehouse( $total_parcels, 'Order: ' . $tid );

        if ( $courier_result['ok'] && ! empty( $courier_result['data'] ) ) {
            // ─── Notify SUCCESS ───
            $pickup_data = $courier_result['data'];
            $courier_ok  = true;

        } elseif ( ! $courier_result['ok'] && function_exists( 'b2b_flash_get_notifications' ) ) {
            // ─── Flash rejected (likely "มีนัดรับอยู่แล้ว") → check /notifications ───
            b2b_log( '[Flash] Notify rejected for #' . $tid . ': ' . ( $courier_result['error'] ?? '' ) . ' — checking /notifications' );
            $notif_result = b2b_flash_get_notifications( date( 'Y-m-d' ) );
            if ( $notif_result['ok'] && ! empty( $notif_result['data'] ) ) {
                // Find active pickup (state 0=รอจัดสรร or 1=รอรับ)
                $pickups = is_array( $notif_result['data'] ) ? $notif_result['data'] : array();
                // If data is a list of pickups
                foreach ( $pickups as $pu ) {
                    $pu_state = isset( $pu['state'] ) ? intval( $pu['state'] ) : -1;
                    if ( $pu_state === 0 || $pu_state === 1 ) {
                        $pickup_data = $pu;
                        $courier_ok  = true;
                        b2b_log( '[Flash] Found active pickup from /notifications: ' . ( $pu['ticketPickupId'] ?? '' ) );
                        break;
                    }
                }
            }
            if ( ! $courier_ok ) {
                $err = $courier_result['error'] ?? 'Unknown error';
                $courier_msg = 'เรียกรถไม่สำเร็จ: ' . $err;
                b2b_log( '[Flash] No active pickup found, courier call truly failed for #' . $tid );
            }
        }
    }

    if ( $courier_ok && $pickup_data ) {
        // ─── Success: cache pickup info + notify admin ───
        b2b_log( '[Flash] Notify response keys: ' . implode( ',', array_keys( $pickup_data ) ) );
        $staff   = $pickup_data['staffInfoName']  ?? $pickup_data['staffInfoname'] ?? '';
        $phone   = $pickup_data['staffInfoPhone'] ?? $pickup_data['staffInfomobile'] ?? '';
        $timeout = $pickup_data['timeoutAtText']  ?? '';
        if ( empty( $staff ) || empty( $phone ) ) {
            b2b_log( '[Flash] ⚠ Courier info incomplete — name=' . var_export($staff,true) . ' phone=' . var_export($phone,true) );
        }
        $pid     = $pickup_data['ticketPickupId']  ?? '';

        // Save transient (shared across all orders in this pickup)
        $active_pickup = array(
            'pickup_id'    => $pid,
            'staff_name'   => $staff,
            'staff_phone'  => $phone,
            'timeout_text' => $timeout,
            'created_at'   => time(),
            'parcel_count' => $total_parcels,
            'ticket_ids'   => array( $tid ),
        );
        set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );

        // Update this order
        update_post_meta( $tid, '_flash_packing_status', 'courier_called' );
        update_post_meta( $tid, '_flash_pickup_id', $pid );
        update_post_meta( $tid, '_flash_courier_info', array( 'name' => $staff, 'phone' => $phone, 'pickupId' => $pid ) );

        $courier_msg = "คูเรียร์: {$staff} {$phone} มารับภายใน {$timeout}";
        b2b_log( '[Flash] Courier called for #' . $tid . ': ' . $courier_msg );

        // Admin Flex: full pickup card with courier info + order list
        if ( function_exists( 'b2b_build_flex_courier_pickup' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
            $flex = b2b_build_flex_courier_pickup( $active_pickup );
            b2b_push_raw_to_admin( array( $flex ) );
        } elseif ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '🚛 เรียกรถ Flash สำเร็จ — ' . $courier_msg );
        }

        return new WP_REST_Response( array(
            'success'        => true,
            'queued'         => false,
            'message'        => $courier_msg,
            'courier_info'   => $courier_msg,
            'packing_status' => 'courier_called',
        ), 200 );
    }

    // ─── Failed: schedule WP Cron retry (network errors only) ───
    update_post_meta( $tid, '_flash_packing_status', 'notify_error' );
    update_post_meta( $tid, '_flash_notify_error', $courier_msg );
    $retry_count = intval( get_post_meta( $tid, '_flash_courier_retry_count', true ) );
    update_post_meta( $tid, '_flash_courier_retry_count', $retry_count + 1 );

    $retry_delays = array( 120, 300, 600, 900 ); // 2min, 5min, 10min, 15min
    if ( $retry_count < count( $retry_delays ) ) {
        $delay = $retry_delays[ $retry_count ];
        wp_schedule_single_event( time() + $delay, 'b2b_flash_courier_retry', array( $tid ) );
        b2b_log( '[Flash] Scheduled retry #' . ( $retry_count + 1 ) . ' for #' . $tid . ' in ' . $delay . 's' );
        $courier_msg .= ' (จะลองใหม่อัตโนมัติใน ' . intval( $delay / 60 ) . ' นาที)';
    } else {
        // All retries exhausted → notify admin with Flex
        b2b_log( '[Flash] All retries exhausted for #' . $tid );
        if ( function_exists( 'b2b_build_flex_flash_admin' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
            $admin_flex = b2b_build_flex_flash_admin( $tid, 'courier_fail', array(
                'error' => $courier_msg . ' (retry หมดแล้ว)',
            ) );
            b2b_push_raw_to_admin( array( $admin_flex ) );
        }
    }

    return new WP_REST_Response( array(
        'success'        => true,  // tell kiosk "รับแล้ว" (ระบบจะ retry เอง)
        'queued'         => true,
        'message'        => 'ระบบรับแล้ว กำลังเรียกรถ...',
        'courier_info'   => $courier_msg,
        'packing_status' => 'notify_error',
    ), 200 );
}

// ═══════════════════════════════════════════════════════════════
// V.22.0: COMBINED BILL PAYMENT — Upload slip for multiple tickets
// ═══════════════════════════════════════════════════════════════
function b2b_rest_combined_slip_upload( WP_REST_Request $request ) {
    try {
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $ticket_ids = $request->get_param('ticket_ids');
    $image_b64  = $request->get_param('image_base64');
    $gid        = $session['gid'];

    if ( empty($ticket_ids) || !is_array($ticket_ids) || empty($image_b64) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing ticket_ids or image'), 400);

    // Validate all tickets belong to this group + status = awaiting_payment
    $combined_total = 0;
    $valid_tickets = array();
    foreach ( $ticket_ids as $tid ) {
        $tid = intval($tid);
        if ( !$tid || get_post_type($tid) !== 'b2b_order' )
            return new WP_REST_Response(array('success'=>false,'message'=>'Ticket #'.$tid.' ไม่พบ'), 404);
        if ( get_field('source_group_id', $tid) !== $gid )
            return new WP_REST_Response(array('success'=>false,'message'=>'Ticket #'.$tid.' ไม่ใช่ของคุณ'), 403);
        $status = get_field('order_status', $tid);
        if ( $status !== 'awaiting_payment' )
            return new WP_REST_Response(array('success'=>false,'message'=>'Ticket #'.$tid.' ไม่ได้อยู่ในสถานะรอชำระ (status: '.$status.')'), 400);
        $total = floatval(get_field('total_amount', $tid));
        $combined_total += $total;
        $valid_tickets[] = array('id' => $tid, 'total' => $total);
    }

    // ── Save slip image (same pattern as slip-upload) ──
    $upload_dir = wp_upload_dir();
    $slip_dir   = $upload_dir['basedir'] . '/b2b-slips';
    if ( !file_exists($slip_dir) ) wp_mkdir_p($slip_dir);

    $filename = 'slip-combined-' . implode('-', array_column($valid_tickets, 'id')) . '-' . b2b_date('YmdHis') . '.jpg';
    $filepath = $slip_dir . '/' . $filename;

    $raw = $image_b64;
    if ( strpos($raw, ',') !== false ) $raw = explode(',', $raw, 2)[1];
    $decoded = base64_decode($raw);

    if ( !$decoded || strlen($decoded) < 1000 )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid image data'), 400);
    if ( strlen($decoded) > 5 * 1024 * 1024 )
        return new WP_REST_Response(array('success'=>false,'message'=>'ไฟล์ใหญ่เกินไป (max 5MB)'), 400);

    $finfo = new finfo(FILEINFO_MIME_TYPE);
    $mime = $finfo->buffer($decoded);
    if ( !in_array($mime, array('image/jpeg','image/png','image/gif','image/webp')) )
        return new WP_REST_Response(array('success'=>false,'message'=>'ไฟล์ไม่ใช่รูปภาพ'), 400);

    if ( file_put_contents($filepath, $decoded) === false )
        return new WP_REST_Response(array('success'=>false,'message'=>'บันทึกไฟล์ไม่สำเร็จ'), 500);
    $slip_url = $upload_dir['baseurl'] . '/b2b-slips/' . $filename;

    // ── Verify via Slip2go ──
    $slip_result = null;
    if ( defined('B2B_SLIP2GO_SECRET_KEY') ) {
        $api_url = defined('B2B_SLIP2GO_API_URL')
            ? B2B_SLIP2GO_API_URL
            : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';

        $check_condition = array('checkDuplicate' => true);
        $bank_info = function_exists('b2b_get_bank_info') ? b2b_get_bank_info() : null;
        if ( $bank_info && !empty($bank_info['account']) ) {
            $account_number = preg_replace('/[^0-9]/', '', $bank_info['account']);
            $receiver = array('accountNumber' => $account_number);
            if ( !empty($bank_info['bank_code']) ) {
                $receiver['accountType'] = '01' . str_pad($bank_info['bank_code'], 3, '0', STR_PAD_LEFT);
            }
            $receivers = array($receiver);
            // V.38.6: Walk-in bank — accept both regular and walk-in bank accounts
            if ( defined('B2B_WALKIN_BANK_ACCOUNT') && B2B_WALKIN_BANK_ACCOUNT ) {
                $walkin_acct = preg_replace('/[^0-9]/', '', B2B_WALKIN_BANK_ACCOUNT);
                if ( $walkin_acct !== $account_number ) {
                    $walkin_receiver = array('accountNumber' => $walkin_acct);
                    $walkin_code = defined('B2B_WALKIN_BANK_CODE') ? B2B_WALKIN_BANK_CODE : (defined('B2B_BANK_CODE') ? B2B_BANK_CODE : '');
                    if ( !empty($walkin_code) ) {
                        $walkin_receiver['accountType'] = '01' . str_pad($walkin_code, 3, '0', STR_PAD_LEFT);
                    }
                    $receivers[] = $walkin_receiver;
                }
            }
            $check_condition['checkReceiver'] = $receivers;
        }

        $slip_response = wp_remote_post($api_url, array(
            'headers' => array('Authorization'=>'Bearer '.B2B_SLIP2GO_SECRET_KEY,'Content-Type'=>'application/json'),
            'body' => wp_json_encode(array('payload'=>array(
                'imageBase64'    => 'data:'.$mime.';base64,' . base64_encode($decoded),
                'checkCondition' => $check_condition,
            ))),
            'timeout' => 45,
        ));

        if ( !is_wp_error($slip_response) && wp_remote_retrieve_response_code($slip_response) === 200 ) {
            $slip_result = json_decode(wp_remote_retrieve_body($slip_response), true);
        }

        // ── Check slip amount >= combined total (2% tolerance) ──
        if ( $slip_result && isset($slip_result['data']['amount']) ) {
            $slip_amount = floatval($slip_result['data']['amount']);
            if ( $slip_amount < $combined_total * 0.98 ) {
                return new WP_REST_Response(array(
                    'success' => false,
                    'message' => 'ยอดสลิป ฿'.number_format($slip_amount,2).' ไม่ตรงกับยอดรวม ฿'.number_format($combined_total,2),
                    'slip_url' => $slip_url,
                    'slip_result' => $slip_result,
                ), 400);
            }
        }
    }

    // ── Mark all tickets as paid ──
    $dist = b2b_get_dist_by_group($gid);
    $paid_ticket_ids = array();
    foreach ( $valid_tickets as $vt ) {
        $tid = $vt['id'];
        // Re-check status to prevent race condition
        if ( get_field('order_status', $tid) !== 'awaiting_payment' ) continue;

        if ( function_exists('b2b_set_order_status') ) {
            b2b_set_order_status($tid, 'paid');
        } else {
            update_field('order_status', 'paid', $tid);
        }
        update_field('paid_date', b2b_date('Y-m-d H:i:s'), $tid);
        update_field('slip_image_url', $slip_url, $tid);
        if ( function_exists('b2b_schedule_sla_alert') ) b2b_schedule_sla_alert($tid);
        $paid_ticket_ids[] = $tid;

        // Push paid confirmation to group
        if ( function_exists('b2b_build_flex_ticket_paid') ) {
            $items_raw = get_field('order_items', $tid) ?: '';
            $items_preview = trim(mb_substr(preg_replace('/^.*?ขอยืนยัน[^:]*:\s*/u', '', $items_raw), 0, 100));
            $flex_tp = b2b_build_flex_ticket_paid($tid, $vt['total'], $items_preview);
            b2b_line_push_raw($gid, array($flex_tp));
        }
    }

    // FIX H1: Deduct debt atomically (prevents race condition with concurrent operations)
    if ( $dist && !empty($paid_ticket_ids) ) {
        if ( function_exists('b2b_recalculate_debt') ) {
            $new_debt = b2b_recalculate_debt($dist->ID);
        } elseif ( function_exists('b2b_debt_subtract') ) {
            $new_debt = b2b_debt_subtract($dist->ID, $combined_total, 'liff_combined_slip', 0);
            if ($new_debt === false) {
                $old_debt = floatval(get_field('current_debt', $dist->ID));
                $new_debt = round(max(0, $old_debt - $combined_total), 2);
                update_field('current_debt', $new_debt, $dist->ID);
            }
        } else {
            $old_debt = floatval(get_field('current_debt', $dist->ID));
            $new_debt = round(max(0, $old_debt - $combined_total), 2);
            update_field('current_debt', $new_debt, $dist->ID);
        }
        if ( $new_debt <= 0 ) {
            update_field('credit_hold', false, $dist->ID);
        }
    }

    // ── Admin notification ──
    $dist_name = $dist ? get_the_title($dist->ID) : 'Unknown';
    $admin_msg = "💳 ชำระรวม " . count($paid_ticket_ids) . " บิล\n🏪 " . $dist_name . "\n━━━━━━━━━━━━━━━━";
    foreach ( $valid_tickets as $vt ) {
        $admin_msg .= "\n📋 #" . $vt['id'] . " — ฿" . number_format($vt['total'], 0);
    }
    $admin_msg .= "\n━━━━━━━━━━━━━━━━\n💰 ยอดรวม: ฿" . number_format($combined_total, 0);
    if ( $slip_result && isset($slip_result['data']['amount']) ) {
        $admin_msg .= "\n✅ Slip verified (" . number_format(floatval($slip_result['data']['amount']), 2) . ")";
    }
    $admin_msg .= "\n🔗 " . $slip_url;
    if ( function_exists('b2b_push_to_admin') ) b2b_push_to_admin($admin_msg);

    // Push flex to admin if available
    if ( function_exists('b2b_build_flex_combined_payment_alert') ) {
        $flex = b2b_build_flex_combined_payment_alert($dist_name, $valid_tickets, $combined_total, $slip_url);
        if ( function_exists('b2b_push_raw_to_admin') ) b2b_push_raw_to_admin(array($flex));
    }

    return new WP_REST_Response(array(
        'success'        => true,
        'message'        => 'ชำระรวม ' . count($paid_ticket_ids) . ' บิลสำเร็จ',
        'paid_tickets'   => $paid_ticket_ids,
        'combined_total' => $combined_total,
        'slip_url'       => $slip_url,
        'slip_result'    => $slip_result,
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[CombinedSlipUpload] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════════════════════════════
// V.22.0: COMBINED INVOICE — Generate combined invoice image
// ═══════════════════════════════════════════════════════════════
function b2b_rest_combined_invoice_gen( WP_REST_Request $request ) {
    $ticket_ids_raw = $request->get_param('ticket_ids');
    if ( empty($ticket_ids_raw) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing ticket_ids'), 400);

    $ticket_ids = array_map('intval', explode(',', $ticket_ids_raw));
    $ticket_ids = array_filter($ticket_ids, function($id){ return $id > 0; });
    if ( empty($ticket_ids) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid ticket_ids'), 400);

    // Security: check permission via session token OR signed URL OR admin
    $session = b2b_verify_session_token($request);
    $is_admin = current_user_can('manage_options');
    if ( !$session && !$is_admin ) {
        // Check HMAC signature
        $sig = $request->get_param('_sig');
        $ts  = intval($request->get_param('_ts'));
        if ( !$sig || !$ts || abs(time() - $ts) > 14400 ) {
            return b2b_unauthorized_response();
        }
    }

    if ( !function_exists('b2b_generate_combined_invoice_pages') )
        return new WP_REST_Response(array('success'=>false,'message'=>'Combined invoice generator not available'), 500);

    $pages = b2b_generate_combined_invoice_pages($ticket_ids);
    if ( empty($pages) )
        return new WP_REST_Response(array('success'=>false,'message'=>'ไม่สามารถสร้าง Invoice ได้'), 500);

    $format = $request->get_param('format');
    if ( $format === 'json' ) {
        return new WP_REST_Response(array('success'=>true,'pages'=>$pages), 200);
    }

    // Single page → redirect; multi page → HTML gallery
    if ( count($pages) === 1 ) {
        wp_redirect($pages[0]); exit;
    }
    echo '<html><head><meta name="viewport" content="width=device-width,initial-scale=1"><style>body{margin:0;background:#111;display:flex;flex-direction:column;align-items:center;gap:8px;padding:8px;}img{width:100%;max-width:800px;}</style></head><body>';
    foreach ($pages as $url) echo '<img src="'.esc_url($url).'">';
    echo '</body></html>'; exit;
}

