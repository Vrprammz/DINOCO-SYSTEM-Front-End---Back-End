/**
 * POST /b2b/v1/print-requeue/{ticket_id} — Reprint an order.
 * Can be called by admin (WP nonce) or RPi (API key).
 */
function b2b_rest_print_requeue( WP_REST_Request $request ) {
    // Accept either admin nonce or RPi API key
    $is_admin = wp_verify_nonce($request->get_header('X-WP-Nonce'), 'wp_rest') && current_user_can('manage_options');
    $is_rpi   = b2b_verify_print_key($request);

    if ( !$is_admin && !$is_rpi )
        return new WP_REST_Response(array('success'=>false,'message'=>'Unauthorized'), 403);

    $tid = intval($request->get_param('ticket_id'));
    if ( !$tid || get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Ticket not found'), 404);

    update_field('print_status', 'queued', $tid);
    update_field('print_error', '', $tid);
    b2b_log('[Print] Requeued #' . $tid . ($is_admin ? ' by admin' : ' by RPi'));
    return new WP_REST_Response(array('success'=>true,'message'=>'Requeued for print'), 200);
