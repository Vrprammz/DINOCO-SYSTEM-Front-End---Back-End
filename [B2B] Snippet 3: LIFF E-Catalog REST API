/**
 * GET /admin-stock-list — V.39.1: Read from custom table (source of truth)
 */
function b2b_rest_admin_stock_list( WP_REST_Request $request ) {
    $session = b2b_rest_verify_admin($request);
    if ( !$session ) return b2b_unauthorized_response('Admin only');

    // Get all BO tickets at once for counting
    $bo_tickets = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>'backorder')),
    ));

    // Build SKU → BO count map
    $bo_count_map = array();
    foreach ($bo_tickets as $bt) {
        $items_text = get_field('order_items', $bt->ID) ?: '';
        if (preg_match_all('/\(([A-Z0-9\-]+)\)/i', $items_text, $sku_matches)) {
            foreach ($sku_matches[1] as $sku) {
                $sku = strtoupper($sku);
                if (!isset($bo_count_map[$sku])) $bo_count_map[$sku] = 0;
                $bo_count_map[$sku]++;
            }
        }
    }

    $result = array();

    // V.39.1: Read from custom table first
    if ( class_exists('DINOCO_Catalog') ) {
        $all_products = DINOCO_Catalog::get_all();
        // Build pid map for backward compat
        $pid_map = array();
        $b2b_ids = get_posts(array('post_type'=>'b2b_product','posts_per_page'=>-1,'post_status'=>'publish','fields'=>'ids'));
        foreach ($b2b_ids as $bpid) {
            $s = get_post_meta($bpid, 'product_sku', true);
            if ($s) $pid_map[strtoupper(trim($s))] = $bpid;
        }
        foreach ($all_products as $p) {
            $sku = $p['sku'];
            $oos_ts = intval($p['oos_timestamp'] ?? 0);
            $bo_count = isset($bo_count_map[$sku]) ? $bo_count_map[$sku] : 0;
            $result[] = array(
                'id'         => isset($pid_map[$sku]) ? $pid_map[$sku] : 0,
                'name'       => $p['name'],
                'sku'        => $sku,
                'stock'      => $p['stock_status'] ?: 'in_stock',
                'oos_since'  => $oos_ts > 0 ? b2b_date('Y-m-d H:i', $oos_ts) : '',
                'oos_days'   => $oos_ts > 0 ? floor((time() - $oos_ts) / 86400) : 0,
                'eta'        => $p['oos_eta_date'] ?: '',
                'bo_count'   => $bo_count,
            );
        }
    } else {
        // Fallback: ACF
        $products = get_posts(array('post_type'=>'b2b_product','posts_per_page'=>-1,'post_status'=>'publish','orderby'=>'title','order'=>'ASC'));
        foreach ($products as $p) {
            $sku = get_field('product_sku', $p->ID) ?: '';
            $stock = get_field('stock_status', $p->ID) ?: 'in_stock';
            $oos_ts = intval(get_field('oos_timestamp', $p->ID));
            $eta = get_field('oos_eta_date', $p->ID) ?: '';
            $bo_count = isset($bo_count_map[strtoupper($sku)]) ? $bo_count_map[strtoupper($sku)] : 0;
            $result[] = array(
                'id'         => $p->ID,
                'name'       => get_the_title($p->ID),
                'sku'        => $sku,
                'stock'      => $stock,
                'oos_since'  => $oos_ts > 0 ? b2b_date('Y-m-d H:i', $oos_ts) : '',
                'oos_days'   => $oos_ts > 0 ? floor((time() - $oos_ts) / 86400) : 0,
                'eta'        => $eta,
                'bo_count'   => $bo_count,
            );
        }
    }

    return new WP_REST_Response(array('success'=>true,'products'=>$result), 200);
}

/**
 * GET /admin-bo-tickets?sku=XXX — BO tickets containing a specific SKU
 */
function b2b_rest_admin_bo_tickets( WP_REST_Request $request ) {
    $session = b2b_rest_verify_admin($request);
    if ( !$session ) return b2b_unauthorized_response('Admin only');

    $sku = strtoupper(sanitize_text_field($request->get_param('sku')));
    if (empty($sku)) return new WP_REST_Response(array('success'=>false,'message'=>'Missing sku'), 400);

    $tickets = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(
            array('key'=>'order_status','value'=>'backorder'),
            array('key'=>'order_items','value'=>$sku,'compare'=>'LIKE'),
        ),
    ));

    $result = array();
    foreach ($tickets as $t) {
        $gid = get_field('source_group_id', $t->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $total = floatval(get_field('total_amount', $t->ID));
        $result[] = array(
            'ticket_id' => $t->ID,
            'shop'      => $shop,
            'total'     => $total,
            'date'      => b2b_date('d/m H:i', get_post_time('U', true, $t->ID)),
            'group_id'  => $gid,
        );
    }

    return new WP_REST_Response(array('success'=>true,'tickets'=>$result), 200);
}

/**
 * POST /admin-stock-unlock — unlock SKU + notify selected BO tickets
 * Body: { sku, notify_tickets: [id1, id2, ...] }
 */
function b2b_rest_admin_stock_unlock( WP_REST_Request $request ) {
    $session = b2b_rest_verify_admin($request);
    if ( !$session ) return b2b_unauthorized_response('Admin only');

    $sku = strtoupper(sanitize_text_field($request->get_param('sku')));
    $notify_tickets = $request->get_param('notify_tickets');
    if (empty($sku)) return new WP_REST_Response(array('success'=>false,'message'=>'Missing sku'), 400);

    // Unlock the product
    $result = function_exists('b2b_unlock_product_oos') ? b2b_unlock_product_oos($sku) : false;
    if (!$result) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่พบ SKU: '.$sku), 404);

    // Notify selected BO tickets
    $notified = 0;
    if (!empty($notify_tickets) && is_array($notify_tickets)) {
        foreach ($notify_tickets as $tid) {
            $tid = intval($tid);
            if ($tid <= 0 || get_post_type($tid) !== 'b2b_order') continue;
            $group_id = get_field('source_group_id', $tid);
            if ($group_id && function_exists('b2b_build_flex_bo_restock')) {
                $flex = b2b_build_flex_bo_restock($tid, $sku);
                b2b_line_push_raw($group_id, array($flex));
                $notified++;
            }
        }
    }

    return new WP_REST_Response(array(
        'success'=>true,
        'message'=>'ปลดล็อก '.$sku.' เรียบร้อย',
        'notified'=>$notified,
    ), 200);
}

/**
 * POST /admin-stock-mark-oos — mark product OOS with ETA
 * Body: { sku, eta_days }
 */
function b2b_rest_admin_stock_mark_oos( WP_REST_Request $request ) {
    $session = b2b_rest_verify_admin($request);
    if ( !$session ) return b2b_unauthorized_response('Admin only');

    $sku = strtoupper(sanitize_text_field($request->get_param('sku')));
    $eta_days = max(0, intval($request->get_param('eta_days')));
    if (empty($sku)) return new WP_REST_Response(array('success'=>false,'message'=>'Missing sku'), 400);

    $result = function_exists('b2b_mark_product_oos') ? b2b_mark_product_oos($sku, $eta_days) : false;
    if (!$result) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่พบ SKU: '.$sku), 404);

    $eta_date = $eta_days > 0 ? b2b_date('Y-m-d', strtotime(b2b_date('Y-m-d') . ' +'.$eta_days.' days')) : '';

    return new WP_REST_Response(array(
        'success'=>true,
        'message'=>'ตั้งหมดสต็อก '.$sku.' เรียบร้อย',
        'eta_date'=>$eta_date,
    ), 200);
}

