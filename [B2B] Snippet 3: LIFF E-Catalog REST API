/**
 * GET /admin-shipping-queue — orders that need tracking numbers
 */
function b2b_rest_admin_shipping_queue( WP_REST_Request $request ) {
    $session = b2b_rest_verify_admin($request);
    if ( !$session ) return b2b_unauthorized_response('Admin only');

    // Orders ready for shipping: paid or awaiting_payment (credit system)
    // V.41.7: exclude manual_invoice — Manual Invoice ไม่มี shipping flow, admin ห้ามกรอก tracking ใส่ manual invoice
    $orders = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(
            'relation' => 'AND',
            array('key'=>'order_status','value'=>array('paid','awaiting_payment'),'compare'=>'IN'),
            array(
                'relation' => 'OR',
                array('key' => '_order_source', 'compare' => 'NOT EXISTS'),
                array('key' => '_order_source', 'value' => 'manual_invoice', 'compare' => '!='),
            ),
        ),
        'orderby'=>'date','order'=>'ASC',
    ));

    $pending = array();
    foreach ($orders as $o) {
        // Skip orders that already have tracking
        $tracking = get_field('tracking_number', $o->ID);
        if (!empty($tracking)) continue;

        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $total = floatval(get_field('total_amount', $o->ID));
        $days = floor((time() - get_post_time('U', true, $o->ID)) / 86400);
        $items_raw = get_field('order_items', $o->ID) ?: '';
        // Extract short items preview
        $items_preview = '';
        if (preg_match_all('/^(.+?)\s*\([A-Z0-9\-]+\)\s*x(\d+)/mu', $items_raw, $im, PREG_SET_ORDER)) {
            $parts = array();
            foreach ($im as $m) $parts[] = trim($m[1]).' x'.$m[2];
            $items_preview = implode(', ', $parts);
        }
        $claimed = get_field('claimed_by_admin', $o->ID) ?: '';

        $pending[] = array(
            'ticket_id'     => $o->ID,
            'shop'          => $shop,
            'shop_id'       => $dist ? $dist->ID : 0,
            'group_id'      => $gid,
            'total'         => $total,
            'days'          => $days,
            'date'          => b2b_date('d/m H:i', get_post_time('U', true, $o->ID)),
            'items_preview' => mb_substr($items_preview, 0, 100),
            'claimed_by'    => $claimed,
        );
    }

    // Also get recently shipped (today) for reference
    $tz = new DateTimeZone('Asia/Bangkok');
    $today_start = (new DateTime('today', $tz))->getTimestamp();
    $shipped = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>20,'post_status'=>'publish',
        'meta_query'=>array(
            array('key'=>'order_status','value'=>'shipped'),
            array('key'=>'shipped_date','value'=>b2b_date('Y-m-d', $today_start),'compare'=>'>=','type'=>'DATE'),
        ),
        'orderby'=>'date','order'=>'DESC',
    ));

    $recent = array();
    foreach ($shipped as $o) {
        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $recent[] = array(
            'ticket_id' => $o->ID,
            'shop'      => $shop,
            'tracking'  => get_field('tracking_number', $o->ID) ?: '-',
            'carrier'   => get_field('shipping_provider', $o->ID) ?: '-',
            'shipped_at'=> get_field('shipped_date', $o->ID) ?: '',
        );
    }

    return new WP_REST_Response(array('success'=>true,'pending'=>$pending,'recent'=>$recent), 200);
}

/**
 * POST /admin-submit-tracking — batch save tracking numbers + notify customers
 * Body: { entries: [{ticket_id, tracking_number, carrier}] }
 */
function b2b_rest_admin_submit_tracking( WP_REST_Request $request ) {
    try {
    $session = b2b_rest_verify_admin($request);
    if ( !$session ) return b2b_unauthorized_response('Admin only');

    $entries = $request->get_param('entries');
    if (empty($entries) || !is_array($entries))
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing entries'), 400);

    $updated = 0;
    $errors = array();

    foreach ($entries as $entry) {
        $tid = intval($entry['ticket_id'] ?? 0);
        $tracking = sanitize_text_field($entry['tracking_number'] ?? '');
        $carrier = sanitize_text_field($entry['carrier'] ?? '');

        $is_rider = in_array($carrier, array('Rider','Lalamove','Grab'));
        if (!$tid || empty($carrier) || (!$is_rider && empty($tracking))) {
            $errors[] = 'ข้อมูลไม่ครบ (Ticket #'.$tid.')';
            continue;
        }

        if (get_post_type($tid) !== 'b2b_order') {
            $errors[] = 'ไม่พบ Ticket #'.$tid;
            continue;
        }

        $status = get_field('order_status', $tid);
        if (!in_array($status, array('paid','awaiting_payment','shipped'))) {
            $errors[] = 'Ticket #'.$tid.' ยังไม่พร้อมจัดส่ง (สถานะ: '.$status.')';
            continue;
        }

        // Save tracking info — Rider/Lalamove/Grab use display text instead of tracking number
        $display_tracking = $is_rider ? ($carrier . ' มารับแล้ว') : $tracking;
        if (function_exists('b2b_set_order_status')) { b2b_set_order_status($tid, 'shipped'); } else { update_field('order_status', 'shipped', $tid); }
        update_field('tracking_number', $display_tracking, $tid);
        update_field('shipping_provider', $carrier, $tid);
        update_field('shipped_date', b2b_date('Y-m-d H:i:s'), $tid);

        // Clear SLA nag if exists
        if (function_exists('b2b_clear_sla_nag')) b2b_clear_sla_nag($tid);

        // Notify customer group
        $group_id = get_field('source_group_id', $tid);
        if ($group_id && function_exists('b2b_build_flex_shipped')) {
            $flex = b2b_build_flex_shipped($tid, $display_tracking, $carrier);
            b2b_line_push_raw($group_id, array($flex));
        }

        // Schedule delivery check (3 days later)
        wp_schedule_single_event(time() + (3 * DAY_IN_SECONDS), 'b2b_delivery_check_event', array($tid));

        $updated++;
    }

    return new WP_REST_Response(array(
        'success' => true,
        'message' => 'บันทึกเลขพัสดุ '.$updated.' รายการ',
        'updated' => $updated,
        'errors'  => $errors,
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[SubmitTracking] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

