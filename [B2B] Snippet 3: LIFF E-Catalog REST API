// ═══════════════════════════════════════
// GET /order-history 🔒 ต้องมี token
// ═══════════════════════════════════════
function b2b_rest_order_history( WP_REST_Request $request ) {
    try {
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $gid = $session['gid'];

    // V.9: B1 — Pagination + Filter
    $page     = max(1, intval($request->get_param('page')) ?: 1);
    $per_page = max(1, min(50, intval($request->get_param('per_page')) ?: 10));
    $status   = sanitize_text_field($request->get_param('status') ?: '');
    $allowed_statuses = array('pending','draft','checking_stock','awaiting_confirm','awaiting_payment','paid','packed','shipped','completed','backorder','cancel_requested','cancelled','change_requested','claim_opened','claim_resolved');
    if ( !empty($status) && !in_array($status, $allowed_statuses, true) && $status !== 'all' ) $status = '';

    $meta_query = array(array('key'=>'source_group_id','value'=>$gid));
    if ( !empty($status) && $status !== 'all' ) {
        $meta_query[] = array('key'=>'order_status','value'=>$status);
    }

    // Count total
    $count_query = new WP_Query(array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => 1,
        'post_status'    => 'publish',
        'meta_query'     => $meta_query,
        'fields'         => 'ids',
        'no_found_rows'  => false,
    ));
    $total_orders = $count_query->found_posts;
    $total_pages  = max(1, ceil($total_orders / $per_page));

    // ── ดึง recommended SKUs ──
    $recommended = b2b_get_recommended_skus($gid);

    $orders = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>$per_page,'post_status'=>'publish',
        'meta_query'=>$meta_query,
        'orderby'=>'date','order'=>'DESC',
        'paged'=>$page,
    ));

    if (empty($orders)) return new WP_REST_Response(array(
        'success'=>true,'orders'=>array(),'recommended_skus'=>$recommended,
        'page'=>$page,'per_page'=>$per_page,'total'=>$total_orders,'total_pages'=>$total_pages,
    ), 200);

    // V.9.1 PERF-H9: prime post meta cache once → 6× get_field per order use cache (was 300 uncached reads for 50 orders)
    if ( ! empty( $orders ) ) {
        update_meta_cache( 'post', wp_list_pluck( $orders, 'ID' ) );
    }

    $result = array();

    foreach ($orders as $o) {
        $status_val = get_field('order_status', $o->ID) ?: 'draft';
        $total      = floatval(get_field('total_amount', $o->ID));
        $items_raw  = get_field('order_items', $o->ID) ?: '';
        $tracking   = get_field('tracking_number', $o->ID) ?: '';
        $carrier    = get_field('shipping_provider', $o->ID) ?: '';
        $due_date   = get_field('due_date', $o->ID) ?: '';

        $preview = preg_replace('/^.*?ขอยืนยันสั่งสินค้า[:\s]*/u', '', $items_raw);
        $preview = mb_substr($preview, 0, 200);

        $parsed_items = array();
        if ( preg_match_all('/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)\s*(?:=\s*฿?([\d,.]+))?/mu', $items_raw, $matches, PREG_SET_ORDER) ) {
            foreach ($matches as $m) {
                $parsed_items[] = array(
                    'name'  => trim($m[1]),
                    'sku'   => $m[2],
                    'qty'   => intval($m[3]),
                    'price' => isset($m[4]) ? floatval(str_replace(',', '', $m[4])) : 0,
                );
            }
        }

        $ticket_url = function_exists('b2b_liff_url')
            ? b2b_liff_url('b2b-ticket/', array('ticket_id' => $o->ID))
            : '';

        $can_cancel = in_array($status_val, array('draft','checking_stock','awaiting_confirm','awaiting_payment','backorder'));

        // V.9: sub-ticket label
        $sub_label = '';
        if ( function_exists('b2b_get_sub_ticket_label') ) {
            $parent = intval(get_field('parent_ticket_id', $o->ID));
            if ( $parent > 0 ) $sub_label = b2b_get_sub_ticket_label($o->ID);
        }

        $result[] = array(
            'id'            => $o->ID,
            'date'          => b2b_date('d/m/Y H:i', get_post_time('U', true, $o->ID)),
            'status'        => $status_val,
            'total'         => $total,
            'items_preview' => $preview,
            'items'         => $parsed_items,
            'tracking'      => $tracking,
            'carrier'       => $carrier,
            'ticket_url'    => $ticket_url,
            'due_date'      => $due_date ? (function_exists('b2b_parse_date') ? b2b_parse_date($due_date) : $due_date) : '',
            'can_cancel'    => $can_cancel,
            'sub_label'     => $sub_label,
        );
    }

    return new WP_REST_Response(array(
        'success'=>true,'orders'=>$result,'recommended_skus'=>$recommended,
        'page'=>$page,'per_page'=>$per_page,'total'=>$total_orders,'total_pages'=>$total_pages,
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[OrderHistory] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════
// HELPER: ดึง Recommended SKUs (Admin set)
// ═══════════════════════════════════════
// Priority:
//   1. distributor → recommended_skus (per ร้าน)
//   2. b2b_product → is_featured = true (global)
// ═══════════════════════════════════════
function b2b_get_recommended_skus( $gid ) {
    // ── Priority 1: Per-distributor (ACF: recommended_skus on distributor) ──
    $dist = function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
    if ( $dist ) {
        $raw = get_field('recommended_skus', $dist->ID);
        if ( !empty($raw) ) {
            // รองรับทั้ง comma, newline, space separated
            $skus = preg_split('/[\s,;]+/', trim($raw));
            $skus = array_filter(array_map('trim', $skus));
            if ( !empty($skus) ) return array_values(array_slice($skus, 0, 8));
        }
    }

    // ── Priority 2: Global featured products (ACF: is_featured on b2b_product) ──
    $featured = get_posts(array(
        'post_type'      => 'b2b_product',
        'posts_per_page' => 8,
        'post_status'    => 'publish',
        'meta_query'     => array(array('key'=>'is_featured','value'=>'1')),
        'orderby'        => 'menu_order',
        'order'          => 'ASC',
    ));

    $skus = array();
    foreach ($featured as $p) {
        $sku = get_field('product_sku', $p->ID);
        if ($sku) $skus[] = $sku;
    }

    return $skus;
}

// ═══════════════════════════════════════
// GET /order-detail 🔒 ต้องมี token + ตรวจ ownership
// ═══════════════════════════════════════
function b2b_rest_order_detail( WP_REST_Request $request ) {
    try {
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $tid = intval($request->get_param('ticket_id'));
    $gid = $session['gid'];

    if (!$tid)
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing ticket_id'), 400);

    if ( get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Not found'), 404);

    // Verify ownership — ดูได้เฉพาะออเดอร์ของตัวเอง
    $source = get_field('source_group_id', $tid);
    if ($source !== $gid)
        return new WP_REST_Response(array('success'=>false,'message'=>'Unauthorized'), 403);

    $items_raw = get_field('order_items', $tid) ?: '';
    $parsed = array();
    if ( preg_match_all('/\(([A-Z0-9\-]+)\)\s*x(\d+)/i', $items_raw, $matches, PREG_SET_ORDER) ) {
        foreach ($matches as $m) {
            $parsed[] = array('sku'=>$m[1],'qty'=>intval($m[2]));
        }
    }

    return new WP_REST_Response(array(
        'success' => true,
        'ticket_id' => $tid,
        'status' => get_field('order_status', $tid),
        'total' => floatval(get_field('total_amount', $tid)),
        'items' => $parsed,
        'items_raw' => $items_raw,
        // V.9: N5 + N4 fields
        'customer_note'    => get_field('customer_note', $tid) ?: '',
        'orderer_name'     => get_field('orderer_display_name', $tid) ?: '',
        'tracking'         => get_field('tracking_number', $tid) ?: '',
        'carrier'          => get_field('shipping_provider', $tid) ?: '',
        'due_date'         => get_field('due_date', $tid) ?: '',
        'parent_ticket_id' => intval(get_field('parent_ticket_id', $tid)),
        'sub_ticket_index' => intval(get_field('sub_ticket_index', $tid)),
        'sub_label'        => function_exists('b2b_get_sub_ticket_label') ? b2b_get_sub_ticket_label($tid) : '#'.$tid,
        'bo_customer_response' => get_field('bo_customer_response', $tid) ?: '',
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[OrderDetail] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════════════════════════════
// V.9: N4 — POST /bo-notify (Admin แจ้งลูกค้า BO partial)
// ═══════════════════════════════════════════════════════════════
// Admin กรอกจำนวนที่มีใน LIFF → กด "แจ้งลูกค้า" → เรียก endpoint นี้
// → บันทึก bo_available_qty → ส่ง Flex ถามลูกค้า
function b2b_rest_bo_notify( WP_REST_Request $request ) {
    try {
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $ticket_id = intval($request->get_param('ticket_id'));
    $items     = $request->get_param('items'); // array of {sku, name, ordered, available, unit_price}

    if ( !$ticket_id || empty($items) || !is_array($items) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing ticket_id or items'), 400);

    if ( get_post_type($ticket_id) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Ticket not found'), 404);

    // ── SEC: BO-notify is admin-only — verify admin group (fail-closed) ──
    $admin_gid = defined('B2B_ADMIN_GROUP_ID') ? B2B_ADMIN_GROUP_ID : '';
    if ( empty($admin_gid) || $session['gid'] !== $admin_gid )
        return new WP_REST_Response(array('success'=>false,'message'=>'สิทธิ์ Admin เท่านั้น'), 403);

    $status = get_field('order_status', $ticket_id);
    if ( !in_array($status, array('backorder', 'checking_stock')) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ได้อยู่ในสถานะเช็คสต็อก'), 400);

    // ── Sanitize + save bo_available_qty ──
    $clean_items = array();
    $partial_total = 0;
    foreach ( $items as $item ) {
        $ci = array(
            'sku'        => sanitize_text_field($item['sku'] ?? ''),
            'name'       => sanitize_text_field($item['name'] ?? ''),
            'ordered'    => intval($item['ordered'] ?? 0),
            'available'  => intval($item['available'] ?? 0),
            'unit_price' => floatval($item['unit_price'] ?? 0),
        );
        $clean_items[] = $ci;
        $partial_total += $ci['unit_price'] * min($ci['available'], $ci['ordered']);
    }

    update_field('bo_available_qty', wp_json_encode($clean_items), $ticket_id);

    // ── ส่ง Flex ถามลูกค้า ──
    $group_id = get_field('source_group_id', $ticket_id);
    if ( $group_id && function_exists('b2b_build_flex_bo_partial_ask') ) {
        $flex = b2b_build_flex_bo_partial_ask($ticket_id, $clean_items, $partial_total);
        b2b_line_push_raw($group_id, array($flex));
    }

    return new WP_REST_Response(array(
        'success'=>true,
        'message'=>'ส่ง Flex แจ้งลูกค้าแล้ว',
        'partial_total'=>$partial_total,
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[BONotify] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════════════════════════════
// V.9: F4 — GET /invoice-gen (generate invoice image link)
// ═══════════════════════════════════════════════════════════════
function b2b_rest_invoice_gen( WP_REST_Request $request ) {
    try {
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $tid = intval($request->get_param('ticket_id'));
    $gid = $session['gid'];

    if ( !$tid )
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing ticket_id'), 400);

    if ( get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Not found'), 404);

    // V.14.0: Verify ownership — allow admin bypass
    $source = get_field('source_group_id', $tid);
    $is_admin = (isset($session['role']) && $session['role'] === 'admin');
    if ( $source !== $gid && !$is_admin )
        return new WP_REST_Response(array('success'=>false,'message'=>'Unauthorized'), 403);

    // Generate invoice via S10
    if ( function_exists('b2b_generate_invoice_pages') ) {
        $urls = b2b_generate_invoice_pages($tid);
        if ( $urls && is_array($urls) ) {
            return new WP_REST_Response(array('success'=>true,'pages'=>$urls), 200);
        }
        // V.14.0: Better error when generation fails
        return new WP_REST_Response(array('success'=>false,'message'=>'สร้างใบแจ้งหนี้ไม่สำเร็จ (GD/Font error)'), 500);
    }

    // Fallback: direct API URL with HMAC signature (V.10.7-SEC)
    $base = defined('B2B_SITE_URL') ? B2B_SITE_URL : site_url();
    $inv_params = array('ticket_id' => $tid, '_ts' => time());
    if ( function_exists('b2b_generate_sig') ) {
        $inv_params['_sig'] = b2b_generate_sig('invoice-image/', $inv_params);
    }
    $api_url = $base . '/wp-json/b2b/v1/invoice-image?' . http_build_query($inv_params);

    return new WP_REST_Response(array('success'=>true,'pages'=>array($api_url)), 200);
    } catch ( Exception $e ) {
        b2b_log('[InvoiceGen] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════════════════════════════
// V.9: F5 — POST /slip-upload (upload slip จาก ticket view)
// ═══════════════════════════════════════════════════════════════
// ลูกค้าอัพโหลดรูปสลิปจาก S8 ticket view → save + ส่งตรวจ
function b2b_rest_slip_upload( WP_REST_Request $request ) {
    try {
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $tid       = intval($request->get_param('ticket_id'));
    $image_b64 = $request->get_param('image_base64'); // data:image/jpeg;base64,...
    $gid       = $session['gid'];
    $uid       = $session['uid'];

    if ( !$tid || empty($image_b64) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Missing ticket_id or image'), 400);

    if ( get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Not found'), 404);

    $source = get_field('source_group_id', $tid);
    if ( $source !== $gid )
        return new WP_REST_Response(array('success'=>false,'message'=>'Unauthorized'), 403);

    // ── Save slip image to uploads ──
    $upload_dir = wp_upload_dir();
    $slip_dir   = $upload_dir['basedir'] . '/b2b-slips';
    if ( !file_exists($slip_dir) ) wp_mkdir_p($slip_dir);
    if ( !file_exists($slip_dir . '/.htaccess') && file_put_contents($slip_dir . '/.htaccess', "Options -Indexes\nDeny from all\n") === false ) b2b_log('[SLIP] Failed to write .htaccess');
    if ( !file_exists($slip_dir . '/index.php') && file_put_contents($slip_dir . '/index.php', '<?php // Silence is golden') === false ) b2b_log('[SLIP] Failed to write index.php');

    $filename = 'slip-' . $tid . '-' . b2b_date('YmdHis') . '.jpg';
    $filepath = $slip_dir . '/' . $filename;

    // Strip base64 prefix
    $raw = $image_b64;
    if ( strpos($raw, ',') !== false ) $raw = explode(',', $raw, 2)[1];
    $decoded = base64_decode($raw);

    if ( !$decoded || strlen($decoded) < 1000 )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid image data'), 400);

    // ── SEC: Max file size 5MB + MIME validation ──
    if ( strlen($decoded) > 5 * 1024 * 1024 )
        return new WP_REST_Response(array('success'=>false,'message'=>'ไฟล์ใหญ่เกินไป (max 5MB)'), 400);

    $finfo = new finfo(FILEINFO_MIME_TYPE);
    $mime = $finfo->buffer($decoded);
    if ( !in_array($mime, array('image/jpeg','image/png','image/gif','image/webp')) )
        return new WP_REST_Response(array('success'=>false,'message'=>'ไฟล์ไม่ใช่รูปภาพ'), 400);

    if ( file_put_contents($filepath, $decoded) === false )
        return new WP_REST_Response(array('success'=>false,'message'=>'บันทึกไฟล์ไม่สำเร็จ'), 500);
    $slip_url = $upload_dir['baseurl'] . '/b2b-slips/' . $filename;

    // Save URL to ticket
    update_field('slip_image_url', $slip_url, $tid);

    // ── ส่งตรวจ Slip2go แบบ async ──
    update_field('slip_status', 'verifying', $tid);
    if ( defined('B2B_SLIP2GO_SECRET_KEY') ) {
        wp_schedule_single_event(time(), 'b2b_verify_slip_async', array($tid, $filepath));
    }

    // ── แจ้ง Admin ──
    $dist = b2b_get_dist_by_group($gid);
    $dist_name = $dist ? get_the_title($dist->ID) : 'Unknown';
    $admin_msg = "📸 ลูกค้า " . $dist_name . " อัพโหลดสลิป Ticket #" . $tid;
    $admin_msg .= "\n🔗 " . $slip_url;
    if ( function_exists('b2b_push_to_admin') ) b2b_push_to_admin($admin_msg);

    return new WP_REST_Response(array(
        'success'    => true,
        'message'    => 'อัพโหลดสลิปเรียบร้อย',
        'slip_url'   => $slip_url,
        'slip_status'=> 'verifying',
    ), 200);
    } catch ( Exception $e ) {
        b2b_log('[SlipUpload] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

