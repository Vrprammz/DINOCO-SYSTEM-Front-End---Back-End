// SESSION TOKEN HELPERS (V.8.2-SEC)
// ═══════════════════════════════════════

/**
 * สร้าง session token สำหรับ group_id
 * เก็บเป็น WP transient อายุ 2 ชม.
 */
if ( ! function_exists('b2b_create_session_token') ) {
    function b2b_create_session_token( $group_id, $line_uid = '' ) {
        // V.31: Use DINOCO_JWT if available (stateless, no DB hit per request)
        if ( class_exists('DINOCO_JWT') ) {
            $token = DINOCO_JWT::create( array( 'gid' => $group_id, 'uid' => $line_uid ), 7200 );
            b2b_log('[Session] JWT token created for group=' . $group_id);
            return $token;
        }

        // Fallback: transient-based token
        if ( !defined('B2B_LINE_CHANNEL_SECRET') || empty(B2B_LINE_CHANNEL_SECRET) ) {
            b2b_log('[SECURITY] Cannot create session — B2B_LINE_CHANNEL_SECRET not defined');
            return '';
        }
        $random = bin2hex( random_bytes(32) );
        $secret = B2B_LINE_CHANNEL_SECRET;
        $token  = hash_hmac('sha256', $random . time(), $secret);
        $data   = array('gid' => $group_id, 'uid' => $line_uid, 'created' => time());
        set_transient('b2b_sess_' . $token, $data, 7200);
        return $token;
    }
}

/**
 * ตรวจ session token จาก X-B2B-Token header หรือ _token param
 * return array{gid,uid} หรือ false
 */
if ( ! function_exists('b2b_verify_session_token') ) {
    function b2b_verify_session_token( WP_REST_Request $request ) {
        $token = $request->get_header('X-B2B-Token');
        if ( empty($token) ) {
            $token = sanitize_text_field($request->get_param('_token'));
        }
        if ( empty($token) ) return false;

        // V.31: Try JWT first (stateless — no DB query needed)
        if ( class_exists('DINOCO_JWT') && strpos($token, '.') !== false ) {
            $payload = DINOCO_JWT::verify( $token );
            if ( $payload && isset($payload['gid']) ) {
                return array( 'gid' => $payload['gid'], 'uid' => $payload['uid'] ?? '' );
            }
            return false; // JWT expired or invalid
        }

        // Fallback: transient-based token
        $token = preg_replace('/[^a-f0-9]/i', '', $token);
        if ( empty($token) ) return false;
        $data = get_transient('b2b_sess_' . $token);
        if ( !$data || !isset($data['gid']) ) return false;
        return $data;
    }
}

/**
 * Standard 401 response
 */
if ( ! function_exists('b2b_unauthorized_response') ) {
    function b2b_unauthorized_response( $msg = '' ) {
        return new WP_REST_Response(array(
            'success' => false,
            'error'   => 'unauthorized',
            'message' => $msg ?: 'Session หมดอายุ กรุณาเปิดหน้าสั่งสินค้าใหม่'
        ), 401);
    }
}

// ═══════════════════════════════════════
// SHARED SKU DATA CACHE
// ═══════════════════════════════════════

/** Cached SKU data map — V.39.1: batch query from custom table (source of truth)
 *  V.41.6 PERF-M1: stampede protection — when the 5-minute transient expires, N
 *  concurrent requests would race to rebuild the map (thundering herd). A
 *  wp_cache_add() sentinel grants a short-lived rebuild lock to one worker; losers
 *  briefly wait + re-check the transient so they return fresh data without running
 *  a redundant full-catalog scan.
 *
 *  Safety contract:
 *    - Lock TTL is SHORT (5s) so a crashed/slow rebuilder can't block other workers
 *      for long. If lock acquisition fails AND transient is still empty after the
 *      retry, we rebuild anyway (last-resort — still correct, just not optimal).
 *    - wp_cache_add() is atomic per WordPress Object Cache API contract (transient
 *      fallback would ALSO satisfy atomicity via DB-level INSERT ON DUPLICATE — but
 *      we prefer wp_cache_add for performance).
 *    - Sentinel is always deleted in finally {} so a PHP fatal doesn't wedge the lock.
 */
function b2b_get_sku_data_map() {
    $cache_key = 'b2b_sku_data_map';
    $data = get_transient($cache_key);
    if ( false !== $data ) return $data;

    // V.41.6 stampede guard — only one worker rebuilds; others retry briefly.
    $lock_key = 'b2b_sku_data_map_lock';
    $acquired_lock = wp_cache_add( $lock_key, 1, '', 5 );
    if ( ! $acquired_lock ) {
        // Another worker is rebuilding. Wait briefly then re-check the transient.
        // usleep is cheap + avoids the 1s granularity of sleep() for a snappier retry.
        usleep( 250000 ); // 250ms
        $data = get_transient( $cache_key );
        if ( false !== $data ) return $data;
        // Lock-holder didn't complete in 250ms (cold cache / slow query) — fall through
        // and rebuild anyway. Correctness > perfection: better to double-query the DB
        // once than block the user-facing endpoint.
    }

    try {
        $data = array();

        // Source 1: Custom table (batch query — 1 SQL)
        if ( class_exists( 'DINOCO_Catalog' ) ) {
            $all = DINOCO_Catalog::get_all();
            if ( ! empty( $all ) ) {
                // Also build pid map for backward compat
                $pid_map = array();
                $ids = get_posts(array('post_type'=>'b2b_product','posts_per_page'=>-1,'post_status'=>'publish','fields'=>'ids'));
                if ( !empty($ids) ) update_meta_cache('post', $ids);
                foreach ( $ids as $pid ) {
                    $s = get_post_meta($pid, 'product_sku', true);
                    if ($s) $pid_map[strtoupper(trim($s))] = $pid;
                }
                foreach ( $all as $p ) {
                    $sku = $p['sku'];
                    $data[$sku] = array(
                        'pid'            => isset($pid_map[$sku]) ? $pid_map[$sku] : 0,
                        'discount'       => floatval( $p['b2b_discount_percent'] ?? 0 ),
                        'b2b_discount_percent' => floatval( $p['b2b_discount_percent'] ?? 0 ),
                        'stock_status'   => $p['stock_status'] ?: 'in_stock',
                        'oos_eta'        => $p['oos_eta_date'] ?: '',
                        'oos_timestamp'  => intval( $p['oos_timestamp'] ?? 0 ),
                        'oos_duration'   => intval( $p['oos_duration_hours'] ?? 0 ),
                        'boxes_per_unit' => max( 1, intval( $p['boxes_per_unit'] ?? 1 ) ),
                        'units_per_box'  => max( 1, intval( $p['units_per_box'] ?? 1 ) ),
                        'price_standard' => floatval( $p['base_price'] ?? 0 ),
                        'price_silver'   => floatval( $p['price_silver'] ?? 0 ),  // V.39.3: now % discount
                        'price_gold'     => floatval( $p['price_gold'] ?? 0 ),    // V.39.3: now % discount
                        'price_platinum' => floatval( $p['price_platinum'] ?? 0 ), // V.39.3: now % discount
                        'price_diamond'  => floatval( $p['price_diamond'] ?? 0 ),  // V.39.3: now % discount
                        'min_order_qty'  => max( 1, intval( $p['min_order_qty'] ?? 1 ) ),
                        'category'       => $p['category'] ?? '',
                        'b2b_visible'    => isset($p['b2b_visible']) ? intval($p['b2b_visible']) : 1,
                    );
                }
                set_transient($cache_key, $data, 300);
                return $data;
            }
        }

        // Source 2: Fallback ACF
        $ids = get_posts(array(
            'post_type'      => 'b2b_product',
            'posts_per_page' => -1,
            'post_status'    => 'publish',
            'fields'         => 'ids',
        ));
        if ( !empty($ids) ) update_meta_cache('post', $ids);

        foreach ( $ids as $pid ) {
            $sku = get_post_meta($pid, 'product_sku', true);
            if ( !$sku ) continue;
            $data[$sku] = array(
                'pid'            => $pid,
                'discount'       => floatval(get_post_meta($pid, 'b2b_discount_percent', true)),
                'stock_status'   => get_post_meta($pid, 'stock_status', true) ?: 'in_stock',
                'oos_eta'        => get_post_meta($pid, 'oos_eta_date', true) ?: '',
                'oos_timestamp'  => intval(get_post_meta($pid, 'oos_timestamp', true)),
                'oos_duration'   => intval(get_post_meta($pid, 'oos_duration_hours', true)),
                'boxes_per_unit' => function_exists('b2b_get_boxes_per_unit') ? b2b_get_boxes_per_unit($sku, $pid) : max(1, intval(get_post_meta($pid, 'boxes_per_unit', true) ?: 1)),
                'units_per_box'  => function_exists('b2b_get_units_per_box') ? b2b_get_units_per_box($sku, $pid) : 1,
            );
        }
        set_transient($cache_key, $data, 300);
        return $data;
    } finally {
        // Always release the lock, even on exception — prevents wedged sentinel.
        if ( $acquired_lock ) {
            wp_cache_delete( $lock_key );
        }
    }
}

/** Invalidate SKU cache on product save */
add_action('acf/save_post', function($post_id) {
    if ( get_post_type($post_id) === 'b2b_product' ) {
        delete_transient('b2b_sku_data_map');
    }
}, 20);

// ═══════════════════════════════════════
// POST /auth-group (LIFF ตรวจสอบสิทธิ์ + ออก token)
// ═══════════════════════════════════════
function b2b_rest_auth_group( WP_REST_Request $request ) {
    // V.31 SEC: Rate limiting — 20 attempts per 5 min per IP
    $ip = isset($_SERVER['REMOTE_ADDR']) ? $_SERVER['REMOTE_ADDR'] : 'unknown';
    $rate_key = 'b2b_auth_rate_' . md5($ip);
    $attempts = intval(get_transient($rate_key));
    if ( $attempts > 20 ) {
        return new WP_REST_Response(array('authorized'=>false,'message'=>'Too many attempts. Try again later.'), 429);
    }
    set_transient($rate_key, $attempts + 1, 300);

    // V.31 SEC: Verify LIFF URL signature + expiry (1 hour)
    $sig = sanitize_text_field($request->get_param('_sig'));
    $ts  = intval($request->get_param('_ts'));
    if ( empty($sig) || $ts <= 0 ) {
        return new WP_REST_Response(array('authorized'=>false,'message'=>'ลิงก์ไม่ถูกต้อง กรุณาเปิดจากกลุ่ม LINE'), 200);
    }
    if ( abs(time() - $ts) > 3600 ) {
        return new WP_REST_Response(array('authorized'=>false,'message'=>'ลิงก์หมดอายุ กรุณากดลิงก์ใหม่'), 200);
    }
    $group_id    = sanitize_text_field($request->get_param('group_id'));
    $verify_params = array('gid' => $group_id, '_ts' => $ts);
    ksort($verify_params);
    $expected = function_exists('b2b_generate_sig') ? b2b_generate_sig('', $verify_params) : '';
    if ( empty($expected) || !hash_equals($expected, $sig) ) {
        return new WP_REST_Response(array('authorized'=>false,'message'=>'ลิงก์ไม่ถูกต้อง'), 200);
    }

    $line_uid    = sanitize_text_field($request->get_param('line_user_id'));
    $id_token    = sanitize_text_field($request->get_param('id_token'));

    if ( empty($group_id) )
        return new WP_REST_Response(array('authorized'=>false,'message'=>'ลิงก์ไม่ถูกต้อง'), 200);

    if ( empty($line_uid) )
        return new WP_REST_Response(array('authorized'=>false,'message'=>'ต้องเปิดผ่าน LINE เท่านั้น'), 401);

    // ── SEC: Verify LINE ID Token when available (best-effort) ──
    // liff.getIDToken() may return null if openid scope is missing or token expired.
    // When id_token is provided, verify it and use the verified sub as line_uid.
    // When not available, fall back to client-provided line_user_id from liff.getProfile().
    // Security is still maintained by: HMAC-signed LIFF URL (Layer 1) + LIFF Guard group check (Layer 2).
    if ( ! empty($id_token) ) {
        $liff_channel_id = defined('B2B_LIFF_ID') ? preg_replace('/-.*$/', '', B2B_LIFF_ID) : '';
        if ( $liff_channel_id ) {
            $verify_resp = wp_remote_post('https://api.line.me/oauth2/v2.1/verify', array(
                'body' => array('id_token' => $id_token, 'client_id' => $liff_channel_id),
                'timeout' => 10,
            ));
            if ( ! is_wp_error($verify_resp) ) {
                $verify_body = json_decode(wp_remote_retrieve_body($verify_resp), true);
                if ( ! empty($verify_body['sub']) ) {
                    // Use verified LINE user ID (most secure)
                    $line_uid = sanitize_text_field($verify_body['sub']);
                }
            }
        }
    }

    $dist = b2b_get_dist_by_group($group_id);
    if ( !$dist )
        return new WP_REST_Response(array('authorized'=>false,'message'=>'ไม่พบร้านค้าในระบบ กรุณาติดต่อแอดมิน'), 200);

    // เช็ค Credit Hold
    if ( get_field('credit_hold', $dist->ID) )
        return new WP_REST_Response(array('authorized'=>false,'reason'=>'credit_hold','message'=>'บัญชีถูกระงับ กรุณาชำระยอดค้างก่อน'), 200);

    $rank = get_field('rank_system', $dist->ID) ?: 'standard';

    // ── V.8.2-SEC: สร้าง session token ──
    $token = b2b_create_session_token($group_id, $line_uid);

    return new WP_REST_Response(array(
        'authorized' => true,
        'dist_id'    => $dist->ID,
        'dist_name'  => get_the_title($dist->ID),
        'dist_logo'  => get_field('shop_logo_url', $dist->ID) ?: '',
        'rank'       => $rank,
        'credit_hold'=> false,
        'debt'       => floatval(get_field('current_debt', $dist->ID)),
        'token'      => $token, // ← NEW: ส่ง token กลับให้ LIFF
    ), 200);
}

// ═══════════════════════════════════════
// GET /catalog 🔒 ต้องมี token
// ═══════════════════════════════════════
function b2b_rest_get_catalog( WP_REST_Request $request ) {
    try {
    // ── Security: ตรวจ session token ──
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    $group_id = $session['gid'];
    $catalog  = function_exists('b2b_get_catalog_b2b') ? b2b_get_catalog_b2b() : ( function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option( 'dinoco_product_catalog', array() ) );
    if ( empty($catalog) ) return new WP_REST_Response( array('success'=>true,'products'=>array()), 200 );

    $sku_data = b2b_get_sku_data_map();

    // V.39.3: Get distributor rank for tier pricing
    $dist = b2b_get_dist_by_group($group_id);
    $rank = $dist ? ( get_field('rank_system', $dist->ID) ?: 'standard' ) : 'standard';

    $relations = get_option( 'dinoco_sku_relations', array() );
    $products  = array();

    foreach ( $catalog as $sku => $item ) {
        // V.39.4: Skip products hidden from B2B (หยุดจำหน่าย)
        if ( isset($sku_data[$sku]) && intval($sku_data[$sku]['b2b_visible'] ?? 1) === 0 ) {
            continue;
        }

        $name  = isset($item['name'])  ? $item['name']  : $sku;
        $img   = isset($item['img'])   ? $item['img']   : '';
        $price = isset($item['price']) ? b2b_parse_price($item['price']) : 0;
        $sub   = isset($item['sub'])   ? $item['sub']   : '';

        $discount     = isset($sku_data[$sku]) ? $sku_data[$sku]['discount']     : 0;
        $stock_status = isset($sku_data[$sku]) ? $sku_data[$sku]['stock_status'] : 'in_stock';
        $oos_eta      = isset($sku_data[$sku]) ? $sku_data[$sku]['oos_eta']      : '';

        // OOS auto-expire — Guard: ถ้าระบบ Inventory ใหม่จัดการ stock แล้ว → ข้าม OOS auto-expire เดิม
        if ( !get_option('dinoco_inv_initialized') ) {
            if ( $stock_status === 'out_of_stock' && isset($sku_data[$sku]) ) {
                $ts  = $sku_data[$sku]['oos_timestamp'];
                $dur = $sku_data[$sku]['oos_duration'];
                if ( $dur > 0 && $ts > 0 && time() > ($ts + $dur * 3600) ) {
                    $stock_status = 'in_stock';
                    if ( function_exists('b2b_find_product_by_sku') ) {
                        $pid = b2b_find_product_by_sku($sku);
                        if ($pid) update_field('stock_status', 'in_stock', $pid);
                    }
                }
            }
        }

        $boxes_per_unit = isset($sku_data[$sku]) ? $sku_data[$sku]['boxes_per_unit'] : 1;
        $units_per_box  = isset($sku_data[$sku]) ? ($sku_data[$sku]['units_per_box'] ?? 1) : 1;

        // V.38.7: Compute stock_display from inventory DB (Phase 2)
        $stock_display = $stock_status; // fallback to legacy stock_status
        $stock_eta     = null;
        if ( function_exists( 'dinoco_stock_get' ) ) {
            $inv = dinoco_stock_get( $sku );
            if ( $inv ) {
                $stock_display = $inv['stock_display']; // in_stock / low_stock / out_of_stock
                // Compute ETA: bo_eta_override > oos_eta_date (legacy)
                if ( $stock_display === 'out_of_stock' ) {
                    if ( ! empty( $inv['bo_eta_override'] ) ) {
                        $stock_eta = $inv['bo_eta_override'];
                    } elseif ( ! empty( $oos_eta ) ) {
                        $stock_eta = $oos_eta; // legacy fallback
                    }
                    // Hide expired ETA
                    if ( $stock_eta && strtotime( $stock_eta ) < time() ) {
                        $stock_eta = null;
                    }
                }
            }
        } elseif ( $stock_status === 'out_of_stock' ) {
            $stock_display = 'out_of_stock';
            $stock_eta     = $oos_eta ?: null;
        }

        // V.38.9: category + compatible_models for Shopee-style filter
        $category          = isset($item['category']) ? $item['category'] : '';
        $compatible_models = isset($item['compatible_models']) ? $item['compatible_models'] : '[]';

        // V.40.3 [H-15]: sanitize compatible_models ก่อนส่งไป LIFF
        $cm = is_string($compatible_models) ? json_decode($compatible_models, true) : $compatible_models;
        if ( is_array($cm) ) {
            $cm_clean = array();
            foreach ( array_slice($cm, 0, 50) as $c ) {
                if ( ! is_array($c) ) continue;
                $cm_clean[] = array(
                    'brand_name' => sanitize_text_field( isset($c['brand_name']) ? $c['brand_name'] : '' ),
                    'name'       => sanitize_text_field( isset($c['name']) ? $c['name'] : '' ),
                );
            }
            $compatible_models = wp_json_encode($cm_clean);
        } else {
            $compatible_models = '[]';
        }

        // V.39.3: Compute dealer_price via shared helper (rank-aware tier discount %)
        $sd = isset($sku_data[$sku]) ? $sku_data[$sku] : array();
        $dealer_price = function_exists('b2b_compute_dealer_price')
            ? b2b_compute_dealer_price( $price, $rank, $sd )
            : round( $price * ( 1 - $discount / 100 ), 2 );
        // Effective discount % for display
        $effective_discount = $price > 0 ? round( ( 1 - $dealer_price / $price ) * 100, 1 ) : 0;

        // V.6.0: 3-level hierarchy — is_set, children, tree, leaf flags
        $children_arr = isset($relations[$sku]) ? $relations[$sku] : array();
        $is_set = !empty($children_arr);
        $is_leaf = function_exists('dinoco_is_leaf_sku') ? dinoco_is_leaf_sku($sku, $relations) : !$is_set;
        $tree = null;
        $children_detail = array();
        if ($is_set) {
            // tree structure สำหรับ product detail view
            if (function_exists('dinoco_get_sku_tree')) {
                $tree = dinoco_get_sku_tree($sku, $relations);
            }
            // children detail: sku, name, img, price, dealer_price, stock_display, stock_eta, has_grandchildren, grandchildren
            foreach ($children_arr as $ch_sku) {
                $ch_item = isset($catalog[$ch_sku]) ? $catalog[$ch_sku] : null;
                $ch_name = $ch_item ? ($ch_item['name'] ?? $ch_sku) : $ch_sku;
                $ch_img  = $ch_item ? ($ch_item['img'] ?? '') : '';
                $ch_price = $ch_item ? b2b_parse_price($ch_item['price'] ?? '0') : 0;
                $ch_sd = isset($sku_data[$ch_sku]) ? $sku_data[$ch_sku] : array();
                $ch_dealer = function_exists('b2b_compute_dealer_price') ? b2b_compute_dealer_price($ch_price, $rank, $ch_sd) : round($ch_price * (1 - (isset($ch_sd['discount']) ? $ch_sd['discount'] : 0) / 100), 2);
                $ch_stock = 'in_stock'; $ch_eta = null;
                if (function_exists('dinoco_stock_get')) {
                    $ch_inv = dinoco_stock_get($ch_sku);
                    if ($ch_inv) { $ch_stock = $ch_inv['stock_display']; if ($ch_stock === 'out_of_stock' && !empty($ch_inv['bo_eta_override'])) $ch_eta = $ch_inv['bo_eta_override']; }
                }
                $gc_arr = isset($relations[$ch_sku]) ? $relations[$ch_sku] : array();
                $grandchildren = array();
                foreach ($gc_arr as $gc_sku) {
                    $gc_item = isset($catalog[$gc_sku]) ? $catalog[$gc_sku] : null;
                    $gc_price = $gc_item ? b2b_parse_price($gc_item['price'] ?? '0') : 0;
                    $gc_sd = isset($sku_data[$gc_sku]) ? $sku_data[$gc_sku] : array();
                    $gc_dealer = function_exists('b2b_compute_dealer_price') ? b2b_compute_dealer_price($gc_price, $rank, $gc_sd) : round($gc_price * (1 - (isset($gc_sd['discount']) ? $gc_sd['discount'] : 0) / 100), 2);
                    $gc_stock = 'in_stock'; $gc_eta = null;
                    if (function_exists('dinoco_stock_get')) { $gc_inv = dinoco_stock_get($gc_sku); if ($gc_inv) { $gc_stock = $gc_inv['stock_display']; if ($gc_stock === 'out_of_stock' && !empty($gc_inv['bo_eta_override'])) $gc_eta = $gc_inv['bo_eta_override']; } }
                    $grandchildren[] = array('sku'=>$gc_sku, 'name'=>$gc_item ? ($gc_item['name'] ?? $gc_sku) : $gc_sku, 'img'=>$gc_item ? ($gc_item['img'] ?? '') : '', 'price'=>$gc_price, 'dealer_price'=>$gc_dealer, 'stock_display'=>$gc_stock, 'stock_eta'=>$gc_eta);
                }
                $children_detail[] = array('sku'=>$ch_sku, 'name'=>$ch_name, 'img'=>$ch_img, 'price'=>$ch_price, 'dealer_price'=>$ch_dealer, 'stock_display'=>$ch_stock, 'stock_eta'=>$ch_eta, 'has_grandchildren'=>!empty($gc_arr), 'grandchildren'=>$grandchildren);
            }
        }

        $products[] = array(
            'sku'=>$sku,'name'=>$name,'img'=>$img,'price'=>$price,
            'discount'=>$effective_discount,'dealer_price'=>$dealer_price,
            'sub'=>$sub,'stock_status'=>$stock_status,'oos_eta'=>$oos_eta,
            'stock_display'=>$stock_display,'stock_eta'=>$stock_eta,
            'children'=>$children_arr,
            'children_detail'=>$children_detail,
            'is_set'=>$is_set,'is_leaf'=>$is_leaf,
            'boxes_per_unit'=>$boxes_per_unit,
            'units_per_box'=>$units_per_box,
            'category'=>$category,
            'compatible_models'=>$compatible_models,
        );
    }

    // V.38.9: Moto Catalog inline (ลด round-trip)
    $moto_catalog = array();
    if ( class_exists( 'DINOCO_MotoDB' ) && method_exists( 'DINOCO_MotoDB', 'get_full_catalog_json' ) ) {
        $moto_catalog = DINOCO_MotoDB::get_full_catalog_json();
    }

    return new WP_REST_Response( array('success'=>true,'products'=>$products,'count'=>count($products),'moto_catalog'=>$moto_catalog), 200 );
    } catch ( \Throwable $e ) {
        error_log('[Catalog] ' . get_class($e) . ' — ' . $e->getMessage() . ' at ' . $e->getFile() . ':' . $e->getLine());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══════════════════════════════════════
// POST /place-order 🔒 ต้องมี token
// ═══════════════════════════════════════
function b2b_rest_place_order( WP_REST_Request $request ) {
    // ── Security: ตรวจ session token ──
    $session = b2b_verify_session_token($request);
    if ( !$session ) return b2b_unauthorized_response();

    try {
    $group_id = $session['gid'];
    $line_uid = $session['uid'];
    $items    = $request->get_param('items');
    $note     = mb_substr(sanitize_textarea_field($request->get_param('note')), 0, 500);

    if ( empty($items) || !is_array($items) )
        return new WP_REST_Response(array('success'=>false,'message'=>'กรุณาระบุรายการสินค้า'), 400);
    if ( count($items) > 50 )
        return new WP_REST_Response(array('success'=>false,'message'=>'รายการสินค้ามากเกินไป (สูงสุด 50 รายการ)'), 400);

    // SEC: Duplicate order prevention — transient lock per group
    $dedup_key = 'b2b_order_dedup_' . md5($group_id . wp_json_encode($items));
    if ( get_transient($dedup_key) )
        return new WP_REST_Response(array('success'=>false,'message'=>'คำสั่งซื้อนี้ถูกส่งไปแล้ว กรุณารอสักครู่'), 429);
    set_transient($dedup_key, 1, 30);

    $dist = b2b_get_dist_by_group($group_id);
    if (!$dist) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่พบร้านค้าในระบบ'), 404);

    $dist_name = get_the_title($dist->ID);
    if ( get_field('credit_hold', $dist->ID) )
        return new WP_REST_Response(array('success'=>false,'message'=>'⛔ ร้าน '.$dist_name.' ถูกระงับสิทธิ์สั่งสินค้าชั่วคราว'), 403);

    // SEC: Server-side price lookup — never trust client-supplied prices
    // V.39.3: Tier pricing % discount — use b2b_compute_dealer_price() (shared helper)
    $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
    $rank = get_field('rank_system', $dist->ID) ?: 'standard';
    $price_map = array();
    $sku_data_map = b2b_get_sku_data_map();
    foreach ($sku_data_map as $sku => $sdata) {
        $base = isset($sdata['price_standard']) && $sdata['price_standard'] > 0
            ? $sdata['price_standard']
            : (isset($catalog[$sku]['price']) ? b2b_parse_price($catalog[$sku]['price']) : 0);
        if ( $base <= 0 ) continue;
        $dealer = function_exists('b2b_compute_dealer_price')
            ? b2b_compute_dealer_price( $base, $rank, $sdata )
            : round( $base * ( 1 - floatval($sdata['discount']) / 100 ), 2 );
        if ($dealer > 0) $price_map[$sku] = $dealer;
    }

    $order_lines = array();
    $total = 0;
    foreach ( $items as $item ) {
        $sku = sanitize_text_field($item['sku']);
        $qty = max(0, min(9999, intval($item['qty'])));
        $name = sanitize_text_field($item['name']);
        // SEC: Only accept server-side prices — reject unknown SKUs
        if ( !isset($price_map[$sku]) ) continue;
        $price = $price_map[$sku];
        if ($qty <= 0) continue;
        $lt = $price * $qty;
        $total += $lt;
        $order_lines[] = $name.' ('.$sku.') x'.$qty.' = ฿'.number_format($lt,0);
    }
    if ( empty($order_lines) ) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่มีรายการที่ถูกต้อง'), 400);

    // FIX H5: Soft credit limit check — warn before order creation
    $credit_limit = floatval(get_field('credit_limit', $dist->ID));
    if ($credit_limit > 0) {
        $current_debt = function_exists('b2b_recalculate_debt') ? b2b_recalculate_debt($dist->ID) : floatval(get_field('current_debt', $dist->ID));
        if (($current_debt + $total) > $credit_limit) {
            $avail = max(0, $credit_limit - $current_debt);
            return new WP_REST_Response(array('success'=>false,
                'message'=>'⚠️ เกินวงเครดิต: เหลือ ฿'.number_format($avail,0).' แต่ยอดสั่ง ฿'.number_format($total,0)."\nกรุณาชำระยอดค้างก่อนสั่งสินค้าครับ"), 403);
        }
    }

    $order_text = implode("\n", $order_lines);
    if ($note) $order_text .= "\n\n📝 หมายเหตุ: ".$note;

    $edit_ticket = intval($request->get_param('edit_ticket'));

    if ($edit_ticket > 0) {
        // Verify the ticket belongs to this group and is in editable status
        $existing_gid = get_field('source_group_id', $edit_ticket);
        $existing_status = get_field('order_status', $edit_ticket);
        $editable_statuses = array('draft', 'pending', 'checking_stock');

        if ($existing_gid !== $group_id) {
            return new WP_REST_Response(array('success' => false, 'message' => 'ไม่มีสิทธิ์แก้ไขออเดอร์นี้'), 403);
        }
        if (!in_array($existing_status, $editable_statuses, true)) {
            return new WP_REST_Response(array('success' => false, 'message' => 'ออเดอร์นี้ไม่สามารถแก้ไขได้แล้ว (สถานะ: ' . $existing_status . ')'), 400);
        }

        // Update existing order instead of creating new
        $post_id = $edit_ticket;
        update_field('order_items', $order_text, $post_id);
        update_field('total_amount', $total, $post_id);
        if ( function_exists('b2b_calculate_total_boxes') ) {
            update_field('total_boxes', b2b_calculate_total_boxes($post_id), $post_id);
        }
        // M16 (V.40.7): route through b2b_set_order_status() helper so the transition
        //   fires b2b_order_status_changed hooks + appends _b2b_status_history. The FSM
        //   table (Snippet 14 V.1.5) may not allow every from→to combo here (e.g. 'pending'
        //   isn't in the FSM table, and 'checking_stock'→'checking_stock' is a self-loop)
        //   but the canonical helper uses soft fallback: FSM warnings are logged + the
        //   direct update still fires the hook, so downstream listeners see all edges.
        //
        //   $editable_statuses = ['draft', 'pending', 'checking_stock'] (guard above, line 700)
        //   Walk-in target  : 'awaiting_confirm' (skip stock check)
        //   Non-walk-in     : 'checking_stock'  (regular flow)
        $edit_target = ( get_post_meta($post_id, '_b2b_is_walkin', true) === '1' )
            ? 'awaiting_confirm'
            : 'checking_stock';
        if ( function_exists('b2b_set_order_status') ) {
            b2b_set_order_status( $post_id, $edit_target );
        } else {
            update_field( 'order_status', $edit_target, $post_id );
            do_action( 'b2b_order_status_changed', $post_id, get_field('order_status', $post_id), $edit_target, 'system' );
        }
        // Copy distributor address to order (refresh on edit)
        if ( $dist ) {
            $dist_title = get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID);
            update_field('dist_name', $dist_title, $post_id);
            foreach (array('dist_phone','dist_address','dist_district','dist_city','dist_province','dist_postcode') as $af) {
                $v = get_field($af, $dist->ID);
                if ( !empty($v) ) update_field($af, $v, $post_id);
            }
        }

        b2b_log("[PlaceOrder] Edited ticket #{$post_id} — Total: {$total}");

        // Notify admin about the edit
        $msg = "📝 แก้ไขออเดอร์ #{$post_id}\n🏪 " . $dist_name . "\nยอดใหม่: ฿" . number_format($total, 0);
        b2b_push_to_admin($msg);

        if (function_exists('b2b_build_flex_stock_check_alert') && function_exists('b2b_push_raw_to_admin')) {
            $flex = b2b_build_flex_stock_check_alert($post_id, $order_text, $group_id);
            b2b_push_raw_to_admin(array($flex));
        }

        // Auto-print: re-queue after edit (V.21.0 parity)
        if ( function_exists('b2b_enqueue_print_job') ) {
            b2b_enqueue_print_job($post_id);
        }

        return new WP_REST_Response(array('success' => true, 'ticket_id' => $post_id, 'total' => $total, 'edited' => true), 200);
    }

    $post_id = wp_insert_post(array('post_type'=>'b2b_order','post_title'=>'Order จาก '.$dist_name.' — '.b2b_date('d/m/Y H:i'),'post_status'=>'publish'));
    if ( is_wp_error($post_id) ) return new WP_REST_Response(array('success'=>false,'message'=>'สร้าง Order ไม่สำเร็จ'), 500);

    update_field('order_status', 'draft', $post_id);
    update_field('source_group_id', $group_id, $post_id);
    update_field('order_items', $order_text, $post_id);
    update_field('total_amount', $total, $post_id);
    update_field('is_billed', false, $post_id);
    // Walk-in flag — stamp on order if distributor is walk-in
    if ( get_field('is_walkin', $dist->ID) ) {
        update_post_meta($post_id, '_b2b_is_walkin', '1');
    }
    if ( function_exists('b2b_calculate_total_boxes') ) {
        update_field('total_boxes', b2b_calculate_total_boxes($post_id), $post_id);
    }
    // V.9: N5 — save customer_note as ACF field
    if ( !empty($note) ) update_field('customer_note', $note, $post_id);
    // V.9: save orderer info from session
    if ( !empty($line_uid) ) {
        $orderer_name = function_exists('b2b_get_line_profile_name') ? b2b_get_line_profile_name($line_uid) : '';
        if ( $orderer_name ) update_field('orderer_display_name', $orderer_name, $post_id);
        update_field('orderer_user_id', $line_uid, $post_id);
    }
    // Copy distributor address to order for Flash shipping
    if ( $dist ) {
        $dist_title = get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID);
        update_field('dist_name', $dist_title, $post_id);
        foreach (array('dist_phone','dist_address','dist_district','dist_city','dist_province','dist_postcode') as $af) {
            $v = get_field($af, $dist->ID);
            if ( !empty($v) ) update_field($af, $v, $post_id);
        }
    }

    // ── Send Draft Confirm Flex to dealer group for review ──
    $line_token = defined('B2B_LINE_ACCESS_TOKEN') ? B2B_LINE_ACCESS_TOKEN : '';
    b2b_log("[PlaceOrder] New DRAFT #{$post_id} — {$dist_name} — ฿" . number_format($total, 0) . " — gid:{$group_id} — token:" . ($line_token ? 'set('.strlen($line_token).')' : 'MISSING'));

    if ( $line_token && $group_id && function_exists('b2b_build_flex_draft_confirm') ) {
        $flex = b2b_build_flex_draft_confirm($post_id, $order_text, $total, $dist_name);
        $r1 = wp_remote_post( 'https://api.line.me/v2/bot/message/push', array(
            'headers' => array('Content-Type'=>'application/json','Authorization'=>'Bearer '.$line_token),
            'body'    => wp_json_encode(array('to'=>$group_id,'messages'=>array($flex))),
            'timeout' => 15,
        ));
        if ( is_wp_error($r1) ) {
            b2b_log("[PlaceOrder] #{$post_id} draft flex push WP_Error: " . $r1->get_error_message());
        } else {
            b2b_log("[PlaceOrder] #{$post_id} draft flex push HTTP " . wp_remote_retrieve_response_code($r1));
        }
    } elseif ( $line_token && $group_id ) {
        // Fallback: send text if flex builder not available
        $msg = "📋 ตรวจสอบรายการสั่งซื้อ #".$post_id."\n🏪 ".$dist_name."\n".$order_text."\n💰 มูลค่ารวมสุทธิ: ฿".number_format($total,0);
        $r1 = wp_remote_post( 'https://api.line.me/v2/bot/message/push', array(
            'headers' => array('Content-Type'=>'application/json','Authorization'=>'Bearer '.$line_token),
            'body'    => wp_json_encode(array('to'=>$group_id,'messages'=>array(array('type'=>'text','text'=>$msg)))),
            'timeout' => 15,
        ));
        b2b_log("[PlaceOrder] #{$post_id} draft text fallback — HTTP " . (is_wp_error($r1) ? $r1->get_error_message() : wp_remote_retrieve_response_code($r1)));
    } else {
        b2b_log("[PlaceOrder] #{$post_id} SKIP draft push — token:" . ($line_token ? 'yes' : 'NO') . " gid:" . ($group_id ?: 'EMPTY'));
    }
    // NOTE: Admin notification + stock check happens AFTER dealer confirms via postback (action=confirm_order in Snippet 2)

    // V.41.4 — C1 FIX: Fire post-process hook for BO system (Snippet 16 listens)
    // เปิดโอกาสให้ BO system route order → pending_stock_review (ถ้า b2b_flag_bo_system=true)
    $dist_id_post = $dist ? (int) $dist->ID : 0;
    do_action( 'b2b_place_order_post_process', $post_id, $dist_id_post, $items, $total );

    return new WP_REST_Response(array('success'=>true,'ticket_id'=>$post_id,'message'=>'✅ ส่งออเดอร์เรียบร้อย'), 200);
    } catch ( \Throwable $e ) {
        b2b_log('[PlaceOrder] Error: ' . get_class($e) . ' — ' . $e->getMessage() . ' at ' . $e->getFile() . ':' . $e->getLine());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

// ═══════════════════════════════════════
// POST /cancel-request 🔒 ต้องมี token
// ═══════════════════════════════════════
function b2b_rest_cancel_request( WP_REST_Request $request ) {
    try {
        $session = b2b_verify_session_token($request);
        if ( !$session ) return new WP_REST_Response(array('success' => false, 'message' => 'Unauthorized'), 401);

        $body = $request->get_json_params();
        $ticket_id = isset($body['ticket_id']) ? intval($body['ticket_id']) : 0;
        if ( !$ticket_id ) {
            return new WP_REST_Response(array('success' => false, 'message' => 'Missing ticket_id'), 400);
        }

        // V.40.6 — Audit H8: ownership check BEFORE rate limiter, then use canonical helper.
        // Ownership-first prevents attackers from burning a victim's quota by spamming
        // ticket_ids they don't own. The helper uses transient-primary so it works on
        // default WP (no Redis/Memcache required) — unlike V.40.5 which relied on
        // wp_cache_* that resets per-request on non-persistent backends.
        $group_id = $session['gid'];
        $ticket_gid = get_field('source_group_id', $ticket_id);
        if ( $ticket_gid !== $group_id ) {
            return new WP_REST_Response(array('success' => false, 'message' => 'ไม่มีสิทธิ์ยกเลิกออเดอร์นี้'), 403);
        }

        // V.41.3 — Cancel grace period (security H4 fix per spec §3.5 E2)
        // แยก rate limit 2 ชั้น: grace period ภายใน 5 นาทีแรก = unlimited
        // หลัง grace: 2/hr + 10/day (tighter than legacy 5/60s to prevent probe attacks)
        //
        // Normal use case: ลูกค้าสั่ง → เปลี่ยนใจ → cancel ใน 2-5 นาที = ต้องอนุญาต
        // Attack case: เว้น 5+ นาทีแล้ว cancel+retry loop = ต้อง rate-limit
        $ticket_created = get_the_date( 'U', $ticket_id );
        $age_minutes    = $ticket_created ? ( time() - $ticket_created ) / 60 : 999;
        $grace_minutes  = function_exists( 'b2b_bo_get_config' )
            ? (int) b2b_bo_get_config( 'b2b_bo_cancel_grace_minutes' )
            : 5;

        if ( $age_minutes > $grace_minutes && function_exists( 'b2b_rate_limit' ) ) {
            // Past grace — apply stricter BO-spec rate limits (2/hr + 10/day)
            $rate_hr  = function_exists( 'b2b_bo_get_config' )
                ? (int) b2b_bo_get_config( 'b2b_bo_rate_cancel_per_hour' )
                : 2;
            $rate_day = function_exists( 'b2b_bo_get_config' )
                ? (int) b2b_bo_get_config( 'b2b_bo_rate_cancel_per_day' )
                : 10;

            $rl_hr = b2b_rate_limit( 'cancel_hr_' . $group_id, $rate_hr, 3600 );
            if ( is_wp_error( $rl_hr ) ) {
                // Log attempt for enumeration scan
                if ( function_exists( 'b2b_log_attempt' ) ) {
                    $dist_id = 0;
                    if ( function_exists( 'b2b_get_dist_by_group' ) ) {
                        $dist = b2b_get_dist_by_group( $group_id );
                        if ( $dist ) $dist_id = (int) $dist->ID;
                    }
                    b2b_log_attempt( $dist_id, 'cancel', $ticket_id, '', 'rate_limit', 'CANCEL_HOUR_LIMIT', array( 'group_id' => $group_id ) );
                }
                return new WP_REST_Response( array(
                    'success' => false,
                    'message' => 'ยกเลิกบ่อยเกินไป กรุณาติดต่อทีมงาน',
                ), 429 );
            }

            $rl_day = b2b_rate_limit( 'cancel_day_' . $group_id, $rate_day, 86400 );
            if ( is_wp_error( $rl_day ) ) {
                if ( function_exists( 'b2b_log_attempt' ) ) {
                    $dist_id = 0;
                    if ( function_exists( 'b2b_get_dist_by_group' ) ) {
                        $dist = b2b_get_dist_by_group( $group_id );
                        if ( $dist ) $dist_id = (int) $dist->ID;
                    }
                    b2b_log_attempt( $dist_id, 'cancel', $ticket_id, '', 'rate_limit', 'CANCEL_DAY_LIMIT', array( 'group_id' => $group_id ) );
                }
                return new WP_REST_Response( array(
                    'success' => false,
                    'message' => 'เกินจำนวนครั้งยกเลิกต่อวัน กรุณาติดต่อทีมงาน',
                ), 429 );
            }
        }
        // else: ภายใน grace period → ไม่ rate-limit (normal use case)

        $status = get_field('order_status', $ticket_id);
        $cancellable = array('draft', 'pending', 'checking_stock', 'pending_stock_review', 'awaiting_confirm', 'awaiting_payment');
        if ( !in_array($status, $cancellable, true) ) {
            return new WP_REST_Response(array('success' => false, 'message' => 'ออเดอร์นี้ไม่สามารถยกเลิกได้ (สถานะ: ' . $status . ')'), 400);
        }

        // Advisory lock
        $lock_key = 'b2b_lock_' . $ticket_id;
        if ( get_transient($lock_key) ) {
            return new WP_REST_Response(array('success' => false, 'message' => 'กำลังดำเนินการอยู่ กรุณารอสักครู่'), 429);
        }
        set_transient($lock_key, 1, 10);

        // Save previous status for undo
        update_field('cancel_prev_status', $status, $ticket_id);
        // V.39.2: ใช้ FSM เพื่อ validate transition + บันทึก status history + fire hooks
        if (function_exists('b2b_set_order_status')) {
            b2b_set_order_status($ticket_id, 'cancel_requested', 'customer');
        } else {
            update_field('order_status', 'cancel_requested', $ticket_id);
        }

        b2b_log("[Cancel] Request from customer for #{$ticket_id} (was: {$status})");

        // Notify admin
        $dist_name = get_field('dist_name', $ticket_id) ?: 'ลูกค้า';
        $total = get_field('total_amount', $ticket_id);
        $msg = "⚠️ ขอยกเลิกออเดอร์ #{$ticket_id}\nร้าน: {$dist_name}\nยอด: ฿" . number_format($total, 0);

        if ( function_exists('b2b_push_raw_to_admin') && function_exists('b2b_build_flex_cancel_request') ) {
            $flex = b2b_build_flex_cancel_request($ticket_id);
            b2b_push_raw_to_admin(array($flex));
        } else {
            b2b_push_to_admin($msg);
        }

        delete_transient($lock_key);

        return new WP_REST_Response(array('success' => true, 'message' => 'ส่งคำขอยกเลิกเรียบร้อย'), 200);
    } catch ( Exception $e ) {
        b2b_log('[CancelRequest] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาด'), 500);
    }
}

