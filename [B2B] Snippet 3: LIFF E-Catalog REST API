/**
 * Helper: verify admin session (reuse session token + admin group check)
 */
if ( ! function_exists('b2b_rest_verify_admin') ) {
    function b2b_rest_verify_admin( WP_REST_Request $request ) {
        $session = b2b_verify_session_token($request);
        if ( !$session ) return false;
        $admin_gid = defined('B2B_ADMIN_GROUP_ID') ? B2B_ADMIN_GROUP_ID : '';
        if ( empty($admin_gid) || $session['gid'] !== $admin_gid ) return false;
        return $session;
    }
