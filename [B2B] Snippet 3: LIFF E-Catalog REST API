// ═══════════════════════════════════════════════════════════════
// V.41.0: Manual Flash Status — เช็คสถานะจาก Flash Routes API (#2)
// ═══════════════════════════════════════════════════════════════
function b2b_rest_manual_flash_status( WP_REST_Request $r ) {
    try {
        $pno = sanitize_text_field( $r->get_param( 'pno' ) );
        if ( empty( $pno ) ) return new WP_REST_Response( array( 'success' => false, 'message' => 'Missing PNO' ), 400 );
        if ( ! function_exists( 'b2b_flash_get_routes' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Flash routes function not available' ), 500 );
        }
        $result = b2b_flash_get_routes( $pno );
        if ( ! empty( $result['ok'] ) ) {
            // Also update manual shipment status from routes data
            $data = $result['data'] ?? array();
            $state = isset( $data['state'] ) ? intval( $data['state'] ) : -1;
            if ( $state > 0 && function_exists( 'b2b_flash_manual_shipment_webhook' ) ) {
                b2b_flash_manual_shipment_webhook( $pno, array( 'state' => $state ) );
            }
            return new WP_REST_Response( array( 'success' => true, 'data' => $data ), 200 );
        }
        return new WP_REST_Response( array( 'success' => false, 'message' => $result['error'] ?? 'Cannot get status' ), 400 );
    } catch ( \Throwable $e ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error' ), 500 );
    }
}

// ═══════════════════════════════════════════════════════════════
// V.41.0: Manual Flash Test — ทดสอบ Flash API connection (#8)
// ═══════════════════════════════════════════════════════════════
function b2b_rest_manual_flash_test( WP_REST_Request $r ) {
    try {
        if ( ! defined( 'B2B_FLASH_MCH_ID' ) || ! defined( 'B2B_FLASH_SECRET_KEY' ) || ! defined( 'B2B_FLASH_API_URL' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Flash constants not configured' ), 400 );
        }
        if ( ! function_exists( 'b2b_flash_get_warehouses' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Flash function not available' ), 500 );
        }
        $result = b2b_flash_get_warehouses();
        $diag = array(
            'api_url'       => B2B_FLASH_API_URL,
            'mch_id'        => B2B_FLASH_MCH_ID,
            'is_production' => strpos( B2B_FLASH_API_URL, 'open-api-tra' ) === false,
        );
        if ( ! empty( $result['ok'] ) ) {
            return new WP_REST_Response( array( 'success' => true, 'message' => 'Flash API OK', 'diagnostic' => $diag ), 200 );
        }
        return new WP_REST_Response( array( 'success' => false, 'message' => $result['error'] ?? 'Flash API error', 'diagnostic' => $diag ), 200 );
    } catch ( \Throwable $e ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error' ), 500 );
    }
}

// ═══════════════════════════════════════════════════════════════
// V.41.0: Manual Flash Status Polling Cron (#7)
// ═══════════════════════════════════════════════════════════════
add_action( 'b2b_manual_flash_poll_cron', 'b2b_run_manual_flash_poll' );
add_action( 'init', function() {
    if ( ! wp_next_scheduled( 'b2b_manual_flash_poll_cron' ) ) {
        wp_schedule_event( time(), 'everytwohours', 'b2b_manual_flash_poll_cron' );
    }
});

function b2b_run_manual_flash_poll() {
    $terminal = array( 'delivered', 'cancelled', 'returned', 'closed' );
    $months = function_exists( 'b2b_manual_shipment_months' ) ? b2b_manual_shipment_months( 3 ) : array( date( 'Y_m' ) );
    $active_pnos = array();

    foreach ( $months as $m ) {
        $shipments = get_option( 'b2b_manual_shipments_' . $m, array() );
        foreach ( $shipments as $s ) {
            if ( ! empty( $s['pno'] ) && ! in_array( $s['status'] ?? '', $terminal ) ) {
                $active_pnos[] = $s['pno'];
            }
        }
    }

    if ( empty( $active_pnos ) ) return;
    if ( ! function_exists( 'b2b_flash_get_routes' ) ) return;

    // Poll each PNO (max 20 per cron run to avoid timeout)
    $to_poll = array_slice( $active_pnos, 0, 20 );
    foreach ( $to_poll as $pno ) {
        $result = b2b_flash_get_routes( $pno );
        if ( empty( $result['ok'] ) ) continue;
        $data = $result['data'] ?? array();
        $state = isset( $data['state'] ) ? intval( $data['state'] ) : -1;
        if ( $state > 0 && function_exists( 'b2b_flash_manual_shipment_webhook' ) ) {
            b2b_flash_manual_shipment_webhook( $pno, array( 'state' => $state ) );
        }
    }

    b2b_log( '[ManualFlash] Cron polled ' . count( $to_poll ) . '/' . count( $active_pnos ) . ' active PNOs' );
}
