// =====================================================================
// V.37: PER-BOX SCAN — Mark individual box as packed
// =====================================================================

function b2b_rest_rpi_flash_box_packed( WP_REST_Request $request ) {
    if ( ! b2b_verify_print_key( $request ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Invalid API key' ), 403 );

    $pno = sanitize_text_field( $request->get_param( 'pno' ) );
    if ( ! $pno )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Missing pno' ), 400 );

    // Find ticket by PNO
    $ticket_id = 0;
    if ( function_exists( 'b2b_flash_find_ticket_by_pno' ) ) {
        $ticket_id = b2b_flash_find_ticket_by_pno( $pno );
    }
    if ( ! $ticket_id )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'PNO not found' ), 404 );

    $pno_statuses = get_post_meta( $ticket_id, '_flash_pno_statuses', true );
    if ( ! is_array( $pno_statuses ) || ! isset( $pno_statuses[ $pno ] ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'PNO not in ticket #' . $ticket_id ), 404 );

    // Mark this box as packed
    $now = time();
    if ( is_array( $pno_statuses[ $pno ] ) ) {
        $pno_statuses[ $pno ]['packed_at'] = $now;
    }
    update_post_meta( $ticket_id, '_flash_pno_statuses', $pno_statuses );

    // Set pack_started timestamp (first scan)
    $pack_started = get_post_meta( $ticket_id, '_flash_pack_started', true );
    if ( ! $pack_started ) {
        update_post_meta( $ticket_id, '_flash_pack_started', $now );
        $pack_started = $now;
    }

    // Update packing status
    update_post_meta( $ticket_id, '_flash_packing_status', 'packing' );

    // Count packed vs total (excluding cancelled/hold)
    $total_active = 0;
    $packed_count = 0;
    foreach ( $pno_statuses as $p => $info ) {
        $s = is_array( $info ) ? ( $info['status'] ?? 'created' ) : 'created';
        if ( in_array( $s, array( 'cancelled', 'hold_pending' ), true ) ) continue;
        $total_active++;
        $pa = is_array( $info ) ? ( $info['packed_at'] ?? null ) : null;
        if ( $pa ) $packed_count++;
    }

    $box_info = $pno_statuses[ $pno ];
    $box_label = is_array( $box_info ) ? ( $box_info['box'] ?? '' ) : '';
    $item_name = is_array( $box_info ) ? ( $box_info['name'] ?? '' ) : '';
    $remaining = $total_active - $packed_count;
    $all_packed = ( $packed_count >= $total_active );

    b2b_log( '[Flash BoxPacked] #' . $ticket_id . ' PNO=' . $pno . ' box=' . $box_label . ' packed=' . $packed_count . '/' . $total_active );

    if ( $all_packed ) {
        // All boxes packed → auto-call courier
        update_post_meta( $ticket_id, '_flash_packing_status', 'all_packed' );
        b2b_add_audit_log( $ticket_id, 'all_boxes_packed', 'ครบ ' . $total_active . ' กล่อง (RPi per-box scan)' );

        // Trigger courier call by delegating to flash-ready logic
        $courier_result = null;
        if ( function_exists( 'b2b_flash_notify_courier_from_warehouse' ) ) {
            // Mark as ready first
            update_post_meta( $ticket_id, '_flash_packing_status', 'ready_to_ship' );

            // Check active pickup
            $active_pickup = get_transient( 'b2b_flash_active_pickup' );
            if ( is_array( $active_pickup ) && ! empty( $active_pickup['pickup_id'] ) ) {
                // Reuse active pickup
                $active_pickup['parcel_count'] = intval( $active_pickup['parcel_count'] ?? 0 ) + $total_active;
                if ( ! is_array( $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'] = array();
                if ( ! in_array( $ticket_id, $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'][] = $ticket_id;
                set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );
                update_post_meta( $ticket_id, '_flash_packing_status', 'courier_called' );
                update_post_meta( $ticket_id, '_flash_pickup_id', $active_pickup['pickup_id'] );
                update_post_meta( $ticket_id, '_flash_courier_info', array( 'name' => $active_pickup['staff_name'], 'phone' => $active_pickup['staff_phone'] ) );

                if ( function_exists( 'b2b_build_flex_pickup_added' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
                    $flex = b2b_build_flex_pickup_added( $ticket_id, $active_pickup );
                    b2b_push_raw_to_admin( array( $flex ) );
                }

                return new WP_REST_Response( array(
                    'success'      => true,
                    'all_packed'   => true,
                    'courier'      => 'reused_pickup',
                    'message'      => '✅ ครบ ' . $total_active . ' กล่อง — เพิ่มเข้า pickup',
                    'box_label'    => $box_label,
                    'item_name'    => $item_name,
                    'packed_count' => $packed_count,
                    'total_active' => $total_active,
                ), 200 );
            }

            // Call new courier
            $cr = b2b_flash_notify_courier_from_warehouse( $total_active, 'AllPacked: #' . $ticket_id );
            if ( $cr['ok'] && ! empty( $cr['data'] ) ) {
                $pd = $cr['data'];
                $staff   = $pd['staffInfoName']  ?? $pd['staffInfoname'] ?? '';
                $phone   = $pd['staffInfoPhone'] ?? $pd['staffInfomobile'] ?? '';
                $timeout = $pd['timeoutAtText']  ?? '';
                $pid     = $pd['ticketPickupId']  ?? '';

                $active_pickup = array(
                    'pickup_id' => $pid, 'staff_name' => $staff, 'staff_phone' => $phone,
                    'timeout_text' => $timeout, 'created_at' => time(),
                    'parcel_count' => $total_active, 'ticket_ids' => array( $ticket_id ),
                );
                set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );
                update_post_meta( $ticket_id, '_flash_packing_status', 'courier_called' );
                update_post_meta( $ticket_id, '_flash_pickup_id', $pid );
                update_post_meta( $ticket_id, '_flash_courier_info', array( 'name' => $staff, 'phone' => $phone, 'pickupId' => $pid ) );

                if ( function_exists( 'b2b_build_flex_courier_pickup' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
                    $flex = b2b_build_flex_courier_pickup( $active_pickup );
                    b2b_push_raw_to_admin( array( $flex ) );
                }

                return new WP_REST_Response( array(
                    'success'      => true,
                    'all_packed'   => true,
                    'courier'      => 'called',
                    'message'      => '✅ ครบ ' . $total_active . ' กล่อง — 🚛 เรียกคูเรียร์สำเร็จ',
                    'courier_info' => $staff . ' ' . $phone,
                    'box_label'    => $box_label,
                    'item_name'    => $item_name,
                    'packed_count' => $packed_count,
                    'total_active' => $total_active,
                ), 200 );
            }
        }

        return new WP_REST_Response( array(
            'success'      => true,
            'all_packed'   => true,
            'courier'      => 'pending',
            'message'      => '✅ ครบ ' . $total_active . ' กล่อง — ระบบกำลังเรียกคูเรียร์',
            'box_label'    => $box_label,
            'item_name'    => $item_name,
            'packed_count' => $packed_count,
            'total_active' => $total_active,
        ), 200 );
    }

    // Not all packed yet — return partial status
    return new WP_REST_Response( array(
        'success'      => true,
        'all_packed'   => false,
        'message'      => '✅ กล่อง ' . $box_label . ' ' . $item_name . ' — เหลือ ' . $remaining . ' กล่อง',
        'box_label'    => $box_label,
        'item_name'    => $item_name,
        'packed_count' => $packed_count,
        'total_active' => $total_active,
        'remaining'    => $remaining,
        'pack_started' => $pack_started,
        'pno_statuses' => $pno_statuses,
        'ticket_id'    => $ticket_id,
    ), 200 );
}

// =====================================================================
// V.37: Ship only packed boxes (partial shipment after timeout)
// =====================================================================

function b2b_rest_flash_ship_packed( WP_REST_Request $request ) {
    if ( ! b2b_verify_print_key( $request ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Invalid API key' ), 403 );

    $tid = intval( $request->get_param( 'ticket_id' ) );
    if ( ! $tid || get_post_type( $tid ) !== 'b2b_order' )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Ticket not found' ), 404 );

    $pno_statuses = get_post_meta( $tid, '_flash_pno_statuses', true );
    if ( ! is_array( $pno_statuses ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'No PNO statuses' ), 400 );

    // Count packed vs unpacked
    $packed_pnos = array();
    $hold_pnos   = array();
    $hold_names  = array();
    foreach ( $pno_statuses as $pno => $info ) {
        $s  = is_array( $info ) ? ( $info['status'] ?? 'created' ) : 'created';
        if ( in_array( $s, array( 'cancelled', 'hold_pending' ), true ) ) continue;
        $pa = is_array( $info ) ? ( $info['packed_at'] ?? null ) : null;
        if ( $pa ) {
            $packed_pnos[] = $pno;
        } else {
            $hold_pnos[] = $pno;
            $hold_names[] = is_array( $info ) ? ( $info['name'] ?? $pno ) : $pno;
            // Mark as hold_pending
            if ( is_array( $pno_statuses[ $pno ] ) ) {
                $pno_statuses[ $pno ]['status'] = 'hold_pending';
            }
        }
    }

    if ( empty( $packed_pnos ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่มีกล่องที่พร้อมส่ง' ), 400 );

    // Save updated statuses
    update_post_meta( $tid, '_flash_pno_statuses', $pno_statuses );
    update_post_meta( $tid, '_flash_packing_status', 'partial_shipped' );

    // Call courier for packed boxes only
    $estimate = count( $packed_pnos );
    $courier_msg = '';
    if ( function_exists( 'b2b_flash_notify_courier_from_warehouse' ) ) {
        $active_pickup = get_transient( 'b2b_flash_active_pickup' );
        if ( is_array( $active_pickup ) && ! empty( $active_pickup['pickup_id'] ) ) {
            // Reuse active pickup
            $active_pickup['parcel_count'] = intval( $active_pickup['parcel_count'] ?? 0 ) + $estimate;
            if ( ! is_array( $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'] = array();
            if ( ! in_array( $tid, $active_pickup['ticket_ids'] ) ) $active_pickup['ticket_ids'][] = $tid;
            set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );
            update_post_meta( $tid, '_flash_packing_status', 'courier_called' );
            update_post_meta( $tid, '_flash_pickup_id', $active_pickup['pickup_id'] );
            $courier_msg = 'เพิ่มเข้า pickup เดิม';
        } else {
            $cr = b2b_flash_notify_courier_from_warehouse( $estimate, 'PartialShip: #' . $tid );
            if ( $cr['ok'] && ! empty( $cr['data'] ) ) {
                $pd = $cr['data'];
                $staff   = $pd['staffInfoName'] ?? $pd['staffInfoname'] ?? '';
                $phone   = $pd['staffInfoPhone'] ?? $pd['staffInfomobile'] ?? '';
                $timeout = $pd['timeoutAtText'] ?? '';
                $pid     = $pd['ticketPickupId'] ?? '';
                $active_pickup = array(
                    'pickup_id' => $pid, 'staff_name' => $staff, 'staff_phone' => $phone,
                    'timeout_text' => $timeout, 'created_at' => time(),
                    'parcel_count' => $estimate, 'ticket_ids' => array( $tid ),
                );
                set_transient( 'b2b_flash_active_pickup', $active_pickup, 4 * HOUR_IN_SECONDS );
                update_post_meta( $tid, '_flash_packing_status', 'courier_called' );
                update_post_meta( $tid, '_flash_pickup_id', $pid );
                update_post_meta( $tid, '_flash_courier_info', array( 'name' => $staff, 'phone' => $phone ) );
                $courier_msg = 'เรียกคูเรียร์สำเร็จ — ' . $staff;
            }
        }
    }

    // Notify admin
    if ( function_exists( 'b2b_push_to_admin' ) ) {
        $dist = get_field( 'dist_name', $tid ) ?: '';
        b2b_push_to_admin( '📦 ส่ง ' . count($packed_pnos) . '/' . ( count($packed_pnos) + count($hold_pnos) ) . ' กล่อง #' . $tid . ' ' . $dist . ' — ' . implode(', ', $hold_names) . ' รอส่งรอบถัดไป' );
    }

    // Notify dealer (hold boxes)
    if ( ! empty( $hold_pnos ) && function_exists( 'b2b_build_flex_box_hold' ) ) {
        $customer_gid = get_field( 'source_group_id', $tid );
        if ( $customer_gid && function_exists( 'b2b_push_raw_to_group' ) ) {
            $flex = b2b_build_flex_box_hold( $tid, $pno_statuses, $hold_names );
            b2b_push_raw_to_group( $customer_gid, array( $flex ) );
        }
    }

    b2b_add_audit_log( $tid, 'partial_ship', 'ส่ง ' . count($packed_pnos) . ' กล่อง, hold ' . count($hold_pnos) . ' กล่อง' );

    return new WP_REST_Response( array(
        'success'     => true,
        'message'     => 'ส่ง ' . count($packed_pnos) . ' กล่อง — ' . implode(', ', $hold_names) . ' รอส่งรอบถัดไป',
        'packed'      => $packed_pnos,
        'hold'        => $hold_pnos,
        'courier'     => $courier_msg,
    ), 200 );
}

// =====================================================================
// V.22: FLASH EXPRESS WEBHOOK RECEIVER + TRACKING ENDPOINTS
// =====================================================================

/**
 * Flash Webhook — receives all 5 callback types at one endpoint
 * PUBLIC endpoint — Flash signs with mchId + nonceStr
 * MUST return {"errorCode":"1","state":"success"} or Flash retries forever
 */
function b2b_rest_flash_webhook( WP_REST_Request $req ) {
    try {
    $body = $req->get_json_params();
    if ( empty( $body ) ) $body = $req->get_params();

    // BUG 4 FIX: Flash sends { mchId, nonceStr, sign, data: { pno, state, ... } }
    // Top-level: mchId, nonceStr, sign — actual payload is inside 'data'
    $mch_id    = isset( $body['mchId'] )    ? $body['mchId']    : '';
    $nonce_str = isset( $body['nonceStr'] ) ? $body['nonceStr'] : '';
    $sign      = isset( $body['sign'] )     ? $body['sign']     : '';

    // Extract nested data — Flash wraps all payload fields inside 'data'
    $data = isset( $body['data'] ) && is_array( $body['data'] ) ? $body['data'] : $body;
    // If data was sent as JSON string inside 'data' key, decode it
    if ( isset( $body['data'] ) && is_string( $body['data'] ) ) {
        $decoded = json_decode( $body['data'], true );
        if ( is_array( $decoded ) ) $data = $decoded;
    }

    $pno = isset( $data['pno'] ) ? sanitize_text_field( $data['pno'] ) : '';

    b2b_log( '[Flash WH] Received: pno=' . $pno . ' mchId=' . $mch_id );

    // V.31.5: Fail-safe verify — reject ถ้า function ไม่มี (ไม่ให้ bypass ถ้า S1 ไม่ load)
    if ( ! function_exists( 'b2b_flash_verify_webhook' ) ) {
        b2b_log( '[Flash WH] 🔴 REJECTED: verify function not available (S1 not loaded)' );
        return new WP_REST_Response( array( 'errorCode' => '0', 'message' => 'config_error' ), 500 );
    }
    if ( ! b2b_flash_verify_webhook( $mch_id, $nonce_str, $sign ) ) {
        b2b_log( '[Flash WH] 🔴 REJECTED: Signature mismatch — pno=' . $pno . ' mchId=' . $mch_id );
        return new WP_REST_Response( array( 'errorCode' => '0', 'message' => 'signature_mismatch' ), 403 );
    }

    // BUG 5 FIX: Detect webhook type by payload fields (Flash doesn't send 'code')
    // BUG 6 FIX: Courier webhook has no 'pno', uses ticketPickupId instead
    if ( isset( $data['ticketPickupId'] ) && empty( $pno ) ) {
        // Courier webhook (code 3) — no pno, find ticket by pickup ID
        $pickup_id = sanitize_text_field( $data['ticketPickupId'] );
        b2b_log( '[Flash WH] Courier webhook: pickupId=' . $pickup_id );
        $ticket_id = b2b_flash_find_ticket_by_pickup_id( $pickup_id );
        if ( $ticket_id ) {
            b2b_flash_wh_courier( $ticket_id, '', $data );
        } else {
            b2b_log( '[Flash WH] No ticket found for pickupId=' . $pickup_id );
        }
        return new WP_REST_Response( array( 'errorCode' => '1', 'state' => 'success' ) );
    }

    if ( ! $pno ) {
        b2b_log( '[Flash WH] No pno in payload' );
        return new WP_REST_Response( array( 'errorCode' => '1', 'state' => 'success' ) );
    }

    // Find ticket by pno
    $ticket_id = b2b_flash_find_ticket_by_pno( $pno );
    // V.32 FIX: Fallback to recentPno/origPno for relabeled parcels
    if ( ! $ticket_id && isset( $data['recentPno'] ) && $data['recentPno'] !== $pno ) {
        $ticket_id = b2b_flash_find_ticket_by_pno( sanitize_text_field( $data['recentPno'] ) );
    }
    if ( ! $ticket_id && isset( $data['origPno'] ) && $data['origPno'] !== $pno ) {
        $ticket_id = b2b_flash_find_ticket_by_pno( sanitize_text_field( $data['origPno'] ) );
    }
    if ( ! $ticket_id ) {
        // V.40.8: Fallback — check if this is a manual shipment PNO
        $manual_status = b2b_flash_manual_shipment_webhook( $pno, $data );
        if ( $manual_status ) {
            b2b_log( '[Flash WH] Manual shipment updated: pno=' . $pno . ' status=' . $manual_status );
        } else {
            b2b_log( '[Flash WH] No ticket found for pno=' . $pno );
        }
        return new WP_REST_Response( array( 'errorCode' => '1', 'state' => 'success' ) );
    }

    // Detect webhook type by payload fields (no 'code' field from Flash)
    if ( isset( $data['routedAction'] ) ) {
        // Routes webhook (code 4)
        b2b_flash_wh_routes( $ticket_id, $pno, $data );
    } elseif ( isset( $data['weightTime'] ) ) {
        // Weight webhook (code 1)
        b2b_flash_wh_weight( $ticket_id, $pno, $data );
    } elseif ( isset( $data['freightPrice'] ) || isset( $data['pricePolicy'] ) ) {
        // Price webhook (code 2)
        b2b_flash_wh_price( $ticket_id, $pno, $data );
    } else {
        // Status webhook (code 0) — default
        b2b_flash_wh_status( $ticket_id, $pno, $data );
    }

    return new WP_REST_Response( array( 'errorCode' => '1', 'state' => 'success' ) );
    } catch ( Exception $e ) {
        b2b_log('[FlashWebhook] Error: ' . $e->getMessage());
        return new WP_REST_Response( array( 'errorCode' => '1', 'state' => 'success' ) );
    }
}

/**
 * Find ticket ID by Flash pno (tracking number)
 */
function b2b_flash_find_ticket_by_pno( $pno ) {
    global $wpdb;
    // V.42.2 CRITICAL FIX C2: search BOTH primary and BO secondary PNO meta keys
    // BO fulfill stores PNOs in `_flash_tracking_numbers_bo` — webhook status
    // updates for BO PNOs were not matching any ticket → tracking stuck at 'created'
    $results = $wpdb->get_col( $wpdb->prepare(
        "SELECT post_id FROM {$wpdb->postmeta}
         WHERE meta_key IN ('_flash_tracking_numbers','_flash_tracking_numbers_bo')
         AND meta_value LIKE %s LIMIT 1",
        '%"' . $wpdb->esc_like( $pno ) . '"%'
    ) );
    return ! empty( $results ) ? intval( $results[0] ) : 0;
}

/**
 * Find ticket ID by Flash pickup ID (for courier webhooks that don't have pno)
 */
function b2b_flash_find_ticket_by_pickup_id( $pickup_id ) {
    global $wpdb;
    $results = $wpdb->get_col( $wpdb->prepare(
        "SELECT post_id FROM {$wpdb->postmeta} WHERE meta_key = '_flash_pickup_id' AND meta_value = %s LIMIT 1",
        $pickup_id
    ) );
    return ! empty( $results ) ? intval( $results[0] ) : 0;
}

/**
 * Append event to tracking events array
 */
function b2b_flash_append_event( $ticket_id, $event ) {
    $events = get_post_meta( $ticket_id, '_flash_tracking_events', true );
    if ( ! is_array( $events ) ) $events = array();
    $event['received_at'] = current_time( 'mysql' );
    $events[] = $event;
    // Keep max 100 events
    if ( count( $events ) > 100 ) $events = array_slice( $events, -100 );
    update_post_meta( $ticket_id, '_flash_tracking_events', $events );
    update_post_meta( $ticket_id, '_flash_last_tracked', current_time( 'mysql' ) );
}

/**
 * V.31: Shared helper — Check and store COD refund data from any webhook type
 */
function b2b_flash_check_cod_refunded( $ticket_id, $pno, $data ) {
    $codRefunded = isset( $data['codRefunded'] ) ? $data['codRefunded'] : '0';
    $codRefundedPno = isset( $data['codRefundedPno'] ) ? sanitize_text_field( $data['codRefundedPno'] ) : '';
    if ( $codRefunded === '1' || $codRefunded === 1 ) {
        $already = get_post_meta( $ticket_id, '_flash_cod_refunded', true );
        if ( ! $already ) {
            update_post_meta( $ticket_id, '_flash_cod_refunded', true );
            if ( $codRefundedPno ) update_post_meta( $ticket_id, '_flash_cod_refunded_pno', $codRefundedPno );
            b2b_log( '[Flash WH] ⚠ COD REFUNDED: pno=' . $pno . ' ticket=#' . $ticket_id );
            if ( function_exists( 'b2b_push_to_admin' ) ) {
                b2b_push_to_admin( '🔴 COD คืนเงิน: #' . $ticket_id . ' pno=' . $pno );
            }
        }
    }
}

/**
 * Status webhook (code 0): state 1-9, POD photos
 */
function b2b_flash_wh_status( $ticket_id, $pno, $data ) {
    $state = isset( $data['state'] ) ? intval( $data['state'] ) : 0;
    b2b_log( '[Flash WH] Status: pno=' . $pno . ' state=' . $state . ' ticket=#' . $ticket_id );

    $state_labels_fallback = array( 0=>'อัปเดตสถานะ', 1=>'รับพัสดุแล้ว', 2=>'ระหว่างขนส่ง', 3=>'กำลังนำส่ง', 4=>'คงคลัง', 5=>'เซ็นรับแล้ว', 6=>'มีปัญหา', 7=>'ตีกลับ', 8=>'ปิดงาน(ปัญหา)', 9=>'ยกเลิก' );
    $label = function_exists( 'b2b_flash_state_label' ) ? b2b_flash_state_label( $state ) : ( isset( $state_labels_fallback[$state] ) ? $state_labels_fallback[$state] : 'สถานะ ' . $state );

    // V.31: Store returned parcel info
    $returned = isset( $data['returned'] ) ? $data['returned'] : '0';
    $returnedPno = isset( $data['returnedPno'] ) ? sanitize_text_field( $data['returnedPno'] ) : '';
    $customaryPno = isset( $data['customaryPno'] ) ? sanitize_text_field( $data['customaryPno'] ) : '';
    if ( $returned === '1' || $returned === 1 ) {
        update_post_meta( $ticket_id, '_flash_returned', true );
        if ( $returnedPno ) update_post_meta( $ticket_id, '_flash_returned_pno', $returnedPno );
        if ( $customaryPno ) update_post_meta( $ticket_id, '_flash_customary_pno', $customaryPno );
    }

            // V.32 FIX: Index returnedPno for future webhook lookups
            if ( $returnedPno ) {
                $existing_pnos = get_post_meta( $ticket_id, '_flash_tracking_numbers', true );
                if ( is_array( $existing_pnos ) && ! in_array( $returnedPno, $existing_pnos, true ) ) {
                    $existing_pnos[] = $returnedPno;
                    update_post_meta( $ticket_id, '_flash_tracking_numbers', $existing_pnos );
                }
            }

    // V.31: Handle COD refund (🔴 critical field from Flash API)
    $codRefunded = isset( $data['codRefunded'] ) ? $data['codRefunded'] : '0';
    $codRefundedPno = isset( $data['codRefundedPno'] ) ? sanitize_text_field( $data['codRefundedPno'] ) : '';
    if ( $codRefunded === '1' || $codRefunded === 1 ) {
        update_post_meta( $ticket_id, '_flash_cod_refunded', true );
        if ( $codRefundedPno ) update_post_meta( $ticket_id, '_flash_cod_refunded_pno', $codRefundedPno );
        b2b_log( '[Flash WH] ⚠ COD REFUNDED: pno=' . $pno . ' refundedPno=' . $codRefundedPno . ' ticket=#' . $ticket_id );
        if ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '🔴 COD คืนเงิน: #' . $ticket_id . ' pno=' . $pno . ( $codRefundedPno ? ' refPno=' . $codRefundedPno : '' ) );
        }
    }

    // V.32 FIX: Store operationAddress and stateDate
    if ( isset( $data['operationAddress'] ) ) {
        update_post_meta( $ticket_id, '_flash_operation_address', sanitize_text_field( $data['operationAddress'] ) );
    }
    if ( isset( $data['stateDate'] ) ) {
        update_post_meta( $ticket_id, '_flash_state_date', sanitize_text_field( $data['stateDate'] ) );
    }

    // Map state to internal status
    $status_map = array( 1=>'picked_up', 2=>'in_transit', 3=>'delivering', 4=>'detained', 5=>'delivered', 6=>'problem', 7=>'returned', 8=>'closed', 9=>'cancelled' );
    $packing_map = array( 1=>'picked_up', 2=>'in_transit', 3=>'delivering', 4=>'detained', 5=>'delivered', 6=>'problem', 7=>'returned', 8=>'closed', 9=>'cancelled' );

    // V.36: Update per-PNO status + aggregate
    $pno_statuses = get_post_meta( $ticket_id, '_flash_pno_statuses', true );
    $is_multi_box = is_array( $pno_statuses ) && count( $pno_statuses ) > 1;

    if ( is_array( $pno_statuses ) && isset( $pno_statuses[ $pno ] ) && isset( $status_map[ $state ] ) ) {
        $pno_statuses[ $pno ]['status'] = $status_map[ $state ];
        update_post_meta( $ticket_id, '_flash_pno_statuses', $pno_statuses );
    }

    // V.36: Use aggregate status for ticket-level when multi-box
    if ( $is_multi_box && function_exists( 'b2b_flash_aggregate_status' ) ) {
        $agg = b2b_flash_aggregate_status( $pno_statuses );
        update_post_meta( $ticket_id, '_flash_status', $agg );
        update_post_meta( $ticket_id, '_flash_packing_status', $agg );
    } elseif ( isset( $status_map[ $state ] ) ) {
        update_post_meta( $ticket_id, '_flash_status', $status_map[ $state ] );
        update_post_meta( $ticket_id, '_flash_packing_status', $packing_map[ $state ] );
    }

    // V.36 helper: check if ALL active PNOs reached a given status
    $all_active_reached = false;
    if ( $is_multi_box && isset( $status_map[ $state ] ) ) {
        $target = $status_map[ $state ];
        $all_active_reached = true;
        foreach ( $pno_statuses as $_p => $_info ) {
            $_s = is_array( $_info ) ? ( isset( $_info['status'] ) ? $_info['status'] : 'created' ) : $_info;
            if ( $_s === 'cancelled' ) continue;
            if ( $_s !== $target ) { $all_active_reached = false; break; }
        }
    }

    // Count active boxes for display
    $active_box_count = 0;
    if ( is_array( $pno_statuses ) ) {
        foreach ( $pno_statuses as $_p => $_info ) {
            $_s = is_array( $_info ) ? ( isset( $_info['status'] ) ? $_info['status'] : 'created' ) : $_info;
            if ( $_s !== 'cancelled' ) $active_box_count++;
        }
    }
    $box_info = is_array( $pno_statuses ) && isset( $pno_statuses[ $pno ] ) ? $pno_statuses[ $pno ] : array();
    $box_label_str = isset( $box_info['box'] ) ? $box_info['box'] : '';
    $box_name_str = isset( $box_info['name'] ) ? $box_info['name'] : '';

    // Append event
    b2b_flash_append_event( $ticket_id, array(
        'type'    => 'status',
        'state'   => $state,
        'label'   => $label,
        'pno'     => $pno,
        'message' => isset( $data['message'] ) ? $data['message'] : '',
        'returned' => $returned,
        'codRefunded' => $codRefunded,
    ) );

    $sgid = get_field( 'source_group_id', $ticket_id );

    // Actions per state
    switch ( $state ) {
        case 1: // Picked up
            // V.36: Only set shipped + notify when ALL active PNOs picked up (or single box)
            if ( ! $is_multi_box || $all_active_reached ) {
                if ( function_exists( 'b2b_set_order_status' ) ) {
                    b2b_set_order_status( $ticket_id, 'shipped' );
                }
                // FIX A-1: set shipped_date + schedule delivery_check 3 วัน (เหมือน manual shipping)
                update_field( 'shipped_date', b2b_date( 'Y-m-d' ), $ticket_id );
                wp_schedule_single_event( time() + ( 3 * DAY_IN_SECONDS ), 'b2b_delivery_check_event', array( $ticket_id ) );
                if ( $sgid && function_exists( 'b2b_build_flex_flash_status' ) ) {
                    $msg = $is_multi_box ? 'Flash รับพัสดุแล้ว (' . $active_box_count . ' กล่อง)' : 'Flash รับพัสดุแล้ว';
                    // V.31.3: guaranteed push — retry on fail
                    if ( function_exists( 'b2b_push_guaranteed' ) ) {
                        b2b_push_guaranteed( $sgid, array( b2b_build_flex_flash_status( $ticket_id, 1, $msg ) ), $ticket_id, 'flash_picked_up' );
                    } else {
                        b2b_line_push_raw( $sgid, array( b2b_build_flex_flash_status( $ticket_id, 1, $msg ) ) );
                    }
                }
            }
            break;

        case 3: // Delivering — merge webhook data + saved courier info
            $wh_name  = isset($data['staffInfoName'])  ? $data['staffInfoName']  : '';
            $wh_phone = isset($data['staffInfoPhone']) ? $data['staffInfoPhone'] : '';
            $saved_courier = get_post_meta( $ticket_id, '_flash_courier_info', true ) ?: array();
            $delivery_staff = array(
                'name'  => !empty($wh_name)  ? $wh_name  : ( !empty($saved_courier['name'])  ? $saved_courier['name']  : '' ),
                'phone' => !empty($wh_phone) ? $wh_phone : ( !empty($saved_courier['phone']) ? $saved_courier['phone'] : '' ),
            );
            if ( !empty($wh_phone) || !empty($wh_name) ) {
                update_post_meta( $ticket_id, '_flash_courier_info', $delivery_staff );
            }
            // V.36: Always notify delivering (per-box info)
            if ( $sgid && function_exists( 'b2b_build_flex_flash_status' ) ) {
                $msg = $is_multi_box ? 'กำลังนำส่ง กล่อง ' . $box_label_str . ($box_name_str ? ': ' . $box_name_str : '') : 'กำลังนำส่ง';
                // V.31.3: guaranteed push — retry on fail
                if ( function_exists( 'b2b_push_guaranteed' ) ) {
                    b2b_push_guaranteed( $sgid, array( b2b_build_flex_flash_status( $ticket_id, 3, $msg, $delivery_staff ) ), $ticket_id, 'flash_delivering' );
                } else {
                    b2b_line_push_raw( $sgid, array( b2b_build_flex_flash_status( $ticket_id, 3, $msg, $delivery_staff ) ) );
                }
            }
            break;

        case 4: // Detained
            $reason = isset( $data['markerCategory'] ) ? $data['markerCategory'] : '';
            if ( function_exists( 'b2b_build_flex_flash_admin' ) ) {
                b2b_push_raw_to_admin( array( b2b_build_flex_flash_admin( $ticket_id, 'detained', array( 'reason' => $reason, 'pno' => $pno, 'box' => $box_label_str ) ) ) );
            }
            break;

        case 5: // Signed/Delivered
            $pod = array(
                'eSignature'               => isset( $data['eSignature'] )                    ? $data['eSignature']                    : '',
                'photo1'                   => isset( $data['photo']['photo1'] )                ? $data['photo']['photo1']                : '',
                'photo2'                   => isset( $data['photo']['photo2'] )                ? $data['photo']['photo2']                : '',
                'ticketDeliveryStaffLat'   => isset( $data['ticketDeliveryStaffLat'] )         ? $data['ticketDeliveryStaffLat']         : '',
                'ticketDeliveryStaffLng'   => isset( $data['ticketDeliveryStaffLng'] )         ? $data['ticketDeliveryStaffLng']         : '',
                'staffInfoId'              => isset( $data['staffInfoId'] )                    ? $data['staffInfoId']                    : '',
                'staffInfoPhone'           => isset( $data['staffInfoPhone'] )                 ? $data['staffInfoPhone']                 : '',
                'signer'                   => isset( $data['signer'] ) ? sanitize_text_field( $data['signer'] ) : '',
                'signerType'               => isset( $data['signerTypeText'] ) ? sanitize_text_field( $data['signerTypeText'] ) : '',
            );
            $pod = array_filter( $pod );
            if ( ! empty( $pod ) ) update_post_meta( $ticket_id, '_flash_pod_data', $pod );

            // V.31.5: Duplicate + race condition guard (webhook ซ้ำ หรือ webhook+cron พร้อมกัน)
            $existing_delivered_at = get_post_meta( $ticket_id, '_flash_delivered_at', true );
            $dlv_lock = 'b2b_flash_dlv_' . $ticket_id;

            // FIX A-7: ไม่ auto-complete ทันที — ส่ง Flex ให้ลูกค้ายืนยัน + schedule 24hr auto-complete
            if ( ( ! $is_multi_box || $all_active_reached ) && empty( $existing_delivered_at ) && ! get_transient( $dlv_lock ) ) {
                set_transient( $dlv_lock, 1, 60 );
                // ยังไม่เปลี่ยนเป็น completed — รอลูกค้ายืนยัน หรือ 24 ชม.
                update_post_meta( $ticket_id, '_flash_delivered_at', current_time( 'mysql' ) );
                // ส่ง Flex แจ้งลูกค้าว่าของถึง + ปุ่มยืนยัน
                if ( $sgid ) {
                    $msg = $is_multi_box ? 'พัสดุส่งถึงแล้ว (' . $active_box_count . ' กล่อง)' : 'พัสดุส่งถึงแล้ว';
                    $signer = isset( $pod['signer'] ) ? $pod['signer'] : '';
                    $signer_type = isset( $pod['signerType'] ) ? $pod['signerType'] : '';
                    $sign_text = $signer ? 'เซ็นรับโดย: ' . $signer . ( $signer_type ? ' (' . $signer_type . ')' : '' ) : '';
                    // สร้าง Flex พร้อมปุ่มยืนยันรับของ + ปุ่มแจ้งปัญหา
                    $body_contents = array(
                        array( 'type' => 'text', 'text' => '✅ ' . $msg, 'weight' => 'bold', 'size' => 'lg', 'color' => '#16a34a' ),
                        array( 'type' => 'text', 'text' => '#' . $ticket_id . ' — ' . ( get_field( 'dist_name', $ticket_id ) ?: '' ), 'size' => 'xs', 'color' => '#666' ),
                    );
                    if ( $sign_text ) $body_contents[] = array( 'type' => 'text', 'text' => $sign_text, 'size' => 'xs', 'color' => '#333', 'margin' => 'sm' );
                    $body_contents[] = array( 'type' => 'separator', 'margin' => 'lg' );
                    $body_contents[] = array( 'type' => 'text', 'text' => 'กรุณายืนยันรับสินค้าภายใน 24 ชม.', 'size' => 'xs', 'color' => '#92400e', 'margin' => 'md', 'wrap' => true );
                    $body_contents[] = array( 'type' => 'text', 'text' => 'หากไม่ยืนยัน ระบบจะปิดออเดอร์อัตโนมัติ', 'size' => 'xxs', 'color' => '#94a3b8', 'margin' => 'xs', 'wrap' => true );
                    $logo = function_exists( 'b2b_get_logo_url' ) ? b2b_get_logo_url() : '';
                    $header = array( 'type' => 'box', 'layout' => 'horizontal', 'backgroundColor' => '#16a34a', 'paddingAll' => '14px', 'contents' => array(
                        array( 'type' => 'image', 'url' => $logo ?: 'https://dinoco.in.th/wp-content/uploads/dinoco-logo.png', 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                        array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                            array( 'type' => 'text', 'text' => '📦 พัสดุส่งถึงแล้ว', 'color' => '#ffffff', 'size' => 'sm', 'weight' => 'bold' ),
                            array( 'type' => 'text', 'text' => 'Flash Express', 'color' => '#dcfce7', 'size' => 'xxs' )))));
                    $footer = array( 'type' => 'box', 'layout' => 'vertical', 'spacing' => 'sm', 'paddingAll' => '12px', 'contents' => array(
                        array( 'type' => 'button', 'style' => 'primary', 'height' => 'sm', 'color' => '#16a34a',
                            'action' => array( 'type' => 'postback', 'label' => '✅ ยืนยันรับสินค้า', 'data' => 'action=confirm_received&ticket_id=' . $ticket_id ) ),
                        array( 'type' => 'button', 'style' => 'link', 'height' => 'sm', 'color' => '#dc2626',
                            'action' => array( 'type' => 'postback', 'label' => '⚠️ สินค้ามีปัญหา', 'data' => 'action=delivery_no&ticket_id=' . $ticket_id ) ),
                    ));
                    $bubble = array( 'type' => 'bubble', 'header' => $header,
                        'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'spacing' => 'sm', 'contents' => $body_contents ),
                        'footer' => $footer );
                    $flex = array( 'type' => 'flex', 'altText' => '📦 พัสดุส่งถึงแล้ว #' . $ticket_id . ' — กรุณายืนยันรับสินค้า', 'contents' => $bubble );
                    // V.31.3: guaranteed push — retry on fail (critical: ตัวแทนต้องได้รับ Flex นี้เพื่อกดยืนยัน)
                    if ( function_exists( 'b2b_push_guaranteed' ) ) {
                        $push_ok = b2b_push_guaranteed( $sgid, array( $flex ), $ticket_id, 'flash_delivered' );
                    } else {
                        $result = b2b_line_push_raw( $sgid, array( $flex ) );
                        $push_ok = is_array( $result ) && isset( $result['code'] ) && $result['code'] === 200;
                    }
                }
                // V.31.4: Schedule 24hr auto-complete (ถ้าลูกค้าไม่กดยืนยัน) — ใช้ handler แยกที่รับ $ticket_id
                wp_schedule_single_event( time() + ( 24 * HOUR_IN_SECONDS ), 'b2b_flash_24hr_complete', array( $ticket_id ) );
                $push_status = isset( $push_ok ) ? ( $push_ok ? ' (push OK)' : ' (push queued retry)' ) : ' (no sgid)';
                b2b_add_audit_log( $ticket_id, 'flash_delivered', 'Flash: ส่งถึง — รอยืนยันรับ 24 ชม.' . $push_status );
            } else {
                b2b_add_audit_log( $ticket_id, 'flash_delivered_partial', 'Flash: กล่อง ' . $box_label_str . ' ส่งถึง (pno=' . $pno . ')' );
            }
            break;

        case 6: // Problem shipment
            $reason_code = isset( $data['markerCategory'] ) ? $data['markerCategory'] : '';
            $reason_text = function_exists( 'b2b_flash_marker_label' ) ? b2b_flash_marker_label( $reason_code ) : $reason_code;
            update_post_meta( $ticket_id, '_flash_marker_category', $reason_code );
            // V.36: Always notify problem immediately (per-box)
            if ( function_exists( 'b2b_push_to_admin' ) ) {
                $box_ctx = $is_multi_box ? ' กล่อง ' . $box_label_str : '';
                b2b_push_to_admin( '🔴 พัสดุมีปัญหา #' . $ticket_id . $box_ctx . ': ' . $reason_text );
            }
            if ( function_exists( 'b2b_build_flex_flash_admin' ) ) {
                $flex = b2b_build_flex_flash_admin( $ticket_id, 'problem', array( 'reason' => $reason_text, 'pno' => $pno, 'box' => $box_label_str ) );
                if ( $flex && function_exists( 'b2b_push_raw_to_admin' ) ) {
                    b2b_push_raw_to_admin( array( $flex ) );
                }
            }
            break;

        case 7: // Returned — always notify immediately
            $reason = isset( $data['cancelReason'] ) ? $data['cancelReason'] : ( isset( $data['markerCategory'] ) ? $data['markerCategory'] : '' );
            if ( function_exists( 'b2b_build_flex_flash_admin' ) ) {
                b2b_push_raw_to_admin( array( b2b_build_flex_flash_admin( $ticket_id, 'returned', array( 'reason' => $reason, 'pno' => $pno, 'box' => $box_label_str ) ) ) );
            }
            break;

        case 8: // Closed (problem resolved)
            // FIX A-4: handle state=8 — Flash ปิดงาน(ปัญหา) resolved
            if ( function_exists( 'b2b_push_to_admin' ) ) {
                $box_ctx = $is_multi_box ? ' กล่อง ' . $box_label_str : '';
                b2b_push_to_admin( '🔵 Flash ปิดงาน (ปัญหา resolved) #' . $ticket_id . $box_ctx );
            }
            b2b_add_audit_log( $ticket_id, 'flash_closed', 'Flash: ปิดงาน (ปัญหา resolved) pno=' . $pno );
            break;

        case 9: // Cancelled
            if ( function_exists( 'b2b_build_flex_flash_admin' ) ) {
                b2b_push_raw_to_admin( array( b2b_build_flex_flash_admin( $ticket_id, 'cancelled', array( 'pno' => $pno, 'box' => $box_label_str ) ) ) );
            }
            break;
    }
}

/**
 * Weight webhook (code 1)
 */
function b2b_flash_wh_weight( $ticket_id, $pno, $data ) {
    b2b_log( '[Flash WH] Weight: pno=' . $pno . ' ticket=#' . $ticket_id );
    $w = array(
        'weight' => isset( $data['weight'] ) ? $data['weight'] : '',
        'length' => isset( $data['length'] ) ? $data['length'] : '',
        'width'  => isset( $data['width'] )  ? $data['width']  : '',
        'height' => isset( $data['height'] ) ? $data['height'] : '',
        'price'  => isset( $data['price'] )  ? $data['price']  : '',
        'weightTime' => isset( $data['weightTime'] ) ? $data['weightTime'] : '',
    );
    update_post_meta( $ticket_id, '_flash_actual_weight', $w );
    // V.31: Track COD refund from weight webhook
    b2b_flash_check_cod_refunded( $ticket_id, $pno, $data );
    b2b_flash_append_event( $ticket_id, array( 'type' => 'weight', 'pno' => $pno, 'data' => $w ) );
}

/**
 * Price webhook (code 2)
 */
function b2b_flash_wh_price( $ticket_id, $pno, $data ) {
    b2b_log( '[Flash WH] Price: pno=' . $pno . ' ticket=#' . $ticket_id );
    $p = array(
        'freight'           => isset( $data['freightPrice'] )       ? $data['freightPrice']       : 0,
        'codFee'            => isset( $data['codFee'] )             ? $data['codFee']             : 0,
        'codAmount'         => isset( $data['codAmount'] )          ? $data['codAmount']          : 0,
        'remoteArea'        => isset( $data['remoteAreaFee'] )      ? $data['remoteAreaFee']      : 0,
        'insureFee'         => isset( $data['opdInsureFee'] )       ? $data['opdInsureFee']       : 0,
        'valueInsuranceFee' => isset( $data['valueInsuranceFee'] )  ? $data['valueInsuranceFee']  : 0,
        'packagingFee'      => isset( $data['packagingFee'] )       ? $data['packagingFee']       : 0,
        'labelFee'          => isset( $data['labelFee'] )           ? $data['labelFee']           : 0,
        'speedFee'          => isset( $data['speedFee'] )           ? $data['speedFee']           : 0,
        'expressCategory'   => isset( $data['expressCategory'] )    ? $data['expressCategory']    : '',
        'pricePolicy'       => isset( $data['pricePolicy'] )        ? $data['pricePolicy']        : '',
        'pricePolicyText'   => isset( $data['pricePolicyText'] )    ? $data['pricePolicyText']    : '',
        'declaredValue'     => isset( $data['declaredValue'] )      ? $data['declaredValue']      : 0,
        'priceAt'           => isset( $data['priceAt'] )            ? $data['priceAt']            : '',
        'chargableWeight'   => isset( $data['chargableWeight'] )    ? $data['chargableWeight']    : '',
        'chargableLength'   => isset( $data['chargableLength'] )    ? $data['chargableLength']    : '',
        'chargableWidth'    => isset( $data['chargableWidth'] )     ? $data['chargableWidth']     : '',
        'chargableHeight'   => isset( $data['chargableHeight'] )    ? $data['chargableHeight']    : '',
        'settlementType'    => isset( $data['settlementType'] )    ? $data['settlementType']    : '',
        'freightInsurance'  => isset( $data['freightInsurance'] )  ? $data['freightInsurance']  : 0,
    );
    update_post_meta( $ticket_id, '_flash_shipping_cost', $p );
    // V.31: Track COD refund from price webhook
    b2b_flash_check_cod_refunded( $ticket_id, $pno, $data );
    b2b_flash_append_event( $ticket_id, array( 'type' => 'price', 'pno' => $pno, 'data' => $p ) );
}

/**
 * Courier webhook (code 3)
 */
function b2b_flash_wh_courier( $ticket_id, $pno, $data ) {
    // BUG 6 FIX: Flash sends 'state' (not pickupState), 'staffInfoName' (not staffName), 'staffInfoPhone' (not staffPhone)
    $pickup_state = isset( $data['state'] ) ? intval( $data['state'] ) : -1;
    $pickup_id = isset( $data['ticketPickupId'] ) ? $data['ticketPickupId'] : '';
    $current_pickup_id = isset( $data['currentTicketPickupId'] ) ? $data['currentTicketPickupId'] : '';
    b2b_log( '[Flash WH] Courier: pickupId=' . $pickup_id . ' state=' . $pickup_state . ' ticket=#' . $ticket_id );
    if ( empty( $data['staffInfoName'] ) ) {
        b2b_log( '[Flash WH] ⚠ Missing staffInfoName in courier webhook, keys: ' . implode( ',', array_keys( $data ) ) );
    }
    $info = array(
        'name'              => isset( $data['staffInfoName'] )  ? $data['staffInfoName']  : '',
        'phone'             => isset( $data['staffInfoPhone'] ) ? $data['staffInfoPhone'] : '',
        'state'             => $pickup_state,
        'pickupId'          => $pickup_id,
        'currentPickupId'   => $current_pickup_id,
        'storeName'         => isset( $data['storeName'] )      ? $data['storeName']      : '',
        'estimateParcelNum' => isset( $data['estimateParcelNumber'] ) ? $data['estimateParcelNumber'] : '',
    );

    // ── V.35: Handle each courier state ──
    if ( $pickup_state === 2 ) {
        // state=2: รับพัสดุแล้ว → update ALL orders in this pickup + send customer Flex
        b2b_log( '[Flash WH] ✅ Courier PICKED UP: ticket=#' . $ticket_id );
        // Find all orders sharing this pickup
        $all_tids = b2b_flash_find_all_tickets_by_pickup_id( $current_pickup_id ?: $pickup_id );
        foreach ( $all_tids as $otid ) {
            update_post_meta( $otid, '_flash_packing_status', 'picked_up' );
            update_post_meta( $otid, '_flash_courier_info', $info );
            // V.31.5: Duplicate guard — ถ้าแจ้ง pickup ไปแล้ว ไม่ส่ง Flex ซ้ำ
            if ( get_post_meta( $otid, '_flash_pickup_notified', true ) ) continue;
            update_post_meta( $otid, '_flash_pickup_notified', 1 );
            // Send customer Flex (tracking + status)
            $sgid = get_field( 'source_group_id', $otid );
            $tracking = get_field( 'tracking_number', $otid ) ?: '';
            if ( $sgid && function_exists( 'b2b_build_flex_flash_status' ) ) {
                $ci = array( 'name' => $info['name'], 'phone' => $info['phone'] );
                $flex = b2b_build_flex_flash_status( $otid, 1, 'Flash รับพัสดุแล้ว — tracking: ' . $tracking, $ci );
                // V.31.4: guaranteed push — retry on fail
                if ( function_exists( 'b2b_push_guaranteed' ) ) {
                    b2b_push_guaranteed( $sgid, array( $flex ), $otid, 'flash_courier_picked_up' );
                } else {
                    b2b_line_push_raw( $sgid, array( $flex ) );
                }
            }
        }
        // Admin text
        if ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '✅ Flash รับพัสดุแล้ว (' . count( $all_tids ) . ' orders) — ' . $info['name'] );
        }
        // Clear active pickup transient (pickup is done)
        delete_transient( 'b2b_flash_active_pickup' );

    } elseif ( $pickup_state === 4 ) {
        // state=4: คูเรียร์ยกเลิก → notify admin + auto re-call
        $info['cancelReasonCode'] = isset( $data['cancelReasonCode'] ) ? $data['cancelReasonCode'] : '';
        $info['cancelReasonText'] = isset( $data['cancelReasonText'] ) ? $data['cancelReasonText'] : '';
        $info['cancelOperatorId'] = isset( $data['cancelOperatorId'] ) ? $data['cancelOperatorId'] : '';
        b2b_log( '[Flash WH] ⚠ Courier CANCELLED: reason=' . $info['cancelReasonText'] . ' ticket=#' . $ticket_id );

        // Clear active pickup transient (it's been cancelled)
        delete_transient( 'b2b_flash_active_pickup' );

        // Reset all orders in this pickup back to ready_to_ship
        $all_tids = b2b_flash_find_all_tickets_by_pickup_id( $current_pickup_id ?: $pickup_id );
        $total_parcels = 0;
        foreach ( $all_tids as $otid ) {
            update_post_meta( $otid, '_flash_packing_status', 'ready_to_ship' );
            delete_post_meta( $otid, '_flash_pickup_id' );
            $opnos = get_post_meta( $otid, '_flash_tracking_numbers', true );
            $total_parcels += is_array( $opnos ) ? count( $opnos ) : 1;
        }

        // Auto re-call courier (schedule immediate retry via cron)
        $reason = $info['cancelReasonText'] ?: 'ไม่ระบุเหตุผล';
        if ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '⚠ คูเรียร์ยกเลิกงานรับ: ' . $reason . ' — ระบบกำลังเรียกรถใหม่อัตโนมัติ (' . count( $all_tids ) . ' orders)' );
        }
        // Use the first ticket to trigger re-call
        if ( ! empty( $all_tids ) ) {
            wp_schedule_single_event( time() + 10, 'b2b_flash_courier_retry', array( $all_tids[0] ) );
            b2b_log( '[Flash WH] Auto re-call scheduled after courier cancellation' );
        }

    } elseif ( $pickup_state === 3 ) {
        // state=3: โอนงาน (courier changed) → update info
        b2b_log( '[Flash WH] Courier TRANSFERRED: new courier=' . $info['name'] . ' ticket=#' . $ticket_id );
        // Update transient with new courier info
        $active = get_transient( 'b2b_flash_active_pickup' );
        if ( is_array( $active ) ) {
            $active['staff_name']  = $info['name'];
            $active['staff_phone'] = $info['phone'];
            set_transient( 'b2b_flash_active_pickup', $active, 4 * HOUR_IN_SECONDS );
        }
        if ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '🔄 Flash โอนงานรับ — คูเรียร์ใหม่: ' . $info['name'] . ' ' . $info['phone'] );
        }

    } elseif ( $pickup_state === 1 ) {
        // state=1: รอรับพัสดุ (courier assigned) — FIX S-8: ส่ง Flex card แจ้งข้อมูลคูเรียร์
        b2b_log( '[Flash WH] 🚛 Courier ASSIGNED: ' . $info['name'] . ' ' . $info['phone'] . ' ticket=#' . $ticket_id );
        // อัพเดทข้อมูลคูเรียร์ให้ทุก ticket ใน pickup นี้
        $all_tids = b2b_flash_find_all_tickets_by_pickup_id( $current_pickup_id ?: $pickup_id );
        foreach ( $all_tids as $otid ) {
            update_post_meta( $otid, '_flash_courier_info', $info );
        }
        // ส่ง Flex card แจ้ง admin
        if ( function_exists( 'b2b_build_flex_courier_pickup' ) && function_exists( 'b2b_push_raw_to_admin' ) ) {
            $pickup_info = array(
                'staff_name'   => $info['name'],
                'staff_phone'  => $info['phone'],
                'pickup_id'    => $pickup_id,
                'parcel_count' => $info['estimateParcelNum'] ?: count( $all_tids ),
                'ticket_ids'   => $all_tids,
            );
            $flex = b2b_build_flex_courier_pickup( $pickup_info );
            b2b_push_raw_to_admin( array( $flex ) );
        } elseif ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin( '🚛 คูเรียร์ ' . $info['name'] . ' (' . $info['phone'] . ') กำลังมารับพัสดุ' );
        }
    }

    update_post_meta( $ticket_id, '_flash_courier_info', $info );
    // Save pickup ID for future courier webhook lookups (use current if transferred)
    $save_pickup_id = $current_pickup_id ?: $pickup_id;
    if ( $save_pickup_id ) {
        update_post_meta( $ticket_id, '_flash_pickup_id', $save_pickup_id );
    }
    b2b_flash_append_event( $ticket_id, array( 'type' => 'courier', 'pno' => $pno, 'state' => $pickup_state, 'data' => $info ) );
}

/**
 * V.35: Find ALL tickets sharing a pickup ID (not just LIMIT 1)
 */
function b2b_flash_find_all_tickets_by_pickup_id( $pickup_id ) {
    if ( ! $pickup_id ) return array();
    global $wpdb;
    return array_map( 'intval', $wpdb->get_col( $wpdb->prepare(
        "SELECT post_id FROM {$wpdb->postmeta} WHERE meta_key = '_flash_pickup_id' AND meta_value = %s",
        $pickup_id
    ) ) );
}

/**
 * Routes webhook (code 4)
 */
function b2b_flash_wh_routes( $ticket_id, $pno, $data ) {
    $action = isset( $data['routedAction'] ) ? $data['routedAction'] : '';
    $state  = isset( $data['state'] ) ? intval( $data['state'] ) : 0;
    b2b_log( '[Flash WH] Routes: pno=' . $pno . ' action=' . $action . ' state=' . $state . ' ticket=#' . $ticket_id );
    $label = function_exists( 'b2b_flash_route_label' ) ? b2b_flash_route_label( $action ) : $action;

    // V.31: Sync order status from routes webhook (same as status webhook)
    $status_map = array( 1=>'picked_up', 2=>'in_transit', 3=>'delivering', 4=>'detained', 5=>'delivered', 6=>'problem', 7=>'returned', 8=>'closed', 9=>'cancelled' );

    // V.36: Update per-PNO status from routes webhook
    $pno_statuses = get_post_meta( $ticket_id, '_flash_pno_statuses', true );
    if ( is_array( $pno_statuses ) && isset( $pno_statuses[ $pno ] ) && $state > 0 && isset( $status_map[ $state ] ) ) {
        $pno_statuses[ $pno ]['status'] = $status_map[ $state ];
        update_post_meta( $ticket_id, '_flash_pno_statuses', $pno_statuses );
    }

    if ( $state > 0 && isset( $status_map[ $state ] ) ) {
        // V.36: Use aggregate for multi-box tickets
        if ( is_array( $pno_statuses ) && count( $pno_statuses ) > 1 && function_exists( 'b2b_flash_aggregate_status' ) ) {
            $agg = b2b_flash_aggregate_status( $pno_statuses );
            update_post_meta( $ticket_id, '_flash_status', $agg );
            update_post_meta( $ticket_id, '_flash_packing_status', $agg );
        } else {
            $current = get_post_meta( $ticket_id, '_flash_status', true );
            $terminal = array( 'delivered', 'returned', 'closed', 'cancelled' );
            if ( ! in_array( $current, $terminal, true ) || $state >= 5 ) {
                update_post_meta( $ticket_id, '_flash_status', $status_map[ $state ] );
                update_post_meta( $ticket_id, '_flash_packing_status', $status_map[ $state ] );
            }
        }
    }

    // V.31: Track returned + COD refund from routes webhook
    $returned = isset( $data['returned'] ) ? $data['returned'] : '0';
    if ( $returned === '1' || $returned === 1 || $returned === true ) {
        update_post_meta( $ticket_id, '_flash_returned', true );
        if ( isset( $data['returnedPno'] ) && $data['returnedPno'] ) {
            update_post_meta( $ticket_id, '_flash_returned_pno', sanitize_text_field( $data['returnedPno'] ) );
            // V.32 FIX: Index returnedPno for future webhook lookups
            $existing_pnos = get_post_meta( $ticket_id, '_flash_tracking_numbers', true );
            if ( is_array( $existing_pnos ) && ! in_array( $data['returnedPno'], $existing_pnos, true ) ) {
                $existing_pnos[] = sanitize_text_field( $data['returnedPno'] );
                update_post_meta( $ticket_id, '_flash_tracking_numbers', $existing_pnos );
            }
        }
        if ( isset( $data['customaryPno'] ) && $data['customaryPno'] ) {
            update_post_meta( $ticket_id, '_flash_customary_pno', sanitize_text_field( $data['customaryPno'] ) );
        }
    }
    b2b_flash_check_cod_refunded( $ticket_id, $pno, $data );

    b2b_flash_append_event( $ticket_id, array(
        'type'     => 'routes',
        'pno'      => $pno,
        'state'    => $state,
        'action'   => $action,
        'label'    => $label,
        'message'  => isset( $data['message'] )         ? sanitize_text_field( $data['message'] )         : '',
        'province' => isset( $data['currentProvince'] ) ? sanitize_text_field( $data['currentProvince'] ) : '',
        'routedAt' => isset( $data['routedAt'] )        ? sanitize_text_field( $data['routedAt'] )        : '',
    ) );

    // V.31.5: ถ้า routes webhook state=5 (delivered) → schedule 24hr เหมือน status webhook
    if ( $state === 5 ) {
        $delivered_at = get_post_meta( $ticket_id, '_flash_delivered_at', true );
        if ( empty( $delivered_at ) ) {
            update_post_meta( $ticket_id, '_flash_delivered_at', current_time( 'mysql' ) );
            $sgid = get_field( 'source_group_id', $ticket_id );
            if ( $sgid && function_exists( 'b2b_build_flex_flash_status' ) ) {
                $flex = b2b_build_flex_flash_status( $ticket_id, 5, 'พัสดุส่งถึงแล้ว (ตรวจพบจาก Routes)' );
                if ( function_exists( 'b2b_push_guaranteed' ) ) {
                    b2b_push_guaranteed( $sgid, array( $flex ), $ticket_id, 'flash_delivered_routes' );
                } else {
                    b2b_line_push_raw( $sgid, array( $flex ) );
                }
            }
            wp_schedule_single_event( time() + ( 24 * HOUR_IN_SECONDS ), 'b2b_flash_24hr_complete', array( $ticket_id ) );
            b2b_add_audit_log( $ticket_id, 'flash_delivered_routes', 'Flash Routes: ส่งถึง — รอยืนยันรับ 24 ชม.' );
        }
    }
}

/**
 * GET Flash tracking events for a ticket
 */
function b2b_rest_flash_tracking( WP_REST_Request $req ) {
    $tid = intval( $req->get_param( 'ticket_id' ) );
    if ( ! $tid || get_post_type( $tid ) !== 'b2b_order' ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Invalid ticket' ), 400 );
    }

    // V.24: ?refresh=1 → เรียก Flash API real-time แล้ว update cache
    // V.36: Loop ALL PNOs instead of just the first one
    $refresh = $req->get_param( 'refresh' );
    if ( $refresh && function_exists('b2b_flash_get_routes') ) {
        $pnos = get_post_meta( $tid, '_flash_tracking_numbers', true ) ?: array();
        $tracking = get_field( 'tracking_number', $tid ) ?: '';
        if ( empty( $pnos ) && $tracking ) $pnos = array( $tracking );

        $all_events = array();
        $pno_statuses = get_post_meta( $tid, '_flash_pno_statuses', true );
        $state_to_packing = array( 1=>'picked_up', 2=>'in_transit', 3=>'delivering', 4=>'detained', 5=>'delivered', 6=>'problem', 7=>'returned', 8=>'closed', 9=>'cancelled' );
        $latest_state = 0;

        foreach ( $pnos as $pno ) {
            $result = b2b_flash_get_routes( $pno );
            if ( empty($result['data']) ) continue;
            $d = $result['data'];

            // Collect routes events with PNO tag
            if ( !empty($d['routes']) && is_array($d['routes']) ) {
                foreach ( $d['routes'] as $r ) {
                    $all_events[] = array(
                        'state'       => $r['state'] ?? 0,
                        'action'      => $r['routeAction'] ?? '',
                        'message'     => $r['message'] ?? '',
                        'pno'         => $pno,
                        'timestamp'   => isset($r['routedAt']) ? gmdate('Y-m-d H:i:s', intval($r['routedAt'])) : '',
                        'received_at' => isset($r['routedAt']) ? gmdate('Y-m-d H:i:s', intval($r['routedAt'])) : '',
                    );
                }
            }

            // V.36: Update per-PNO status
            if ( isset($d['state']) && is_array($pno_statuses) && isset($pno_statuses[$pno]) ) {
                $pno_statuses[$pno]['status'] = isset($state_to_packing[$d['state']]) ? $state_to_packing[$d['state']] : $pno_statuses[$pno]['status'];
            }
            if ( isset($d['state']) && intval($d['state']) > $latest_state ) $latest_state = intval($d['state']);
        }

        // Save merged events
        if ( ! empty( $all_events ) ) {
            update_post_meta( $tid, '_flash_tracking_events', $all_events );
        }

        // V.36: Save per-PNO statuses + aggregate
        if ( is_array( $pno_statuses ) ) {
            update_post_meta( $tid, '_flash_pno_statuses', $pno_statuses );
            if ( count( $pno_statuses ) > 1 && function_exists( 'b2b_flash_aggregate_status' ) ) {
                $agg = b2b_flash_aggregate_status( $pno_statuses );
                update_post_meta( $tid, '_flash_status', $agg );
                update_post_meta( $tid, '_flash_packing_status', $agg );
            } elseif ( $latest_state > 0 && isset( $state_to_packing[ $latest_state ] ) ) {
                update_post_meta( $tid, '_flash_status', $state_to_packing[ $latest_state ] );
                update_post_meta( $tid, '_flash_packing_status', $state_to_packing[ $latest_state ] );
            }
        } elseif ( $latest_state > 0 && isset( $state_to_packing[ $latest_state ] ) ) {
            update_post_meta( $tid, '_flash_status', $state_to_packing[ $latest_state ] );
            update_post_meta( $tid, '_flash_packing_status', $state_to_packing[ $latest_state ] );
        }

        // V.31.5: ถ้า delivered → schedule 24hr auto-complete (ไม่ complete ทันที)
        $agg_final = is_array($pno_statuses) && function_exists('b2b_flash_aggregate_status') ? b2b_flash_aggregate_status($pno_statuses) : ( isset($state_to_packing[$latest_state]) ? $state_to_packing[$latest_state] : '' );
        if ( $agg_final === 'delivered' ) {
            $cur = get_field('order_status', $tid);
            $delivered_at = get_post_meta( $tid, '_flash_delivered_at', true );
            if ( in_array($cur, array('shipped','packed'), true) && empty($delivered_at) ) {
                update_post_meta( $tid, '_flash_delivered_at', current_time('mysql') );
                wp_schedule_single_event( time() + ( 24 * HOUR_IN_SECONDS ), 'b2b_flash_24hr_complete', array( $tid ) );
                b2b_add_audit_log( $tid, 'flash_delivered_refresh', 'Flash Tracking refresh: ส่งถึง — schedule 24hr auto-complete' );
            }
        }

        update_post_meta( $tid, '_flash_last_tracked', current_time( 'mysql' ) );
    }

    $events  = get_post_meta( $tid, '_flash_tracking_events', true ) ?: array();
    $status  = get_post_meta( $tid, '_flash_status', true ) ?: '';
    $packing = get_post_meta( $tid, '_flash_packing_status', true ) ?: '';
    $pnos    = get_post_meta( $tid, '_flash_tracking_numbers', true ) ?: array();
    $courier = get_post_meta( $tid, '_flash_courier_info', true ) ?: array();
    $pod     = get_post_meta( $tid, '_flash_pod_data', true ) ?: array();
    $weight  = get_post_meta( $tid, '_flash_actual_weight', true ) ?: array();
    $cost    = get_post_meta( $tid, '_flash_shipping_cost', true ) ?: array();
    $last_tracked = get_post_meta( $tid, '_flash_last_tracked', true ) ?: '';

    // V.36: Include per-PNO statuses in response
    $pno_statuses_resp = get_post_meta( $tid, '_flash_pno_statuses', true ) ?: array();

    return new WP_REST_Response( array(
        'success'       => true,
        'status'        => $status,
        'status_text'   => get_post_meta( $tid, '_flash_state_text', true ) ?: '',
        'packing'       => $packing,
        'pnos'          => $pnos,
        'pno_statuses'  => $pno_statuses_resp,
        'events'        => array_reverse( $events ),
        'courier'       => $courier,
        'pod'           => $pod,
        'weight'        => $weight,
        'cost'          => $cost,
        'last_tracked'  => $last_tracked,
    ) );
}

/**
 * GET Flash dashboard stats (for LIFF)
 */
function b2b_rest_flash_dashboard_stats( WP_REST_Request $req ) {
    global $wpdb;
    $counts = $wpdb->get_results(
        "SELECT meta_value AS status, COUNT(*) AS cnt FROM {$wpdb->postmeta}
         WHERE meta_key = '_flash_packing_status' AND meta_value != '' AND meta_value != 'none'
         GROUP BY meta_value",
        OBJECT_K
    );
    $stats = array();
    foreach ( $counts as $s => $row ) {
        $stats[ $s ] = intval( $row->cnt );
    }
    // Today's shipping cost total
    $today = current_time( 'Y-m-d' );
    $today_cost = $wpdb->get_var( $wpdb->prepare(
        "SELECT SUM(CAST(JSON_EXTRACT(pm.meta_value, '$.total') AS DECIMAL(10,2)))
         FROM {$wpdb->postmeta} pm
         JOIN {$wpdb->postmeta} pm2 ON pm.post_id = pm2.post_id AND pm2.meta_key = '_flash_last_tracked'
         WHERE pm.meta_key = '_flash_shipping_cost' AND pm2.meta_value LIKE %s",
        $today . '%'
    ) );
    $stats['today_cost'] = floatval( $today_cost );
    return new WP_REST_Response( array( 'success' => true, 'stats' => $stats ) );
}

// ═══════════════════════════════════════════════════
// Async Slip Verification Handler
// ═══════════════════════════════════════════════════
add_action('b2b_verify_slip_async', function($tid, $filepath) {
    if ( !defined('B2B_SLIP2GO_SECRET_KEY') ) return;

    $api_url = defined('B2B_SLIP2GO_API_URL')
        ? B2B_SLIP2GO_API_URL
        : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';

    $decoded = file_get_contents($filepath);
    if ( !$decoded ) {
        update_field('slip_status', 'error', $tid);
        b2b_log('[Slip Async] Cannot read file for ticket #' . $tid);
        return;
    }

    $finfo = new finfo(FILEINFO_MIME_TYPE);
    $mime = $finfo->buffer($decoded);

    $check_condition = array('checkDuplicate' => true);
    $bank_info = function_exists('b2b_get_bank_info') ? b2b_get_bank_info() : null;
    if ( $bank_info && !empty($bank_info['account']) ) {
        $account_number = preg_replace('/[^0-9]/', '', $bank_info['account']);
        $receiver = array('accountNumber' => $account_number);
        if ( !empty($bank_info['bank_code']) ) {
            $receiver['accountType'] = '01' . str_pad($bank_info['bank_code'], 3, '0', STR_PAD_LEFT);
        }
        $receivers = array($receiver);
        // V.38.6: Walk-in bank — accept both regular and walk-in bank accounts
        if ( defined('B2B_WALKIN_BANK_ACCOUNT') && B2B_WALKIN_BANK_ACCOUNT ) {
            $walkin_acct = preg_replace('/[^0-9]/', '', B2B_WALKIN_BANK_ACCOUNT);
            if ( $walkin_acct !== $account_number ) {
                $walkin_receiver = array('accountNumber' => $walkin_acct);
                $walkin_code = defined('B2B_WALKIN_BANK_CODE') ? B2B_WALKIN_BANK_CODE : (defined('B2B_BANK_CODE') ? B2B_BANK_CODE : '');
                if ( !empty($walkin_code) ) {
                    $walkin_receiver['accountType'] = '01' . str_pad($walkin_code, 3, '0', STR_PAD_LEFT);
                }
                $receivers[] = $walkin_receiver;
            }
        }
        $check_condition['checkReceiver'] = $receivers;
    }

    $slip_response = wp_remote_post($api_url, array(
        'headers' => array('Authorization'=>'Bearer '.B2B_SLIP2GO_SECRET_KEY,'Content-Type'=>'application/json'),
        'body' => wp_json_encode(array('payload'=>array(
            'imageBase64'    => 'data:'.$mime.';base64,' . base64_encode($decoded),
            'checkCondition' => $check_condition,
        ))),
        'timeout' => 45,
    ));

    if ( is_wp_error($slip_response) ) {
        update_field('slip_status', 'error', $tid);
        b2b_log('[Slip Async] API error for ticket #' . $tid . ': ' . $slip_response->get_error_message());
        return;
    }

    $slip_result = null;
    if ( wp_remote_retrieve_response_code($slip_response) === 200 ) {
        $slip_result = json_decode(wp_remote_retrieve_body($slip_response), true);
    }

    if ( $slip_result && isset($slip_result['data']) ) {
        update_field('slip_status', 'verified', $tid);
        update_field('slip_verify_result', wp_json_encode($slip_result), $tid);
        // Notify admin with verification result
        $group_id = get_field('source_group_id', $tid);
        $dist = $group_id ? b2b_get_dist_by_group($group_id) : null;
        $dist_name = $dist ? get_the_title($dist->ID) : 'Unknown';
        $admin_msg = "✅ สลิปตรวจแล้ว Ticket #" . $tid . " (" . $dist_name . ")";
        if ( isset($slip_result['data']['amount']) ) {
            $admin_msg .= "\nยอด: ฿" . number_format(floatval($slip_result['data']['amount']), 2);
        }
        if ( function_exists('b2b_push_to_admin') ) b2b_push_to_admin($admin_msg);
    } else {
        update_field('slip_status', 'rejected', $tid);
        b2b_log('[Slip Async] Verification failed for ticket #' . $tid);
        if ( function_exists('b2b_push_to_admin') ) {
            b2b_push_to_admin('⚠ สลิปตรวจไม่ผ่าน Ticket #' . $tid);
        }
    }

    // Notify customer about verification result
    $slip_status = get_field('slip_status', $tid);
    $cust_group_id = get_field('source_group_id', $tid);
    if ($cust_group_id) {
        if ($slip_status === 'verified') {
            $msg = "✅ สลิปออเดอร์ #{$tid} ตรวจสอบผ่านแล้ว\nกำลังดำเนินการต่อ";
        } else {
            $msg = "❌ สลิปออเดอร์ #{$tid} ตรวจสอบไม่ผ่าน\nกรุณาอัพโหลดสลิปใหม่อีกครั้ง";
        }
        b2b_line_push($cust_group_id, $msg);
    }
}, 10, 2);

// ═══════════════════════════════════════════════════════════════
// V.38: Manual Flash Shipping — สร้างพัสดุ Flash โดยไม่ต้องมี B2B order
// เก็บข้อมูลใน wp_option `b2b_manual_shipments` (JSON array)
// ═══════════════════════════════════════════════════════════════

function b2b_rest_manual_flash_create( WP_REST_Request $r ) {
    try {
        if ( ! defined( 'B2B_FLASH_MCH_ID' ) || ! defined( 'B2B_FLASH_SECRET_KEY' ) || ! defined( 'B2B_FLASH_API_URL' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Flash ยังไม่ตั้งค่า' ), 400 );
        }

        // Validate required fields
        $dst_name     = sanitize_text_field( $r->get_param( 'dst_name' ) );
        $dst_phone    = sanitize_text_field( $r->get_param( 'dst_phone' ) );
        $dst_address  = sanitize_text_field( $r->get_param( 'dst_address' ) );
        $dst_district = sanitize_text_field( $r->get_param( 'dst_district' ) );
        $dst_city     = sanitize_text_field( $r->get_param( 'dst_city' ) );
        $dst_province = sanitize_text_field( $r->get_param( 'dst_province' ) );
        $dst_postcode = sanitize_text_field( $r->get_param( 'dst_postcode' ) );
        $item_desc    = sanitize_text_field( $r->get_param( 'item_desc' ) ) ?: 'DINOCO Products';
        // V.42.1 M3: server-side clamp weight 1g-60kg (default 1kg)
        $weight       = intval( $r->get_param( 'weight' ) );
        $weight       = max( 1, min( 60000, $weight ?: 1000 ) );
        $remark       = sanitize_text_field( $r->get_param( 'remark' ) );

        // V.42.0 PHASE 4: Accept per-PNO dims + SKU + ad-hoc save-back
        // V.42.1 M3: server-side clamp dims 1-200cm (0 = not set, preserved)
        $req_sku         = strtoupper( sanitize_text_field( $r->get_param( 'sku' ) ) );
        $req_length_cm   = intval( $r->get_param( 'length_cm' ) );
        $req_length_cm   = $req_length_cm > 0 ? max( 1, min( 200, $req_length_cm ) ) : 0;
        $req_width_cm    = intval( $r->get_param( 'width_cm' ) );
        $req_width_cm    = $req_width_cm > 0 ? max( 1, min( 200, $req_width_cm ) ) : 0;
        $req_height_cm   = intval( $r->get_param( 'height_cm' ) );
        $req_height_cm   = $req_height_cm > 0 ? max( 1, min( 200, $req_height_cm ) ) : 0;
        $req_ec          = intval( $r->get_param( 'express_category' ) );  // 1 or 4, empty=auto
        $req_article_cat = intval( $r->get_param( 'article_category' ) );
        $save_sku_data   = (int) $r->get_param( 'save_sku_data' ) === 1;  // ad-hoc save-back flag
        $req_box_tpl_id  = intval( $r->get_param( 'box_template_id' ) );

        // D-12: articleCategory 1→6 migration gated by V.42 feature flag
        $v42_flag_on = function_exists( 'get_option' ) && get_option( 'dinoco_shipping_meta_enabled', '0' ) === '1';
        if ( $req_article_cat < 1 || $req_article_cat > 99 ) {
            $req_article_cat = $v42_flag_on ? 6 : 1;  // V.42 default=6 (อะไหล่รถยนต์), legacy=1
        }

        // Auto-suggest expressCategory from dims if not provided + V.42 flag ON + helper available
        if ( ! in_array( $req_ec, array( 1, 4 ), true ) && $v42_flag_on && function_exists( 'dinoco_suggest_express_category' ) ) {
            $req_ec = dinoco_suggest_express_category( $weight, array(
                'length_cm' => $req_length_cm,
                'width_cm'  => $req_width_cm,
                'height_cm' => $req_height_cm,
            ) );
        } elseif ( ! in_array( $req_ec, array( 1, 4 ), true ) ) {
            $req_ec = 1;  // legacy default
        }

        // V.42 ad-hoc SKU save-back — UPSERT to wp_dinoco_products with pack_mode='unknown'
        //   Only if: SKU provided + save_sku_data flag + SKU not already in catalog
        //   Guard: only saves dims + weight (not pack_mode/box_template — admin classifies later)
        if ( $save_sku_data && $req_sku && class_exists( 'DINOCO_Catalog' ) ) {
            $existing = DINOCO_Catalog::get_by_sku( $req_sku );
            if ( ! $existing && $req_length_cm && $req_width_cm && $req_height_cm && $weight ) {
                global $wpdb;
                $tbl = $wpdb->prefix . 'dinoco_products';
                // Minimal upsert — name defaults to item_desc, everything else nullable
                $insert_result = $wpdb->insert( $tbl, array(
                    'sku'                 => $req_sku,
                    'name'                => $item_desc,
                    'is_active'           => 1,
                    'b2b_visible'         => 0,  // hidden until admin classifies
                    'pack_mode'           => 'unknown',
                    'packaging_source'    => 'unknown',
                    'weight_grams'        => $weight,
                    'length_cm'           => $req_length_cm,
                    'width_cm'            => $req_width_cm,
                    'height_cm'           => $req_height_cm,
                    'article_category'    => $req_article_cat,
                    'shipping_updated_by' => get_current_user_id(),
                    'shipping_updated_at' => current_time( 'mysql' ),
                    'created_at'          => current_time( 'mysql' ),
                    'updated_at'          => current_time( 'mysql' ),
                ) );
                // V.42.1 H1: handle soft-deleted SKU UNIQUE collision gracefully.
                // DINOCO_Catalog::get_by_sku() filters is_active=1, so a soft-deleted row passes
                // the "doesn't exist" guard above. The INSERT then fails silently on UNIQUE(sku).
                // Log the collision + continue (don't fail the shipment — save-back is opportunistic).
                if ( $insert_result === false ) {
                    if ( function_exists( 'b2b_log' ) ) {
                        $err = isset( $wpdb->last_error ) ? $wpdb->last_error : 'unknown';
                        b2b_log( "[ManualFlash V.42.1] ad-hoc SKU insert failed (possible soft-delete collision): sku={$req_sku} err={$err}", 'error' );
                    }
                    // Don't flush cache on failure — nothing changed
                } else {
                    if ( function_exists( 'b2b_log' ) ) b2b_log( "[ManualFlash V.42] ad-hoc save-back: SKU={$req_sku} added with pack_mode=unknown (admin review queue)" );
                    if ( method_exists( 'DINOCO_Catalog', 'flush_memo' ) ) DINOCO_Catalog::flush_memo();
                    if ( function_exists( 'wp_cache_flush_group' ) ) @wp_cache_flush_group( 'dinoco_shipping' );
                }
            }
        }

        $missing = array();
        if ( empty( $dst_name ) )     $missing[] = 'ชื่อผู้รับ';
        if ( empty( $dst_phone ) )    $missing[] = 'เบอร์โทร';
        if ( empty( $dst_address ) )  $missing[] = 'ที่อยู่';
        if ( empty( $dst_province ) ) $missing[] = 'จังหวัด';
        if ( empty( $dst_postcode ) ) $missing[] = 'รหัสไปรษณีย์';
        if ( ! empty( $missing ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ข้อมูลไม่ครบ: ' . implode( ', ', $missing ) ), 400 );
        }

        // V.41.1: PICKUP (warehouse) vs LABEL (registered) — แยกเหมือน b2b_flash_create_order (ticket flow)
        //   - srcDetailAddress ที่ส่ง Flash API = warehouse address → คูเรียไปรับที่โกดัง
        //   - label_sender (return ให้ RPi render label) = registered address → ลูกค้าเห็นบนใบปะหน้า
        $sender_key = sanitize_text_field( $r->get_param( 'sender_key' ) );

        // Warehouse (Pickup — Flash เรียกรถมารับ) — อ่านจาก B2B Admin Control setting
        $wh = get_option( 'b2b_warehouse_address', array() );
        $wh_name     = ! empty( $wh['wh_name'] )     ? $wh['wh_name']     : 'DINOCO Warehouse';
        $wh_phone    = ! empty( $wh['wh_phone'] )    ? $wh['wh_phone']    : '0616399994';
        $wh_address  = ! empty( $wh['wh_address'] )  ? $wh['wh_address']  : 'ซอยรามอินทรา 14 ถนนรามอินทรา';
        $wh_district = ! empty( $wh['wh_district'] ) ? $wh['wh_district'] : 'ท่าแร้ง';
        $wh_city     = ! empty( $wh['wh_city'] )     ? $wh['wh_city']     : 'บางเขน';
        $wh_province = ! empty( $wh['wh_province'] ) ? $wh['wh_province'] : 'กรุงเทพมหานคร';
        $wh_postcode = ! empty( $wh['wh_postcode'] ) ? $wh['wh_postcode'] : '10220';

        // srcName (บน Flash K system) — override ตาม sender_key, address ใช้ warehouse เสมอ
        if ( $sender_key === 'dinoco' ) {
            $src_name = 'บริษัท พีพีที กรุ๊ป คอร์ปอเรชั่น จํากัด';
        } elseif ( $sender_key === 'foxrider' ) {
            $src_name = 'FoxRiderShop';
        } else {
            $src_name = $wh_name;
        }
        $src_phone    = $wh_phone;
        $src_address  = $wh_address;
        $src_district = $wh_district;
        $src_city     = $wh_city;
        $src_province = $wh_province;
        $src_postcode = $wh_postcode;

        // Registered address (สำหรับ RPi render บน label) — อ่านจาก B2B Admin Control setting
        // V.41.2: concat reg_address + reg_district + reg_province + reg_postcode เป็น string เดียว
        $reg = get_option( 'b2b_registered_address', array() );
        $build_reg_addr = function( $r ) {
            $parts = array();
            if ( ! empty( $r['reg_address'] ) )  $parts[] = $r['reg_address'];
            if ( ! empty( $r['reg_district'] ) ) $parts[] = $r['reg_district'];
            if ( ! empty( $r['reg_province'] ) ) $parts[] = $r['reg_province'];
            if ( ! empty( $r['reg_postcode'] ) ) $parts[] = $r['reg_postcode'];
            return implode( ' ', $parts );
        };
        $reg_addr_built = $build_reg_addr( $reg );

        if ( $sender_key === 'dinoco' ) {
            $reg_name    = ! empty( $reg['reg_name'] )  ? $reg['reg_name']  : 'บริษัท พีพีที กรุ๊ป คอร์ปอเรชั่น จํากัด';
            $reg_phone   = ! empty( $reg['reg_phone'] ) ? $reg['reg_phone'] : '0616399994';
            $reg_address = ! empty( $reg_addr_built )   ? $reg_addr_built   : '21/106 ซอยลาดพร้าว 15 แขวงจอมพล เขตจตุจักร กรุงเทพมหานคร 10900';
        } elseif ( $sender_key === 'foxrider' ) {
            // FoxRider: ที่อยู่จดทะเบียน = warehouse (อยู่ที่เดียวกัน)
            $reg_name    = 'FoxRiderShop';
            $reg_phone   = '0860355678';
            $reg_address = 'ซอยรามอินทรา 14 ถนนรามอินทรา แขวงท่าแร้ง เขตบางเขน กรุงเทพมหานคร 10220';
        } else {
            $reg_name    = ! empty( $reg['reg_name'] )  ? $reg['reg_name']  : $src_name;
            $reg_phone   = ! empty( $reg['reg_phone'] ) ? $reg['reg_phone'] : $src_phone;
            $reg_address = ! empty( $reg_addr_built )   ? $reg_addr_built   : trim( $src_address . ' ' . $src_district . ' ' . $src_city . ' ' . $src_province . ' ' . $src_postcode );
        }

        // Generate unique outTradeNo
        $out_trade_no = 'MAN-' . date( 'ymdHis' ) . '-' . wp_rand( 100, 999 );

        $params = array(
            'outTradeNo'       => $out_trade_no,
            'expressCategory'  => $req_ec,                // V.42: auto-suggest or admin override
            'articleCategory'  => $req_article_cat,       // V.42: D-12 flag-gated (6 if flag ON)
            'srcName'          => $src_name,
            'srcPhone'         => $src_phone,
            'srcDetailAddress' => $src_address,
            'srcDistrictName'  => $src_district,
            'srcCityName'      => $src_city,
            'srcProvinceName'  => $src_province,
            'srcPostalCode'    => $src_postcode,
            'dstName'          => $dst_name,
            'dstPhone'         => $dst_phone,
            'dstDetailAddress' => $dst_address,
            'dstDistrictName'  => $dst_district,
            'dstCityName'      => $dst_city,
            'dstProvinceName'  => $dst_province,
            'dstPostalCode'    => $dst_postcode,
            'weight'           => $weight,
            'insured'          => 0,
            'codEnabled'       => 0,
            'remark'           => $remark ?: $item_desc,
        );
        // V.42 PHASE 4: Add dimensions if provided (Flash per-PNO routing)
        if ( $req_length_cm > 0 ) $params['length'] = $req_length_cm;
        if ( $req_width_cm > 0 )  $params['width']  = $req_width_cm;
        if ( $req_height_cm > 0 ) $params['height'] = $req_height_cm;

        $result = b2b_flash_request( 'open/v3/orders', $params );

        if ( ! $result['ok'] || empty( $result['data']['pno'] ) ) {
            $err = isset( $result['error'] ) ? $result['error'] : 'ไม่สามารถสร้างพัสดุได้';
            b2b_log( '[ManualFlash] Create failed: ' . $err );
            return new WP_REST_Response( array( 'success' => false, 'message' => $err ), 400 );
        }

        $pno       = $result['data']['pno'];
        $sort_code = isset( $result['data']['sortCode'] ) ? $result['data']['sortCode'] : '';
        $slc       = isset( $result['data']['sortingLineCode'] ) ? $result['data']['sortingLineCode'] : '';
        $dst_store = isset( $result['data']['dstStoreName'] ) ? $result['data']['dstStoreName'] : '';

        // Store in manual shipments list
        $month_key = 'b2b_manual_shipments_' . date( 'Y_m' );
        $shipments = get_option( $month_key, array() );
        $shipments[] = array(
            'pno'           => $pno,
            'out_trade_no'  => $out_trade_no,
            'sort_code'     => $sort_code,
            'sorting_line'  => $slc,
            'dst_store'     => $dst_store,
            'sender_key'    => $sender_key,
            'dst_name'      => $dst_name,
            'dst_phone'     => $dst_phone,
            'dst_address'   => $dst_address,
            'dst_district'  => $dst_district,
            'dst_city'      => $dst_city,
            'dst_province'  => $dst_province,
            'dst_postcode'  => $dst_postcode,
            'item_desc'     => $item_desc,
            'weight'        => $weight,
            'remark'        => $remark,
            'status'        => 'created',
            'created_at'    => current_time( 'Y-m-d H:i:s' ),
            // V.41.1: snapshot registered address สำหรับ reprint (กันปัญหา option เปลี่ยนภายหลัง)
            'label_sender_name'    => $reg_name,
            'label_sender_phone'   => $reg_phone,
            'label_sender_address' => $reg_address,
            // V.42.0 PHASE 4: snapshot V.42 shipping params
            'sku'              => $req_sku,
            'length_cm'        => $req_length_cm,
            'width_cm'         => $req_width_cm,
            'height_cm'        => $req_height_cm,
            'express_category' => $req_ec,
            'article_category' => $req_article_cat,
            'box_template_id'  => $req_box_tpl_id,
            'adhoc_saved'      => $save_sku_data ? 1 : 0,
        );
        update_option( $month_key, $shipments, false );

        b2b_log( '[ManualFlash] Created ' . $out_trade_no . ' -> pno=' . $pno . ' (pickup=warehouse, label=' . $sender_key . ')' );

        return new WP_REST_Response( array(
            'success'    => true,
            'pno'        => $pno,
            'sort_code'  => $sort_code,
            'sorting_line_code' => $slc,
            'dst_store_name'    => $dst_store,
            'out_trade_no'      => $out_trade_no,
            // V.41.1: registered address สำหรับ RPi render บน label (pickup = warehouse — handled ที่ backend แยก)
            'label_sender' => array(
                'name'    => $reg_name,
                'phone'   => $reg_phone,
                'address' => $reg_address,
            ),
            'message'    => 'สร้างพัสดุสำเร็จ: ' . $pno,
        ), 200 );
    } catch ( \Throwable $e ) {
        b2b_log( '[ManualFlash] Error: ' . $e->getMessage() );
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error' ), 500 );
    }
}

function b2b_rest_manual_shipments( WP_REST_Request $r ) {
    $month = sanitize_text_field( $r->get_param( 'month' ) );
    if ( ! $month || ! preg_match( '/^\d{4}_\d{2}$/', $month ) ) {
        $month = date( 'Y_m' );
    }
    $month_key = 'b2b_manual_shipments_' . $month;
    $shipments = get_option( $month_key, array() );

    // Enrich with latest Flash status if available
    foreach ( $shipments as &$s ) {
        // Status from webhook updates (if stored)
        $cached = get_transient( 'manual_flash_status_' . $s['pno'] );
        if ( $cached ) {
            $s['status'] = $cached;
        }
    }
    unset( $s );

    return new WP_REST_Response( array(
        'success'    => true,
        'month'      => $month,
        'shipments'  => $shipments,
        'total'      => count( $shipments ),
    ), 200 );
}

function b2b_rest_manual_flash_cancel( WP_REST_Request $r ) {
    try {
        $pno = sanitize_text_field( $r->get_param( 'pno' ) );
        if ( empty( $pno ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'ไม่มี PNO' ), 400 );
        }
        if ( ! function_exists( 'b2b_flash_cancel_order' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Flash cancel function not available' ), 500 );
        }
        $result = b2b_flash_cancel_order( $pno );
        if ( $result['ok'] ) {
            // Update status in monthly list — search current + previous month
            $months = function_exists( 'b2b_manual_shipment_months' ) ? b2b_manual_shipment_months() : array( date( 'Y_m' ) );
            foreach ( $months as $m ) {
                $month_key = 'b2b_manual_shipments_' . $m;
                $shipments = get_option( $month_key, array() );
                foreach ( $shipments as &$s ) {
                    if ( $s['pno'] === $pno ) {
                        $s['status'] = 'cancelled';
                        update_option( $month_key, $shipments, false );
                        b2b_log( '[ManualFlash] Cancelled pno=' . $pno . ' (month=' . $m . ')' );
                        unset( $s );
                        return new WP_REST_Response( array( 'success' => true, 'message' => 'ยกเลิกสำเร็จ' ), 200 );
                    }
                }
                unset( $s );
            }
            b2b_log( '[ManualFlash] Cancelled pno=' . $pno . ' (not found in options but Flash cancelled)' );
            return new WP_REST_Response( array( 'success' => true, 'message' => 'ยกเลิกสำเร็จ' ), 200 );
        }
        return new WP_REST_Response( array( 'success' => false, 'message' => $result['error'] ?? 'ยกเลิกไม่สำเร็จ' ), 400 );
    } catch ( \Throwable $e ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error' ), 500 );
    }
}

// V.38.4: Helper — update manual shipment status by PNO
function b2b_manual_shipment_update_status( $pno, $new_status ) {
    if ( empty( $pno ) ) return false;
    $months = function_exists( 'b2b_manual_shipment_months' ) ? b2b_manual_shipment_months() : array( date( 'Y_m' ) );
    foreach ( $months as $m ) {
        $key = 'b2b_manual_shipments_' . $m;
        $shipments = get_option( $key, array() );
        foreach ( $shipments as &$s ) {
            if ( isset( $s['pno'] ) && $s['pno'] === $pno ) {
                $s['status'] = $new_status;
                update_option( $key, $shipments, false );
                return true;
            }
        }
        unset( $s );
    }
    return false;
}

// V.41.0: Month range helper — search up to 12 months for manual shipments (#6 cancel across months)
function b2b_manual_shipment_months( $depth = 12 ) {
    $months = array();
    for ( $i = 0; $i < $depth; $i++ ) {
        $months[] = date( 'Y_m', strtotime( "-{$i} months" ) );
    }
    return $months;
}

// V.40.8: Handle Flash webhook for manual shipments (no B2B ticket)
// Maps Flash state → manual status, updates wp_options + transient cache
function b2b_flash_manual_shipment_webhook( $pno, $data ) {
    if ( empty( $pno ) ) return false;

    // Check if PNO exists in manual shipments (current + previous month)
    $found = false;
    $months = function_exists( 'b2b_manual_shipment_months' ) ? b2b_manual_shipment_months() : array( date( 'Y_m' ) );
    foreach ( $months as $m ) {
        $key = 'b2b_manual_shipments_' . $m;
        $shipments = get_option( $key, array() );
        foreach ( $shipments as $s ) {
            if ( isset( $s['pno'] ) && $s['pno'] === $pno ) {
                $found = true;
                break 2;
            }
        }
    }
    if ( ! $found ) return false;

    // Map Flash state to manual shipment status
    $flash_state = isset( $data['state'] ) ? intval( $data['state'] ) : -1;
    $status_map = array(
        1 => 'picked_up',    // รับพัสดุแล้ว
        2 => 'in_transit',   // ระหว่างการขนส่ง
        3 => 'delivering',   // ระหว่างการจัดส่ง
        4 => 'detained',     // พัสดุคงคลัง
        5 => 'delivered',    // เซ็นรับแล้ว
        6 => 'problem',      // ระหว่างจัดการพัสดุมีปัญหา
        7 => 'returned',     // พัสดุตีกลับแล้ว
        8 => 'closed',       // ปิดงานมีปัญหา
        9 => 'cancelled',    // เรียกคืนพัสดุแล้ว
    );
    $new_status = isset( $status_map[ $flash_state ] ) ? $status_map[ $flash_state ] : null;
    if ( ! $new_status ) return false;

    // Update wp_options (persistent)
    b2b_manual_shipment_update_status( $pno, $new_status );

    // Set transient cache (for fast enrichment in list API, 7 days TTL)
    set_transient( 'manual_flash_status_' . $pno, $new_status, 7 * DAY_IN_SECONDS );

    return $new_status;
}

// V.38: Manual Flash Ready — เรียก courier โดยไม่ต้องมี ticket_id
// ใช้ b2b_flash_notify_courier_from_warehouse() ตรง (เรียกรถมารับพัสดุทั้งหมดที่โกดัง)
function b2b_rest_manual_flash_ready( WP_REST_Request $r ) {
    if ( ! b2b_verify_print_key( $r ) )
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Invalid API key' ), 403 );

    try {
        $pno = sanitize_text_field( $r->get_param( 'pno' ) );

        // Check active pickup — ถ้ามีอยู่แล้วใช้เดิม
        $active_pickup = get_transient( 'b2b_flash_active_pickup' );
        if ( is_array( $active_pickup ) && ! empty( $active_pickup['pickup_id'] ) ) {
            $info = '';
            if ( ! empty( $active_pickup['staff_name'] ) ) {
                $info = $active_pickup['staff_name'] . ' ' . ( $active_pickup['staff_phone'] ?? '' );
            }
            // อัพเดทสถานะ manual shipment — V.41.0: support all_pnos for multi-box
            $all_pnos = $r->get_param( 'all_pnos' );
            if ( is_array( $all_pnos ) ) {
                foreach ( $all_pnos as $p ) b2b_manual_shipment_update_status( sanitize_text_field( $p ), 'courier_called' );
            } elseif ( $pno ) {
                b2b_manual_shipment_update_status( $pno, 'courier_called' );
            }
            return new WP_REST_Response( array(
                'success'      => true,
                'message'      => 'มี pickup อยู่แล้ว — คูเรียร์กำลังมา',
                'courier_info' => $info,
                'pickup_id'    => $active_pickup['pickup_id'],
            ), 200 );
        }

        // เรียก courier ใหม่
        if ( ! function_exists( 'b2b_flash_notify_courier_from_warehouse' ) ) {
            return new WP_REST_Response( array( 'success' => false, 'message' => 'Flash notify function not available' ), 500 );
        }

        $courier_result = b2b_flash_notify_courier_from_warehouse( 1, 'Manual Shipment' );

        if ( ! empty( $courier_result['ok'] ) && ! empty( $courier_result['data'] ) ) {
            $d = $courier_result['data'];
            $pickup_data = is_array( $d ) ? $d : array();
            $staff_name  = $pickup_data['staffInfoName']  ?? '';
            $staff_phone = $pickup_data['staffInfoPhone'] ?? '';
            $pickup_id   = $pickup_data['ticketPickupId'] ?? '';

            // Cache active pickup
            set_transient( 'b2b_flash_active_pickup', array(
                'pickup_id'    => $pickup_id,
                'staff_name'   => $staff_name,
                'staff_phone'  => $staff_phone,
                'timeout_text' => $pickup_data['timeoutAtText'] ?? '',
                'created_at'   => time(),
                'parcel_count' => 1,
                'ticket_ids'   => array(),
            ), 4 * HOUR_IN_SECONDS );

            $info = $staff_name . ' ' . $staff_phone;
            b2b_log( '[ManualFlash] Courier called: ' . $info );

            // อัพเดทสถานะ manual shipment — V.41.0: support all_pnos
            $all_pnos = $r->get_param( 'all_pnos' );
            if ( is_array( $all_pnos ) ) {
                foreach ( $all_pnos as $p ) b2b_manual_shipment_update_status( sanitize_text_field( $p ), 'courier_called' );
            } elseif ( $pno ) {
                b2b_manual_shipment_update_status( $pno, 'courier_called' );
            }

            return new WP_REST_Response( array(
                'success'      => true,
                'message'      => 'เรียกรถสำเร็จ',
                'courier_info' => trim( $info ),
                'pickup_id'    => $pickup_id,
            ), 200 );
        }

        // Flash rejected — might already have a pickup (e.g. "คุณได้ทำรายนัดรับพัสดุแล้ว")
        $err = $courier_result['error'] ?? 'Unknown error';
        $already_booked = ( mb_strpos( $err, 'นัดรับ' ) !== false || mb_strpos( $err, 'ซ้ำ' ) !== false );
        if ( $already_booked ) {
            // Flash says pickup already exists — treat as success + update status
            $all_pnos = $r->get_param( 'all_pnos' );
            if ( is_array( $all_pnos ) ) {
                foreach ( $all_pnos as $p ) b2b_manual_shipment_update_status( sanitize_text_field( $p ), 'courier_called' );
            } elseif ( $pno ) {
                b2b_manual_shipment_update_status( $pno, 'courier_called' );
            }
            b2b_log( '[ManualFlash] Already booked, treating as success: ' . $err );
            return new WP_REST_Response( array( 'success' => true, 'message' => 'เรียกรถแล้ว (มีนัดรับอยู่)' ), 200 );
        }
        b2b_log( '[ManualFlash] Courier call failed: ' . $err );
        return new WP_REST_Response( array( 'success' => false, 'message' => $err ), 400 );

    } catch ( \Throwable $e ) {
        b2b_log( '[ManualFlash] Ready error: ' . $e->getMessage() );
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Internal error' ), 500 );
    }
}

// ═══════════════════════════════════════════════════════════════
// V.40.1: RPi Distributor List — ดึงรายชื่อตัวแทนพร้อมที่อยู่สำหรับ manual shipping
// ═══════════════════════════════════════════════════════════════
function b2b_rest_rpi_distributors( WP_REST_Request $r ) {
    $distributors = get_posts( array(
        'post_type'      => 'distributor',
        'posts_per_page' => 200,
        'post_status'    => 'publish',
    ) );

    $results = array();
    foreach ( $distributors as $d ) {
        $active = get_field( 'is_active', $d->ID );
        if ( $active === '0' || $active === false ) continue;

        $results[] = array(
            'id'       => $d->ID,
            'name'     => get_field( 'shop_name', $d->ID ) ?: $d->post_title,
            'phone'    => get_field( 'dist_phone', $d->ID ) ?: '',
            'address'  => get_field( 'dist_address', $d->ID ) ?: '',
            'district' => get_field( 'dist_district', $d->ID ) ?: '',
            'city'     => get_field( 'dist_city', $d->ID ) ?: '',
            'province' => get_field( 'dist_province', $d->ID ) ?: '',
            'postcode' => get_field( 'dist_postcode', $d->ID ) ?: '',
        );
    }

    return new WP_REST_Response( array( 'success' => true, 'data' => $results ), 200 );
}

