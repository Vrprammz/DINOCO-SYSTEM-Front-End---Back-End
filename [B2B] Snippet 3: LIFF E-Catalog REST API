/**
 * Validate print API key from query param or header.
 */
function b2b_verify_print_key( WP_REST_Request $request ) {
    $stored_key = get_option('b2b_print_api_key', '');
    if ( empty($stored_key) ) return false;
    $key = $request->get_header('X-Print-Key');
    if ( empty($key) ) {
        $key = sanitize_text_field($request->get_param('key'));
        // V.31 SEC: Warn when API key sent via URL (visible in access logs)
        if ( !empty($key) ) {
            b2b_log('[SEC] ⚠ Print API key sent via URL param — use X-Print-Key header instead');
        }
    }
    if ( empty($key) || !hash_equals($stored_key, $key) ) {
        return false;
    }
    // Update last poll timestamp (throttled — write at most once per 60s)
    $last_poll = intval(get_option('b2b_print_last_poll', 0));
    if ( time() - $last_poll >= 60 ) {
        update_option('b2b_print_last_poll', time(), false);
    }
    return true;
}

/**
 * GET /b2b/v1/print-queue — RPi polls this every 10 seconds.
 * Returns queued print jobs with full order data.
 */
function b2b_rest_print_queue( WP_REST_Request $request ) {
    try {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    // Recovery: stale 'printing' jobs older than 5 minutes → re-queue
    $stale_jobs = get_posts(array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => 10,
        'post_status'    => 'publish',
        'meta_query'     => array(
            array('key' => 'print_status', 'value' => 'printing'),
            array('key' => 'print_started_at', 'value' => time() - 300, 'compare' => '<', 'type' => 'NUMERIC'),
        ),
    ));
    foreach ($stale_jobs as $stale) {
        update_field('print_status', 'queued', $stale->ID);
        b2b_log('[Print] Recovered stale job #' . $stale->ID . ' — re-queued');
    }

    $mode = get_option('b2b_shipping_mode', 'manual');
    $orders = get_posts(array(
        'post_type'      => 'b2b_order',
        'posts_per_page' => 10,
        'post_status'    => 'publish',
        'meta_query'     => array(array('key'=>'print_status','value'=>'queued')),
        'orderby'        => 'date',
        'order'          => 'ASC',
    ));

    // Check for test print job
    $test_job = get_transient('b2b_print_test_job');
    if ( $test_job ) delete_transient('b2b_print_test_job');

    // V.25: Always check for pending remote commands, even when no print jobs
    $pending_cmds = get_option('b2b_rpi_pending_commands', array());

    if ( empty($orders) && !$test_job ) {
        $resp = array('success'=>true,'jobs'=>array());
        if ( !empty($pending_cmds) ) {
            $resp['remote_commands'] = $pending_cmds;
        }
        return new WP_REST_Response($resp, 200);
    }

    $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
    $settings = get_option('b2b_settings', array());
    $reg = get_option('b2b_registered_address', array());
    $reg_addr_parts = array_filter(array(
        isset($reg['reg_address'])  ? $reg['reg_address']  : '',
        isset($reg['reg_district']) ? $reg['reg_district'] : '',
        isset($reg['reg_province']) ? $reg['reg_province'] : '',
        isset($reg['reg_postcode']) ? $reg['reg_postcode'] : '',
    ));
    $company = array(
        'name'     => ! empty($reg['reg_name'])  ? $reg['reg_name']  : (isset($settings['company_name']) ? $settings['company_name'] : (defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO CO.,LTD')),
        'phone'    => ! empty($reg['reg_phone']) ? $reg['reg_phone'] : '',
        'address'  => ! empty($reg_addr_parts)   ? implode(' ', $reg_addr_parts) : '',
        'province' => ! empty($reg['reg_province']) ? $reg['reg_province'] : '',
        'postcode' => ! empty($reg['reg_postcode']) ? $reg['reg_postcode'] : '',
        'bank'     => array(
            'name'    => isset($settings['bank_name']) ? $settings['bank_name'] : (defined('B2B_BANK_NAME') ? B2B_BANK_NAME : ''),
            'account' => isset($settings['bank_account']) ? $settings['bank_account'] : (defined('B2B_BANK_ACCOUNT') ? B2B_BANK_ACCOUNT : ''),
            'holder'  => isset($settings['bank_holder']) ? $settings['bank_holder'] : (defined('B2B_BANK_HOLDER') ? B2B_BANK_HOLDER : ''),
        ),
    );

    $jobs = array();
    foreach ( $orders as $o ) {
        $tid = $o->ID;
        // Mark as printing immediately to prevent duplicate pulls
        update_field('print_status', 'printing', $tid);
        update_field('print_started_at', time(), $tid);

        $gid  = get_field('source_group_id', $tid) ?: '';
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;

        // Parse items
        $items_text = get_field('order_items', $tid) ?: '';
        $parsed_items = array();
        // V.36: Resolve SET children from dinoco_sku_relations
        $sku_relations = get_option('dinoco_sku_relations', array());
        if (!is_array($sku_relations)) $sku_relations = array();
        $catalog_for_children = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());

        if ( preg_match_all('/^(.+?)\s*\(([A-Z0-9\-]+)\)\s*x(\d+)\s*=\s*฿?([\d,.]+)/mu', $items_text, $matches, PREG_SET_ORDER) ) {
            foreach ( $matches as $m ) {
                $sku = strtoupper(trim($m[2]));
                $pid = function_exists('b2b_find_product_by_sku') ? b2b_find_product_by_sku($sku) : 0;
                $bpu = function_exists('b2b_get_boxes_per_unit') ? b2b_get_boxes_per_unit($sku, $pid) : ($pid ? max(1, intval(get_field('boxes_per_unit', $pid) ?: 1)) : 1);
                $upb = function_exists('b2b_get_units_per_box') ? b2b_get_units_per_box($sku, $pid) : 1;

                // V.36: Resolve children for SET SKUs
                $children = array();
                if (isset($sku_relations[$sku]) && is_array($sku_relations[$sku])) {
                    foreach ($sku_relations[$sku] as $child_sku) {
                        $child_name = isset($catalog_for_children[$child_sku]['name']) ? $catalog_for_children[$child_sku]['name'] : $child_sku;
                        $children[] = array('sku' => $child_sku, 'name' => $child_name);
                    }
                }

                $parsed_items[] = array(
                    'name'           => trim($m[1]),
                    'sku'            => $sku,
                    'qty'            => intval($m[3]),
                    'price'          => floatval(str_replace(',','',$m[4])),
                    'boxes_per_unit' => $bpu,
                    'units_per_box'  => $upb,
                    'children'       => $children,
                );
            }
        }

        // V.39.3: Invoice data — rank pricing via b2b_compute_dealer_price (tier % discount)
        $dist_rank = $dist ? (get_field('rank_system', $dist->ID) ?: 'standard') : 'standard';
        $total_amount = floatval(get_field('total_amount', $tid));

        // Per-item: retail price + discount % — use shared helper
        foreach ($parsed_items as &$_pi) {
            $_sku = strtoupper(trim($_pi['sku']));
            $_retail = 0; $_disc_str = '';
            $_pd = function_exists('b2b_get_product_data') ? b2b_get_product_data($_sku) : null;
            if ($_pd) {
                $_retail = floatval($_pd['base_price'] ?? $_pd['price_standard'] ?? 0);
                if ($_retail <= 0 && isset($catalog[$_sku]['price'])) {
                    $_retail = floatval(str_replace(',', '', $catalog[$_sku]['price']));
                }
                if ($_retail > 0 && function_exists('b2b_compute_dealer_price')) {
                    $_dealer = b2b_compute_dealer_price($_retail, $dist_rank, $_pd);
                    if ($_dealer < $_retail) {
                        $_disc_str = number_format(round((1 - $_dealer / $_retail) * 100, 1), 1) . '%';
                    }
                } else {
                    $_disc = floatval($_pd['b2b_discount_percent'] ?? 0);
                    if ($_disc > 0) $_disc_str = number_format($_disc, 2) . '%';
                }
            } else {
                $_pid = function_exists('b2b_find_product_by_sku') ? b2b_find_product_by_sku($_sku) : 0;
                if ($_pid) {
                    $_retail = floatval(get_field('price_standard', $_pid));
                    $_disc = floatval(get_field('b2b_discount_percent', $_pid));
                    if ($_disc > 0) $_disc_str = number_format($_disc, 2) . '%';
                }
            }
            if ($_retail <= 0 && isset($catalog[$_sku]['price'])) {
                $_retail = floatval(str_replace(',', '', $catalog[$_sku]['price']));
            }
            $_pi['retail_price'] = $_retail;
            $_pi['discount_pct'] = $_disc_str;
        }
        unset($_pi);

        // Summary totals for invoice footer
        $_ft_total_retail = 0;
        foreach ($parsed_items as $_pi) {
            if ($_pi['retail_price'] > 0) $_ft_total_retail += $_pi['retail_price'] * $_pi['qty'];
        }
        $_ft_total_discount = $_ft_total_retail > 0 ? max(0, $_ft_total_retail - $total_amount) : 0;

        // Doc type: receipt if paid/completed
        $_ticket_status = get_field('order_status', $tid) ?: 'draft';
        $_doc_type = in_array($_ticket_status, array('paid','completed','claim_resolved'), true) ? 'receipt' : 'invoice';

        // Credit term
        $_term = $dist ? (intval(get_field('credit_term_days', $dist->ID)) ?: 30) : 30;

        // Baht text (reuse function from Snippet 10)
        $_baht_text = function_exists('b2b_baht_text') ? '(' . b2b_baht_text($total_amount) . ')' : '';

        $jobs[] = array(
            'ticket_id' => $tid,
            'mode'      => $mode,
            'order'     => array(
                'dist_name'    => $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : 'Unknown',
                'dist_phone'   => $dist ? (get_field('dist_phone', $dist->ID) ?: '') : '',
                'dist_address' => $dist ? (get_field('dist_address', $dist->ID) ?: '') : '',
                'dist_district'=> $dist ? (get_field('dist_district', $dist->ID) ?: '') : '',
                'dist_city'    => $dist ? (get_field('dist_city', $dist->ID) ?: '') : '',
                'dist_province'=> $dist ? (get_field('dist_province', $dist->ID) ?: '') : '',
                'dist_postcode'=> $dist ? (get_field('dist_postcode', $dist->ID) ?: '') : '',
                'total'        => $total_amount,
                'due_date'     => get_field('due_date', $tid) ?: '',
                'items'        => $parsed_items,
                'note'         => get_field('admin_note', $tid) ?: '',
                'tracking'     => get_field('tracking_number', $tid) ?: '',
                'total_boxes'  => intval(get_field('total_boxes', $tid)),
                'shipping_provider' => get_field('shipping_provider', $tid) ?: '',
                // V.30: Invoice fields (match Snippet 10 design)
                'credit_term'    => $_term,
                'dist_rank'      => $dist_rank,
                'doc_type'       => $_doc_type,
                'baht_text'      => $_baht_text,
                'total_retail'   => $_ft_total_retail,
                'total_discount' => $_ft_total_discount,
                'creator'        => defined('B2B_CREATOR_NAME') ? B2B_CREATOR_NAME : 'DINOCO System',
                'customer_note'  => get_field('customer_note', $tid) ?: '',
            ),
            'company' => $company,
            'flash_label_pnos' => (get_field('shipping_provider', $tid) === 'Flash') ? (get_post_meta($tid, '_flash_tracking_numbers', true) ?: array()) : array(),
            'flash_meta' => (get_field('shipping_provider', $tid) === 'Flash') ? array(
                'sort_code'         => get_post_meta($tid, '_flash_sort_code', true) ?: '',
                'sorting_line_code' => get_post_meta($tid, '_flash_sorting_line_code', true) ?: '',
                'dst_store_name'    => get_post_meta($tid, '_flash_dst_store_name', true) ?: '',
            ) : array(),
        );
    }

    $response = array('success'=>true,'jobs'=>$jobs);
    if ( $test_job ) {
        $response['test_job'] = $test_job;
        b2b_log('[Print] Test job included: ' . $test_job['type']);
    }

    // V.25: Attach pending remote commands for RPi to execute
    if ( !empty($pending_cmds) ) {
        $response['remote_commands'] = $pending_cmds;
    }

    if ( count($jobs) > 0 ) b2b_log('[Print] Queue polled — ' . count($jobs) . ' jobs returned');
    return new WP_REST_Response($response, 200);
    } catch ( Exception $e ) {
        b2b_log('[PrintQueue] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

/**
 * POST /b2b/v1/print-ack — RPi reports print result back.
 */
function b2b_rest_print_ack( WP_REST_Request $request ) {
    try {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $tid    = intval($request->get_param('ticket_id'));
    $status = sanitize_text_field($request->get_param('status')); // 'done' or 'error'
    $msg    = sanitize_text_field($request->get_param('message') ?: '');
    $details = $request->get_param('details'); // JSON object
    $printed_at = sanitize_text_field($request->get_param('printed_at') ?: '');

    if ( !$tid || !in_array($status, array('done','error','partial'), true) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid params'), 400);

    if ( get_post_type($tid) !== 'b2b_order' )
        return new WP_REST_Response(array('success'=>false,'message'=>'Ticket not found'), 404);

    update_field('print_status', $status, $tid);
    if ( in_array($status, array('error','partial'), true) && $msg ) update_field('print_error', $msg, $tid);
    if ( $printed_at ) update_field('print_timestamp', $printed_at, $tid);
    if ( $details && is_array($details) ) update_field('print_details', wp_json_encode($details), $tid);

    // V.30: Update flash_packing_status when print completes
    if ( $status === 'done' ) {
        $current_fps = get_post_meta( $tid, '_flash_packing_status', true );
        if ( $current_fps === 'print_queued' ) {
            update_post_meta( $tid, '_flash_packing_status', 'print_done' );
            b2b_log( '[Print] Updated flash_packing_status → print_done for #' . $tid );
        }
    }

    // Notify LINE admin on print error or partial success
    if ( in_array($status, array('error','partial'), true) && function_exists('b2b_push_to_admin') ) {
        $gid  = get_field('source_group_id', $tid) ?: '';
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : 'Unknown';

        // Translate common print errors to Thai
        $thai_hint = 'เกิดข้อผิดพลาดในการปริ้น';
        $msg_lower = strtolower($msg);
        if ( strpos($msg_lower, 'not found') !== false && strpos($msg_lower, 'printer') !== false ) {
            $thai_hint = 'ไม่พบเครื่องปริ้น — ตรวจสอบว่าเปิดเครื่องและเชื่อมต่ออยู่';
        } elseif ( strpos($msg_lower, 'no printer configured') !== false ) {
            $thai_hint = 'ยังไม่ได้ตั้งค่าเครื่องปริ้นใน config';
        } elseif ( strpos($msg_lower, 'cups') !== false || strpos($msg_lower, 'connection') !== false ) {
            $thai_hint = 'เชื่อมต่อเครื่องปริ้นไม่ได้ — ตรวจสอบ CUPS service';
        } elseif ( strpos($msg_lower, 'not iterable') !== false || strpos($msg_lower, 'builtin_function') !== false ) {
            $thai_hint = 'ข้อผิดพลาดภายในตัวปริ้น (CSS/PDF render) — อัปเดต print client';
        } elseif ( strpos($msg_lower, 'template') !== false || strpos($msg_lower, 'templatenotfound') !== false ) {
            $thai_hint = 'ไม่พบ template ปริ้น — ตรวจสอบไฟล์ templates/ ใน RPi';
        } elseif ( strpos($msg_lower, 'timeout') !== false ) {
            $thai_hint = 'ปริ้นไม่ทันเวลา (timeout) — ลองปริ้นซ้ำ';
        } elseif ( strpos($msg_lower, 'flash label') !== false || strpos($msg_lower, 'download') !== false ) {
            $thai_hint = 'ดาวน์โหลด Flash label ไม่สำเร็จ — ตรวจสอบการเชื่อมต่อ';
        } elseif ( strpos($msg_lower, 'resource busy') !== false || strpos($msg_lower, 'errno 16') !== false ) {
            $thai_hint = 'USB เครื่องปริ้นค้าง (Resource busy) — ลองปริ้นซ้ำหรือ restart RPi service';
        } elseif ( strpos($msg_lower, 'paper') !== false || strpos($msg_lower, 'media') !== false ) {
            $thai_hint = 'ปัญหากระดาษ — ตรวจสอบกระดาษในเครื่องปริ้น';
        }

        $icon = ($status === 'partial') ? '⚠️' : '🔴';
        $title = ($status === 'partial') ? 'ปริ้นไม่ครบ' : 'ปริ้นไม่สำเร็จ';
        b2b_push_to_admin(
            "{$icon} {$title} — Ticket #{$tid}\n"
            . "━━━━━━━━━━━━━━━━\n"
            . "ร้าน: {$shop}\n"
            . "❗ {$thai_hint}\n"
            . "Error: {$msg}\n"
            . "กดปริ้นซ้ำได้ที่ Admin Dashboard"
        );
    }

    b2b_log('[Print] Ack #' . $tid . ' — ' . $status . ($msg ? ': '.$msg : ''));
    return new WP_REST_Response(array('success'=>true,'message'=>'Status updated'), 200);
    } catch ( Exception $e ) {
        b2b_log('[PrintAck] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'เกิดข้อผิดพลาดภายใน กรุณาลองใหม่'), 500);
    }
}

/**
 * POST /b2b/v1/print-heartbeat — RPi sends device status every 30s.
 * Stores: hostname, IP, CPU temp, uptime, printers list, disk usage.
 */
function b2b_rest_print_heartbeat( WP_REST_Request $request ) {
    if ( !b2b_verify_print_key($request) )
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid API key'), 403);

    $device = array(
        'hostname'   => sanitize_text_field($request->get_param('hostname') ?: ''),
        'ip'         => sanitize_text_field($request->get_param('ip') ?: ''),
        'cpu_temp'   => sanitize_text_field($request->get_param('cpu_temp') ?: ''),
        'uptime'     => sanitize_text_field($request->get_param('uptime') ?: ''),
        'disk_usage' => sanitize_text_field($request->get_param('disk_usage') ?: ''),
        'printers'   => array(),
        'timestamp'  => time(),
    );

    $printers = $request->get_param('printers');
    if ( is_array($printers) ) {
        foreach ( $printers as $p ) {
            $device['printers'][] = array(
                'name'          => sanitize_text_field($p['name'] ?? ''),
                'status'        => sanitize_text_field($p['status'] ?? 'unknown'),
                'state_reasons' => sanitize_text_field($p['state_reasons'] ?? ''),
            );
        }
    }

    // Detect printer status changes (e.g. idle→disabled, error states)
    $prev = get_option('b2b_print_device_info', array());
    $prev_printers = isset($prev['printers']) ? $prev['printers'] : array();
    $prev_map = array();
    foreach ( $prev_printers as $pp ) { $prev_map[$pp['name']] = $pp['status']; }
    foreach ( $device['printers'] as $np ) {
        $old_st = isset($prev_map[$np['name']]) ? $prev_map[$np['name']] : '';
        if ( $old_st && $old_st !== $np['status'] && in_array($np['status'], array('disabled','stopped'), true) ) {
            if ( function_exists('b2b_push_to_admin') ) {
                $reason = $np['state_reasons'] ? " ({$np['state_reasons']})" : '';
                b2b_push_to_admin(
                    "⚠️ Printer สถานะเปลี่ยน\n"
                    . "━━━━━━━━━━━━━━━━\n"
                    . "🖨️ {$np['name']}: {$old_st} → {$np['status']}{$reason}"
                );
            }
        }
    }

    update_option('b2b_print_device_info', $device, false);
    return new WP_REST_Response(array('success'=>true), 200);
}

/**
