#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════
# DINOCO Test Gate — pre-push git hook V.1.0
#
# Runs Jest only when frontend files have changed.
# Skipped silently for backend-only pushes (PHP/SQL/MD).
#
# Path triggers (mirror of .github/workflows/jest.yml):
#   - liff-src/**
#   - tests/jest/**
#   - jest.config.js / babel.config.json
#   - package.json / package-lock.json
#
# Override (emergency only): git push --no-verify
# Skip when node_modules missing: SKIP_JEST=1 git push
# ═══════════════════════════════════════════════════════════
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ZERO_SHA="0000000000000000000000000000000000000000"

# Path regex matching jest.yml paths
WATCH_REGEX='^(liff-src/|tests/jest/|jest\.config\.js$|babel\.config\.json$|package(-lock)?\.json$)'

# ─────────────────────────────────────────────────────────────
# Read stdin refs per git hook spec:
#   <local ref> <local sha> <remote ref> <remote sha>
# Falls back to upstream..HEAD when run interactively.
# ─────────────────────────────────────────────────────────────
CHANGED=""

if [ -t 0 ]; then
  UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
  if [ -n "$UPSTREAM" ]; then
    CHANGED=$(git diff --name-only "$UPSTREAM"..HEAD 2>/dev/null || true)
  else
    CHANGED=$(git diff --name-only HEAD~10..HEAD 2>/dev/null || true)
  fi
else
  while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "$ZERO_SHA" ]; then
      continue
    fi
    if [ "$remote_sha" = "$ZERO_SHA" ]; then
      REMOTE_HEAD=$(git rev-parse --verify --quiet refs/remotes/origin/HEAD 2>/dev/null || echo "")
      if [ -n "$REMOTE_HEAD" ]; then
        RANGE_CHANGED=$(git diff --name-only "$REMOTE_HEAD".."$local_sha" 2>/dev/null || true)
      else
        RANGE_CHANGED=$(git diff --name-only "$(git rev-list --max-parents=0 "$local_sha" | head -1)".."$local_sha" 2>/dev/null || true)
      fi
    else
      RANGE_CHANGED=$(git diff --name-only "$remote_sha".."$local_sha" 2>/dev/null || true)
    fi
    CHANGED="${CHANGED}"$'\n'"${RANGE_CHANGED}"
  done
fi

# Skip if no relevant frontend files changed
if ! echo "$CHANGED" | grep -qE "$WATCH_REGEX"; then
  exit 0
fi

# Allow skip via env (CI / no-deps machines)
if [ "${SKIP_JEST:-0}" = "1" ]; then
  echo -e "${YELLOW}[jest-gate]${NC} SKIP_JEST=1 — skipping (override)."
  exit 0
fi

# Bail gracefully if Jest isn't installed (warn, don't block)
if [ ! -x "node_modules/.bin/jest" ]; then
  echo -e "${YELLOW}[frontend-gate]${NC} node_modules/.bin/jest not found — run 'npm install' first."
  echo -e "${YELLOW}[frontend-gate]${NC} Skipping gate (CI will catch it). Use SKIP_JEST=1 to silence."
  exit 0
fi

echo -e "${YELLOW}[frontend-gate]${NC} Frontend files changed — running ESLint..."
if [ -x "node_modules/.bin/eslint" ]; then
  if ! node_modules/.bin/eslint liff-src/ tests/jest/ --quiet; then
    echo ""
    echo -e "${RED}[frontend-gate] ESLint FAIL${NC} — push blocked."
    echo ""
    echo "Fix above, then retry:    npm run lint:fix && git push"
    echo "Emergency override:       git push --no-verify"
    exit 1
  fi
fi

if [ -x "node_modules/.bin/tsc" ]; then
  echo -e "${YELLOW}[frontend-gate]${NC} Running TypeScript --checkJs..."
  if ! node_modules/.bin/tsc --noEmit; then
    echo ""
    echo -e "${RED}[frontend-gate] TypeScript FAIL${NC} — push blocked."
    echo ""
    echo "Fix JSDoc/type issues above, then retry:    git push"
    echo "Emergency override:                          git push --no-verify"
    exit 1
  fi
fi

echo -e "${YELLOW}[frontend-gate]${NC} Running Jest..."
if node_modules/.bin/jest --silent; then
  echo -e "${GREEN}[frontend-gate] PASS${NC} — push allowed."
  exit 0
else
  echo ""
  echo -e "${RED}[frontend-gate] Jest FAIL${NC} — push blocked."
  echo ""
  echo "Fix failing tests above, then retry:"
  echo "  git push"
  echo ""
  echo "Emergency override:  git push --no-verify"
  exit 1
fi
