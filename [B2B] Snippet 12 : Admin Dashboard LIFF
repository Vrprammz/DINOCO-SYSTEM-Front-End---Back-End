    var b2bBase = <?php echo json_encode( defined('B2B_SITE_URL') ? rtrim(B2B_SITE_URL, '/') : '' ); ?>;
    function cancelPno(ticketId, pno, btn) {
      if (!confirm('ยกเลิกกล่อง ' + pno + ' จาก #' + ticketId + '?')) return;
      btn.disabled = true; btn.textContent = '...';
      fetch(b2bBase + '/wp-json/b2b/v1/flash-test/run-step', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ticket_id: parseInt(ticketId), step: 'cancel_pno', target_pno: pno})
      })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.ok || d.success) { btn.textContent = '✅'; setTimeout(function(){ location.reload(); }, 800); }
        else { btn.textContent = '❌'; alert(d.error || d.message || 'Failed'); btn.disabled = false; }
      })
      .catch(function(e){ btn.textContent = '❌'; alert(e.message); btn.disabled = false; });
    }
    // V.37: Re-ship cancelled/hold PNO — create new PNO + print label
    function reshipPno(ticketId, pno, btn) {
      if (!confirm('สร้าง PNO ใหม่สำหรับกล่องนี้? (จะปริ้น label ใหม่)')) return;
      btn.disabled = true; btn.textContent = '...';
      fetch(b2bBase + '/wp-json/b2b/v1/flash-test/run-step', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ticket_id: parseInt(ticketId), step: 'reship_pno', target_pno: pno})
      })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.ok || d.success) { btn.textContent = '✅ ' + (d.new_pno || ''); setTimeout(function(){ location.reload(); }, 1200); }
        else { btn.textContent = '❌'; alert(d.error || d.message || 'Failed'); btn.disabled = false; }
      })
      .catch(function(e){ btn.textContent = '❌'; alert(e.message); btn.disabled = false; });
    }
    // V.31.1: Auto-refresh respects global DINOCO_AUTO_REFRESH toggle
    (function(){
      var SEC=60,sec=SEC,el=document.getElementById('b2b-refresh-sec');
      if(!el)return;
      setInterval(function(){
        if(window.DINOCO_AUTO_REFRESH===false){el.textContent='⏸';return;}
        sec--;el.textContent=sec;
        if(sec<=0){sec=SEC;location.reload();}
