                : esc_url($base . '/b2b-ticket/?ticket_id=' . $o->ID . '&view=admin');

            // V.9: claimed_by (N6)
            $claimed = $show_claimed ? (get_field('claimed_by_admin', $o->ID) ?: '') : '';

            $html .= '<a class="b2b-row" href="' . $url . '">';
            $html .= '<div class="left"><div>';
            $html .= '<div class="label" style="color:' . $color . ';">#' . $o->ID . ' · ' . esc_html($sl) . '</div>';
            $html .= '<div class="desc">' . esc_html(mb_substr($shop, 0, 18)) . ' · ' . $date . '</div>';
            if ($claimed) $html .= '<div class="b2b-claimed">✋ ' . esc_html($claimed) . '</div>';
            $html .= '</div></div>';
            $html .= '<div style="font-weight:700; color:' . $color . ';">฿' . number_format($total, 0) . '</div>';
            $html .= '</a>';
        }
        return $html;
    }
}

