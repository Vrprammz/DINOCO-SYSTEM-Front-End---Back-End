    <script>
    (function(){
        var API='<?php echo esc_js($api_base); ?>';
        var TOKEN='<?php echo esc_js($api_token); ?>';
        var headers={'Content-Type':'application/json','X-B2B-Token':TOKEN};
        function _esc(s){var d=document.createElement('span');d.textContent=s;return d.innerHTML;}

        // Search filter
        var searchEl=document.getElementById('stk-search');
        searchEl.addEventListener('input',function(){
            var q=this.value.toLowerCase();
            document.querySelectorAll('.stk-item').forEach(function(el){
                var sku=(el.dataset.sku||'').toLowerCase();
                var name=(el.dataset.name||'').toLowerCase();
                el.classList.toggle('hidden',q&&sku.indexOf(q)===-1&&name.indexOf(q)===-1);
            });
        });

        // Filter pills
        document.querySelectorAll('.stk-pill[data-filter]').forEach(function(btn){
            btn.addEventListener('click',function(){
                document.querySelectorAll('.stk-pill').forEach(function(b){b.classList.remove('active');});
                this.classList.add('active');
                var f=this.dataset.filter;
                document.querySelectorAll('.stk-item').forEach(function(el){
                    if(f==='all') el.classList.remove('hidden');
                    else el.classList.toggle('hidden',el.dataset.stock!==(f==='oos'?'oos':'in_stock'));
                });
            });
        });

        // Unlock
        window.b2bUnlock=function(sku,btn){
            var item=btn.closest('.stk-item');
            var checks=item.querySelectorAll('.bo-check:checked');
            var tickets=[];
            checks.forEach(function(c){tickets.push(parseInt(c.value));});

            if(!confirm('ปลดล็อก '+sku+'?'+(tickets.length?' + แจ้ง '+tickets.length+' ร้าน':''))) return;
            btn.disabled=true; btn.textContent='⏳ กำลังดำเนินการ...';

            fetch(API+'/admin-stock-unlock',{method:'POST',headers:headers,
                body:JSON.stringify({sku:sku,notify_tickets:tickets})})
            .then(function(r){return r.json();})
            .then(function(d){
                if(d.success){
                    item.className='stk-item stk-success';
                    item.dataset.stock='in_stock';
                    item.innerHTML='<div class="stk-sku">✅ '+_esc(sku)+'</div><div style="font-size:12px;color:var(--success);margin-top:4px;">ปลดล็อกแล้ว'+(d.notified>0?' · แจ้ง '+d.notified+' ร้าน':'')+'</div>';
                } else {
                    alert(d.message||'เกิดข้อผิดพลาด');
                    btn.disabled=false; btn.textContent='🔓 ปลดล็อก';
                }
            })
            .catch(function(){alert('Network error'); btn.disabled=false; btn.textContent='🔓 ปลดล็อก';});
        };

        // Toggle all checkboxes
        window.b2bToggleAll=function(btn){
            var list=btn.closest('.stk-bo-list');
            var checks=list.querySelectorAll('.bo-check');
            var allChecked=true;
            checks.forEach(function(c){if(!c.checked)allChecked=false;});
            checks.forEach(function(c){c.checked=!allChecked;});
        };

        // Mark OOS
        var oosModal=document.getElementById('oos-modal');
        var oosSku='';
        var oosItem=null;
        var oosEta=0;

        window.b2bMarkOOS=function(sku,name,btn){
            oosSku=sku; oosItem=btn.closest('.stk-item'); oosEta=0;
            document.getElementById('oos-modal-name').textContent=name+' ('+sku+')';
            document.querySelectorAll('.stk-eta-pill').forEach(function(p){p.classList.remove('selected');});
            document.getElementById('oos-confirm-btn').disabled=true;
            oosModal.classList.add('show');
        };
        window.b2bCloseOOS=function(){oosModal.classList.remove('show');};

        document.querySelectorAll('.stk-eta-pill').forEach(function(pill){
            pill.addEventListener('click',function(){
                document.querySelectorAll('.stk-eta-pill').forEach(function(p){p.classList.remove('selected');});
                this.classList.add('selected');
                oosEta=parseInt(this.dataset.days);
                document.getElementById('oos-confirm-btn').disabled=false;
            });
        });

        document.getElementById('oos-confirm-btn').addEventListener('click',function(){
            var btn=this; btn.disabled=true; btn.textContent='⏳ กำลังดำเนินการ...';
            fetch(API+'/admin-stock-mark-oos',{method:'POST',headers:headers,
                body:JSON.stringify({sku:oosSku,eta_days:oosEta})})
            .then(function(r){return r.json();})
            .then(function(d){
                if(d.success){
                    oosModal.classList.remove('show');
                    if(oosItem){
                        oosItem.className='stk-item oos';
                        oosItem.dataset.stock='oos';
                        oosItem.innerHTML='<div class="stk-sku">❌ '+_esc(oosSku)+'</div><div style="font-size:12px;color:var(--danger);margin-top:4px;">ตั้งหมดสต็อกแล้ว'+(d.eta_date?' · ETA: '+_esc(d.eta_date):'')+'</div>';
                    }
                } else { alert(d.message||'เกิดข้อผิดพลาด'); }
                btn.disabled=false; btn.textContent='⛔ ยืนยัน';
            })
            .catch(function(){alert('Network error'); btn.disabled=false; btn.textContent='⛔ ยืนยัน';});
        });

        // Close modal on backdrop click
        oosModal.addEventListener('click',function(e){if(e.target===oosModal)b2bCloseOOS();});
    })();
    </script>
    <?php
    return ob_get_clean();
}

