function b2b_render_tracking_entry_page() {
    $sig_status = function_exists('b2b_check_sig_status') ? b2b_check_sig_status('b2b-tracking/', 600) : 'missing';
    $is_wp_admin = current_user_can('manage_options');
    if ( $sig_status !== 'valid' && ! $is_wp_admin ) {
        return function_exists('b2b_access_denied_html')
            ? b2b_access_denied_html('เฉพาะ Admin เท่านั้น', $sig_status)
            : '<div style="text-align:center; padding:60px 20px;">🔒 Access Denied</div>';
    }

    $admin_gid = defined('B2B_ADMIN_GROUP_ID') ? B2B_ADMIN_GROUP_ID : '';
    $api_token = function_exists('b2b_create_session_token') ? b2b_create_session_token($admin_gid, 'admin') : '';
    $api_base = rest_url('b2b/v1');

    // Query orders awaiting shipping
    $orders = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>array('paid','awaiting_payment'),'compare'=>'IN')),
        'orderby'=>'date','order'=>'ASC'));

    $tier_red = array(); $tier_yellow = array(); $tier_green = array();
    $shop_map = array(); // shop_name => [orders]
    foreach ($orders as $o) {
        $tracking = get_field('tracking_number', $o->ID);
        if (!empty($tracking)) continue; // already has tracking

        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $total = floatval(get_field('total_amount', $o->ID));
        $days = floor((time() - get_post_time('U', true, $o->ID)) / 86400);
        $items_raw = get_field('order_items', $o->ID) ?: '';
        $items_preview = '';
        if (preg_match_all('/^(.+?)\s*\([A-Z0-9\-]+\)\s*x(\d+)/mu', $items_raw, $im, PREG_SET_ORDER)) {
            $parts = array();
            foreach ($im as $m) $parts[] = trim($m[1]).' x'.$m[2];
            $items_preview = implode(', ', $parts);
        }
        $claimed = get_field('claimed_by_admin', $o->ID) ?: '';

        // V.14.1: Include shipping address for modal display
        $d_addr = '';
        if ($dist) {
            $a = get_field('dist_address', $dist->ID) ?: '';
            $dt = get_field('dist_district', $dist->ID) ?: '';
            $pv = get_field('dist_province', $dist->ID) ?: '';
            $pc = get_field('dist_postcode', $dist->ID) ?: '';
            $d_addr = trim("$a $dt $pv $pc");
        }
        $d_phone = $dist ? (get_field('dist_phone', $dist->ID) ?: '') : '';

        $item = array('id'=>$o->ID,'shop'=>$shop,'shop_id'=>$dist?$dist->ID:0,'gid'=>$gid,
            'total'=>$total,'days'=>$days,'date'=>b2b_date('d/m H:i',get_post_time('U',true,$o->ID)),'items'=>mb_substr($items_preview,0,80),'claimed'=>$claimed,
            'addr'=>$d_addr,'phone'=>$d_phone);

        if ($days > 2) $tier_red[] = $item;
        elseif ($days >= 1) $tier_yellow[] = $item;
        else $tier_green[] = $item;

        if (!isset($shop_map[$shop])) $shop_map[$shop] = array();
        $shop_map[$shop][] = $item;
    }

    $total_pending = count($tier_red) + count($tier_yellow) + count($tier_green);

    // Recently shipped today
    $today_start = strtotime(b2b_date('Y-m-d') . ' 00:00:00');
    $shipped_orders = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>20,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>'shipped')),
        'orderby'=>'date','order'=>'DESC'));
    $recent_shipped = array();
    foreach ($shipped_orders as $o) {
        $sd = get_field('shipped_date', $o->ID);
        if (!$sd || strtotime($sd) < $today_start) continue;
        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $recent_shipped[] = array('id'=>$o->ID,'shop'=>$shop,'tracking'=>get_field('tracking_number',$o->ID)?:'-',
            'carrier'=>get_field('shipping_provider',$o->ID)?:'-','time'=>b2b_date('H:i',strtotime($sd)));
    }

