            'oos_ts'=>$oos_ts,'eta'=>$eta,'bo'=>$bo_list);
        if ($stock !== 'in_stock') $oos_products[] = $item;
        else $in_stock_products[] = $item;
    }
    $total_oos = count($oos_products);
    $total_in = count($in_stock_products);
