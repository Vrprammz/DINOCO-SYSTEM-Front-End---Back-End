            <div style="font-size:13px; font-weight:600; margin-bottom:8px;">เลขพัสดุ:</div>
            <input type="text" id="trk-number" class="trk-input" placeholder="กรอกเลขพัสดุ">

            <div id="trk-batch-wrap" class="hidden">
                <div class="trk-batch-section">
                    <div style="font-size:12px; font-weight:600; margin-bottom:6px;">📦 รวมส่งกับออเดอร์อื่น (ร้านเดียวกัน)</div>
                    <div id="trk-batch-list"></div>
                    <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">เลขพัสดุจะใช้เลขเดียวกันทั้งหมด</div>
                </div>
            </div>

            <div style="display:flex; gap:8px; margin-top:16px;">
                <button class="trk-btn" id="trk-submit-btn" style="flex:1; padding:10px 14px; font-size:13px;" disabled>📬 บันทึก + แจ้งลูกค้า</button>
                <button class="trk-btn" onclick="b2bCloseTracking()" style="flex:0 0 auto; padding:10px 14px; font-size:13px; background:var(--bg-row); color:var(--text-secondary);">ยกเลิก</button>
            </div>
        </div>
    </div>

    <script>
    (function(){
        var API='<?php echo esc_js($api_base); ?>';
        var TOKEN='<?php echo esc_js($api_token); ?>';
        var headers={'Content-Type':'application/json','X-B2B-Token':TOKEN};
        function _esc(s){var d=document.createElement('span');d.textContent=s;return d.innerHTML;}

        // View switching
        document.querySelectorAll('.trk-pill[data-view]').forEach(function(btn){
            btn.addEventListener('click',function(){
                document.querySelectorAll('.trk-pill').forEach(function(b){b.classList.remove('active');});
                this.classList.add('active');
                var v=this.dataset.view;
                document.getElementById('view-urgency').classList.toggle('hidden',v!=='urgency');
                document.getElementById('view-shop').classList.toggle('hidden',v!=='shop');
                document.getElementById('view-shipped').classList.toggle('hidden',v!=='shipped');
            });
        });

        // Search
        document.getElementById('trk-search').addEventListener('input',function(){
            var q=this.value.toLowerCase();
            document.querySelectorAll('.trk-order,.trk-shop-group,.trk-shipped').forEach(function(el){
                var text=(el.textContent||'').toLowerCase();
                el.classList.toggle('hidden',q&&text.indexOf(q)===-1);
            });
        });

        // Tracking modal state
        var trkModal=document.getElementById('trk-modal');
        var trkTicketIds=[];
        var trkCarrier='';
        var trkShopOrders=<?php echo wp_json_encode($shop_map); ?>;

        // Open tracking modal for single order (V.14.1: +addr, +phone)
        window.b2bOpenTracking=function(ticketId,shop,total,items,addr,phone){
            trkTicketIds=[ticketId];
            document.getElementById('trk-modal-title').textContent='📬 กรอกเลขพัสดุ #'+ticketId;
            var subText=shop+' · ฿'+Number(total).toLocaleString('th-TH');
            if(addr) subText+='\n📦 '+addr;
            if(phone) subText+='\n📞 '+phone;
            document.getElementById('trk-modal-sub').textContent=subText;
            document.getElementById('trk-modal-sub').style.whiteSpace='pre-line';
            document.getElementById('trk-modal-items').textContent=items||'';
            document.getElementById('trk-number').value='';
            trkCarrier='';
            document.querySelectorAll('.trk-carrier-pill').forEach(function(p){p.classList.remove('selected');});
            document.getElementById('trk-custom-carrier-wrap').classList.add('hidden');
            document.getElementById('trk-submit-btn').disabled=true;

            // Check if same shop has other pending orders
            var batchWrap=document.getElementById('trk-batch-wrap');
            var batchList=document.getElementById('trk-batch-list');
            batchList.innerHTML='';
            var shopOrders=null;
            for(var s in trkShopOrders){
                var found=false;
                trkShopOrders[s].forEach(function(o){if(o.id===ticketId)found=true;});
                if(found&&trkShopOrders[s].length>1){shopOrders=trkShopOrders[s];break;}
            }
            if(shopOrders&&shopOrders.length>1){
                shopOrders.forEach(function(o){
                    if(o.id===ticketId)return;
                    var row=document.createElement('div');
                    row.className='trk-batch-row';
                    row.innerHTML='<label><input type="checkbox" class="batch-check" value="'+o.id+'"> #'+o.id+' · ฿'+Number(o.total).toLocaleString('th-TH')+'</label>';
                    batchList.appendChild(row);
                });
                batchWrap.classList.remove('hidden');
            } else {
                batchWrap.classList.add('hidden');
            }

            trkModal.classList.add('show');
        };

        // Batch shop entry
        window.b2bBatchShop=function(shopName){
            var orders=trkShopOrders[shopName]||[];
            if(!orders.length)return;
            trkTicketIds=orders.map(function(o){return o.id;});
            document.getElementById('trk-modal-title').textContent='📬 กรอกเลขพัสดุรวม';
            document.getElementById('trk-modal-sub').textContent='🏪 '+shopName+' · '+orders.length+' ออเดอร์';
            document.getElementById('trk-modal-items').textContent='ใช้เลขพัสดุเดียวกันทั้งหมด';
            document.getElementById('trk-number').value='';
            trkCarrier='';
            document.querySelectorAll('.trk-carrier-pill').forEach(function(p){p.classList.remove('selected');});
            document.getElementById('trk-custom-carrier-wrap').classList.add('hidden');
            document.getElementById('trk-submit-btn').disabled=true;
            document.getElementById('trk-batch-wrap').classList.add('hidden');
            trkModal.classList.add('show');
        };

        window.b2bCloseTracking=function(){trkModal.classList.remove('show');};
        trkModal.addEventListener('click',function(e){if(e.target===trkModal)b2bCloseTracking();});

        // Carrier selection
        document.querySelectorAll('.trk-carrier-pill').forEach(function(pill){
            pill.addEventListener('click',function(){
                document.querySelectorAll('.trk-carrier-pill').forEach(function(p){p.classList.remove('selected');});
                this.classList.add('selected');
                trkCarrier=this.dataset.carrier;
                if(!trkCarrier){
                    document.getElementById('trk-custom-carrier-wrap').classList.remove('hidden');
                    document.getElementById('trk-custom-carrier').focus();
                } else {
                    document.getElementById('trk-custom-carrier-wrap').classList.add('hidden');
                }
                checkTrkReady();
            });
        });

        var trkNumberEl=document.getElementById('trk-number');
        var trkCustomEl=document.getElementById('trk-custom-carrier');
        trkNumberEl.addEventListener('input',checkTrkReady);
        trkCustomEl.addEventListener('input',function(){trkCarrier=this.value; checkTrkReady();});

        function checkTrkReady(){
            var carrier=trkCarrier||trkCustomEl.value;
            var number=trkNumberEl.value.trim();
            // Rider/Lalamove ไม่ต้องกรอกเลขพัสดุ
            var isRider=(carrier==='Rider'||carrier==='Lalamove');
            var trkWrap=document.getElementById('trk-number').parentNode;
            if(isRider){trkWrap.style.opacity='0.4';document.getElementById('trk-number').placeholder='ไม่ต้องกรอก (Rider มารับ)';}
            else{trkWrap.style.opacity='1';document.getElementById('trk-number').placeholder='กรอกเลขพัสดุ';}
            document.getElementById('trk-submit-btn').disabled=!(carrier&&(number||isRider));
        }

        // Submit tracking
        document.getElementById('trk-submit-btn').addEventListener('click',function(){
            var btn=this;
            var carrier=trkCarrier||trkCustomEl.value.trim();
            var number=trkNumberEl.value.trim();
            var isRider=(carrier==='Rider'||carrier==='Lalamove'||carrier==='Grab');
            if(!carrier||(!number&&!isRider))return;

            // Collect batch tickets
            var ids=trkTicketIds.slice();
            document.querySelectorAll('.batch-check:checked').forEach(function(c){
                var v=parseInt(c.value);
                if(ids.indexOf(v)===-1)ids.push(v);
            });

            if(!confirm('บันทึกเลขพัสดุ '+ids.length+' รายการ?'))return;
            btn.disabled=true; btn.textContent='⏳ กำลังบันทึก...';

            var entries=ids.map(function(id){return{ticket_id:id,tracking_number:number,carrier:carrier};});

            fetch(API+'/admin-submit-tracking',{method:'POST',headers:headers,
                body:JSON.stringify({entries:entries})})
            .then(function(r){return r.json();})
            .then(function(d){
                if(d.success){
                    trkModal.classList.remove('show');
                    // Update DOM: mark submitted orders
                    ids.forEach(function(id){
                        var el=document.querySelector('.trk-order[data-id="'+id+'"]');
                        if(el){
                            el.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;"><div><span style="font-size:13px;font-weight:600;">🚚 #'+_esc(''+id)+'</span><div style="font-size:11px;color:var(--success);">'+_esc(carrier)+' · '+_esc(number)+'</div></div><span style="font-size:11px;color:var(--success);">✅ ส่งแล้ว</span></div>';
                            el.style.background='#f0fdf4';
                            el.style.borderLeft='4px solid var(--success)';
                        }
                    });
                    if(d.errors&&d.errors.length>0) alert('บันทึก '+d.updated+' รายการ\nข้อผิดพลาด:\n'+d.errors.join('\n'));
                } else {
                    alert(d.message||'เกิดข้อผิดพลาด');
                }
                btn.disabled=false; btn.textContent='📬 บันทึก + แจ้งลูกค้า';
            })
            .catch(function(){alert('Network error'); btn.disabled=false; btn.textContent='📬 บันทึก + แจ้งลูกค้า';});
        });
    })();
    </script>
    <?php
    return ob_get_clean();
}

// Helper: render single tracking order row
if ( ! function_exists('b2b_render_tracking_order_row') ) {
    function b2b_render_tracking_order_row($o, $color) {
        $urgency = '';
        if ($o['days'] > 2) $urgency = '<span style="color:var(--danger); font-size:11px;">⚠️ ค้าง '.$o['days'].' วัน</span>';
        elseif ($o['days'] >= 1) $urgency = '<span style="color:var(--warning); font-size:11px;">'.$o['days'].' วัน</span>';
        else $urgency = '<span style="color:var(--success); font-size:11px;">วันนี้</span>';

        $claimed = $o['claimed'] ? '<div style="font-size:10px;color:#8b5cf6;margin-top:2px;">✋ '.esc_html($o['claimed']).'</div>' : '';
        $items_js = esc_js($o['items']);
        $shop_js = esc_js($o['shop']);
        $addr_js = esc_js(isset($o['addr']) ? $o['addr'] : '');
        $phone_js = esc_js(isset($o['phone']) ? $o['phone'] : '');

        return '<div class="trk-order" data-id="'.$o['id'].'" data-shop="'.esc_attr($o['shop']).'">'
            .'<div class="trk-head">'
            .'<div><div class="trk-id" style="color:'.$color.';">#'.$o['id'].' · '.esc_html(mb_substr($o['shop'],0,18)).'</div>'
            .'<div class="trk-shop">'.$o['date'].' · '.$urgency.'</div>'
            .($o['items'] ? '<div class="trk-items">'.esc_html($o['items']).'</div>' : '')
            .$claimed.'</div>'
            .'<div class="trk-amount" style="color:'.$color.';">฿'.number_format($o['total'],0).'</div></div>'
            .'<button class="trk-btn" onclick="b2bOpenTracking('.$o['id'].',\''.$shop_js.'\','.$o['total'].',\''.$items_js.'\',\''.$addr_js.'\',\''.$phone_js.'\')">📬 กรอกเลขพัสดุ</button>'
            .'</div>';
    }
}
