        return function_exists('b2b_access_denied_html')
            ? b2b_access_denied_html('เฉพาะ Admin เท่านั้น', $sig_status)
            : '<div style="text-align:center; padding:60px 20px;">🔒 Access Denied</div>';
    }

    // Create admin session token for REST API calls
    $admin_gid = defined('B2B_ADMIN_GROUP_ID') ? B2B_ADMIN_GROUP_ID : '';
    $api_token = function_exists('b2b_create_session_token') ? b2b_create_session_token($admin_gid, 'admin') : '';
    $api_base = rest_url('b2b/v1');

    // Query all products server-side
    $products = get_posts(array('post_type'=>'b2b_product','posts_per_page'=>-1,'post_status'=>'publish','orderby'=>'title','order'=>'ASC'));
    $bo_tickets = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'order_status','value'=>'backorder'))));

    // Build SKU → BO tickets map
    $bo_map = array(); // sku => [{ticket_id, shop, total}]
    foreach ($bo_tickets as $bt) {
        $items_text = get_field('order_items', $bt->ID) ?: '';
        $gid = get_field('source_group_id', $bt->ID);
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '-';
        $total = floatval(get_field('total_amount', $bt->ID));
        if (preg_match_all('/\(([A-Z0-9\-]+)\)/i', $items_text, $skus)) {
            foreach ($skus[1] as $sku) {
                $sku = strtoupper($sku);
                if (!isset($bo_map[$sku])) $bo_map[$sku] = array();
                $bo_map[$sku][] = array('id'=>$bt->ID,'shop'=>$shop,'total'=>$total);
