add_shortcode( 'b2b_dashboard', 'b2b_render_dashboard_page' );

function b2b_render_dashboard_page() {

    // V.10.6-SEC: ลด max_age จาก 4 ชม. → 10 นาที (Admin page ต้อง strict)
    $sig_status = function_exists('b2b_check_sig_status') ? b2b_check_sig_status('b2b-dashboard/', 600) : 'missing';
    $is_wp_admin = current_user_can('manage_options');

    if ( $sig_status !== 'valid' && ! $is_wp_admin ) {
        $admin_msg = $sig_status === 'expired' ? '' : 'เฉพาะ Admin เท่านั้น — กรุณาเปิดผ่าน LINE';
        return function_exists('b2b_access_denied_html')
            ? b2b_access_denied_html($admin_msg, $sig_status)
            : '<div style="text-align:center; padding:60px 20px; font-size:16px; color:#94a3b8;">🔒 Access Denied</div>';
    }

    $tab = isset($_GET['tab']) ? sanitize_text_field($_GET['tab']) : 'overview';
    $labels = function_exists('b2b_get_status_labels') ? b2b_get_status_labels() : array();
    $base_url = strtok(esc_url_raw($_SERVER['REQUEST_URI']), '?');
    $base = defined('B2B_SITE_URL') ? B2B_SITE_URL : '';

    $tab_url = function($t) {
        return function_exists('b2b_liff_url') ? b2b_liff_url('b2b-dashboard/', array('tab'=>$t)) : '?tab='.$t;
    };
    $ticket_url = function($id) use ($base) {
        return function_exists('b2b_liff_url') ? b2b_liff_url('b2b-ticket/', array('ticket_id'=>$id, 'view'=>'admin')) : $base.'/b2b-ticket/?ticket_id='.$id.'&view=admin';
    };

    $tabs = array(
        'overview'  => '📊 สรุป',
        'sales'     => '💰 ยอด',
        'shipping'  => '📦 จัดส่ง',
        'confirm'   => '📋 รอยืนยัน',
        'payment'   => '💳 รอชำระ',
        'debts'     => '🏦 หนี้',
        'backorder' => '🚫 BO',
        'flash'     => '⚡ Flash',
    );

    // V.10.0 A8: Date range filter
    $date_range = isset($_GET['range']) ? sanitize_text_field($_GET['range']) : 'today';
    $date_ranges = array('today'=>'วันนี้','week'=>'สัปดาห์นี้','month'=>'เดือนนี้','all'=>'ทั้งหมด');
    switch ($date_range) {
        case 'week': $today_ts = strtotime(b2b_date('Y-m-d')); $wday = intval(b2b_date('N', $today_ts)); $date_after = b2b_date('Y-m-d 00:00:00', $today_ts - (($wday - 1) * 86400)); break;
        case 'month': $date_after = b2b_date('Y-m-01 00:00:00'); break;
        case 'all': $date_after = '2020-01-01 00:00:00'; break;
        default: $date_after = b2b_date('Y-m-d 00:00:00'); $date_range = 'today'; break;
    }
    $range_url = function($r) use ($tab_url, $tab) {
        $url = $tab_url($tab);
        return add_query_arg('range', $r, $url);
    };

    ob_start();

    if ( function_exists('b2b_liff_page_css') ) {
        echo b2b_liff_page_css();
    } else {
        echo b2b_dashboard_fallback_css();
    }
    // V.10.6: Black CI header + Tab scroll fix + extra CSS
    echo '<style>
:root { --brand-navy: #111 !important; --brand-navy-end: #1a1a1a !important; }
.b2b-header { background: linear-gradient(135deg, #111 0%, #1a1a1a 100%) !important; }
.b2b-header .logo-row img { width: 48px; height: 48px; border-radius: 10px; object-fit: contain; }
.b2b-header .logo-row .logo-right { height: 22px !important; width: auto !important; border-radius: 0 !important; }
.dash-filter-bar { display: flex; gap: 8px; padding: 8px 16px; }
.dash-filter-group { display: flex; align-items: center; gap: 6px; flex: 1; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 4px 10px; }
.dash-filter-icon { font-size: 16px; flex-shrink: 0; line-height: 1; }
.dash-filter-select { flex: 1; border: none; background: transparent; font-size: 13px; font-weight: 600; color: var(--text); padding: 8px 0; font-family: var(--font); appearance: none; -webkit-appearance: none; outline: none; cursor: pointer; background-image: url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2712%27 height=%2712%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%2394a3b8%27 stroke-width=%272.5%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3E%3Cpolyline points=%276 9 12 15 18 9%27%3E%3C/polyline%3E%3C/svg%3E"); background-repeat: no-repeat; background-position: right 2px center; padding-right: 18px; }
.b2b-tab-wrap { position: relative; margin-bottom: 16px; }
.b2b-tab-wrap::after { content: ""; position: absolute; right: 0; top: 0; bottom: 0; width: 28px; background: linear-gradient(to right, transparent, var(--bg)); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; pointer-events: none; }
.b2b-tab-wrap .b2b-tab-bar { overflow-x: auto; -webkit-overflow-scrolling: touch; }
.b2b-tab-wrap .b2b-tab-bar::-webkit-scrollbar { display: none; }
.b2b-tab-wrap .b2b-tab { flex: 0 0 auto; padding: 10px 12px; min-width: auto; }
.b2b-claimed { font-size: 10px; color: #8b5cf6; margin-top: 2px; }
.b2b-bo-eta { font-size: 10px; color: #f97316; margin-top: 2px; }
.b2b-rank-sm { font-size: 10px; font-weight: 700; color: #f59e0b; margin-left: 4px; }
</style>';

    $admin_gid = defined('B2B_ADMIN_GROUP_ID') ? B2B_ADMIN_GROUP_ID : '';
    if ( function_exists('b2b_liff_guard_js') && ! $is_wp_admin ) {
        echo b2b_liff_guard_js('b2b-dashboard', $admin_gid);
    }
    ?>
    <div class="b2b-wrap">
        <div class="b2b-header">
            <div class="logo-row">
                <?php $logo_url = function_exists('b2b_get_logo_url') ? b2b_get_logo_url() : 'https://dinoco.in.th/wp-content/uploads/2026/02/logodnc.png'; ?>
                <div class="hdr-text">
                    <h1>📊 Admin Dashboard</h1>
                    <div class="sub">DINOCO · <?php echo b2b_date('d/m/Y H:i'); ?></div>
                </div>
                <img class="logo-right" src="<?php echo esc_url($logo_url); ?>" alt="DINOCO">
            </div>
        </div>

        <div class="b2b-tab-wrap">
        <div class="b2b-tab-bar">
            <?php foreach ($tabs as $tk => $tl) : ?>
            <a class="b2b-tab <?php echo $tab===$tk ? 'active' : ''; ?>"
               href="<?php echo esc_url($tab_url($tk)); ?>"><?php echo $tl; ?></a>
            <?php endforeach; ?>
        </div>
        </div>

        <?php
        // ═══════════════════════════════════════════════════
        // TAB: Overview — V.9: +MTD stat
        // ═══════════════════════════════════════════════════
        if ($tab === 'overview') :
            global $wpdb;
            // All statuses in one query
            $sc_raw = $wpdb->get_results("
                SELECT pm.meta_value AS s, COUNT(*) AS c
                FROM {$wpdb->posts} p
                INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'order_status'
                WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
                GROUP BY pm.meta_value
            ", ARRAY_A);
            $sc = array(); $grand = 0;
            foreach ($sc_raw as $r) { $sc[$r['s']] = intval($r['c']); $grand += intval($r['c']); }

            // Today's revenue
            $today_data = $wpdb->get_row($wpdb->prepare("
                SELECT COUNT(*) AS cnt, COALESCE(SUM(CAST(a.meta_value AS DECIMAL(12,2))),0) AS total
                FROM {$wpdb->posts} p
                INNER JOIN {$wpdb->postmeta} s ON p.ID = s.post_id AND s.meta_key = 'order_status'
                INNER JOIN {$wpdb->postmeta} a ON p.ID = a.post_id AND a.meta_key = 'total_amount'
                WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
                  AND s.meta_value NOT IN ('cancelled','cancel_requested')
                  AND p.post_date >= %s
            ", b2b_date('Y-m-d 00:00:00')));
            $today_ids = array(); // placeholder for count() usage below
            for ($i = 0; $i < intval($today_data->cnt); $i++) $today_ids[] = $i;
            $today_total = floatval($today_data->total);

            // V.9: MTD — month-to-date total
            $mtd_data = $wpdb->get_row($wpdb->prepare("
                SELECT COALESCE(SUM(CAST(a.meta_value AS DECIMAL(12,2))),0) AS total
                FROM {$wpdb->posts} p
                INNER JOIN {$wpdb->postmeta} s ON p.ID = s.post_id AND s.meta_key = 'order_status'
                INNER JOIN {$wpdb->postmeta} a ON p.ID = a.post_id AND a.meta_key = 'total_amount'
                WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
                  AND s.meta_value NOT IN ('cancelled','cancel_requested')
                  AND p.post_date >= %s
            ", b2b_date('Y-m-01 00:00:00')));
            $mtd_total = floatval($mtd_data->total);
        ?>
            <div class="b2b-card">
                <div class="b2b-stat-row">
                    <div class="b2b-stat">
                        <div class="num text-blue"><?php echo count($today_ids); ?></div>
                        <div class="lbl">ออเดอร์วันนี้</div>
                    </div>
                    <div class="b2b-stat">
                        <div class="num text-green">฿<?php echo number_format($today_total,0); ?></div>
                        <div class="lbl">ยอดขายวันนี้</div>
                    </div>
                    <div class="b2b-stat">
                        <div class="num" style="color:#8b5cf6;">฿<?php echo number_format($mtd_total,0); ?></div>
                        <div class="lbl">MTD เดือนนี้</div>
                    </div>
                </div>
            </div>

            <div class="b2b-card">
                <h2>📋 สรุปออเดอร์ทั้งหมด (<?php echo $grand; ?>)</h2>
                <?php
                // V.10.2 Fix: เพิ่ม draft + cancel_requested ให้ครบทุกสถานะ
                $display_order = array('draft','checking_stock','awaiting_confirm','awaiting_payment','shipped','paid','backorder','completed','cancel_requested','cancelled');
                foreach ($display_order as $sk) :
                    if (!isset($sc[$sk])) continue;
                    $sl = isset($labels[$sk]) ? $labels[$sk] : $sk;
                ?>
                <div class="b2b-info-row">
                    <span class="k"><?php echo esc_html($sl); ?></span>
                    <span class="v"><?php echo $sc[$sk]; ?></span>
                </div>
                <?php endforeach; ?>
            </div>

        <?php
        // ═══════════════════════════════════════════════════
        // TAB: Sales
        // ═══════════════════════════════════════════════════
        elseif ($tab === 'sales') :
            // V.11.0: Status filter for sales tab
            global $wpdb;
            $sales_status = isset($_GET['status']) ? sanitize_text_field($_GET['status']) : 'all';
            $sales_filters = array(
                'all'              => 'ทั้งหมด',
                'paid'             => '✅ ชำระแล้ว',
                'shipped'          => '🚚 จัดส่งแล้ว',
                'completed'        => '🏁 สำเร็จ',
                'awaiting_payment' => '💳 รอชำระ',
            );

            // V.21.5: Use SQL aggregation instead of get_posts(-1) + loop to prevent memory issues
            $status_where = '';
            if ($sales_status !== 'all' && array_key_exists($sales_status, $sales_filters)) {
                $status_where = $wpdb->prepare("AND s.meta_value = %s", $sales_status);
            } else {
                $status_where = "AND s.meta_value NOT IN ('cancelled','cancel_requested')";
            }
            $sales_agg = $wpdb->get_row("
                SELECT COUNT(*) AS cnt, COALESCE(SUM(CAST(a.meta_value AS DECIMAL(12,2))),0) AS total
                FROM {$wpdb->posts} p
                INNER JOIN {$wpdb->postmeta} s ON p.ID = s.post_id AND s.meta_key = 'order_status'
                LEFT JOIN {$wpdb->postmeta} a ON p.ID = a.post_id AND a.meta_key = 'total_amount'
                WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
                  AND p.post_date >= '{$date_after}'
                  {$status_where}
            ");
            $count = $sales_agg ? intval($sales_agg->cnt) : 0;
            $total = $sales_agg ? floatval($sales_agg->total) : 0;

            // Build meta query for order list (paginated, max 20)
            $sales_meta = array();
            if ($sales_status !== 'all' && array_key_exists($sales_status, $sales_filters)) {
                $sales_meta[] = array('key'=>'order_status','value'=>$sales_status);
            } else {
                $sales_meta[] = array('key'=>'order_status','value'=>array('cancelled','cancel_requested'),'compare'=>'NOT IN');
            }

            $sales_filter_url = function($st) use ($tab_url, $date_range) {
                $url = $tab_url('sales');
                $url = add_query_arg('range', $date_range, $url);
                if ($st !== 'all') $url = add_query_arg('status', $st, $url);
                return $url;
            };
        ?>
            <div class="dash-filter-bar">
                <div class="dash-filter-group">
                    <label class="dash-filter-icon" for="filterRange">📅</label>
                    <select class="dash-filter-select" id="filterRange" onchange="location.href=this.value">
                        <?php foreach ($date_ranges as $rk => $rl) : ?>
                        <option value="<?php echo esc_url(add_query_arg(array('range'=>$rk,'status'=>$sales_status), $tab_url('sales'))); ?>" <?php echo $date_range===$rk ? 'selected' : ''; ?>><?php echo esc_html($rl); ?></option>
                        <?php endforeach; ?>
                    </select>
                </div>
                <div class="dash-filter-group">
                    <label class="dash-filter-icon" for="filterStatus">📋</label>
                    <select class="dash-filter-select" id="filterStatus" onchange="location.href=this.value">
                        <?php foreach ($sales_filters as $fk => $fl) : ?>
                        <option value="<?php echo esc_url($sales_filter_url($fk)); ?>" <?php echo $sales_status===$fk ? 'selected' : ''; ?>><?php echo esc_html($fl); ?></option>
                        <?php endforeach; ?>
                    </select>
                </div>
            </div>

            <div class="b2b-card">
                <div class="b2b-stat-row">
                    <div class="b2b-stat">
                        <div class="num text-blue"><?php echo $count; ?></div>
                        <div class="lbl">ออเดอร์<?php echo esc_html($date_ranges[$date_range]); ?></div>
                    </div>
                    <div class="b2b-stat">
                        <div class="num text-green">฿<?php echo number_format($total,0); ?></div>
                        <div class="lbl">ยอดรวม</div>
                    </div>
                </div>
            </div>

            <?php if ($count > 0) :
                $today_full = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>20,'post_status'=>'publish',
                    'date_query'=>array(array('after'=>$date_after,'inclusive'=>true)),
                    'meta_query'=>$sales_meta,
                    'orderby'=>'date','order'=>'DESC'));
            ?>
            <div class="b2b-card">
                <h2>📝 ออเดอร์<?php echo esc_html($date_ranges[$date_range]); ?></h2>
                <?php foreach ($today_full as $o) :
                    $gid_o = get_field('source_group_id', $o->ID);
                    $d = $gid_o && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid_o) : null;
                    $sn = $d ? (get_field('shop_name', $d->ID) ?: get_the_title($d->ID)) : '-';
                    $t = floatval(get_field('total_amount', $o->ID));
                    $sl = isset($labels[get_field('order_status', $o->ID)]) ? $labels[get_field('order_status', $o->ID)] : '';
                ?>
                <a class="b2b-row" href="<?php echo esc_url($ticket_url($o->ID)); ?>">
                    <div class="left">
                        <div>
                            <div class="label">#<?php echo $o->ID; ?> <?php echo esc_html(mb_substr($sn,0,15)); ?></div>
                            <div class="desc"><?php echo b2b_date('H:i', get_post_time('U', true, $o->ID)); ?> · <?php echo esc_html($sl); ?></div>
                        </div>
                    </div>
                    <div class="v text-green">฿<?php echo number_format($t,0); ?></div>
                </a>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>

        <?php
        // ═══════════════════════════════════════════════════
        // TAB: Shipping — V.11.1: Merged shipping+overdue, 3-tier urgency
        // ═══════════════════════════════════════════════════
        elseif ($tab === 'shipping') :
            $orders = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
                'meta_query'=>array(array('key'=>'order_status','value'=>'awaiting_payment')),
                'orderby'=>'date','order'=>'ASC'));
            if (!empty($orders)) { if (function_exists('update_post_meta_cache')) update_post_meta_cache(wp_list_pluck($orders, 'ID')); }
            // 3-tier urgency: red >2d, yellow 1-2d, green 0d
            $tier_red = array(); $tier_yellow = array(); $tier_green = array();
            foreach ($orders as $o) {
                $days = floor((time() - get_post_time('U', true, $o->ID)) / 86400);
                $o->_days_pending = $days;
                if ($days > 2) $tier_red[] = $o;
                elseif ($days >= 1) $tier_yellow[] = $o;
                else $tier_green[] = $o;
            }
        ?>
            <div class="b2b-card">
                <div class="b2b-stat-row">
                    <div class="b2b-stat">
                        <div class="num text-red"><?php echo count($tier_red); ?></div>
                        <div class="lbl">🔴 เกิน 2 วัน</div>
                    </div>
                    <div class="b2b-stat">
                        <div class="num" style="color:#f59e0b;"><?php echo count($tier_yellow); ?></div>
                        <div class="lbl">🟡 1-2 วัน</div>
                    </div>
                    <div class="b2b-stat">
                        <div class="num text-green"><?php echo count($tier_green); ?></div>
                        <div class="lbl">🟢 วันนี้</div>
                    </div>
                </div>
                <div style="font-size:12px;color:#64748b;text-align:center;margin-top:8px;">รอจัดส่งทั้งหมด <?php echo count($orders); ?> รายการ</div>
            </div>

            <?php if (empty($orders)) : ?>
            <div class="b2b-card">
                <div class="b2b-empty" style="padding:20px;"><div class="em">✅</div><p>ไม่มีรายการรอจัดส่ง</p></div>
            </div>
            <?php else : ?>

            <?php if (!empty($tier_red)) : ?>
            <div class="b2b-card">
                <h2 style="color:#dc2626;">🔴 ค้างเกิน 2 วัน — ต้องรีบจัดส่ง! (<?php echo count($tier_red); ?>)</h2>
                <?php foreach ($tier_red as $o) :
                    $gid_o = get_field('source_group_id', $o->ID);
                    $d = $gid_o && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid_o) : null;
                    $sn = $d ? (get_field('shop_name', $d->ID) ?: get_the_title($d->ID)) : '-';
                    $t = floatval(get_field('total_amount', $o->ID));
                    $claimed = get_field('claimed_by_admin', $o->ID) ?: '';
                ?>
                <a class="b2b-row" href="<?php echo esc_url($ticket_url($o->ID)); ?>">
                    <div class="left">
                        <div>
                            <div class="label" style="font-weight:700;">#<?php echo $o->ID; ?> <?php echo esc_html(mb_substr($sn,0,15)); ?></div>
                            <div class="desc text-red" style="font-weight:600;">⚠️ ค้าง <?php echo $o->_days_pending; ?> วัน · <?php echo b2b_date('d/m H:i', get_post_time('U', true, $o->ID)); ?></div>
                            <?php if ($claimed) : ?><div class="b2b-claimed">✋ <?php echo esc_html($claimed); ?></div><?php endif; ?>
                        </div>
                    </div>
                    <div class="v text-red" style="font-weight:700;">฿<?php echo number_format($t,0); ?></div>
                </a>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>

            <?php if (!empty($tier_yellow)) : ?>
            <div class="b2b-card">
                <h2 style="color:#f59e0b;">🟡 1-2 วัน (<?php echo count($tier_yellow); ?>)</h2>
                <?php foreach ($tier_yellow as $o) :
                    $gid_o = get_field('source_group_id', $o->ID);
                    $d = $gid_o && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid_o) : null;
                    $sn = $d ? (get_field('shop_name', $d->ID) ?: get_the_title($d->ID)) : '-';
                    $t = floatval(get_field('total_amount', $o->ID));
                    $claimed = get_field('claimed_by_admin', $o->ID) ?: '';
                ?>
                <a class="b2b-row" href="<?php echo esc_url($ticket_url($o->ID)); ?>">
