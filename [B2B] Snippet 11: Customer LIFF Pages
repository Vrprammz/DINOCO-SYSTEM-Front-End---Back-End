// V.9: Rank label helper
if ( ! function_exists( 'b2b_rank_label_html' ) ) {
    function b2b_rank_label_html( $rank ) {
        $labels = array('silver'=>'🥈 Silver','gold'=>'🥇 Gold','platinum'=>'💎 Platinum','diamond'=>'💠 Diamond');
        if ( empty($rank) || $rank === 'standard' ) return '';
        $lbl = isset($labels[$rank]) ? $labels[$rank] : ucfirst($rank);
        return '<span class="rank-tag">' . esc_html($lbl) . '</span>';
    }
}

