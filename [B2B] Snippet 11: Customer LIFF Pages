add_shortcode( 'b2b_commands', 'b2b_render_commands_page' );
function b2b_render_commands_page() {
    $sig_status = function_exists('b2b_check_sig_status') ? b2b_check_sig_status('b2b-commands/') : 'missing';
    if ( $sig_status !== 'valid' ) {
        return function_exists('b2b_access_denied_html') ? b2b_access_denied_html('', $sig_status) : '🔒 Access Denied';
    }
    $gid = b2b_liff_param('gid');
    $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
    $name = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : 'DINOCO';
    $rank = $dist ? (get_field('rank_system', $dist->ID) ?: 'standard') : 'standard';
    $rank_labels = array('standard'=>'Standard','silver'=>'Silver','gold'=>'Gold','platinum'=>'Platinum','diamond'=>'Diamond');
    $dist_thumb = $dist ? ( get_field('shop_logo_url', $dist->ID) ?: '' ) : '';
    $dist_initial = mb_substr($name, 0, 1);
    $base = defined('B2B_SITE_URL') ? B2B_SITE_URL : '';
    $gq = $gid ? '?gid='.urlencode($gid) : '';
    $liff_url = defined('B2B_LIFF_URL') ? B2B_LIFF_URL : '';

    $orders_link  = function_exists('b2b_liff_url') ? b2b_liff_url('b2b-orders/', $gid ? array('gid'=>$gid) : array()) : $base.'/b2b-orders/'.$gq;
