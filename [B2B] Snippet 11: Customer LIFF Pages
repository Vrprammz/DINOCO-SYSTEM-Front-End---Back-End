    <script>
    (function(){
      var REST_URL='<?php echo esc_url(rest_url("b2b/v1/")); ?>';
      var bankText='<?php echo esc_js($bank_info["name"] . "\n" . $bank_info["account"] . "\nชื่อ: " . $bank_info["holder"]); ?>';
      var selectedIds=[];

      function escapeHtml(str) {
          if (!str) return '';
          var div = document.createElement('div');
          div.appendChild(document.createTextNode(str));
          return div.innerHTML;
      }

      function fmt(n){return n.toLocaleString('th-TH',{minimumFractionDigits:0});}

      /* ── Checkbox toggle ── */
      window.toggleBillCb=function(row){
        var cb=row.querySelector('.bill-cb');
        cb.checked=!cb.checked;
        row.classList.toggle('checked',cb.checked);
        updateSelBar();
        updateToggleAll();
      };
      window.toggleAllClick=function(){
        var allCbs=document.querySelectorAll('.bill-cb');
        var allChecked=true;
        allCbs.forEach(function(cb){if(!cb.checked)allChecked=false;});
        var on=!allChecked;
        allCbs.forEach(function(cb){
          cb.checked=on;
          cb.closest('.bill-sel-row').classList.toggle('checked',on);
        });
        updateSelBar();
        updateToggleAll();
      };
      function updateToggleAll(){
        var btn=document.getElementById('toggleAllBtn');
        if(!btn)return;
        var allCbs=document.querySelectorAll('.bill-cb');
        var allChecked=true;
        allCbs.forEach(function(cb){if(!cb.checked)allChecked=false;});
        btn.classList.toggle('all-checked',allChecked);
      }

      function getSelected(){
        var items=[];
        document.querySelectorAll('.bill-cb:checked').forEach(function(cb){
          items.push({id:parseInt(cb.value),amount:parseFloat(cb.dataset.amount),due:cb.dataset.due});
        });
        return items;
      }

      function updateSelBar(){
        var items=getSelected();
        var bar=document.getElementById('billSelBar');
        var spacer=document.getElementById('billSelSpacer');
        if(items.length===0){bar.style.display='none';if(spacer)spacer.style.display='none';return;}
        bar.style.display='block';
        if(spacer)spacer.style.display='block';
        var total=items.reduce(function(s,i){return s+i.amount;},0);
        document.getElementById('selCount').textContent=items.length;
        document.getElementById('selTotal').textContent=fmt(total);
        selectedIds=items.map(function(i){return i.id;});
      }

      /* ── Combined Payment Modal ── */
      window.openCombinedPay=function(){
        var items=getSelected();
        if(items.length===0)return;
        var body=document.getElementById('cpayBody');
        var html='';
        var total=0;
        items.forEach(function(it){
          html+='<div class="cpay-ticket"><span class="tid">#'+escapeHtml(String(it.id))+'</span><span style="font-size:11px;color:var(--text-muted)">'+escapeHtml(it.due)+'</span><span class="tamt">฿'+fmt(it.amount)+'</span></div>';
          total+=it.amount;
        });
        body.innerHTML=html;
        document.getElementById('cpayTotal').textContent='฿'+fmt(total);
        document.getElementById('cpaySlipPreview').style.display='none';
        document.getElementById('cpaySlipStatus').textContent='';
        document.getElementById('cpayUploadBtn').style.display='';
        document.getElementById('cpayOverlay').classList.add('show');
      };
      window.closeCpay=function(){
        document.getElementById('cpayOverlay').classList.remove('show');
      };

      /* ── Copy bank ── */
      window.cpCopyBank=function(){
        if(navigator.clipboard){navigator.clipboard.writeText(bankText).then(function(){alert('คัดลอกข้อมูลบัญชีแล้ว');});}
        else{prompt('คัดลอก:',bankText);}
      };

      /* ── Combined Invoice ── */
      window.viewCombinedInvoice=function(){
        var ids=selectedIds.join(',');
        if(!ids)return;
        var ov=document.getElementById('cpayInvOverlay');
        var pages=document.getElementById('cpayInvPages');
        pages.innerHTML='<div style="text-align:center;padding:40px;color:#fff;">กำลังสร้าง Invoice...</div>';
        ov.classList.add('show');
        fetch(REST_URL+'combined-invoice-gen?ticket_ids='+encodeURIComponent(ids)+'&format=json')
          .then(function(r){return r.json();})
          .then(function(d){
            if(d.success&&d.pages){
              var h='';
              d.pages.forEach(function(url){h+='<img src="'+escapeHtml(url)+'" alt="Invoice">';});
              pages.innerHTML=h;
            } else {
              pages.innerHTML='<div style="text-align:center;padding:40px;color:#f87171;">'+escapeHtml(d.message||'ไม่สามารถสร้าง Invoice ได้')+'</div>';
            }
          })
          .catch(function(e){pages.innerHTML='<div style="text-align:center;padding:40px;color:#f87171;">'+escapeHtml(e.message)+'</div>';});
      };
      window.closeCpayInv=function(){
        document.getElementById('cpayInvOverlay').classList.remove('show');
      };

      /* ── Slip Upload ── */
      window.handleCombinedSlip=function(input){
        if(!input.files||!input.files[0])return;
        var file=input.files[0];
        if(file.size>5*1024*1024){alert('ไฟล์ใหญ่เกิน 5MB');return;}
        var reader=new FileReader();
        var statusEl=document.getElementById('cpaySlipStatus');
        var previewEl=document.getElementById('cpaySlipPreview');
        reader.onload=function(e){
          previewEl.src=e.target.result;
          previewEl.style.display='block';
          statusEl.className='cpay-slip-status loading';
          statusEl.textContent='กำลังตรวจสอบสลิป...';
          document.getElementById('cpayUploadBtn').style.display='none';

          var base64=e.target.result.split(',')[1];
          fetch(REST_URL+'combined-slip-upload',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({ticket_ids:selectedIds,image_base64:base64})
          })
          .then(function(r){return r.json();})
          .then(function(d){
            if(d.success){
              statusEl.className='cpay-slip-status ok';
              statusEl.textContent='✅ ชำระเงินสำเร็จ! กำลังรีเฟรช...';
              setTimeout(function(){location.reload();},2000);
            } else {
              statusEl.className='cpay-slip-status err';
              statusEl.textContent='❌ '+(d.message||'เกิดข้อผิดพลาด');
              document.getElementById('cpayUploadBtn').style.display='';
            }
          })
          .catch(function(e){
            statusEl.className='cpay-slip-status err';
            statusEl.textContent='❌ '+e.message;
            document.getElementById('cpayUploadBtn').style.display='';
          });
        };
        reader.readAsDataURL(file);
        input.value='';
      };
    })();
    </script>
    <?php endif; ?>
    <?php
    return ob_get_clean();
}
