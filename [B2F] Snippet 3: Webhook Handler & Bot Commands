        // V.2.8: ENG labels
        $mk_cur_act = get_field( 'maker_currency', $maker['id'] ) ?: 'THB';
        $mk_eng_act = $mk_cur_act !== 'THB';

        // Verify PO belongs to this maker
        $po_maker = get_field( 'po_maker_id', $po_id );
        if ( intval( $po_maker ) !== intval( $maker['id'] ) ) {
            b2f_line_reply_raw( $reply_token, array( array(
                'type' => 'text', 'text' => $mk_eng_act ? '❌ This PO does not belong to your factory' : '❌ PO นี้ไม่ใช่ของโรงงานคุณ',
            ) ) );
            return;
        }

        // Transition to delivering
        $result = b2f_transition_order( $po_id, 'delivering', 'maker', 'Maker แจ้งส่งของ' );
        if ( is_wp_error( $result ) ) {
            b2f_line_reply_raw( $reply_token, array( array(
                'type' => 'text', 'text' => '❌ ' . $result->get_error_message(),
            ) ) );
            return;
        }

        $po_number = get_field( 'po_number', $po_id );
        update_field( 'po_actual_date', wp_date( 'Y-m-d' ), $po_id );

        // แจ้ง Admin (always Thai)
        $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
        if ( $admin_group && function_exists( 'b2f_build_flex_delivered' ) ) {
            b2f_line_push( $admin_group, array( b2f_build_flex_delivered( $po_id ) ) );
        } elseif ( $admin_group ) {
            b2f_line_push( $admin_group, array( array(
                'type' => 'text',
                'text' => "🚚 โรงงาน {$maker['name']} แจ้งส่งของ\nPO: {$po_number}\n\nกรุณาตรวจรับสินค้า",
            ) ) );
        }

        $reply_text = $mk_eng_act
            ? "✅ Shipment notification for {$po_number} submitted.\nDINOCO will inspect goods and update this group."
            : "✅ แจ้งส่งของ {$po_number} เรียบร้อย\nDINOCO จะตรวจรับสินค้าและแจ้งผลในกลุ่มนี้";
        b2f_line_reply_raw( $reply_token, array( array(
            'type' => 'text',
            'text' => $reply_text,
        ) ) );
    }
}

