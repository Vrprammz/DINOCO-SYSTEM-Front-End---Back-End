if ( ! function_exists( 'b2f_route_maker_command' ) ) {
    /**
     * Route commands จาก Maker LINE group
     * เรียกจาก B2B Snippet 2 เมื่อ group_id match b2f_maker
     *
     * @param array $event    LINE webhook event
     * @param array $maker    { id, name, group_id } จาก b2f_get_maker_by_group()
     */
    function b2f_route_maker_command( $event, $maker ) {
        $type = $event['type'] ?? '';

        // Bot enabled check — เหมือน B2B distributor toggle
        // Default = enabled (ถ้ายังไม่เคย set ค่า)
        $bot_val = get_post_meta( $maker['id'], 'maker_bot_enabled', true );
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Route maker: id=%d name=%s bot_val=[%s] type=%s', $maker['id'], $maker['name'], var_export( $bot_val, true ), $type ) );
        }
        if ( $bot_val === '0' || $bot_val === 0 ) {
            // Bot ถูกปิดสำหรับ Maker นี้ → เงียบ (ยกเว้น join event)
            if ( $type === 'join' ) { b2f_handle_join_event( $event ); }
            return;
        }

        if ( $type === 'message' && ( $event['message']['type'] ?? '' ) === 'text' ) {
            b2f_handle_maker_text( $event, $maker );
        } elseif ( $type === 'postback' ) {
            b2f_handle_maker_postback( $event, $maker );
        }
        // join event → bot ถูก invite เข้ากลุ่มใหม่
        elseif ( $type === 'join' ) {
            b2f_handle_join_event( $event );
        }
    }
}

if ( ! function_exists( 'b2f_handle_maker_text' ) ) {
    function b2f_handle_maker_text( $event, $maker ) {
        $raw_text = $event['message']['text'] ?? '';
        $reply_token = $event['replyToken'] ?? '';
        $group_id = $event['source']['groupId'] ?? '';

        // Dedup protection (60s)
        $msg_id = $event['message']['id'] ?? '';
        if ( $msg_id && get_transient( 'b2f_dedup_' . $msg_id ) ) return;
        if ( $msg_id ) set_transient( 'b2f_dedup_' . $msg_id, 1, 60 );

        // Check for mention — ตรวจจากทั้ง LINE API และ text pattern
        $is_mention = false;

        // วิธี 1: LINE API mentionees.isSelf
        if ( isset( $event['message']['mention']['mentionees'] ) ) {
            foreach ( $event['message']['mention']['mentionees'] as $m ) {
                if ( ! empty( $m['isSelf'] ) ) {
                    $is_mention = true;
                    break;
                }
            }
        }

        // วิธี 2: ตรวจจาก text — ถ้ามี @ อยู่ใน raw_text → ถือว่า mention เสมอ
        // (LINE mention อาจมี Unicode ที่ preg_match จับไม่ได้)
        if ( ! $is_mention && strpos( $raw_text, '@' ) !== false ) {
            $is_mention = true;
        }

        // Strip @mention text
        $text = $raw_text;
        $text = preg_replace( '/^@?DINOCO\s*B2B\s*System\s*/ui', '', $text );
        $text = preg_replace( '/^@?dinoco\s*/ui', '', $text );
        $text = preg_replace( '/^@\S+\s*/u', '', $text );
        // ลบ Unicode zero-width + invisible characters
        $text = preg_replace( '/[\x{200b}\x{200c}\x{200d}\x{feff}\x{00a0}]/u', '', $text );
        $text = trim( strtolower( $text ) );

        // วิธี 3: ถ้า strip แล้ว text ว่าง แต่ raw_text ไม่ว่าง → mention
        if ( ! $is_mention && empty( $text ) && ! empty( trim( $raw_text ) ) ) {
            $is_mention = true;
        }

        // Log สำหรับ debug @mention
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( '[MakerText] raw=[%s] stripped=[%s] is_mention=%s reply_token=%s', $raw_text, $text, $is_mention ? 'Y' : 'N', $reply_token ? 'yes' : 'empty' ) );
        }

        // @mention (text ว่างหรือไม่ก็ตาม) → แสดง Maker menu
        if ( $is_mention ) {
            $maker_name = $maker['name'] ?? 'โรงงาน';
            $maker_id = $maker['id'] ?? 0;
            $logo = 'https://dinoco.in.th/wp-content/uploads/2026/02/logodnc.png';

            // LIFF URLs — ใช้ JWT token (maker-level, ไม่ต้อง po_id)
            $menu_token = '';
            if ( class_exists( 'DINOCO_JWT' ) ) {
                $menu_token = DINOCO_JWT::create( array(
                    'maker_id' => intval( $maker_id ),
                ), 86400 * 3 );
            }
            $liff_id = defined( 'B2F_LIFF_ID' ) ? B2F_LIFF_ID : ( defined( 'B2B_LIFF_ID' ) ? B2B_LIFF_ID : '' );
            $liff_base = $liff_id ? 'https://liff.line.me/' . $liff_id . '/b2f-maker/' : '#';
            $url_po_list    = $liff_base !== '#' ? $liff_base . '?' . http_build_query( array( 'page' => 'list', 'token' => $menu_token ) ) : '#';
            $url_deliver    = $liff_base !== '#' ? $liff_base . '?' . http_build_query( array( 'page' => 'deliver', 'token' => $menu_token ) ) : '#';
            $url_reschedule = $liff_base !== '#' ? $liff_base . '?' . http_build_query( array( 'page' => 'reschedule', 'token' => $menu_token ) ) : '#';

            // นับ PO ค้าง
            $pending_q = new WP_Query( array( 'post_type' => 'b2f_order', 'posts_per_page' => -1, 'fields' => 'ids',
                'meta_query' => array( 'relation' => 'AND',
                    array( 'key' => 'po_maker_id', 'value' => $maker_id ),
                    array( 'key' => 'po_status', 'value' => array( 'submitted', 'confirmed', 'delivering', 'partial_received' ), 'compare' => 'IN' ),
                ),
            ) );
            $pending_count = $pending_q->found_posts;
            $subtitle = $pending_count > 0 ? 'ใบสั่งซื้อที่รอดำเนินการ: ' . $pending_count . ' รายการ' : 'ไม่มีใบสั่งซื้อที่รอดำเนินการ';

            $body_contents = array(
                // สรุป PO ค้าง
                array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'paddingAll' => '10px', 'cornerRadius' => '10px',
                    'backgroundColor' => $pending_count > 0 ? '#fffbeb' : '#f0fdf4',
                    'contents' => array(
                    array( 'type' => 'text', 'text' => $pending_count > 0 ? '📌' : '✅', 'flex' => 0, 'size' => 'lg' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'margin' => 'md', 'contents' => array(
                        array( 'type' => 'text', 'text' => $subtitle, 'size' => 'xs', 'color' => $pending_count > 0 ? '#92400e' : '#166534', 'weight' => 'bold', 'wrap' => true ),
                    ) ),
                ) ),
                array( 'type' => 'separator', 'margin' => 'lg' ),
                array( 'type' => 'text', 'text' => '📋 เมนูสำหรับโรงงาน', 'weight' => 'bold', 'size' => 'sm', 'color' => '#d97706', 'margin' => 'lg' ),
                // ดูใบสั่งซื้อ
                array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'margin' => 'md', 'paddingAll' => '10px',
                    'cornerRadius' => '10px', 'backgroundColor' => '#f8fafc',
                    'action' => array( 'type' => 'uri', 'label' => 'รายการใบสั่งซื้อ', 'uri' => $url_po_list ),
                    'contents' => array(
                    array( 'type' => 'text', 'text' => '📋', 'flex' => 0, 'gravity' => 'center', 'size' => 'xl' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'contents' => array(
                        array( 'type' => 'text', 'text' => 'รายการใบสั่งซื้อ', 'weight' => 'bold', 'size' => 'sm' ),
                        array( 'type' => 'text', 'text' => 'ดูใบสั่งซื้อทั้งหมด · ยืนยัน · ปฏิเสธ', 'size' => 'xs', 'color' => '#64748b', 'wrap' => true ),
                    ) ),
                ) ),
                // แจ้งจัดส่งสินค้า
                array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'margin' => 'sm', 'paddingAll' => '10px',
                    'cornerRadius' => '10px', 'backgroundColor' => '#f8fafc',
                    'action' => array( 'type' => 'uri', 'label' => 'แจ้งจัดส่งสินค้า', 'uri' => $url_deliver ),
                    'contents' => array(
                    array( 'type' => 'text', 'text' => '🚚', 'flex' => 0, 'gravity' => 'center', 'size' => 'xl' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'contents' => array(
                        array( 'type' => 'text', 'text' => 'แจ้งจัดส่งสินค้า', 'weight' => 'bold', 'size' => 'sm' ),
                        array( 'type' => 'text', 'text' => 'แจ้ง DINOCO ว่าจัดส่งสินค้าแล้ว', 'size' => 'xs', 'color' => '#64748b', 'wrap' => true ),
                    ) ),
                ) ),
                // ขอเลื่อนกำหนดส่ง
                array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'margin' => 'sm', 'paddingAll' => '10px',
                    'cornerRadius' => '10px', 'backgroundColor' => '#f8fafc',
                    'action' => array( 'type' => 'uri', 'label' => 'ขอเลื่อนกำหนดส่ง', 'uri' => $url_reschedule ),
                    'contents' => array(
                    array( 'type' => 'text', 'text' => '📅', 'flex' => 0, 'gravity' => 'center', 'size' => 'xl' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'contents' => array(
                        array( 'type' => 'text', 'text' => 'ขอเลื่อนกำหนดส่ง', 'weight' => 'bold', 'size' => 'sm' ),
                        array( 'type' => 'text', 'text' => 'แจ้งขอเลื่อนวันจัดส่งพร้อมเหตุผล', 'size' => 'xs', 'color' => '#64748b', 'wrap' => true ),
                    ) ),
                ) ),
            );

            $flex = array(
                'type' => 'flex',
                'altText' => '🏭 DINOCO — ' . $maker_name . ' (' . $pending_count . ' PO ค้าง)',
                'contents' => array(
                    'type' => 'bubble',
                    'size' => 'mega',
                    'header' => array(
                        'type' => 'box', 'layout' => 'vertical', 'backgroundColor' => '#0f2447', 'paddingAll' => '16px',
                        'contents' => array(
                            array( 'type' => 'box', 'layout' => 'horizontal', 'alignItems' => 'center', 'contents' => array(
                                array( 'type' => 'image', 'url' => $logo, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                                array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                                    array( 'type' => 'text', 'text' => 'DINOCO · ระบบสั่งซื้อ', 'weight' => 'bold', 'color' => '#ffffff', 'size' => 'md' ),
                                    array( 'type' => 'text', 'text' => $maker_name, 'color' => '#93c5fd', 'size' => 'sm', 'margin' => 'xs' ),
                                ) ),
                            ) ),
                        ),
                    ),
                    'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '14px', 'spacing' => 'sm', 'contents' => $body_contents ),
                ),
            );
            b2f_line_reply_raw( $reply_token, array( $flex ) );
            return;
        }

        // Pending reject — จับเหตุผลหลัง Maker กดปฏิเสธ
        $pending_po = get_transient( 'b2f_pending_reject_' . $maker['id'] );
        if ( $pending_po && ! empty( $raw_text ) && ! $is_mention ) {
            delete_transient( 'b2f_pending_reject_' . $maker['id'] );
            update_field( 'po_rejected_reason', sanitize_textarea_field( $raw_text ), $pending_po );
            $po_number = get_field( 'po_number', $pending_po ) ?: '#' . $pending_po;
            b2f_line_reply_raw( $reply_token, array( array(
                'type' => 'text',
                'text' => "📝 บันทึกเหตุผลปฏิเสธ {$po_number} แล้ว\nเหตุผล: " . mb_substr( $raw_text, 0, 100 ),
            ) ) );
            // Push Admin เหตุผล
            $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
            if ( $admin_group ) {
                b2f_line_push( $admin_group, array( array(
                    'type' => 'text',
                    'text' => "📝 เหตุผลปฏิเสธ {$po_number}:\n" . mb_substr( $raw_text, 0, 200 ),
                ) ) );
            }
            return;
        }

        // "ส่งของ" / "deliver"
        if ( in_array( $text, array( 'ส่งของ', 'deliver', 'ส่ง' ) ) ) {
            b2f_show_deliverable_pos( $reply_token, $maker );
            return;
        }

        // "ดูpo" / "po" / "ดูใบสั่งซื้อ"
        if ( in_array( $text, array( 'ดูpo', 'po', 'ดูใบสั่งซื้อ', 'ใบสั่งซื้อ' ) ) ) {
            b2f_show_maker_po_list( $reply_token, $maker );
            return;
        }

        // Catch-all: ข้อความที่ไม่ match คำสั่ง → เงียบ (ไม่ตอบทุกข้อความในกลุ่ม)
    }
}

if ( ! function_exists( 'b2f_handle_maker_postback' ) ) {
    function b2f_handle_maker_postback( $event, $maker ) {
        $data = $event['postback']['data'] ?? '';
        $reply_token = $event['replyToken'] ?? '';
        parse_str( $data, $params );
        $action = $params['action'] ?? '';
        $po_id = intval( $params['po_id'] ?? 0 );

        // Dedup
        $dedup_key = 'b2f_pb_' . md5( $data . ( $event['source']['userId'] ?? '' ) );
        if ( get_transient( $dedup_key ) ) return;
        set_transient( $dedup_key, 1, 10 );

        switch ( $action ) {
            case 'b2f_maker_deliver':
                b2f_action_maker_deliver( $reply_token, $po_id, $maker );
                break;

            case 'b2f_maker_confirm':
                // Maker ยืนยัน PO + เลือกวันส่ง (datetimepicker)
                $date = $event['postback']['params']['date'] ?? '';
                if ( empty( $date ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ กรุณาเลือกวันส่ง' ) ) );
                    break;
                }
                // Validate date > today
                $date_obj = DateTime::createFromFormat( 'Y-m-d', $date );
                $now = new DateTime( 'now', new DateTimeZone( 'Asia/Bangkok' ) );
                if ( ! $date_obj || $date_obj <= $now ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ วันส่งต้องเป็นวันในอนาคต' ) ) );
                    break;
                }
                // Verify ownership
                $po_maker = get_field( 'po_maker_id', $po_id );
                if ( intval( $po_maker ) !== intval( $maker['id'] ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ PO นี้ไม่ใช่ของโรงงานคุณ' ) ) );
                    break;
                }
                // Transition
                $result = b2f_transition_order( $po_id, 'confirmed', 'maker', 'Maker ยืนยัน วันส่ง: ' . $date );
                if ( is_wp_error( $result ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ ' . $result->get_error_message() ) ) );
                    break;
                }
                update_field( 'po_expected_date', $date, $po_id );
                $po_number = get_field( 'po_number', $po_id ) ?: '#' . $po_id;
                $thai_date = date( 'd/m/Y', strtotime( $date ) );
                // Reply Maker
                b2f_line_reply_raw( $reply_token, array( array(
                    'type' => 'text',
                    'text' => "✅ ยืนยัน {$po_number} เรียบร้อย\nวันส่ง: {$thai_date}\n\nDINOCO จะติดตามตามกำหนด",
                ) ) );
                // Push Flex to Admin (V.1.6: ใช้ Flex builder แทน text)
                $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
                if ( $admin_group && function_exists( 'b2f_build_flex_maker_confirmed' ) ) {
                    $flex = b2f_build_flex_maker_confirmed( $po_id, $date );
                    if ( $flex ) b2f_line_push( $admin_group, $flex );
                } elseif ( $admin_group ) {
                    b2f_line_push( $admin_group, array( array(
                        'type' => 'text',
                        'text' => "✅ โรงงาน {$maker['name']} ยืนยัน\nPO: {$po_number}\nวันส่ง: {$thai_date}",
                    ) ) );
                }
                break;

            case 'b2f_maker_reject':
                $po_maker = get_field( 'po_maker_id', $po_id );
                if ( intval( $po_maker ) !== intval( $maker['id'] ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ PO นี้ไม่ใช่ของโรงงานคุณ' ) ) );
                    break;
                }
                $result = b2f_transition_order( $po_id, 'rejected', 'maker', 'Maker ปฏิเสธ' );
                if ( is_wp_error( $result ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ ' . $result->get_error_message() ) ) );
                    break;
                }
                $po_number = get_field( 'po_number', $po_id ) ?: '#' . $po_id;
                b2f_line_reply_raw( $reply_token, array( array(
                    'type' => 'text',
                    'text' => "📝 บันทึกปฏิเสธ {$po_number} แล้ว\nกรุณาพิมพ์เหตุผลที่ปฏิเสธ:",
                ) ) );
                // Store pending reject — ข้อความถัดไปจะเป็นเหตุผล
                set_transient( 'b2f_pending_reject_' . $maker['id'], $po_id, 300 );
                // Push Flex to Admin (V.1.6: ใช้ Flex builder แทน text)
                $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
                if ( $admin_group && function_exists( 'b2f_build_flex_maker_rejected' ) ) {
                    $flex = b2f_build_flex_maker_rejected( $po_id, '(รอเหตุผลจาก Maker...)' );
                    if ( $flex ) b2f_line_push( $admin_group, $flex );
                } elseif ( $admin_group ) {
                    b2f_line_push( $admin_group, array( array(
                        'type' => 'text',
                        'text' => "❌ โรงงาน {$maker['name']} ปฏิเสธ\nPO: {$po_number}\n(รอเหตุผล...)",
                    ) ) );
                }
                break;

            case 'b2f_maker_po_detail':
                $items = get_field( 'po_items', $po_id ) ?: array();
                $po_number = get_field( 'po_number', $po_id ) ?: '#' . $po_id;
                $lines = array( "📋 {$po_number}", '' );
                foreach ( $items as $item ) {
                    $lines[] = ($item['poi_product_name'] ?: $item['poi_sku']) . ' x' . $item['poi_qty_ordered'] . ' ฿' . number_format( $item['poi_unit_cost'] * $item['poi_qty_ordered'], 2 );
                }
                $lines[] = '';
                $lines[] = 'รวม: ฿' . number_format( floatval( get_field( 'po_total_amount', $po_id ) ), 2 );
                b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => implode( "\n", $lines ) ) ) );
                break;

            case 'b2f_approve_reschedule':
            case 'b2f_reject_reschedule':
                // Admin actions — handled ใน admin group (ไม่ใช่ maker group)
                break;
        }
    }
}

