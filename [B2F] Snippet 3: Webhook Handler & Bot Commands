if ( ! function_exists( 'b2f_route_admin_command' ) ) {
    /**
     * Route B2F commands จาก Admin group
     * เรียกจาก B2B Snippet 2 สำหรับ B2F-specific keywords
     *
     * @param string $text        ข้อความที่พิมพ์
     * @param string $reply_token LINE reply token
     * @return bool true ถ้า handled, false ถ้าไม่ใช่ B2F command
     */
    function b2f_route_admin_command( $text, $reply_token ) {
        $text = trim( strtolower( $text ) );

        // "สั่งโรงงาน" / "สั่ง maker"
        if ( in_array( $text, array( 'สั่งโรงงาน', 'สั่ง maker', 'สั่งซื้อโรงงาน' ) ) ) {
            $liff_url = function_exists( 'b2f_liff_url' ) ? b2f_liff_url( 'b2f-create-po/' ) : '#';
            $flex = array(
                'type' => 'flex',
                'altText' => '🏭 สร้างใบสั่งซื้อโรงงาน',
                'contents' => array(
                    'type' => 'bubble',
                    'size' => 'kilo',
                    'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '16px', 'contents' => array(
                        array( 'type' => 'text', 'text' => '🏭 สร้างใบสั่งซื้อโรงงาน', 'weight' => 'bold', 'size' => 'md' ),
                        array( 'type' => 'text', 'text' => 'เลือกโรงงาน → เลือก SKU → กรอกจำนวน', 'size' => 'xs', 'color' => '#888888', 'margin' => 'sm' ),
                    ) ),
                    'footer' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '12px', 'contents' => array(
                        array( 'type' => 'button', 'style' => 'primary', 'color' => '#d97706', 'height' => 'sm',
                            'action' => array( 'type' => 'uri', 'label' => '📝 สร้าง PO', 'uri' => $liff_url ) ),
                    ) ),
                ),
            );
            b2f_line_reply_raw( $reply_token, array( $flex ) );
            return true;
        }

        // "ดูpo" / "po" / "สรุปโรงงาน"
        if ( in_array( $text, array( 'ดูpo', 'po', 'สรุปโรงงาน' ) ) ) {
            b2f_show_admin_po_summary( $reply_token );
            return true;
        }

        return false; // ไม่ใช่ B2F command
    }
}

