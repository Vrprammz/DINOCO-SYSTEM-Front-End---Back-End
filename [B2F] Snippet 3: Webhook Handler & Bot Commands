if ( ! function_exists( 'b2f_line_reply_raw' ) ) {
    function b2f_line_reply_raw( $reply_token, $messages ) {
        if ( empty( $reply_token ) ) return;
        $token = defined( 'B2B_LINE_ACCESS_TOKEN' ) ? B2B_LINE_ACCESS_TOKEN : '';
        if ( empty( $token ) ) return;

        wp_remote_post( 'https://api.line.me/v2/bot/message/reply', array(
            'headers' => array(
                'Content-Type'  => 'application/json',
                'Authorization' => 'Bearer ' . $token,
            ),
            'body'    => json_encode( array(
                'replyToken' => $reply_token,
                'messages'   => array_slice( $messages, 0, 5 ),
            ) ),
            'timeout' => 10,
        ) );
    }
}

