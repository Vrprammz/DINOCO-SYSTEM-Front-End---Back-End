if ( ! function_exists( 'b2f_route_maker_command' ) ) {
    /**
     * Route commands จาก Maker LINE group
     * เรียกจาก B2B Snippet 2 เมื่อ group_id match b2f_maker
     *
     * @param array $event    LINE webhook event
     * @param array $maker    { id, name, group_id } จาก b2f_get_maker_by_group()
     */
    function b2f_route_maker_command( $event, $maker ) {
        $type = $event['type'] ?? '';

        // Bot enabled check — เหมือน B2B distributor toggle
        // Default = enabled (ถ้ายังไม่เคย set ค่า)
        $bot_val = get_post_meta( $maker['id'], 'maker_bot_enabled', true );
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Route maker: id=%d name=%s bot_val=[%s] type=%s', $maker['id'], $maker['name'], var_export( $bot_val, true ), $type ) );
        }
        if ( $bot_val === '0' || $bot_val === 0 ) {
            // Bot ถูกปิดสำหรับ Maker นี้ → เงียบ (ยกเว้น join event)
            if ( $type === 'join' ) { b2f_handle_join_event( $event ); }
            return;
        }

        if ( $type === 'message' && ( $event['message']['type'] ?? '' ) === 'text' ) {
            b2f_handle_maker_text( $event, $maker );
        } elseif ( $type === 'message' && ( $event['message']['type'] ?? '' ) === 'image' ) {
            b2f_handle_maker_slip_image( $event, $maker );
        } elseif ( $type === 'postback' ) {
            b2f_handle_maker_postback( $event, $maker );
        }
        // join event → bot ถูก invite เข้ากลุ่มใหม่
        elseif ( $type === 'join' ) {
            b2f_handle_join_event( $event );
        }
    }
}

if ( ! function_exists( 'b2f_handle_maker_text' ) ) {
    function b2f_handle_maker_text( $event, $maker ) {
        $raw_text = $event['message']['text'] ?? '';
        $reply_token = $event['replyToken'] ?? '';
        $group_id = $event['source']['groupId'] ?? '';

        // Dedup protection (60s)
        $msg_id = $event['message']['id'] ?? '';
        if ( $msg_id && get_transient( 'b2f_dedup_' . $msg_id ) ) return;
        if ( $msg_id ) set_transient( 'b2f_dedup_' . $msg_id, 1, 60 );

        // Check for mention — ตรวจจากทั้ง LINE API และ text pattern
        $is_mention = false;

        // วิธี 1: LINE API mentionees.isSelf
        if ( isset( $event['message']['mention']['mentionees'] ) ) {
            foreach ( $event['message']['mention']['mentionees'] as $m ) {
                if ( ! empty( $m['isSelf'] ) ) {
                    $is_mention = true;
                    break;
                }
            }
        }

        // วิธี 2: ตรวจจาก text — ถ้ามี @ อยู่ใน raw_text → ถือว่า mention เสมอ
        // (LINE mention อาจมี Unicode ที่ preg_match จับไม่ได้)
        if ( ! $is_mention && strpos( $raw_text, '@' ) !== false ) {
            $is_mention = true;
        }

        // Strip @mention text
        $text = $raw_text;
        $text = preg_replace( '/^@?DINOCO\s*B2B\s*System\s*/ui', '', $text );
        $text = preg_replace( '/^@?dinoco\s*/ui', '', $text );
        $text = preg_replace( '/^@\S+\s*/u', '', $text );
        // ลบ Unicode zero-width + invisible characters
        $text = preg_replace( '/[\x{200b}\x{200c}\x{200d}\x{feff}\x{00a0}]/u', '', $text );
        $text = trim( strtolower( $text ) );

        // วิธี 3: ถ้า strip แล้ว text ว่าง แต่ raw_text ไม่ว่าง → mention
        if ( ! $is_mention && empty( $text ) && ! empty( trim( $raw_text ) ) ) {
            $is_mention = true;
        }

        // Log สำหรับ debug @mention
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( '[MakerText] raw=[%s] stripped=[%s] is_mention=%s reply_token=%s', $raw_text, $text, $is_mention ? 'Y' : 'N', $reply_token ? 'yes' : 'empty' ) );
        }

        // @mention (text ว่างหรือไม่ก็ตาม) → แสดง Maker menu
        if ( $is_mention ) {
            $maker_name = $maker['name'] ?? 'โรงงาน';
            $maker_id = $maker['id'] ?? 0;
            $logo = 'https://dinoco.in.th/wp-content/uploads/2026/02/logodnc.png';

            // V.2.8: ENG labels for non-THB Maker
            $maker_currency = get_field( 'maker_currency', $maker_id ) ?: 'THB';
            $is_eng = $maker_currency !== 'THB';

            // V.2.4: LIFF URLs — JWT แยกต่อปุ่ม ฝัง page ใน token เป็น fallback
            $liff_id = defined( 'B2F_LIFF_ID' ) ? B2F_LIFF_ID : ( defined( 'B2B_LIFF_ID' ) ? B2B_LIFF_ID : '' );
            $liff_base = $liff_id ? 'https://liff.line.me/' . $liff_id . '/b2f-maker/' : '#';
            $mk_id = intval( $maker_id );
            $mk_cur = get_field( 'maker_currency', $mk_id ) ?: 'THB';
            if ( class_exists( 'DINOCO_JWT' ) && $liff_base !== '#' ) {
                $token_list      = DINOCO_JWT::create( array( 'maker_id' => $mk_id, 'maker_currency' => $mk_cur, 'page' => 'list' ), 86400 * 3 );
                $token_deliver   = DINOCO_JWT::create( array( 'maker_id' => $mk_id, 'maker_currency' => $mk_cur, 'page' => 'deliver' ), 86400 * 3 );
                $token_reschedule = DINOCO_JWT::create( array( 'maker_id' => $mk_id, 'maker_currency' => $mk_cur, 'page' => 'reschedule' ), 86400 * 3 );
            } else {
                $token_list = $token_deliver = $token_reschedule = '';
            }
            // V.2.5: ใช้ 'view' แทน 'page'
            $url_po_list    = $liff_base !== '#' ? $liff_base . '?' . http_build_query( array( 'view' => 'list', 'token' => $token_list ) ) : '#';
            $url_deliver    = $liff_base !== '#' ? $liff_base . '?' . http_build_query( array( 'view' => 'deliver', 'token' => $token_deliver ) ) : '#';
            $url_reschedule = $liff_base !== '#' ? $liff_base . '?' . http_build_query( array( 'view' => 'reschedule', 'token' => $token_reschedule ) ) : '#';

            // นับ PO ค้าง
            $pending_q = new WP_Query( array( 'post_type' => 'b2f_order', 'posts_per_page' => -1, 'fields' => 'ids',
                'meta_query' => array( 'relation' => 'AND',
                    array( 'key' => 'po_maker_id', 'value' => $maker_id ),
                    array( 'key' => 'po_status', 'value' => array( 'submitted', 'confirmed', 'delivering', 'partial_received' ), 'compare' => 'IN' ),
                ),
            ) );
            $pending_count = $pending_q->found_posts;
            $subtitle = $is_eng
                ? ( $pending_count > 0 ? 'Pending POs: ' . $pending_count : 'No pending POs' )
                : ( $pending_count > 0 ? 'ใบสั่งซื้อที่รอดำเนินการ: ' . $pending_count . ' รายการ' : 'ไม่มีใบสั่งซื้อที่รอดำเนินการ' );

            $body_contents = array(
                // สรุป PO ค้าง
                array( 'type' => 'box', 'layout' => 'horizontal', 'margin' => 'md', 'paddingAll' => '10px', 'cornerRadius' => '10px',
                    'backgroundColor' => $pending_count > 0 ? '#fffbeb' : '#f0fdf4',
                    'contents' => array(
                    array( 'type' => 'text', 'text' => $pending_count > 0 ? '📌' : '✅', 'flex' => 0, 'size' => 'lg' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'margin' => 'md', 'contents' => array(
                        array( 'type' => 'text', 'text' => $subtitle, 'size' => 'xs', 'color' => $pending_count > 0 ? '#92400e' : '#166534', 'weight' => 'bold', 'wrap' => true ),
                    ) ),
                ) ),
                array( 'type' => 'separator', 'margin' => 'lg' ),
                array( 'type' => 'text', 'text' => $is_eng ? '📋 Factory Menu' : '📋 เมนูสำหรับโรงงาน', 'weight' => 'bold', 'size' => 'sm', 'color' => '#d97706', 'margin' => 'lg' ),
                // ดูใบสั่งซื้อ
                array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'margin' => 'md', 'paddingAll' => '10px',
                    'cornerRadius' => '10px', 'backgroundColor' => '#f8fafc',
                    'action' => array( 'type' => 'uri', 'label' => $is_eng ? 'Purchase Orders' : 'รายการใบสั่งซื้อ', 'uri' => $url_po_list ),
                    'contents' => array(
                    array( 'type' => 'text', 'text' => '📋', 'flex' => 0, 'gravity' => 'center', 'size' => 'xl' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'contents' => array(
                        array( 'type' => 'text', 'text' => $is_eng ? 'Purchase Orders' : 'รายการใบสั่งซื้อ', 'weight' => 'bold', 'size' => 'sm' ),
                        array( 'type' => 'text', 'text' => $is_eng ? 'View all POs · Confirm · Reject' : 'ดูใบสั่งซื้อทั้งหมด · ยืนยัน · ปฏิเสธ', 'size' => 'xs', 'color' => '#64748b', 'wrap' => true ),
                    ) ),
                ) ),
                // แจ้งจัดส่งสินค้า
                array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'margin' => 'sm', 'paddingAll' => '10px',
                    'cornerRadius' => '10px', 'backgroundColor' => '#f8fafc',
                    'action' => array( 'type' => 'uri', 'label' => $is_eng ? 'Notify Shipment' : 'แจ้งจัดส่งสินค้า', 'uri' => $url_deliver ),
                    'contents' => array(
                    array( 'type' => 'text', 'text' => '🚚', 'flex' => 0, 'gravity' => 'center', 'size' => 'xl' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'contents' => array(
                        array( 'type' => 'text', 'text' => $is_eng ? 'Notify Shipment' : 'แจ้งจัดส่งสินค้า', 'weight' => 'bold', 'size' => 'sm' ),
                        array( 'type' => 'text', 'text' => $is_eng ? 'Inform DINOCO that goods have been shipped' : 'แจ้ง DINOCO ว่าจัดส่งสินค้าแล้ว', 'size' => 'xs', 'color' => '#64748b', 'wrap' => true ),
                    ) ),
                ) ),
                // ขอเลื่อนกำหนดส่ง
                array( 'type' => 'box', 'layout' => 'horizontal', 'spacing' => 'md', 'margin' => 'sm', 'paddingAll' => '10px',
                    'cornerRadius' => '10px', 'backgroundColor' => '#f8fafc',
                    'action' => array( 'type' => 'uri', 'label' => $is_eng ? 'Reschedule Delivery' : 'ขอเลื่อนกำหนดส่ง', 'uri' => $url_reschedule ),
                    'contents' => array(
                    array( 'type' => 'text', 'text' => '📅', 'flex' => 0, 'gravity' => 'center', 'size' => 'xl' ),
                    array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 5, 'contents' => array(
                        array( 'type' => 'text', 'text' => $is_eng ? 'Reschedule Delivery' : 'ขอเลื่อนกำหนดส่ง', 'weight' => 'bold', 'size' => 'sm' ),
                        array( 'type' => 'text', 'text' => $is_eng ? 'Request delivery date change with reason' : 'แจ้งขอเลื่อนวันจัดส่งพร้อมเหตุผล', 'size' => 'xs', 'color' => '#64748b', 'wrap' => true ),
                    ) ),
                ) ),
            );

            $alt_text = $is_eng
                ? ( '🏭 DINOCO — ' . $maker_name . ' (' . $pending_count . ' pending POs)' )
                : ( '🏭 DINOCO — ' . $maker_name . ' (' . $pending_count . ' PO ค้าง)' );

            $flex = array(
                'type' => 'flex',
                'altText' => $alt_text,
                'contents' => array(
                    'type' => 'bubble',
                    'size' => 'mega',
                    'header' => array(
                        'type' => 'box', 'layout' => 'vertical', 'backgroundColor' => '#0f2447', 'paddingAll' => '16px',
                        'contents' => array(
                            array( 'type' => 'box', 'layout' => 'horizontal', 'alignItems' => 'center', 'contents' => array(
                                array( 'type' => 'image', 'url' => $logo, 'size' => 'xxs', 'aspectMode' => 'fit', 'flex' => 0 ),
                                array( 'type' => 'box', 'layout' => 'vertical', 'flex' => 1, 'margin' => 'md', 'contents' => array(
                                    array( 'type' => 'text', 'text' => $is_eng ? 'DINOCO · Procurement' : 'DINOCO · ระบบสั่งซื้อ', 'weight' => 'bold', 'color' => '#ffffff', 'size' => 'md' ),
                                    array( 'type' => 'text', 'text' => $maker_name, 'color' => '#93c5fd', 'size' => 'sm', 'margin' => 'xs' ),
