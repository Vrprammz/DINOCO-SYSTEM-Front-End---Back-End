            // V.2.8: ENG labels
            $mk_cur_pend = get_field( 'maker_currency', $maker['id'] ) ?: 'THB';
            $mk_eng_pend = $mk_cur_pend !== 'THB';
            $reason_reply = $mk_eng_pend
                ? "📝 Rejection reason for {$po_number} recorded.\nReason: " . mb_substr( $raw_text, 0, 100 )
                : "📝 บันทึกเหตุผลปฏิเสธ {$po_number} แล้ว\nเหตุผล: " . mb_substr( $raw_text, 0, 100 );
            b2f_line_reply_raw( $reply_token, array( array(
                'type' => 'text',
                'text' => $reason_reply,
            ) ) );
            // Push Admin เหตุผล
            $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
            if ( $admin_group ) {
                b2f_line_push( $admin_group, array( array(
                    'type' => 'text',
                    'text' => "📝 เหตุผลปฏิเสธ {$po_number}:\n" . mb_substr( $raw_text, 0, 200 ),
                ) ) );
            }
            return;
        }

        // "ส่งของ" / "deliver"
        if ( in_array( $text, array( 'ส่งของ', 'deliver', 'ส่ง' ) ) ) {
            b2f_show_deliverable_pos( $reply_token, $maker );
            return;
        }

        // "ดูpo" / "po" / "ดูใบสั่งซื้อ"
        if ( in_array( $text, array( 'ดูpo', 'po', 'ดูใบสั่งซื้อ', 'ใบสั่งซื้อ' ) ) ) {
            b2f_show_maker_po_list( $reply_token, $maker );
            return;
        }

        // Catch-all: ข้อความที่ไม่ match คำสั่ง → เงียบ (ไม่ตอบทุกข้อความในกลุ่ม)
    }
}

if ( ! function_exists( 'b2f_handle_maker_postback' ) ) {
    function b2f_handle_maker_postback( $event, $maker ) {
        $data = $event['postback']['data'] ?? '';
        $reply_token = $event['replyToken'] ?? '';
        parse_str( $data, $params );
        $action = $params['action'] ?? '';
        $po_id = intval( $params['po_id'] ?? 0 );

        // Dedup
        $dedup_key = 'b2f_pb_' . md5( $data . ( $event['source']['userId'] ?? '' ) );
        if ( get_transient( $dedup_key ) ) return;
        set_transient( $dedup_key, 1, 10 );

        switch ( $action ) {
            case 'b2f_maker_deliver':
                b2f_action_maker_deliver( $reply_token, $po_id, $maker );
                break;

            case 'b2f_maker_confirm':
                // Maker ยืนยัน PO + เลือกวันส่ง (datetimepicker)
                $date = $event['postback']['params']['date'] ?? '';
                // V.2.8: ENG labels
                $mk_currency = get_field( 'maker_currency', $maker['id'] ) ?: 'THB';
                $mk_eng = $mk_currency !== 'THB';
                if ( empty( $date ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => $mk_eng ? '❌ Please select delivery date' : '❌ กรุณาเลือกวันส่ง' ) ) );
                    break;
                }
                // Validate date > today
                $date_obj = DateTime::createFromFormat( 'Y-m-d', $date );
                $now = new DateTime( 'now', new DateTimeZone( 'Asia/Bangkok' ) );
                if ( ! $date_obj || $date_obj <= $now ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => $mk_eng ? '❌ Delivery date must be in the future' : '❌ วันส่งต้องเป็นวันในอนาคต' ) ) );
                    break;
                }
                // Verify ownership
                $po_maker = get_field( 'po_maker_id', $po_id );
                if ( intval( $po_maker ) !== intval( $maker['id'] ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => $mk_eng ? '❌ This PO does not belong to your factory' : '❌ PO นี้ไม่ใช่ของโรงงานคุณ' ) ) );
                    break;
                }
                // Transition
                $result = b2f_transition_order( $po_id, 'confirmed', 'maker', 'Maker ยืนยัน วันส่ง: ' . $date );
                if ( is_wp_error( $result ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ ' . $result->get_error_message() ) ) );
                    break;
                }
                update_field( 'po_expected_date', $date, $po_id );
                $po_number = get_field( 'po_number', $po_id ) ?: '#' . $po_id;
                $thai_date = date( 'd/m/Y', strtotime( $date ) );
                // Reply Maker — ใช้ Flex builder เดียวกับ Admin (มีรายการสินค้าครบ)
                if ( function_exists( 'b2f_build_flex_maker_confirmed' ) ) {
                    $reply_flex = b2f_build_flex_maker_confirmed( $po_id, $date );
                    if ( $reply_flex ) b2f_line_reply_raw( $reply_token, array( $reply_flex ) );
                } else {
                    $confirm_text = $mk_eng
                        ? "✅ Confirmed {$po_number}\nDelivery date: {$thai_date}"
                        : "✅ ยืนยัน {$po_number} เรียบร้อย\nวันส่ง: {$thai_date}";
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => $confirm_text ) ) );
                }
                // Push Flex to Admin (เหมือนกัน)
                $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
                if ( $admin_group && function_exists( 'b2f_build_flex_maker_confirmed' ) ) {
                    $flex = b2f_build_flex_maker_confirmed( $po_id, $date );
                    if ( $flex ) b2f_line_push( $admin_group, $flex );
                } elseif ( $admin_group ) {
                    b2f_line_push( $admin_group, array( array( 'type' => 'text',
                        'text' => "✅ โรงงาน {$maker['name']} ยืนยัน\nPO: {$po_number}\nวันส่ง: {$thai_date}" ) ) );
                }
                break;

            case 'b2f_maker_reject':
                $po_maker = get_field( 'po_maker_id', $po_id );
                // V.2.8: ENG labels
                $mk_currency_rej = get_field( 'maker_currency', $maker['id'] ) ?: 'THB';
                $mk_eng_rej = $mk_currency_rej !== 'THB';
                if ( intval( $po_maker ) !== intval( $maker['id'] ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => $mk_eng_rej ? '❌ This PO does not belong to your factory' : '❌ PO นี้ไม่ใช่ของโรงงานคุณ' ) ) );
                    break;
                }
                $result = b2f_transition_order( $po_id, 'rejected', 'maker', 'Maker ปฏิเสธ' );
                if ( is_wp_error( $result ) ) {
                    b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => '❌ ' . $result->get_error_message() ) ) );
                    break;
                }
                $po_number = get_field( 'po_number', $po_id ) ?: '#' . $po_id;
                $reject_text = $mk_eng_rej
                    ? "📝 Rejection recorded for {$po_number}\nPlease type the reason for rejection:"
                    : "📝 บันทึกปฏิเสธ {$po_number} แล้ว\nกรุณาพิมพ์เหตุผลที่ปฏิเสธ:";
                b2f_line_reply_raw( $reply_token, array( array(
                    'type' => 'text',
                    'text' => $reject_text,
                ) ) );
                // Store pending reject — ข้อความถัดไปจะเป็นเหตุผล
                set_transient( 'b2f_pending_reject_' . $maker['id'], $po_id, 300 );
                // Push Flex to Admin (V.1.6: ใช้ Flex builder แทน text)
                $admin_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
                if ( $admin_group && function_exists( 'b2f_build_flex_maker_rejected' ) ) {
                    $flex = b2f_build_flex_maker_rejected( $po_id, '(รอเหตุผลจาก Maker...)' );
                    if ( $flex ) b2f_line_push( $admin_group, $flex );
                } elseif ( $admin_group ) {
                    b2f_line_push( $admin_group, array( array(
                        'type' => 'text',
                        'text' => "❌ โรงงาน {$maker['name']} ปฏิเสธ\nPO: {$po_number}\n(รอเหตุผล...)",
                    ) ) );
                }
                break;

            case 'b2f_maker_po_detail':
                $items = get_field( 'po_items', $po_id ) ?: array();
                $po_number = get_field( 'po_number', $po_id ) ?: '#' . $po_id;
                $po_currency = get_field( 'po_currency', $po_id ) ?: 'THB';
                $sym = function_exists( 'b2f_currency_symbol' ) ? b2f_currency_symbol( $po_currency ) : '฿';
                $det_eng = $po_currency !== 'THB';
                $lines = array( "📋 {$po_number}", '' );
                foreach ( $items as $item ) {
                    $lines[] = ($item['poi_product_name'] ?: $item['poi_sku']) . ' x' . $item['poi_qty_ordered'] . ' ' . $sym . number_format( $item['poi_unit_cost'] * $item['poi_qty_ordered'], 2 );
                }
                $lines[] = '';
                $lines[] = ( $det_eng ? 'Total: ' : 'รวม: ' ) . $sym . number_format( floatval( get_field( 'po_total_amount', $po_id ) ), 2 );
                b2f_line_reply_raw( $reply_token, array( array( 'type' => 'text', 'text' => implode( "\n", $lines ) ) ) );
                break;

            case 'b2f_approve_reschedule':
            case 'b2f_reject_reschedule':
                // Admin actions — handled ใน admin group (ไม่ใช่ maker group)
                break;
        }
    }
}

