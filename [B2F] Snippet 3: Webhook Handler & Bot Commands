if ( ! function_exists( 'b2f_route_maker_command' ) ) {
    /**
     * Route commands จาก Maker LINE group
     * เรียกจาก B2B Snippet 2 เมื่อ group_id match b2f_maker
     *
     * @param array $event    LINE webhook event
     * @param array $maker    { id, name, group_id } จาก b2f_get_maker_by_group()
     */
    function b2f_route_maker_command( $event, $maker ) {
        $type = $event['type'] ?? '';

        // Bot enabled check — เหมือน B2B distributor toggle
        // Default = enabled (ถ้ายังไม่เคย set ค่า)
        $bot_val = get_post_meta( $maker['id'], 'maker_bot_enabled', true );
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Route maker: id=%d name=%s bot_val=[%s] type=%s', $maker['id'], $maker['name'], var_export( $bot_val, true ), $type ) );
        }
        if ( $bot_val === '0' || $bot_val === 0 ) {
            // Bot ถูกปิดสำหรับ Maker นี้ → เงียบ (ยกเว้น join event)
            if ( $type === 'join' ) { b2f_handle_join_event( $event ); }
            return;
        }

        if ( $type === 'message' && ( $event['message']['type'] ?? '' ) === 'text' ) {
            b2f_handle_maker_text( $event, $maker );
        } elseif ( $type === 'postback' ) {
            b2f_handle_maker_postback( $event, $maker );
        }
        // join event → bot ถูก invite เข้ากลุ่มใหม่
        elseif ( $type === 'join' ) {
            b2f_handle_join_event( $event );
        }
    }
}

if ( ! function_exists( 'b2f_handle_maker_text' ) ) {
    function b2f_handle_maker_text( $event, $maker ) {
        $raw_text = $event['message']['text'] ?? '';
        $reply_token = $event['replyToken'] ?? '';
        $group_id = $event['source']['groupId'] ?? '';

        // Dedup protection (60s)
        $msg_id = $event['message']['id'] ?? '';
        if ( $msg_id && get_transient( 'b2f_dedup_' . $msg_id ) ) return;
        if ( $msg_id ) set_transient( 'b2f_dedup_' . $msg_id, 1, 60 );

        // Check for mention — ตรวจจากทั้ง LINE API และ text pattern
        $is_mention = false;

        // วิธี 1: LINE API mentionees.isSelf
        if ( isset( $event['message']['mention']['mentionees'] ) ) {
            foreach ( $event['message']['mention']['mentionees'] as $m ) {
                if ( ! empty( $m['isSelf'] ) ) {
                    $is_mention = true;
                    break;
                }
            }
        }

        // วิธี 2: ตรวจจาก text pattern (fallback — LINE อาจไม่ส่ง isSelf ใน group)
        if ( ! $is_mention ) {
            if ( preg_match( '/@DINOCO/i', $raw_text ) || preg_match( '/^@/u', trim( $raw_text ) ) ) {
                $is_mention = true;
            }
        }

        // Strip @mention text
        $text = $raw_text;
        $text = preg_replace( '/^@?DINOCO\s*B2B\s*System\s*/ui', '', $text );
        $text = preg_replace( '/^@?dinoco\s*/ui', '', $text );
        $text = preg_replace( '/^@\S+\s*/u', '', $text );
        $text = trim( strtolower( $text ) );

        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( sprintf( 'Maker text: raw=[%s] clean=[%s] mention=%s maker=%d', substr( $raw_text, 0, 50 ), $text, $is_mention ? 'Y' : 'N', $maker['id'] ) );
        }

        // @mention (text ว่างหรือไม่ก็ตาม) → แสดง Maker menu
        if ( $is_mention ) {
            $menu_sent = false;
            if ( function_exists( 'b2f_build_flex_command_menu_maker' ) ) {
                try {
                    $flex = b2f_build_flex_command_menu_maker( $maker['id'] );
                    if ( $flex && is_array( $flex ) && ! empty( $flex['type'] ) ) {
                        b2f_line_reply_raw( $reply_token, array( $flex ) );
                        $menu_sent = true;
                    }
                } catch ( \Exception $e ) {
                    if ( function_exists( 'b2f_log' ) ) b2f_log( 'Flex menu error: ' . $e->getMessage() );
                }
            }
            // Fallback: text reply ถ้า Flex ไม่ได้ส่ง
            if ( ! $menu_sent ) {
                b2f_line_reply_raw( $reply_token, array( array(
                    'type' => 'text',
                    'text' => "🏭 DINOCO B2F Bot\n\nคำสั่ง:\n📦 ส่งของ — แจ้งส่งสินค้า\n📋 ดูPO — ดูใบสั่งซื้อ\n\nโรงงาน: " . ( $maker['name'] ?? '?' ),
                ) ) );
            }
            return;
        }

        // "ส่งของ" / "deliver"
        if ( in_array( $text, array( 'ส่งของ', 'deliver', 'ส่ง' ) ) ) {
            b2f_show_deliverable_pos( $reply_token, $maker );
            return;
        }

        // "ดูpo" / "po" / "ดูใบสั่งซื้อ"
        if ( in_array( $text, array( 'ดูpo', 'po', 'ดูใบสั่งซื้อ', 'ใบสั่งซื้อ' ) ) ) {
            b2f_show_maker_po_list( $reply_token, $maker );
            return;
        }

        // Catch-all: ข้อความที่ไม่ match คำสั่ง → เงียบ (ไม่ตอบทุกข้อความในกลุ่ม)
    }
}

if ( ! function_exists( 'b2f_handle_maker_postback' ) ) {
    function b2f_handle_maker_postback( $event, $maker ) {
        $data = $event['postback']['data'] ?? '';
        $reply_token = $event['replyToken'] ?? '';
        parse_str( $data, $params );
        $action = $params['action'] ?? '';
        $po_id = intval( $params['po_id'] ?? 0 );

        // Dedup
        $dedup_key = 'b2f_pb_' . md5( $data . ( $event['source']['userId'] ?? '' ) );
        if ( get_transient( $dedup_key ) ) return;
        set_transient( $dedup_key, 1, 10 );

        switch ( $action ) {
            case 'b2f_maker_deliver':
                b2f_action_maker_deliver( $reply_token, $po_id, $maker );
                break;

            case 'b2f_approve_reschedule':
            case 'b2f_reject_reschedule':
                // Admin actions — handled ใน admin group (ไม่ใช่ maker group)
                break;
        }
    }
}

