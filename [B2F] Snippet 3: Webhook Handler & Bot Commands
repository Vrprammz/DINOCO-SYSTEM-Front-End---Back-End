if ( ! function_exists( 'b2f_show_deliverable_pos' ) ) {
    function b2f_show_deliverable_pos( $reply_token, $maker ) {
        $q = new WP_Query( array(
            'post_type'      => 'b2f_order',
            'posts_per_page' => 10,
            'post_status'    => 'publish',
            'meta_query'     => array(
                array( 'key' => 'po_maker_id', 'value' => $maker['id'] ),
                array( 'key' => 'po_status', 'value' => array( 'confirmed', 'partial_received' ), 'compare' => 'IN' ),
            ),
            'orderby'        => 'date',
            'order'          => 'DESC',
        ) );

        if ( ! $q->have_posts() ) {
            b2f_line_reply_raw( $reply_token, array( array(
                'type' => 'text',
                'text' => '📦 ไม่มี PO ที่รอส่งของตอนนี้',
            ) ) );
            return;
        }

        $bubbles = array();
        foreach ( $q->posts as $post ) {
            $po_number = get_field( 'po_number', $post->ID ) ?: '#' . $post->ID;
            $po_total = floatval( get_field( 'po_total_amount', $post->ID ) ?: 0 );
            $item_count = intval( get_field( 'po_item_count', $post->ID ) ?: 0 );
            $status = get_field( 'po_status', $post->ID );

            $bubbles[] = array(
                'type' => 'bubble',
                'size' => 'kilo',
                'body' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '14px', 'spacing' => 'sm', 'contents' => array(
                    array( 'type' => 'text', 'text' => '📦 ' . $po_number, 'weight' => 'bold', 'size' => 'md' ),
                    array( 'type' => 'text', 'text' => $item_count . ' รายการ | ฿' . number_format( $po_total, 2 ), 'size' => 'xs', 'color' => '#888888' ),
                    array( 'type' => 'text', 'text' => 'สถานะ: ' . B2F_Order_FSM::label( $status ), 'size' => 'xs', 'color' => '#d97706', 'margin' => 'sm' ),
                ) ),
                'footer' => array( 'type' => 'box', 'layout' => 'vertical', 'paddingAll' => '10px', 'contents' => array(
                    array( 'type' => 'button', 'style' => 'primary', 'color' => '#d97706', 'height' => 'sm',
                        'action' => array( 'type' => 'postback', 'label' => '📦 แจ้งส่งของ', 'data' => 'action=b2f_maker_deliver&po_id=' . $post->ID ) ),
                ) ),
            );
        }

        b2f_line_reply_raw( $reply_token, array( array(
            'type' => 'flex',
            'altText' => '📦 PO ที่รอส่งของ (' . count( $bubbles ) . ' รายการ)',
            'contents' => array( 'type' => 'carousel', 'contents' => array_slice( $bubbles, 0, 10 ) ),
        ) ) );
    }
}

