if ( ! function_exists( 'b2f_show_admin_po_summary' ) ) {
    function b2f_show_admin_po_summary( $reply_token ) {
        global $wpdb;

        $statuses = array( 'submitted', 'confirmed', 'delivering', 'partial_received', 'received' );
        $counts = array();
        foreach ( $statuses as $s ) {
            $counts[ $s ] = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$wpdb->posts} p
                 JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'po_status'
                 WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish' AND pm.meta_value = %s",
                $s
            ) );
        }

        // Overdue count
        $overdue = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} ps ON ps.post_id = p.ID AND ps.meta_key = 'po_status'
             JOIN {$wpdb->postmeta} pe ON pe.post_id = p.ID AND pe.meta_key = 'po_expected_date'
             WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
             AND ps.meta_value IN ('confirmed','delivering')
             AND pe.meta_value < CURDATE()"
        );

        $lines = array(
            '🏭 สรุป B2F PO',
            '',
            '📝 รอ Maker ยืนยัน: ' . $counts['submitted'],
            '✅ ยืนยันแล้ว: ' . $counts['confirmed'],
            '🚚 กำลังส่ง: ' . $counts['delivering'],
            '📦 รับบางส่วน: ' . $counts['partial_received'],
            '💰 รอจ่ายเงิน: ' . $counts['received'],
            '',
            '⚠️ ล่าช้า: ' . $overdue . ' PO',
        );

        b2f_line_reply_raw( $reply_token, array( array(
            'type' => 'text',
            'text' => implode( "\n", $lines ),
        ) ) );
    }
}

