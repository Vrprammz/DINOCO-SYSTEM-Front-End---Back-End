// 3. ADMIN POSTBACK HANDLER
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_handle_admin_postback' ) ) {
    /**
     * Handle B2F postback actions จาก Admin group
     * เรียกจาก B2B Snippet 2 postback handler
     *
     * @param string $action     Action name (starts with 'b2f_')
     * @param array  $params     Parsed postback data
     * @param string $reply_token
     * @return bool true ถ้า handled
     */
    function b2f_handle_admin_postback( $action, $params, $reply_token ) {
        $po_id = intval( $params['po_id'] ?? 0 );

        switch ( $action ) {
            case 'b2f_approve_reschedule':
                $new_date = sanitize_text_field( $params['new_date'] ?? '' );
                if ( $po_id && $new_date ) {
                    update_field( 'po_expected_date', $new_date, $po_id );
                    b2f_transition_order( $po_id, 'confirmed', 'admin', 'อนุมัติเลื่อนวันส่ง' );

                    // แจ้ง Maker
                    $maker_id = get_field( 'po_maker_id', $po_id );
                    $maker_group = get_field( 'maker_line_group_id', $maker_id );
                    if ( $maker_group && function_exists( 'b2f_line_push' ) ) {
                        b2f_line_push( $maker_group, array( array(
                            'type' => 'text',
                            'text' => '✅ DINOCO อนุมัติเลื่อนวันส่ง PO ' . get_field( 'po_number', $po_id ) . "\nวันส่งใหม่: " . $new_date,
                        ) ) );
                    }

                    b2f_line_reply_raw( $reply_token, array( array(
                        'type' => 'text',
                        'text' => '✅ อนุมัติเลื่อนวันส่ง PO ' . get_field( 'po_number', $po_id ) . ' เป็น ' . $new_date,
                    ) ) );
                }
                return true;

            case 'b2f_reject_reschedule':
                if ( $po_id ) {
                    $maker_id = get_field( 'po_maker_id', $po_id );
                    $maker_group = get_field( 'maker_line_group_id', $maker_id );
                    if ( $maker_group && function_exists( 'b2f_line_push' ) ) {
                        b2f_line_push( $maker_group, array( array(
                            'type' => 'text',
                            'text' => '❌ DINOCO ไม่อนุมัติเลื่อนวันส่ง PO ' . get_field( 'po_number', $po_id ) . "\nกรุณาส่งตามกำหนดเดิม",
                        ) ) );
                    }

                    b2f_line_reply_raw( $reply_token, array( array(
                        'type' => 'text',
                        'text' => '❌ ไม่อนุมัติเลื่อน — แจ้ง Maker แล้ว',
                    ) ) );
                }
                return true;
        }

        return false;
    }
}

