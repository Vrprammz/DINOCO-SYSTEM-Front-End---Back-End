if ( ! function_exists( 'b2f_show_maker_po_list' ) ) {
    function b2f_show_maker_po_list( $reply_token, $maker ) {
        $q = new WP_Query( array(
            'post_type'      => 'b2f_order',
            'posts_per_page' => 5,
            'post_status'    => 'publish',
            'meta_query'     => array(
                array( 'key' => 'po_maker_id', 'value' => $maker['id'] ),
                array( 'key' => 'po_status', 'value' => array( 'cancelled', 'completed' ), 'compare' => 'NOT IN' ),
            ),
            'orderby'        => 'date',
            'order'          => 'DESC',
        ) );

        if ( ! $q->have_posts() ) {
            b2f_line_reply_raw( $reply_token, array( array(
                'type' => 'text',
                'text' => '📋 ไม่มี PO ที่ค้างอยู่ตอนนี้',
            ) ) );
            return;
        }

        $lines = array( '📋 PO ที่ค้างอยู่:', '' );
        foreach ( $q->posts as $post ) {
            $po_number = get_field( 'po_number', $post->ID ) ?: '#' . $post->ID;
            $status = get_field( 'po_status', $post->ID );
            $eta = get_field( 'po_expected_date', $post->ID );
            $line = $po_number . ' — ' . B2F_Order_FSM::label( $status );
            if ( $eta ) $line .= ' (ส่ง: ' . date( 'd/m/Y', strtotime( $eta ) ) . ')';
            $lines[] = $line;
        }

        b2f_line_reply_raw( $reply_token, array( array(
            'type' => 'text',
            'text' => implode( "\n", $lines ),
        ) ) );
    }
}

