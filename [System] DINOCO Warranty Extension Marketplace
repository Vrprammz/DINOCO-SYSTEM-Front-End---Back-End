if ( ! function_exists( 'dinoco_sn_mpx_check_grace_period' ) ) {
    /**
     * Check if warranty is within grace period for extension.
     *
     * Allows extension if: not yet expired OR expired ≤ grace_days ago.
     *
     * @param string $warranty_until 'YYYY-MM-DD' or empty
     * @param string $today 'YYYY-MM-DD' (testable injection)
     * @param int $grace_days default 30
     * @return array ['ok' => bool, 'reason' => string, 'days_past_expiry' => int]
     */
    function dinoco_sn_mpx_check_grace_period( $warranty_until, $today = null, $grace_days = 30 ) {
        if ( $today === null ) {
            $today = date( 'Y-m-d', current_time( 'timestamp' ) );
        }
        $grace_days = max( 0, (int) $grace_days );

        if ( empty( $warranty_until ) ) {
            return array( 'ok' => false, 'reason' => 'no_warranty_record', 'days_past_expiry' => 0 );
        }

        // Parse YYYY-MM-DD safely
        $w_ts = strtotime( $warranty_until );
        $t_ts = strtotime( $today );
        if ( $w_ts === false || $t_ts === false ) {
            return array( 'ok' => false, 'reason' => 'date_parse_error', 'days_past_expiry' => 0 );
        }

        $days_past = (int) floor( ( $t_ts - $w_ts ) / 86400 );

        if ( $days_past <= 0 ) {
            // Not yet expired — eligible
            return array( 'ok' => true, 'reason' => '', 'days_past_expiry' => 0 );
        }

        if ( $days_past <= $grace_days ) {
            return array( 'ok' => true, 'reason' => 'within_grace', 'days_past_expiry' => $days_past );
        }

        return array(
            'ok'              => false,
            'reason'          => 'grace_exceeded',
            'days_past_expiry'=> $days_past,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_mpx_compute_total' ) ) {
    /**
     * Compute total breakdown for a plan.
     *
     * V.0.6 (boss decision 2026-05-15): NON-VAT บัญชีบุคคล — VAT removed from scope.
     * Backward-compat signature retained (4th arg accepted but ignored if 0/falsy);
     * VAT field always 0.00 in response so callers don't break, but display is hidden
     * in UI (V.0.6 customer LIFF removes "VAT 7%" row + JS skips data-role="total-vat").
     *
     * @param float $base_price Plan price (THB)
     * @param float $discount Discount amount (from coupon, default 0)
     * @param float $vat_rate IGNORED in V.0.6+ — boss directive 2026-05-15 non-VAT บุคคล
     * @return array {subtotal, discount, vat, total} — vat always 0.00 post-V.0.6
     */
    function dinoco_sn_mpx_compute_total( $base_price, $discount = 0.0, $vat_rate = 0.0 ) {
        $base = max( 0.0, (float) $base_price );
        $disc = max( 0.0, min( $base, (float) $discount ) );

        // V.0.6: NO VAT calculation per boss decision 2026-05-15 (non-VAT บัญชีบุคคล).
        // $vat_rate parameter retained for backward-compat but value forced to 0.
        // If any caller passes >0 it's silently ignored — DO NOT re-enable without
        // boss approval. See memory feedback_non_vat_personal_bank.md.
        $vat = 0.0;
        $total = round( $base - $disc + $vat, 2 );

        return array(
            'subtotal' => round( $base, 2 ),
            'discount' => round( $disc, 2 ),
            'vat'      => $vat,  // always 0 — keep field for backward-compat
            'total'    => $total,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_mpx_image_compress_target' ) ) {
    /**
     * Compute target compression for slip image.
     *
     * Returns quality 0.0-1.0 + max dimension.
     * Strategy: if file > 2MB → quality 0.85 + maxDim 1600
     *           else passthrough
     *
     * Pure-logic helper (mirrored in JS client).
     *
     * @param int $file_size_bytes
     * @return array {quality, max_dimension, should_compress}
     */
    function dinoco_sn_mpx_image_compress_target( $file_size_bytes ) {
        $size = max( 0, (int) $file_size_bytes );
        $threshold = 2 * 1024 * 1024; // 2MB

        if ( $size <= $threshold ) {
            return array(
                'quality'        => 1.0,
                'max_dimension'  => 0, // 0 = no resize
                'should_compress'=> false,
            );
        }

        return array(
            'quality'        => 0.85,
            'max_dimension'  => 1600,
            'should_compress'=> true,
        );
    }
}

