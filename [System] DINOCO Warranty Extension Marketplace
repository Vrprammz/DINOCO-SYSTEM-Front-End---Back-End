                });
                var target = $('.dnc-sn-mpx-stage-' + n);
                if (target){
                    target.classList.add('is-active');
                    target.hidden = false;
                    // Focus management
                    var heading = $('h2', target);
                    if (heading) heading.setAttribute('tabindex', '-1'), heading.focus();
                }
            }

            // ─── Modal helpers (defensive fallback) ─────────
            function alertMsg(msg){
                if (window.dinocoModal && typeof window.dinocoModal.alert === 'function') {
                    window.dinocoModal.alert({title:'แจ้งเตือน', message:msg});
                } else {
                    try { alert(msg); } catch(e) {}
                }
            }
            function confirmMsg(msg, cb){
                if (window.dinocoModal && typeof window.dinocoModal.confirm === 'function') {
                    window.dinocoModal.confirm({title:'ยืนยัน', message:msg, onConfirm:cb});
                } else {
                    try { if (confirm(msg)) cb(); } catch(e) {}
                }
            }

            // ─── REST helper ─────────────────────────────────
            function api(method, path, body){
                var opts = {
                    method: method,
                    credentials: 'include',
                    headers: {
                        'Accept': 'application/json',
                        'X-WP-Nonce': NONCE
                    }
                };
                if (body){
                    opts.headers['Content-Type'] = 'application/json';
                    opts.body = JSON.stringify(body);
                }
                return fetch(REST + path, opts).then(function(r){
                    if (r.status === 503){
                        throw {code: 'feature_disabled', message: 'ระบบยังไม่เปิดให้บริการ'};
                    }
                    return r.json().then(function(data){
                        if (!r.ok){
                            throw {code: data.code || 'http_'+r.status, message: data.message || 'เกิดข้อผิดพลาด'};
                        }
                        return data;
                    });
                });
            }

            // ─── ESC handler ─────────────────────────────────
            document.addEventListener('keydown', function(e){
                if (e.key === 'Escape' || e.keyCode === 27){
                    // Stage 2/3 → allow back to stage 1; stage 4 → no-op
                    if (STATE.stage === 2) showStage(1);
                }
            });

            // ─── Stage 1: Load quotes ────────────────────────
            function loadQuotes(){
                var loading = $('[data-role="stage1-loading"]');
                var body    = $('[data-role="stage1-body"]');
                var restReady = $('.dnc-sn-mpx-stage-1').getAttribute('data-rest-ready') === '1';

                if (!restReady){
                    loading.innerHTML = '<div class="dnc-sn-mpx-error">⚠️ ระบบยังไม่เปิดให้บริการ — กรุณาลองใหม่ภายหลัง</div>';
                    return;
                }

                // Fetch quotes for 1y, 2y, 3y in parallel
                var calls = [1,2,3].map(function(y){
                    return api('GET', 'marketplace/quote?sn=' + encodeURIComponent(SN) + '&years=' + y)
                        .then(function(d){ return {years:y, ok:true, data:d}; })
                        .catch(function(e){ return {years:y, ok:false, error:e}; });
                });

                Promise.all(calls).then(function(results){
                    var anyOk = false;
                    var firstErr = null;

                    results.forEach(function(r){
                        if (r.ok){
                            anyOk = true;
                            STATE.quotes[r.years] = r.data;
                        } else if (!firstErr){
                            firstErr = r.error;
                        }
                    });

                    if (!anyOk){
                        loading.innerHTML = '<div class="dnc-sn-mpx-error">' +
                            '<strong>⚠️ ' + (firstErr && firstErr.message ? escapeHtml(firstErr.message) : 'ไม่สามารถโหลดข้อมูลได้') + '</strong>' +
                            '</div>';
                        return;
                    }

                    // Hydrate product card from any successful quote
                    var first = STATE.quotes[1] || STATE.quotes[2] || STATE.quotes[3];
                    if (first){
                        if (first.product_image && $('[data-role="product-img"]')){
                            $('[data-role="product-img"]').src = first.product_image;
                        }
                        if (first.product_name){
                            // V.0.7 — SET-context renewal-as-bundle (boss decision 2026-05-18):
                            //   "ไม่ต้องต่อทีละชิ้นถ้าเป็นชุดก็ต่ออายุเป็นชุด"
                            //   When is_set_context=true, append "(ชุด N ชิ้น)" to product name
                            //   so customer understands they're renewing the entire SET bundle.
                            var displayName = first.product_name;
                            if (first.is_set_context && first.plate_count > 1){
                                displayName += ' (ชุด ' + first.plate_count + ' ชิ้น)';
                            }
                            $('[data-role="product-name"]').textContent = displayName;
                        }
                        if (first.current_warranty_end){
                            $('[data-role="product-meta"]').textContent = 'ประกันถึง: ' + first.current_warranty_end;
                        }
                        // V.0.7 — Inject SET-context info banner under product card.
                        // Tells customer: this renewal covers ALL plates in the SET,
                        // not just the SN they scanned.
                        if (first.is_set_context && first.plate_count > 1){
                            var card = $('[data-role="product-card"]');
                            if (card && !$('[data-role="set-context-banner"]')){
                                var banner = document.createElement('div');
                                banner.className = 'dnc-sn-mpx-info';
                                banner.setAttribute('data-role', 'set-context-banner');
                                banner.setAttribute('role', 'status');
                                banner.style.cssText = 'margin:12px 0;padding:12px;background:#eff6ff;border-left:4px solid #2563eb;border-radius:6px;font-size:13px;color:#1e3a8a;';
                                banner.innerHTML =
                                    '<strong>🔗 ต่ออายุเป็นชุด</strong><br>' +
                                    '<span style="font-size:12px;">เพลทนี้อยู่ในชุดสินค้า (' + first.plate_count + ' ชิ้น) — ' +
                                    'การต่ออายุจะครอบคลุมเพลททุกชิ้นในชุดเดียวกันโดยอัตโนมัติ</span>';
                                card.parentNode.insertBefore(banner, card.nextSibling);
                            }
                        }
                    }

                    renderPlans();

                    loading.style.display = 'none';
                    body.hidden = false;
                });
            }

            function escapeHtml(s){
                if (s == null) return '';
                return String(s).replace(/[&<>"']/g, function(c){
                    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
                });
            }

            function renderPlans(){
                var container = $('[data-role="plans-container"]');
                if (!container) return;
                container.innerHTML = '';

                var availableYears = [];
                [1,2,3].forEach(function(y){
                    var q = STATE.quotes[y];
                    if (q && q.base_price != null) availableYears.push(y);
                });

                if (availableYears.length === 0){
                    container.innerHTML = '<div class="dnc-sn-mpx-error">ไม่มีแผนสำหรับเพลทนี้</div>';
                    return;
                }

                // Pick "best value" = highest savings %
                var bestYears = null, bestSavings = 0;
                availableYears.forEach(function(y){
                    var q = STATE.quotes[y];
                    var perYear = q.base_price / y;
                    var oneYear = STATE.quotes[1] ? STATE.quotes[1].base_price : perYear;
                    var savings = oneYear > 0 ? Math.round((1 - perYear/oneYear) * 100) : 0;
                    if (savings > bestSavings){ bestSavings = savings; bestYears = y; }
                });

                // If selected default not available, pick first available
                if (availableYears.indexOf(STATE.selectedYears) === -1){
                    STATE.selectedYears = availableYears[0];
                }

                availableYears.forEach(function(y){
                    var q = STATE.quotes[y];
                    var card = document.createElement('div');
                    card.className = 'dnc-sn-mpx-plan' + (y === STATE.selectedYears ? ' is-selected' : '');
                    card.setAttribute('data-action', 'select-plan');
                    card.setAttribute('data-years', String(y));
                    card.setAttribute('role', 'button');
                    card.setAttribute('tabindex', '0');
                    card.setAttribute('aria-pressed', y === STATE.selectedYears ? 'true' : 'false');

                    var perYear = q.base_price / y;
                    var savingsPct = STATE.quotes[1] && STATE.quotes[1].base_price > 0
                        ? Math.round((1 - perYear / STATE.quotes[1].base_price) * 100)
                        : 0;

                    var html = '';
                    if (y === bestYears && bestSavings > 0){
                        html += '<span class="badge-recommend">🔥 แนะนำ</span>';
                    }
                    html += '<div class="label">' + y + ' ปี</div>';
                    html += '<div class="price">' + escapeHtml(fmtBaht(q.base_price)) + '</div>';
                    if (savingsPct > 0){
                        html += '<div class="savings">ประหยัด ' + savingsPct + '%</div>';
                    }
                    card.innerHTML = html;
                    container.appendChild(card);
                });

                updateTotal();
            }

            function updateTotal(){
                var q = STATE.quotes[STATE.selectedYears];
                if (!q){
                    $('[data-role="total-box"]').hidden = true;
                    setCheckoutEnabled(false);
                    return;
                }
                var subtotal = Number(q.base_price) || 0;
                var discount = Number(q.discount_if_any) || 0;
                // V.0.6 (boss 2026-05-15 non-VAT): vat=0 always; backward-compat field retained.
                var vat = Number(q.vat) || 0;
                var total = Number(q.total) || (subtotal - discount + vat);

                $('[data-role="total-subtotal"]').textContent = fmtBaht(subtotal);
                // V.0.6: VAT row removed from HTML — selector returns null. Guard prevents
                // TypeError on .textContent set if any legacy version of HTML restored.
                var vatEl = $('[data-role="total-vat"]');
                if (vatEl) vatEl.textContent = fmtBaht(vat);
                $('[data-role="total-final"]').textContent    = fmtBaht(total);

                if (discount > 0){
                    $('[data-role="total-discount-line"]').hidden = false;
                    $('[data-role="total-discount"]').textContent = '-' + fmtBaht(discount);
                } else {
                    $('[data-role="total-discount-line"]').hidden = true;
                }

                $('[data-role="total-box"]').hidden = false;
                setCheckoutEnabled(true);
            }

            function setCheckoutEnabled(enabled){
                var btn = $('[data-role="checkout-btn"]');
                if (!btn) return;
                btn.disabled = !enabled;
                btn.classList.toggle('is-disabled', !enabled);
            }

            // ─── Coupon ──────────────────────────────────────
            function applyCoupon(){
                var input = $('[data-role="coupon-input"]');
                var code = (input.value || '').trim().toUpperCase();
                if (!code){
                    STATE.couponCode = '';
                    loadQuotes(); // reload without coupon
                    return;
                }

                // Re-fetch quote for selected years with coupon
                api('GET', 'marketplace/quote?sn=' + encodeURIComponent(SN) +
                    '&years=' + STATE.selectedYears +
                    '&coupon=' + encodeURIComponent(code))
                    .then(function(d){
                        STATE.couponCode = code;
                        STATE.quotes[STATE.selectedYears] = d;
                        updateTotal();
                        alertMsg('✅ ใช้โค้ดส่วนลดสำเร็จ');
                    })
                    .catch(function(e){
                        alertMsg('❌ ' + (e.message || 'โค้ดไม่ถูกต้อง'));
                    });
            }

            // ─── Stage 2: Checkout ───────────────────────────
            function proceedCheckout(){
                var btn = $('[data-role="checkout-btn"]');
                if (btn.disabled) return;
                btn.disabled = true;

                api('POST', 'marketplace/checkout', {
                    sn: SN,
                    years: STATE.selectedYears,
                    coupon_code: STATE.couponCode
                })
                .then(function(d){
                    STATE.extensionId = d.extension_id;
                    STATE.expiresAt   = d.expires_at;

                    if (d.promptpay_qr){
                        $('[data-role="promptpay-qr"]').src = d.promptpay_qr;
                    }
                    $('[data-role="payment-amount"]').textContent = fmtBaht(d.amount);

                    if (d.bank){
                        $('[data-role="bank-name"]').textContent    = d.bank.name || '—';
                        $('[data-role="bank-account"]').textContent = d.bank.account || '—';
                        $('[data-role="bank-holder"]').textContent  = d.bank.holder || '—';
                    }

                    startCountdown(d.expires_at);
                    showStage(2);
                })
                .catch(function(e){
                    alertMsg('❌ ' + (e.message || 'ไม่สามารถดำเนินการได้'));
                    btn.disabled = false;
                });
            }

            function startCountdown(expiresAt){
                if (STATE.countdownTimer) clearInterval(STATE.countdownTimer);
                if (!expiresAt) return;
                var endTs = new Date(expiresAt).getTime();
                if (isNaN(endTs)) return;

                function tick(){
                    var diff = endTs - Date.now();
                    if (diff <= 0){
                        $('[data-role="timer-display"]').textContent = '00:00:00';
                        clearInterval(STATE.countdownTimer);
                        return;
                    }
                    var h = Math.floor(diff / 3600000);
                    var m = Math.floor((diff % 3600000) / 60000);
                    var s = Math.floor((diff % 60000) / 1000);
                    $('[data-role="timer-display"]').textContent =
                        (h<10?'0':'') + h + ':' + (m<10?'0':'') + m + ':' + (s<10?'0':'') + s;
                }
                tick();
                STATE.countdownTimer = setInterval(tick, 1000);
            }

            // ─── Stage 3: Slip upload ────────────────────────
            function triggerUpload(){
                $('[data-role="slip-file-input"]').click();
            }

            function onSlipSelected(e){
                var file = e.target.files && e.target.files[0];
                if (!file) return;
                if (!/^image\//.test(file.type)){
                    alertMsg('❌ กรุณาเลือกรูปภาพเท่านั้น');
                    return;
                }
                if (file.size > 10 * 1024 * 1024){
                    alertMsg('❌ ไฟล์ใหญ่เกิน 10MB');
                    return;
                }

                showStage(3);
                compressIfNeeded(file).then(uploadSlip).catch(function(err){
                    alertMsg('❌ ' + (err.message || 'อัพโหลดล้มเหลว'));
                    showStage(2);
                });
            }

            // Client-side compression: > 2MB → JPEG q=0.85, max 1600px
            function compressIfNeeded(file){
                return new Promise(function(resolve, reject){
                    if (file.size <= 2 * 1024 * 1024){
                        resolve(file);
                        return;
                    }
                    var url = URL.createObjectURL(file);
                    var img = new Image();
                    img.onload = function(){
                        try {
                            var maxDim = 1600;
                            var w = img.width, h = img.height;
                            if (w > maxDim || h > maxDim){
                                if (w > h){ h = Math.round(h * maxDim / w); w = maxDim; }
                                else      { w = Math.round(w * maxDim / h); h = maxDim; }
                            }
                            var canvas = document.createElement('canvas');
                            canvas.width = w; canvas.height = h;
                            var ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, w, h);
                            canvas.toBlob(function(blob){
                                URL.revokeObjectURL(url);
                                if (!blob){ reject(new Error('compress_failed')); return; }
                                resolve(new File([blob], file.name.replace(/\.[^.]+$/,'') + '.jpg', {type:'image/jpeg'}));
                            }, 'image/jpeg', 0.85);
                        } catch(e){
                            URL.revokeObjectURL(url);
                            reject(e);
                        }
                    };
                    img.onerror = function(){ URL.revokeObjectURL(url); reject(new Error('image_load_failed')); };
                    img.src = url;
                });
            }

            function uploadSlip(file){
                // Step 1 — upload to WP media library
                var fd = new FormData();
                fd.append('file', file);

                fetch('/wp-json/wp/v2/media', {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'X-WP-Nonce': NONCE },
                    body: fd
                })
                .then(function(r){ return r.json().then(function(d){ return {ok:r.ok, data:d}; }); })
                .then(function(res){
                    if (!res.ok || !res.data.id){
                        throw new Error(res.data.message || 'media_upload_failed');
                    }
                    var mediaId = res.data.id;
                    var thumb   = res.data.source_url || (res.data.media_details && res.data.media_details.sizes && res.data.media_details.sizes.medium && res.data.media_details.sizes.medium.source_url);
                    if (thumb){
                        $('[data-role="slip-preview"]').innerHTML = '<img src="' + escapeHtml(thumb) + '" alt="slip preview">';
                    }
                    return api('POST', 'marketplace/checkout/' + STATE.extensionId + '/upload-slip', {
                        slip_image_id: mediaId
                    });
                })
                .then(function(d){
                    handleVerifyResult(d);
                })
                .catch(function(e){
                    alertMsg('❌ ' + (e.message || 'อัพโหลดล้มเหลว'));
                    showStage(2);
                });
            }

            function handleVerifyResult(d){
                if (d.status === 'paid'){
                    showSuccess(d);
                } else if (d.status === 'pending_admin_review'){
                    // Begin polling
                    STATE.pollCount = 0;
                    pollVerifyStatus();
                } else if (d.status === 'rejected'){
                    showRejected(d);
                } else {
                    pollVerifyStatus();
                }
            }

            function pollVerifyStatus(){
                STATE.pollCount += 1;
                if (STATE.pollCount > 3){
                    // After 30s → show "admin will review" message
                    $('[data-role="verify-status"]').hidden = true;
                    $('[data-role="verify-pending-msg"]').hidden = false;
                    if (STATE.pollTimer) clearTimeout(STATE.pollTimer);
                    return;
                }

                STATE.pollTimer = setTimeout(function(){
                    api('GET', 'marketplace/' + STATE.extensionId + '/status').then(function(d){
                        if (d.status === 'paid'){ showSuccess(d); }
                        else if (d.status === 'rejected'){ showRejected(d); }
                        else { pollVerifyStatus(); }
                    }).catch(function(){
                        pollVerifyStatus();
                    });
                }, 10000);
            }

            // ─── Stage 4: Result ─────────────────────────────
            function showSuccess(d){
                if (STATE.pollTimer) clearTimeout(STATE.pollTimer);
                var card = $('[data-role="result-card"]');
                var html = '<div class="icon">✅</div>';
                html += '<h2>ต่อประกันสำเร็จ!</h2>';
                if (d.new_warranty_end){
                    html += '<p class="sub">ประกันใหม่ถึง <strong>' + escapeHtml(d.new_warranty_end) + '</strong></p>';
                }
                if (d.receipt_url){
                    html += '<a href="' + escapeHtml(d.receipt_url) + '" class="dnc-sn-mpx-btn dnc-sn-mpx-btn-primary" style="margin-top:20px;">📥 ดาวน์โหลดใบเสร็จ</a>';
                }
                html += '<a href="/dashboard" class="dnc-sn-mpx-btn dnc-sn-mpx-btn-secondary">↩ กลับหน้าหลัก</a>';
                card.innerHTML = html;
                showStage(4);
            }

            function showPending(){
                if (STATE.pollTimer) clearTimeout(STATE.pollTimer);
                var card = $('[data-role="result-card"]');
                card.innerHTML =
                    '<div class="icon">⏳</div>' +
                    '<h2>รอแอดมินตรวจสอบ</h2>' +
                    '<p class="sub">แอดมินจะตรวจสอบสลิปของคุณภายใน 2-4 ชม.<br>ระบบจะส่ง LINE แจ้งทันทีที่อนุมัติ</p>' +
                    '<a href="/dashboard" class="dnc-sn-mpx-btn dnc-sn-mpx-btn-secondary">↩ กลับหน้าหลัก</a>';
                showStage(4);
            }

            function showRejected(d){
                if (STATE.pollTimer) clearTimeout(STATE.pollTimer);
                var card = $('[data-role="result-card"]');
                var reason = d && d.reject_reason ? d.reject_reason : 'ไม่ผ่านการตรวจสอบ';
                card.innerHTML =
                    '<div class="icon">❌</div>' +
                    '<h2>ไม่ผ่านการตรวจสอบ</h2>' +
                    '<p class="sub">เหตุผล: ' + escapeHtml(reason) + '<br>กรุณาติดต่อทีมงานเพื่อแก้ไข</p>' +
                    '<a href="/dashboard" class="dnc-sn-mpx-btn dnc-sn-mpx-btn-secondary">↩ กลับหน้าหลัก</a>';
                showStage(4);
            }

            // ─── Event delegation (UX-H3 compliant) ──────────
            ROOT.addEventListener('click', function(e){
                var t = e.target;
                while (t && t !== ROOT){
                    var act = t.getAttribute && t.getAttribute('data-action');
                    if (act){
                        e.preventDefault();
                        switch (act){
                            case 'select-plan':
                                var y = parseInt(t.getAttribute('data-years'), 10);
                                if (y && STATE.quotes[y]){
                                    STATE.selectedYears = y;
                                    $$('.dnc-sn-mpx-plan').forEach(function(c){
                                        c.classList.remove('is-selected');
                                        c.setAttribute('aria-pressed', 'false');
                                    });
                                    t.classList.add('is-selected');
                                    t.setAttribute('aria-pressed', 'true');
                                    updateTotal();
                                }
                                return;
                            case 'apply-coupon':       applyCoupon(); return;
                            case 'proceed-checkout':   proceedCheckout(); return;
                            case 'upload-slip-trigger':triggerUpload(); return;
                            case 'back-to-plans':      showStage(1); return;
                        }
                    }
                    t = t.parentNode;
                }
            });

            // Keyboard activation for plan cards
            ROOT.addEventListener('keydown', function(e){
                if (e.key !== 'Enter' && e.key !== ' ') return;
                var t = e.target;
                if (t && t.getAttribute && t.getAttribute('data-action') === 'select-plan'){
                    e.preventDefault();
                    t.click();
                }
            });

            // File input change
            var fileInput = $('[data-role="slip-file-input"]');
            if (fileInput){
                fileInput.addEventListener('change', onSlipSelected);
            }

            // ─── Bootstrap ───────────────────────────────────
            loadQuotes();
        })();
        </script>
        <?php
    }
}

