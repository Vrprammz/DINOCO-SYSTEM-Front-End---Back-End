            // V.31.2 F1 — Banner dismiss + 7-day TTL via localStorage.
            // Per-user key prefix prevents cross-user leak on shared device:
            //   Key shape: dnc_sn_banner_dismiss_<user_id>_<bid> = expires_at_ms
            // On page load, scan all dismiss keys → drop ones whose user_id
            // segment doesn't match current user (logout/login swap).
            (function() {
                var DNC_USER_ID = "<?php echo (int) get_current_user_id(); ?>";
                var KEY_PREFIX  = 'dnc_sn_banner_dismiss_';
                var USER_PREFIX = KEY_PREFIX + DNC_USER_ID + '_';

                function buildKey(bid) { return USER_PREFIX + bid; }

                // Scrub stale keys belonging to other users (shared device safety).
                // Also drops legacy V.31.1 keys (no user_id segment) that would
                // otherwise persist forever and leak across login switches.
                function scrubOtherUserKeys() {
                    try {
                        if (typeof localStorage === 'undefined') return;
                        var toRemove = [];
                        for (var i = 0; i < localStorage.length; i++) {
                            var k = localStorage.key(i);
                            if (!k || k.indexOf(KEY_PREFIX) !== 0) continue;
                            // Match `dnc_sn_banner_dismiss_<digits>_<bid>` strictly.
                            // Anything else (other user OR legacy unscoped) → drop.
                            if (k.indexOf(USER_PREFIX) !== 0) toRemove.push(k);
                        }
                        toRemove.forEach(function(k) { localStorage.removeItem(k); });
                    } catch (e) { /* silent */ }
                }

                function applyDismissFilter() {
                    try {
                        var now = Date.now();
                        var banners = document.querySelectorAll('.dnc-sn-banner[data-banner-id]');
                        banners.forEach(function(el) {
                            var bid = el.getAttribute('data-banner-id') || '';
                            if (!bid) return;
                            var key = buildKey(bid);
                            var exp = parseInt(localStorage.getItem(key) || '0', 10);
                            if (exp && exp > now) {
                                el.style.display = 'none';
                            } else if (exp && exp <= now) {
                                // expired → cleanup
                                localStorage.removeItem(key);
                            }
                        });
                    } catch (e) { /* localStorage disabled — silent */ }
