if ( ! function_exists( 'dinoco_render_tier_badge' ) ) {
    /**
     * Render tier badge inline span HTML.
     *
     * Boss Q27 confirmed = B2B distributor rank_system pattern (silver/gold/
     * platinum/diamond visual style, with bronze added for new members).
     *
     * 5 tier slugs:
     *   bronze   🥉 #b45309 bg
     *   silver   🥈 #94a3b8 bg
     *   gold     🥇 #ca8a04 bg
     *   platinum 💜 #4338ca bg
     *   diamond  💎 linear-gradient(135deg, #7c3aed, #a855f7)
     *
     * Returns empty string for invalid/unknown tier slug — caller can safely
     * concat without null check. Whitespace + case normalized to lowercase.
     *
     * @param string $tier  Tier slug (case-insensitive)
     * @return string  HTML <span> or empty string
     */
    function dinoco_render_tier_badge( $tier ) {
        $valid = array(
            'bronze'   => array( '🥉', 'Bronze' ),
            'silver'   => array( '🥈', 'Silver' ),
            'gold'     => array( '🥇', 'Gold' ),
            'platinum' => array( '💜', 'Platinum' ),
            'diamond'  => array( '💎', 'Diamond' ),
        );
        $tier = is_string( $tier ) ? strtolower( trim( $tier ) ) : '';
        if ( $tier === '' || ! isset( $valid[ $tier ] ) ) {
            return '';
        }
        list( $emoji, $label ) = $valid[ $tier ];
        return sprintf(
            '<span class="dnc-sn-tier-badge dnc-sn-tier-%s">%s %s</span>',
            esc_attr( $tier ),
            esc_html( $emoji ),
            esc_html( $label )
        );
    }
}

// -----------------------------------------------------------
// V.31.1 — Banner data aggregator (cached) + rotation (1 per category)
// -----------------------------------------------------------
// Perf finding: previous helper fired up to 4-6 standalone queries
// (expiring + anniversary + review_pending each = 1+ query). Cache result
// in per-user transient 5 min (`dinoco_sn_banner_<user_id>`). Invalidation
// via `dinoco_sn_pool_status_changed_for_user` action — fire from SN flip
// sites. Defensive function_exists guards everywhere.
if ( ! function_exists( 'dinoco_dashboard_banner_data' ) ) {
    /**
     * Returns aggregated banner queue { items: array, total_pending: int }.
     * Each item shape: { type, sn, days_left|years|score, ts }.
     *
     * @param int $user_id
     * @return array { items: array<array>, total_pending: int }
     */
    function dinoco_dashboard_banner_data( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return array( 'items' => array(), 'total_pending' => 0 );

        $cache_key = 'dinoco_sn_banner_' . $user_id;
        $cached = get_transient( $cache_key );
        if ( is_array( $cached ) && isset( $cached['items'] ) ) {
            return $cached;
        }

        $items = array();
        $total = 0;

        // V.32.0 Sprint 32 — Claim charge pending banner (flag-gated).
        // Renders FIRST (highest priority — financial urgency outranks
        // expiry/anniversary/review). Defensive function_exists +
        // table_name guard; silent skip when feature off or schema
        // missing (REG-029 preserves V.31.8 behavior when flag OFF).
        if ( (bool) get_option( 'dinoco_claim_payment_enabled', false )
             && function_exists( 'dinoco_claim_charges_table_name' ) ) {
            global $wpdb;
            $ch_table = dinoco_claim_charges_table_name();
            // Cheap row count — short-circuits when no pending charges.
            // user_id column populated by V.0.7 / V.0.8 paths (claim
            // owner mirrored at INSERT). Status whitelist matches
            // DINOCO_CLAIM_CHARGES_STATUS_WHITELIST `pending_payment`
            // (awaiting customer slip) + `pending_review` (slip uploaded,
            // admin verifying).
            $ch_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, claim_id, amount_thb FROM {$ch_table}
                  WHERE user_id = %d AND status IN ('pending_payment','pending_review')
                  ORDER BY created_at DESC
                  LIMIT 5",
                $user_id
            ) );
            if ( is_array( $ch_rows ) ) {
                foreach ( $ch_rows as $chrow ) {
                    $items[] = array(
                        'type'      => 'charge_pending',
                        'sn'        => '', // not SN-bound — claim-bound
                        'claim_id'  => isset( $chrow->claim_id )  ? (int)   $chrow->claim_id  : 0,
                        'charge_id' => isset( $chrow->id )        ? (int)   $chrow->id        : 0,
                        'amount'    => isset( $chrow->amount_thb )? (float) $chrow->amount_thb: 0.0,
                    );
                    $total++;
                }
            }
        }

        // F#1 Expiry
        if ( function_exists( 'dinoco_sn_get_user_expiring_plates' ) ) {
            $rows = dinoco_sn_get_user_expiring_plates( $user_id, 30 );
            if ( is_array( $rows ) ) {
                foreach ( $rows as $row ) {
                    $sn = isset( $row->sn ) ? (string) $row->sn : '';
                    if ( $sn === '' ) continue;
                    $items[] = array(
                        'type'      => 'expiry',
                        'sn'        => $sn,
                        'days_left' => isset( $row->days_left ) ? (int) $row->days_left : 0,
                    );
                    $total++;
                }
            }
        }

        // F#4 Anniversary
        if ( function_exists( 'dinoco_sn_get_user_anniversaries' ) ) {
            $rows = dinoco_sn_get_user_anniversaries( $user_id, 7 );
            if ( is_array( $rows ) ) {
                foreach ( $rows as $row ) {
                    $sn = isset( $row->sn ) ? (string) $row->sn : '';
                    if ( $sn === '' ) continue;
                    $items[] = array(
                        'type'  => 'anniversary',
                        'sn'    => $sn,
                        'years' => isset( $row->years_diff ) ? (int) $row->years_diff : 1,
                    );
                    $total++;
                }
            }
        }

        // F#10 Review
        if ( function_exists( 'dinoco_sn_get_pending_reviews' ) ) {
            $rows = dinoco_sn_get_pending_reviews( $user_id );
            if ( is_array( $rows ) ) {
                foreach ( $rows as $row ) {
                    $sn = isset( $row->sn ) ? (string) $row->sn : '';
                    if ( $sn === '' ) continue;
                    $items[] = array(
                        'type' => 'review',
                        'sn'   => $sn,
                    );
                    $total++;
                }
            }
        }

        $payload = array(
            'items'         => $items,
            'total_pending' => $total,
        );
        set_transient( $cache_key, $payload, 5 * MINUTE_IN_SECONDS );
        return $payload;
    }
}

// Cache invalidation listener — wired to optional canonical action that SN flip
// sites can fire. function_exists guard is tolerated since `add_action` is
// always available; we bail in the callback if user_id is bad.
if ( ! function_exists( 'dinoco_sn_invalidate_banner_cache' ) ) {
    function dinoco_sn_invalidate_banner_cache( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id > 0 ) {
            delete_transient( 'dinoco_sn_banner_' . $user_id );
        }
    }
    add_action( 'dinoco_sn_pool_status_changed_for_user', 'dinoco_sn_invalidate_banner_cache', 10, 1 );
}

// V.32.0 Sprint 32 — Claim charge state change → invalidate banner cache for
// owner. Listens to `dinoco/claim/charge_state_changed` fired by Claim Payment
// LIFF charge state machine (verified / refunded / cancelled / rejected →
// banner should disappear instantly, not wait for 5min transient TTL).
if ( ! function_exists( 'dinoco_sn_invalidate_banner_cache_on_charge_state' ) ) {
    function dinoco_sn_invalidate_banner_cache_on_charge_state( $charge_id, $from_state, $to_state, $context = array() ) {
        $owner_uid = isset( $context['user_id'] ) ? (int) $context['user_id'] : 0;
        if ( $owner_uid <= 0 && function_exists( 'dinoco_claim_payment_resolve_claim_owner' ) ) {
            $claim_id = isset( $context['claim_id'] ) ? (int) $context['claim_id'] : 0;
            if ( $claim_id > 0 ) {
                $owner_uid = (int) dinoco_claim_payment_resolve_claim_owner( $claim_id );
            }
        }
        if ( $owner_uid > 0 ) {
            delete_transient( 'dinoco_sn_banner_' . $owner_uid );
        }
    }
    add_action( 'dinoco/claim/charge_state_changed', 'dinoco_sn_invalidate_banner_cache_on_charge_state', 10, 4 );
}

if ( ! function_exists( 'dinoco_dashboard_banners' ) ) {
    /**
     * Render banner stack on home (V.31.1 priority rotation).
     *
     * Boss Q25 cap=3. V.31.1 enforces rotation: at most 1 per category
     * (expiry / anniversary / review) — prevents 3 expiry banners hiding
     * an anniversary milestone. ✕ dismiss button writes localStorage TTL 7d.
     * "ดูทั้งหมด (N)" link surfaces total pending when > 3.
     *
     * @param int $user_id
     * @return string  HTML (empty if no banners after dismiss filter)
     */
    function dinoco_dashboard_banners( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return '';

        $data = function_exists( 'dinoco_dashboard_banner_data' )
            ? dinoco_dashboard_banner_data( $user_id )
            : array( 'items' => array(), 'total_pending' => 0 );
        $items_all = isset( $data['items'] ) && is_array( $data['items'] ) ? $data['items'] : array();
        $total     = isset( $data['total_pending'] ) ? (int) $data['total_pending'] : count( $items_all );

        // Rotation: 1 per category max (boss Q25 cap=3 raised to 4 in V.32.0
        // when charge_pending present — financial urgency overrides cap).
        $picked = array( 'charge_pending' => null, 'expiry' => null, 'anniversary' => null, 'review' => null );
        foreach ( $items_all as $row ) {
            $type = isset( $row['type'] ) ? $row['type'] : '';
            if ( ! isset( $picked[ $type ] ) || $picked[ $type ] !== null ) continue;
            $picked[ $type ] = $row;
        }
        // V.32.1 Sprint 33 S4 — Banner priority dynamic. Default = charge_pending FIRST
        // (Sprint 32 financial urgency rule). BUT: if customer has expiry banner with
        // days_left < 7 → expiry wins (irreversible warranty lapse outranks recoverable
        // payment delay; customer can always pay later, cannot un-expire a warranty).
        // For all other charge+expiry combos charge_pending still wins.
        $_expiry_window_days = 7;
        $_expiry_critical = false;
        if ( is_array( $picked['expiry'] ) ) {
            $_dl = isset( $picked['expiry']['days_left'] ) ? (int) $picked['expiry']['days_left'] : 999;
            if ( $_dl >= 0 && $_dl < $_expiry_window_days ) {
                $_expiry_critical = true;
            }
        }
        if ( $_expiry_critical ) {
            // Expiry-critical mode: expiry first, charge_pending second.
            $ordered = array_filter( array(
                $picked['expiry'],
                $picked['charge_pending'],
                $picked['anniversary'],
                $picked['review'],
            ) );
        } else {
            // Default Sprint 32 order — charge_pending first.
            $ordered = array_filter( array(
                $picked['charge_pending'],
                $picked['expiry'],
                $picked['anniversary'],
                $picked['review'],
            ) );
        }
        if ( empty( $ordered ) ) return '';

        $html = array();
        foreach ( $ordered as $row ) {
            $type = $row['type'];
            $sn   = (string) ( $row['sn'] ?? '' );
            // Stable banner ID → JS reads localStorage with this key
            $bid = $type . '_' . substr( md5( $sn . '|' . $user_id ), 0, 10 );

            if ( $type === 'charge_pending' ) {
                // V.32.0 Sprint 32 / V.32.1 Sprint 33 — Claim charge pending banner.
                // B4 — single sentence copy + whole banner clickable (anchor wrap).
                // S6 — role="alert" + aria-live="polite" (screen reader financial cue).
                // Click scrolls to inline asset card anchor + auto-opens payment modal
                // via `?action=pay` URL param handled by `dncDashClaimAutoScroll()`.
                $claim_id  = (int) ( $row['claim_id']  ?? 0 );
                $charge_id = (int) ( $row['charge_id'] ?? 0 );
                $amount    = (float) ( $row['amount']  ?? 0.0 );
                $amount_fmt = number_format( $amount, 0, '.', ',' );
                $dash_url = home_url( '/dashboard/' )
                          . '?action=pay&claim_id=' . $claim_id
                          . '&charge_id=' . $charge_id
                          . '#claim-' . $claim_id . '-charge-' . $charge_id;
                $banner_bid = 'charge_pending_' . substr( md5( $charge_id . '|' . $user_id ), 0, 10 );
                $html[] = sprintf(
                    '<a href="%s" class="dnc-sn-banner dnc-sn-banner-charge-pending dnc-sn-banner-clickable" data-banner-id="%s" data-charge-id="%d" data-claim-id="%d" role="alert" aria-live="polite">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this);event.preventDefault();event.stopPropagation();">✕</button>'
                    . '<div class="dnc-sn-banner-icon">💰</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">💰 ค่าซ่อมรอชำระ ฿%s — แตะเพื่อชำระ</div>'
                    . '</div>'
                    . '</a>',
                    esc_url( $dash_url ),
                    esc_attr( $banner_bid ),
                    $charge_id,
                    $claim_id,
                    esc_html( $amount_fmt )
                );
            } elseif ( $type === 'expiry' ) {
                $days = (int) ( $row['days_left'] ?? 0 );
                $html[] = sprintf(
                    '<div class="dnc-sn-banner dnc-sn-banner-expiry" data-banner-id="%s">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this)">✕</button>'
                    . '<div class="dnc-sn-banner-icon">⏰</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">%s ประกันหมดใน %d วัน</div>'
                    .   '<div class="dnc-sn-banner-actions">'
                    .     '<a href="%s" class="dnc-sn-banner-cta">ต่อประกัน</a>'
                    .     '<a href="%s" class="dnc-sn-banner-link">ดูรายละเอียด</a>'
                    .   '</div>'
                    . '</div>'
                    . '</div>',
                    esc_attr( $bid ),
                    esc_html( $sn ),
                    $days,
                    esc_url( '/extension?sn=' . rawurlencode( $sn ) ),
                    esc_url( '/warranty/detail?sn=' . rawurlencode( $sn ) )
                );
            } elseif ( $type === 'anniversary' ) {
                $years = (int) ( $row['years'] ?? 1 );
                $html[] = sprintf(
                    '<div class="dnc-sn-banner dnc-sn-banner-anniversary" data-banner-id="%s">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this)">✕</button>'
                    . '<div class="dnc-sn-banner-icon">🎉</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">ครบรอบ %d ปีแล้ว!</div>'
                    .   '<div class="dnc-sn-banner-sub">ขอบคุณที่อยู่กับเรา %s</div>'
                    .   '<div class="dnc-sn-banner-actions">'
                    .     '<a href="%s" class="dnc-sn-banner-cta">รับรางวัล</a>'
                    .   '</div>'
                    . '</div>'
                    . '</div>',
                    esc_attr( $bid ),
                    $years,
                    esc_html( $sn ),
                    esc_url( '/anniversary?sn=' . rawurlencode( $sn ) )
                );
            } elseif ( $type === 'review' ) {
                $html[] = sprintf(
                    '<div class="dnc-sn-banner dnc-sn-banner-review" data-banner-id="%s">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this)">✕</button>'
                    . '<div class="dnc-sn-banner-icon">⭐</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">ให้คะแนน DINOCO หน่อย</div>'
                    .   '<div class="dnc-sn-banner-sub">รับ ฿50 หลังให้คะแนน</div>'
                    .   '<div class="dnc-sn-banner-actions">'
                    .     '<a href="%s" class="dnc-sn-banner-cta">ให้คะแนน + รับ ฿50</a>'
                    .   '</div>'
                    . '</div>'
                    . '</div>',
                    esc_attr( $bid ),
                    esc_url( '/review?sn=' . rawurlencode( $sn ) )
                );
            }
        }

        // V.31.2 F8 — "ดูทั้งหมด" surfaces when total > rendered.
        // Phase 4 `/notifications/all` page is not yet built — gate the link
        // behind `dinoco_sn_notifications_page_ready` flag (default OFF).
        // Until flag flips → render disabled informational badge instead so
        // user is not led to a broken page.
        $rendered = count( $html );
        if ( $total > $rendered ) {
            $extra        = $total - $rendered;
            $page_ready   = (bool) get_option( 'dinoco_sn_notifications_page_ready', false );
            if ( $page_ready ) {
                $html[] = sprintf(
                    '<a href="%s" class="dnc-sn-banner-viewall">ดูทั้งหมด (%d)</a>',
                    esc_url( '/notifications/all' ),
                    $total
                );
            } else {
                // Disabled badge — not a link. role=note + tooltip via title.
                $html[] = sprintf(
                    '<span class="dnc-sn-banner-viewall dnc-sn-banner-viewall-disabled" '
                    . 'role="note" aria-disabled="true" '
                    . 'title="หน้ารายการแจ้งเตือนกำลังพัฒนา">+%d เพิ่มเติม</span>',
                    $extra
                );
            }
        }

        /* V.31.5 S3 — Banner carousel when ≥2 banners.
           CSS scroll-snap horizontal carousel (native, no JS lib) — saves
           ~240px vertical space when boss customer has 3 banners pending.
           Mobile swipe-friendly + dots indicator. Falls back to vertical
           stack on ≥1024px viewport (admin tablet use). */
        $count = count( $html );
        if ( $count <= 1 ) {
            // 0 or 1 banner — no carousel needed, keep simple stack
            return '<div class="dnc-sn-banners-wrap" data-banners-total="' . (int) $total . '">' . implode( '', $html ) . '</div>';
        }
        // Build dots indicator
        $dots = '<div class="dnc-sn-banners-dots" role="tablist" aria-label="แจ้งเตือน">';
        for ( $i = 0; $i < $count; $i++ ) {
            $dots .= sprintf(
                '<button type="button" class="dnc-sn-banners-dot%s" role="tab" aria-label="แจ้งเตือนที่ %d" data-banner-index="%d" onclick="dncSnBannerScrollTo(this)"></button>',
                $i === 0 ? ' dnc-sn-banners-dot-active' : '',
                $i + 1,
                $i
            );
        }
        $dots .= '</div>';
        return '<div class="dnc-sn-banners-wrap dnc-sn-banners-carousel" data-banners-total="' . (int) $total . '" data-banners-count="' . $count . '">'
            . '<div class="dnc-sn-banners-track" tabindex="0" role="region" aria-label="แจ้งเตือน ' . $count . ' รายการ">'
            . implode( '', $html )
            . '</div>'
            . $dots
            . '</div>';
    }
}

if ( ! function_exists( 'dinoco_dashboard_stats_card' ) ) {
    /**
     * 4-cell stats grid (plates / active / claims / member years).
     *
     * Defensive: uses dinoco_sn_get_user_stats() under function_exists guard.
     * Returns empty string when SN system not loaded — caller renders nothing.
     *
     * @param int $user_id
     * @return string HTML
     */
    function dinoco_dashboard_stats_card( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return '';
        if ( ! function_exists( 'dinoco_sn_get_user_stats' ) ) return '';

        $stats = dinoco_sn_get_user_stats( $user_id );
        if ( ! is_array( $stats ) ) return '';

        $plates  = (int) ( $stats['plates_count'] ?? 0 );
        $active  = (int) ( $stats['active_count'] ?? 0 );
        $claims  = (int) ( $stats['claim_count']  ?? 0 );
        $years   = (int) ( $stats['member_years'] ?? 0 );

        // No plates yet (legacy fallback or new user) → don't render section
        // (Member Dashboard Header already shows "Royal Upgrade" + register CTA)
        if ( $plates === 0 && $active === 0 && $claims === 0 && $years === 0 ) {
            return '';
        }

        return sprintf(
            '<div class="dnc-sn-stats-grid">'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">ประกันทั้งหมด</div></div>'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">ใช้งานอยู่</div></div>'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">เคลม</div></div>'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">ปีที่เป็นสมาชิก</div></div>'
            . '</div>',
            $plates, $active, $claims, $years
        );
    }
}

