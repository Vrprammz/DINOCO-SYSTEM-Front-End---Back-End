if ( ! function_exists( 'dinoco_render_tier_badge' ) ) {
    /**
     * Render tier badge inline span HTML.
     *
     * Boss Q27 confirmed = B2B distributor rank_system pattern (silver/gold/
     * platinum/diamond visual style, with bronze added for new members).
     *
     * 5 tier slugs:
     *   bronze   🥉 #b45309 bg
     *   silver   🥈 #94a3b8 bg
     *   gold     🥇 #ca8a04 bg
     *   platinum 💜 #4338ca bg
     *   diamond  💎 linear-gradient(135deg, #7c3aed, #a855f7)
     *
     * Returns empty string for invalid/unknown tier slug — caller can safely
     * concat without null check. Whitespace + case normalized to lowercase.
     *
     * @param string $tier  Tier slug (case-insensitive)
     * @return string  HTML <span> or empty string
     */
    function dinoco_render_tier_badge( $tier ) {
        $valid = array(
            'bronze'   => array( '🥉', 'Bronze' ),
            'silver'   => array( '🥈', 'Silver' ),
            'gold'     => array( '🥇', 'Gold' ),
            'platinum' => array( '💜', 'Platinum' ),
            'diamond'  => array( '💎', 'Diamond' ),
        );
        $tier = is_string( $tier ) ? strtolower( trim( $tier ) ) : '';
        if ( $tier === '' || ! isset( $valid[ $tier ] ) ) {
            return '';
        }
        list( $emoji, $label ) = $valid[ $tier ];
        return sprintf(
            '<span class="dnc-sn-tier-badge dnc-sn-tier-%s">%s %s</span>',
            esc_attr( $tier ),
            esc_html( $emoji ),
            esc_html( $label )
        );
    }
}

// -----------------------------------------------------------
// V.31.1 — Banner data aggregator (cached) + rotation (1 per category)
// -----------------------------------------------------------
// Perf finding: previous helper fired up to 4-6 standalone queries
// (expiring + anniversary + review_pending each = 1+ query). Cache result
// in per-user transient 5 min (`dinoco_sn_banner_<user_id>`). Invalidation
// via `dinoco_sn_pool_status_changed_for_user` action — fire from SN flip
// sites. Defensive function_exists guards everywhere.
if ( ! function_exists( 'dinoco_dashboard_banner_data' ) ) {
    /**
     * Returns aggregated banner queue { items: array, total_pending: int }.
     * Each item shape: { type, sn, days_left|years|score, ts }.
     *
     * @param int $user_id
     * @return array { items: array<array>, total_pending: int }
     */
    function dinoco_dashboard_banner_data( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return array( 'items' => array(), 'total_pending' => 0 );

        $cache_key = 'dinoco_sn_banner_' . $user_id;
        $cached = get_transient( $cache_key );
        if ( is_array( $cached ) && isset( $cached['items'] ) ) {
            return $cached;
        }

        $items = array();
        $total = 0;

        // F#1 Expiry
        if ( function_exists( 'dinoco_sn_get_user_expiring_plates' ) ) {
            $rows = dinoco_sn_get_user_expiring_plates( $user_id, 30 );
            if ( is_array( $rows ) ) {
                foreach ( $rows as $row ) {
                    $sn = isset( $row->sn ) ? (string) $row->sn : '';
                    if ( $sn === '' ) continue;
                    $items[] = array(
                        'type'      => 'expiry',
                        'sn'        => $sn,
                        'days_left' => isset( $row->days_left ) ? (int) $row->days_left : 0,
                    );
                    $total++;
                }
            }
        }

        // F#4 Anniversary
        if ( function_exists( 'dinoco_sn_get_user_anniversaries' ) ) {
            $rows = dinoco_sn_get_user_anniversaries( $user_id, 7 );
            if ( is_array( $rows ) ) {
                foreach ( $rows as $row ) {
                    $sn = isset( $row->sn ) ? (string) $row->sn : '';
                    if ( $sn === '' ) continue;
                    $items[] = array(
                        'type'  => 'anniversary',
                        'sn'    => $sn,
                        'years' => isset( $row->years_diff ) ? (int) $row->years_diff : 1,
                    );
                    $total++;
                }
            }
        }

        // F#10 Review
        if ( function_exists( 'dinoco_sn_get_pending_reviews' ) ) {
            $rows = dinoco_sn_get_pending_reviews( $user_id );
            if ( is_array( $rows ) ) {
                foreach ( $rows as $row ) {
                    $sn = isset( $row->sn ) ? (string) $row->sn : '';
                    if ( $sn === '' ) continue;
                    $items[] = array(
                        'type' => 'review',
                        'sn'   => $sn,
                    );
                    $total++;
                }
            }
        }

        $payload = array(
            'items'         => $items,
            'total_pending' => $total,
        );
        set_transient( $cache_key, $payload, 5 * MINUTE_IN_SECONDS );
        return $payload;
    }
}

// Cache invalidation listener — wired to optional canonical action that SN flip
// sites can fire. function_exists guard is tolerated since `add_action` is
// always available; we bail in the callback if user_id is bad.
if ( ! function_exists( 'dinoco_sn_invalidate_banner_cache' ) ) {
    function dinoco_sn_invalidate_banner_cache( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id > 0 ) {
            delete_transient( 'dinoco_sn_banner_' . $user_id );
        }
    }
    add_action( 'dinoco_sn_pool_status_changed_for_user', 'dinoco_sn_invalidate_banner_cache', 10, 1 );
}

if ( ! function_exists( 'dinoco_dashboard_banners' ) ) {
    /**
     * Render banner stack on home (V.31.1 priority rotation).
     *
     * Boss Q25 cap=3. V.31.1 enforces rotation: at most 1 per category
     * (expiry / anniversary / review) — prevents 3 expiry banners hiding
     * an anniversary milestone. ✕ dismiss button writes localStorage TTL 7d.
     * "ดูทั้งหมด (N)" link surfaces total pending when > 3.
     *
     * @param int $user_id
     * @return string  HTML (empty if no banners after dismiss filter)
     */
    function dinoco_dashboard_banners( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return '';

        $data = function_exists( 'dinoco_dashboard_banner_data' )
            ? dinoco_dashboard_banner_data( $user_id )
            : array( 'items' => array(), 'total_pending' => 0 );
        $items_all = isset( $data['items'] ) && is_array( $data['items'] ) ? $data['items'] : array();
        $total     = isset( $data['total_pending'] ) ? (int) $data['total_pending'] : count( $items_all );

        // Rotation: 1 per category max (boss Q25 cap=3)
        $picked = array( 'expiry' => null, 'anniversary' => null, 'review' => null );
        foreach ( $items_all as $row ) {
            $type = isset( $row['type'] ) ? $row['type'] : '';
            if ( ! isset( $picked[ $type ] ) || $picked[ $type ] !== null ) continue;
            $picked[ $type ] = $row;
        }
        $ordered = array_filter( array(
            $picked['expiry'],
            $picked['anniversary'],
            $picked['review'],
        ) );
        if ( empty( $ordered ) ) return '';

        $html = array();
        foreach ( $ordered as $row ) {
            $type = $row['type'];
            $sn   = (string) ( $row['sn'] ?? '' );
            // Stable banner ID → JS reads localStorage with this key
            $bid = $type . '_' . substr( md5( $sn . '|' . $user_id ), 0, 10 );

            if ( $type === 'expiry' ) {
                $days = (int) ( $row['days_left'] ?? 0 );
                $html[] = sprintf(
                    '<div class="dnc-sn-banner dnc-sn-banner-expiry" data-banner-id="%s">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this)">✕</button>'
                    . '<div class="dnc-sn-banner-icon">⏰</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">%s ประกันหมดใน %d วัน</div>'
                    .   '<div class="dnc-sn-banner-actions">'
                    .     '<a href="%s" class="dnc-sn-banner-cta">ต่อประกัน</a>'
                    .     '<a href="%s" class="dnc-sn-banner-link">ดูรายละเอียด</a>'
                    .   '</div>'
                    . '</div>'
                    . '</div>',
                    esc_attr( $bid ),
                    esc_html( $sn ),
                    $days,
                    esc_url( '/extension?sn=' . rawurlencode( $sn ) ),
                    esc_url( '/warranty/detail?sn=' . rawurlencode( $sn ) )
                );
            } elseif ( $type === 'anniversary' ) {
                $years = (int) ( $row['years'] ?? 1 );
                $html[] = sprintf(
                    '<div class="dnc-sn-banner dnc-sn-banner-anniversary" data-banner-id="%s">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this)">✕</button>'
                    . '<div class="dnc-sn-banner-icon">🎉</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">ครบรอบ %d ปีแล้ว!</div>'
                    .   '<div class="dnc-sn-banner-sub">ขอบคุณที่อยู่กับเรา %s</div>'
                    .   '<div class="dnc-sn-banner-actions">'
                    .     '<a href="%s" class="dnc-sn-banner-cta">รับรางวัล</a>'
                    .   '</div>'
                    . '</div>'
                    . '</div>',
                    esc_attr( $bid ),
                    $years,
                    esc_html( $sn ),
                    esc_url( '/anniversary?sn=' . rawurlencode( $sn ) )
                );
            } elseif ( $type === 'review' ) {
                $html[] = sprintf(
                    '<div class="dnc-sn-banner dnc-sn-banner-review" data-banner-id="%s">'
                    . '<button type="button" class="dnc-sn-banner-dismiss" aria-label="ปิดการแจ้งเตือน" onclick="dncSnDismissBanner(this)">✕</button>'
                    . '<div class="dnc-sn-banner-icon">⭐</div>'
                    . '<div class="dnc-sn-banner-body">'
                    .   '<div class="dnc-sn-banner-title">ให้คะแนน DINOCO หน่อย</div>'
                    .   '<div class="dnc-sn-banner-sub">รับ ฿50 หลังให้คะแนน</div>'
                    .   '<div class="dnc-sn-banner-actions">'
                    .     '<a href="%s" class="dnc-sn-banner-cta">ให้คะแนน + รับ ฿50</a>'
                    .   '</div>'
                    . '</div>'
                    . '</div>',
                    esc_attr( $bid ),
                    esc_url( '/review?sn=' . rawurlencode( $sn ) )
                );
            }
        }

        // V.31.2 F8 — "ดูทั้งหมด" surfaces when total > rendered.
        // Phase 4 `/notifications/all` page is not yet built — gate the link
        // behind `dinoco_sn_notifications_page_ready` flag (default OFF).
        // Until flag flips → render disabled informational badge instead so
        // user is not led to a broken page.
        $rendered = count( $html );
        if ( $total > $rendered ) {
            $extra        = $total - $rendered;
            $page_ready   = (bool) get_option( 'dinoco_sn_notifications_page_ready', false );
            if ( $page_ready ) {
                $html[] = sprintf(
                    '<a href="%s" class="dnc-sn-banner-viewall">ดูทั้งหมด (%d)</a>',
                    esc_url( '/notifications/all' ),
                    $total
                );
            } else {
                // Disabled badge — not a link. role=note + tooltip via title.
                $html[] = sprintf(
                    '<span class="dnc-sn-banner-viewall dnc-sn-banner-viewall-disabled" '
                    . 'role="note" aria-disabled="true" '
                    . 'title="หน้ารายการแจ้งเตือนกำลังพัฒนา">+%d เพิ่มเติม</span>',
                    $extra
                );
            }
        }

        return '<div class="dnc-sn-banners-wrap" data-banners-total="' . (int) $total . '">' . implode( '', $html ) . '</div>';
    }
}

if ( ! function_exists( 'dinoco_dashboard_stats_card' ) ) {
    /**
     * 4-cell stats grid (plates / active / claims / member years).
     *
     * Defensive: uses dinoco_sn_get_user_stats() under function_exists guard.
     * Returns empty string when SN system not loaded — caller renders nothing.
     *
     * @param int $user_id
     * @return string HTML
     */
    function dinoco_dashboard_stats_card( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return '';
        if ( ! function_exists( 'dinoco_sn_get_user_stats' ) ) return '';

        $stats = dinoco_sn_get_user_stats( $user_id );
        if ( ! is_array( $stats ) ) return '';

        $plates  = (int) ( $stats['plates_count'] ?? 0 );
        $active  = (int) ( $stats['active_count'] ?? 0 );
        $claims  = (int) ( $stats['claim_count']  ?? 0 );
        $years   = (int) ( $stats['member_years'] ?? 0 );

        // No plates yet (legacy fallback or new user) → don't render section
        // (Member Dashboard Header already shows "Royal Upgrade" + register CTA)
        if ( $plates === 0 && $active === 0 && $claims === 0 && $years === 0 ) {
            return '';
        }

        return sprintf(
            '<div class="dnc-sn-stats-grid">'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">ประกันทั้งหมด</div></div>'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">ใช้งานอยู่</div></div>'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">เคลม</div></div>'
            . '<div class="dnc-sn-stat-cell"><div class="dnc-sn-stat-num">%d</div><div class="dnc-sn-stat-label">ปีที่เป็นสมาชิก</div></div>'
            . '</div>',
            $plates, $active, $claims, $years
        );
    }
}

// -----------------------------------------------------------
// [PHASE 1] LOGIC HANDLER (AJAX & System Actions)
// -----------------------------------------------------------
add_action( 'init', 'dinoco_dashboard_v115_handler', 5 );

function dinoco_dashboard_v115_handler() {
    // ตรวจสอบว่าเป็น POST request และมี action ของเราหรือไม่
    if ( $_SERVER['REQUEST_METHOD'] === 'POST' && isset( $_POST['dinoco_action'] ) ) {
        
        // --- CLEAN OUTPUT BUFFER ---
        while ( ob_get_level() ) {
            @ob_end_clean();
        }
        
        // เริ่ม Buffer ใหม่สำหรับการส่งออก JSON โดยเฉพาะ
        ob_start();

        // ส่ง Header เป็น JSON แท้ๆ และสั่งไม่ให้ Cache
        header( 'Content-Type: application/json; charset=utf-8' );
        status_header( 200 ); 
        nocache_headers();
        
        $current_user_id = get_current_user_id();
        $current_user = wp_get_current_user();
        $current_username = $current_user->user_login;

        // 1. Security Check (Nonce)
        if ( ! isset( $_POST['dinoco_security_token'] ) || ! wp_verify_nonce( $_POST['dinoco_security_token'], 'dinoco_core_action' ) ) {
            echo json_encode( [
                'success' => false,
                'message' => 'Security Error',
                'data' => [ 'msg' => 'เกิดข้อผิดพลาดด้านความปลอดภัย กรุณารีเฟรชหน้าเว็บแล้วลองใหม่' ]
            ] );
            exit;
        }

        // 2. Auth Check
        if ( ! is_user_logged_in() ) {
            echo json_encode( [
                'success' => false,
                'message' => 'Session Expired',
                'data' => [ 'msg' => 'เซสชันหมดอายุ กรุณาเข้าสู่ระบบใหม่' ]
            ] );
            exit;
        }

        // 3. Rate Limit Check
        if ( ! dinoco_check_rate_limit_global( $current_user_id, 'ajax_action_handler', 1 ) ) {
            echo json_encode( [
                'success' => false,
                'message' => 'Rate Limit',
                'data' => [ 'msg' => 'กรุณารอสักครู่แล้วลองใหม่' ]
            ] );
            exit;
        }

        $request_action = sanitize_text_field( $_POST['dinoco_action'] );

        // ACTION: CREATE BUNDLE
        if ( $request_action === 'create_bundle' ) {
            $target_sku = sanitize_text_field( $_POST['target_sku'] );
            $child_ids  = isset( $_POST['child_ids'] ) ? $_POST['child_ids'] : [];

            $sku_relations = function_exists('b2b_get_sku_relations') ? b2b_get_sku_relations() : get_option( 'dinoco_sku_relations', [] );

            // V.6.0 [DD-6]: เฉพาะ top-level SET เท่านั้น (ไม่ให้สร้าง bundle จาก sub-SET)
            if ( function_exists('dinoco_is_top_level_set') && ! dinoco_is_top_level_set($target_sku, $sku_relations) ) {
                echo json_encode(['success' => false, 'message' => 'Invalid Bundle', 'data' => ['msg' => 'ไม่สามารถสร้าง bundle จากชุดย่อยได้']]);
                exit;
            }

            if ( ! isset( $sku_relations[ $target_sku ] ) ) {
                dinoco_log_system_event($current_user_id, 'CREATE_BUNDLE', 'FAIL', "Recipe Not Found for SKU: $target_sku");
                echo json_encode( [ 
                    'success' => false, 
                    'message' => 'Recipe Not Found',
                    'data' => [ 'msg' => 'Error: Recipe definition not found for SKU: ' . $target_sku ] 
                ] );
                exit;
            }

            $required_skus  = $sku_relations[ $target_sku ];
            
            if ( !is_array($required_skus) || empty($required_skus) ) {
                 dinoco_log_system_event($current_user_id, 'CREATE_BUNDLE', 'FAIL', "Invalid Recipe Configuration");
                 echo json_encode( [ 
                    'success' => false, 
                    'message' => 'Invalid Recipe',
                    'data' => [ 'msg' => 'Error: System Recipe is empty or invalid.' ] 
                ] );
                exit;
            }

            $submitted_skus = [];
            $valid_children = [];

            foreach ( $child_ids as $cid ) {
                $cid = intval( $cid );
                $p_owner = get_post_meta( $cid, 'owner_product', true );
                if(empty($p_owner)) $p_owner = get_field('owner_product', $cid);
              
                if ( $p_owner !== $current_username ) {
                    dinoco_log_system_event($current_user_id, 'CREATE_BUNDLE', 'FAIL', "Ownership Error on Item ID $cid");
                    echo json_encode( [ 'success' => false, 'message' => 'Ownership Error', 'data' => [ 'msg' => 'Error: You do not own item ID: ' . $cid ] ] );
                    exit;
                }
              
                $curr_bundle = get_post_meta( $cid, 'current_bundle_id', true );
                if ( ! empty( $curr_bundle ) ) {
                    dinoco_log_system_event($current_user_id, 'CREATE_BUNDLE', 'FAIL', "Item Already Bundled ID $cid");
                    echo json_encode( [ 'success' => false, 'message' => 'Already Bundled', 'data' => [ 'msg' => 'Error: Item ' . $cid . ' is already in another bundle.' ] ] );
                    exit;
                }

                $this_sku = get_post_meta( $cid, 'product_sku', true );
                if(empty($this_sku)) $this_sku = get_field('product_sku', $cid);

                if ( ! $this_sku ) {
                    echo json_encode( [ 'success' => false, 'message' => 'No SKU', 'data' => [ 'msg' => 'Error: Item ' . $cid . ' has no SKU.' ] ] );
                    exit;
                }

                $submitted_skus[] = $this_sku;
                $valid_children[] = $cid;
            }

            $req_sorted = $required_skus;
            sort( $req_sorted );
            
            $sub_sorted = $submitted_skus;
            sort( $sub_sorted );

            if ( $req_sorted !== $sub_sorted ) {
                $missing = array_diff($req_sorted, $sub_sorted);
                $extra   = array_diff($sub_sorted, $req_sorted);
                $err_detail = "";
                if(!empty($missing)) $err_detail .= "Missing: " . implode(', ', $missing) . ". ";
                if(!empty($extra))   $err_detail .= "Extra: " . implode(', ', $extra) . ".";

                dinoco_log_system_event($current_user_id, 'CREATE_BUNDLE', 'FAIL', "Recipe Mismatch: $err_detail");
                
                echo json_encode( [ 
                    'success' => false, 
                    'message' => 'Recipe Mismatch',
                    'data' => [ 
                        'msg' => 'Mismatch Error: ส่วนผสมไม่ถูกต้อง (' . $err_detail . ')',
                        'debug_required' => $req_sorted,
                        'debug_submitted' => $sub_sorted
                    ] 
                ] );
                exit;
            }

            $bundle_title = 'SET-' . wp_date( 'Ymd' ) . '-' . rand( 1000, 9999 );
            $system_admin_id = 1; 

            $post_data = [ 
                'post_type'   => 'product_bundle', 
                'post_title'  => $bundle_title, 
                'post_status' => 'publish', 
                'post_author' => $system_admin_id 
            ];

            $bundle_id = wp_insert_post( $post_data, true );

            if ( $bundle_id && ! is_wp_error( $bundle_id ) ) {
                update_post_meta( $bundle_id, 'bundle_sku', $target_sku );
                update_post_meta( $bundle_id, 'bundle_owner', $current_user_id ); 
                update_field( 'bundle_children', $valid_children, $bundle_id );
              
                foreach ( $valid_children as $child_id ) {
                    update_post_meta( $child_id, 'current_bundle_id', $bundle_id );
                }

                dinoco_log_system_event(
                    $current_user_id, 
                    'CREATE_BUNDLE', 
                    'SUCCESS', 
                    sprintf("System created Bundle ID %d for User %d", $bundle_id, $current_user_id)
                );

                echo json_encode( [ 'success' => true, 'message' => 'Success', 'data' => [ 'msg' => 'Success: รวมร่างสินค้าสำเร็จ! (Bundle Created)' ] ] );
                exit;
            } else {
                $err_msg = is_wp_error($bundle_id) ? $bundle_id->get_error_message() : 'Unknown DB Error';
                dinoco_log_system_event($current_user_id, 'CREATE_BUNDLE', 'DB_ERROR', $err_msg);
                echo json_encode( [ 'success' => false, 'message' => 'DB Error', 'data' => [ 'msg' => 'Database Error: Could not create bundle post.' ] ] );
                exit;
            }
        }

        // ACTION: DELETE BUNDLE
        if ( $request_action === 'delete_bundle' ) {
            $bid = intval( $_POST['bundle_id'] );
            $b_owner = get_post_meta( $bid, 'bundle_owner', true );

            if ( intval( $b_owner ) !== intval( $current_user_id ) ) {
                dinoco_log_system_event($current_user_id, 'DELETE_BUNDLE', 'DENIED', "User attempted to delete Bundle ID $bid owned by $b_owner");
                echo json_encode( [ 'success' => false, 'message' => 'Permission Denied', 'data' => [ 'msg' => 'Permission Denied: Not your bundle.' ] ] );
                exit;
            }

            $locked_children = get_posts([
                'post_type' => 'serial_number',
                'meta_query' => [
                    ['key' => 'current_bundle_id', 'value' => $bid]
                ],
                'fields' => 'ids',
                'posts_per_page' => -1
            ]);

            if ( !empty($locked_children) ) {
                foreach ( $locked_children as $child_id ) {
                    delete_post_meta( $child_id, 'current_bundle_id' ); 
                }
            }

            wp_delete_post( $bid, true ); 
            
            dinoco_log_system_event($current_user_id, 'DELETE_BUNDLE', 'SUCCESS', "Dissolved Bundle ID $bid and unlocked " . count($locked_children) . " items.");
            
            echo json_encode( [ 'success' => true, 'message' => 'Success', 'data' => [ 'msg' => 'Success: แยกชุดสินค้าเรียบร้อย (Bundle Dissolved).' ] ] );
            exit;
        }

        // ACTION: SAVE TRACK
        if ( $request_action === 'save_track' ) {
            $tid = intval( $_POST['ticket_id'] );
            $track_info = sanitize_text_field( $_POST['tracking'] );
            $p = get_post( $tid );
            
            if ( $p && $p->post_type === 'claim_ticket' && intval( $p->post_author ) === intval( $current_user_id ) ) {
                update_field( 'tracking_inbound', $track_info, $tid );
                $current_st = get_field( 'ticket_status', $tid );
                if ( in_array( $current_st, ['Registered in System','registered','Awaiting Customer Shipment','wait_shipping','รอลูกค้าส่งสินค้า','waiting_for_customer'] ) ) {
                    // M18: route through canonical helper. All 6 from-state variants are
                    // registered via dinoco_member_dashboard_register_claim_states (top of
                    // this file). The helper logs which variant was actually present →
                    // feeds M20 canonicalization data.
                    if ( function_exists( 'dinoco_set_claim_status' ) ) {
                        dinoco_set_claim_status( $tid, 'In Transit to Company', array(
                            'actor'  => 'member',
                            'source' => 'member_dashboard_save_track',
                            'note'   => 'Tracking uploaded by customer',
                        ) );
                    } else {
                        update_field( 'ticket_status', 'In Transit to Company', $tid );
                    }
                }
                update_field( 'customer_send_date', current_time( 'Y-m-d H:i:s' ), $tid );
                
                dinoco_log_system_event($current_user_id, 'SAVE_TRACK', 'SUCCESS', "Ticket $tid Updated Tracking: $track_info");
                
                echo json_encode( [ 'success' => true, 'message' => 'Saved', 'data' => [ 'msg' => 'Saved' ] ] );
                exit;
            }
            echo json_encode( [ 'success' => false, 'message' => 'Invalid Ticket', 'data' => [ 'msg' => 'Invalid Ticket or Permission' ] ] );
            exit;
        }

        // ACTION: CONFIRM RECEIPT
        if ( $request_action === 'confirm_receipt' ) {
            $tid = intval( $_POST['ticket_id'] );
            $p = get_post( $tid );
            
            if ( $p && $p->post_type === 'claim_ticket' && intval( $p->post_author ) === intval( $current_user_id ) ) {
                // M18: route through canonical helper
                if ( function_exists( 'dinoco_set_claim_status' ) ) {
                    dinoco_set_claim_status( $tid, 'Maintenance Completed', array(
                        'actor'  => 'member',
                        'source' => 'member_dashboard_confirm_receipt',
                    ) );
                } else {
                    update_field( 'ticket_status', 'Maintenance Completed', $tid );
                }
                update_field( 'customer_confirm_date', current_time( 'Y-m-d H:i:s' ), $tid );
                
                dinoco_log_system_event($current_user_id, 'CONFIRM_RECEIPT', 'SUCCESS', "Ticket $tid confirmed by user");
                
                echo json_encode( [ 'success' => true, 'message' => 'Confirmed', 'data' => [ 'msg' => 'Confirmed' ] ] );
                exit;
            }
            echo json_encode( [ 'success' => false, 'message' => 'Error', 'data' => [ 'msg' => 'Error' ] ] );
            exit;
        }

        echo json_encode( [ 'success' => false, 'message' => 'Unknown Action', 'data' => [ 'msg' => 'Unknown Action Request: ' . $request_action ] ] );
        exit;
    }
}

// -----------------------------------------------------------
// Main Shortcode & View Controller
// -----------------------------------------------------------
add_shortcode( 'dinoco_dashboard', 'dinoco_dashboard_main_controller' );

function dinoco_dashboard_main_controller() {
    
    if ( ! is_user_logged_in() ) {
        return '<div style="text-align:center; padding:50px;"><h3>กรุณาเข้าสู่ระบบ</h3><p>Please Login to access Dashboard</p></div>' . do_shortcode( '[dinoco_login_button]' );
    }

    $current_user_id = get_current_user_id();
    $current_url = get_permalink();
    $dinoco_system_notice = '';

    // =========================================================================================
    // [PHASE 2] STATE PROCESSING (Data Handling with Security) - Handle Forms HERE
    // =========================================================================================

    // 2.X SEGMENT CHOICE SAVE
    if ( isset( $_GET['dinoco_set_segment'] ) && is_user_logged_in() ) {
        $seg = sanitize_text_field( $_GET['dinoco_set_segment'] );
        // [SECURITY FIX] Whitelist valid segments to prevent arbitrary meta values
        $valid_segments = array( 'standard', 'legacy', 'premium', 'qr' );
        if ( ! in_array( $seg, $valid_segments, true ) ) { $seg = 'standard'; }
        update_user_meta( $current_user_id, 'dinoco_segment_choice', $seg );
        
        if ( $seg === 'legacy' ) {
             echo '<script>window.location.href = "/legacy-migration";</script>';
             return;
        } else {
             echo '<script>window.location.href = "' . remove_query_arg('dinoco_set_segment', $current_url) . '";</script>';
             return;
        }
    }

    // 2.1 PDPA CONSENT SAVE
    if ( isset( $_POST['dinoco_save_pdpa'] ) && wp_verify_nonce( $_POST['dinoco_pdpa_nonce'], 'save_pdpa_action' ) ) {
        if ( ! dinoco_check_rate_limit_global( $current_user_id, 'save_pdpa', 5 ) ) {
            $dinoco_system_notice .= '<div class="status-msg error-msg">⛔ กรุณารอหน้าเว็บโหลดสักครู่</div>';
        } else {
            $analytics_val = isset( $_POST['consent_analytics'] ) ? sanitize_text_field( $_POST['consent_analytics'] ) : '';
            $marketing_val = isset( $_POST['consent_marketing'] ) ? sanitize_text_field( $_POST['consent_marketing'] ) : '';

            if ( empty( $analytics_val ) || empty( $marketing_val ) ) {
                $dinoco_system_notice .= '<div class="status-msg error-msg" style="position:fixed; top:20px; left:50%; transform:translateX(-50%); z-index:999999;">⚠️ กรุณาเลือกความยินยอมให้ครบทุกข้อ</div>';
            } else {
                update_user_meta( $current_user_id, 'dinoco_pdpa_consent', 'accepted' );
                update_user_meta( $current_user_id, 'dinoco_pdpa_timestamp', current_time( 'Y-m-d H:i:s' ) );
                update_user_meta( $current_user_id, 'dinoco_pdpa_version', '1.0' );
                update_user_meta( $current_user_id, 'dinoco_analytics_consent', $analytics_val );
                update_user_meta( $current_user_id, 'dinoco_marketing_consent', $marketing_val );
                echo '<script>window.location.href = "' . $current_url . '";</script>';
            }
        }
    }

    // 2.2 PROFILE SAVE
    if ( isset( $_POST['dinoco_save_profile'] ) && wp_verify_nonce( $_POST['dinoco_nonce'], 'save_profile' ) ) {
        if ( ! dinoco_check_rate_limit_global( $current_user_id, 'save_profile', 5 ) ) {
            $dinoco_system_notice .= '<div class="status-msg error-msg">⛔ กรุณารอหน้าเว็บโหลดสักครู่</div>';
        } else {
            $meta = [
                'first_name'        => sanitize_text_field( $_POST['p_fname'] ),
                'last_name'         => sanitize_text_field( $_POST['p_lname'] ),
                'phone_number'      => preg_replace( '/[^0-9]/', '', sanitize_text_field( $_POST['p_phone'] ) ),
                'birth_date'        => sanitize_text_field( $_POST['p_birth'] ),
                'addr_house_no'     => sanitize_text_field( $_POST['p_house'] ),
                'addr_soi'          => sanitize_text_field( $_POST['p_soi'] ),
                'addr_province'     => sanitize_text_field( $_POST['p_province'] ),
                'addr_district'     => sanitize_text_field( $_POST['p_district'] ),
                'addr_subdistrict'  => sanitize_text_field( $_POST['p_subdist'] ),
                'addr_zip'          => sanitize_text_field( $_POST['p_zip'] )
            ];

            if ( $meta['first_name'] && $meta['phone_number'] && $meta['addr_house_no'] ) {
                foreach ( $meta as $k => $v ) {
                    update_user_meta( $current_user_id, $k, $v );
                }
                echo '<script>window.location.href = "' . $current_url . '";</script>';
            } else {
                $dinoco_system_notice .= '<div class="status-msg error-msg">⚠️ กรุณากรอกข้อมูลให้ครบถ้วน</div>';
            }
        }
    }

    // 2.3 MOTO SAVE
    if ( isset( $_POST['dinoco_save_moto'] ) && wp_verify_nonce( $_POST['dinoco_nonce_moto'], 'save_moto' ) ) {
        if ( ! dinoco_check_rate_limit_global( $current_user_id, 'save_moto', 5 ) ) {
            $dinoco_system_notice .= '<div class="status-msg error-msg">⛔ กรุณารอหน้าเว็บโหลดสักครู่</div>';
        } else {
            $brand_input = sanitize_text_field( $_POST['m_brand'] );
            // Universal: ใช้ moto_model_select (dropdown จาก catalog) หรือ manual_model (free text fallback)
            $model_input = !empty($_POST['moto_model_select']) ? sanitize_text_field($_POST['moto_model_select']) : sanitize_text_field($_POST['manual_model'] ?? '');
            $moto_meta   = [
                'user_moto_brand' => $brand_input,
                'user_moto_model' => $model_input,
                'user_moto_year'  => sanitize_text_field( $_POST['m_year'] )
            ];
            if ( $moto_meta['user_moto_brand'] && $moto_meta['user_moto_model'] && $moto_meta['user_moto_year'] ) {
                foreach ( $moto_meta as $k => $v ) {
                    update_user_meta( $current_user_id, $k, $v );
                }
                echo '<script>window.location.href = "' . $current_url . '?welcome=1";</script>';
            } else {
                $dinoco_system_notice .= '<div class="status-msg error-msg">⚠️ กรุณากรอกข้อมูลให้ครบถ้วน</div>';
            }
        }
    }

    // 2.4-PRE V.31.0 — F#3 SN System auto-link
    // ?register_serial=DNCSS... (8+ chars) → SN system new flow.
    // Existing serial_number CPT path stays for legacy (DNC*/DNX* etc).
    // Boss spec: when `register_serial` starts with "DNCSS" → redirect to
    // /warranty/activate?sn=...  (LIFF activation snippet handles auth).
    // Fallthrough: legacy CPT lookup for non-DNCSS prefixes (DD-3 backward compat).
    // V.31.3 (2026-05-08) R3 customer UX C2 HOTFIX — DNCSS prefix ALWAYS routes to
    //   Activation LIFF regardless of dinoco_sn_get_plate_data() result.
    //   V.31.2 bug: when plate not yet in pool (Phase 6 race — admin printed batch
    //   but no production receive yet), dinoco_sn_get_plate_data() returns null →
    //   block A fell through silently → block B legacy CPT lookup ran → "ไม่พบ
    //   Serial Number" shown to customer with brand-new product. Activation LIFF
    //   has proper "not_yet_shipped" state E handler for this case.
    // Flag used to disable legacy block B for DNCSS prefix (avoid `goto`).
    $dinoco_skip_legacy_register_handler = false;
    if ( isset( $_GET['register_serial'] ) ) {
        $sn_raw = trim( sanitize_text_field( $_GET['register_serial'] ) );
        $sn_upper = strtoupper( $sn_raw );
        // DNCSS prefix = SN system plates (boss-defined production format)
        if ( $sn_upper !== '' && strpos( $sn_upper, 'DNCSS' ) === 0 ) {
            // Already registered to CURRENT user? Show inline notice (no redirect needed)
            if ( function_exists( 'dinoco_sn_get_plate_data' ) ) {
                $plate = dinoco_sn_get_plate_data( $sn_upper );
                if ( is_object( $plate ) && isset( $plate->status ) && $plate->status === 'registered' && (int) ( $plate->registered_user_id ?? 0 ) === $current_user_id ) {
                    $dinoco_system_notice .= '<div class="status-msg info-msg">ℹ️ S/N นี้ลงทะเบียนกับบัญชีคุณแล้ว</div>';
                    // Skip legacy block B (would show wrong "ไม่พบ" message)
                    $dinoco_skip_legacy_register_handler = true;
                }
            }
            // For ALL non-current-owner DNCSS cases (in_pool / not_yet_shipped /
            //   registered_to_other / voided / recalled / not_found / SN module
            //   disabled) → route to Activation LIFF which has dedicated state
            //   handlers + proper UX. Legacy CPT block B is NEVER appropriate
            //   for DNCSS prefix.
            if ( ! $dinoco_skip_legacy_register_handler ) {
                $redirect_url = home_url( '/warranty/activate?sn=' . rawurlencode( $sn_upper ) );
                echo '<script>window.location.href = ' . wp_json_encode( $redirect_url ) . ';</script>';
                return;
            }
        }
    }

    // 2.4 REGISTER SN (GET Request) — legacy serial_number CPT path
    // *Moved this logic inside Header form part OR keep here but pass message via global/param
    // For strictly robust structure, keeping the logic here is safer for redirects.
    // The notice will be passed to Header component.
    // V.31.3 C2: skip if DNCSS already-owned notice was emitted above
    if ( isset( $_GET['register_serial'] ) && empty( $dinoco_skip_legacy_register_handler ) ) {
        if ( ! dinoco_check_rate_limit_global( $current_user_id, 'register_serial', 2 ) ) {
            $dinoco_system_notice .= '<div class="status-msg error-msg">⛔ กรุณารอหน้าเว็บโหลดสักครู่</div>';
        } else {
            $sn    = trim( sanitize_text_field( $_GET['register_serial'] ) );
            $current_username = wp_get_current_user()->user_login;
            
            $args = [
                'post_type'      => 'serial_number',
                'meta_query'     => [
                    [
                        'key'      => 'serial_code',
                        'value'    => $sn,
                        'compare' => '='
                    ]
                ],
                'posts_per_page' => 1
            ];
            $q    = new WP_Query( $args );
            if ( ! $q->have_posts() ) {
                $args2 = [
                    'post_type'      => 'serial_number',
                    's'              => $sn,
                    'posts_per_page' => 1
                ];
                $q      = new WP_Query( $args2 );
            }

            if ( $q->have_posts() ) {
                $q->the_post();
                $pid          = get_the_ID();
                $owner_val    = get_field( 'owner_product', $pid );
                $w_status_raw = get_field( 'w_status', $pid );
                $w_status     = is_array( $w_status_raw ) ? ( isset( $w_status_raw['value'] ) ? $w_status_raw['value'] : ( isset( $w_status_raw[0] ) ? $w_status_raw[0] : '' ) ) : $w_status_raw;
                $w_status     = trim( $w_status );
                $db_sn        = trim( get_field( 'serial_code' ) );
                $db_title     = trim( get_the_title() );

                if ( strcasecmp( $sn, $db_sn ) !== 0 && strcasecmp( $sn, $db_title ) !== 0 ) {
                    $dinoco_system_notice .= '<div class="status-msg error-msg">⚠️ ไม่พบ Serial Number ที่ระบุ</div>';
                } else {
                    if ( $owner_val === $current_username ) {
                        $dinoco_system_notice .= '<div class="status-msg info-msg">ℹ️ สินค้าเป็นของคุณอยู่แล้ว</div>';
                    } elseif ( $w_status === 'warranty_available' || $w_status === 'warranty available' ) {
                        update_field( 'owner_product', $current_username, $pid );
                        update_field( 'w_status', 'warranty_on', $pid );
                        update_field( 'owner_sequence', 1, $pid );

                        $today_date = wp_date( 'd/m/Y' );
                        update_field( 'warranty_register_date', $today_date, $pid );
                        $years = (int) get_field( 'warranty_duration_years', $pid );
                        if ( $years > 0 ) {
                            $exp_obj = DateTime::createFromFormat( 'd/m/Y', $today_date );
                            $exp_obj->modify( "+$years years" );
                            update_field( 'warranty_expiry', $exp_obj->format( 'd/m/Y' ), $pid );
                        }

                        $dinoco_system_notice .= '<div class="status-msg success-msg">✅ ลงทะเบียนสำเร็จ</div>';
                        echo '<script>if(window.history.replaceState){var c=window.location.href.split("?")[0];window.history.replaceState(null,null,c);}</script>';
                    } else {
                        $err = '⛔ ไม่สามารถลงทะเบียนได้';
                        if ( $w_status === 'warranty_on' || $w_status === 'warranty on' )
                            $err = 'สินค้านี้ถูกลงทะเบียนไปแล้ว';
                        elseif ( $w_status === 'claim_process' || $w_status === 'claim process' )
