if ( ! function_exists( 'dinoco_check_rate_limit_global' ) ) {
    function dinoco_check_rate_limit_global( $user_id, $action_name, $seconds = 2 ) {
        $key = 'dinoco_limit_' . $user_id . '_' . $action_name;
        $last_request = get_transient( $key );
        if ( $last_request ) {
            return false;
        }
        set_transient( $key, true, $seconds );
        return true;
    }
}

// Helper Function: Transaction Logging
if ( ! function_exists( 'dinoco_log_system_event' ) ) {
    function dinoco_log_system_event( $user_id, $action, $status, $details ) {
        $timestamp = current_time( 'Y-m-d H:i:s' );
        
        $log_message = sprintf( 
            "[%s] [User: %d] [%s] [%s] -> %s" . PHP_EOL, 
            $timestamp, 
            $user_id,
            strtoupper( $action ),
            strtoupper( $status ), 
            $details 
        );
        
        // [SECURITY FIX] Log to private directory with unpredictable filename
        $salt = defined( 'AUTH_SALT' ) ? AUTH_SALT : 'dinoco_fallback';
        $log_hash = substr( hash( 'sha256', $salt . '_system_log_' . date('Ym') ), 0, 16 );
        $log_file = WP_CONTENT_DIR . '/uploads/.dinoco_sys_' . $log_hash . '.log';
        @file_put_contents( $log_file, $log_message, FILE_APPEND | LOCK_EX );
    }
}

// -----------------------------------------------------------
// V.31.2 — F4 Buddhist year fallback helper (unified 2-arg signature)
// -----------------------------------------------------------
// 4 fallback definitions of `dinoco_sn_format_thai_date()` exist across the
// codebase — Production SN Manager (1-arg legacy), REST API V.0.3 (2-arg —
// canonical), Warranty Lifecycle Notifier (1-arg), and this member-side
// fallback. F4 unifies on the 2-arg shape `($ts, $buddhist=true)` that
// autodetects Unix timestamp vs MySQL DATETIME — copy of REST API canonical
// body. Only registers when no other definition has loaded yet
// (function_exists guard avoids redeclare fatal).
//
// Empty string return preserved for parse failures (other call sites already
// handle '' via short-circuit; '—' would inject a literal dash into Flex
// payloads).
if ( ! function_exists( 'dinoco_sn_format_thai_date' ) ) {
    function dinoco_sn_format_thai_date( $ts, $buddhist = true ) {
        // Accept Unix timestamp (int / numeric string) OR MySQL DATETIME
        if ( ! is_numeric( $ts ) ) {
            $ts = strtotime( (string) $ts );
        }
        $ts = (int) $ts;
        if ( $ts <= 0 ) return '';
        $year = (int) date( 'Y', $ts );
        if ( $buddhist ) $year += 543;
        $months = array(
            'ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.',
            'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.',
        );
        $m = (int) date( 'n', $ts );
        return date( 'j', $ts ) . ' ' . $months[ max( 0, min( 11, $m - 1 ) ) ] . ' ' . $year;
    }
}

