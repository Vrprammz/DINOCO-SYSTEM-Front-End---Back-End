// -----------------------------------------------------------
// M18 — Register legacy claim-state variants
// -----------------------------------------------------------
// The Member Dashboard owns these legacy + slug state variants because
// older client builds and the member-facing self-serve flow use them as
// from-states (see line 287 in_array guard). Register them via the shared
// filter so dinoco_set_claim_status() accepts them as valid transition
// targets. Canonicalization to a single label per logical state is tracked
// as M20 in docs/FULL-LOOP-REVIEW-v1.md — needs observability data first.
add_filter( 'dinoco/claim/allowed_states', 'dinoco_member_dashboard_register_claim_states' );
function dinoco_member_dashboard_register_claim_states( $states ) {
    return array_merge( is_array( $states ) ? $states : array(), array(
        // Legacy "customer hasn't shipped yet" variants — 6 variants for 1 logical state
        'registered',
        'Awaiting Customer Shipment',
        'wait_shipping',
        'รอลูกค้าส่งสินค้า',
        'waiting_for_customer',
        // Member-facing slug variants (Dashboard Assets List self-serve actions)
        'shipping_in',
        'completed',
    ) );
}

