                window.dncSnDismissBanner = function(btn) {
                    try {
                        var card = btn && btn.closest ? btn.closest('.dnc-sn-banner') : null;
                        if (!card) return;
                        var bid = card.getAttribute('data-banner-id') || '';
                        if (bid) {
                            var ttl = Date.now() + (7 * 24 * 60 * 60 * 1000); // 7 days
                            localStorage.setItem(buildKey(bid), String(ttl));
                        }
                        card.style.display = 'none';
                    } catch (e) { /* silent */ }
                };
                document.addEventListener('DOMContentLoaded', function() {
                    scrubOtherUserKeys();
                    applyDismissFilter();
                });
                window.addEventListener('pageshow', applyDismissFilter);
            })();
        </script>

        <?php
        // LOGIC CONTROLLER FOR SUB-PAGES

        // 1. Call Header/Forms
        // Logic: Checks state inside the shortcode too, but we are in main wrapper.
        // If state is incomplete, header handles everything.
        echo do_shortcode('[dinoco_dashboard_header]');

        // V.31.0 — Banners + Stats grid (only after onboarding complete)
        // Both helpers function_exists guarded; safe no-op when SN system off.
        if ( $has_pdpa === 'accepted' && !empty($has_address) && !empty($has_moto) ) {
            // Banners (cap=3 boss Q25)
            if ( function_exists( 'dinoco_dashboard_banners' ) ) {
                echo dinoco_dashboard_banners( $current_user_id );
            }
            // Stats grid (4-cell)
            if ( function_exists( 'dinoco_dashboard_stats_card' ) ) {
                echo dinoco_dashboard_stats_card( $current_user_id );
            }
        }

        // 2. Call Assets
        // Only if everything is complete
        if ( $has_pdpa === 'accepted' && !empty($has_address) && !empty($has_moto) ) {
            echo do_shortcode('[dinoco_dashboard_assets]');
        }
        ?>
    </div>
    <?php
    return ob_get_clean();
