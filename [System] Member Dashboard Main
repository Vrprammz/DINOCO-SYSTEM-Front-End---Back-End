                        for (var i = 0; i < localStorage.length; i++) {
                            var k = localStorage.key(i);
                            if (!k || k.indexOf(KEY_PREFIX) !== 0) continue;
                            // Match `dnc_sn_banner_dismiss_<digits>_<bid>` strictly.
                            // Anything else (other user OR legacy unscoped) → drop.
                            if (k.indexOf(USER_PREFIX) !== 0) toRemove.push(k);
                        }
                        toRemove.forEach(function(k) { localStorage.removeItem(k); });
                    } catch (e) { /* silent */ }
                }

                function applyDismissFilter() {
                    try {
                        var now = Date.now();
                        var banners = document.querySelectorAll('.dnc-sn-banner[data-banner-id]');
                        banners.forEach(function(el) {
                            var bid = el.getAttribute('data-banner-id') || '';
                            if (!bid) return;
                            var key = buildKey(bid);
                            var exp = parseInt(localStorage.getItem(key) || '0', 10);
                            if (exp && exp > now) {
                                el.style.display = 'none';
                            } else if (exp && exp <= now) {
                                // expired → cleanup
                                localStorage.removeItem(key);
                            }
                        });
                    } catch (e) { /* localStorage disabled — silent */ }
                }
                window.dncSnDismissBanner = function(btn) {
                    try {
                        var card = btn && btn.closest ? btn.closest('.dnc-sn-banner') : null;
                        if (!card) return;
                        var bid = card.getAttribute('data-banner-id') || '';
                        if (bid) {
                            var ttl = Date.now() + (7 * 24 * 60 * 60 * 1000); // 7 days
                            localStorage.setItem(buildKey(bid), String(ttl));
                        }
                        card.style.display = 'none';
                    } catch (e) { /* silent */ }
                };

                /* V.31.5 S3 — Banner carousel dot navigation + scroll-sync.
                   Click dot → scroll track to corresponding banner. Track
                   scroll → highlight active dot. Wired via IntersectionObserver
                   on banner cards within the track. */
                window.dncSnBannerScrollTo = function(dotBtn) {
                    try {
                        var idx = parseInt(dotBtn.getAttribute('data-banner-index'), 10);
                        if (isNaN(idx)) return;
                        var wrap = dotBtn.closest('.dnc-sn-banners-carousel');
                        if (!wrap) return;
                        var track = wrap.querySelector('.dnc-sn-banners-track');
                        var banners = track ? track.querySelectorAll('.dnc-sn-banner') : [];
                        if (banners[idx]) {
                            banners[idx].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
                        }
                    } catch (e) { /* silent */ }
                };

                function setupBannerCarousel() {
                    var carousels = document.querySelectorAll('.dnc-sn-banners-carousel');
                    if (!carousels.length || !window.IntersectionObserver) return;
                    carousels.forEach(function(wrap) {
                        var track = wrap.querySelector('.dnc-sn-banners-track');
                        var dots = wrap.querySelectorAll('.dnc-sn-banners-dot');
                        if (!track || !dots.length) return;
                        var banners = track.querySelectorAll('.dnc-sn-banner');
                        var io = new IntersectionObserver(function(entries) {
                            entries.forEach(function(en) {
                                if (en.isIntersecting && en.intersectionRatio > 0.5) {
                                    var bidx = Array.prototype.indexOf.call(banners, en.target);
                                    dots.forEach(function(d, i) {
                                        d.classList.toggle('dnc-sn-banners-dot-active', i === bidx);
                                    });
                                }
                            });
                        }, { root: track, threshold: 0.5 });
                        banners.forEach(function(b) { io.observe(b); });
                    });
                }

                /* V.32.0 Sprint 32 — Deep-link from Flex notification or
                   charge_pending banner. URL pattern:
                     /dashboard/?action=pay&claim_id=X&charge_id=Y#claim-X-charge-Y
                   On DOMContentLoaded we read the query, find the matching
                   asset card anchor (rendered by Assets List V.32.0), smooth-
                   scroll to it, then dispatch CustomEvent 'dnc:claim-pay-open'
                   which Assets List listens for to auto-open the payment
                   modal. Defensive — silent no-op when params absent or
                   anchor missing (e.g. customer landed before assets loaded).
                */
                window.dncDashClaimAutoScroll = function() {
                    try {
                        var params = new URLSearchParams(window.location.search || '');
                        if (params.get('action') !== 'pay') return;
                        var cid = parseInt(params.get('claim_id') || '0', 10);
                        var chid = parseInt(params.get('charge_id') || '0', 10);
                        if (!cid || !chid) return;
                        var anchor = document.getElementById('claim-' + cid + '-charge-' + chid);
                        if (!anchor) {
                            // Anchor not yet rendered (lazy load race) — retry once after 500ms
                            setTimeout(function() {
                                var late = document.getElementById('claim-' + cid + '-charge-' + chid);
                                if (late) {
                                    late.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                    document.dispatchEvent(new CustomEvent('dnc:claim-pay-open', {
                                        detail: { claim_id: cid, charge_id: chid }
                                    }));
                                }
                            }, 500);
                            return;
                        }
                        anchor.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        document.dispatchEvent(new CustomEvent('dnc:claim-pay-open', {
                            detail: { claim_id: cid, charge_id: chid }
                        }));
                    } catch (e) { /* silent */ }
                };

                document.addEventListener('DOMContentLoaded', function() {
                    scrubOtherUserKeys();
                    applyDismissFilter();
                    setupBannerCarousel();
                    // V.32.0 Sprint 32 — trigger URL deep-link scroll/modal
                    window.dncDashClaimAutoScroll();
                });
                window.addEventListener('pageshow', applyDismissFilter);
            })();
        </script>

