        btn.disabled=false;btn.textContent='Sync Now';
        if(res.ok&&res.data.ok){
            msg.className='sd-msg ok';msg.textContent='Sync complete! Updated: '+(res.data.updated||[]).length+' snippet(s)'+(res.data.errors&&res.data.errors.length?' | Errors: '+res.data.errors.length:'');
        }else{
            msg.className='sd-msg err';msg.textContent='Sync failed: '+(res.data.error||res.data.message||'Unknown error');
        }
        msg.style.display='block';
        setTimeout(function(){location.reload()},2000);
    })
    .catch(function(e){
        btn.disabled=false;btn.textContent='Sync Now';
        msg.className='sd-msg err';msg.textContent='Network error: '+e.message;msg.style.display='block';
    });
