add_action( 'rest_api_init', function () {
    register_rest_route( 'b2b/v1', '/sync-status', array(
        'methods'             => 'GET',
        'callback'            => 'b2b_github_sync_status',
        'permission_callback' => function() { return current_user_can('manage_options'); },
    ) );
} );

if ( ! function_exists( 'b2b_github_sync_status' ) ) {
    function b2b_github_sync_status() {
        global $wpdb;
        $table = $wpdb->prefix . 'snippets';

        // V.16.0: Show only active snippets
        $like_prefix = $wpdb->esc_like( '[B2B] Snippet' ) . '%';
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, name, active, modified, revision, SUBSTRING(code, 1, 500) AS code_head FROM {$table} WHERE name LIKE %s AND active = 1 ORDER BY name",
            $like_prefix
        ) );

        $snippets = array();
        foreach ( $rows as $r ) {
            $num = '';
            if ( preg_match( '/Snippet\s+(\d+)(?![A-Za-z])/', $r->name, $m ) ) {
                $num = $m[1];
            }
            $php_ver = '';
            if ( !empty($r->code_head) && preg_match('/Version:\s*(V\.[\d.]+)/', $r->code_head, $vm) ) {
                $php_ver = trim($vm[1]);
            }
            $snippets[] = array(
                'id'       => $r->id,
                'num'      => $num,
                'name'     => b2b_normalize_snippet_name( $r->name ),
                'raw_name' => $r->name,
                'version'  => $php_ver,
                'modified' => $r->modified,
                'revision' => $r->revision,
            );
        }

        return new WP_REST_Response( array(
            'last_sync' => get_option( 'b2b_last_sync_result', null ),
            'snippets'  => $snippets,
        ), 200 );
    }
}

