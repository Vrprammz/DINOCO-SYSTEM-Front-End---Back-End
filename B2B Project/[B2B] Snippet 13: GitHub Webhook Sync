        headers:{'X-WP-Nonce':'<?php echo esc_js( $nonce ); ?>','Content-Type':'application/json'},
        credentials:'same-origin'
    })
    .then(function(r){return r.json().then(function(d){return{ok:r.ok,data:d}})})
