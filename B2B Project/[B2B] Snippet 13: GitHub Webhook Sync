// ══════════════════════════════════════════════════════════════
// HELPER: Normalize DB snippet name → GitHub filename
// WordPress Code Snippets plugin อาจเก็บ &amp; แทน & ใน DB
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'b2b_normalize_snippet_name' ) ) {
    function b2b_normalize_snippet_name( $name ) {
        return trim( html_entity_decode( $name, ENT_QUOTES | ENT_HTML5, 'UTF-8' ) );
    }
}

// ══════════════════════════════════════════════════════════════
// V.19.0: HELPER — Update snippet code with cache-bust + verify
// Fix: wpdb->update() alone doesn't flush object cache
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'b2b_sync_update_snippet' ) ) {
    function b2b_sync_update_snippet( $row, $code, $file_name ) {
        global $wpdb;
        $table = $wpdb->prefix . 'snippets';

        $new_revision = intval( $row->revision ) + 1;

        // ── 1. Execute update ──
        $result = $wpdb->update(
            $table,
            array(
                'code'     => $code,
                'modified' => current_time( 'mysql' ),
                'revision' => $new_revision,
            ),
            array( 'id' => $row->id ),
            array( '%s', '%s', '%d' ),
            array( '%d' )
        );

        // ── 2. Check return value ──
        if ( $result === false ) {
            $err = $wpdb->last_error;
            b2b_log( '[Sync] DB UPDATE FAILED: ' . $file_name . ' (id=' . $row->id . '): ' . $err );
            return array( 'ok' => false, 'message' => 'db_update_failed: ' . $err );
        }

        // ── 3. Flush WordPress object cache (targeted, not global) ──
        wp_cache_delete( 'alloptions', 'options' );

        // ── 4. Clear Code Snippets plugin caches ──
        delete_transient( 'code_snippets' );
        delete_transient( 'code_snippets_active' );
        delete_transient( 'all_snippets' );
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%code_snippets%' AND option_name LIKE '%_transient%'" );
        wp_cache_delete( $row->id, 'code_snippets' );
        wp_cache_delete( 'all_snippets', 'code_snippets' );

        // ── 5. Clear WP Fastest Cache if available ──
        if ( function_exists( 'wpfc_clear_all_cache' ) ) {
            wpfc_clear_all_cache( true );
        }

        // ── 6. Verify-after-write ──
        $verify_hash = $wpdb->get_var( $wpdb->prepare(
            "SELECT md5(code) FROM {$table} WHERE id = %d",
            $row->id
        ) );
        $expected_hash = md5( $code );

        if ( $verify_hash !== $expected_hash ) {
            b2b_log( '[Sync] VERIFY MISMATCH: ' . $file_name . ' expected=' . substr( $expected_hash, 0, 8 ) . ' actual=' . substr( $verify_hash ?: 'null', 0, 8 ) . ' len=' . strlen( $code ) );
            return array( 'ok' => false, 'message' => 'verify_hash_mismatch (len=' . strlen( $code ) . ')' );
        }

        b2b_log( '[Sync] OK: ' . $file_name . ' (id=' . $row->id . ', rev=' . $new_revision . ', len=' . strlen( $code ) . ')' );
        return array( 'ok' => true, 'message' => 'updated_and_verified' );
    }
}

// ══════════════════════════════════════════════════════════════
// REST API ENDPOINT: /wp-json/b2b/v1/github-sync
// V.15.0: respond 200 → run sync via shutdown hook
// ══════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {
    register_rest_route( 'b2b/v1', '/github-sync', array(
        'methods'             => 'POST',
        'callback'            => 'b2b_github_sync_handler',
        'permission_callback' => '__return_true',
    ) );
} );

if ( ! function_exists( 'b2b_github_sync_handler' ) ) {
    function b2b_github_sync_handler( WP_REST_Request $req ) {

        // ── 1. Verify GitHub HMAC-SHA256 Signature ──
        $secret = defined( 'B2B_GITHUB_WEBHOOK_SECRET' ) ? B2B_GITHUB_WEBHOOK_SECRET : '';
        if ( empty( $secret ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'webhook_secret_not_configured' ), 500 );
        }

        $signature = $req->get_header( 'X-Hub-Signature-256' );
        $payload   = $req->get_body();

        if ( empty( $signature ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'missing_signature' ), 403 );
        }

        $expected = 'sha256=' . hash_hmac( 'sha256', $payload, $secret );
        if ( ! hash_equals( $expected, $signature ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'invalid_signature' ), 403 );
        }

        // ── 2. Parse push event — quick validation only ──
        $data = json_decode( $payload, true );
        if ( empty( $data['commits'] ) || empty( $data['repository'] ) ) {
            return new WP_REST_Response( array( 'ok' => true, 'message' => 'ping_received' ), 200 );
        }

        // V.1.2: Only sync from main branch
        $ref = isset( $data['ref'] ) ? $data['ref'] : '';
        if ( $ref !== 'refs/heads/main' ) {
            return new WP_REST_Response( array(
                'ok'      => true,
                'message' => 'ignored_non_main_branch',
                'ref'     => $ref,
            ), 200 );
        }

        // ── 3. V.15.0: Primary = shutdown hook (runs after response sent) ──
        $GLOBALS['_b2b_pending_sync'] = $data;
        add_action( 'shutdown', 'b2b_sync_on_shutdown', 0 );

        // Backup: WP-Cron (delay 30s — gives shutdown hook time to run first)
        $job_id = 'b2b_sync_' . substr( md5( $payload ), 0, 12 );
        set_transient( $job_id, $data, 600 );
        wp_clear_scheduled_hook( 'b2b_github_sync_process', array( $job_id ) );
        wp_schedule_single_event( time() + 30, 'b2b_github_sync_process', array( $job_id ) );
        spawn_cron();

        return new WP_REST_Response( array(
            'ok'      => true,
            'message' => 'sync_started',
            'job_id'  => $job_id,
            'ref'     => $ref,
        ), 200 );
    }
}

// ══════════════════════════════════════════════════════════════
// V.15.0: SHUTDOWN HOOK — runs after REST response is sent
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'b2b_sync_on_shutdown' ) ) {
    function b2b_sync_on_shutdown() {
        if ( empty( $GLOBALS['_b2b_pending_sync'] ) ) return;
        $data = $GLOBALS['_b2b_pending_sync'];
        unset( $GLOBALS['_b2b_pending_sync'] );

        // Close connection to client (prevent GitHub timeout)
        if ( function_exists( 'fastcgi_finish_request' ) ) {
            fastcgi_finish_request();
        }

        @set_time_limit( 300 );
        ignore_user_abort( true );

        b2b_do_full_sync( $data, 'shutdown' );
    }
}

// ══════════════════════════════════════════════════════════════
// WP-CRON BACKUP: fires 30s later if shutdown didn't run
// ══════════════════════════════════════════════════════════════

add_action( 'b2b_github_sync_process', 'b2b_github_sync_process_job' );

if ( ! function_exists( 'b2b_github_sync_process_job' ) ) {
    function b2b_github_sync_process_job( $job_id ) {
        @set_time_limit( 300 );

        $data = get_transient( $job_id );
        if ( ! $data ) return; // Already processed by shutdown hook
        delete_transient( $job_id );

        b2b_do_full_sync( $data, 'cron' );
    }
}

// ══════════════════════════════════════════════════════════════
// V.15.0: SHARED SYNC LOGIC — used by shutdown hook + WP-Cron
// ══════════════════════════════════════════════════════════════

if ( ! function_exists( 'b2b_do_full_sync' ) ) {
    function b2b_do_full_sync( $data, $trigger = 'unknown' ) {

        // ── Execution lock: prevent double-run ──
        $lock = get_transient( 'b2b_sync_running' );
        if ( $lock ) {
            update_option( 'b2b_last_sync_result', array(
                'time'    => current_time( 'mysql' ),
                'trigger' => $trigger,
                'message' => 'skipped_already_running (locked by: ' . $lock . ')',
            ) );
            return;
        }
        set_transient( 'b2b_sync_running', $trigger, 300 );
        try {

        // ── V.22.0: Detect merge commits — force full sync ──
        // GitHub merge commits have empty modified/added arrays in webhook payload
        // but may contain snippet changes from the merged branch
        $is_merge = false;
        $head_msg = ! empty( $data['head_commit']['message'] ) ? $data['head_commit']['message'] : '';
        if ( preg_match( '/^Merge (pull request|branch)\b/', $head_msg ) ) {
            $is_merge = true;
            b2b_log( '[Sync] Merge commit detected: ' . substr( $head_msg, 0, 80 ) . ' → force full sync' );
        }

        // ── Quick check: did any snippet files change? ──
        $modified_files = array();
        if ( ! empty( $data['commits'] ) ) {
            foreach ( $data['commits'] as $commit ) {
                if ( ! empty( $commit['modified'] ) ) {
                    $modified_files = array_merge( $modified_files, $commit['modified'] );
                }
                if ( ! empty( $commit['added'] ) ) {
                    $modified_files = array_merge( $modified_files, $commit['added'] );
                }
            }
        }
        if ( ! empty( $data['head_commit'] ) ) {
            if ( ! empty( $data['head_commit']['modified'] ) ) {
                $modified_files = array_merge( $modified_files, $data['head_commit']['modified'] );
            }
            if ( ! empty( $data['head_commit']['added'] ) ) {
                $modified_files = array_merge( $modified_files, $data['head_commit']['added'] );
            }
        }

        $has_snippet = false;
        foreach ( $modified_files as $f ) {
            if ( strpos( $f, '[B2B] Snippet' ) === 0 ) {
                $has_snippet = true;
                break;
            }
        }

        // V.22.0: Merge commit → always has_snippet (force full sync)
        if ( $is_merge ) {
            $has_snippet = true;
        }

        // Compare API fallback: ถ้า commits ไม่มี snippet + ไม่ใช่ merge → เช็คจาก compare
        if ( ! $has_snippet && ! empty( $data['before'] ) && ! empty( $data['after'] ) ) {
            $token = defined( 'B2B_GITHUB_TOKEN' ) ? B2B_GITHUB_TOKEN : '';
            if ( ! empty( $token ) ) {
                $compare_url = sprintf(
                    'https://api.github.com/repos/%s/compare/%s...%s',
                    $data['repository']['full_name'], $data['before'], $data['after']
                );
                $cmp_resp = wp_remote_get( $compare_url, array(
                    'headers' => array(
                        'Accept'        => 'application/vnd.github.v3+json',
                        'Authorization' => 'Bearer ' . $token,
                        'User-Agent'    => 'DINOCO-B2B-Sync/22.0',
                    ),
                    'timeout' => 15,
                ) );
                if ( ! is_wp_error( $cmp_resp ) && wp_remote_retrieve_response_code( $cmp_resp ) === 200 ) {
                    $cmp_data = json_decode( wp_remote_retrieve_body( $cmp_resp ), true );
                    if ( ! empty( $cmp_data['files'] ) ) {
                        foreach ( $cmp_data['files'] as $cf ) {
                            if ( ! empty( $cf['filename'] ) && strpos( $cf['filename'], '[B2B] Snippet' ) === 0 ) {
                                $has_snippet = true;
                                break;
                            }
                        }
                    }
                } else {
                    // V.22.0: Compare API failed — log and fallback to full sync
                    $cmp_err = is_wp_error( $cmp_resp ) ? $cmp_resp->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $cmp_resp );
                    b2b_log( '[Sync] Compare API failed: ' . $cmp_err . ' → fallback to full sync' );
                    $has_snippet = true; // Force sync when compare fails
                }
            }
        }

        if ( ! $has_snippet ) {
            delete_transient( 'b2b_sync_running' );
            update_option( 'b2b_last_sync_result', array(
                'time'    => current_time( 'mysql' ),
                'trigger' => $trigger,
                'message' => 'no_snippet_files_changed',
                'files'   => array_values( array_unique( $modified_files ) ),
            ) );
            return;
        }

        // ── V.17.0: Sync snippets — use commit SHA to bypass CDN cache ──
        $repo       = $data['repository']['full_name'];
        $branch     = str_replace( 'refs/heads/', '', $data['ref'] );
        $commit_sha = ! empty( $data['after'] ) ? $data['after'] : $branch; // V.17.0: exact commit → no cache
        $token      = defined( 'B2B_GITHUB_TOKEN' ) ? B2B_GITHUB_TOKEN : '';

        if ( empty( $token ) ) {
            delete_transient( 'b2b_sync_running' );
            update_option( 'b2b_last_sync_result', array(
                'time'    => current_time( 'mysql' ),
                'trigger' => $trigger,
                'error'   => 'github_token_not_configured',
            ) );
            return;
        }

        global $wpdb;
        $table   = $wpdb->prefix . 'snippets';
        $updated = array();
        $errors  = array();

        // V.16.0: Load active DB rows, keyed by snippet number
        $like_prefix = $wpdb->esc_like( '[B2B] Snippet' ) . '%';
        $all_db_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, name, active, revision FROM {$table} WHERE name LIKE %s AND active = 1 ORDER BY id ASC",
            $like_prefix
        ) );
        $db_by_number = array();
        foreach ( $all_db_rows as $dbr ) {
            if ( preg_match( '/Snippet\s+(\d+)(?![A-Za-z])/', $dbr->name, $m ) ) {
                $num = $m[1];
                if ( ! isset( $db_by_number[ $num ] ) ) {
                    $db_by_number[ $num ] = $dbr;   // first match wins (lowest id)
                }
            }
        }

        // V.16.0: Build file list from commits + DB — no dir listing needed
        $snippet_files = array();
        foreach ( $modified_files as $f ) {
            if ( preg_match( '/^\[B2B\] Snippet\s+(\d+)(?![A-Za-z])/', $f, $m ) ) {
                $snippet_files[ $m[1] ] = $f;
            }
        }
        // Full sync: add DB snippets not in commits (derive filename from DB name)
        foreach ( $db_by_number as $num => $dbr ) {
            if ( ! isset( $snippet_files[ $num ] ) ) {
                $snippet_files[ $num ] = b2b_normalize_snippet_name( $dbr->name );
            }
        }

        foreach ( $snippet_files as $snippet_num => $file_name ) {

            // V.17.0: Primary = raw.githubusercontent.com with COMMIT SHA (bypass CDN cache)
            $raw_url = sprintf(
                'https://raw.githubusercontent.com/%s/%s/%s',
                $repo,
                rawurlencode( $commit_sha ),
                rawurlencode( $file_name )
            );
            $raw_resp = wp_remote_get( $raw_url, array(
                'headers' => array(
                    'Authorization' => 'token ' . $token,
                    'User-Agent'    => 'DINOCO-B2B-Sync/17.0',
                ),
                'timeout' => 30,
            ) );

            // Fallback: GitHub Contents API with commit SHA
            if ( is_wp_error( $raw_resp ) || wp_remote_retrieve_response_code( $raw_resp ) !== 200 ) {
                $content_url = sprintf(
                    'https://api.github.com/repos/%s/contents/%s?ref=%s',
                    $repo,
                    rawurlencode( $file_name ),
                    rawurlencode( $commit_sha )
                );
                $raw_resp = wp_remote_get( $content_url, array(
                    'headers' => array(
                        'Accept'        => 'application/vnd.github.v3.raw',
                        'Authorization' => 'Bearer ' . $token,
                        'User-Agent'    => 'DINOCO-B2B-Sync/17.0',
                    ),
                    'timeout' => 30,
                ) );
            }

            if ( is_wp_error( $raw_resp ) || wp_remote_retrieve_response_code( $raw_resp ) !== 200 ) {
                $err_msg = is_wp_error( $raw_resp ) ? $raw_resp->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $raw_resp );
                $errors[] = $file_name . ': ' . $err_msg;
                continue;
            }

            $code = wp_remote_retrieve_body( $raw_resp );

            // Match by snippet number
            $row = isset( $db_by_number[ $snippet_num ] ) ? $db_by_number[ $snippet_num ] : null;

            if ( $row ) {
                $sync_result = b2b_sync_update_snippet( $row, $code, $file_name );
                if ( $sync_result['ok'] ) {
                    $updated[] = $file_name . ' (db:' . $row->name . ')';
                } else {
                    $errors[] = $file_name . ': ' . $sync_result['message'];
                }
            } else {
                $errors[] = $file_name . ': snippet_not_found_in_db (num=' . $snippet_num . ')';
            }
        }

        // ── V.21.0: Global cache flush after ALL snippets updated ──
        // Fix: Code Snippets plugin may serve stale code from object cache
        wp_cache_flush();
        if ( function_exists( 'opcache_reset' ) ) {
            @opcache_reset();
        }
        if ( function_exists( 'wpfc_clear_all_cache' ) ) {
            wpfc_clear_all_cache( true );
        }
        // Clear Code Snippets plugin transients (global)
        global $wpdb;
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%snippet%' AND option_name LIKE '%transient%'" );
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%code_snippets%'" );

        // ── Save result for debugging ──
        $db_names = array();
        foreach ( $db_by_number as $num => $dbr ) {
            $db_names[ 'S' . $num ] = $dbr->name;
        }
        update_option( 'b2b_last_sync_result', array(
            'time'           => current_time( 'mysql' ),
            'trigger'        => $trigger,
            'branch'         => $branch,
            'commit_sha'     => $commit_sha, // V.17.0: track SHA used
            'mode'           => 'full_sync_v17',
            'files_synced'   => array_values( $snippet_files ),
            'db_names'       => $db_names,
            'updated'        => $updated,
            'errors'         => $errors,
        ) );
        } finally {
            delete_transient( 'b2b_sync_running' );
        }
    }
}

// ══════════════════════════════════════════════════════════════
// MANUAL SYNC ENDPOINT: /wp-json/b2b/v1/github-sync-manual
// สำหรับ sync ด้วยมือ (เรียกจาก browser/Postman ได้)
// ══════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {
    register_rest_route( 'b2b/v1', '/github-sync-manual', array(
        'methods'             => 'POST',
        'callback'            => 'b2b_github_sync_manual',
        'permission_callback' => function () {
            return current_user_can( 'manage_options' );
        },
    ) );
} );

if ( ! function_exists( 'b2b_github_sync_manual' ) ) {
    function b2b_github_sync_manual( WP_REST_Request $req ) {
        $token = defined( 'B2B_GITHUB_TOKEN' ) ? B2B_GITHUB_TOKEN : '';
        $repo  = defined( 'B2B_GITHUB_REPO' )  ? B2B_GITHUB_REPO  : '';

        if ( empty( $token ) || empty( $repo ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'missing_config: B2B_GITHUB_TOKEN or B2B_GITHUB_REPO' ), 500 );
        }

        $branch = $req->get_param( 'branch' ) ?: 'main';

        // V.16.0: Load active DB rows, build file list from DB names
        global $wpdb;
        $table   = $wpdb->prefix . 'snippets';
        $updated = array();
        $errors  = array();

        $like_prefix = $wpdb->esc_like( '[B2B] Snippet' ) . '%';
        $all_db_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, name, active, revision FROM {$table} WHERE name LIKE %s AND active = 1 ORDER BY id ASC",
            $like_prefix
        ) );
        $db_by_number = array();
        foreach ( $all_db_rows as $dbr ) {
            if ( preg_match( '/Snippet\s+(\d+)(?![A-Za-z])/', $dbr->name, $m ) ) {
                $num = $m[1];
                if ( ! isset( $db_by_number[ $num ] ) ) {
                    $db_by_number[ $num ] = $dbr;
                }
            }
        }

        foreach ( $db_by_number as $snippet_num => $row ) {
            $file_name = b2b_normalize_snippet_name( $row->name );

            // V.16.0: Primary = raw.githubusercontent.com
            $raw_url = sprintf(
                'https://raw.githubusercontent.com/%s/%s/%s',
                $repo,
                rawurlencode( $branch ),
                rawurlencode( $file_name )
            );
            $raw_response = wp_remote_get( $raw_url, array(
                'headers' => array(
                    'Authorization' => 'token ' . $token,
                    'User-Agent'    => 'DINOCO-B2B-Sync/16.1',
                ),
                'timeout' => 30,
            ) );

            // Fallback: GitHub Contents API
            if ( is_wp_error( $raw_response ) || wp_remote_retrieve_response_code( $raw_response ) !== 200 ) {
                $content_url = sprintf(
                    'https://api.github.com/repos/%s/contents/%s?ref=%s',
                    $repo,
                    rawurlencode( $file_name ),
                    rawurlencode( $branch )
                );
                $raw_response = wp_remote_get( $content_url, array(
                    'headers' => array(
                        'Accept'        => 'application/vnd.github.v3.raw',
                        'Authorization' => 'Bearer ' . $token,
                        'User-Agent'    => 'DINOCO-B2B-Sync/16.1',
                    ),
                    'timeout' => 30,
                ) );
            }

            if ( is_wp_error( $raw_response ) || wp_remote_retrieve_response_code( $raw_response ) !== 200 ) {
                $err_msg = is_wp_error( $raw_response ) ? $raw_response->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $raw_response );
                $errors[] = $file_name . ': ' . $err_msg;
                continue;
            }

            $code = wp_remote_retrieve_body( $raw_response );

            $sync_result = b2b_sync_update_snippet( $row, $code, $file_name );
            if ( $sync_result['ok'] ) {
                $updated[] = $file_name;
            } else {
                $errors[] = $file_name . ': ' . $sync_result['message'];
            }
        }

        // V.21.0: Global cache flush after ALL snippets updated
        wp_cache_flush();
        if ( function_exists( 'opcache_reset' ) ) {
            @opcache_reset();
        }
        if ( function_exists( 'wpfc_clear_all_cache' ) ) {
            wpfc_clear_all_cache( true );
        }
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%snippet%' AND option_name LIKE '%transient%'" );
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%code_snippets%'" );

        return new WP_REST_Response( array(
            'ok'      => true,
            'updated' => $updated,
            'errors'  => $errors,
            'branch'  => $branch,
        ), 200 );
    }
}

