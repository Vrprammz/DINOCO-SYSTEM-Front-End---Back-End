 * ╔══════════════════════════════════════════════════════════════╗
 * ║  [Admin System] DINOCO Config Layer                          ║
 * ║  Version: V.1.1 (2026-04-24) — Register slip.ai_classifier_*  ║
 * ║    • slip.ai_classifier_enabled (bool, default ON, legacy     ║
 * ║      b2b_slip_ai_classifier_enabled) — Snippet 1 V.34.17       ║
 * ║      AI Vision pre-classifier toggle.                          ║
 * ║    • slip.ai_classifier_min_confidence (float, default 0.7,    ║
 * ║      reserved — Snippet 1 currently hardcodes threshold).      ║
 * ║  Version: V.1.0 (2026-04-24) — Phase 3 Architecture Refactor ║
 * ║  DB_ID: (pending — populate after first WP Code Snippets sync) ║
 * ║  Description: Schema-driven config layer (Pillar 4).          ║
 * ║    Replaces the "132+ raw get_option() calls scatter" pain    ║
 * ║    that produced silent flag-drift + typo bugs (e.g. typo     ║
 * ║    "b2b_flag_bo_systmem" → default OFF silently).             ║
 * ╚══════════════════════════════════════════════════════════════╝
 *
 * What it does:
 *   - dinoco_register_config([...])  — declare schema (type/default/section)
 *   - dinoco_config($key, $default)  — read with type-coerce + cache + legacy mapping
 *   - dinoco_config_set($key, $val)  — write with validation + audit log + cache bust
 *   - dinoco_get_config_schema()     — full schema grouped by section (admin viewer)
 *   - shortcode [dinoco_admin_config_viewer] — section-grouped tab UI
 *   - REST GET /dinoco/v1/config/list?section=slip  (admin only)
 *
 * Backward compat (CRITICAL):
 *   - 132+ existing `get_option('b2b_flag_*')` calls remain UNTOUCHED
 *   - dinoco_config('bo.flag_enabled') with `legacy_option` schema field
 *     transparently reads/writes `b2b_flag_bo_system` — both APIs see
 *     the same value
 *   - Disabling this snippet → no fatals, just lose the typed accessor
 *
 * Storage:
 *   - Schema: in-memory $GLOBALS['_dinoco_config_schema'] (per-request)
 *   - Values: standard wp_options (legacy mapping or `dinoco_config_<dotted>`)
 *
 * Why a separate snippet (not inside Snippet 1):
 *   - Mirrors Module Registry / Audit Log / Modal Helpers / Observability
 *   - Admin UI is concern-isolated (no REST/cron coupling)
 *   - Easier kill-switch — disable snippet to revert to raw get_option()
 *
 * Schema field reference (passed to dinoco_register_config):
 *   key            string  required  dot-notation 'namespace.key' (^[a-z0-9_.]+$)
 *   type           string  required  int|float|string|bool|array
 *   default        mixed   required  fallback when option unset / invalid
 *   label          string  optional  human-readable label for UI
 *   description    string  optional  helper text
 *   section        string  optional  group key (default = first segment of $key)
 *   legacy_option  string  optional  existing wp_option key (backward compat)
 *   choices        array   optional  for type=string with fixed enum
 *   min/max        number  optional  for type=int|float (clamps / falls back on out-of-range)
 *   validate       callable optional return true|WP_Error
 *   sensitive      bool    optional  hide value in viewer (mask as ********)
 *
 * Audit hookup:
 *   dinoco_config_set() calls dinoco_audit_log() if available
 *   event_type = 'config_change'
 *   target_type = 'config' / target_id = the dotted key
 *   delta_before / delta_after = stringified old/new values
 */

if ( ! defined( 'ABSPATH' ) ) exit;

/* ============================================================
 * 1. SCHEMA REGISTRATION
 * ============================================================ */

if ( ! function_exists( 'dinoco_register_config' ) ) {
    /**
     * Register a config schema entry. Idempotent — same key re-registered
     * overrides the previous registration (snippet hot-reload friendly).
     *
     * @param array $args see header for full schema.
     * @return true|WP_Error
     */
    function dinoco_register_config( $args ) {
        if ( ! is_array( $args ) ) {
            return new WP_Error( 'dnc_cfg_invalid_args', 'args must be array' );
        }

        $defaults = array(
            'key'           => '',
            'type'          => 'string',
            'default'       => null,
            'label'         => '',
            'description'   => '',
            'section'       => '',
            'legacy_option' => '',
            'choices'       => null,
            'min'           => null,
            'max'           => null,
            'validate'      => null,
            'sensitive'     => false,
        );
        $args = array_merge( $defaults, $args );

        // ---- Validation ----
        $errors = array();

        if ( ! is_string( $args['key'] ) || $args['key'] === '' ) {
            $errors[] = 'missing_key';
        } elseif ( ! preg_match( '/^[a-z0-9_]+\.[a-z0-9_.]+$/', $args['key'] ) ) {
            $errors[] = 'invalid_key_format (expected: namespace.key, lowercase a-z 0-9 _ .)';
        }

        $allowed_types = array( 'int', 'float', 'string', 'bool', 'array' );
        if ( ! in_array( $args['type'], $allowed_types, true ) ) {
            $errors[] = 'invalid_type (allowed: ' . implode( '|', $allowed_types ) . ')';
        }

        if ( $args['choices'] !== null && ! is_array( $args['choices'] ) ) {
            $errors[] = 'choices_not_array';
        }

        if ( $args['validate'] !== null && ! is_callable( $args['validate'] ) ) {
            $errors[] = 'validate_not_callable';
        }

        if ( ! empty( $errors ) ) {
            $msg = sprintf(
                "dinoco_register_config FAILED for key='%s': %s",
                $args['key'], implode( ', ', $errors )
            );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[ConfigLayer] ' . $msg );
            } else {
                error_log( '[DINOCO] ' . $msg );
            }
            return new WP_Error( 'dnc_cfg_validation_fail', $msg, $errors );
        }

        // Default section = first segment of key
        if ( $args['section'] === '' ) {
            $parts = explode( '.', $args['key'] );
            $args['section'] = $parts[0];
        }

        if ( ! isset( $GLOBALS['_dinoco_config_schema'] ) || ! is_array( $GLOBALS['_dinoco_config_schema'] ) ) {
            $GLOBALS['_dinoco_config_schema'] = array();
        }
        $GLOBALS['_dinoco_config_schema'][ $args['key'] ] = $args;

        return true;
    }
}

if ( ! function_exists( 'dinoco_get_config_schema' ) ) {
    /**
     * Get full schema grouped by section, sorted alphabetically within each.
     *
     * @return array<string, array<string, array>> section => key => def
     */
    function dinoco_get_config_schema() {
        $schema = isset( $GLOBALS['_dinoco_config_schema'] ) && is_array( $GLOBALS['_dinoco_config_schema'] )
            ? $GLOBALS['_dinoco_config_schema'] : array();

        $grouped = array();
        foreach ( $schema as $key => $def ) {
            $section = isset( $def['section'] ) ? $def['section'] : 'misc';
            if ( ! isset( $grouped[ $section ] ) ) $grouped[ $section ] = array();
            $grouped[ $section ][ $key ] = $def;
        }

        ksort( $grouped );
        foreach ( $grouped as &$entries ) {
            ksort( $entries );
        }
        unset( $entries );

        return $grouped;
    }
}

if ( ! function_exists( 'dinoco_get_config_def' ) ) {
    /**
     * Get a single schema entry, or null if not registered.
     */
    function dinoco_get_config_def( $key ) {
        if ( ! is_string( $key ) || $key === '' ) return null;
        if ( ! isset( $GLOBALS['_dinoco_config_schema'][ $key ] ) ) return null;
        return $GLOBALS['_dinoco_config_schema'][ $key ];
    }
}

/* ============================================================
 * 2. READ / WRITE API
 * ============================================================ */

if ( ! function_exists( 'dinoco_config_option_key' ) ) {
    /**
     * Translate a dotted config key to a wp_option key.
     * If schema declares legacy_option → use that (backward compat).
     * Else → 'dinoco_config_' + dot-replaced-with-underscore.
     */
    function dinoco_config_option_key( $key ) {
        $def = dinoco_get_config_def( $key );
        if ( $def && ! empty( $def['legacy_option'] ) ) {
            return (string) $def['legacy_option'];
        }
        return 'dinoco_config_' . str_replace( '.', '_', $key );
    }
}

if ( ! function_exists( 'dinoco_config_coerce' ) ) {
    /**
     * Apply type coercion + min/max + choices validation. Returns the
     * sanitized value, or the schema default if validation fails.
     *
     * @param mixed $raw   value as read from wp_options
     * @param array $def   schema entry
     * @param mixed $fallback caller-supplied default (used if schema default missing)
     * @return mixed
     */
    function dinoco_config_coerce( $raw, $def, $fallback = null ) {
        $default = isset( $def['default'] ) ? $def['default'] : $fallback;

        // Empty string from get_option means truly unset → use default
        if ( $raw === false || $raw === null ) {
            return $default;
        }

        $type = isset( $def['type'] ) ? $def['type'] : 'string';

        switch ( $type ) {
            case 'int':
                if ( ! is_numeric( $raw ) ) return $default;
                $val = (int) $raw;
                if ( isset( $def['min'] ) && $val < (int) $def['min'] ) return $default;
                if ( isset( $def['max'] ) && $val > (int) $def['max'] ) return $default;
                return $val;

            case 'float':
                if ( ! is_numeric( $raw ) ) return $default;
                $val = (float) $raw;
                if ( isset( $def['min'] ) && $val < (float) $def['min'] ) return $default;
                if ( isset( $def['max'] ) && $val > (float) $def['max'] ) return $default;
                return $val;

            case 'bool':
                if ( is_bool( $raw ) ) return $raw;
                if ( $raw === '1' || $raw === 1 || $raw === 'true' || $raw === true ) return true;
                if ( $raw === '0' || $raw === 0 || $raw === 'false' || $raw === '' || $raw === false ) return false;
                return (bool) $default;

            case 'array':
                if ( is_array( $raw ) ) return $raw;
                if ( is_string( $raw ) ) {
                    $decoded = json_decode( $raw, true );
                    if ( is_array( $decoded ) ) return $decoded;
                }
                return is_array( $default ) ? $default : array();

            case 'string':
            default:
                $val = is_scalar( $raw ) ? (string) $raw : $default;
                if ( ! empty( $def['choices'] ) && is_array( $def['choices'] )
                     && ! in_array( $val, $def['choices'], true ) ) {
                    return $default;
                }
                return $val;
        }
    }
}

if ( ! function_exists( 'dinoco_config' ) ) {
    /**
     * Read a config value with type coercion + per-request cache.
     *
     * If key NOT registered → fall back to raw get_option of legacy-style
     * 'dinoco_config_<dotted>' key, returning $default.
     *
     * @param string $key dot-notation
     * @param mixed  $default caller fallback (overridden by schema default if registered)
     * @return mixed
     */
    function dinoco_config( $key, $default = null ) {
        if ( ! is_string( $key ) || $key === '' ) return $default;

        // Per-request cache
        if ( ! isset( $GLOBALS['_dinoco_config_cache'] ) ) $GLOBALS['_dinoco_config_cache'] = array();
        if ( array_key_exists( $key, $GLOBALS['_dinoco_config_cache'] ) ) {
            return $GLOBALS['_dinoco_config_cache'][ $key ];
        }

        $def        = dinoco_get_config_def( $key );
        $option_key = dinoco_config_option_key( $key );
        $raw        = get_option( $option_key, null );

        if ( $def ) {
            $value = dinoco_config_coerce( $raw, $def, $default );
        } else {
            // Unregistered key — return raw (string) value or caller default
            $value = ( $raw === false || $raw === null ) ? $default : $raw;
        }

        $GLOBALS['_dinoco_config_cache'][ $key ] = $value;
        return $value;
    }
}

if ( ! function_exists( 'dinoco_config_set' ) ) {
    /**
     * Persist a config value (admin only — caller must capability-check
     * separately for REST flows; helper itself does NOT enforce caps).
     * Validates against schema, writes to wp_options, busts cache, audits.
     *
     * @param string $key
     * @param mixed  $value
     * @return true|WP_Error
     */
    function dinoco_config_set( $key, $value ) {
        if ( ! is_string( $key ) || $key === '' ) {
            return new WP_Error( 'dnc_cfg_invalid_key', 'key required' );
        }

        $def        = dinoco_get_config_def( $key );
        $option_key = dinoco_config_option_key( $key );
        $old_raw    = get_option( $option_key, null );

        // Coerce input through schema (also validates)
        if ( $def ) {
            // Type cast input first to detect "invalid → coerce returns default" cases
            $coerced = dinoco_config_coerce( $value, $def, $def['default'] ?? null );

            // Custom validate callback
            if ( ! empty( $def['validate'] ) && is_callable( $def['validate'] ) ) {
                $check = call_user_func( $def['validate'], $coerced );
                if ( is_wp_error( $check ) ) return $check;
                if ( $check === false ) {
                    return new WP_Error( 'dnc_cfg_validate_fail', 'validate callback returned false' );
                }
            }

            $to_store = $coerced;
        } else {
            // Unregistered — store raw scalar / array as-is
            $to_store = $value;
        }

        // For 'array' type, JSON-encode for option storage to keep schema simple
        // (legacy options that already store arrays directly remain unaffected)
        $store_value = $to_store;
        if ( $def && $def['type'] === 'array' && is_array( $to_store ) ) {
            // wp_options can store arrays directly — leave as PHP array
            $store_value = $to_store;
        }
        if ( $def && $def['type'] === 'bool' ) {
            // Store as '1' / '0' strings (WP idiom for boolean flags)
            $store_value = $to_store ? '1' : '0';
        }

        $ok = update_option( $option_key, $store_value );

        // Bust cache
        if ( isset( $GLOBALS['_dinoco_config_cache'][ $key ] ) ) {
            unset( $GLOBALS['_dinoco_config_cache'][ $key ] );
        }

        // Audit (best-effort)
        if ( function_exists( 'dinoco_audit_log' ) ) {
            $old_str = is_scalar( $old_raw ) ? (string) $old_raw : wp_json_encode( $old_raw );
            $new_str = is_scalar( $store_value ) ? (string) $store_value : wp_json_encode( $store_value );
            $ctx     = array( 'option_key' => $option_key );
            if ( $def ) {
                $ctx['type']    = $def['type'];
                $ctx['section'] = $def['section'];
                if ( ! empty( $def['legacy_option'] ) ) $ctx['legacy_option'] = $def['legacy_option'];
                if ( ! empty( $def['sensitive'] ) ) {
                    $old_str = '[REDACTED]';
                    $new_str = '[REDACTED]';
                }
            }
            dinoco_audit_log( array(
                'event_type'   => 'config_change',
                'target_type'  => 'config',
                'target_id'    => $key,
                'delta_before' => $old_str,
                'delta_after'  => $new_str,
                'context'      => $ctx,
                'success'      => $ok ? 1 : 0,
            ) );
        }

        return true;
    }
}

if ( ! function_exists( 'dinoco_config_reset' ) ) {
    /**
     * Reset a config to its schema default (delete the wp_option row so
     * subsequent reads re-coerce from default).
     */
    function dinoco_config_reset( $key ) {
        $def        = dinoco_get_config_def( $key );
        if ( ! $def ) {
            return new WP_Error( 'dnc_cfg_unknown_key', 'key not registered' );
        }
        $option_key = dinoco_config_option_key( $key );
        $old_raw    = get_option( $option_key, null );
        delete_option( $option_key );
        if ( isset( $GLOBALS['_dinoco_config_cache'][ $key ] ) ) {
            unset( $GLOBALS['_dinoco_config_cache'][ $key ] );
        }
        if ( function_exists( 'dinoco_audit_log' ) ) {
            dinoco_audit_log( array(
                'event_type'   => 'config_reset',
                'target_type'  => 'config',
                'target_id'    => $key,
                'delta_before' => is_scalar( $old_raw ) ? (string) $old_raw : wp_json_encode( $old_raw ),
                'delta_after'  => '(default)',
                'context'      => array( 'option_key' => $option_key ),
            ) );
        }
        return true;
    }
}

