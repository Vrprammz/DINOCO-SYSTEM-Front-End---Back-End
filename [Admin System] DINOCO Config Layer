if ( ! function_exists( 'dinoco_admin_config_viewer_shortcode' ) ) {
    function dinoco_admin_config_viewer_shortcode() {
        if ( ! current_user_can( 'manage_options' ) ) {
            return '<p>คุณไม่มีสิทธิ์เข้าถึงหน้านี้</p>';
        }

        // Handle POST (save) — single-form per row, in-place UI
        $notice = '';
        if ( isset( $_POST['_dnc_cfg_nonce'] ) && wp_verify_nonce( $_POST['_dnc_cfg_nonce'], 'dnc_cfg_save' ) ) {
            $action = isset( $_POST['_dnc_cfg_action'] ) ? sanitize_text_field( $_POST['_dnc_cfg_action'] ) : '';
            $key    = isset( $_POST['_dnc_cfg_key'] ) ? sanitize_text_field( $_POST['_dnc_cfg_key'] ) : '';
            if ( $action === 'set' && $key !== '' ) {
                $val = isset( $_POST['_dnc_cfg_value'] ) ? wp_unslash( $_POST['_dnc_cfg_value'] ) : '';
                $res = dinoco_config_set( $key, $val );
                $notice = is_wp_error( $res )
                    ? '<div class="dnc-cfg-notice dnc-cfg-err">บันทึกไม่สำเร็จ: ' . esc_html( $res->get_error_message() ) . '</div>'
                    : '<div class="dnc-cfg-notice dnc-cfg-ok">บันทึก ' . esc_html( $key ) . ' เรียบร้อย</div>';
            } elseif ( $action === 'reset' && $key !== '' ) {
                $res = dinoco_config_reset( $key );
                $notice = is_wp_error( $res )
                    ? '<div class="dnc-cfg-notice dnc-cfg-err">รีเซ็ตไม่สำเร็จ: ' . esc_html( $res->get_error_message() ) . '</div>'
                    : '<div class="dnc-cfg-notice dnc-cfg-ok">รีเซ็ต ' . esc_html( $key ) . ' กลับเป็นค่า default แล้ว</div>';
            }
        }

        $grouped = dinoco_get_config_schema();

        ob_start();
        ?>
        <div class="dnc-cfg-viewer">
            <style>
                .dnc-cfg-viewer { max-width: 1100px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
                .dnc-cfg-viewer h2 { font-size: 22px; margin: 0 0 8px; color: #111827; }
                .dnc-cfg-viewer .dnc-cfg-sub { color: #6b7280; margin: 0 0 16px; font-size: 14px; }
                .dnc-cfg-section { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 16px; overflow: hidden; }
                .dnc-cfg-section h3 { margin: 0; padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-size: 14px; text-transform: uppercase; letter-spacing: 0.04em; color: #374151; }
                .dnc-cfg-row { display: flex; flex-wrap: wrap; gap: 12px; padding: 12px 16px; border-bottom: 1px solid #f3f4f6; align-items: center; }
                .dnc-cfg-row:last-child { border-bottom: 0; }
                .dnc-cfg-meta { flex: 1 1 280px; min-width: 220px; }
                .dnc-cfg-meta .dnc-cfg-key { font-family: monospace; font-size: 13px; color: #111827; }
                .dnc-cfg-meta .dnc-cfg-label { font-size: 14px; font-weight: 600; color: #111827; margin-top: 2px; }
                .dnc-cfg-meta .dnc-cfg-desc { font-size: 12px; color: #6b7280; margin-top: 4px; line-height: 1.5; }
                .dnc-cfg-input { flex: 1 1 240px; min-width: 180px; }
                .dnc-cfg-input input[type="text"], .dnc-cfg-input input[type="number"], .dnc-cfg-input textarea, .dnc-cfg-input select {
                    width: 100%; padding: 8px 10px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; font-family: inherit;
                }
                .dnc-cfg-input textarea { font-family: monospace; font-size: 12px; min-height: 56px; }
                .dnc-cfg-actions { display: flex; gap: 8px; }
                .dnc-cfg-btn { padding: 8px 14px; border: 1px solid #d1d5db; border-radius: 6px; background: #fff; cursor: pointer; font-size: 13px; }
                .dnc-cfg-btn-primary { background: #2563eb; color: #fff; border-color: #2563eb; }
                .dnc-cfg-btn-warn { color: #b45309; border-color: #fcd34d; background: #fffbeb; }
                .dnc-cfg-bool { display: inline-flex; gap: 8px; align-items: center; font-size: 13px; }
                .dnc-cfg-tag { display: inline-block; padding: 2px 6px; border-radius: 4px; font-size: 11px; font-family: monospace; background: #eef2ff; color: #4338ca; }
                .dnc-cfg-tag-legacy { background: #fef3c7; color: #92400e; margin-left: 6px; }
                .dnc-cfg-notice { padding: 10px 14px; border-radius: 6px; margin-bottom: 12px; font-size: 14px; }
                .dnc-cfg-ok { background: #d1fae5; color: #065f46; }
                .dnc-cfg-err { background: #fee2e2; color: #991b1b; }
                .dnc-cfg-empty { padding: 24px; text-align: center; color: #6b7280; background: #f9fafb; border-radius: 8px; }
            </style>
            <h2>DINOCO Config Layer</h2>
            <p class="dnc-cfg-sub">Schema-driven configuration viewer — schemas registered โดย snippets ตอน boot. ค่า fallback ไป default ของ schema ถ้า wp_option ไม่ตั้ง.</p>
            <?php echo $notice; // already escaped ?>

            <?php if ( empty( $grouped ) ) : ?>
                <div class="dnc-cfg-empty">ยังไม่มี config schema ที่ลงทะเบียน — เรียก <code>dinoco_register_config()</code> จาก snippet ของคุณ</div>
            <?php else : ?>
                <?php foreach ( $grouped as $section => $entries ) : ?>
                    <div class="dnc-cfg-section">
                        <h3><?php echo esc_html( $section ); ?> <span style="float:right;font-weight:400;text-transform:none;color:#9ca3af"><?php echo count( $entries ); ?> keys</span></h3>
                        <?php foreach ( $entries as $key => $def ) :
                            $cur = dinoco_config( $key );
                            $is_sensitive = ! empty( $def['sensitive'] );
                            ?>
                            <div class="dnc-cfg-row">
                                <div class="dnc-cfg-meta">
                                    <div class="dnc-cfg-key"><?php echo esc_html( $key ); ?>
                                        <span class="dnc-cfg-tag"><?php echo esc_html( $def['type'] ); ?></span>
                                        <?php if ( ! empty( $def['legacy_option'] ) ) : ?>
                                            <span class="dnc-cfg-tag dnc-cfg-tag-legacy">legacy: <?php echo esc_html( $def['legacy_option'] ); ?></span>
                                        <?php endif; ?>
                                    </div>
                                    <?php if ( ! empty( $def['label'] ) ) : ?>
                                        <div class="dnc-cfg-label"><?php echo esc_html( $def['label'] ); ?></div>
                                    <?php endif; ?>
                                    <?php if ( ! empty( $def['description'] ) ) : ?>
                                        <div class="dnc-cfg-desc"><?php echo esc_html( $def['description'] ); ?></div>
                                    <?php endif; ?>
                                </div>
                                <form method="post" class="dnc-cfg-input" style="display:flex;gap:8px;align-items:center;flex:1 1 320px">
                                    <?php wp_nonce_field( 'dnc_cfg_save', '_dnc_cfg_nonce' ); ?>
                                    <input type="hidden" name="_dnc_cfg_action" value="set" />
                                    <input type="hidden" name="_dnc_cfg_key" value="<?php echo esc_attr( $key ); ?>" />
                                    <?php if ( $is_sensitive ) : ?>
                                        <input type="text" name="_dnc_cfg_value" value="********" disabled style="flex:1" />
                                    <?php elseif ( $def['type'] === 'bool' ) : ?>
                                        <select name="_dnc_cfg_value" style="flex:1">
                                            <option value="0" <?php selected( ! $cur ); ?>>OFF</option>
                                            <option value="1" <?php selected( $cur ); ?>>ON</option>
                                        </select>
                                    <?php elseif ( ! empty( $def['choices'] ) && is_array( $def['choices'] ) ) : ?>
                                        <select name="_dnc_cfg_value" style="flex:1">
                                            <?php foreach ( $def['choices'] as $c ) : ?>
                                                <option value="<?php echo esc_attr( $c ); ?>" <?php selected( $cur === $c ); ?>><?php echo esc_html( $c ); ?></option>
                                            <?php endforeach; ?>
                                        </select>
                                    <?php elseif ( $def['type'] === 'int' || $def['type'] === 'float' ) : ?>
                                        <input type="number"
                                            name="_dnc_cfg_value"
                                            value="<?php echo esc_attr( (string) $cur ); ?>"
                                            <?php if ( isset( $def['min'] ) ) echo ' min="' . esc_attr( $def['min'] ) . '"'; ?>
                                            <?php if ( isset( $def['max'] ) ) echo ' max="' . esc_attr( $def['max'] ) . '"'; ?>
                                            <?php if ( $def['type'] === 'float' ) echo ' step="0.01"'; ?>
                                            style="flex:1"
                                        />
                                    <?php elseif ( $def['type'] === 'array' ) : ?>
                                        <textarea name="_dnc_cfg_value" style="flex:1"><?php echo esc_textarea( wp_json_encode( $cur, JSON_UNESCAPED_UNICODE ) ); ?></textarea>
                                    <?php else : ?>
                                        <input type="text" name="_dnc_cfg_value" value="<?php echo esc_attr( (string) $cur ); ?>" style="flex:1" />
                                    <?php endif; ?>
                                    <?php if ( ! $is_sensitive ) : ?>
                                        <button type="submit" class="dnc-cfg-btn dnc-cfg-btn-primary">บันทึก</button>
                                    <?php endif; ?>
                                </form>
                                <form method="post" class="dnc-cfg-actions">
                                    <?php wp_nonce_field( 'dnc_cfg_save', '_dnc_cfg_nonce' ); ?>
                                    <input type="hidden" name="_dnc_cfg_action" value="reset" />
                                    <input type="hidden" name="_dnc_cfg_key" value="<?php echo esc_attr( $key ); ?>" />
                                    <button type="submit" class="dnc-cfg-btn dnc-cfg-btn-warn"
                                        onclick="return confirm('รีเซ็ต <?php echo esc_js( $key ); ?> เป็น default?');">↺ default</button>
                                </form>
                            </div>
                        <?php endforeach; ?>
                    </div>
                <?php endforeach; ?>
            <?php endif; ?>
        </div>
        <?php
        return ob_get_clean();
    }
}
add_shortcode( 'dinoco_admin_config_viewer', 'dinoco_admin_config_viewer_shortcode' );

/* ============================================================
 * 5. REGISTER AS ADMIN MODULE (Phase 1 integration)
 * ============================================================ */

add_action( 'init', function() {
    if ( ! function_exists( 'dinoco_register_admin_module' ) ) return;
    dinoco_register_admin_module( array(
        'key'        => 'config_viewer',
        'shortcode'  => 'dinoco_admin_config_viewer',
        'label'      => 'Config Layer',
        'section'    => 'system',
        'icon'       => 'fa-sliders-h',
        'color'      => '#2563eb',
        'cache_ttl'  => 0,
        'capability' => 'manage_options',
        'order'      => 70,
        'source'     => '[Admin System] DINOCO Config Layer V.1.0',
    ) );
}, 30 ); // priority 30 = after schema registration (25)

/* ============================================================
 * 6. REST ENDPOINT — config inspection (admin only)
 * ============================================================ */

add_action( 'rest_api_init', function() {
    register_rest_route( 'dinoco/v1', '/config/list', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_config_rest_list',
        'permission_callback' => function() { return current_user_can( 'manage_options' ); },
        'args'                => array(
            'section' => array( 'sanitize_callback' => 'sanitize_text_field' ),
        ),
    ) );
} );

if ( ! function_exists( 'dinoco_config_rest_list' ) ) {
    function dinoco_config_rest_list( $request ) {
        $section = (string) $request->get_param( 'section' );
        $grouped = dinoco_get_config_schema();
        if ( $section !== '' ) {
            $grouped = isset( $grouped[ $section ] ) ? array( $section => $grouped[ $section ] ) : array();
        }
        // Materialize current values for the response
        $out = array();
        foreach ( $grouped as $sec => $entries ) {
            $out[ $sec ] = array();
            foreach ( $entries as $key => $def ) {
                $cur = dinoco_config( $key );
                $row = array(
                    'key'         => $key,
                    'type'        => $def['type'],
                    'default'     => $def['default'],
                    'value'       => $cur,
                    'label'       => $def['label'],
                    'description' => $def['description'],
                    'section'     => $def['section'],
                );
                if ( ! empty( $def['legacy_option'] ) ) $row['legacy_option'] = $def['legacy_option'];
                if ( ! empty( $def['choices'] ) )       $row['choices']       = $def['choices'];
                if ( ! empty( $def['sensitive'] ) ) {
                    $row['value'] = '********';
                    $row['sensitive'] = true;
                }
                $out[ $sec ][] = $row;
            }
        }
        return array(
            'count'    => array_sum( array_map( 'count', $out ) ),
            'sections' => $out,
        );
    }
}
