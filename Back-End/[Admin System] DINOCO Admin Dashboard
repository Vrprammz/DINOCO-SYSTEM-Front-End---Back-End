    // =========================================================================
    // 4. TAB SWITCHING + LAZY LOADING
    // =========================================================================
    window.switchTab = function(tab) {
        if (!TAB_LABELS[tab]) return;
        currentTab = tab;

        // Update sidebar active
        $('.nav-item').removeClass('active');
        $('.nav-item[data-tab="' + tab + '"]').addClass('active');

        // Update breadcrumb
        $('#breadcrumb-label').text(TAB_LABELS[tab]);

        // Update URL hash
        window.location.hash = tab;

        // Hide all sections, show target
        $('.section-view').removeClass('active');
        if (tab === 'dashboard') {
            $('#tab-dashboard').addClass('active');
            loadStats();
            return;
        }

        var $wrapper = $('#tab-wrapper-' + tab);
        $wrapper.addClass('active');
        var loaded = $wrapper.attr('data-loaded');

        if (loaded === 'true') {
            // Already initialized — just trigger module if applicable
            if (MODULE_TRIGGERS[tab]) {
                MODULE_TRIGGERS[tab]();
            }
            return;
        }

        // First activation: execute deferred scripts (HTML+CSS already pre-rendered)
        var deferredScripts = $wrapper.find('script[type="text/deferred"]').toArray();
        var loadNext = function(idx) {
            if (idx >= deferredScripts.length) {
                $wrapper.attr('data-loaded', 'true');
                if (MODULE_TRIGGERS[tab]) MODULE_TRIGGERS[tab]();
                return;
            }
            var el = deferredScripts[idx];
            var $el = $(el);
            var src = $el.attr('src');

            if (src) {
                // External script — must load via new <script> element
                var script = document.createElement('script');
                script.src = src;
                if ($el.attr('data-was-module') === '1') script.type = 'module';
                script.onload = function() { loadNext(idx + 1); };
                script.onerror = function() {
                    console.warn('[DNC] Failed to load external script in module:', tab, src);
                    loadNext(idx + 1);
                };
                document.head.appendChild(script);
            } else {
                // Inline script — execute directly
                var scriptContent = $el.text();
                if (scriptContent) {
                    try {
                        $.globalEval(scriptContent);
                    } catch(e) {
                        console.warn('[DNC] Script error in module:', tab, e);
                    }
                }
                loadNext(idx + 1);
            }
            $el.remove();
        };
        loadNext(0);
        return; // data-loaded and MODULE_TRIGGERS handled inside loadNext callback
    };

    // =========================================================================
    // 5. COMMAND PALETTE (⌘K)
    // =========================================================================
    window.openCommandPalette = function() {
        $('#cmd-palette').addClass('active');
        $('#cmd-input').val('').focus();
        $('.cmd-item').show().removeClass('selected');
        cmdSelectedIndex = -1;
    };

    window.closeCommandPalette = function() {
        $('#cmd-palette').removeClass('active');
    };

    // Click overlay backdrop to close
    $(document).on('click', '#cmd-palette', function(e) {
        if ($(e.target).is('#cmd-palette')) {
            window.closeCommandPalette();
        }
    });

    // Filter command items on input
    $(document).on('input', '#cmd-input', function() {
        var query = $(this).val().toLowerCase();
        cmdSelectedIndex = -1;
        $('.cmd-item').each(function() {
            var text = $(this).text().toLowerCase();
            if (text.indexOf(query) !== -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
        $('.cmd-item').removeClass('selected');
    });

    // Keyboard navigation inside palette
    $(document).on('keydown', '#cmd-input', function(e) {
        var $visible = $('.cmd-item:visible');
        var count = $visible.length;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            cmdSelectedIndex = Math.min(cmdSelectedIndex + 1, count - 1);
            $visible.removeClass('selected');
            $visible.eq(cmdSelectedIndex).addClass('selected');
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            cmdSelectedIndex = Math.max(cmdSelectedIndex - 1, 0);
            $visible.removeClass('selected');
            $visible.eq(cmdSelectedIndex).addClass('selected');
        } else if (e.key === 'Enter') {
            e.preventDefault();
            if (cmdSelectedIndex >= 0 && cmdSelectedIndex < count) {
                $visible.eq(cmdSelectedIndex).trigger('click');
            }
        } else if (e.key === 'Escape') {
            e.preventDefault();
            window.closeCommandPalette();
        }
    });

    // Click command item
    $(document).on('click', '.cmd-item', function() {
        var action = $(this).attr('data-action');
        if (action && action.indexOf('nav:') === 0) {
            var tab = action.replace('nav:', '');
            window.switchTab(tab);
        }
        window.closeCommandPalette();
    });

    // =========================================================================
    // 6. KEYBOARD SHORTCUTS
    // =========================================================================
    $(document).on('keydown', function(e) {
        var isMeta = e.metaKey || e.ctrlKey;
        var tag = (e.target.tagName || '').toLowerCase();
        var isInput = (tag === 'input' || tag === 'textarea' || tag === 'select' || $(e.target).attr('contenteditable'));

        // ⌘K / Ctrl+K — toggle command palette
        if (isMeta && e.key === 'k') {
            e.preventDefault();
            if ($('#cmd-palette').hasClass('active')) {
                window.closeCommandPalette();
            } else {
                window.openCommandPalette();
            }
            return;
        }

        // ⌘B / Ctrl+B — toggle sidebar
        if (isMeta && e.key === 'b') {
            e.preventDefault();
            window.toggleSidebar();
            return;
        }

        // ⌘1-9 / Ctrl+1-9 — switch tab by index
        if (isMeta && e.key >= '1' && e.key <= '9') {
            e.preventDefault();
            var tabKeys = Object.keys(TAB_LABELS);
            var idx = parseInt(e.key) - 1;
            if (idx < tabKeys.length) {
                window.switchTab(tabKeys[idx]);
            }
            return;
        }

        // Escape — close palette or modal
        if (e.key === 'Escape') {
            if ($('#cmd-palette').hasClass('active')) {
                window.closeCommandPalette();
            } else {
                $('.modal-overlay.active').removeClass('active');
            }
            return;
        }

        // / (when not in input) — focus search or open palette
        if (e.key === '/' && !isInput) {
            e.preventDefault();
            var $moduleSearch = $('.module-search-input:visible');
            if ($moduleSearch.length) {
                $moduleSearch.first().focus();
            } else {
                window.openCommandPalette();
            }
            return;
        }
    });

