    window.addNotification = function(type, title, desc) {
        var iconMap = {
            order:   { icon: 'fa-box', bg: '#dbeafe', color: '#2563eb' },
            user:    { icon: 'fa-user', bg: '#dcfce7', color: '#16a34a' },
            warning: { icon: 'fa-triangle-exclamation', bg: '#fef9c3', color: '#ca8a04' },
            system:  { icon: 'fa-gear', bg: '#f1f5f9', color: '#64748b' },
            info:    { icon: 'fa-circle-info', bg: '#dbeafe', color: '#2563eb' }
        };
        var style = iconMap[type] || iconMap.info;
        _notifs.unshift({
            type: type,
            title: title,
            desc: desc,
            time: new Date().toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }),
            icon: style.icon,
            bg: style.bg,
            color: style.color,
            unread: true
        });
        if (_notifs.length > 50) _notifs = _notifs.slice(0, 50);
        saveNotifs();
        renderNotifs();
        updateNotifBadge();
    };

    window.clearAllNotifs = function() {
        _notifs = [];
        saveNotifs();
        renderNotifs();
        updateNotifBadge();
    };

    function saveNotifs() {
