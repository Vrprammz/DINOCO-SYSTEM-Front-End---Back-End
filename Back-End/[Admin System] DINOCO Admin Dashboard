    // =========================================================================
    // 2. TOAST SYSTEM
    // =========================================================================
    var toastCounter = 0;

    window.showToast = function(type, title, msg, duration) {
        var iconMap = {
            success: 'fa-circle-check',
            error:   'fa-circle-xmark',
            warning: 'fa-triangle-exclamation',
            info:    'fa-circle-info'
        };
        if (typeof duration === 'undefined' || duration === null) {
            duration = (type === 'error') ? 5000 : 3000;
        }
        var id = 'toast-' + (++toastCounter);
        var icon = iconMap[type] || iconMap.info;
        var html = '<div id="' + id + '" class="toast-item toast-' + type + '">' +
            '<div class="toast-icon"><i class="fa-solid ' + icon + '"></i></div>' +
            '<div class="toast-body">' +
                '<div class="toast-title">' + title + '</div>' +
                '<div class="toast-msg">' + msg + '</div>' +
            '</div>' +
            '<button class="toast-close" onclick="dismissToast(\'' + id + '\')">' +
                '<i class="fa-solid fa-xmark"></i>' +
            '</button>' +
        '</div>';
        $('#toast-container').append(html);
        if (duration > 0) {
            setTimeout(function(){ window.dismissToast(id); }, duration);
        }
        // Also log to notification panel (except info toasts)
        if (type !== 'info' && window.addNotification) {
            var ntMap = { success: 'system', error: 'warning', warning: 'warning' };
            window.addNotification(ntMap[type] || 'info', title, msg);
        }
    };

    window.dismissToast = function(id) {
        var $el = $('#' + id);
        if ($el.length && !$el.hasClass('removing')) {
            $el.addClass('removing');
            setTimeout(function(){ $el.remove(); }, 300);
        }
    };

    // =========================================================================
    // 3a. AUTO-REFRESH UI INIT (logic moved to early inline <script>)
    // =========================================================================
    (function() {
