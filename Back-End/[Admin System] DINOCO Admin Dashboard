.kpi-purple .kpi-badge { background: #f3e8ff; color: #9333ea; }

/* ----- MISSING CSS: Dash Cards ----- */
.dash-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    overflow: hidden;
}
.dash-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--c-border-lt);
}
.dash-card-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-heading);
    display: flex;
    align-items: center;
    gap: 8px;
}
.dash-card-title i { color: var(--c-text-dim); font-size: 14px; }
.dash-card-body {
    padding: 18px;
}

/* ----- MISSING CSS: Topbar avatar/username ----- */
.topbar-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--c-border);
}
.topbar-username {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-heading);
}

/* ----- MISSING CSS: Quick Actions ----- */
.quick-actions-grid {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.quick-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--c-text);
    cursor: pointer;
    transition: all 0.15s;
}
.quick-action-btn:hover {
    background: var(--c-heading);
    color: #fff;
    border-color: var(--c-heading);
}
.quick-action-btn i { font-size: 13px; }

/* ----- MISSING CSS: Count Badge ----- */
.count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 7px;
    border-radius: 11px;
    font-size: 11px;
    font-weight: 700;
    background: #ef4444;
    color: #fff;
}

/* ----- MISSING CSS: Stat card extensions ----- */
.stat-value {
    font-size: 28px;
    font-weight: 700;
    color: var(--c-heading);
    line-height: 1.2;
}
.stat-body { flex: 1; }
.stat-orange .stat-icon { color: #f97316; background: #fff7ed; }
.stat-pink .stat-icon { color: #ec4899; background: #fdf2f8; }

/* ----- 14. Quick Actions (cc- prefix) ----- */
.cc-quick-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
}

.cc-quick-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all var(--t-fast);
    min-width: 100px;
}

.cc-quick-btn i {
    font-size: 20px;
    color: var(--c-text-dim);
    transition: color var(--t-fast);
}

.cc-quick-btn span {
    font-size: 11px;
    font-weight: 600;
    color: var(--c-text-dim);
    text-align: center;
    white-space: nowrap;
}

.cc-quick-btn:hover {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.08);
}

.cc-quick-btn:hover i {
    color: #3b82f6;
}

/* ----- 15. AI Inbox ----- */
.ai-inbox-list {
    display: flex;
    flex-direction: column;
}

.ai-inbox-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--c-border-lt);
    cursor: pointer;
    transition: background var(--t-fast);
}

.ai-inbox-item:hover {
    background: var(--c-bg);
}

.ai-inbox-item:last-child {
    border-bottom: none;
}

.ai-inbox-pic {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent-ai);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    flex-shrink: 0;
}

.ai-inbox-pic img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
}

.ai-inbox-body {
    flex: 1;
    min-width: 0;
}

.ai-inbox-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-text);
}

.ai-inbox-msg {
    font-size: 12px;
    color: var(--c-text-dim);
    margin-top: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.ai-inbox-time {
    font-size: 10px;
    color: var(--c-text-xdim);
    margin-top: 4px;
}

/* ----- 16. Charts & Panels ----- */
.dash-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
}

.dash-grid-2 {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
}

.dash-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 24px;
}

.dash-panel {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: 20px;
}

.dash-panel-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--c-heading);
    margin: 0 0 16px 0;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* ----- 17. Alert Bar ----- */
.alert-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 24px;
}

.alert-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
    flex: 1;
    min-width: 220px;
}

.alert-item i {
    font-size: 16px;
    flex-shrink: 0;
}

.alert-item.warning {
    background: #fffbeb;
    color: #92400e;
    border: 1px solid #fde68a;
}

.alert-item.warning i {
    color: #f59e0b;
}

.alert-item.danger {
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
}

.alert-item.danger i {
    color: #ef4444;
}

.alert-item.info {
    background: #eff6ff;
    color: #1e40af;
    border: 1px solid #bfdbfe;
}

.alert-item.info i {
    color: #3b82f6;
}

/* ----- 18. Pipeline ----- */
.pipeline-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
}

.pipeline-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--c-text-dim);
    min-width: 80px;
}

.pipeline-stages {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
}

.pipeline-stage {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    white-space: nowrap;
}

.pipeline-stage-count {
    font-weight: 700;
    color: var(--c-heading);
}

.pipeline-arrow {
    color: var(--c-text-xdim);
    font-size: 10px;
    flex-shrink: 0;
}

.pipeline-arrow::after {
    content: '\f054';
    font-family: 'Font Awesome 6 Free';
    font-weight: 900;
}

.legacy-pipeline-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

/* ----- 19. Activity Feed ----- */
.activity-list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.activity-item {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--c-border-lt);
}

.activity-item:last-child {
    border-bottom: none;
}

.activity-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
}

.activity-icon.green { background: #ecfdf5; color: #10b981; }
.activity-icon.blue { background: #eff6ff; color: #3b82f6; }
.activity-icon.yellow { background: #fffbeb; color: #f59e0b; }
.activity-icon.red { background: #fef2f2; color: #ef4444; }
.activity-icon.purple { background: #faf5ff; color: #a855f7; }

.activity-text {
    font-size: 13px;
    color: var(--c-text);
    flex: 1;
    line-height: 1.5;
}

.activity-text strong {
    font-weight: 600;
    color: var(--c-heading);
}

.activity-time {
    font-size: 11px;
    color: var(--c-text-xdim);
    white-space: nowrap;
    flex-shrink: 0;
}

/* ----- 20. Global Components ----- */

/* Form Input */
.form-input {
    width: 100%;
    padding: 9px 14px;
    border: 1px solid var(--c-border);
    border-radius: 8px;
    font-size: 13px;
    font-family: var(--font);
    color: var(--c-text);
    background: var(--c-surface);
    transition: all var(--t-fast);
