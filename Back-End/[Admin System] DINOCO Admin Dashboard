        }

        $('#cc-action-items').html(html);
        $('#cc-total-tasks').text(total);
    }

    // =========================================================================
    // 9. CHART: Claims Trend
    // =========================================================================
    var claimsTrendChart = null;

    function renderClaimsTrend(trend) {
        var labels = [];
        var values = [];
        for (var i = 0; i < trend.length; i++) {
            labels.push(trend[i].label || trend[i].date);
            values.push(trend[i].count || trend[i].value || 0);
        }

        // Calculate average
        var sum = 0;
        for (var j = 0; j < values.length; j++) { sum += values[j]; }
        var avg = values.length > 0 ? Math.round(sum / values.length) : 0;

        var options = {
            series: [{ name: 'Claims', data: values }],
            chart: {
                type: 'area',
                height: 240,
                toolbar: { show: false },
                fontFamily: 'inherit'
            },
            stroke: { curve: 'smooth', width: 2 },
            colors: ['#3b82f6'],
            fill: {
                type: 'gradient',
                gradient: {
                    shadeIntensity: 1,
                    opacityFrom: 0.4,
                    opacityTo: 0.05,
                    stops: [0, 100]
                }
            },
            xaxis: {
                categories: labels,
                labels: { style: { fontSize: '11px' } }
            },
            yaxis: {
                labels: { style: { fontSize: '11px' } }
            },
            annotations: {
                yaxis: [{
                    y: avg,
                    borderColor: '#f59e0b',
                    label: {
                        text: 'AVG: ' + avg,
                        style: { color: '#fff', background: '#f59e0b', fontSize: '11px' }
                    }
                }]
            },
            tooltip: { theme: 'dark' },
            grid: { borderColor: '#e5e7eb', strokeDashArray: 3 }
        };

        var el = document.querySelector('#chart-claims-trend');
        if (!el) return;

        if (claimsTrendChart) {
            claimsTrendChart.updateOptions(options);
        } else {
            claimsTrendChart = new ApexCharts(el, options);
            claimsTrendChart.render();
        }
    }

    // =========================================================================
    // 10. CHART: Inventory Pie
    // =========================================================================
    var invPieChart = null;

    function renderInvPie(pieData) {
        var labels = [];
        var values = [];
        var colorMap = {
            active:   '#22c55e',
            expiring: '#f59e0b',
            expired:  '#ef4444',
            claimed:  '#8b5cf6',
            transferred: '#3b82f6',
            inactive: '#6b7280'
        };
        var colors = [];

        for (var i = 0; i < pieData.length; i++) {
            labels.push(pieData[i].label || pieData[i].status);
            values.push(pieData[i].count || pieData[i].value || 0);
            colors.push(colorMap[pieData[i].status] || colorMap[pieData[i].key] || '#6b7280');
        }

        var total = 0;
        for (var j = 0; j < values.length; j++) { total += values[j]; }

        var options = {
            series: values,
            labels: labels,
            chart: {
                type: 'donut',
                height: 220,
                fontFamily: 'inherit'
            },
            colors: colors,
            plotOptions: {
                pie: {
                    donut: {
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                label: 'ทั้งหมด',
                                formatter: function() { return total.toLocaleString(); }
                            }
                        }
                    }
                }
            },
            legend: {
                position: 'bottom',
                fontSize: '12px'
            },
            tooltip: { theme: 'dark' }
        };

        var el = document.querySelector('#chart-inv-pie');
        if (!el) return;

        if (invPieChart) {
            invPieChart.updateOptions(options);
        } else {
            invPieChart = new ApexCharts(el, options);
            invPieChart.render();
        }
    }

    // =========================================================================
    // 11. PIPELINE SNAPSHOT
    // =========================================================================
    function renderPipeline(pipeline) {
        var html = '';

        // PCLM row (blue)
        if (pipeline.pclm) {
            html += '<div class="pipeline-row pipeline-blue">';
            html += '<div class="pipeline-label">PCLM</div>';
            html += '<div class="pipeline-stages">';
            for (var i = 0; i < pipeline.pclm.length; i++) {
                var s = pipeline.pclm[i];
                if (i > 0) {
                    html += '<span class="pipeline-chevron"><i class="fa-solid fa-chevron-right"></i></span>';
                }
                html += '<span class="pipeline-chip pipeline-chip-blue' + (s.count > 0 ? ' active' : '') + '">' +
                    s.label + ' <strong>' + s.count + '</strong>' +
                '</span>';
            }
            html += '</div></div>';
        }

        // CLM row (green)
        if (pipeline.clm) {
            html += '<div class="pipeline-row pipeline-green">';
            html += '<div class="pipeline-label">CLM</div>';
            html += '<div class="pipeline-stages">';
            for (var j = 0; j < pipeline.clm.length; j++) {
                var c = pipeline.clm[j];
                if (j > 0) {
                    html += '<span class="pipeline-chevron"><i class="fa-solid fa-chevron-right"></i></span>';
                }
                html += '<span class="pipeline-chip pipeline-chip-green' + (c.count > 0 ? ' active' : '') + '">' +
                    c.label + ' <strong>' + c.count + '</strong>' +
                '</span>';
            }
            html += '</div></div>';
        }

        $('#pipeline-snapshot').html(html);
    }

    // =========================================================================
    // 12. LEGACY PIPELINE
    // =========================================================================
    function renderLegacyPipeline(stages) {
        var html = '<div class="legacy-pipeline-flow">';
        for (var i = 0; i < stages.length; i++) {
            var s = stages[i];
            var activeClass = s.count > 0 ? ' active' : '';
            var colorClass = s.color ? ' legacy-chip-' + s.color : '';
            if (i > 0) {
                html += '<span class="pipeline-chevron"><i class="fa-solid fa-chevron-right"></i></span>';
            }
            html += '<span class="legacy-chip' + colorClass + activeClass + '">' +
                s.label + ' <strong>' + s.count + '</strong>' +
            '</span>';
        }
        html += '</div>';
        $('#legacy-pipeline').html(html);
    }

    // =========================================================================
    // 13. AI INBOX
    // =========================================================================
    function renderAIInbox(inbox) {
        if (!inbox || !inbox.length) {
            $('#ai-inbox-list').html('<div class="empty-state">ไม่มีแชทรอดำเนินการ</div>');
            return;
        }

        // Sort: admin-needed first, then claim-pending
        inbox.sort(function(a, b) {
            var aWeight = a.status === 'admin_needed' ? 2 : (a.status === 'claim_pending' ? 1 : 0);
            var bWeight = b.status === 'admin_needed' ? 2 : (b.status === 'claim_pending' ? 1 : 0);
            return bWeight - aWeight;
        });

        var maxShow = 6;
        var html = '';

        for (var i = 0; i < Math.min(inbox.length, maxShow); i++) {
            var item = inbox[i];
            var avatar = item.avatar || '';
            var name = item.name || 'ไม่ทราบชื่อ';
            var msg = item.last_message || '';
            if (msg.length > 60) msg = msg.substring(0, 60) + '...';
            var time = item.time || '';

            var tag = '';
            if (item.status === 'admin_needed') {
                tag = '<span class="ai-tag tag-red">รอแอดมิน</span>';
            } else if (item.status === 'claim_pending') {
                tag = '<span class="ai-tag tag-yellow">เคลม</span>';
            }

            html += '<div class="ai-inbox-item" onclick="switchTab(\'ai_control\')">' +
                '<div class="ai-inbox-avatar">' +
                    (avatar ? '<img src="' + avatar + '" alt="">' : '<i class="fa-solid fa-user"></i>') +
                '</div>' +
                '<div class="ai-inbox-content">' +
                    '<div class="ai-inbox-header">' +
                        '<span class="ai-inbox-name">' + name + '</span>' +
                        tag +
                        '<span class="ai-inbox-time">' + time + '</span>' +
                    '</div>' +
                    '<div class="ai-inbox-msg">' + msg + '</div>' +
                '</div>' +
            '</div>';
        }

        if (inbox.length > maxShow) {
            html += '<a class="ai-inbox-more" href="#" onclick="switchTab(\'ai_control\'); return false;">ดูทั้งหมด (' + inbox.length + ')</a>';
        }

        $('#ai-inbox-list').html(html);
    }

    // =========================================================================
    // 14. ALERTS
    // =========================================================================
    function renderAlerts(alerts) {
        if (!alerts || !alerts.length) {
            $('#alerts-list').html('<div class="empty-state">ไม่มีการแจ้งเตือน</div>');
            return;
        }

        var html = '';
        for (var i = 0; i < alerts.length; i++) {
            var a = alerts[i];
            var cssClass = 'alert-warning';
            if (a.type === 'danger') cssClass = 'alert-danger';
            else if (a.type === 'info') cssClass = 'alert-info';

            var tab = a.tab || 'dashboard';
            html += '<div class="alert-item ' + cssClass + '" onclick="switchTab(\'' + tab + '\')">' +
                '<i class="fa-solid ' + (a.icon || 'fa-circle-exclamation') + '"></i> ' +
                '<span>' + (a.text || a.message || '') + '</span>' +
            '</div>';
        }

        $('#alerts-list').html(html);
    }

    // =========================================================================
    // 15. ACTIVITY FEED
    // =========================================================================
    function renderActivity(activities) {
        if (!activities || !activities.length) {
            $('#activity-feed').html('<div class="empty-state">ไม่มีกิจกรรมล่าสุด</div>');
            return;
        }

        var html = '';
        for (var i = 0; i < activities.length; i++) {
            var act = activities[i];
            var tab = act.tab || 'dashboard';
            html += '<div class="activity-item" onclick="switchTab(\'' + tab + '\')">' +
                '<div class="activity-icon"><i class="fa-solid ' + (act.icon || 'fa-circle') + '"></i></div>' +
                '<div class="activity-content">' +
                    '<div class="activity-text">' + (act.text || '') + '</div>' +
                    '<div class="activity-time">' + (act.time || '') + '</div>' +
                '</div>' +
            '</div>';
        }

        $('#activity-feed').html(html);
    }

    // =========================================================================
    // 16. HELPER FUNCTIONS
    // =========================================================================
    function animateNumber(selector, target) {
        target = parseInt(target) || 0;
        $(selector).text(target.toLocaleString());
    }

    function updateBadge(selector, count) {
        count = parseInt(count) || 0;
        var $badge = $(selector);
        if (count > 0) {
            $badge.text(count).show();
        } else {
            $badge.hide();
        }
    }

    // =========================================================================
    // 17. URL HASH RESTORE
    // =========================================================================
    (function initFromHash() {
        var hash = window.location.hash.replace('#', '');
        if (hash && TAB_LABELS[hash]) {
            switchTab(hash);
        } else {
            // Default: dashboard
            switchTab('dashboard');
        }
    })();

    // Sidebar nav click handler
    $(document).on('click', '.nav-item', function(e) {
        e.preventDefault();
        var tab = $(this).attr('data-tab');
        if (tab) switchTab(tab);
    });

});
</script>
