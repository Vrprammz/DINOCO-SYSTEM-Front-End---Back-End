            data: { dinoco_dashboard_action: 'get_dashboard_extended' },
            dataType: 'json',
            success: function(data) {
                if (!data || !data.success) return;
                if (data.trend)            renderClaimsTrend(data.trend);
                if (data.inv_breakdown)    renderInvPie(data.inv_breakdown);
                if (data.pipeline)         renderPipeline(data.pipeline);
                if (data.legacy_pipeline)  renderLegacyPipeline(data.legacy_pipeline);
                if (data.ai_inbox)         renderAIInbox(data.ai_inbox);
                if (data.alerts)           renderAlerts(data.alerts);
                if (data.recent)           renderActivity(data.recent);
            }
        });
    };

    // =========================================================================
    // 8. ACTION CENTER — buildActionCenter(d)
    // =========================================================================
    function buildActionCenter(d) {
        var items = [];
        var priority = 0;

        if (d.b2b_pending > 0) {
            items.push({ priority: 100, icon: 'fa-cart-shopping', color: 'red', title: 'ออเดอร์ B2B รอกดรับ', desc: 'ลูกค้าสั่งซื้อสินค้า B2B รอแอดมินกดรับออเดอร์', count: d.b2b_pending, tab: 'b2b_dnc' });
        }
        if (d.b2b_packing > 0) {
            items.push({ priority: 90, icon: 'fa-box-open', color: 'orange', title: 'ออเดอร์ B2B รอแพ็คส่ง', desc: 'ออเดอร์ยืนยันแล้ว รอแพ็คและจัดส่งสินค้า', count: d.b2b_packing, tab: 'b2b_dnc' });
        }
        if (d.b2b_shipping > 0) {
            items.push({ priority: 80, icon: 'fa-truck-fast', color: 'blue', title: 'B2B รอขนส่งเข้ารับ', desc: 'แพ็คเสร็จแล้ว รอขนส่งมารับพัสดุ', count: d.b2b_shipping, tab: 'b2b_dnc' });
        }
        if (d.claims_pending > 0) {
            items.push({ priority: 70, icon: 'fa-gavel', color: 'red', title: 'เคลมรออนุมัติ', desc: 'ลูกค้าส่งเรื่องเคลมแล้ว รอแอดมินตรวจสอบและอนุมัติ', count: d.claims_pending, tab: 'claims' });
        }
        if (d.claims_received > 0) {
            items.push({ priority: 60, icon: 'fa-clipboard-check', color: 'yellow', title: 'เคลมรอตรวจสอบ', desc: 'ได้รับสินค้าแล้ว รอตรวจสอบปัญหาจริง', count: d.claims_received, tab: 'claims' });
        }
        if (d.claims_repairing > 0) {
            items.push({ priority: 50, icon: 'fa-wrench', color: 'blue', title: 'กำลังซ่อม/ตรวจ', desc: 'สินค้าอยู่ระหว่างซ่อมหรือตรวจสอบ', count: d.claims_repairing, tab: 'claims' });
        }
        if (d.ai_claims_pending > 0) {
            items.push({ priority: 40, icon: 'fa-box-open', color: 'yellow', title: 'เคลมรอตรวจ (AI Chat)', desc: 'ลูกค้าแจ้งเคลมผ่าน AI — ข้อมูลครบแล้ว รอรับเรื่อง', count: d.ai_claims_pending, tab: 'ai_control' });
        }
        if (d.ai_pending > 0) {
            items.push({ priority: 30, icon: 'fa-comment-dots', color: 'purple', title: 'แชทรอแอดมินตอบ', desc: 'AI ตอบไม่ได้ ส่งเรื่องให้แอดมินมาตอบ', count: d.ai_pending, tab: 'ai_control' });
        }
        if (d.warranty_transfer_pending > 0) {
            items.push({ priority: 20, icon: 'fa-shuffle', color: 'red', title: 'โอนประกันรอตรวจสอบ', desc: 'มีคำขอโอนประกันรอแอดมินตรวจสอบและอนุมัติ', count: d.warranty_transfer_pending, tab: 'transfer' });
        }
        if (d.legacy_pending > 0) {
            items.push({ priority: 10, icon: 'fa-hourglass-half', color: 'orange', title: 'Legacy กำลังดำเนินการ', desc: 'คำขอ Legacy Migration ที่ยังไม่เสร็จ', count: d.legacy_pending, tab: 'legacy' });
        }
        if (d.sn_expiring > 0) {
            items.push({ priority: 5, icon: 'fa-shield-halved', color: 'pink', title: 'ประกันใกล้หมด', desc: 'สินค้าที่ประกันจะหมดภายใน 30 วัน', count: d.sn_expiring, tab: 'inventory', badgeClass: 'warn' });
        }

        // Sort by priority descending
        items.sort(function(a, b) { return b.priority - a.priority; });

        var html = '';
        var total = 0;

        for (var i = 0; i < items.length; i++) {
            var item = items[i];
            total += item.count;
            var badgeCls = item.badgeClass || item.color;
