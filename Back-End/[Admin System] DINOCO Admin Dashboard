<!-- Auto-Refresh Override - MUST run before any module scripts -->
<script>
(function() {
    var _origSetInterval = window.setInterval;
    var _origSetTimeout = window.setTimeout;
    var _tracked = [];
    var _enabled = localStorage.getItem('dnc_auto_refresh') === 'true';

    window._dncAutoRefresh = {
        tracked: _tracked,
        origSetInterval: _origSetInterval,
        origSetTimeout: _origSetTimeout
    };
    window.DINOCO_AUTO_REFRESH = _enabled;

    // Override setInterval
    window.setInterval = function(fn, delay) {
        var entry = { type: 'interval', fn: fn, delay: delay, id: null, paused: false };
        if (!window.DINOCO_AUTO_REFRESH && delay >= 3000) {
