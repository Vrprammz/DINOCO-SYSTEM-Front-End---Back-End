/*
 * Template Name: [Admin System] DINOCO Admin Dashboard
 * Shortcode: [dinoco_admin_dashboard]
 * Description: Command Center — Full Dashboard: KPIs, Action Queue, Charts, Pipeline, AI Inbox, Alerts
 * Version: V.30.0
 */

// ─────────────────────────────────────────────────────────────────────────────
// AJAX Endpoints via POST — dinoco_dashboard_action
// ─────────────────────────────────────────────────────────────────────────────
add_action('init', function () {

    if ($_SERVER['REQUEST_METHOD'] !== 'POST' || empty($_POST['dinoco_dashboard_action'])) {
        return;
    }

    $action = sanitize_text_field($_POST['dinoco_dashboard_action']);

    // =====================================================================
    // (a) get_dashboard_stats — Core KPI numbers
    // =====================================================================
    if ($action === 'get_dashboard_stats') {

        if (ob_get_length()) ob_clean();
        error_reporting(0);
        @ini_set('display_errors', 0);

        header('Content-Type: application/json; charset=utf-8');
        header('Cache-Control: no-cache, no-store, must-revalidate');
        header('Pragma: no-cache');
        header('Expires: 0');

        if (!current_user_can('manage_options')) {
            echo json_encode(['success' => false, 'error' => 'ACCESS DENIED']);
            exit;
        }

        global $wpdb;

        // Legacy requests
        $legacy_counts    = wp_count_posts('legacy_request');
        $legacy_total     = isset($legacy_counts->publish) ? (int) $legacy_counts->publish : 0;

        $legacy_pending_q = new WP_Query([
            'post_type'      => 'legacy_request',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'request_status',
                    'value'   => ['Completed', 'Shipped'],
                    'compare' => 'NOT IN',
                ],
            ],
        ]);
        $legacy_pending = $legacy_pending_q->found_posts;

        // Claims — open tickets
        $claims_q = new WP_Query([
            'post_type'      => 'claim_ticket',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'ticket_status',
                    'value'   => ['completed', 'replacement_rejected', 'returned'],
                    'compare' => 'NOT IN',
                ],
            ],
        ]);
        $claims = $claims_q->found_posts;

        // Claims — pending admin
        $claims_pending_q = new WP_Query([
            'post_type'      => 'claim_ticket',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'ticket_status',
                    'value'   => 'pending_admin',
                    'compare' => '=',
                ],
            ],
        ]);
        $claims_pending = $claims_pending_q->found_posts;

        // Claims — received at company (รอตรวจสอบ)
        $claims_received_q = new WP_Query([
            'post_type'      => 'claim_ticket',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'ticket_status',
                    'value'   => 'received_at_company',
                    'compare' => '=',
                ],
            ],
        ]);
        $claims_received = $claims_received_q->found_posts;

        // Claims — repairing (under_maintenance or pending_verification)
        $claims_repairing_q = new WP_Query([
            'post_type'      => 'claim_ticket',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'ticket_status',
                    'value'   => ['under_maintenance', 'pending_verification'],
                    'compare' => 'IN',
                ],
            ],
        ]);
        $claims_repairing = $claims_repairing_q->found_posts;

        // Users
        $user_counts = count_users();
        $users_total = isset($user_counts['total_users']) ? (int) $user_counts['total_users'] : 0;

        // Serial Numbers — totals by w_status
        $total_sn_q = new WP_Query([
            'post_type'      => 'serial_number',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
        ]);
        $total_sn = $total_sn_q->found_posts;

        $sn_avail_q = new WP_Query([
            'post_type'      => 'serial_number',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'w_status',
                    'value'   => 'warranty_available',
                    'compare' => '=',
                ],
            ],
        ]);
        $sn_avail = $sn_avail_q->found_posts;

        $sn_active_q = new WP_Query([
            'post_type'      => 'serial_number',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'w_status',
                    'value'   => ['warranty_on', 'repaired', 'claim_process'],
                    'compare' => 'IN',
                ],
            ],
        ]);
        $sn_active = $sn_active_q->found_posts;

        // Serial Numbers — warranty expiring within 30 days (direct SQL)
        $today    = date('Y-m-d');
        $plus30   = date('Y-m-d', strtotime('+30 days'));
        $sn_expiring = (int) $wpdb->get_var($wpdb->prepare(
            "SELECT COUNT(DISTINCT p.ID)
             FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id
             WHERE p.post_type   = 'serial_number'
               AND p.post_status = 'publish'
               AND pm.meta_key   = 'warranty_expiry'
               AND pm.meta_value BETWEEN %s AND %s",
            $today,
            $plus30
        ));

        // AI Chat — from dinoco_chat_logs_v9.json
        $ai_pending       = 0;
        $ai_total          = 0;
        $ai_claims_pending = 0;

        $upload_dir = wp_upload_dir();
        $chat_log_file = $upload_dir['basedir'] . '/dinoco_chat_logs_v9.json';

        if (file_exists($chat_log_file)) {
            $raw = file_get_contents($chat_log_file);
            $chats = json_decode($raw, true);
            if (is_array($chats)) {
                foreach ($chats as $chat) {
                    // Skip sandbox sessions
                    if (!empty($chat['sandbox'])) {
                        continue;
                    }
                    $ai_total++;
                    if (!empty($chat['needs_admin']) && $chat['needs_admin'] === true) {
                        $ai_pending++;
                    }
                    if (isset($chat['claim_status']) && $chat['claim_status'] === 'pending') {
                        $ai_claims_pending++;
                    }
                }
            }
        }

        // B2B Orders — pending (needs acceptance)
        $b2b_pending_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'order_status',
                    'value'   => 'pending',
                    'compare' => '=',
                ],
            ],
        ]);
        $b2b_pending = $b2b_pending_q->found_posts;

        // B2B Orders — confirmed (needs packing)
        $b2b_packing_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'order_status',
                    'value'   => 'confirmed',
                    'compare' => '=',
                ],
            ],
        ]);
        $b2b_packing = $b2b_packing_q->found_posts;

        // B2B Orders — packed (waiting courier pickup)
        $b2b_shipping_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'order_status',
                    'value'   => 'packed',
                    'compare' => '=',
                ],
            ],
        ]);
        $b2b_shipping = $b2b_shipping_q->found_posts;

        // Warranty Transfer — pending review
        $warranty_transfer_pending_q = new WP_Query([
            'post_type'      => 'serial_number',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                [
                    'key'     => 'w_status',
                    'value'   => 'warranty_pending',
                    'compare' => '=',
                ],
            ],
        ]);
        $warranty_transfer_pending = $warranty_transfer_pending_q->found_posts;

        // Action items — sum of all actionable counts
        $action_items = $legacy_pending
                      + $claims_pending
                      + $claims_received
                      + $claims_repairing
                      + $ai_pending
                      + $ai_claims_pending
                      + $b2b_pending
                      + $b2b_packing
                      + $b2b_shipping
                      + $warranty_transfer_pending;

        echo json_encode([
            'success'                    => true,
            'legacy'                     => $legacy_total,
            'legacy_pending'             => $legacy_pending,
            'claims'                     => $claims,
            'claims_pending'             => $claims_pending,
            'claims_received'            => $claims_received,
            'claims_repairing'           => $claims_repairing,
            'users'                      => $users_total,
            'total_sn'                   => $total_sn,
            'sn_avail'                   => $sn_avail,
            'sn_active'                  => $sn_active,
            'sn_expiring'                => $sn_expiring,
            'ai_pending'                 => $ai_pending,
            'ai_total'                   => $ai_total,
            'ai_claims_pending'          => $ai_claims_pending,
            'b2b_pending'                => $b2b_pending,
            'b2b_packing'                => $b2b_packing,
            'b2b_shipping'               => $b2b_shipping,
            'warranty_transfer_pending'  => $warranty_transfer_pending,
            'action_items'               => $action_items,
        ]);
        exit;
    }

    // =====================================================================
    // (b) get_dashboard_extended — Trends, Pipelines, AI Inbox, Alerts
    // =====================================================================
    if ($action === 'get_dashboard_extended') {

        if (ob_get_length()) ob_clean();
        error_reporting(0);
        @ini_set('display_errors', 0);

        header('Content-Type: application/json; charset=utf-8');
        header('Cache-Control: no-cache, no-store, must-revalidate');
        header('Pragma: no-cache');
        header('Expires: 0');

        if (!current_user_can('manage_options')) {
            echo json_encode(['success' => false, 'error' => 'ACCESS DENIED']);
            exit;
        }

        global $wpdb;

        // ── Trend: claims per day for last 14 days ──
        $trend = [];
        for ($i = 13; $i >= 0; $i--) {
            $date = date('Y-m-d', strtotime("-{$i} days"));
            $q = new WP_Query([
                'post_type'      => 'claim_ticket',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'date_query'     => [
                    [
                        'year'  => (int) date('Y', strtotime($date)),
                        'month' => (int) date('m', strtotime($date)),
                        'day'   => (int) date('d', strtotime($date)),
                    ],
                ],
            ]);
            $trend[] = [
                'date'  => $date,
                'count' => $q->found_posts,
            ];
        }

        // ── Inventory Breakdown by w_status ──
        $inv_statuses = [
            'warranty_available',
            'warranty_on',
            'warranty_expired',
            'claim_process',
            'repaired',
        ];
        $inv_breakdown = [];
        foreach ($inv_statuses as $status) {
            $q = new WP_Query([
                'post_type'      => 'serial_number',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => [
                    [
                        'key'     => 'w_status',
                        'value'   => $status,
                        'compare' => '=',
                    ],
                ],
            ]);
            $inv_breakdown[$status] = $q->found_posts;
        }

        // ── Pipeline: PCLM (Pre-Claim / Replacement) ──
        $pclm_stages = ['pending_admin', 'approved', 'shipped', 'received'];
        $pipeline_pclm = [];
        foreach ($pclm_stages as $stage) {
            $q = new WP_Query([
                'post_type'      => 'claim_ticket',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => [
                    [
                        'key'     => 'ticket_status',
                        'value'   => $stage,
                        'compare' => '=',
                    ],
                ],
            ]);
            $pipeline_pclm[$stage] = $q->found_posts;
        }

        // ── Pipeline: CLM (Claim / Repair) ──
        $clm_stages = ['pending_admin', 'in_repair', 'repaired', 'shipped_back'];
        $pipeline_clm = [];
        foreach ($clm_stages as $stage) {
            $q = new WP_Query([
                'post_type'      => 'claim_ticket',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => [
                    [
                        'key'     => 'ticket_status',
                        'value'   => $stage,
                        'compare' => '=',
                    ],
                ],
            ]);
            $pipeline_clm[$stage] = $q->found_posts;
        }

        // ── Legacy Pipeline ──
        $legacy_stages = [
            'Submission Received',
            'Verification Passed',
            'Work Order Created',
            'Shipped',
            'Pending Serial Number',
            'Completed',
        ];
        $legacy_pipeline = [];
        foreach ($legacy_stages as $stage) {
            $q = new WP_Query([
                'post_type'      => 'legacy_request',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => [
                    [
                        'key'     => 'request_status',
                        'value'   => $stage,
                        'compare' => '=',
                    ],
                ],
            ]);
            $legacy_pipeline[$stage] = $q->found_posts;
        }

        // ── Recent Activity: last 10 (claims + legacy, sorted by modified) ──
        $recent_claims = new WP_Query([
            'post_type'      => 'claim_ticket',
            'post_status'    => 'publish',
            'posts_per_page' => 10,
            'orderby'        => 'modified',
            'order'          => 'DESC',
            'fields'         => 'ids',
        ]);

        $recent_legacy = new WP_Query([
            'post_type'      => 'legacy_request',
            'post_status'    => 'publish',
            'posts_per_page' => 10,
            'orderby'        => 'modified',
            'order'          => 'DESC',
            'fields'         => 'ids',
        ]);

        $combined_ids = array_merge($recent_claims->posts, $recent_legacy->posts);
        $combined = [];
        foreach ($combined_ids as $pid) {
            $combined[] = [
                'id'        => $pid,
                'type'      => get_post_type($pid),
                'title'     => get_the_title($pid),
                'status'    => get_post_meta($pid, (get_post_type($pid) === 'claim_ticket' ? 'ticket_status' : 'request_status'), true),
                'modified'  => get_post_modified_time('Y-m-d H:i:s', false, $pid),
            ];
        }
        usort($combined, function ($a, $b) {
            return strtotime($b['modified']) - strtotime($a['modified']);
        });
        $recent = array_slice($combined, 0, 10);

        // ── AI Inbox — needs_admin or claim_status=pending ──
        $ai_inbox = [];
        $upload_dir = wp_upload_dir();
        $chat_log_file = $upload_dir['basedir'] . '/dinoco_chat_logs_v9.json';

        if (file_exists($chat_log_file)) {
            $raw   = file_get_contents($chat_log_file);
            $chats = json_decode($raw, true);
            if (is_array($chats)) {
                foreach ($chats as $chat) {
                    if (!empty($chat['sandbox'])) {
                        continue;
                    }
                    $needs_admin   = !empty($chat['needs_admin']) && $chat['needs_admin'] === true;
                    $claim_pending = isset($chat['claim_status']) && $chat['claim_status'] === 'pending';
                    if ($needs_admin || $claim_pending) {
                        $ai_inbox[] = [
                            'session_id'   => isset($chat['session_id'])   ? $chat['session_id']   : '',
                            'user'         => isset($chat['user_name'])    ? $chat['user_name']     : (isset($chat['user']) ? $chat['user'] : 'Unknown'),
                            'needs_admin'  => $needs_admin,
                            'claim_status' => isset($chat['claim_status']) ? $chat['claim_status']  : null,
                            'last_message' => isset($chat['last_message']) ? $chat['last_message']  : '',
                            'timestamp'    => isset($chat['timestamp'])    ? $chat['timestamp']     : '',
                        ];
                    }
                }
            }
        }

        // ── Alerts ──
        $alerts = [];

        // Overdue claims: open claims modified > 7 days ago
        $overdue_q = new WP_Query([
            'post_type'      => 'claim_ticket',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [
                [
                    'column' => 'post_modified',
                    'before' => '7 days ago',
                ],
            ],
            'meta_query'     => [
                [
                    'key'     => 'ticket_status',
                    'value'   => ['completed', 'replacement_rejected', 'returned'],
                    'compare' => 'NOT IN',
                ],
            ],
        ]);
        if ($overdue_q->found_posts > 0) {
            $alerts[] = [
                'type'    => 'overdue_claims',
                'severity'=> 'critical',
                'message' => $overdue_q->found_posts . ' claim(s) overdue — no update in 7+ days',
                'count'   => $overdue_q->found_posts,
            ];
        }

        // Warranty expiring in 7 days
        $today  = date('Y-m-d');
        $plus7  = date('Y-m-d', strtotime('+7 days'));
        $expiring_7d = (int) $wpdb->get_var($wpdb->prepare(
            "SELECT COUNT(DISTINCT p.ID)
             FROM {$wpdb->posts} p
             INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id
             WHERE p.post_type   = 'serial_number'
               AND p.post_status = 'publish'
               AND pm.meta_key   = 'warranty_expiry'
               AND pm.meta_value BETWEEN %s AND %s",
            $today,
            $plus7
        ));
        if ($expiring_7d > 0) {
            $alerts[] = [
                'type'    => 'warranty_expiring',
                'severity'=> 'warning',
                'message' => $expiring_7d . ' serial number(s) warranty expiring within 7 days',
                'count'   => $expiring_7d,
            ];
        }

        // AI needs admin
        $ai_admin_count = count(array_filter($ai_inbox, function ($c) {
            return $c['needs_admin'];
        }));
        if ($ai_admin_count > 0) {
            $alerts[] = [
                'type'    => 'ai_needs_admin',
                'severity'=> 'warning',
                'message' => $ai_admin_count . ' AI chat(s) require admin attention',
                'count'   => $ai_admin_count,
            ];
        }

        // B2B orders pending > 24h
        $b2b_overdue_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [
                [
                    'column' => 'post_date',
                    'before' => '24 hours ago',
                ],
            ],
            'meta_query'     => [
                [
                    'key'     => 'order_status',
                    'value'   => 'pending',
                    'compare' => '=',
                ],
            ],
        ]);
        if ($b2b_overdue_q->found_posts > 0) {
            $alerts[] = [
                'type'    => 'b2b_pending_overdue',
                'severity'=> 'critical',
                'message' => $b2b_overdue_q->found_posts . ' B2B order(s) pending for over 24 hours',
                'count'   => $b2b_overdue_q->found_posts,
            ];
        }

        echo json_encode([
            'success'          => true,
            'trend'            => $trend,
            'inv_breakdown'    => $inv_breakdown,
            'pipeline'         => [
                'pclm' => $pipeline_pclm,
                'clm'  => $pipeline_clm,
            ],
            'legacy_pipeline'  => $legacy_pipeline,
            'recent'           => $recent,
            'ai_inbox'         => $ai_inbox,
            'alerts'           => $alerts,
        ]);
        exit;
    }

    // =====================================================================
    // (c) lazy_load_module — Dynamic shortcode loader
    // =====================================================================
    if ($action === 'lazy_load_module') {

        if (ob_get_length()) ob_clean();
        error_reporting(0);
        @ini_set('display_errors', 0);

        header('Content-Type: text/html; charset=utf-8');
        header('Cache-Control: no-cache, no-store, must-revalidate');

        if (!current_user_can('manage_options')) {
            echo '<div style="text-align:center;padding:20px;color:red;">ACCESS DENIED</div>';
            exit;
        }

        $module = isset($_POST['module_name']) ? sanitize_text_field($_POST['module_name']) : '';

        $module_map = [
            'claims'          => '[dinoco_admin_claims]',
            'legacy'          => '[dinoco_admin_legacy]',
            'inventory'       => '[dinoco_admin_inventory]',
            'users'           => '[dinoco_admin_users]',
            'ai_control'      => '[dinoco_admin_ai_control]',
            'transfer'        => '[dinoco_admin_transfer]',
            'b2b_dnc'         => '[b2b_admin_dashboard]',
            'b2b_admin'       => '[b2b_admin_control]',
        ];

        if (isset($module_map[$module])) {
            echo do_shortcode($module_map[$module]);
        } else {
            echo '<div style="text-align:center;padding:20px;color:#888;">Module not found: ' . esc_html($module) . '</div>';
        }
        exit;
    }

}, 20);


// ─────────────────────────────────────────────────────────────────────────────
