            #dinoco-export-toast {
                position: fixed; bottom: 90px; right: 24px; z-index: 9999;
                background: #1e293b; color: #fff; padding: 12px 18px; border-radius: 8px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.25); font-size: 13px; font-weight: 600;
                display: none; max-width: 340px;
            }
            #dinoco-export-toast.show { display: block; animation: dex-slide 0.25s ease-out; }
            #dinoco-export-toast.err { background: #b91c1c; }
            #dinoco-export-toast.ok  { background: #059669; }
            @keyframes dex-slide { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        </style>
        <button id="dinoco-export-fab" title="Download Product Catalog + Makers + Hierarchy เป็นไฟล์ ZIP">
            <span class="dex-icon">📦</span>
            <span class="dex-spinner"></span>
            <span class="dex-label">Export Catalog (ZIP)</span>
        </button>
        <div id="dinoco-export-toast"></div>
        <script>
        (function(){
            var btn   = document.getElementById('dinoco-export-fab');
            var toast = document.getElementById('dinoco-export-toast');
            if (!btn) return;
            var URL_ALL = <?php echo wp_json_encode( $url ); ?>;
            var NONCE   = <?php echo wp_json_encode( $nonce ); ?>;

            function showToast(msg, type) {
                toast.textContent = msg;
                toast.className = 'show ' + (type || '');
                setTimeout(function(){ toast.className = ''; }, 4500);
            }

            btn.addEventListener('click', function() {
                if (btn.classList.contains('loading')) return;
                btn.classList.add('loading');
                btn.disabled = true;
                var labelEl = btn.querySelector('.dex-label');
                var originalLabel = labelEl.textContent;
                labelEl.textContent = 'กำลังสร้าง ZIP...';
                showToast('กำลังสร้างไฟล์ ZIP... (อาจใช้เวลา 5-30 วินาที)', 'ok');

                fetch(URL_ALL, {
                    method: 'GET',
                    credentials: 'same-origin',
                    headers: { 'X-WP-Nonce': NONCE }
                })
                .then(function(res) {
                    if (!res.ok) {
                        return res.text().then(function(t){
                            var msg = 'HTTP ' + res.status;
                            try { var j = JSON.parse(t); if (j.message) msg = j.message; } catch(e){}
                            throw new Error(msg);
                        });
                    }
                    // filename จาก Content-Disposition
                    var disp = res.headers.get('Content-Disposition') || '';
                    var m = disp.match(/filename="([^"]+)"/);
                    var fname = m ? m[1] : 'dinoco-catalog.zip';
                    return res.blob().then(function(blob){ return { blob: blob, fname: fname }; });
                })
                .then(function(data) {
                    var a = document.createElement('a');
                    a.href = window.URL.createObjectURL(data.blob);
                    a.download = data.fname;
                    document.body.appendChild(a);
                    a.click();
                    setTimeout(function(){
                        document.body.removeChild(a);
                        window.URL.revokeObjectURL(a.href);
                    }, 500);
                    showToast('✅ ดาวน์โหลดเรียบร้อย: ' + data.fname, 'ok');
                })
                .catch(function(err) {
                    showToast('❌ Error: ' + (err.message || 'Unknown error'), 'err');
                    console.error('[DINOCO Export]', err);
                })
                .finally(function() {
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    labelEl.textContent = originalLabel;
                });
            });
        })();
        </script>
