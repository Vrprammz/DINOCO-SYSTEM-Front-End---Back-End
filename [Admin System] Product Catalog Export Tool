        if ( ! $has_target ) return;

        $url = esc_url( rest_url( 'dinoco-export/v1/download-all' ) );
        // ใช้ WP REST nonce เพื่อให้ WordPress recognize logged-in state (cookie auth)
        $nonce = wp_create_nonce( 'wp_rest' );
        ?>
        <style>
            #dinoco-export-fab {
                position: fixed;
                bottom: 24px;
                right: 24px;
                z-index: 9998;
                background: linear-gradient(135deg, #7c3aed 0%, #2563eb 100%);
