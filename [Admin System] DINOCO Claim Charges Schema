/* ═══════════════════════════════════════════════════════════════════════════
 * 3. RETENTION CRON — 90-day purge for cancelled + expired rows
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_charges_cleanup_run' ) ) {
    /**
     * DELETE cancelled + expired rows older than 90 days. Chunked
     * 1000/iter × 20 iterations max (= 20K rows/run cap). Pending /
     * verified / refunded rows are PRESERVED indefinitely — finance
     * audit + PDPA retention require them (refund traceability).
     *
     * Why limited to cancelled+expired:
     *   - cancelled = customer aborted → no money moved → safe to purge
     *   - expired   = 24h timeout reached → no slip uploaded → safe to purge
     *   - verified  = money moved → keep for tax/finance
     *   - refunded  = money moved twice → keep for refund audit
     *   - rejected  = admin rejected slip → keep for fraud forensics
     *
     * @return int Total rows deleted this run
     */
    function dinoco_claim_charges_cleanup_run() {
        global $wpdb;
        $table = dinoco_claim_charges_table_name();

        // Defensive: table may not exist yet (snippet activated before sync)
        if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $table ) ) ) !== $table ) {
            // Still write heartbeat so Health Monitor sees the cron is alive
            update_option( 'dinoco_cron_claim_charges_cleanup_last_run', current_time( 'mysql' ), false );
            return 0;
        }

        $days = (int) get_option( 'dinoco_claim_charges_retention_days', 90 );
        if ( $days < 30 ) $days = 30;   // Floor — protect against misconfig
        if ( $days > 365 ) $days = 365; // Ceiling

        $total_deleted = 0;
        $max_iters     = 20;
        try {
            for ( $i = 0; $i < $max_iters; $i++ ) {
                // V.0.3 Sprint 12 SEC-M3 fix — explicit ORDER BY created_at ASC
                // for deterministic + replication-safe row selection. Without it,
                // MySQL is free to pick any rows matching the WHERE clause →
                // statement-based replication can diverge between primary+replica.
                // Combined with new idx_status_created (DB-C1), this query becomes
                // index-only (no filesort).
                $deleted = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$table}
                      WHERE status IN ('cancelled','expired')
                        AND created_at < DATE_SUB(NOW(), INTERVAL %d DAY)
                      ORDER BY created_at ASC
                      LIMIT 1000",
                    $days
                ) );
                if ( ! $deleted || $deleted === false ) break;
                $total_deleted += (int) $deleted;
                if ( $deleted < 1000 ) break;
                usleep( 50000 ); // 50ms gap — let other queries breathe
            }
        } catch ( \Throwable $e ) {
            error_log( '[DINOCO_CLAIM_CHARGES] cleanup exception: ' . $e->getMessage() );
        } finally {
            // R12 pattern: heartbeat in `finally` so Health Monitor sees a
            // cron run even when an exception aborts the loop midway.
            update_option( 'dinoco_cron_claim_charges_cleanup_last_run', current_time( 'mysql' ), false );
        }

        // Sprint 15 M4 — also purge expired refund_approvals rows.
        // Consent tokens are short-lived audit trail (default 15min TTL);
        // 7-day retention is plenty for forensics. Chunked + ORDER BY id ASC
        // for replication safety.
        $approvals_deleted = 0;
        if ( function_exists( 'dinoco_claim_refund_approvals_table_name' ) ) {
            $atable = dinoco_claim_refund_approvals_table_name();
            if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $atable ) ) ) === $atable ) {
                try {
                    for ( $i = 0; $i < 20; $i++ ) {
                        // V.0.5 Sprint 16 H1 fix — was `WHERE expires_at < N
                        // DAY` only — consumed (successful) tokens with TTL
                        // 15min sat in table forever, growing unbounded. Now
                        // also purges rows where consumed_at is older than
                        // 7 days. Both branches use ORDER BY id ASC for
                        // replication-safe row selection.
                        $deleted = $wpdb->query(
                            "DELETE FROM {$atable}
                              WHERE expires_at < DATE_SUB(NOW(), INTERVAL 7 DAY)
                                 OR consumed_at < DATE_SUB(NOW(), INTERVAL 7 DAY)
                              ORDER BY id ASC
                              LIMIT 1000"
                        );
                        if ( ! $deleted || $deleted === false ) break;
                        $approvals_deleted += (int) $deleted;
                        if ( $deleted < 1000 ) break;
                        usleep( 50000 );
                    }
                } catch ( \Throwable $e ) {
                    error_log( '[DINOCO_CLAIM_CHARGES] refund_approvals cleanup exception: ' . $e->getMessage() );
                }
            }
        }

        if ( $total_deleted > 0 || $approvals_deleted > 0 ) {
            update_option( 'dinoco_claim_charges_cleanup_last_run', array(
                'ran_at'             => current_time( 'mysql' ),
                'deleted'            => $total_deleted,
                'approvals_deleted'  => $approvals_deleted,
                'days'               => $days,
            ), false );
        }

        return $total_deleted + $approvals_deleted;
    }
}

if ( ! wp_next_scheduled( 'dinoco_claim_charges_cleanup_cron' ) ) {
    // V.0.2 Sprint 11 HIGH-1 fix — moved 03:30 → 03:45 to avoid contention.
    // Canonical DINOCO cron stagger schedule (cf. SN Manager line 12416):
    //   02:00 LTV recompute      · 02:05 expiry reminder      · 02:10 anniversary
    //   02:15 review request     · 02:20 forecast              · 03:00 flag audit retention
    //   03:15 idempotency cleanup · 03:30 GDPR/B2B/SN cleanup (4 crons)
    //   03:35 SN orphan claim scan · 03:45 [THIS]              · 03:55 SN audit pepper
    // 03:30 slot was over-allocated (GDPR + B2B slip-pool + SN audit retention +
    // SN orphan_claim_scan) — adding 5th cleanup there caused lock-wait risk on
    // the same MySQL instance. 03:45 falls between SN orphan + SN audit pepper.
    $first_run = strtotime( 'tomorrow 03:45' );
    if ( ! $first_run ) $first_run = time() + DAY_IN_SECONDS;
    wp_schedule_event( $first_run, 'daily', 'dinoco_claim_charges_cleanup_cron' );
}

