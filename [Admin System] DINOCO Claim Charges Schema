 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_claim_charges_schema_install' ) ) {
    /**
     * Install wp_dinoco_claim_charges table via dbDelta. Idempotent —
     * tracks version in wp_option 'dinoco_claim_charges_schema_version'.
     *
     * Schema rationale (mirrors spec §3.1 V.2.2):
     *   - id BIGINT UNSIGNED — surrogate PK
     *   - claim_id BIGINT UNSIGNED NOT NULL — FK to wp_posts (claim_ticket)
     *   - user_id BIGINT UNSIGNED NOT NULL — FK to wp_users (customer)
     *   - amount_thb DECIMAL(12,2) NOT NULL — Thai baht precision (avoid float)
     *   - reason VARCHAR(32) NOT NULL — whitelist enforced by PHP handler
     *   - reason_note VARCHAR(500) — free-form admin annotation
     *   - status VARCHAR(24) — state machine column (NOT ENUM — ALTER-friendly)
     *   - bank_* columns — IMMUTABLE snapshot at INSERT (see spec §6.4)
     *   - slip_image_url VARCHAR(500) — short LINE/CDN URL fits
     *   - slip_ref_hash CHAR(64) — SHA256 hex; UNIQUE prevents replay
     *   - slip_verify_data LONGTEXT — full Slip2Go response JSON
     *   - payment_ref VARCHAR(64) — public-facing token (CLM-CHG-0001-7f3a)
     *   - verified_at / verified_by — admin approval audit
     *   - refund_* — 4-eyes audit (refund_approver_id = second approver)
     *   - expires_at DATETIME NOT NULL — 24h default (set by handler)
     *   - created_at / created_by — INSERT-time audit
     *
     *   - 4 KEY indexes:
     *       idx_claim          — admin "all charges for claim N"
     *       idx_user_status    — customer LIFF "my pending charges"
     *       idx_status_expires — expiry cron sweep WHERE status=pending_payment
     *                            AND expires_at < NOW()
     *       idx_created        — chronological audit
     *   - 1 UNIQUE: uq_slip_replay_claim (slip_ref_hash) — spec §6.4 lines 805–816
     *     namespace scoping: Phase 2.2 handler MUST compute hash as
     *       sha256("{$bank_context}::{$trans_ref}::{$datetime}::{$amount}::{$bank_code_prefix}")
     *     where:
     *       - $bank_context     = 'claim' OR 'claim_walkin' (cross-bucket replay defense)
     *       - $trans_ref        = Slip2Go trans_ref (deterministic per slip)
     *       - $datetime         = Slip2Go datetime (deterministic per slip, NOT request epoch)
     *       - $amount           = charge amount THB
     *       - $bank_code_prefix = first 3 chars of bank_code
     *     Avoids collisions with Extension Marketplace's slip_ref_hash UNIQUE
     *     constraint (parallel feature). NOTE: V.0.1 header comment incorrectly
     *     suggested "$img_sha + $amount + $ts" — corrected V.0.2 (Sprint 11 MED-3).
     *
     * CHECK constraints (MySQL 8.0.16+ / MariaDB 10.2.1+ only — silently
     * skipped on lower versions per b2f_audit_check_mysql_version pattern):
     *   chk_amount_positive    — amount_thb > 0
     *   chk_reason_whitelist   — reason IN (4 values)
     *   chk_status_whitelist   — status IN (7 values)
     * PHP validator in future Phase 2.2 handler is the PRIMARY defense.
     * Constraints are defense-in-depth only.
     *
     * @return void
     */
    function dinoco_claim_charges_schema_install() {
        global $wpdb;

        $current = get_option( 'dinoco_claim_charges_schema_version', '0' );
        $target  = DINOCO_CLAIM_CHARGES_SCHEMA_VERSION;
        if ( $current === $target ) return;

        $table   = dinoco_claim_charges_table_name();
        $charset = $wpdb->get_charset_collate();

        // dbDelta-compatible DDL.
        // NOTE: dbDelta is fussy — two spaces between PRIMARY KEY and (col),
        // each KEY on its own line, no trailing commas.
        // V.0.3 Sprint 12 schema-audit fixes:
        //   DB-H1: utf8mb4_bin column overrides on case-sensitive identifier columns
        //          (slip_ref_hash SHA256 hex, payment_ref CLM-CHG-NNNN, bank_code,
        //          bank_account) — mirrors wp_dinoco_products.sku convention.
        //   DB-H2: amount_thb DECIMAL(12,2) → DECIMAL(14,2) — B2B parity (avoids
        //          implicit type-conversion on JOIN with _b2b_order_total).
        //   DB-C1: NEW idx_status_created (status, created_at) — retention cron
        //          query `WHERE status IN ('cancelled','expired') AND created_at<…`
        //          cannot use idx_status_expires (different columns). At 100k rows
        //          previous index plan = full scan + filesort every 03:45.
        //   DB-M1: slip_verify_data LONGTEXT → MEDIUMTEXT (Slip2Go JSON ~2-5KB).
        //   DB-C2: uq_slip_replay_claim explicitly NULL-tolerant — MySQL treats
        //          multiple NULLs as distinct, so replay defense activates only
        //          AFTER slip submission. Comment annotates the intentional gap.
        // Sprint 15 H2 — amount_thb_at_create immutable snapshot at INSERT.
        // 4-eyes threshold reads this column (not amount_thb) so attacker who
        // mutates amount_thb (via direct DB or future admin-edit endpoint)
        // cannot bypass the ≥฿5K consent flow. PHP handler (Phase 2.6) MUST
        // mirror amount_thb = amount_thb_at_create at INSERT time; refund
        // handler asserts equality (else 422 amount_drift_detected).
        $sql = "CREATE TABLE {$table} (
            id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
            claim_id BIGINT(20) UNSIGNED NOT NULL,
            user_id BIGINT(20) UNSIGNED NOT NULL,
            amount_thb DECIMAL(14,2) NOT NULL,
            amount_thb_at_create DECIMAL(14,2) NOT NULL,
            reason VARCHAR(32) NOT NULL,
            reason_note VARCHAR(500) DEFAULT NULL,
            status VARCHAR(24) NOT NULL DEFAULT 'pending_payment',
            bank_code VARCHAR(16) COLLATE utf8mb4_bin DEFAULT NULL,
            bank_account VARCHAR(32) COLLATE utf8mb4_bin DEFAULT NULL,
            bank_holder VARCHAR(128) DEFAULT NULL,
            bank_name VARCHAR(64) DEFAULT NULL,
            bank_branch VARCHAR(64) DEFAULT NULL,
            bank_context VARCHAR(16) DEFAULT 'claim',
            slip_image_url VARCHAR(500) DEFAULT NULL,
            slip_ref_hash CHAR(64) COLLATE utf8mb4_bin DEFAULT NULL,
            slip_verify_data MEDIUMTEXT DEFAULT NULL,
            payment_ref VARCHAR(64) COLLATE utf8mb4_bin NOT NULL,
            verified_at DATETIME DEFAULT NULL,
            verified_by BIGINT(20) UNSIGNED DEFAULT NULL,
            refund_reason VARCHAR(500) DEFAULT NULL,
            refund_approver_id BIGINT(20) UNSIGNED DEFAULT NULL,
            refunded_at DATETIME DEFAULT NULL,
            refunded_by BIGINT(20) UNSIGNED DEFAULT NULL,
            expires_at DATETIME NOT NULL,
            created_at DATETIME NOT NULL,
            created_by BIGINT(20) UNSIGNED NOT NULL,
            PRIMARY KEY  (id),
            KEY idx_claim (claim_id),
            KEY idx_user_status (user_id, status),
            KEY idx_status_expires (status, expires_at),
            KEY idx_status_created (status, created_at),
            KEY idx_created (created_at),
            UNIQUE KEY uq_slip_replay_claim (slip_ref_hash)
        ) {$charset};";

        // Sprint 15 M4 — refund consent tokens table. Forgeable refund_approver_id
        // closed: actor admin A cannot fabricate approver B's consent. Each refund
        // ≥฿5K requires a SINGLE-USE token created by the actual approver via
        // their own authenticated POST /charges/{id}/approve-refund call. Token
        // consumed atomically inside the FSM transition transaction (UPDATE
        // affected_rows=1 invariant); on consume failure → ROLLBACK + 409.
        $approvals_table = dinoco_claim_refund_approvals_table_name();
        $sql_approvals = "CREATE TABLE {$approvals_table} (
            id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
            charge_id BIGINT(20) UNSIGNED NOT NULL,
            approver_user_id BIGINT(20) UNSIGNED NOT NULL,
            consent_token CHAR(64) COLLATE utf8mb4_bin NOT NULL,
            created_at DATETIME NOT NULL,
            expires_at DATETIME NOT NULL,
            consumed_at DATETIME DEFAULT NULL,
            consumed_by_user_id BIGINT(20) UNSIGNED DEFAULT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY uq_consent_token (consent_token),
            KEY idx_charge_approver (charge_id, approver_user_id),
            KEY idx_expires (expires_at)
        ) {$charset};";

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';

        try {
            dbDelta( $sql );
            dbDelta( $sql_approvals );
        } catch ( \Throwable $e ) {
            // Non-throwing — log + bail. Future install attempt will retry.
            error_log( '[DINOCO_CLAIM_CHARGES] dbDelta exception: ' . $e->getMessage() );
            return;
        }

        // ─── Optional CHECK constraints (MySQL 8.0.16+ / MariaDB 10.2.1+) ──
        // Defense-in-depth ONLY — PHP validator in charge create handler
        // (Phase 2.2) is the primary defense. Silent skip on lower versions.
        dinoco_claim_charges_maybe_add_check_constraints( $table );

        update_option( 'dinoco_claim_charges_schema_version', $target, false );
    }
}

if ( ! function_exists( 'dinoco_claim_charges_supports_check_constraints' ) ) {
    /**
     * Probe whether the current MySQL/MariaDB version enforces CHECK
     * constraints. Mirrors b2f_audit_check_mysql_version() pattern but
     * stays defensive (no dep on B2F snippet).
     *
     *   MySQL    8.0.16+  → enforced
     *   MariaDB  10.2.1+  → enforced
     *   Older            → parsed but silently ignored
     *
     * @return bool true if enforced, false otherwise
     */
    function dinoco_claim_charges_supports_check_constraints() {
        global $wpdb;
        $version = (string) $wpdb->get_var( "SELECT VERSION()" );
        $lower   = strtolower( $version );
        $is_mariadb = ( strpos( $lower, 'mariadb' ) !== false );

        if ( ! preg_match( '/^(\d+\.\d+\.\d+)/', $version, $m ) ) {
            return false;
        }
        $v = $m[1];

        if ( $is_mariadb ) {
            return version_compare( $v, '10.2.1', '>=' );
        }
        // MySQL
        return version_compare( $v, '8.0.16', '>=' );
    }
}

if ( ! function_exists( 'dinoco_claim_charges_maybe_add_check_constraints' ) ) {
    /**
     * Apply CHECK constraints if (1) the server supports them AND
     * (2) they are not already present. Each ALTER is gated by an
     * INFORMATION_SCHEMA.CHECK_CONSTRAINTS probe so re-runs are safe.
     *
     * @param string $table Fully prefixed table name
     * @return void
     */
    function dinoco_claim_charges_maybe_add_check_constraints( $table ) {
        global $wpdb;

        if ( ! dinoco_claim_charges_supports_check_constraints() ) {
            // Defense-in-depth not available; PHP validator handles whitelist.
            return;
        }

        // Build reason whitelist literal — must match
        // DINOCO_CLAIM_CHARGES_REASON_WHITELIST exactly.
        $reasons  = explode( ',', DINOCO_CLAIM_CHARGES_REASON_WHITELIST );
        $statuses = explode( ',', DINOCO_CLAIM_CHARGES_STATUS_WHITELIST );

        $reason_list  = "'" . implode( "','", array_map( 'esc_sql', $reasons ) ) . "'";
        $status_list  = "'" . implode( "','", array_map( 'esc_sql', $statuses ) ) . "'";

        $constraints = array(
            'chk_amount_positive'  => "(amount_thb > 0)",
            'chk_reason_whitelist' => "(reason IN ({$reason_list}))",
            'chk_status_whitelist' => "(status IN ({$status_list}))",
            // V.0.5 Sprint 16 C1 fix — was `(amount_thb_at_create > 0)` which
            // only enforced positivity (already covered by chk_amount_positive
            // line ~411) and did NOT enforce the immutability invariant
            // advertised in V.0.4 docstring. Replaced with the actual
            // equality the docstring claims. CHECK fires on every INSERT +
            // UPDATE — compromised admin who mutates amount_thb without
            // also matching amount_thb_at_create is now rejected at DB layer
            // even if PHP drift assertion is bypassed. NOTE: MySQL CHECK
            // semantics — fires on ANY column touched, including UPDATE that
            // sets amount_thb_at_create itself, so a hostile rewrite of
            // BOTH columns to the same wrong value would still pass. Trigger
            // would be stronger but adds DB privilege complexity; this
            // CHECK + PHP drift = adequate defense-in-depth per Sprint 14 spec.
            'chk_amount_snapshot'  => "(amount_thb = amount_thb_at_create)",
        );

        foreach ( $constraints as $name => $clause ) {
            try {
                // INFORMATION_SCHEMA gate: skip if already present
                $exists = $wpdb->get_var( $wpdb->prepare(
                    "SELECT CONSTRAINT_NAME FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS
                     WHERE CONSTRAINT_SCHEMA = DATABASE()
                       AND TABLE_NAME = %s
                       AND CONSTRAINT_NAME = %s
                       AND CONSTRAINT_TYPE = 'CHECK'
                     LIMIT 1",
                    $table,
                    $name
                ) );
                if ( $exists === $name ) continue;

                // Safe to ALTER. Note: identifier interpolation; $clause is
                // string-built from class-internal literals, never user input.
                $wpdb->query( "ALTER TABLE {$table} ADD CONSTRAINT {$name} CHECK {$clause}" );
            } catch ( \Throwable $e ) {
                error_log( '[DINOCO_CLAIM_CHARGES] ADD CONSTRAINT ' . $name . ' exception: ' . $e->getMessage() );
                // Continue — defense-in-depth is best-effort.
            }
        }
    }
}

