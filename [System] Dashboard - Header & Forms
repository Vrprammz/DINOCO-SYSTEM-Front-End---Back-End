    // --- SIDEBAR (MEMBER CARD) DISPLAY ---
    // V.31.1 — Resolve tier badge (boss Q27 R2 — reuse B2B distributor
    // rank_system pattern). Read loyalty_tier from sn_customer_ltv_snapshot
    // then map to B2B rank slug when helper exists. Falls back to default.
    // Defensive: function_exists guards + null-safe rendering everywhere.
    //
    // V.31.6 (2026-05-08) Phase 8 S2 + NH3 — Tooltip + tier ladder progress bar.
    //   Customer didn't understand "ขึ้น Gold ยังไง?". Now: tap badge → popup
    //   shows tier ladder + ฿X to next tier (NH3). Tier thresholds from SN
    //   Manager admin tab: <฿5K Bronze / 5-20K Silver / 20-50K Gold / 50-100K
    //   Platinum / 100K+ Diamond.
    $tier_badge_html = '';
    $tier_progress_html = '';
    $tier_current_slug = '';
    $tier_current_ltv_thb = 0.0;
    if ( function_exists( 'dinoco_sn_get_user_ltv' ) && function_exists( 'dinoco_render_tier_badge' ) ) {
        $ltv_row = dinoco_sn_get_user_ltv( $current_user_id );
        if ( is_object( $ltv_row ) && isset( $ltv_row->loyalty_tier ) ) {
            $tier_slug = (string) $ltv_row->loyalty_tier;
            $tier_current_slug = $tier_slug;
            $tier_current_ltv_thb = isset( $ltv_row->lifetime_value_thb )
                ? (float) $ltv_row->lifetime_value_thb
                : 0.0;
            // Q27 R2 — map LTV tier → equivalent B2B distributor rank
            $rank_map = array(
                'bronze'   => 'standard',
                'silver'   => 'silver',
                'gold'     => 'gold',
                'platinum' => 'platinum',
                'diamond'  => 'diamond',
            );
            $b2b_rank = isset( $rank_map[ $tier_slug ] ) ? $rank_map[ $tier_slug ] : $tier_slug;
            if ( function_exists( 'dinoco_b2b_rank_label' ) && function_exists( 'dinoco_b2b_rank_color' ) ) {
                $label = (string) dinoco_b2b_rank_label( $b2b_rank );
                $color = (string) dinoco_b2b_rank_color( $b2b_rank );
                if ( $label !== '' ) {
                    // V.31.6 S2 — wrap badge in clickable button + aria-controls
                    $tier_badge_html = sprintf(
                        '<button type="button" class="dnc-sn-tier-badge dnc-sn-tier-%s" style="background:%s;border:0;cursor:pointer;font-weight:600;color:#fff;" aria-expanded="false" aria-controls="dnc-tier-tooltip" onclick="dncSnToggleTierTooltip(this)" title="กดดูเงื่อนไขขึ้น tier">%s</button>',
                        esc_attr( $tier_slug ),
                        esc_attr( $color ),
                        esc_html( $label )
                    );
                }
            }
            if ( $tier_badge_html === '' ) {
                $tier_badge_html = dinoco_render_tier_badge( $tier_slug );
            }
        }
    }
    // V.31.6 NH3 — Build tier ladder + "฿X to next tier" calculation
    if ( $tier_current_slug !== '' ) {
        $tier_thresholds = array(
            'bronze'   => array( 'min' => 0,      'next' => 5000,   'next_label' => '🥈 Silver' ),
            'silver'   => array( 'min' => 5000,   'next' => 20000,  'next_label' => '🟡 Gold' ),
            'gold'     => array( 'min' => 20000,  'next' => 50000,  'next_label' => '💜 Platinum' ),
            'platinum' => array( 'min' => 50000,  'next' => 100000, 'next_label' => '💎 Diamond' ),
            'diamond'  => array( 'min' => 100000, 'next' => null,   'next_label' => '' ),
        );
        $curr_info  = $tier_thresholds[ $tier_current_slug ] ?? null;
        if ( $curr_info ) {
            if ( $curr_info['next'] === null ) {
                // Already at top tier
                $next_html = '<div style="text-align:center;color:#7c3aed;font-weight:700;font-size:14px;margin-top:8px;">🎉 คุณคือลูกค้า Diamond — สูงสุดแล้ว!</div>';
            } else {
                $remaining = max( 0, (float) $curr_info['next'] - (float) $tier_current_ltv_thb );
                $progress_pct = $curr_info['next'] > $curr_info['min']
                    ? min( 100, max( 0, ( (float) $tier_current_ltv_thb - (float) $curr_info['min'] ) / ( (float) $curr_info['next'] - (float) $curr_info['min'] ) * 100 ) )
                    : 0;
                $next_html = sprintf(
                    '<div style="margin-top:10px;font-size:12px;color:#475569;">อีก <strong style="color:#0f172a;">฿%s</strong> ขึ้น <strong>%s</strong></div>'
                    . '<div style="background:#e2e8f0;border-radius:10px;height:8px;margin-top:6px;overflow:hidden;">'
                    .   '<div style="background:linear-gradient(90deg,#06C755,#10b981);width:%.1f%%;height:100%%;transition:width 0.5s ease;"></div>'
                    . '</div>',
                    number_format( $remaining, 0 ),
                    esc_html( $curr_info['next_label'] ),
                    $progress_pct
                );
            }
