/* ────────────────────────────────────────────────────────────
 * V.31.2 — Q27 R2 defensive B2B rank helpers (inline fallback)
 * ────────────────────────────────────────────────────────────
 * `dinoco_b2b_rank_label` + `dinoco_b2b_rank_color` are referenced by the
 * sidebar tier badge resolver below but were never declared in B2B Snippet 1
 * (only `b2b_rank_label_html` exists in Snippet 11 with a different signature).
 * Without these, the function_exists guard always falls through to the basic
 * `dinoco_render_tier_badge()` and the Q27 R2 spec (gradient + emoji per rank)
 * never renders.
 *
 * Define minimal pure-logic fallbacks here so the existing call site works
 * out-of-the-box. function_exists guards keep us safe if B2B Snippet 1 ever
 * ships canonical implementations later — those will win.
 *
 * Q27 R2 spec (from CLAUDE.md project memory):
 *   standard / silver / gold / platinum / diamond
 *   Labels Thai: ทั่วไป / เงิน / ทอง / แพลทินัม / ไดมอนด์
 *   Colors:
 *     standard #6b7280  silver #94a3b8  gold #ca8a04
 *     platinum #4338ca  diamond linear-gradient(135deg, #6d28d9, #9333ea)
 *   Emojis: 👤 🥈 🥇 💜 💎
 */
if ( ! function_exists( 'dinoco_b2b_rank_label' ) ) {
    function dinoco_b2b_rank_label( $rank ) {
        $rank = is_string( $rank ) ? strtolower( trim( $rank ) ) : '';
        $map = array(
            'standard' => '👤 ทั่วไป',
            'silver'   => '🥈 เงิน',
            'gold'     => '🥇 ทอง',
            'platinum' => '💜 แพลทินัม',
            'diamond'  => '💎 ไดมอนด์',
        );
        return isset( $map[ $rank ] ) ? $map[ $rank ] : '';
    }
}
if ( ! function_exists( 'dinoco_b2b_rank_color' ) ) {
    function dinoco_b2b_rank_color( $rank ) {
        $rank = is_string( $rank ) ? strtolower( trim( $rank ) ) : '';
        $map = array(
            'standard' => '#6b7280',
            'silver'   => '#94a3b8',
            'gold'     => '#ca8a04',
            'platinum' => '#4338ca',
            'diamond'  => 'linear-gradient(135deg, #6d28d9, #9333ea)',
        );
        return isset( $map[ $rank ] ) ? $map[ $rank ] : '';
    }
}

/* ────────────────────────────────────────────────────────────
 * V.31.0 — Notification preferences AJAX handler (boss Q26)
 * 5 wp_usermeta keys; first 3 default ON, last 2 default OFF.
 * ──────────────────────────────────────────────────────────── */
add_action( 'wp_ajax_dinoco_save_notif_prefs', 'dinoco_save_notif_prefs_handler' );
if ( ! function_exists( 'dinoco_save_notif_prefs_handler' ) ) {
    function dinoco_save_notif_prefs_handler() {
        if ( ! is_user_logged_in() ) {
            wp_send_json_error( array( 'msg' => 'not_logged_in' ), 403 );
        }
        $nonce = isset( $_POST['_dnc_notif_nonce'] ) ? sanitize_text_field( $_POST['_dnc_notif_nonce'] ) : '';
        if ( ! wp_verify_nonce( $nonce, 'dinoco_save_notif_prefs' ) ) {
            wp_send_json_error( array( 'msg' => 'bad_nonce' ), 403 );
        }
        $uid = get_current_user_id();
        // Rate limit
        if ( function_exists( 'dinoco_check_rate_limit_global' ) && ! dinoco_check_rate_limit_global( $uid, 'save_notif_prefs', 2 ) ) {
            wp_send_json_error( array( 'msg' => 'rate_limited' ), 429 );
        }

        // V.31.3 (R4): when LINE Push Governance V.1.0 is synced, route
        // through canonical setter so PDPA §19 audit trail captures every
        // opt-in/out. Backward compat: legacy update_user_meta path runs
        // when Governance not yet synced.
        if ( function_exists( 'dinoco_line_set_user_prefs' ) ) {
            $prefs = array(
                'expiry'      => ! empty( $_POST['notif_expiry'] ),
                'anniversary' => ! empty( $_POST['notif_anniversary'] ),
                'review'      => ! empty( $_POST['notif_review'] ),
                // Legacy form key 'promo' → canonical 'marketing'
                'marketing'   => ! empty( $_POST['notif_promo'] ),
                'opt_out_all' => ! empty( $_POST['notif_opt_out_all'] ),
            );
            dinoco_line_set_user_prefs( $uid, $prefs );
            // 'service' kept on legacy meta key (not yet a canonical category)
            $service_val = ! empty( $_POST['notif_service'] ) ? '1' : '0';
            update_user_meta( $uid, 'dinoco_sn_notif_service', $service_val );
        } else {
            // V.31.2 legacy path
            $keys = array( 'expiry', 'anniversary', 'review', 'promo', 'service' );
            foreach ( $keys as $k ) {
                $val = ! empty( $_POST[ 'notif_' . $k ] ) ? '1' : '0';
                update_user_meta( $uid, 'dinoco_sn_notif_' . $k, $val );
            }
            // Nuclear opt-out — same key whether Governance loaded or not
            $opt_out_all = ! empty( $_POST['notif_opt_out_all'] ) ? '1' : '0';
            update_user_meta( $uid, 'dinoco_line_opt_out_all', $opt_out_all );
        }

        // Per-user quiet hours override (HH:MM 24h Asia/Bangkok). Empty
        // value clears override → governance falls back to admin defaults.
        $qstart = isset( $_POST['quiet_start'] ) ? sanitize_text_field( $_POST['quiet_start'] ) : '';
        $qend   = isset( $_POST['quiet_end'] )   ? sanitize_text_field( $_POST['quiet_end'] )   : '';
        $valid_hhmm = function( $s ) {
            return $s === '' || preg_match( '/^\d{1,2}:\d{2}$/', $s );
        };
        if ( $valid_hhmm( $qstart ) ) {
            update_user_meta( $uid, 'dinoco_sn_quiet_hours_start', $qstart );
        }
        if ( $valid_hhmm( $qend ) ) {
            update_user_meta( $uid, 'dinoco_sn_quiet_hours_end', $qend );
        }

        wp_send_json_success( array( 'msg' => 'saved' ) );
    }
}

