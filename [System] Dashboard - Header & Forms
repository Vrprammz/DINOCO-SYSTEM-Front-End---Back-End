    function dincocNotifToggle(){
        var box = document.getElementById('dnc-sn-notif-settings');
        if(!box) return;
        var open = box.getAttribute('data-open') === '1';
        box.setAttribute('data-open', open ? '0' : '1');
        var hdr = box.querySelector('.dnc-sn-notif-header');
        if(hdr) hdr.setAttribute('aria-expanded', open ? 'false' : 'true');
    }
    function dincocNotifSave(){
        var box = document.getElementById('dnc-sn-notif-settings');
        var status = document.getElementById('dnc-sn-notif-status');
        if(!box) return;
        var fd = new FormData();
        fd.append('action','dinoco_save_notif_prefs');
        fd.append('_dnc_notif_nonce', window.DNC_SN_NOTIF_NONCE || '');
        ['expiry','anniversary','review','promo','service'].forEach(function(k){
            var el = box.querySelector('input[name="notif_'+k+'"]');
            if(el && el.checked) fd.append('notif_'+k,'1');
        });
        // V.31.3 — nuclear opt-out + quiet hours
        var optOutEl = box.querySelector('input[name="notif_opt_out_all"]');
        if(optOutEl && optOutEl.checked) fd.append('notif_opt_out_all','1');
        var qsEl = box.querySelector('input[name="quiet_start"]');
        var qeEl = box.querySelector('input[name="quiet_end"]');
        if(qsEl) fd.append('quiet_start', qsEl.value || '');
        if(qeEl) fd.append('quiet_end', qeEl.value || '');
        if(status){ status.textContent = 'กำลังบันทึก…'; status.style.color = '#94a3b8'; }
        fetch(window.DNC_SN_AJAX_URL || '/wp-admin/admin-ajax.php', { method:'POST', credentials:'same-origin', body: fd })
            .then(function(r){ return r.json().catch(function(){ return { success:false }; }); })
            .then(function(j){
                if(j && j.success){
                    if(status){ status.textContent = '✓ บันทึกเรียบร้อย'; status.style.color = '#06C755'; }
                } else {
                    var msg = (j && j.data && j.data.msg) ? j.data.msg : 'ผิดพลาด';
                    if(status){ status.textContent = '✗ ' + msg; status.style.color = '#ef4444'; }
                }
            })
            .catch(function(){ if(status){ status.textContent = '✗ Network error'; status.style.color = '#ef4444'; } });
    }
    // V.31.0 — Scan-first lazy load + start camera. Reuses startQR() from
    // Global App Menu when available (P02 dedup); else loads html5-qrcode CDN.
    function dinocoScanFirstQr(){
        if (typeof window.startQR === 'function') { try { window.startQR(); return; } catch(e){} }
        if (typeof Html5Qrcode !== 'undefined' && typeof window.startQR === 'function') {
            try { window.startQR(); return; } catch(e){}
        }
        // Lazy load CDN as last resort, then call startQR if present
        var s = document.createElement('script');
        s.src = 'https://unpkg.com/html5-qrcode';
        s.async = true;
        s.onload = function(){
            if (typeof window.startQR === 'function') { try { window.startQR(); } catch(e){} }
            else { window.location.href = '/scan-qr'; }
        };
        s.onerror = function(){ window.location.href = '/scan-qr'; };
        document.head.appendChild(s);
    }
    </script>
    
