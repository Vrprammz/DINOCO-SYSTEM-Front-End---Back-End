<?xml version="1.0"?>
<!--
    DINOCO Integration Test Config (Phase 5).

    Separate from phpunit.xml.dist because PHPUnit doesn't support
    per-testsuite bootstrap. Boots wordpress-develop test suite via
    tests/integration/bootstrap.php — requires WP_TESTS_DIR env var
    pointing to a wordpress-develop checkout.

    PHPUnit 9 schema (cacheResultFile + <coverage>) — WordPress's test
    suite uses parseTestMethodAnnotations() which was removed in PHPUnit 10.

    Run with: composer test:integration
    See: docs/runbooks/TESTING-PHASE-5.md
-->
<phpunit
    bootstrap="tests/integration/bootstrap.php"
    colors="true"
    testdox="true"
    cacheResultFile=".phpunit.integration.result.cache"
    beStrictAboutOutputDuringTests="false"
    beStrictAboutTestsThatDoNotTestAnything="true"
    failOnRisky="false"
    failOnWarning="false"
    convertDeprecationsToExceptions="false">
    <testsuites>
        <testsuite name="DINOCO Integration">
            <directory>tests/integration</directory>
            <exclude>tests/integration/bootstrap.php</exclude>
            <exclude>tests/integration/DinocoIntegrationTestCase.php</exclude>
            <exclude>tests/integration/snippet-loader.php</exclude>
            <exclude>tests/integration/fixtures</exclude>
        </testsuite>
    </testsuites>
    <coverage>
        <include>
            <directory>tests/integration</directory>
        </include>
        <exclude>
            <directory>tests/integration/fixtures</directory>
        </exclude>
    </coverage>
</phpunit>
