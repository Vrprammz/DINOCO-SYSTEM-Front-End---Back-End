#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════
# DINOCO Regression Guard — pre-push git hook V.1.0
#
# Blocks push if critical regression scenarios fail.
# Only runs if chatbot-related files changed.
#
# To override (emergency only): git push --no-verify
# ═══════════════════════════════════════════════════════════
set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Paths that matter to chatbot regression
WATCH_PATHS=(
  "openclawminicrm/proxy/modules/ai-chat.js"
  "openclawminicrm/proxy/modules/shared.js"
  "openclawminicrm/proxy/modules/dinoco-tools.js"
  "openclawminicrm/proxy/modules/claim-flow.js"
  "openclawminicrm/proxy/modules/lead-pipeline.js"
  "openclawminicrm/proxy/modules/dinoco-cache.js"
  "openclawminicrm/docs/chatbot-rules.md"
)

# Check if any watched files changed in the push
# Use @{upstream} if available, else HEAD~10
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
if [ -n "$UPSTREAM" ]; then
  CHANGED=$(git diff --name-only "$UPSTREAM"..HEAD 2>/dev/null || git diff --name-only HEAD~10..HEAD 2>/dev/null || true)
else
  CHANGED=$(git diff --name-only HEAD~10..HEAD 2>/dev/null || true)
fi

SHOULD_RUN=0
for path in "${WATCH_PATHS[@]}"; do
  if echo "$CHANGED" | grep -qF "$path"; then
    SHOULD_RUN=1
    break
  fi
done

if [ "$SHOULD_RUN" -eq 0 ]; then
  echo -e "${GREEN}[regression-guard]${NC} No chatbot files changed — skipping gate."
  exit 0
fi

echo -e "${YELLOW}[regression-guard]${NC} Chatbot files changed — running critical scenarios..."

# Check agent container is running
if ! docker ps --format '{{.Names}}' 2>/dev/null | grep -qE 'dinoco-agent|smltrack-agent|agent'; then
  echo -e "${YELLOW}[regression-guard] WARNING:${NC} Agent container not running locally — skipping gate."
  echo -e "${YELLOW}[regression-guard]${NC} Start with: docker compose up -d agent"
  echo -e "${YELLOW}[regression-guard]${NC} Continuing push without gate (agent unavailable)"
  exit 0
fi

# Detect agent container name
AGENT_CONTAINER=$(docker ps --format '{{.Names}}' | grep -E 'dinoco-agent|smltrack-agent' | head -1)
if [ -z "$AGENT_CONTAINER" ]; then
  AGENT_CONTAINER="agent"
fi

# Run regression gate inside the agent container
if docker exec "$AGENT_CONTAINER" node /app/scripts/regression.js --mode=gate --severity=critical --triggered-by=pre-push; then
  echo -e "${GREEN}[regression-guard] GATE PASSED${NC} — push allowed."
  exit 0
else
  EXIT_CODE=$?
  echo ""
  echo -e "${RED}[regression-guard] GATE FAILED${NC} — push blocked."
  echo ""
  echo "Fix the failing critical scenarios above, then retry:"
  echo "  git push"
  echo ""
  echo "Emergency override (not recommended):"
  echo "  git push --no-verify"
  exit "$EXIT_CODE"
fi
