/* ═══════════════════════════════════════════════════════════════════════════
 * 5. PNG RENDERER — for LINE Flex push (image-based receipt)
 *
 * Reuses GD library that's already on the server (per B2B Snippet 10
 * Invoice Image Generator). Outputs A4-portrait 800×1130 px.
 *
 * Defensive: if GD missing → returns empty string + logs warning.
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_receipt_render_png' ) ) {
    /**
     * Render PNG receipt (in-memory) + return base64 data URL.
     * For server-side caching, callers should write to wp_upload_dir().
     *
     * @param int $extension_id
     * @return string PNG binary, or '' on failure
     */
    function dinoco_vat_receipt_render_png( $extension_id ) {
        if ( ! function_exists( 'imagecreatetruecolor' ) ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_gd_missing', array(
                    'extension_id' => $extension_id,
                    'hint'         => 'apt install php-gd or yum install php-gd then restart php-fpm',
                ) );
            }
            return '';
        }
        $d = dinoco_vat_receipt_assemble_data( $extension_id );
        if ( ! $d ) return '';

        $W = 800;
        $H = 1130; // A4 portrait ratio
        $img = imagecreatetruecolor( $W, $H );
        $white = imagecolorallocate( $img, 255, 255, 255 );
        $black = imagecolorallocate( $img, 17, 17, 17 );
        $gray  = imagecolorallocate( $img, 107, 114, 128 );
        $light = imagecolorallocate( $img, 243, 244, 246 );
        $accent = imagecolorallocate( $img, 31, 41, 55 );
        imagefill( $img, 0, 0, $white );

        // Font resolution — try common Thai font paths
        $font = '';
        $candidates = array(
            ABSPATH . 'wp-content/uploads/fonts/Sarabun-Regular.ttf',
            ABSPATH . 'wp-content/uploads/fonts/THSarabunNew.ttf',
            '/usr/share/fonts/truetype/tlwg/Sawasdee.ttf',
            '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf',
        );
        foreach ( $candidates as $cand ) {
            if ( file_exists( $cand ) ) { $font = $cand; break; }
        }
        if ( $font === '' ) {
            imagedestroy( $img );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( 'warning', 'vat_receipt_font_missing', array(
                    'extension_id' => $extension_id,
                    'tried'        => $candidates,
                ) );
            }
            return '';
        }

        $put = function( $size, $x, $y, $color, $text ) use ( $img, $font ) {
            @imagettftext( $img, $size, 0, (int) $x, (int) $y, $color, $font, (string) $text );
        };

        // Header
        $put( 18, 30, 40, $black, $d['company_name'] );
        if ( $d['company_name_en'] !== '' ) {
            $put( 11, 30, 60, $gray, $d['company_name_en'] );
        }
        $put( 10, 30, 82, $black, 'เลขประจำตัวผู้เสียภาษี: ' . $d['tax_id'] . '  สาขา: ' . $d['branch_code'] );
        $put( 10, 30, 100, $black, mb_substr( $d['address'], 0, 80 ) );
        $put( 16, 580, 50, $black, $d['receipt_no'] );
        $put( 10, 580, 70, $gray, (string) $d['receipt_date'] );

        imageline( $img, 30, 115, $W - 30, 115, $black );

        // Title box
        imagefilledrectangle( $img, 30, 130, $W - 30, 175, $light );
        $put( 18, 250, 162, $black, 'ใบกำกับภาษี / ใบเสร็จรับเงิน' );

        // Customer block
        $put( 12, 30, 210, $accent, 'ลูกค้า / Customer' );
        $put( 11, 30, 232, $black, 'ชื่อ: ' . ( $d['customer_name'] ?: '—' ) );
        $put( 11, 30, 252, $black, 'S/N: ' . $d['customer_sn'] );

        // Payment block
        $put( 12, 420, 210, $accent, 'การชำระเงิน / Payment' );
        $put( 11, 420, 232, $black, 'วิธี: ' . $d['payment_method'] );
        $put( 11, 420, 252, $black, 'อ้างอิง: ' . $d['payment_ref'] );

        // Item table
        $top_y = 300;
        imagefilledrectangle( $img, 30, $top_y, $W - 30, $top_y + 30, $light );
        $put( 12, 50,  $top_y + 20, $accent, 'รายการ' );
        $put( 12, 480, $top_y + 20, $accent, 'จำนวน' );
        $put( 12, 580, $top_y + 20, $accent, 'ราคา' );
        $put( 12, 680, $top_y + 20, $accent, 'รวม' );

        $row_y = $top_y + 60;
        $put( 11, 50, $row_y, $black, mb_substr( $d['item_desc'], 0, 55 ) );
        $put( 10, 50, $row_y + 18, $gray, 'SKU: ' . $d['item_sku'] );
        $put( 11, 495, $row_y, $black, (string) $d['item_qty'] );
        $put( 11, 580, $row_y, $black, number_format( $d['subtotal_excl_vat'], 2 ) );
        $put( 11, 680, $row_y, $black, number_format( $d['subtotal_excl_vat'], 2 ) );

        imageline( $img, 30, $row_y + 50, $W - 30, $row_y + 50, $gray );

        // Totals (right-aligned)
        $tot_y = $row_y + 90;
        $put( 12, 450, $tot_y, $gray, 'มูลค่าสินค้า/บริการ (ไม่รวม VAT)' );
        $put( 12, 700, $tot_y, $black, '฿' . number_format( $d['subtotal_excl_vat'], 2 ) );

        $put( 12, 450, $tot_y + 25, $gray, 'ภาษีมูลค่าเพิ่ม ' . number_format( $d['vat_rate'] * 100, 0 ) . '%' );
        $put( 12, 700, $tot_y + 25, $black, '฿' . number_format( $d['vat_amount'], 2 ) );

        imageline( $img, 450, $tot_y + 40, $W - 30, $tot_y + 40, $black );
        $put( 16, 450, $tot_y + 70, $black, 'รวมทั้งสิ้น' );
        $put( 16, 660, $tot_y + 70, $black, '฿' . number_format( $d['grand_total'], 2 ) );

        // Baht text
        if ( $d['grand_total_text'] !== '' ) {
            imagefilledrectangle( $img, 30, $tot_y + 100, $W - 30, $tot_y + 140, $light );
            $put( 11, 50, $tot_y + 126, $black, 'จำนวนเงินตัวอักษร: ' . $d['grand_total_text'] );
        }

        // Footer
        $put( 9, 30, $H - 40, $gray, 'เอกสารฉบับนี้ออกโดยระบบอัตโนมัติ — Generated by DINOCO System' );
        $put( 10, 580, $H - 40, $black, 'ผู้รับเงิน ____________________' );

        ob_start();
        imagepng( $img );
        $png = ob_get_clean();
        imagedestroy( $img );
        return (string) $png;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 6. REST ENDPOINT — GET /dinoco-vat/v1/receipt/{extension_id}
 *
 * Customer can pull their own receipt; admin can pull any.
 * format=html (default) → text/html | format=png → image/png
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_receipt_rest_pull' ) ) {
    function dinoco_vat_receipt_rest_pull( $req ) {
        global $wpdb;
        $extension_id = (int) $req['id'];
        $format = $req->get_param( 'format' ) === 'png' ? 'png' : 'html';

        // Permission: admin can pull any, customer can only pull their own
        $is_admin = current_user_can( 'manage_options' );
        if ( ! $is_admin ) {
            $uid = get_current_user_id();
            if ( $uid <= 0 ) {
                return new WP_Error( 'rest_forbidden', 'login required', array( 'status' => 401 ) );
            }
            $tbl_ext = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'extensions' ) : '';
            $owner = $tbl_ext ? (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT user_id FROM {$tbl_ext} WHERE id = %d LIMIT 1", $extension_id
            ) ) : 0;
            if ( $owner !== $uid ) {
                return new WP_Error( 'rest_forbidden', 'not owner', array( 'status' => 403 ) );
            }
        }

        $eligible = dinoco_vat_receipt_extension_is_eligible( $extension_id );
        if ( ! $eligible['eligible'] ) {
            return new WP_Error( 'not_eligible', 'Receipt not available: ' . $eligible['reason'],
                array( 'status' => 409, 'reason' => $eligible['reason'] ) );
        }

        if ( $format === 'png' ) {
            $png = dinoco_vat_receipt_render_png( $extension_id );
            if ( $png === '' ) {
                return new WP_Error( 'render_failed', 'PNG renderer failed (check GD + font)',
                    array( 'status' => 500 ) );
            }
            // Stream PNG directly (bypass REST envelope)
            header( 'Content-Type: image/png' );
            header( 'Content-Disposition: inline; filename="receipt-' .
                dinoco_vat_receipt_generate_receipt_no( $extension_id ) . '.png"' );
            echo $png;
            exit;
        }

        // HTML default — stream as text/html
        $html = dinoco_vat_receipt_render_html( $extension_id );
        if ( $html === '' ) {
            return new WP_Error( 'render_failed', 'HTML renderer failed', array( 'status' => 500 ) );
        }
        header( 'Content-Type: text/html; charset=utf-8' );
        echo $html;
        exit;
    }
}

add_action( 'rest_api_init', function() {
    register_rest_route( 'dinoco-vat/v1', '/receipt/(?P<id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_vat_receipt_rest_pull',
        'permission_callback' => '__return_true', // permission enforced inside callback (owner-or-admin)
        'args'                => array(
            'id'     => array( 'sanitize_callback' => 'absint' ),
            'format' => array( 'default' => 'html' ),
        ),
    ) );

    // Admin-only diagnostic: check if a receipt can be generated
    register_rest_route( 'dinoco-vat/v1', '/check/(?P<id>\d+)', array(
        'methods'             => 'GET',
        'callback'            => function( $req ) {
            $id = (int) $req['id'];
            $eligibility = dinoco_vat_receipt_extension_is_eligible( $id );
            $data = $eligibility['eligible'] ? dinoco_vat_receipt_assemble_data( $id ) : null;
            return rest_ensure_response( array(
                'extension_id' => $id,
                'eligibility'  => $eligibility,
                'receipt_no'   => dinoco_vat_receipt_generate_receipt_no( $id ),
                'data_present' => $data !== null,
                'vat_ready'    => function_exists( 'dinoco_vat_is_ready' ) ? dinoco_vat_is_ready() : null,
            ) );
        },
        'permission_callback' => function() {
            return current_user_can( 'manage_options' );
        },
    ) );
} );
