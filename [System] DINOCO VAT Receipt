/* ═══════════════════════════════════════════════════════════════════════════
 * 1. RECEIPT NUMBER GENERATOR — EXT-YYMM-XXXX format
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_receipt_generate_receipt_no' ) ) {
    /**
     * Generate stable receipt number from extension_id + paid_at.
     * Format: EXT-{YYMM}-{padded-extension-id}
     * Example: EXT-2605-0001234
     *
     * Receipt number is deterministic from extension_id — same ID always
     * produces same number. Safe for re-print scenarios.
     *
     * @param int $extension_id
     * @return string
     */
    function dinoco_vat_receipt_generate_receipt_no( $extension_id ) {
        global $wpdb;
        $extension_id = (int) $extension_id;
        if ( $extension_id <= 0 ) return '';

        $tbl = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'extensions' ) : '';
        if ( $tbl === '' ) return 'EXT-XXXX-' . str_pad( (string) $extension_id, 7, '0', STR_PAD_LEFT );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT paid_at, created_at FROM {$tbl} WHERE id = %d LIMIT 1",
            $extension_id
        ) );
        if ( ! $row ) return '';

        // Prefer paid_at (when finalized), fallback created_at
        $ts_str = ! empty( $row->paid_at ) ? $row->paid_at : $row->created_at;
        $ts = strtotime( (string) $ts_str );
        if ( ! $ts ) $ts = time();

        $yymm = gmdate( 'ym', $ts );
        return 'EXT-' . $yymm . '-' . str_pad( (string) $extension_id, 7, '0', STR_PAD_LEFT );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. CONTEXT VALIDATION — is this order VAT-eligible?
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_receipt_extension_is_eligible' ) ) {
    /**
     * Returns array { eligible: bool, reason: string }.
     * SN extensions stored in wp_dinoco_sn_extensions custom table — by
     * definition all are B2C marketplace context. Eligibility requires:
     *   1. Extension exists + payment_status = 'paid'
     *   2. VAT settings ready (tax_id + company_name + address)
     *
     * @param int $extension_id
     * @return array
     */
    function dinoco_vat_receipt_extension_is_eligible( $extension_id ) {
        global $wpdb;
        $extension_id = (int) $extension_id;
        $tbl = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'extensions' ) : '';
        if ( $tbl === '' ) {
            return array( 'eligible' => false, 'reason' => 'sn_extensions_schema_missing' );
        }
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT payment_status FROM {$tbl} WHERE id = %d LIMIT 1",
            $extension_id
        ) );
        if ( ! $row ) {
            return array( 'eligible' => false, 'reason' => 'extension_not_found' );
        }
        if ( $row->payment_status !== 'paid' ) {
            return array( 'eligible' => false, 'reason' => 'not_paid', 'status' => $row->payment_status );
        }
        if ( function_exists( 'dinoco_vat_is_ready' ) && ! dinoco_vat_is_ready() ) {
            return array( 'eligible' => false, 'reason' => 'vat_settings_incomplete' );
        }
        return array( 'eligible' => true, 'reason' => 'ok' );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 3. RECEIPT DATA ASSEMBLER — single source of truth for both HTML + PNG
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_receipt_assemble_data' ) ) {
    /**
     * Pulls all data needed to render a receipt — extension row + customer
     * info + product info + VAT settings. Returns null if not renderable.
     *
     * @param int $extension_id
     * @return array|null
     */
    function dinoco_vat_receipt_assemble_data( $extension_id ) {
        global $wpdb;
        $extension_id = (int) $extension_id;
        if ( $extension_id <= 0 ) return null;

        $eligible = dinoco_vat_receipt_extension_is_eligible( $extension_id );
        if ( ! $eligible['eligible'] ) return null;

        $tbl_ext  = dinoco_sn_table( 'extensions' );
        $tbl_pool = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'pool' ) : '';

        $ext = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$tbl_ext} WHERE id = %d LIMIT 1", $extension_id
        ) );
        if ( ! $ext ) return null;

        // Customer info from sn_pool (registered owner) + WP user
        $pool = null;
        $sn = strtoupper( (string) $ext->sn );
        if ( $tbl_pool !== '' ) {
            $pool = $wpdb->get_row( $wpdb->prepare(
                "SELECT registered_user_id, linked_sku FROM {$tbl_pool} WHERE sn = %s LIMIT 1",
                $sn
            ) );
        }

        $customer_name = '';
        $customer_uid  = 0;
        if ( $pool && (int) $pool->registered_user_id > 0 ) {
            $customer_uid = (int) $pool->registered_user_id;
            $u = get_userdata( $customer_uid );
            if ( $u ) {
                $customer_name = trim( $u->display_name ?: ( $u->first_name . ' ' . $u->last_name ) );
                if ( $customer_name === '' ) $customer_name = $u->user_login;
            }
        }

        // Product info via SET-context aware resolver (V.0.53 helper)
        $renewable_sku = '';
        $product_name  = '';
        $plate_count   = 1;
        if ( $pool && function_exists( 'dinoco_sn_get_renewable_sku' ) ) {
            $renewable_sku = strtoupper( (string) dinoco_sn_get_renewable_sku( $pool ) );
        } elseif ( $pool ) {
            $renewable_sku = strtoupper( (string) ( $pool->linked_sku ?? '' ) );
        }
        if ( $renewable_sku !== '' && class_exists( 'DINOCO_Catalog' ) ) {
            $prod = DINOCO_Catalog::get_by_sku( $renewable_sku );
            if ( $prod && isset( $prod->title ) ) $product_name = (string) $prod->title;
        }
        if ( function_exists( 'dinoco_sn_get_renewable_plate_count' ) && $pool ) {
            $plate_count = (int) dinoco_sn_get_renewable_plate_count( $pool );
        }
        if ( $plate_count < 1 ) $plate_count = 1;

        // Pricing breakdown
        // V.1.0 — extension table stores price_paid as final amount (already
        // discount-applied). For VAT receipt we display the gross amount + VAT
        // breakdown. Assumption: price_paid is VAT-inclusive (consistent with
        // Thai retail). subtotal_excl_vat = price_paid / (1 + vat_rate).
        $rate = (float) dinoco_vat_get( 'rate', '0.07' );
        if ( $rate < 0 || $rate > 1 ) $rate = 0.07;
        $grand_total      = (float) $ext->price_paid;
        $subtotal_excl    = $rate > 0 ? round( $grand_total / ( 1 + $rate ), 2 ) : $grand_total;
        $vat_amount       = round( $grand_total - $subtotal_excl, 2 );

        $years = (int) max( 1, round( ( (int) $ext->extension_months ) / 12 ) );
        $item_desc = sprintf(
            'ต่ออายุประกัน %d ปี — %s%s',
            $years,
            $product_name !== '' ? $product_name : ( '— ' . $renewable_sku ),
            $plate_count > 1 ? sprintf( ' (ชุด %d ชิ้น)', $plate_count ) : ''
        );

        return array(
            'receipt_no'       => dinoco_vat_receipt_generate_receipt_no( $extension_id ),
            'receipt_date'     => ! empty( $ext->paid_at ) ? $ext->paid_at : $ext->created_at,
            'extension_id'     => $extension_id,
            // Company (issuer)
            'company_name'     => (string) dinoco_vat_get( 'company_name' ),
            'company_name_en'  => (string) dinoco_vat_get( 'company_name_en' ),
            'tax_id'           => (string) dinoco_vat_get( 'tax_id' ),
            'branch_code'      => (string) dinoco_vat_get( 'branch_code', '00000' ),
            'branch_name'      => (string) dinoco_vat_get( 'branch_name', 'สำนักงานใหญ่' ),
            'address'          => (string) dinoco_vat_get( 'address' ),
            'phone'            => (string) dinoco_vat_get( 'phone' ),
            'email'            => (string) dinoco_vat_get( 'email' ),
            'logo_url'         => (string) dinoco_vat_get( 'logo_url' ),
            // Customer
            'customer_name'    => $customer_name,
            'customer_uid'     => $customer_uid,
            'customer_sn'      => $sn,
            // Item
            'item_desc'        => $item_desc,
            'item_sku'         => $renewable_sku,
            'item_qty'         => 1,
            'item_years'       => $years,
            'item_plate_count' => $plate_count,
            // Totals
            'subtotal_excl_vat'=> $subtotal_excl,
            'vat_rate'         => $rate,
            'vat_amount'       => $vat_amount,
            'grand_total'      => $grand_total,
            'grand_total_text' => function_exists( 'b2b_get_invoice_baht_text' )
                ? b2b_get_invoice_baht_text( $grand_total )
                : '',
            'payment_method'   => (string) $ext->payment_method,
            'payment_ref'      => (string) $ext->payment_ref,
        );
    }
}

