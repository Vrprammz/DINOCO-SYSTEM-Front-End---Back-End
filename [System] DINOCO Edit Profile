    <script>
    (function(){
        // Compress image via canvas (returns Promise<File>)
        function compressImage(file, maxW, maxH, maxBytes, quality) {
            return new Promise(function(resolve) {
                var img = new Image();
                img.onload = function() {
                    var w = img.width, h = img.height;
                    if (w > maxW) { h = h * maxW / w; w = maxW; }
                    if (h > maxH) { w = w * maxH / h; h = maxH; }
                    var c = document.createElement('canvas');
                    c.width = w; c.height = h;
                    c.getContext('2d').drawImage(img, 0, 0, w, h);
                    (function tryQ(q) {
                        c.toBlob(function(blob) {
                            if (blob.size > maxBytes && q > 0.3) {
                                tryQ(q - 0.1);
                            } else {
                                resolve(new File([blob], file.name, { type: 'image/jpeg' }));
                            }
                        }, 'image/jpeg', q);
                    })(quality);
                };
                img.src = URL.createObjectURL(file);
            });
        }

        // Preview + compress avatar
        window.dinocoPreviewImg = function(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];
                // Preview immediately
                var r = new FileReader();
                r.onload = function(e) { document.getElementById('preview_avatar').src = e.target.result; };
                r.readAsDataURL(file);
                // Compress to max 500KB
                compressImage(file, 500, 500, 500 * 1024, 0.85).then(function(compressed) {
                    var dt = new DataTransfer();
                    dt.items.add(compressed);
                    input.files = dt.files;
                });
                // Show save button
                var save = document.getElementById('btn-save-profile');
                if (save) save.classList.add('visible');
            }
        };

        // Preview + compress cover photo
        window.dinocoPreviewCover = function(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];
                // Preview immediately
                var r = new FileReader();
                r.onload = function(e) {
                    var img = document.getElementById('preview_cover');
                    img.src = e.target.result;
                    img.style.display = '';
                };
                r.readAsDataURL(file);
                // Compress to max 500KB, 1200px wide
                compressImage(file, 1200, 600, 500 * 1024, 0.8).then(function(compressed) {
                    var dt = new DataTransfer();
                    dt.items.add(compressed);
                    input.files = dt.files;
                });
                // Show save button
                var save = document.getElementById('btn-save-profile');
                if (save) save.classList.add('visible');
            }
        };

        // Toggle view/edit sections
        var openSections = {};
        window.dinocoToggleEdit = function(section) {
            var view = document.getElementById('view-' + section);
            var edit = document.getElementById('edit-' + section);
            var card = document.getElementById('sec-' + section);
            var btn  = card ? card.querySelector('.d-edit-btn') : null;
            var save = document.getElementById('btn-save-profile');

            if (!view || !edit) return;

            var isOpen = edit.classList.contains('open');
            if (isOpen) {
                edit.classList.remove('open');
                view.style.display = '';
                if (btn) { btn.textContent = 'แก้ไข'; btn.classList.remove('active'); }
                delete openSections[section];
            } else {
                edit.classList.add('open');
                view.style.display = 'none';
                if (btn) { btn.textContent = 'ยกเลิก'; btn.classList.add('active'); }
                openSections[section] = true;
            }

            // Show/hide save button
            var anyOpen = Object.keys(openSections).length > 0;
            if (save) save.classList.toggle('visible', anyOpen);
        };

        // Submit loading state
        var form = document.querySelector('.d-edit-wrap form');
        if (form) {
            form.addEventListener('submit', function(){
                var btn = document.getElementById('btn-save-profile');
                if (btn) { btn.disabled = true; btn.style.opacity = '0.6'; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังบันทึก...'; }
                var loader = document.getElementById('dinoco-loader');
                if (loader) loader.style.display = 'flex';
            });
        }
    })();

    // ย้าย nav ไป body (เผื่อ Elementor ครอบ)
    (function(){
        var nav = document.querySelector('.dinoco-app-nav');
        if (nav && nav.parentElement !== document.body) document.body.appendChild(nav);
    })();

