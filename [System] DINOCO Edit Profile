add_shortcode('dinoco_edit_profile', 'dinoco_edit_profile_v6_manual');

function dinoco_edit_profile_v6_manual() {
    
    // -------------------------------------------------------------------------
    // 1. CHECK LOGIN
    // -------------------------------------------------------------------------
    if (!is_user_logged_in()) {
        return '<div style="text-align:center; padding:40px; color:#ef4444; font-family:\'Noto Sans Thai\', \'Prompt\', sans-serif;">⚠️ กรุณาเข้าสู่ระบบ</div>';
    }

    $current_user = wp_get_current_user();
    $uid = $current_user->ID;
    $msg_status = '';

    // -------------------------------------------------------------------------
    // 2. PROCESS FORM (SAVE DATA WITH VALIDATION)
    // -------------------------------------------------------------------------
    if (isset($_POST['dinoco_update_action']) && wp_verify_nonce($_POST['dinoco_nonce_field'], 'dinoco_update_profile')) {
        
        // --- [LOGIC 1] Prepare Data for Validation ---
        $input_phone = sanitize_text_field($_POST['phone_number']);
        $has_error = false;

        // --- [LOGIC 2] Check Duplicate Phone Number ---
        if (!empty($input_phone)) {
            $users_with_same_phone = get_users([
                'meta_key'   => 'phone_number',
                'meta_value' => $input_phone,
                'exclude'    => [$uid],
                'number'     => 1,
                'fields'     => 'ID'
            ]);

            if (!empty($users_with_same_phone)) {
                $has_error = true;
                $msg_status = '<div class="dinoco-alert error">⛔ เบอร์โทรศัพท์นี้มีผู้ใช้งานแล้ว (Duplicate Phone Number)</div>';
            }
        }

        // --- [LOGIC 3] Proceed to Save (If No Error) ---
        if ($has_error === false) {
            
            // A. Update Core WP Data
            $core_args = [
                'ID'           => $uid,
                'first_name'   => sanitize_text_field($_POST['first_name']),
                'last_name'    => sanitize_text_field($_POST['last_name']),
                'display_name' => sanitize_text_field($_POST['display_name'])
            ];
            wp_update_user($core_args);
            
            // Refresh User Object
            $current_user->first_name   = $core_args['first_name'];
            $current_user->last_name    = $core_args['last_name'];
            $current_user->display_name = $core_args['display_name'];

            // B. Handle Image Upload
            if (!empty($_FILES['user_avatar']['name'])) {
                require_once(ABSPATH . 'wp-admin/includes/image.php');
                require_once(ABSPATH . 'wp-admin/includes/file.php');
                require_once(ABSPATH . 'wp-admin/includes/media.php');
                
                $movefile = wp_handle_upload($_FILES['user_avatar'], ['test_form' => false]);
                
                if ($movefile && !isset($movefile['error'])) {
                    $image_editor = wp_get_image_editor($movefile['file']);
                    if (!is_wp_error($image_editor)) {
                        $image_editor->resize(500, 500, false);
                        $image_editor->set_quality(80);
                        $image_editor->save($movefile['file']);

                        // Delete old avatar file from server (skip LINE URLs)
                        $old_avatar_url = get_user_meta($uid, 'line_picture_url', true);
                        if (!empty($old_avatar_url) && strpos($old_avatar_url, home_url()) === 0) {
                            $upload_dir = wp_upload_dir();
                            $old_avatar_path = str_replace($upload_dir['baseurl'], $upload_dir['basedir'], $old_avatar_url);
                            if (file_exists($old_avatar_path)) {
                                @unlink($old_avatar_path);
                            }
                        }

                        update_user_meta($uid, 'line_picture_url', $movefile['url']);
                    }
                }
            }

            // B2. Handle Cover Photo Upload
            if (!empty($_FILES['user_cover_photo']['name'])) {
                require_once(ABSPATH . 'wp-admin/includes/image.php');
                require_once(ABSPATH . 'wp-admin/includes/file.php');
                require_once(ABSPATH . 'wp-admin/includes/media.php');

                $cover_move = wp_handle_upload($_FILES['user_cover_photo'], ['test_form' => false]);

                if ($cover_move && !isset($cover_move['error'])) {
                    // Resize & compress to max 1200px wide, quality 75
                    $cover_editor = wp_get_image_editor($cover_move['file']);
                    if (!is_wp_error($cover_editor)) {
                        $cover_editor->resize(1200, 600, false);
                        $cover_editor->set_quality(75);
                        $cover_editor->save($cover_move['file']);
                    }

                    // Delete old cover file from server
                    $old_cover_url = get_user_meta($uid, 'user_cover_photo', true);
                    if (!empty($old_cover_url)) {
                        $upload_dir = wp_upload_dir();
                        $old_cover_path = str_replace($upload_dir['baseurl'], $upload_dir['basedir'], $old_cover_url);
                        if (file_exists($old_cover_path)) {
                            @unlink($old_cover_path);
                        }
                    }

                    update_user_meta($uid, 'user_cover_photo', $cover_move['url']);
                }
            }

            // C. Update ACF Meta Fields
            // หมายเหตุ: addr_district และ addr_subdistrict จะรับค่าที่ลูกค้าพิมพ์มาโดยตรง
            $fields_to_save = [
                'phone_number', 'owner_line_id', 'birth_date',
                'addr_house_no', 'addr_soi', 'addr_province', 'addr_district', 'addr_subdistrict', 'addr_zip',
                'user_moto_brand', 'user_moto_model', 'user_moto_year'
            ];

            foreach ($fields_to_save as $field) {
                if (isset($_POST[$field])) {
                    update_user_meta($uid, $field, sanitize_text_field($_POST[$field]));
                }
            }

            $msg_status = '<div class="dinoco-alert success">✅ บันทึกข้อมูลเรียบร้อยแล้ว</div>';
        }
    }

    // -------------------------------------------------------------------------
    // 3. GET EXISTING DATA (PRE-FILL)
    // -------------------------------------------------------------------------
    $phone          = get_user_meta($uid, 'phone_number', true);
    $line_id        = get_user_meta($uid, 'owner_line_id', true);
    $img_url        = get_user_meta($uid, 'line_picture_url', true);
    $birth_date     = get_user_meta($uid, 'birth_date', true);
    
    // Address
    $addr_house     = get_user_meta($uid, 'addr_house_no', true);
    $addr_soi       = get_user_meta($uid, 'addr_soi', true);
    $addr_prov      = get_user_meta($uid, 'addr_province', true);
    $addr_dist      = get_user_meta($uid, 'addr_district', true);     // อำเภอ (User พิมพ์)
    $addr_sub       = get_user_meta($uid, 'addr_subdistrict', true);  // ตำบล (User พิมพ์)
    $addr_zip       = get_user_meta($uid, 'addr_zip', true);
    
    // Moto
    $moto_brand     = get_user_meta($uid, 'user_moto_brand', true);
    $moto_model     = get_user_meta($uid, 'user_moto_model', true);
    $moto_year      = get_user_meta($uid, 'user_moto_year', true);

    if (empty($img_url)) {
        $img_url = 'https://www.dinoco.in.th/wp-content/uploads/elementor/thumbs/800x800-pxou1gkonhphkw4peesozhjgbqhvyueyia1k904zxk.png';
    }

    // --- MEMBER STATS + RANK SYSTEM V2 (Mileage + Product + Activity) ---
    $member_since = $current_user->user_registered;
    $member_days  = max(0, (int) ((time() - strtotime($member_since)) / 86400));
    $loyalty_km   = $member_days * 10;

    // Count owned products (needed for rank calc)
    $owned_count = 0;
    $line_uid = get_user_meta($uid, 'line_user_id', true);
    $owner_key = $current_user->user_login;
    if ($line_uid || $owner_key) {
        $owner_values = array_filter(array($line_uid, $owner_key));
        $owned_count = count(get_posts(array(
            'post_type' => 'serial_number', 'post_status' => 'publish',
            'posts_per_page' => -1, 'fields' => 'ids',
            'meta_query' => array(array('key' => 'owner_product', 'value' => $owner_values, 'compare' => 'IN')),
        )));
    }

    // Count claims
    $claim_count = count(get_posts(array(
        'post_type' => 'claim_ticket', 'post_status' => 'publish',
        'posts_per_page' => -1, 'fields' => 'ids',
        'author' => $uid,
    )));

    // Count transfers (sent)
    $transfer_count = 0;
    if ($owned_count > 0 || true) {
        // Count transfer_logs across all serials this user has touched
        global $wpdb;
        $transfer_count = (int) $wpdb->get_var($wpdb->prepare(
            "SELECT COUNT(*) FROM {$wpdb->postmeta} pm
             JOIN {$wpdb->posts} p ON p.ID = pm.post_id AND p.post_type = 'serial_number'
             WHERE pm.meta_key = 'transfer_logs' AND pm.meta_value LIKE %s",
            '%' . $wpdb->esc_like($owner_key ?: $line_uid ?: '___none___') . '%'
        ));
    }

    // Collect owned SKUs for set completion check
    $owned_skus = array();
    if ($line_uid || $owner_key) {
        $sku_posts = get_posts(array(
            'post_type' => 'serial_number', 'post_status' => 'publish',
            'posts_per_page' => 50, 'fields' => 'ids',
            'meta_query' => array(array('key' => 'owner_product', 'value' => array_filter(array($line_uid, $owner_key)), 'compare' => 'IN')),
        ));
        foreach ($sku_posts as $sp_id) {
            $sku_val = get_post_meta($sp_id, 'product_sku', true);
            if ($sku_val) $owned_skus[] = strtoupper(trim($sku_val));
        }
        $owned_skus = array_unique($owned_skus);
    }

    // SKU set completion check — ถ้ามี SKU ครบตาม dinoco_sku_relations → set bonus
    $sku_relations = get_option('dinoco_sku_relations', array());
    $completed_sets = 0;
    $set_names = array();
    $catalog_for_name = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
    foreach ($sku_relations as $parent_sku => $children) {
        if (!is_array($children) || empty($children)) continue;
        $children_upper = array_map(function($s){ return strtoupper(trim($s)); }, $children);
        $has_all = true;
        foreach ($children_upper as $child) {
            if (!in_array($child, $owned_skus)) { $has_all = false; break; }
        }
        if ($has_all) {
            $completed_sets++;
            $set_names[] = isset($catalog_for_name[$parent_sku]) ? $catalog_for_name[$parent_sku]['name'] : $parent_sku;
        }
    }

    // Product bonus: set completion > count-based
    // Set bonus: แต่ละ set ครบ = +8,000 km (jump rank ได้เลย)
    // Count bonus: fallback ถ้าไม่มี set ครบ
    $set_bonus = $completed_sets * 8000;
    $count_bonus = 0;
    if ($owned_count >= 5)      $count_bonus = 5000;
    elseif ($owned_count >= 3)  $count_bonus = 2500;
    elseif ($owned_count >= 2)  $count_bonus = 1200;
    elseif ($owned_count >= 1)  $count_bonus = 500;
    $product_bonus = max($set_bonus, $count_bonus); // ใช้ค่าที่สูงกว่า

    // Activity bonus (capped at 1000)
    $activity_bonus = min(1000, ($claim_count * 200) + ($transfer_count * 100));

    // Total mileage = loyalty + product + activity
    $total_km = $loyalty_km + $product_bonus + $activity_bonus;

    // Rank tiers V2: based on total mileage (ไม่ใช่แค่วัน)
    $rank_tiers = array(
        array('key' => 'diamond',  'name' => 'Diamond',  'th' => 'ไดมอนด์',    'min' => 12000, 'color' => '#06B6D4', 'bg' => '#ecfeff', 'icon' => 'fa-gem'),
        array('key' => 'platinum', 'name' => 'Platinum', 'th' => 'แพลทินัม',   'min' => 7000,  'color' => '#6366F1', 'bg' => '#eef2ff', 'icon' => 'fa-crown'),
        array('key' => 'gold',     'name' => 'Gold',     'th' => 'ทอง',         'min' => 4000,  'color' => '#F59E0B', 'bg' => '#fffbeb', 'icon' => 'fa-trophy'),
        array('key' => 'silver',   'name' => 'Silver',   'th' => 'เงิน',        'min' => 1500,  'color' => '#94A3B8', 'bg' => '#f1f5f9', 'icon' => 'fa-star'),
        array('key' => 'bronze',   'name' => 'Bronze',   'th' => 'สำริด',       'min' => 300,   'color' => '#CD7F32', 'bg' => '#fef3e2', 'icon' => 'fa-shield'),
        array('key' => 'starter',  'name' => 'Starter',  'th' => 'ผู้เริ่มต้น', 'min' => 0,     'color' => '#9CA3AF', 'bg' => '#f3f4f6', 'icon' => 'fa-flag-checkered'),
    );

    $current_rank = end($rank_tiers);
    $next_rank = null;
    foreach ($rank_tiers as $i => $tier) {
        if ($total_km >= $tier['min']) {
            $current_rank = $tier;
            $next_rank = ($i > 0) ? $rank_tiers[$i - 1] : null;
            break;
        }
    }
    $rank_progress = 100;
    if ($next_rank) {
        $range = $next_rank['min'] - $current_rank['min'];
        $done  = $total_km - $current_rank['min'];
        $rank_progress = min(100, max(0, round(($done / $range) * 100)));
    }

    // Data for rank popup
    $rank_popup_data = json_encode(array(
        'loyalty_km' => $loyalty_km, 'product_bonus' => $product_bonus,
        'set_bonus' => $set_bonus, 'count_bonus' => $count_bonus,
        'completed_sets' => $completed_sets, 'set_names' => $set_names,
        'activity_bonus' => $activity_bonus, 'total_km' => $total_km,
        'member_days' => $member_days, 'owned_count' => $owned_count,
        'claim_count' => $claim_count, 'transfer_count' => $transfer_count,
        'current_key' => $current_rank['key'], 'tiers' => $rank_tiers,
    ), JSON_UNESCAPED_UNICODE);

    // Owned products for timeline
    $owned_products = array();
    if ($line_uid || $owner_key) {
        $owned_posts = get_posts(array(
            'post_type' => 'serial_number', 'post_status' => 'publish',
            'posts_per_page' => 20,
            'meta_query' => array(array('key' => 'owner_product', 'value' => array_filter(array($line_uid, $owner_key)), 'compare' => 'IN')),
        ));
        $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
        foreach ($owned_posts as $op) {
            $sku = get_post_meta($op->ID, 'product_sku', true);
            $cat_data = isset($catalog[$sku]) ? $catalog[$sku] : array();
            $reg_date = get_post_meta($op->ID, 'warranty_register_date', true);
            $w_status = get_post_meta($op->ID, 'w_status', true) ?: 'unknown';
            $owned_products[] = array(
                'id'       => $op->ID,
                'name'     => $cat_data['name'] ?? get_the_title($op->ID),
                'sku'      => $sku,
                'img'      => $cat_data['img'] ?? '',
                'sn'       => get_post_meta($op->ID, 'serial_code', true),
                'reg_date' => $reg_date,
                'status'   => $w_status,
                'expiry'   => get_post_meta($op->ID, 'warranty_expiry', true),
            );
        }
        // Sort by registration date (newest first)
        usort($owned_products, function($a, $b) {
            return strtotime($b['reg_date'] ?: '2000-01-01') - strtotime($a['reg_date'] ?: '2000-01-01');
        });
    }

    // Moto image
    $moto_img = get_user_meta($uid, 'user_moto_image', true);

    // Cover photo (user-uploaded)
    $cover_photo = get_user_meta($uid, 'user_cover_photo', true);

    // PDPA info
    $pdpa_status    = get_user_meta($uid, 'dinoco_pdpa_consent', true) ?: 'ยังไม่ยินยอม';
    $pdpa_timestamp = get_user_meta($uid, 'dinoco_pdpa_timestamp', true);
    $analytics_ok   = get_user_meta($uid, 'dinoco_analytics_consent', true) === 'accepted';
    $marketing_ok   = get_user_meta($uid, 'dinoco_marketing_consent', true) === 'accepted';
    $segment        = get_user_meta($uid, 'dinoco_segment_choice', true) ?: '-';

    // --- CONFIG LISTS (dynamic from MotoDB catalog) ---
    $year_range_cfg = class_exists('DINOCO_MotoDB') ? DINOCO_MotoDB::get_year_range() : ['min'=>2010,'max'=>(int)wp_date('Y')+1];
    $years_list = range($year_range_cfg['max'], $year_range_cfg['min']);
    $brands_list = function_exists('dinoco_get_brands_list') ? dinoco_get_brands_list() : ['Honda','Yamaha','Kawasaki','Suzuki','BMW','Ducati','Harley-Davidson','Triumph','Royal Enfield','GPX','Lambretta','Vespa','Other'];
    $catalog_json_ep = function_exists('dinoco_get_moto_catalog_json') ? dinoco_get_moto_catalog_json() : [];
    
    // Hard Code 77 จังหวัด
    $thai_provinces = [
        "กระบี่", "กรุงเทพมหานคร", "กาญจนบุรี", "กาฬสินธุ์", "กำแพงเพชร", "ขอนแก่น", "จันทบุรี", "ฉะเชิงเทรา", "ชลบุรี", "ชัยนาท", "ชัยภูมิ", "ชุมพร", "เชียงราย", "เชียงใหม่", "ตรัง", "ตราด", "ตาก", "นครนายก", "นครปฐม", "นครพนม", "นครราชสีมา", "นครศรีธรรมราช", "นครสวรรค์", "นนทบุรี", "นราธิวาส", "น่าน", "บึงกาฬ", "บุรีรัมย์", "ปทุมธานี", "ประจวบคีรีขันธ์", "ปราจีนบุรี", "ปัตตานี", "พระนครศรีอยุธยา", "พะเยา", "พังงา", "พัทลุง", "พิจิตร", "พิษณุโลก", "เพชรบุรี", "เพชรบูรณ์", "แพร่", "ภูเก็ต", "มหาสารคาม", "มุกดาหาร", "แม่ฮ่องสอน", "ยโสธร", "ยะลา", "ร้อยเอ็ด", "ระนอง", "ระยอง", "ราชบุรี", "ลพบุรี", "ลำปาง", "ลำพูน", "เลย", "ศรีสะเกษ", "สกลนคร", "สงขลา", "สตูล", "สมุทรปราการ", "สมุทรสงคราม", "สมุทรสาคร", "สระแก้ว", "สระบุรี", "สิงห์บุรี", "สุโขทัย", "สุพรรณบุรี", "สุราษฎร์ธานี", "สุรินทร์", "หนองคาย", "หนองบัวลำภู", "อ่างทอง", "อำนาจเจริญ", "อุดรธานี", "อุตรดิตถ์", "อุทัยธานี", "อุบลราชธานี"
    ];

    ob_start();
    ?>

