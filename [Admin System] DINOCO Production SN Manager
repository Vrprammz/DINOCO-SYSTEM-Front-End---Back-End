if ( ! function_exists( 'dinoco_sn_build_flex_expiry' ) ) {
    /**
     * F#1 Expiry Reminder Flex bubble. Per v2.10 §F#1 design.
     *
     * @param array $ctx {
     *   sn:           string canonical (DNCSS0001234)
     *   product_name: string display name (top SET preferred)
     *   warranty_end: MySQL datetime (warranty_until)
     *   days_left:    int (30/7/1 — drives header severity color)
     *   promo_code:   string optional (e.g. WELCOMEBACK-XK31)
     *   promo_pct:    int 0-100 optional
     *   extension_url: string optional /warranty/extend?sn=...
     *   shop_url:     string optional /products/...?utm=expiry
     * }
     *
     * @return array LINE Flex bubble (json-ready)
     */
    function dinoco_sn_build_flex_expiry( $ctx ) {
        $days = max( 0, (int) ( $ctx['days_left'] ?? 0 ) );
        $sn   = (string) ( $ctx['sn'] ?? '' );
        $name = (string) ( $ctx['product_name'] ?? 'สินค้า DINOCO' );
        $end  = dinoco_sn_format_thai_date( $ctx['warranty_end'] ?? '' );

        // Severity tint
        if ( $days <= 1 )      $header_color = '#dc2626'; // red
        elseif ( $days <= 7 )  $header_color = '#f59e0b'; // amber
        else                   $header_color = '#1f2937'; // navy

        $header_text = $days <= 1 ? "⚠️ ประกันหมดวันนี้!" : "⏰ ประกันใกล้หมดในอีก {$days} วัน";

        $body_contents = array(
            array(
                'type'   => 'text',
                'text'   => $name,
                'weight' => 'bold',
                'size'   => 'md',
                'wrap'   => true,
            ),
            array(
                'type'  => 'text',
                'text'  => "S/N: {$sn}",
                'size'  => 'xs',
                'color' => '#6b7280',
            ),
            array(
                'type'  => 'text',
                'text'  => $end ? "หมดประกัน: {$end}" : '',
                'size'  => 'sm',
                'color' => '#374151',
                'margin' => 'md',
            ),
        );

        // Promo block (optional)
        if ( ! empty( $ctx['promo_code'] ) && ! empty( $ctx['promo_pct'] ) ) {
            $pct = max( 0, min( 100, (int) $ctx['promo_pct'] ) );
            $body_contents[] = array( 'type' => 'separator', 'margin' => 'md' );
            $body_contents[] = array(
                'type'    => 'box',
                'layout'  => 'vertical',
                'margin'  => 'md',
                'spacing' => 'xs',
                'backgroundColor' => '#fef3c7',
                'paddingAll' => 'md',
                'cornerRadius' => 'md',
                'contents' => array(
                    array(
                        'type'   => 'text',
                        'text'   => "🎁 ส่วนลด {$pct}% สำหรับลูกค้าเก่า",
                        'weight' => 'bold',
                        'size'   => 'sm',
                        'color'  => '#92400e',
                    ),
                    array(
                        'type'   => 'text',
                        'text'   => "โค้ด: " . esc_html( (string) $ctx['promo_code'] ),
                        'size'   => 'sm',
                        'color'  => '#92400e',
                    ),
                ),
            );
        }

        // Footer buttons
        $footer = array();
        if ( ! empty( $ctx['extension_url'] ) ) {
            $footer[] = array(
                'type'   => 'button',
                'style'  => 'primary',
                'color'  => '#10b981',
                'action' => array(
                    'type'  => 'uri',
                    'label' => '🔄 ต่อประกัน',
                    'uri'   => esc_url_raw( (string) $ctx['extension_url'] ),
                ),
            );
        }
        if ( ! empty( $ctx['shop_url'] ) ) {
            $footer[] = array(
                'type'   => 'button',
                'style'  => 'secondary',
                'action' => array(
                    'type'  => 'uri',
                    'label' => '✨ ดูสินค้า',
                    'uri'   => esc_url_raw( (string) $ctx['shop_url'] ),
                ),
            );
        }

        $bubble = array(
            'type' => 'bubble',
            'size' => 'kilo',
            'header' => array(
                'type'   => 'box',
                'layout' => 'vertical',
                'backgroundColor' => $header_color,
                'paddingAll' => 'lg',
                'contents' => array(
                    array(
                        'type'   => 'text',
                        'text'   => $header_text,
                        'color'  => '#ffffff',
                        'weight' => 'bold',
                        'size'   => 'md',
                    ),
                ),
            ),
            'body' => array(
                'type'   => 'box',
                'layout' => 'vertical',
                'spacing' => 'sm',
                'contents' => $body_contents,
            ),
        );
        if ( ! empty( $footer ) ) {
            $bubble['footer'] = array(
                'type'    => 'box',
                'layout'  => 'vertical',
                'spacing' => 'sm',
                'contents' => $footer,
            );
        }
        return $bubble;
    }
}

