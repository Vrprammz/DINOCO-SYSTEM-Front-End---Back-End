/* ═══════════════════════════════════════════════════════════════════════════
 * 1.6 PHASE 2 W5.1+W5.2 — TAB 4 SEARCH HELPERS (additive 2026-05-05)
 *
 * Power-user query parser + search SQL + investigation timeline + PII mask.
 *
 * Plan ref: ~/.claude/plans/wiki-doc-sequential-lantern.md v2.13 §K + §K.2
 *
 * Pure-logic where possible (parser is testable without DB) — search/timeline
 * touch DB but are read-only and use $wpdb->prepare everywhere (no raw SQL).
 *
 * Public helpers:
 *   dinoco_sn_parse_search_query( $q ) : array
 *     → Parse "DNCSS* sku:X status:registered phone:0812345678" into struct.
 *
 *   dinoco_sn_search_plates( $parsed, $limit = 50 ) : array
 *     → Execute SQL with prepared statements; return rows joined w/ pool_meta.
 *
 *   dinoco_sn_get_timeline_for_sn( $sn, $limit = 50 ) : array
 *     → Audit events for an S/N + actor display name resolution.
 *
 *   dinoco_sn_mask_phone_for_display( $phone ) : string
 *     → "08x-xxx-1234" unless current_user_can('dinoco_sn_view_pii').
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_parse_search_query' ) ) {
    /**
     * Parse power-user search query syntax.
     *
     * Supported tokens (combine with space = AND):
     *   DNCSS0001234         → exact_sn (uppercased)
     *   DNCSS*               → prefix
     *   *1234                → suffix
     *   *MID*                → contains
     *   phone:0812345678     → filters.phone (digits only)
     *   line:Somchai_J       → filters.line
     *   order:6789           → filters.order_id (int)
     *   sku:DNCGND45L002     → filters.sku (uppercased)
     *   batch:42             → filters.batch_id (int)
     *   status:registered    → filters.status (whitelist enforced downstream)
     *   since:2026-05-01     → filters.since (ISO date string)
     *   actor:warehouse_a    → filters.actor_login
     *   bare-word            → free_text (substring search across sn/sku)
     *
     * Returns shape:
     *   {
     *     exact_sn: string|null,    (literal, no wildcards)
     *     pattern:  string|null,    ('prefix'|'suffix'|'contains' if present)
     *     pattern_value: string|null, (the search string with % chars)
     *     filters: {
     *       phone, line, order_id, sku, batch_id, status, since, actor_login
     *     },
     *     free_text: string|null,
     *     raw: string,
     *   }
     *
     * Pure logic — no DB access. Testable in isolation.
     *
     * @param string $q Raw user input.
     * @return array
     */
    function dinoco_sn_parse_search_query( $q ) {
        $q = is_string( $q ) ? trim( $q ) : '';
        $result = array(
            'exact_sn'      => null,
            'pattern'       => null,
            'pattern_value' => null,
            'filters'       => array(
                'phone'        => null,
                'line'         => null,
                'order_id'     => null,
                'sku'          => null,
                'batch_id'     => null,
                'status'       => null,
                'since'        => null,
                'actor_login'  => null,
            ),
            'free_text' => null,
            'raw'       => $q,
        );
        if ( $q === '' ) return $result;

        // Tokenize on whitespace, preserve quoted strings (rare but defensive)
        $tokens = preg_split( '/\s+/', $q );
        $free_words = array();

        foreach ( $tokens as $tok ) {
            if ( $tok === '' ) continue;
            $colon = strpos( $tok, ':' );
            if ( $colon !== false && $colon > 0 ) {
                $key = strtolower( substr( $tok, 0, $colon ) );
                $val = trim( substr( $tok, $colon + 1 ) );
                if ( $val === '' ) continue;
                switch ( $key ) {
                    case 'phone':
                        // Strip everything except digits
                        $result['filters']['phone'] = preg_replace( '/\D+/', '', $val );
                        break;
                    case 'line':
                    case 'line_name':
                        $result['filters']['line'] = $val;
                        break;
                    case 'order':
                    case 'order_id':
                        $result['filters']['order_id'] = (int) $val;
                        break;
                    case 'sku':
                        $result['filters']['sku'] = strtoupper( $val );
                        break;
                    case 'batch':
                    case 'batch_id':
                        $result['filters']['batch_id'] = (int) $val;
                        break;
                    case 'status':
                        $result['filters']['status'] = strtolower( $val );
                        break;
                    case 'since':
                        // Accept YYYY-MM-DD or full ISO; defensive validate later
                        $result['filters']['since'] = $val;
                        break;
                    case 'actor':
                    case 'actor_login':
                        $result['filters']['actor_login'] = $val;
                        break;
                    default:
                        // Unknown prefix → treat as free text
                        $free_words[] = $tok;
                }
                continue;
            }

            // Wildcard / literal S/N detection
            if ( strpos( $tok, '*' ) !== false ) {
                $upper = strtoupper( $tok );
                $first = $upper[0];
                $last  = substr( $upper, -1 );
                if ( $first === '*' && $last === '*' ) {
                    $result['pattern']       = 'contains';
                    $result['pattern_value'] = trim( $upper, '*' );
                } elseif ( $last === '*' ) {
                    $result['pattern']       = 'prefix';
                    $result['pattern_value'] = rtrim( $upper, '*' );
                } elseif ( $first === '*' ) {
                    $result['pattern']       = 'suffix';
                    $result['pattern_value'] = ltrim( $upper, '*' );
                } else {
                    // mid-wildcard (rare) — treat as contains pattern
                    $result['pattern']       = 'contains';
                    $result['pattern_value'] = str_replace( '*', '', $upper );
                }
                continue;
            }

            // Bare alphanumeric token that "looks like" S/N (≥6 chars, A-Z/0-9)
            if ( $result['exact_sn'] === null
                && preg_match( '/^[A-Za-z0-9._-]{4,}$/', $tok )
                && preg_match( '/[A-Za-z]/', $tok )
                && strlen( $tok ) >= 6
            ) {
                $result['exact_sn'] = strtoupper( $tok );
                continue;
            }

            $free_words[] = $tok;
        }

        if ( $free_words ) {
            $result['free_text'] = implode( ' ', $free_words );
        }
        return $result;
    }
}

if ( ! function_exists( 'dinoco_sn_mask_phone_for_display' ) ) {
    /**
     * Mask phone like "08x-xxx-1234" unless caller has dinoco_sn_view_pii cap.
     *
     * Defensive — accepts any string, only digits matter.
     *
     * @param string|null $phone
     * @return string
     */
    function dinoco_sn_mask_phone_for_display( $phone ) {
        $phone = is_string( $phone ) ? trim( $phone ) : '';
        if ( $phone === '' ) return '—';
        if ( current_user_can( 'dinoco_sn_view_pii' )
            || current_user_can( 'manage_options' )
        ) {
            return $phone;
        }
        $digits = preg_replace( '/\D+/', '', $phone );
        if ( strlen( $digits ) < 4 ) {
            return str_repeat( '•', max( 1, strlen( $digits ) ) );
        }
        $first = substr( $digits, 0, 2 );
        $last4 = substr( $digits, -4 );
        return $first . 'x-xxx-' . $last4;
    }
}

if ( ! function_exists( 'dinoco_sn_search_plates' ) ) {
    /**
     * Execute SQL search using parsed query struct.
     *
     * Read-only. All inputs prepared via $wpdb->prepare.
     *
     * @param array $parsed Output of dinoco_sn_parse_search_query()
     * @param int   $limit  Max rows (capped 1..200)
     * @return array<array> Rows with: sn, linked_sku, status, batch_code, batch_id,
     *                       registered_user_id, registered_at, received_at,
     *                       customer_phone (masked unless view_pii cap),
     *                       customer_display_name
     */
    function dinoco_sn_search_plates( $parsed, $limit = 50 ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return array();
        }
        $limit = max( 1, min( 200, (int) $limit ) );

        global $wpdb;
        $pool    = dinoco_sn_table( 'pool' );
        $batches = dinoco_sn_table( 'batches' );
        $meta_tbl = function_exists( 'dinoco_sn_table_exists' ) && dinoco_sn_table_exists( 'pool_meta' )
            ? dinoco_sn_table( 'pool_meta' )
            : null;

        $where  = array();
        $params = array();

        // Exact S/N takes precedence
        if ( ! empty( $parsed['exact_sn'] ) ) {
            $where[] = 'p.sn = %s';
            $params[] = (string) $parsed['exact_sn'];
        } elseif ( ! empty( $parsed['pattern'] ) && $parsed['pattern_value'] !== null ) {
            $val_esc = $wpdb->esc_like( (string) $parsed['pattern_value'] );
            switch ( $parsed['pattern'] ) {
                case 'prefix':
                    $where[]  = 'p.sn LIKE %s';
                    $params[] = $val_esc . '%';
                    break;
                case 'suffix':
                    $where[]  = 'p.sn LIKE %s';
                    $params[] = '%' . $val_esc;
                    break;
                case 'contains':
                default:
                    $where[]  = 'p.sn LIKE %s';
                    $params[] = '%' . $val_esc . '%';
            }
        }

        $f = $parsed['filters'] ?? array();

        if ( ! empty( $f['sku'] ) ) {
            $where[]  = 'p.linked_sku = %s';
            $params[] = (string) $f['sku'];
        }
        if ( ! empty( $f['batch_id'] ) ) {
            $where[]  = 'p.batch_id = %d';
            $params[] = (int) $f['batch_id'];
        }
        if ( ! empty( $f['status'] ) ) {
            // Whitelist statuses (avoid arbitrary value injection at SQL level)
            $allowed = array(
                'reserved','in_pool','allocated_to_order','shipped','registered',
                'claimed','replaced','transferred','voided','recalled',
                'reserved_for_legacy','shipped_legacy','cancelled_batch','stolen',
            );
            if ( in_array( $f['status'], $allowed, true ) ) {
                $where[]  = 'p.status = %s';
                $params[] = (string) $f['status'];
            }
        }
        if ( ! empty( $f['since'] ) ) {
            $ts = strtotime( (string) $f['since'] );
            if ( $ts !== false ) {
                $where[]  = '( p.received_at >= %s OR p.registered_at >= %s )';
                $params[] = gmdate( 'Y-m-d H:i:s', $ts );
                $params[] = gmdate( 'Y-m-d H:i:s', $ts );
            }
        }

        // Phone / LINE name require lookup via wp_users / usermeta
        if ( ! empty( $f['phone'] ) ) {
            // Match LINE phone meta (if present) OR billing phone
            $phone_digits = preg_replace( '/\D+/', '', (string) $f['phone'] );
            if ( $phone_digits !== '' ) {
                // Sub-query — find user_ids via usermeta phone fields
                $sub_phone = "SELECT um.user_id FROM {$wpdb->usermeta} um
                              WHERE um.meta_key IN ('billing_phone','dinoco_phone','phone')
                                AND REPLACE(REPLACE(REPLACE(um.meta_value,'-',''),' ',''),'+','') LIKE %s";
                $where[]  = "p.registered_user_id IN ( {$sub_phone} )";
                $params[] = '%' . $wpdb->esc_like( $phone_digits ) . '%';
            }
        }
        if ( ! empty( $f['line'] ) ) {
            $sub_line = "SELECT u.ID FROM {$wpdb->users} u WHERE u.display_name LIKE %s";
            $where[]  = "p.registered_user_id IN ( {$sub_line} )";
            $params[] = '%' . $wpdb->esc_like( (string) $f['line'] ) . '%';
        }
        if ( ! empty( $f['order_id'] ) ) {
            // Defensive: pool_meta MIGHT have order_id column; skip if missing
            if ( $meta_tbl ) {
                $cols = $wpdb->get_col( "DESCRIBE {$meta_tbl}", 0 );
                if ( is_array( $cols ) && in_array( 'order_id', $cols, true ) ) {
                    $where[]  = 'm.order_id = %d';
                    $params[] = (int) $f['order_id'];
                }
            }
        }
        if ( ! empty( $f['actor_login'] ) ) {
            // Resolve via audit log: SN had any audit row by this actor
            if ( dinoco_sn_table_exists( 'audit' ) ) {
                $audit_tbl = dinoco_sn_table( 'audit' );
                $sub_actor = "SELECT DISTINCT a.sn FROM {$audit_tbl} a
                              INNER JOIN {$wpdb->users} u ON u.ID = a.actor_user_id
                              WHERE u.user_login = %s OR u.display_name = %s";
                $where[]  = "p.sn IN ( {$sub_actor} )";
                $params[] = (string) $f['actor_login'];
                $params[] = (string) $f['actor_login'];
            }
        }

        // Free-text fallback search across sn + sku
        if ( ! empty( $parsed['free_text'] ) ) {
            $val_esc = $wpdb->esc_like( strtoupper( (string) $parsed['free_text'] ) );
            $where[]  = '( p.sn LIKE %s OR p.linked_sku LIKE %s )';
            $params[] = '%' . $val_esc . '%';
            $params[] = '%' . $val_esc . '%';
        }

        $where_sql = $where ? ( 'WHERE ' . implode( ' AND ', $where ) ) : '';
        $join_meta = $meta_tbl ? "LEFT JOIN {$meta_tbl} m ON m.sn = p.sn" : '';

        $sql = "SELECT p.sn, p.batch_id, p.linked_sku, p.status,
                       p.registered_user_id, p.registered_warranty_id,
                       p.registered_at, p.received_at,
                       b.batch_code
                FROM {$pool} p
                LEFT JOIN {$batches} b ON b.id = p.batch_id
                {$join_meta}
                {$where_sql}
                ORDER BY p.received_at DESC, p.sn ASC
                LIMIT %d";
        $params[] = $limit;

        $rows = $params
            ? $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A )
            : $wpdb->get_results( $sql, ARRAY_A );
        if ( ! is_array( $rows ) ) return array();

        // Enrich w/ display_name + masked phone (best-effort)
        $user_ids = array_unique( array_filter( array_map(
            function( $r ) { return (int) ( $r['registered_user_id'] ?? 0 ); },
            $rows
        ) ) );
        $names = array();
        $phones = array();
        if ( $user_ids ) {
            $ph = implode( ',', array_fill( 0, count( $user_ids ), '%d' ) );
            $u_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT ID, display_name FROM {$wpdb->users} WHERE ID IN ( {$ph} )",
                $user_ids
            ), ARRAY_A );
            foreach ( (array) $u_rows as $u ) {
                $names[ (int) $u['ID'] ] = (string) $u['display_name'];
            }
            // Phones from usermeta (best-effort)
            $ph_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT user_id, meta_value FROM {$wpdb->usermeta}
                 WHERE user_id IN ( {$ph} )
                   AND meta_key IN ('billing_phone','dinoco_phone','phone')",
                $user_ids
            ), ARRAY_A );
            foreach ( (array) $ph_rows as $pr ) {
                $uid = (int) $pr['user_id'];
                if ( ! isset( $phones[ $uid ] ) && ! empty( $pr['meta_value'] ) ) {
                    $phones[ $uid ] = (string) $pr['meta_value'];
                }
            }
        }

        $enriched = array_map( function( $r ) use ( $names, $phones ) {
            $uid = (int) ( $r['registered_user_id'] ?? 0 );
            $r['customer_display_name'] = $uid && isset( $names[ $uid ] ) ? $names[ $uid ] : null;
            $r['customer_phone_masked'] = $uid && isset( $phones[ $uid ] )
                ? dinoco_sn_mask_phone_for_display( $phones[ $uid ] )
                : '—';
            return $r;
        }, $rows );

        return $enriched;
    }
}

if ( ! function_exists( 'dinoco_sn_get_timeline_for_sn' ) ) {
    /**
     * Investigation timeline — full audit history for a single S/N.
     *
     * @param string $sn      Uppercase S/N
     * @param int    $limit   Max rows (1..200, default 50)
     * @return array<array>   Rows with id, event_type, status_from, status_to,
     *                        actor_display, approver_display, reason,
     *                        reason_category, created_at, is_sensitive,
     *                        context (decoded JSON)
     */
    function dinoco_sn_get_timeline_for_sn( $sn, $limit = 50 ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) {
            return array();
        }
        $sn = strtoupper( trim( (string) $sn ) );
        if ( $sn === '' ) return array();
        $limit = max( 1, min( 200, (int) $limit ) );

        global $wpdb;
        $tbl = dinoco_sn_table( 'audit' );
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, event_type, status_from, status_to, actor_user_id,
                    approver_user_id, reason, reason_category, context_json,
                    ip_address, is_sensitive, created_at
             FROM {$tbl}
             WHERE sn = %s
             ORDER BY created_at DESC, id DESC
             LIMIT %d",
            $sn, $limit
        ), ARRAY_A );

        if ( ! is_array( $rows ) ) return array();

        // Resolve user display names with cache
        $user_ids = array();
        foreach ( $rows as $r ) {
            foreach ( array( 'actor_user_id', 'approver_user_id' ) as $field ) {
                if ( ! empty( $r[ $field ] ) ) $user_ids[] = (int) $r[ $field ];
            }
        }
        $user_ids = array_unique( array_filter( $user_ids ) );
        $names = array();
        if ( $user_ids ) {
            $ph = implode( ',', array_fill( 0, count( $user_ids ), '%d' ) );
            $u_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT ID, display_name FROM {$wpdb->users} WHERE ID IN ( {$ph} )",
                $user_ids
            ), ARRAY_A );
            foreach ( (array) $u_rows as $u ) {
                $names[ (int) $u['ID'] ] = (string) $u['display_name'];
            }
        }

        return array_map( function( $r ) use ( $names ) {
            $r['actor_display'] = ! empty( $r['actor_user_id'] )
                && isset( $names[ (int) $r['actor_user_id'] ] )
                ? $names[ (int) $r['actor_user_id'] ]
                : ( ! empty( $r['actor_user_id'] ) ? 'user#' . (int) $r['actor_user_id'] : '—' );
            $r['approver_display'] = ! empty( $r['approver_user_id'] )
                && isset( $names[ (int) $r['approver_user_id'] ] )
                ? $names[ (int) $r['approver_user_id'] ]
                : ( ! empty( $r['approver_user_id'] ) ? 'user#' . (int) $r['approver_user_id'] : null );
            $r['context'] = ! empty( $r['context_json'] ) ? json_decode( $r['context_json'], true ) : null;
            unset( $r['context_json'] );
            return $r;
        }, $rows );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. SCHEMA INSTALL (lazy, idempotent)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_schema_install' ) ) {
    /**
     * Install all 15 tables + ALTER wp_dinoco_products via dbDelta.
     * Idempotent — tracks version in wp_option 'dinoco_sn_schema_version'.
     *
     * Pattern follows [Admin System] DINOCO Idempotency Helper V.1.1
     * + [Admin System] DINOCO Flag Audit Log V.1.0.
     *
     * Schema POC reference: docs/sn-system/05-schema-v1.sql
     *
     * Capacity at 1M plates × 6mo = ~530MB total across all tables.
     */
    function dinoco_sn_schema_install() {
        global $wpdb;

        $current = dinoco_sn_schema_version();
        if ( version_compare( $current, DINOCO_SN_SCHEMA_VERSION, '>=' ) ) {
            return; // Already installed at this version or higher
        }

        // V.0.39 HIGH-5 Sec FIX: serialize concurrent installs with GET_LOCK.
        // Without this, 2 admin tabs hitting admin_init in parallel could both
        // pass the version check, both run dbDelta + ALTER → race producing
        // duplicate INSERT IGNORE warnings, double-applied collation ALTERs,
        // or mid-flight broken indexes. 30s timeout is generous (typical run
        // < 2s, slow envs ~10s).
        //
        // NOTE for MariaDB: ENUM/UNIQUE re-shape ALTERs rebuild the table
        // (vs MySQL 8.0+ INSTANT ALTER). For production rollout > 100K rows
        // use pt-online-schema-change to avoid lock-window write blocks.
        $lock_acquired = false;
        try {
            $lock_acquired = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT GET_LOCK(%s, %d)",
                'dinoco_sn_schema_install', 30
            ) );
            if ( ! $lock_acquired ) {
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( new \Exception( 'sn_schema_install_lock_timeout' ), array(
                        'context'        => 'sn_schema_install',
                        'current_schema' => $current,
                        'target_schema'  => DINOCO_SN_SCHEMA_VERSION,
                    ) );
                }
                return; // Concurrent install in progress — defer to next admin_init tick
            }

            // Re-check version inside lock (another worker may have just finished)
            $current = dinoco_sn_schema_version();
            if ( version_compare( $current, DINOCO_SN_SCHEMA_VERSION, '>=' ) ) {
                return;
            }

            // V.0.40 HIGH ALTER mitigation: pre-flight COUNT(*) on hottest table.
            // For MariaDB / MySQL < 8.0.16, ENUM/UNIQUE re-shape ALTERs rebuild the
            // entire table → multi-second WRITE LOCK. > 100k rows in production
            // pool means the auto-installer should refuse to run on web request
            // and require admin to invoke via WP-CLI or pt-online-schema-change.
            $pool_tbl = $prefix . 'dinoco_sn_pool';
            $pool_table_present = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.tables
                 WHERE table_schema = %s AND table_name = %s",
                DB_NAME, $pool_tbl
            ) );
            if ( $pool_table_present ) {
                $pool_row_count = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$pool_tbl}" );
                $threshold = 100000;
                $is_cli = ( defined( 'WP_CLI' ) && WP_CLI );
                if ( $pool_row_count > $threshold && ! $is_cli ) {
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( sprintf(
                            '[SN-Schema] ALTER mitigation: pool rows=%d > %d threshold — skipping web-context migration. Run `wp eval "dinoco_sn_schema_install();"` from CLI.',
                            $pool_row_count, $threshold
                        ) );
                    }
                    update_option( 'dinoco_sn_schema_alter_blocked_at', current_time( 'mysql' ), 'no' );
                    update_option( 'dinoco_sn_schema_alter_blocked_rowcount', $pool_row_count, 'no' );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture(
                            new \Exception( 'sn_schema_install_skipped_large_pool' ),
                            array(
                                'context'    => 'sn_schema_install',
                                'pool_rows'  => $pool_row_count,
                                'threshold'  => $threshold,
                            )
                        );
                    }
                    return;
                }
            }

            require_once ABSPATH . 'wp-admin/includes/upgrade.php';
            $charset_collate = $wpdb->get_charset_collate();
            $prefix = $wpdb->prefix;
            $_lock_payload_open = true; // marker for try/finally — see closing block

            // V.0.40 HIGH dbDelta uniq_dedup → uq_dedup migration: explicit
            // DROP INDEX before dbDelta runs CREATE/ALTER. dbDelta can't always
            // reshape an existing UNIQUE KEY when the column list changed (V.0.11
            // → V.0.39 reshape added scheduled_at). INFORMATION_SCHEMA precheck
            // makes the DROP idempotent (no error if already dropped).
            $notif_tbl = $prefix . 'dinoco_sn_notifications';
            $notif_present = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.tables
                 WHERE table_schema = %s AND table_name = %s",
                DB_NAME, $notif_tbl
            ) );
            if ( $notif_present ) {
                $legacy_uniq = (int) $wpdb->get_var( $wpdb->prepare(
                    "SELECT COUNT(*) FROM information_schema.statistics
                     WHERE table_schema = %s AND table_name = %s AND index_name = %s",
                    DB_NAME, $notif_tbl, 'uniq_dedup'
                ) );
                if ( $legacy_uniq > 0 ) {
                    // Drop legacy 3-col UNIQUE so dbDelta can clean-add the
                    // V.0.39 4-col uq_dedup. Note: idempotent — guarded by precheck.
                    $wpdb->query( "ALTER TABLE {$notif_tbl} DROP INDEX uniq_dedup" );
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( '[SN-Schema] dropped legacy uniq_dedup on sn_notifications (renamed to uq_dedup with scheduled_at)' );
                    }
                }
            }

        // ═══════════════════════════════════════════════════════
        // TABLE 1: sn_batches — Batch metadata
        // ═══════════════════════════════════════════════════════
        $sql_batches = "CREATE TABLE {$prefix}dinoco_sn_batches (
            id BIGINT UNSIGNED AUTO_INCREMENT,
            batch_code VARCHAR(64) NOT NULL,
            prefix VARCHAR(8) NOT NULL,
            format_pattern VARCHAR(64) NOT NULL DEFAULT '{PREFIX}{RAND6}{CHK1}',
            qty_total INT UNSIGNED NOT NULL,
            qty_received INT UNSIGNED NOT NULL DEFAULT 0,
            qty_voided INT UNSIGNED NOT NULL DEFAULT 0,
            allocation_strategy VARCHAR(20) NOT NULL DEFAULT 'open_pool',
            factory_name VARCHAR(128) DEFAULT NULL,
            factory_po_ref VARCHAR(64) DEFAULT NULL,
            status VARCHAR(32) NOT NULL DEFAULT 'draft',
            notes TEXT DEFAULT NULL,
            created_by BIGINT UNSIGNED NOT NULL,
            created_at DATETIME NOT NULL,
            sent_at DATETIME DEFAULT NULL,
            closed_at DATETIME DEFAULT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY uq_batch_code (batch_code),
            KEY idx_prefix (prefix),
            KEY idx_status (status),
            KEY idx_created_by (created_by)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 2: sn_pool — Hot path 12 columns
        // ═══════════════════════════════════════════════════════
        // V.0.43 R4 BLOCKER #1 — sig_bucket SMALLINT UNSIGNED NULL is the
        // V2 HMAC batch-bucket snapshot (epoch-day at QR generation). Bound
        // to plate lifetime so QRs printed today stay valid 60-90d later.
        // SMALLINT max 65,535 epoch-days = ~179 years (plenty until 2149+).
        // idx_sig_bucket (batch_id, sig_bucket) covers REST API V.0.32 verify
        // path lookup pattern WHERE sn = ? (PK, fast) + columns batch_id +
        // sig_bucket fetched directly from PK row — no separate index needed
        // for that, but the named idx provides a secondary entry for batch-wide
        // bulk re-sign jobs (e.g. admin secret rotation).
        $sql_pool = "CREATE TABLE {$prefix}dinoco_sn_pool (
            sn VARCHAR(40) NOT NULL,
            batch_id BIGINT UNSIGNED NOT NULL,
            sig_bucket SMALLINT UNSIGNED DEFAULT NULL,
            seq_index INT UNSIGNED NOT NULL DEFAULT 0,
            linked_sku VARCHAR(50) DEFAULT NULL,
            status VARCHAR(32) NOT NULL DEFAULT 'reserved',
            prev_status VARCHAR(32) DEFAULT NULL,
            lock_version INT UNSIGNED NOT NULL DEFAULT 0,
            registered_user_id BIGINT UNSIGNED DEFAULT NULL,
            registered_warranty_id BIGINT UNSIGNED DEFAULT NULL,
            claim_id BIGINT UNSIGNED DEFAULT NULL,
            legacy_request_id BIGINT UNSIGNED DEFAULT NULL,
            registered_at DATETIME DEFAULT NULL,
            created_at DATETIME NOT NULL,
            PRIMARY KEY  (sn),
            KEY idx_batch (batch_id),
            KEY idx_batch_seq (batch_id, seq_index),
            KEY idx_sig_bucket (batch_id, sig_bucket),
            KEY idx_status_user (registered_user_id, status),
            KEY idx_linked_sku_status (linked_sku, status),
            KEY idx_lookup (linked_sku, status, registered_at),
            KEY idx_claim (claim_id),
            KEY idx_legacy (legacy_request_id),
            KEY idx_status_created (status, created_at)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 3: sn_pool_meta — Cold path 1:1 join
        // ═══════════════════════════════════════════════════════
        $sql_pool_meta = "CREATE TABLE {$prefix}dinoco_sn_pool_meta (
            sn VARCHAR(40) NOT NULL,
            purchase_dealer_id BIGINT UNSIGNED DEFAULT NULL,
            purchase_date DATE DEFAULT NULL,
            top_set_sku VARCHAR(50) DEFAULT NULL,
            replaced_by_sn VARCHAR(40) DEFAULT NULL,
            replaces_sn VARCHAR(40) DEFAULT NULL,
            stolen_at DATETIME DEFAULT NULL,
            stolen_police_report VARCHAR(64) DEFAULT NULL,
            recalled_at DATETIME DEFAULT NULL,
            voided_at DATETIME DEFAULT NULL,
            notes TEXT DEFAULT NULL,
            PRIMARY KEY  (sn),
            KEY idx_purchase_dealer (purchase_dealer_id),
            KEY idx_top_set (top_set_sku),
            KEY idx_stolen (stolen_at),
            KEY idx_replacement_chain (replaces_sn)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 4: sn_audit — Immutable audit log
        // ═══════════════════════════════════════════════════════
        $sql_audit = "CREATE TABLE {$prefix}dinoco_sn_audit (
            id BIGINT UNSIGNED AUTO_INCREMENT,
            sn VARCHAR(40) NOT NULL,
            event_type VARCHAR(64) NOT NULL,
            status_from VARCHAR(32) DEFAULT NULL,
            status_to VARCHAR(32) DEFAULT NULL,
            actor_user_id BIGINT UNSIGNED NOT NULL,
            approver_user_id BIGINT UNSIGNED DEFAULT NULL,
            reason VARCHAR(255) DEFAULT NULL,
            reason_category VARCHAR(64) DEFAULT NULL,
            context_json TEXT DEFAULT NULL,
            ip_address VARCHAR(45) DEFAULT NULL,
            user_agent VARCHAR(255) DEFAULT NULL,
            is_sensitive TINYINT(1) NOT NULL DEFAULT 0,
            created_at DATETIME NOT NULL,
            PRIMARY KEY  (id),
            KEY idx_sn (sn),
            KEY idx_event (event_type),
            KEY idx_actor (actor_user_id),
            KEY idx_approver (approver_user_id),
            KEY idx_created (created_at),
            KEY idx_sensitive_created (is_sensitive, created_at)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 5: sn_notifications — Phase 3 (F#1, F#4, F#10)
        // ═══════════════════════════════════════════════════════
        // V.0.11 audit fix (P0-4): UNIQUE index on (notification_type, user_id, sn)
        // promotes the previous KEY to UNIQUE — closes SELECT-then-INSERT race
        // where 2 concurrent crons both see $exists=0 → double Flex push.
        // dbDelta will alter existing tables idempotently. INSERT IGNORE in
        // dinoco_sn_schedule_notification handles the duplicate-key gracefully.
        //
        // V.0.39 M4 FIX: extended UNIQUE to include scheduled_at — allows
        // legitimate re-notifications (e.g. 30-day, 7-day, 1-day expiry
        // reminders are all 'expiry' type for same user+sn but different
        // scheduled_at). Cron worker dedup still relies on (type+user+sn)
        // SELECT-before-INSERT for same-day races. dbDelta auto-migrates
        // existing rows; INSERT IGNORE handles duplicate-key gracefully.
        // NEW NAME 'uq_dedup' (was 'uniq_dedup') signals shape change so
        // dbDelta drops/re-adds cleanly.
        $sql_notifications = "CREATE TABLE {$prefix}dinoco_sn_notifications (
            id BIGINT UNSIGNED AUTO_INCREMENT,
            sn VARCHAR(40) NOT NULL,
            user_id BIGINT UNSIGNED NOT NULL,
            notification_type VARCHAR(32) NOT NULL,
            channel VARCHAR(20) NOT NULL DEFAULT 'line_flex',
            scheduled_at DATETIME NOT NULL,
            sent_at DATETIME DEFAULT NULL,
            status VARCHAR(20) NOT NULL DEFAULT 'scheduled',
            meta_json TEXT DEFAULT NULL,
            created_at DATETIME NOT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY uq_dedup (notification_type, user_id, sn, scheduled_at),
            KEY idx_sn (sn),
            KEY idx_user (user_id),
            KEY idx_scheduled_status (scheduled_at, status)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 6: sn_promo_codes — Phase 3 (F#1, F#4, F#10 cross-sell)
        // ═══════════════════════════════════════════════════════
        $sql_promo = "CREATE TABLE {$prefix}dinoco_sn_promo_codes (
            code VARCHAR(20) NOT NULL,
            user_id BIGINT UNSIGNED NOT NULL,
            source_sn VARCHAR(40) DEFAULT NULL,
            discount_pct TINYINT UNSIGNED NOT NULL,
            discount_value DECIMAL(10,2) DEFAULT NULL,
            scope VARCHAR(32) NOT NULL DEFAULT 'any',
            scope_value VARCHAR(255) DEFAULT NULL,
            expires_at DATETIME NOT NULL,
            used_at DATETIME DEFAULT NULL,
            used_order_id BIGINT UNSIGNED DEFAULT NULL,
            created_at DATETIME NOT NULL,
            PRIMARY KEY  (code),
            KEY idx_user (user_id),
            KEY idx_expires_used (expires_at, used_at)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 7: sn_customer_ltv_snapshot — Phase 3 (F#9)
        // ═══════════════════════════════════════════════════════
        $sql_ltv = "CREATE TABLE {$prefix}dinoco_sn_customer_ltv_snapshot (
            user_id BIGINT UNSIGNED NOT NULL,
            plates_count INT UNSIGNED NOT NULL DEFAULT 0,
            registered_count INT UNSIGNED NOT NULL DEFAULT 0,
            active_warranties_count INT UNSIGNED NOT NULL DEFAULT 0,
            total_lifetime_spent DECIMAL(12,2) NOT NULL DEFAULT 0,
            first_purchase_date DATE DEFAULT NULL,
            last_purchase_date DATE DEFAULT NULL,
            claim_count INT UNSIGNED NOT NULL DEFAULT 0,
            loyalty_tier VARCHAR(20) NOT NULL DEFAULT 'bronze',
            computed_at DATETIME NOT NULL,
            PRIMARY KEY  (user_id),
            KEY idx_ltv (total_lifetime_spent),
            KEY idx_tier (loyalty_tier)
        ) {$charset_collate};";

        // ═══════════════════════════════════════════════════════
        // TABLE 8: sn_review_requests — Phase 3 (F#10)
        // ═══════════════════════════════════════════════════════
        $sql_reviews = "CREATE TABLE {$prefix}dinoco_sn_review_requests (
            id BIGINT UNSIGNED AUTO_INCREMENT,
            sn VARCHAR(40) NOT NULL,
            user_id BIGINT UNSIGNED NOT NULL,
            brand_voice_id BIGINT UNSIGNED DEFAULT NULL,
