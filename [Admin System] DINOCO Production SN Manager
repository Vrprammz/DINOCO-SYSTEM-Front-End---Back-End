     *
     * Idempotent: INFORMATION_SCHEMA precheck before each ADD KEY.
     * Caller (schema_install) holds GET_LOCK so safe vs concurrent installs.
     */
    function dinoco_sn_install_perf_indexes() {
        global $wpdb;
        $prefix = $wpdb->prefix;

        $idx_specs = array(
            array(
                'table'   => $prefix . 'dinoco_sn_pool',
                'name'    => 'idx_sku_status_received',
                'columns' => '(linked_sku, status, created_at)',
