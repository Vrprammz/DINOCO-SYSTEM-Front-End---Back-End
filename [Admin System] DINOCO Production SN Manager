if ( ! function_exists( 'dinoco_sn_run_audit_retention' ) ) {
    /**
     * Daily 03:30 — chunked delete sn_audit > 5 years (PDPA §17 financial
     * fraud retention). Sensitive ops (is_sensitive=1) keep 5y; non-sensitive
     * keep 3y per v2.4 SHOULD-FIX #5 ux-ui-expert review.
     *
     * Chunked 1000/iter × 20 iter cap to avoid OOM on huge tables.
     */
    function dinoco_sn_run_audit_retention() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) return;

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'audit' );
            $deleted   = 0;
            $anonymized = 0;
            $cap = 20;
            $cutoff_5y = gmdate( 'Y-m-d H:i:s', time() - 5 * 365 * 86400 );
            $cutoff_3y = gmdate( 'Y-m-d H:i:s', time() - 3 * 365 * 86400 );
            $cutoff_90d = gmdate( 'Y-m-d H:i:s', time() - 90 * 86400 );

            for ( $i = 0; $i < $cap; $i++ ) {
                // Sensitive rows: 5y retention
                $sensitive_del = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl}
                     WHERE is_sensitive = 1 AND created_at < %s
                     LIMIT 500",
                    $cutoff_5y
                ) );
                // Non-sensitive: 3y retention
                $nonsensitive_del = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl}
                     WHERE is_sensitive = 0 AND created_at < %s
                     LIMIT 500",
                    $cutoff_3y
                ) );
                $batch = (int) $sensitive_del + (int) $nonsensitive_del;
                $deleted += $batch;
                if ( $batch === 0 ) break;
                usleep( 50000 ); // 50ms gap to avoid hammering DB
            }

            // V.0.43 R4 HIGH-3 — Replaces V.0.40 last-octet zero (a.b.c.0) with
            // SHA256+pepper anonymization for stronger PDPA §17 minimization.
            // Last-octet zero is reversible at /24 granularity (256 candidates
            // per row — feasible to correlate with login traffic). SHA256+pepper
            // gives k-anonymity collision space ≈ 2^64 (16-hex truncation) and
            // is unlinkable to original IP without compromising both DB+pepper.
            //
            // Pepper stored in wp_option `dinoco_sn_audit_pepper` (autoload=false
            // — keeps secret out of bootstrap query). Auto-generates on first
            // run (32 chars alnum + special). Quarterly rotation via separate
            // cron `dinoco_sn_audit_pepper_rotate_cron`.
            //
            // Idempotent: hashed rows marked with `sha256:` prefix → skipped on
            // subsequent runs via NOT LIKE 'sha256:%%' guard. Pepper rotation
            // does NOT re-hash old rows (additive — old hashes verified with
            // historical pepper if needed; new rows use current pepper).
            $pepper = (string) get_option( 'dinoco_sn_audit_pepper', '' );
            if ( $pepper === '' ) {
                $pepper = wp_generate_password( 32, true, true );
                // autoload=false — secret should not be in every page-load query
                update_option( 'dinoco_sn_audit_pepper', $pepper, false );
            }

            for ( $j = 0; $j < 10; $j++ ) {
                // SHA2(CONCAT(ip, pepper), 256) → SUBSTRING 16 hex chars
                // (64-bit truncation — fits VARCHAR(45) col with 'sha256:'
                // prefix at 23 chars total). Skip already-hashed rows.
                $upd = $wpdb->query( $wpdb->prepare(
                    "UPDATE {$tbl}
                     SET ip_address = CONCAT('sha256:', SUBSTRING(SHA2(CONCAT(ip_address, %s), 256), 1, 16))
                     WHERE created_at < %s
                       AND ip_address IS NOT NULL
                       AND ip_address NOT LIKE 'sha256:%%'
                       AND ip_address != ''
                     LIMIT 500",
                    $pepper,
                    $cutoff_90d
                ) );
                $batch_anon = (int) $upd;
                $anonymized += $batch_anon;
                if ( $batch_anon === 0 ) break;
                usleep( 50000 );
            }

            update_option( 'dinoco_sn_audit_retention_last_run', array(
                'at'         => current_time( 'mysql' ),
                'deleted'    => $deleted,
                'anonymized' => $anonymized,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_audit_retention' ) );
            }
        }

        update_option( 'dinoco_cron_sn_audit_retention_last_run', current_time( 'mysql' ), false );
    }
}

if ( ! function_exists( 'dinoco_sn_run_audit_pepper_rotate' ) ) {
    /**
     * V.0.43 R4 HIGH-3 — Pepper rotation cron (quarterly).
     *
     * Cron fires weekly but callback no-ops if last rotation < 90d ago. WP
     * has no native quarterly recurrence so this gating pattern is the
     * recommended approach.
     *
     * Rotation regenerates `dinoco_sn_audit_pepper` (autoload=false). Old
     * hashes remain valid by design — audit retention only ANONYMIZES
     * (one-way hash, no verification flow). Pepper compromise mitigation:
     * rotation limits exposure window. New rows hash with new pepper; old
     * hashes don't need re-computation (additive, k-anonymity unchanged).
     *
     * Defensive: never throws, always non-destructive.
     */
    function dinoco_sn_run_audit_pepper_rotate() {
        try {
            $last_rotated = (int) get_option( 'dinoco_sn_audit_pepper_rotated_at', 0 );
            $now = time();
            // 90 days = 7,776,000 seconds. Skip if rotated recently.
            if ( $last_rotated > 0 && ( $now - $last_rotated ) < 90 * 86400 ) {
                update_option( 'dinoco_cron_sn_audit_pepper_rotate_last_run',
                    current_time( 'mysql' ), false );
                return;
            }

            $new_pepper = wp_generate_password( 32, true, true );
            update_option( 'dinoco_sn_audit_pepper', $new_pepper, false );
            update_option( 'dinoco_sn_audit_pepper_rotated_at', $now, false );

            // Audit log entry — non-PII (no pepper value, just timestamp).
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log(
                    null,
                    'audit_pepper_rotated',
                    null,
                    null,
                    array( 'rotated_at' => $now, 'reason' => 'quarterly' ),
                    0,
                    null,
                    'Quarterly audit IP-pepper rotation',
                    '',
                    true
                );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_audit_pepper_rotate' ) );
            }
        }

        update_option( 'dinoco_cron_sn_audit_pepper_rotate_last_run',
            current_time( 'mysql' ), false );
    }
}

if ( ! function_exists( 'dinoco_sn_run_batch_reconcile' ) ) {
    /**
     * Weekly batch reconcile — verify sn_batches.qty_received matches
     * actual COUNT in sn_pool grouped by batch_id. Drift > 0 → write
     * `dinoco_sn_batch_drift_report` option for admin review.
     */
    function dinoco_sn_run_batch_reconcile() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'batches' ) || ! dinoco_sn_table_exists( 'pool' ) ) return;

        try {
            global $wpdb;
            $batches = dinoco_sn_table( 'batches' );
            $pool    = dinoco_sn_table( 'pool' );

            $drifts = $wpdb->get_results(
                "SELECT b.id AS batch_id, b.batch_code,
                        b.qty_received AS reported,
                        COUNT( CASE WHEN p.status NOT IN ('reserved') THEN 1 END ) AS actual,
                        ABS( b.qty_received - COUNT( CASE WHEN p.status NOT IN ('reserved') THEN 1 END ) ) AS drift
                 FROM {$batches} b
                 LEFT JOIN {$pool} p ON p.batch_id = b.id
                 WHERE b.status NOT IN ('cancelled', 'closed')
                 GROUP BY b.id, b.batch_code, b.qty_received
                 HAVING drift > 0
                 ORDER BY drift DESC
                 LIMIT 100",
                ARRAY_A
            );

            update_option( 'dinoco_sn_batch_drift_report', array(
                'at'     => current_time( 'mysql' ),
                'count'  => $drifts ? count( $drifts ) : 0,
                'rows'   => $drifts ?: array(),
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_batch_reconcile' ) );
            }
        }

        update_option( 'dinoco_cron_sn_batch_reconcile_last_run', current_time( 'mysql' ), false );
    }
}

/* ─── Phase 3 W8 / V.0.22 — Orphan claim alert scan (Gap D) ─── */

if ( ! function_exists( 'dinoco_sn_run_orphan_claim_scan' ) ) {
    /**
     * Daily 03:30 cron — detect data inconsistency between sn_pool + claim_ticket.
     *
     * Two alert categories per v2.6 §Gap D:
     *   🔴 stuck-claim: plate.status='claimed' for > 7 days (plate locked,
     *      claim_ticket may be stalled; admin should investigate).
     *   🟡 plate-claimed-no-ticket: plate.status='claimed' but claim_id IS NULL
     *      (data drift — plate transitioned to claimed without claim_ticket
     *      record; possible 4-eyes approval bypass or stale state).
     *
     * Storage: `dinoco_sn_orphan_claim_alerts` wp_option (array, capped 200 rows).
     * Tab 4 จัดการ S/N admin can read via /orphan-alerts REST + dismiss via POST.
     *
     * Defensive — catches all throwables, never blocks cron heartbeat.
     */
    function dinoco_sn_run_orphan_claim_scan() {
        update_option( 'dinoco_cron_sn_orphan_claim_scan_last_run', current_time( 'mysql' ), false );

        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return;

        $alerts = array(
            'at'                       => current_time( 'mysql' ),
            'stuck_claim'              => array(),
            'plate_claimed_no_ticket'  => array(),
            'total'                    => 0,
        );

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $threshold = gmdate( 'Y-m-d H:i:s', time() - 7 * DAY_IN_SECONDS );

            // Category 1: stuck-claim (status=claimed > 7 days)
            // Use updated_at if exists, fall back to registered_at
            $stuck = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, registered_user_id, registered_at, claim_id,
                        DATEDIFF( CURDATE(), DATE(registered_at) ) AS days_since_register
                 FROM {$pool}
                 WHERE status = 'claimed'
                   AND registered_at <= %s
                 ORDER BY registered_at ASC
                 LIMIT 100",
                $threshold
            ), ARRAY_A );
            $alerts['stuck_claim'] = is_array( $stuck ) ? $stuck : array();

            // Category 2: plate-claimed-no-ticket (status=claimed AND claim_id IS NULL)
            $orphan = $wpdb->get_results(
                "SELECT sn, registered_user_id, registered_at,
                        DATEDIFF( CURDATE(), DATE(registered_at) ) AS days_since_register
                 FROM {$pool}
                 WHERE status = 'claimed'
                   AND ( claim_id IS NULL OR claim_id = 0 )
                 ORDER BY registered_at ASC
                 LIMIT 100",
                ARRAY_A
            );
            $alerts['plate_claimed_no_ticket'] = is_array( $orphan ) ? $orphan : array();

            $alerts['total'] = count( $alerts['stuck_claim'] ) + count( $alerts['plate_claimed_no_ticket'] );

            update_option( 'dinoco_sn_orphan_claim_alerts', $alerts, false );

            // Phase 5+ Telegram dispatch hook — fire action if helper available
            // (placeholder for future cross-system Telegram integration via Node agent)
            if ( $alerts['total'] > 0 ) {
                do_action( 'dinoco_sn_orphan_claim_alerts_detected', $alerts );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_orphan_claim_scan' ) );
            }
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 12. PHASE 3 W9 — F#1 EXPIRY REMINDER (additive 2026-05-05)
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * 2 cron jobs:
 *   dinoco_sn_expiry_schedule_cron   daily 02:00 — enqueue expiry notifications
 *                                     (status='scheduled', NO LINE push yet)
 *   dinoco_sn_notification_send_cron  every 15 min — send queued (when boss
 *                                     flips dinoco_sn_notification_send_enabled)
 *
 * Master gate: dinoco_sn_notification_send_enabled (default '0').
 * When OFF: schedule cron still enqueues rows for visibility, but send cron
 * is a no-op. This lets boss verify the queue + answer Q21 (LINE Premium tier)
 * before going live.
 *
 * Default warranty period: 1 year from registered_at (configurable per-SKU
 * via wp_dinoco_products.warranty_years — Phase 4 W9). For Phase 3 W9 stub:
 * use option dinoco_sn_default_warranty_years (default 1).
 *
 * Anti-spam dedup: notification_type + user_id + sn unique index — same
 * combo cannot be scheduled twice (handled via INSERT IGNORE in helper).
 *
 * Reference: v2.13 §F.1 + §K.7
 */

if ( ! function_exists( 'dinoco_sn_warranty_end_for_pool_row' ) ) {
    /**
     * Compute warranty end date for a sn_pool row.
     * Returns DateTime or null if not registered.
     *
     * Phase 3 W9 stub: registered_at + N years (default 1, override via option).
     * Phase 4 W9: read warranty_years from linked SKU + extension records.
     */
    function dinoco_sn_warranty_end_for_pool_row( $row ) {
        $registered_at = is_array( $row ) ? ( $row['registered_at'] ?? null ) : ( $row->registered_at ?? null );
        if ( empty( $registered_at ) ) return null;
        $years = (int) get_option( 'dinoco_sn_default_warranty_years', 1 );
        if ( $years < 1 ) $years = 1;
        try {
            $start = new \DateTime( $registered_at, wp_timezone() );
            $start->modify( '+' . $years . ' years' );
            return $start;
        } catch ( \Throwable $e ) {
            return null;
        }
    }
}

if ( ! function_exists( 'dinoco_sn_schedule_notification' ) ) {
    /**
     * Insert notification row idempotent — composite check on
     * (notification_type, user_id, sn) prevents duplicate scheduling.
     *
     * Returns true if inserted, false if dup or invalid.
     */
    function dinoco_sn_schedule_notification( $sn, $user_id, $notif_type, $scheduled_at, $meta = array() ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'notifications' ) ) {
            return false;
        }
        $sn = strtoupper( trim( (string) $sn ) );
        $user_id = (int) $user_id;
        $notif_type = sanitize_key( $notif_type );
        if ( $sn === '' || $user_id <= 0 || $notif_type === '' || ! $scheduled_at ) {
            return false;
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'notifications' );

        // V.0.11 audit fix (P0-4): UNIQUE KEY uniq_dedup enforces dedup
        // at DB level. INSERT IGNORE skips silently on duplicate. App-level
        // SELECT-first race window eliminated.
        // Use direct query (wpdb->insert escapes but doesn't support IGNORE).
        $sql = $wpdb->prepare(
            "INSERT IGNORE INTO {$tbl}
                (sn, user_id, notification_type, channel, scheduled_at, status, meta_json, created_at)
             VALUES (%s, %d, %s, %s, %s, %s, %s, %s)",
            $sn,
            $user_id,
            $notif_type,
            'line_flex',
            $scheduled_at,
            'scheduled',
            wp_json_encode( $meta ),
            current_time( 'mysql' )
        );
        $rows = $wpdb->query( $sql );
        // INSERT IGNORE: rows = 1 if inserted, 0 if dup, false on real error
        return $rows === 1;
    }
}

if ( ! function_exists( 'dinoco_sn_run_expiry_schedule' ) ) {
    /**
     * Daily 02:00 — scan registered plates approaching expiry and enqueue
     * 3 notifications per plate: expiry_30d, expiry_7d, expiry_1d.
     *
     * Idempotent: helper dedups by (type, user_id, sn). Re-running same day
     * is safe (same rows already exist → skipped).
     *
     * Phase 3 W9 stub:
     *   - 1-year warranty default (Phase 4 W9 reads SKU.warranty_years)
     *   - Skip plates with status NOT IN ('registered', 'claimed')
     *   - LIMIT 5000 plates per run to avoid OOM at 1M+ rows
     */
    function dinoco_sn_run_expiry_schedule() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $years = max( 1, (int) get_option( 'dinoco_sn_default_warranty_years', 1 ) );

            // Fetch rows whose computed warranty_end ∈ [now, now+30d]
            // Window includes 30/7/1 day milestones so single query covers all.
            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, registered_user_id, registered_at, linked_sku
                 FROM {$pool}
                 WHERE status IN ('registered', 'claimed')
                   AND registered_user_id IS NOT NULL
                   AND registered_at IS NOT NULL
                   AND registered_at >= DATE_SUB(NOW(), INTERVAL %d YEAR)
                   AND DATE_ADD(registered_at, INTERVAL %d YEAR)
                       BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 DAY)
                 ORDER BY registered_at ASC
                 LIMIT 5000",
                $years, $years
            ), ARRAY_A );

            $scheduled = 0;
            $skipped = 0;
            $milestones = array(
                'expiry_30d' => 30,
                'expiry_7d'  => 7,
                'expiry_1d'  => 1,
            );

            foreach ( $rows ?: array() as $row ) {
                $end = dinoco_sn_warranty_end_for_pool_row( $row );
                if ( ! $end ) { $skipped++; continue; }
                foreach ( $milestones as $type => $days ) {
                    $send_at = clone $end;
                    $send_at->modify( '-' . $days . ' days' );
                    // Skip if already past send window
                    if ( $send_at->getTimestamp() < time() - 86400 ) continue;

                    $ok = dinoco_sn_schedule_notification(
                        $row['sn'],
                        (int) $row['registered_user_id'],
                        $type,
                        $send_at->format( 'Y-m-d H:i:s' ),
                        array(
                            'linked_sku'    => $row['linked_sku'],
                            'warranty_end'  => $end->format( 'Y-m-d' ),
                            'days_to_expiry' => $days,
                        )
                    );
                    if ( $ok ) $scheduled++; else $skipped++;
                }
            }

            update_option( 'dinoco_sn_expiry_schedule_last_run', array(
                'at'        => current_time( 'mysql' ),
                'scanned'   => count( $rows ?: array() ),
                'scheduled' => $scheduled,
                'skipped'   => $skipped,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_expiry_schedule' ) );
            }
        }

        update_option( 'dinoco_cron_sn_expiry_schedule_last_run', current_time( 'mysql' ), false );
    }
}

/* ─── Phase 4 W13 V.0.30 — F#16 Pure-Logic Forecast Helpers ───
 * 4 named helpers extracted for plan-conformance + per-helper testability.
 * Each is pure arithmetic (no DB, no side effects, easy to PHPUnit).
 * Plan ref: docs/sn-system/20-phase4-w13-w14-prep.md §W13.1
 */

if ( ! function_exists( 'dinoco_sn_compute_moving_average' ) ) {
    /**
     * Pure-logic moving average over historical demand data.
     *
     * @param array $historical_data List of ['month' => 'YYYY-MM-01', 'qty' => N]
     *                               (unsorted ok — we sort here defensively).
     * @param int   $window           Window size (default 3 = 3-month MA).
     * @return float Average qty over last $window periods (or all if n<window).
     */
    function dinoco_sn_compute_moving_average( array $historical_data, int $window = 3 ): float {
        if ( empty( $historical_data ) ) return 0.0;
        usort( $historical_data, function( $a, $b ) {
            return strcmp( (string) ( $a['month'] ?? '' ), (string) ( $b['month'] ?? '' ) );
        } );
        $qtys = array_map( function( $r ) {
            return (float) ( $r['qty'] ?? 0 );
        }, $historical_data );
        $n = count( $qtys );
        $w = max( 1, min( $window, $n ) );
        $slice = array_slice( $qtys, -$w );
        return array_sum( $slice ) / max( 1, count( $slice ) );
    }
}

if ( ! function_exists( 'dinoco_sn_compute_exponential_smoothing' ) ) {
    /**
     * Pure-logic single exponential smoothing.
     *   level_t = alpha * actual_t + (1 - alpha) * level_{t-1}
     * Initial level seeded with first observation.
     *
     * @param array $historical_data List of ['month' => 'YYYY-MM-01', 'qty' => N].
     * @param float $alpha            Smoothing factor 0..1 (default 0.3).
     * @return float Final smoothed level (= forecast for next period).
     */
    function dinoco_sn_compute_exponential_smoothing( array $historical_data, float $alpha = 0.3 ): float {
        if ( empty( $historical_data ) ) return 0.0;
        $alpha = max( 0.0, min( 1.0, $alpha ) );
        usort( $historical_data, function( $a, $b ) {
            return strcmp( (string) ( $a['month'] ?? '' ), (string) ( $b['month'] ?? '' ) );
        } );
        $qtys = array_map( function( $r ) {
            return (float) ( $r['qty'] ?? 0 );
        }, $historical_data );
        $n = count( $qtys );
        if ( $n === 0 ) return 0.0;
        $level = $qtys[0];
        for ( $i = 1; $i < $n; $i++ ) {
            $level = $alpha * $qtys[ $i ] + ( 1.0 - $alpha ) * $level;
        }
        return (float) $level;
    }
}

if ( ! function_exists( 'dinoco_sn_classify_confidence' ) ) {
    /**
     * Plan-spec confidence buckets by months-of-data.
     *   >=12 months  → 'high'         (90-95%)
     *   6-11 months  → 'medium'       (75-85%)
     *   3-5 months   → 'low'          (60-70%)
     *   <3 months    → 'insufficient' (0%, flag)
     *
     * @param int $months_of_data Distinct months observed.
     * @return array{ band: string, pct: int, sufficient: bool }
     */
    function dinoco_sn_classify_confidence( int $months_of_data ): array {
        $m = max( 0, $months_of_data );
        if ( $m >= 12 ) {
            return array( 'band' => 'high', 'pct' => 92, 'sufficient' => true );
        }
        if ( $m >= 6 ) {
            return array( 'band' => 'medium', 'pct' => 80, 'sufficient' => true );
        }
        if ( $m >= 3 ) {
            return array( 'band' => 'low', 'pct' => 65, 'sufficient' => true );
        }
        return array( 'band' => 'insufficient', 'pct' => 0, 'sufficient' => false );
    }
}

if ( ! function_exists( 'dinoco_sn_compute_safety_stock' ) ) {
    /**
     * Safety stock buffer = avg monthly × pct (default 20%).
     * Always returns >= 0 integer.
     *
     * @param float $avg_monthly Average monthly consumption.
     * @param float $pct         Buffer percentage 0..1 (default 0.2 = 20%).
     * @return int Safety stock plate count.
     */
    function dinoco_sn_compute_safety_stock( float $avg_monthly, float $pct = 0.2 ): int {
        $avg_monthly = max( 0.0, $avg_monthly );
        $pct = max( 0.0, $pct );
        return (int) ceil( $avg_monthly * $pct );
    }
}

if ( ! function_exists( 'dinoco_sn_compute_demand_forecast' ) ) {
    /**
     * Phase 4 W13 — F#16 Demand Forecasting
     *
     * Pure-PHP time-series forecast using:
     *   - Moving average (last 6 months) for trend
     *   - Single exponential smoothing (alpha=0.3 default) for level
     *   - Combined: weighted blend of MA + ES with confidence based on
     *     data variance + sample size
     *
     * Inputs:
     *   $history = [['month' => 'YYYY-MM-01', 'qty' => N], ...]
     *   $forecast_months = 6 (default)
     *
     * Output: [
     *   ['month' => YYYY-MM-01, 'predicted_qty' => N, 'confidence_pct' => P],
     *   ...
     * ]
     *
     * Confidence model (deterministic):
     *   confidence = max(0, min(100, 100 - (cv_percent + (12 - sample_size)*5)))
     *   where cv_percent = (stddev / mean) * 100
     *   Lower variance + more data → higher confidence.
     *
     * Boss can verify math (testable). Phase 5+ ML is overkill — boss
     * needs explainable + auditable forecasts.
     */
    function dinoco_sn_compute_demand_forecast( array $history, int $forecast_months = 6, float $alpha = 0.3 ): array {
        if ( empty( $history ) ) {
            return array();
        }

        // Sort ascending by month
        usort( $history, function( $a, $b ) {
            return strcmp( (string) $a['month'], (string) $b['month'] );
        } );

        $qtys = array_map( function( $r ) { return (float) ( $r['qty'] ?? 0 ); }, $history );
        $n = count( $qtys );

        // Moving average over last min(6, n) periods
        $ma_window = min( 6, $n );
        $ma_slice = array_slice( $qtys, -$ma_window );
        $ma = array_sum( $ma_slice ) / max( 1, count( $ma_slice ) );

        // Exponential smoothing — initialize with first value, run through
        $level = $qtys[0];
        for ( $i = 1; $i < $n; $i++ ) {
            $level = $alpha * $qtys[ $i ] + ( 1 - $alpha ) * $level;
        }

        // Confidence: variance + sample size
        $mean = array_sum( $qtys ) / $n;
        $variance = 0.0;
        foreach ( $qtys as $q ) {
            $variance += ( $q - $mean ) ** 2;
        }
        $variance = $variance / max( 1, $n );
        $stddev = sqrt( $variance );
        $cv_percent = $mean > 0 ? ( $stddev / $mean ) * 100 : 0;
        $sample_penalty = max( 0, 12 - $n ) * 5;
        $confidence = max( 0, min( 100, 100 - $cv_percent - $sample_penalty ) );

        // Blend MA + ES (50/50 weight) for prediction
        $predicted_base = ( $ma + $level ) / 2;

        // Build forecast for next N months from last history month
        $last_month = $history[ count( $history ) - 1 ]['month'];
        $forecasts = array();
        for ( $i = 1; $i <= $forecast_months; $i++ ) {
            try {
                $dt = new \DateTime( $last_month );
                $dt->modify( '+' . $i . ' months' );
                $forecast_month = $dt->format( 'Y-m-01' );
            } catch ( \Throwable $_e ) {
                continue;
            }
            $forecasts[] = array(
                'month'          => $forecast_month,
                'predicted_qty'  => max( 0, (int) round( $predicted_base ) ),
                'confidence_pct' => (int) round( $confidence ),
            );
        }
        return $forecasts;
    }
}

if ( ! function_exists( 'dinoco_sn_run_demand_forecast' ) ) {
    /**
     * Phase 4 W13 — Weekly Sunday 02:00 demand forecast cron.
     *
     * For each linked_sku in sn_pool with ≥3 months of activation history:
     *   1. Aggregate monthly activation count from registered_at
     *   2. Compute 6-month forecast via dinoco_sn_compute_demand_forecast
     *   3. UPSERT into wp_dinoco_sn_demand_forecast
     *
     * Idempotent — UNIQUE KEY (sku, forecast_month) ensures
     * INSERT...ON DUPLICATE KEY overwrites stale forecasts.
     */
    function dinoco_sn_run_demand_forecast() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'demand_forecast' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $forecast_tbl = dinoco_sn_table( 'demand_forecast' );

            // Find SKUs with at least 3 months of activation history
            $skus = $wpdb->get_col(
                "SELECT linked_sku
                 FROM {$pool}
                 WHERE registered_user_id IS NOT NULL
                   AND linked_sku IS NOT NULL AND linked_sku != ''
                   AND status IN ('registered', 'claimed', 'replaced', 'transferred', 'recalled')
                 GROUP BY linked_sku
                 HAVING COUNT(DISTINCT DATE_FORMAT(registered_at, '%Y-%m')) >= 3
                 ORDER BY linked_sku ASC
                 LIMIT 200"
            );

            $now = current_time( 'mysql' );
            $sku_count = 0;
            $row_count = 0;

            foreach ( $skus ?: array() as $sku ) {
                // 12-month rolling history per SKU
                $history_rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT DATE_FORMAT(registered_at, '%%Y-%%m-01') AS month,
                            COUNT(*) AS qty
                     FROM {$pool}
                     WHERE linked_sku = %s
                       AND registered_at IS NOT NULL
                       AND registered_at >= DATE_SUB(NOW(), INTERVAL 12 MONTH)
                       AND status IN ('registered', 'claimed', 'replaced', 'transferred', 'recalled')
                     GROUP BY DATE_FORMAT(registered_at, '%%Y-%%m-01')
                     ORDER BY month ASC",
                    $sku
                ), ARRAY_A );

                if ( count( $history_rows ?: array() ) < 3 ) continue;

                $forecasts = dinoco_sn_compute_demand_forecast( $history_rows, 6 );
                if ( empty( $forecasts ) ) continue;

                // Current pool qty for SKU
                $current_pool = (int) $wpdb->get_var( $wpdb->prepare(
                    "SELECT COUNT(*) FROM {$pool}
                     WHERE linked_sku = %s AND status = 'in_pool'",
                    $sku
                ) );

                foreach ( $forecasts as $f ) {
                    $suggested = max( 0, $f['predicted_qty'] - $current_pool );
                    $wpdb->query( $wpdb->prepare(
                        "INSERT INTO {$forecast_tbl}
                            (sku, forecast_month, predicted_qty, confidence_pct,
                             current_pool_qty, suggested_order_qty, computed_at)
                         VALUES (%s, %s, %d, %d, %d, %d, %s)
                         ON DUPLICATE KEY UPDATE
                            predicted_qty       = VALUES(predicted_qty),
                            confidence_pct      = VALUES(confidence_pct),
                            current_pool_qty    = VALUES(current_pool_qty),
                            suggested_order_qty = VALUES(suggested_order_qty),
                            computed_at         = VALUES(computed_at)",
                        $sku,
                        $f['month'],
                        $f['predicted_qty'],
                        $f['confidence_pct'],
                        $current_pool,
                        $suggested,
                        $now
                    ) );
                    $row_count++;
                }
                $sku_count++;
            }

            update_option( 'dinoco_sn_demand_forecast_last_run', array(
                'at'         => $now,
                'sku_count'  => $sku_count,
                'row_count'  => $row_count,
            ), false );

            // Phase 4 W13.3 V.0.30 — push weekly Flex report to บอส.
            // Defensive: dispatch failure must NOT break cron.
            if ( function_exists( 'dinoco_sn_dispatch_weekly_forecast_flex' ) ) {
                $threshold = (int) get_option( 'dinoco_sn_forecast_urgent_threshold_days', 60 );
                @dinoco_sn_dispatch_weekly_forecast_flex( $threshold );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_demand_forecast' ) );
            }
        }

        update_option( 'dinoco_cron_sn_demand_forecast_last_run', current_time( 'mysql' ), false );
    }
}

/* ─── Phase 5 W16.3 V.0.32 — Marketplace Pending Payment Timeout Cron ─── */

if ( ! function_exists( 'dinoco_sn_run_marketplace_timeout' ) ) {
    /**
     * Auto-cancel extension marketplace orders stuck in pending_payment > 24h
     * with no slip_image_id uploaded. Customer LINE Flex notification (defensive).
     *
     * Runs every 5 min. Heartbeat tracked in 'dinoco_cron_sn_marketplace_timeout_last_run'.
     *
     * Idempotent: re-running on already-expired rows = no-op (status filter).
     */
    function dinoco_sn_run_marketplace_timeout() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'extensions' ) ) return;

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'extensions' );
            $cutoff = gmdate( 'Y-m-d H:i:s', time() - DAY_IN_SECONDS );

            // Find candidates (pending_payment > 24h with no slip)
            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, sn, user_id FROM {$tbl}
                 WHERE payment_status = 'pending_payment'
                   AND ( slip_image_id IS NULL OR slip_image_id = 0 )
                   AND created_at < %s
                 ORDER BY id ASC
                 LIMIT 100",
                $cutoff
            ) );

            if ( empty( $rows ) ) {
                update_option( 'dinoco_cron_sn_marketplace_timeout_last_run', current_time( 'mysql' ), false );
                return;
            }

            $expired_count = 0;
            foreach ( $rows as $row ) {
                $upd = $wpdb->update(
                    $tbl,
                    array(
                        'payment_status' => 'expired',
                        'cancelled_at'   => current_time( 'mysql' ),
                    ),
                    array( 'id' => $row->id, 'payment_status' => 'pending_payment' ),
                    array( '%s', '%s' ),
                    array( '%d', '%s' )
                );
                if ( $upd > 0 ) {
                    $expired_count++;
                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log( 'extension_expired', array(
                            'sn'           => $row->sn,
                            'extension_id' => (int) $row->id,
                            'user_id'      => (int) $row->user_id,
                            'context'      => array( 'reason' => 'pending_payment_timeout_24h' ),
                        ) );
                    }
                }
            }

            update_option( 'dinoco_sn_marketplace_timeout_last_run', array(
                'at'            => current_time( 'mysql' ),
                'expired_count' => $expired_count,
            ), false );
            update_option( 'dinoco_cron_sn_marketplace_timeout_last_run', current_time( 'mysql' ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_marketplace_timeout' ) );
            }
        }
    }
}

