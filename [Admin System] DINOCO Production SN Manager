                                '<div class="meta">' + b.qty_received + ' / ' + b.qty_total + ' plates · ' + pct + '%</div>' +
                                '<div class="meta">' + (b.factory_name || 'No factory') + ' · created ' + (b.created_at || '').substr(0, 10) + '</div>' +
                                '</div>' +
                                '<div style="text-align:right;">' +
                                '<span class="dnc-sn-batch-status ' + statusClass + '">' + escapeHtml(b.status) + '</span>' +
                                '<div style="margin-top:8px;display:flex;gap:6px;flex-direction:column;">' +
                                (b.status === 'draft' ? '<button class="dnc-sn-btn dnc-sn-btn-secondary" onclick="dncSnMarkSent(' + b.id + ')">▶ ส่งโรงงาน</button>' : '') +
                                '<button class="dnc-sn-btn dnc-sn-btn-secondary" onclick="dncSnDownloadCSV(' + b.id + ')">📥 CSV (รวม QR URL)</button>' +
                                /* QR PDF button REMOVED Round 3 (2026-05-07) — Huali Label generates QR from CSV. */
                                '</div></div></div>';
                        }).join('');

                        // V.0.41 — deep-link focus support
                        // After render, if window._dncSnFocusBatchId is set
                        // (from URL ?focus_batch_id=N OR from "ดู Batch เดิม"
                        // recovery path), scroll into view + highlight pulse.
                        if (window._dncSnFocusBatchId) {
                            var fid = window._dncSnFocusBatchId;
                            window._dncSnFocusBatchId = null; // one-shot
                            setTimeout(function() { dncSnHighlightBatch(fid); }, 50);
                        }
                    })
                    .catch(function(err) {
                        listEl.innerHTML = '<div class="dnc-sn-empty">เกิดข้อผิดพลาด: ' + err.message + '</div>';
                    });
            };

            // V.0.41 — scroll-into-view + 2.5s yellow pulse highlight on a batch card.
            window.dncSnHighlightBatch = function(batchId) {
                if (!batchId) return;
                var el = document.getElementById('dnc-sn-batch-card-' + batchId);
                if (!el) return;
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                el.style.transition = 'box-shadow 0.3s ease, background-color 0.3s ease';
                el.style.boxShadow = '0 0 0 3px #fbbf24';
                el.style.backgroundColor = '#fffbeb';
                setTimeout(function() {
                    el.style.boxShadow = '';
                    el.style.backgroundColor = '';
                }, 2500);
            };

            window.dncSnOpenCreateBatchModal = function() {
                // V.0.37 — pre-flight check: don't waste user input if system is OFF
                var disabledBanner = document.querySelector('.dnc-sn-disabled-banner');
                if (disabledBanner) {
                    var msg = 'ระบบ S/N ยังปิดอยู่ — กดปุ่ม "🟢 เปิดระบบ S/N" บน banner สีเหลืองด้านบนก่อน แล้วค่อยมาสร้าง batch ครับ';
                    if (window.dinocoModal && window.dinocoModal.alert) {
                        window.dinocoModal.alert({ title: '⚠️ ระบบ S/N ยังปิดอยู่', content: msg });
                    } else {
                        alert(msg);
                    }
                    // Scroll to banner so user sees the toggle button
                    disabledBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    var cta = disabledBanner.querySelector('.dnc-sn-banner-cta');
                    if (cta) {
                        cta.focus();
                        cta.style.animation = 'dncSnPulse 1.5s ease-in-out 3';
                    }
                    return;
                }
                document.getElementById('dnc-sn-create-batch-modal').classList.remove('hidden');
                // V.0.41 — reset hint when modal reopens
                var hint = document.getElementById('dnc-sn-new-batch-code-hint');
                if (hint) { hint.textContent = ''; hint.removeAttribute('data-state'); }
                window._dncSnLastBatchCodeChecked = null;
            };

            window.dncSnCloseCreateBatchModal = function() {
                document.getElementById('dnc-sn-create-batch-modal').classList.add('hidden');
            };

            // Live preview
            ['dnc-sn-new-batch-prefix', 'dnc-sn-new-batch-qty', 'dnc-sn-new-batch-format'].forEach(function(id) {
                document.getElementById(id).addEventListener('input', updateBatchPreview);
            });

            // V.0.41 — live batch_code availability check (debounced 500ms)
            //   Hits GET /batches/check?batch_code=X (5s server cache).
            //   Shows inline 🟢 / 🟡 hint + click-to-fill suggestion.
            (function() {
                var inputEl = document.getElementById('dnc-sn-new-batch-code');
                var hintEl  = document.getElementById('dnc-sn-new-batch-code-hint');
                if (!inputEl || !hintEl) return;
                var timer = null;

                window.dncSnCheckBatchCodeAvailable = function(code) {
                    if (!code || code.length < 1) {
                        hintEl.textContent = '';
                        hintEl.removeAttribute('data-state');
                        return;
                    }
                    hintEl.textContent = 'กำลังตรวจสอบ...';
                    hintEl.style.color = '#6b7280';
                    hintEl.setAttribute('data-state', 'checking');

                    var url = REST_BASE + '/batches/check?batch_code=' + encodeURIComponent(code);
                    fetch(url, { headers: { 'X-WP-Nonce': NONCE }, credentials: 'same-origin' })
                        .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, body: j }; }); })
                        .then(function(res) {
                            // Stale-response guard — ignore if input changed mid-flight
                            if ((inputEl.value || '').trim() !== code) return;
                            if (!res.ok || !res.body) {
                                hintEl.textContent = '';
                                hintEl.removeAttribute('data-state');
                                return;
                            }
                            if (res.body.available === true) {
                                hintEl.innerHTML = '🟢 <span style="color:#059669;">✓ ชื่อนี้ใช้ได้</span>';
                                hintEl.setAttribute('data-state', 'available');
                            } else if (res.body.available === false) {
                                var sug = res.body.suggested_code;
                                var ex  = res.body.existing_batch || {};
                                var sugBtn = sug
                                    ? ' — <a href="#" style="color:#1d4ed8;text-decoration:underline;font-weight:600;" onclick="dncSnApplySuggestion(event)" data-suggestion="' + escapeHtml(sug) + '">ใช้ชื่อนี้แทน: ' + escapeHtml(sug) + '</a>'
                                    : '';
                                var exNote = ex && ex.qty_received != null && ex.qty_total != null
                                    ? ' <small style="color:#92400e;">(' + ex.qty_received + '/' + ex.qty_total + ' plates · ' + escapeHtml(ex.status || '') + ')</small>'
                                    : '';
                                hintEl.innerHTML = '🟡 <span style="color:#b45309;">⚠️ ชื่อนี้ใช้แล้ว</span>' + exNote + sugBtn;
                                hintEl.setAttribute('data-state', 'taken');
                            }
                            window._dncSnLastBatchCodeChecked = code;
                        })
                        .catch(function() {
                            // Network error — silent (don't block submit)
                            hintEl.textContent = '';
                            hintEl.removeAttribute('data-state');
                        });
                };

                window.dncSnApplySuggestion = function(ev) {
                    if (ev && ev.preventDefault) ev.preventDefault();
                    var anchor = ev && ev.target ? ev.target : null;
                    var sug = anchor ? anchor.getAttribute('data-suggestion') : null;
                    if (sug && inputEl) {
                        inputEl.value = sug;
                        inputEl.focus();
                        // Re-trigger check for the new value
                        window.dncSnCheckBatchCodeAvailable(sug);
                    }
                    return false;
                };

                inputEl.addEventListener('input', function() {
                    clearTimeout(timer);
                    var code = (inputEl.value || '').trim();
                    if (!code) {
                        hintEl.textContent = '';
                        hintEl.removeAttribute('data-state');
                        return;
                    }
                    timer = setTimeout(function() {
                        window.dncSnCheckBatchCodeAvailable(code);
                    }, 500);
                });
                inputEl.addEventListener('blur', function() {
                    clearTimeout(timer);
                    var code = (inputEl.value || '').trim();
                    if (code && code !== window._dncSnLastBatchCodeChecked) {
                        window.dncSnCheckBatchCodeAvailable(code);
                    }
                });
            })();

            function updateBatchPreview() {
                var prefix = (document.getElementById('dnc-sn-new-batch-prefix').value || '').toUpperCase();
                var qty = parseInt(document.getElementById('dnc-sn-new-batch-qty').value || '0');
                var format = document.getElementById('dnc-sn-new-batch-format').value;
                var preview = document.getElementById('dnc-sn-new-batch-preview');

                if (!prefix || !qty) {
                    preview.textContent = 'Preview: กรอกข้อมูลเพื่อดู preview';
                    return;
                }

                // V.0.36 — random vs sequential preview
                var randMatch = format.match(/\{RAND(\d+)\}/);
                var seqMatch = format.match(/\{SEQ:(\d+)\}/);
                var dbSize = Math.round(qty * 0.0005 * 100) / 100; // ~500B per row
                var html;

                if (randMatch) {
                    var rl = parseInt(randMatch[1]);
                    var hasCheck = format.indexOf('{CHK1}') >= 0;
                    // Sample 2 random examples (not the actual values used)
                    var alphabet = '0123456789ABCDEFGHJKMNPQRSTVWXYZ';
                    var rand = function(n) {
                        var s = '';
                        for (var i = 0; i < n; i++) s += alphabet[Math.floor(Math.random() * alphabet.length)];
                        return s;
                    };
                    var ex1 = prefix + rand(rl) + (hasCheck ? rand(1) : '');
                    var ex2 = prefix + rand(rl) + (hasCheck ? rand(1) : '');
                    html = 'Preview (ตัวอย่าง random):<br>' +
                        '<strong>' + ex1 + '</strong>, <strong>' + ex2 + '</strong>, ...<br>' +
                        '<small>🛡️ Anti-enumeration · DB: ~' + dbSize + ' MB · เวลา: ~' + Math.ceil(qty / 50000) + ' นาที</small>';
                } else {
                    var seq_pad = seqMatch ? parseInt(seqMatch[1]) : 7;
                    var first = prefix + String(1).padStart(seq_pad, '0');
                    var last = prefix + String(qty).padStart(seq_pad, '0');
                    html = '⚠️ Preview (legacy sequential):<br>' +
                        '<strong>' + first + '</strong> .. <strong>' + last + '</strong><br>' +
                        '<small style="color:#dc2626">⚠️ เลขเรียง = เดาง่าย · เสี่ยง enumeration attack · DB: ~' + dbSize + ' MB · เวลา: ~' + Math.ceil(qty / 50000) + ' นาที</small>';
                }
                preview.innerHTML = html;
            }

            window.dncSnSubmitCreateBatch = function() {
                var data = {
                    batch_code: document.getElementById('dnc-sn-new-batch-code').value.trim(),
                    prefix: document.getElementById('dnc-sn-new-batch-prefix').value.trim().toUpperCase(),
                    qty_total: parseInt(document.getElementById('dnc-sn-new-batch-qty').value || '0'),
                    format_pattern: document.getElementById('dnc-sn-new-batch-format').value,
                    allocation_strategy: document.getElementById('dnc-sn-new-batch-strategy').value,
                    factory_name: document.getElementById('dnc-sn-new-batch-factory').value.trim(),
                    factory_po_ref: document.getElementById('dnc-sn-new-batch-po').value.trim(),
                };

                if (!data.batch_code || !data.prefix || !data.qty_total) {
                    alert('กรุณากรอกข้อมูลให้ครบ');
                    return;
                }
                if (!data.prefix.match(/^[A-Z0-9]{3,6}$/)) {
                    alert('Prefix ต้องเป็น A-Z 0-9 ความยาว 3-6 ตัว');
                    return;
                }

                fetch(REST_BASE + '/batches', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': NONCE,
                        'X-Idempotency-Key': crypto.randomUUID(),
                    },
                    body: JSON.stringify(data),
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, body: j }; }); })
                .then(function(res) {
                    if (res.ok) {
                        alert('สร้าง Batch สำเร็จ!\n' + res.body.first_sn + ' .. ' + res.body.last_sn);
                        dncSnCloseCreateBatchModal();
                        dncSnLoadBatches();
                        return;
                    }
                    // V.0.41 — UX dead-end recovery for 409 batch_code_duplicate.
                    //   Backend returns: { code:'batch_code_duplicate', message,
                    //     data: { existing_batch:{...}, suggested_code } }.
                    //   Show 3-action confirm modal instead of plain alert().
                    var b = res.body || {};
                    var errCode = b.code || (b.data && b.data.code);
                    if (res.status === 409 && errCode === 'batch_code_duplicate') {
                        var info = (b.data && b.data.existing_batch) ? b.data.existing_batch : null;
                        var sug  = (b.data && b.data.suggested_code) || null;
                        dncSnHandleBatchDuplicate(data.batch_code, info, sug);
                        return;
                    }
                    alert('Error: ' + (b.message || 'unknown'));
                })
                .catch(function(err) {
                    alert('Network error: ' + err.message);
                });
            };

            /**
             * V.0.41 — Handle 409 batch_code_duplicate with recovery modal.
             *
             * 3 actions:
             *   1. ดู Batch เดิม → close modal + switch to Tab 1 + scroll/highlight
             *      via window._dncSnFocusBatchId state.
             *   2. ใช้ชื่อใหม่ '{suggested}' → fill input + auto-resubmit.
             *   3. ยกเลิก → keep modal open (admin can edit + retry).
             *
             * Falls back to alert() if window.dinocoModal not loaded.
             */
            window.dncSnHandleBatchDuplicate = function(attemptedCode, existing, suggested) {
                var info = existing || {};
                var createdShort = (info.created_at || '').substr(0, 10);
                var statusLabel = info.status || '—';
                var qtyLabel = (info.qty_received != null && info.qty_total != null)
                    ? info.qty_received + '/' + info.qty_total + ' plates'
                    : '';

                var bodyLines = [];
                bodyLines.push('Batch "' + attemptedCode + '" ถูกใช้ไปแล้ว');
                if (createdShort) bodyLines.push('สร้างเมื่อ: ' + createdShort);
                if (qtyLabel) bodyLines.push('สถานะ: ' + statusLabel + ' (' + qtyLabel + ')');
                if (suggested) bodyLines.push('ระบบแนะนำชื่อใหม่: "' + suggested + '"');
                var bodyText = bodyLines.join('\n');
                var bodyHtml = bodyLines.map(function(l) { return escapeHtml(l); }).join('<br>');

                // Fallback path — no dinocoModal helpers loaded.
                if (!window.dinocoModal || typeof window.dinocoModal.confirm !== 'function') {
                    var prompt1 = bodyText + '\n\nกด OK เพื่อใช้ชื่อแนะนำ "' + (suggested || '') + '" / Cancel เพื่อแก้เอง';
                    if (suggested && window.confirm(prompt1)) {
                        document.getElementById('dnc-sn-new-batch-code').value = suggested;
                        window.dncSnSubmitCreateBatch();
                    }
                    // else admin keeps modal open + edits manually
                    return;
                }

                // Primary path — dinocoModal.confirm with custom buttons.
                // Pattern: 2 confirm() chains since helper supports binary
                // confirm/cancel only — first ask "use suggested?" then
                // optionally chain "view existing?" if cancelled.
                var doApplySuggested = function() {
                    if (!suggested) return;
                    document.getElementById('dnc-sn-new-batch-code').value = suggested;
                    var hint = document.getElementById('dnc-sn-new-batch-code-hint');
                    if (hint) {
                        hint.innerHTML = '🟢 <span style="color:#059669;">✓ ชื่อนี้ใช้ได้</span>';
                        hint.setAttribute('data-state', 'available');
                    }
                    window._dncSnLastBatchCodeChecked = suggested;
                    window.dncSnSubmitCreateBatch();
                };

                var doViewExisting = function() {
                    if (!info || !info.id) return;
                    dncSnCloseCreateBatchModal();
                    window._dncSnFocusBatchId = info.id;
                    var tab = document.querySelector('.dnc-sn-tab[data-tab="batches"]');
                    if (tab) tab.click();
                    if (window.dncSnLoadBatches) window.dncSnLoadBatches();
                };

                // Step 1: offer suggested name (most common recovery path).
                if (suggested) {
                    window.dinocoModal.confirm({
                        title: '⚠️ ชื่อ Batch ซ้ำ',
