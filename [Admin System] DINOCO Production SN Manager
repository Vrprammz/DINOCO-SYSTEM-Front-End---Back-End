 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_parse_search_query' ) ) {
    /**
     * Parse power-user search query syntax.
     *
     * Supported tokens (combine with space = AND):
     *   DNCSS0001234         → exact_sn (uppercased)
     *   DNCSS*               → prefix
     *   *1234                → suffix
     *   *MID*                → contains
     *   phone:0812345678     → filters.phone (digits only)
     *   line:Somchai_J       → filters.line
     *   order:6789           → filters.order_id (int)
     *   sku:DNCGND45L002     → filters.sku (uppercased)
     *   batch:42             → filters.batch_id (int)
     *   status:registered    → filters.status (whitelist enforced downstream)
     *   since:2026-05-01     → filters.since (ISO date string)
     *   actor:warehouse_a    → filters.actor_login
     *   bare-word            → free_text (substring search across sn/sku)
     *
     * Returns shape:
     *   {
     *     exact_sn: string|null,    (literal, no wildcards)
     *     pattern:  string|null,    ('prefix'|'suffix'|'contains' if present)
     *     pattern_value: string|null, (the search string with % chars)
     *     filters: {
     *       phone, line, order_id, sku, batch_id, status, since, actor_login
     *     },
     *     free_text: string|null,
     *     raw: string,
     *   }
     *
     * Pure logic — no DB access. Testable in isolation.
     *
     * @param string $q Raw user input.
     * @return array
     */
    function dinoco_sn_parse_search_query( $q ) {
        $q = is_string( $q ) ? trim( $q ) : '';
        $result = array(
            'exact_sn'      => null,
            'pattern'       => null,
            'pattern_value' => null,
            'filters'       => array(
                'phone'        => null,
                'line'         => null,
                'order_id'     => null,
                'sku'          => null,
                'batch_id'     => null,
                'status'       => null,
                'since'        => null,
                'actor_login'  => null,
            ),
            'free_text' => null,
            'raw'       => $q,
        );
        if ( $q === '' ) return $result;

        // Tokenize on whitespace, preserve quoted strings (rare but defensive)
        $tokens = preg_split( '/\s+/', $q );
        $free_words = array();

        foreach ( $tokens as $tok ) {
            if ( $tok === '' ) continue;
            $colon = strpos( $tok, ':' );
            if ( $colon !== false && $colon > 0 ) {
                $key = strtolower( substr( $tok, 0, $colon ) );
                $val = trim( substr( $tok, $colon + 1 ) );
                if ( $val === '' ) continue;
                switch ( $key ) {
                    case 'phone':
                        // Strip everything except digits
                        $result['filters']['phone'] = preg_replace( '/\D+/', '', $val );
                        break;
                    case 'line':
                    case 'line_name':
                        $result['filters']['line'] = $val;
                        break;
                    case 'order':
                    case 'order_id':
                        $result['filters']['order_id'] = (int) $val;
                        break;
                    case 'sku':
                        $result['filters']['sku'] = strtoupper( $val );
                        break;
                    case 'batch':
                    case 'batch_id':
                        $result['filters']['batch_id'] = (int) $val;
                        break;
                    case 'status':
                        $result['filters']['status'] = strtolower( $val );
                        break;
                    case 'since':
                        // Accept YYYY-MM-DD or full ISO; defensive validate later
                        $result['filters']['since'] = $val;
                        break;
                    case 'actor':
                    case 'actor_login':
                        $result['filters']['actor_login'] = $val;
                        break;
                    default:
                        // Unknown prefix → treat as free text
                        $free_words[] = $tok;
                }
                continue;
            }

            // Wildcard / literal S/N detection
            if ( strpos( $tok, '*' ) !== false ) {
                $upper = strtoupper( $tok );
                $first = $upper[0];
                $last  = substr( $upper, -1 );
                if ( $first === '*' && $last === '*' ) {
                    $result['pattern']       = 'contains';
                    $result['pattern_value'] = trim( $upper, '*' );
                } elseif ( $last === '*' ) {
                    $result['pattern']       = 'prefix';
                    $result['pattern_value'] = rtrim( $upper, '*' );
                } elseif ( $first === '*' ) {
                    $result['pattern']       = 'suffix';
                    $result['pattern_value'] = ltrim( $upper, '*' );
                } else {
                    // mid-wildcard (rare) — treat as contains pattern
                    $result['pattern']       = 'contains';
                    $result['pattern_value'] = str_replace( '*', '', $upper );
                }
                continue;
            }

            // Bare alphanumeric token that "looks like" S/N (≥6 chars, A-Z/0-9)
            if ( $result['exact_sn'] === null
                && preg_match( '/^[A-Za-z0-9._-]{4,}$/', $tok )
                && preg_match( '/[A-Za-z]/', $tok )
                && strlen( $tok ) >= 6
            ) {
                $result['exact_sn'] = strtoupper( $tok );
                continue;
            }

            $free_words[] = $tok;
        }

        if ( $free_words ) {
            $result['free_text'] = implode( ' ', $free_words );
        }
        return $result;
    }
}

if ( ! function_exists( 'dinoco_sn_mask_phone_for_display' ) ) {
    /**
     * Mask phone like "08x-xxx-1234" unless caller has dinoco_sn_view_pii cap.
     *
     * Defensive — accepts any string, only digits matter.
     *
     * @param string|null $phone
     * @return string
     */
    function dinoco_sn_mask_phone_for_display( $phone ) {
        $phone = is_string( $phone ) ? trim( $phone ) : '';
        if ( $phone === '' ) return '—';
        if ( current_user_can( 'dinoco_sn_view_pii' )
            || current_user_can( 'manage_options' )
        ) {
            return $phone;
        }
        $digits = preg_replace( '/\D+/', '', $phone );
        if ( strlen( $digits ) < 4 ) {
            return str_repeat( '•', max( 1, strlen( $digits ) ) );
        }
        $first = substr( $digits, 0, 2 );
        $last4 = substr( $digits, -4 );
        return $first . 'x-xxx-' . $last4;
    }
}

if ( ! function_exists( 'dinoco_sn_search_plates' ) ) {
    /**
     * Execute SQL search using parsed query struct.
     *
     * Read-only. All inputs prepared via $wpdb->prepare.
     *
     * @param array $parsed Output of dinoco_sn_parse_search_query()
     * @param int   $limit  Max rows (capped 1..200)
     * @return array<array> Rows with: sn, linked_sku, status, batch_code, batch_id,
     *                       registered_user_id, registered_at, received_at,
     *                       customer_phone (masked unless view_pii cap),
     *                       customer_display_name
     */
    function dinoco_sn_search_plates( $parsed, $limit = 50 ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return array();
        }
        $limit = max( 1, min( 200, (int) $limit ) );

        global $wpdb;
        $pool    = dinoco_sn_table( 'pool' );
        $batches = dinoco_sn_table( 'batches' );
        $meta_tbl = function_exists( 'dinoco_sn_table_exists' ) && dinoco_sn_table_exists( 'pool_meta' )
            ? dinoco_sn_table( 'pool_meta' )
            : null;

        $where  = array();
        $params = array();

        // Exact S/N takes precedence
        if ( ! empty( $parsed['exact_sn'] ) ) {
            $where[] = 'p.sn = %s';
            $params[] = (string) $parsed['exact_sn'];
        } elseif ( ! empty( $parsed['pattern'] ) && $parsed['pattern_value'] !== null ) {
            $val_esc = $wpdb->esc_like( (string) $parsed['pattern_value'] );
            switch ( $parsed['pattern'] ) {
                case 'prefix':
                    $where[]  = 'p.sn LIKE %s';
                    $params[] = $val_esc . '%';
                    break;
                case 'suffix':
                    $where[]  = 'p.sn LIKE %s';
                    $params[] = '%' . $val_esc;
                    break;
                case 'contains':
                default:
                    $where[]  = 'p.sn LIKE %s';
                    $params[] = '%' . $val_esc . '%';
            }
        }

        $f = $parsed['filters'] ?? array();

        if ( ! empty( $f['sku'] ) ) {
            $where[]  = 'p.linked_sku = %s';
            $params[] = (string) $f['sku'];
        }
        if ( ! empty( $f['batch_id'] ) ) {
            $where[]  = 'p.batch_id = %d';
            $params[] = (int) $f['batch_id'];
        }
        if ( ! empty( $f['status'] ) ) {
            // Whitelist statuses (avoid arbitrary value injection at SQL level)
            $allowed = array(
                'reserved','in_pool','allocated_to_order','shipped','registered',
                'claimed','replaced','transferred','voided','recalled',
                'reserved_for_legacy','shipped_legacy','cancelled_batch','stolen',
            );
            if ( in_array( $f['status'], $allowed, true ) ) {
                $where[]  = 'p.status = %s';
                $params[] = (string) $f['status'];
            }
        }
        if ( ! empty( $f['since'] ) ) {
            $ts = strtotime( (string) $f['since'] );
            if ( $ts !== false ) {
                $where[]  = '( p.received_at >= %s OR p.registered_at >= %s )';
                $params[] = gmdate( 'Y-m-d H:i:s', $ts );
                $params[] = gmdate( 'Y-m-d H:i:s', $ts );
            }
        }

        // Phone / LINE name require lookup via wp_users / usermeta
        if ( ! empty( $f['phone'] ) ) {
            // Match LINE phone meta (if present) OR billing phone
            $phone_digits = preg_replace( '/\D+/', '', (string) $f['phone'] );
            if ( $phone_digits !== '' ) {
                // Sub-query — find user_ids via usermeta phone fields
                $sub_phone = "SELECT um.user_id FROM {$wpdb->usermeta} um
                              WHERE um.meta_key IN ('billing_phone','dinoco_phone','phone')
                                AND REPLACE(REPLACE(REPLACE(um.meta_value,'-',''),' ',''),'+','') LIKE %s";
                $where[]  = "p.registered_user_id IN ( {$sub_phone} )";
                $params[] = '%' . $wpdb->esc_like( $phone_digits ) . '%';
            }
        }
        if ( ! empty( $f['line'] ) ) {
            $sub_line = "SELECT u.ID FROM {$wpdb->users} u WHERE u.display_name LIKE %s";
            $where[]  = "p.registered_user_id IN ( {$sub_line} )";
            $params[] = '%' . $wpdb->esc_like( (string) $f['line'] ) . '%';
        }
        if ( ! empty( $f['order_id'] ) ) {
            // Defensive: pool_meta MIGHT have order_id column; skip if missing
            if ( $meta_tbl ) {
                $cols = $wpdb->get_col( "DESCRIBE {$meta_tbl}", 0 );
                if ( is_array( $cols ) && in_array( 'order_id', $cols, true ) ) {
                    $where[]  = 'm.order_id = %d';
                    $params[] = (int) $f['order_id'];
                }
            }
        }
        if ( ! empty( $f['actor_login'] ) ) {
            // Resolve via audit log: SN had any audit row by this actor
            if ( dinoco_sn_table_exists( 'audit' ) ) {
                $audit_tbl = dinoco_sn_table( 'audit' );
                $sub_actor = "SELECT DISTINCT a.sn FROM {$audit_tbl} a
                              INNER JOIN {$wpdb->users} u ON u.ID = a.actor_user_id
                              WHERE u.user_login = %s OR u.display_name = %s";
                $where[]  = "p.sn IN ( {$sub_actor} )";
                $params[] = (string) $f['actor_login'];
                $params[] = (string) $f['actor_login'];
            }
        }

        // Free-text fallback search across sn + sku
        if ( ! empty( $parsed['free_text'] ) ) {
            $val_esc = $wpdb->esc_like( strtoupper( (string) $parsed['free_text'] ) );
            $where[]  = '( p.sn LIKE %s OR p.linked_sku LIKE %s )';
            $params[] = '%' . $val_esc . '%';
            $params[] = '%' . $val_esc . '%';
        }

        $where_sql = $where ? ( 'WHERE ' . implode( ' AND ', $where ) ) : '';
        $join_meta = $meta_tbl ? "LEFT JOIN {$meta_tbl} m ON m.sn = p.sn" : '';

        $sql = "SELECT p.sn, p.batch_id, p.linked_sku, p.status,
                       p.registered_user_id, p.registered_warranty_id,
                       p.registered_at, p.received_at,
                       b.batch_code
                FROM {$pool} p
                LEFT JOIN {$batches} b ON b.id = p.batch_id
                {$join_meta}
                {$where_sql}
                ORDER BY p.received_at DESC, p.sn ASC
                LIMIT %d";
        $params[] = $limit;

        $rows = $params
            ? $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A )
            : $wpdb->get_results( $sql, ARRAY_A );
        if ( ! is_array( $rows ) ) return array();

        // Enrich w/ display_name + masked phone (best-effort)
        $user_ids = array_unique( array_filter( array_map(
            function( $r ) { return (int) ( $r['registered_user_id'] ?? 0 ); },
            $rows
        ) ) );
        $names = array();
        $phones = array();
        if ( $user_ids ) {
            $ph = implode( ',', array_fill( 0, count( $user_ids ), '%d' ) );
            $u_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT ID, display_name FROM {$wpdb->users} WHERE ID IN ( {$ph} )",
                $user_ids
            ), ARRAY_A );
            foreach ( (array) $u_rows as $u ) {
                $names[ (int) $u['ID'] ] = (string) $u['display_name'];
            }
            // Phones from usermeta (best-effort)
            $ph_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT user_id, meta_value FROM {$wpdb->usermeta}
                 WHERE user_id IN ( {$ph} )
                   AND meta_key IN ('billing_phone','dinoco_phone','phone')",
                $user_ids
            ), ARRAY_A );
            foreach ( (array) $ph_rows as $pr ) {
                $uid = (int) $pr['user_id'];
                if ( ! isset( $phones[ $uid ] ) && ! empty( $pr['meta_value'] ) ) {
                    $phones[ $uid ] = (string) $pr['meta_value'];
                }
            }
        }

        $enriched = array_map( function( $r ) use ( $names, $phones ) {
            $uid = (int) ( $r['registered_user_id'] ?? 0 );
            $r['customer_display_name'] = $uid && isset( $names[ $uid ] ) ? $names[ $uid ] : null;
            $r['customer_phone_masked'] = $uid && isset( $phones[ $uid ] )
                ? dinoco_sn_mask_phone_for_display( $phones[ $uid ] )
                : '—';
            return $r;
        }, $rows );

        return $enriched;
    }
}

if ( ! function_exists( 'dinoco_sn_get_timeline_for_sn' ) ) {
    /**
     * Investigation timeline — full audit history for a single S/N.
     *
     * @param string $sn      Uppercase S/N
     * @param int    $limit   Max rows (1..200, default 50)
     * @return array<array>   Rows with id, event_type, status_from, status_to,
     *                        actor_display, approver_display, reason,
     *                        reason_category, created_at, is_sensitive,
     *                        context (decoded JSON)
     */
    function dinoco_sn_get_timeline_for_sn( $sn, $limit = 50 ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) {
            return array();
        }
        $sn = strtoupper( trim( (string) $sn ) );
        if ( $sn === '' ) return array();
        $limit = max( 1, min( 200, (int) $limit ) );

        global $wpdb;
        $tbl = dinoco_sn_table( 'audit' );
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, event_type, status_from, status_to, actor_user_id,
                    approver_user_id, reason, reason_category, context_json,
                    ip_address, is_sensitive, created_at
             FROM {$tbl}
             WHERE sn = %s
             ORDER BY created_at DESC, id DESC
             LIMIT %d",
            $sn, $limit
        ), ARRAY_A );

        if ( ! is_array( $rows ) ) return array();

        // Resolve user display names with cache
        $user_ids = array();
        foreach ( $rows as $r ) {
            foreach ( array( 'actor_user_id', 'approver_user_id' ) as $field ) {
                if ( ! empty( $r[ $field ] ) ) $user_ids[] = (int) $r[ $field ];
            }
        }
        $user_ids = array_unique( array_filter( $user_ids ) );
        $names = array();
        if ( $user_ids ) {
            $ph = implode( ',', array_fill( 0, count( $user_ids ), '%d' ) );
            $u_rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT ID, display_name FROM {$wpdb->users} WHERE ID IN ( {$ph} )",
                $user_ids
            ), ARRAY_A );
            foreach ( (array) $u_rows as $u ) {
                $names[ (int) $u['ID'] ] = (string) $u['display_name'];
            }
        }

        return array_map( function( $r ) use ( $names ) {
            $r['actor_display'] = ! empty( $r['actor_user_id'] )
                && isset( $names[ (int) $r['actor_user_id'] ] )
                ? $names[ (int) $r['actor_user_id'] ]
                : ( ! empty( $r['actor_user_id'] ) ? 'user#' . (int) $r['actor_user_id'] : '—' );
            $r['approver_display'] = ! empty( $r['approver_user_id'] )
                && isset( $names[ (int) $r['approver_user_id'] ] )
                ? $names[ (int) $r['approver_user_id'] ]
                : ( ! empty( $r['approver_user_id'] ) ? 'user#' . (int) $r['approver_user_id'] : null );
            $r['context'] = ! empty( $r['context_json'] ) ? json_decode( $r['context_json'], true ) : null;
            unset( $r['context_json'] );
            return $r;
        }, $rows );
    }
}

