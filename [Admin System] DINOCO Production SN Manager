if ( ! function_exists( 'dinoco_sn_dispatch_weekly_forecast_flex' ) ) {
    /**
     * Aggregate top urgent SKUs from sn_demand_forecast then push Flex
     * to admin LINE group. Defensive — failure logged via obs_capture,
     * never throws.
     *
     * @param int $urgent_threshold_days Threshold for "urgent" (default 60).
     * @return array Result {sent: bool, urgent_count: int, total_skus: int, error?: string}
     */
    function dinoco_sn_dispatch_weekly_forecast_flex( int $urgent_threshold_days = 60 ): array {
        $result = array( 'sent' => false, 'urgent_count' => 0, 'total_skus' => 0 );
        try {
            if ( ! function_exists( 'dinoco_sn_table_exists' )
              || ! dinoco_sn_table_exists( 'demand_forecast' ) ) {
                $result['error'] = 'forecast_table_missing';
                return $result;
            }
            global $wpdb;
            $tbl = dinoco_sn_table( 'demand_forecast' );

            // Aggregate per-SKU latest snapshot (use most recent computed_at row per sku).
            // Heuristic: average predicted_qty across forecast horizon represents
            // expected monthly consumption.
            $rows = $wpdb->get_results(
                "SELECT sku,
                        MIN(current_pool_qty)            AS current_pool_qty,
                        AVG(predicted_qty)               AS avg_predicted,
                        SUM(suggested_order_qty)         AS total_suggested,
                        MAX(computed_at)                 AS computed_at
                 FROM {$tbl}
                 GROUP BY sku
                 ORDER BY total_suggested DESC
                 LIMIT 200",
                ARRAY_A
            );

            $enriched = array();
            $total_skus = 0;
            $total_suggested_qty = 0;
            $urgent = array();

            foreach ( $rows ?: array() as $r ) {
                $total_skus++;
                $avg_monthly = max( 0.0, (float) $r['avg_predicted'] );
                $pool        = (int) $r['current_pool_qty'];
                $sugg        = (int) $r['total_suggested'];
                $total_suggested_qty += $sugg;

                $days = ( $avg_monthly > 0 )
                    ? (int) floor( ( $pool / $avg_monthly ) * 30 )
                    : null;

                $entry = array(
                    'sku'                       => (string) $r['sku'],
                    'current_pool_qty'          => $pool,
                    'avg_consumption_per_month' => (int) round( $avg_monthly ),
                    'days_until_empty'          => $days,
                    'suggested_order_qty'       => $sugg,
                );
                $enriched[] = $entry;
                if ( $days !== null && $days <= $urgent_threshold_days ) {
                    $urgent[] = $entry;
                }
            }

            // Sort urgent by days asc (least days first = most urgent)
            usort( $urgent, function( $a, $b ) {
                $da = $a['days_until_empty'] === null ? PHP_INT_MAX : $a['days_until_empty'];
                $db = $b['days_until_empty'] === null ? PHP_INT_MAX : $b['days_until_empty'];
                return $da - $db;
            } );

            $totals = array(
                'total_skus'          => $total_skus,
                'urgent_count'        => count( $urgent ),
                'total_suggested_qty' => $total_suggested_qty,
            );
            $result['urgent_count'] = $totals['urgent_count'];
            $result['total_skus']   = $total_skus;

            $flex = dinoco_sn_build_weekly_forecast_flex( $urgent, $totals );

            // Push to admin group (defensive)
            if ( function_exists( 'b2b_send_flex_message' ) && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
                @b2b_send_flex_message(
                    B2B_ADMIN_GROUP_ID,
                    'รายงาน Demand Forecast ประจำสัปดาห์',
                    $flex
                );
                $result['sent'] = true;
            } else {
                $result['error'] = 'b2b_send_flex_message_unavailable';
            }
        } catch ( \Throwable $e ) {
            $result['error'] = $e->getMessage();
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_weekly_forecast_flex' ) );
            }
        }
        return $result;
    }
}

