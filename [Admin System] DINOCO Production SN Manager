if ( ! function_exists( 'dinoco_sn_run_ltv_snapshot' ) ) {
    /**
     * Phase 3 W10 — F#9 Customer LTV snapshot
     * Daily 03:00 — aggregate per user_id from sn_pool + B2B orders.
     *
     * Aggregation per user:
     *   - plates_count: COUNT(*) all sn_pool with this registered_user_id
     *   - registered_count: COUNT WHERE status='registered'
     *   - active_warranties_count: COUNT WHERE status IN registered/claimed
     *   - claim_count: COUNT WHERE status IN claimed/replaced
     *   - total_lifetime_spent: best-effort B2B order sum (if helper exists)
     *   - first_purchase_date / last_purchase_date: MIN/MAX(registered_at)
     *   - loyalty_tier: bucketed via compute_loyalty_tier
     *
     * Performance: chunked by user_id range (LIMIT 500/iter ×40 iter cap =
     * 20K users/run worst case). For 100K+ user base, schedule slow_run
     * variant or external cron tick.
     *
     * Idempotent: full snapshot rebuild via INSERT ... ON DUPLICATE KEY
     * UPDATE → safe to re-run same day.
     */
    function dinoco_sn_run_ltv_snapshot() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'ltv_snapshot' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $ltv  = dinoco_sn_table( 'ltv_snapshot' );

            $aggregated = 0;
            $last_user_id = 0;
            $cap = 40;

            for ( $i = 0; $i < $cap; $i++ ) {
                $batch = $wpdb->get_results( $wpdb->prepare(
                    "SELECT registered_user_id AS user_id,
                            COUNT(*)                                                                 AS plates_count,
                            SUM(CASE WHEN status = 'registered' THEN 1 ELSE 0 END)                   AS registered_count,
                            SUM(CASE WHEN status IN ('registered', 'claimed') THEN 1 ELSE 0 END)     AS active_warranties_count,
                            SUM(CASE WHEN status IN ('claimed', 'replaced')  THEN 1 ELSE 0 END)      AS claim_count,
                            MIN(registered_at)                                                       AS first_purchase_date,
                            MAX(registered_at)                                                       AS last_purchase_date
                     FROM {$pool}
                     WHERE registered_user_id IS NOT NULL
                       AND registered_user_id > %d
                     GROUP BY registered_user_id
                     ORDER BY registered_user_id ASC
                     LIMIT 500",
                    $last_user_id
                ), ARRAY_A );

                if ( ! $batch ) break;
                foreach ( $batch as $row ) {
                    $user_id = (int) $row['user_id'];
                    if ( $user_id === 0 ) continue;
                    $last_user_id = max( $last_user_id, $user_id );

                    // Best-effort B2B order spend (graceful degrade if helper missing)
                    $total_spent = 0.0;
                    if ( function_exists( 'b2b_get_user_lifetime_spend' ) ) {
                        $total_spent = (float) b2b_get_user_lifetime_spend( $user_id );
                    }

                    $tier = dinoco_sn_compute_loyalty_tier( $total_spent );
                    $first_date = $row['first_purchase_date']
                        ? date( 'Y-m-d', strtotime( $row['first_purchase_date'] ) )
                        : null;
                    $last_date = $row['last_purchase_date']
                        ? date( 'Y-m-d', strtotime( $row['last_purchase_date'] ) )
                        : null;

                    // INSERT ... ON DUPLICATE KEY UPDATE — full overwrite per run
                    $wpdb->query( $wpdb->prepare(
                        "INSERT INTO {$ltv}
                            (user_id, plates_count, registered_count, active_warranties_count,
                             total_lifetime_spent, first_purchase_date, last_purchase_date,
                             claim_count, loyalty_tier, computed_at)
                         VALUES (%d, %d, %d, %d, %f, %s, %s, %d, %s, %s)
                         ON DUPLICATE KEY UPDATE
                            plates_count            = VALUES(plates_count),
                            registered_count        = VALUES(registered_count),
                            active_warranties_count = VALUES(active_warranties_count),
                            total_lifetime_spent    = VALUES(total_lifetime_spent),
                            first_purchase_date     = VALUES(first_purchase_date),
                            last_purchase_date      = VALUES(last_purchase_date),
                            claim_count             = VALUES(claim_count),
                            loyalty_tier            = VALUES(loyalty_tier),
                            computed_at             = VALUES(computed_at)",
                        $user_id,
                        (int) $row['plates_count'],
                        (int) $row['registered_count'],
                        (int) $row['active_warranties_count'],
                        $total_spent,
                        $first_date,
                        $last_date,
                        (int) $row['claim_count'],
                        $tier,
                        current_time( 'mysql' )
                    ) );
                    $aggregated++;
                }
                if ( count( $batch ) < 500 ) break;
                usleep( 50000 ); // 50ms gap between batches
            }

            update_option( 'dinoco_sn_ltv_snapshot_last_run', array(
                'at'         => current_time( 'mysql' ),
                'aggregated' => $aggregated,
                'last_user'  => $last_user_id,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_ltv_snapshot' ) );
            }
        }

        update_option( 'dinoco_cron_sn_ltv_snapshot_last_run', current_time( 'mysql' ) );
    }
}

