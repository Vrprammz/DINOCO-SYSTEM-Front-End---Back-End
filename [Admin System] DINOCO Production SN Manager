if ( ! function_exists( 'dinoco_sn_build_flex_for_notification' ) ) {
    /**
     * Dispatcher — pick the right builder based on notification_type +
     * decode meta_json context. Returns null if type unknown.
     *
     * Used by `dinoco_sn_run_notification_send` cron (Phase 4 W9).
     * Unit-testable via SnFlexTemplateTest fixture.
     */
    function dinoco_sn_build_flex_for_notification( $notification_type, $meta_json = '', $extra = array() ) {
        $type = strtolower( (string) $notification_type );
        $ctx  = is_array( $meta_json ) ? $meta_json : array();
        if ( is_string( $meta_json ) && strlen( $meta_json ) > 0 ) {
            $decoded = json_decode( $meta_json, true );
            if ( is_array( $decoded ) ) $ctx = array_merge( $ctx, $decoded );
        }
        if ( is_array( $extra ) ) $ctx = array_merge( $ctx, $extra );

        // Phase 5 W18.3 V.0.34 — Auto-inject extension_url for expiry/anniversary
        // notifications when F#8 Marketplace is enabled AND target SKU has at least
        // one extension price configured. Customer Flex card gets "🔄 ต่อประกัน"
        // CTA leading to LIFF /warranty/extend?sn=<SN>.
        //
        // Defensive: never throws. If marketplace OFF or SKU has no pricing →
        // ctx['extension_url'] stays whatever caller provided (or empty).
        if ( empty( $ctx['extension_url'] )
             && ! empty( $ctx['sn'] )
             && ( strpos( $type, 'expiry_' ) === 0 || strpos( $type, 'anniversary_' ) === 0 ) ) {
            try {
                $mp_enabled = (bool) get_option( 'dinoco_sn_marketplace_enabled', 0 );
                if ( $mp_enabled && function_exists( 'dinoco_sn_extension_available' ) ) {
                    // Need SKU to check availability — derive from sn → linked_sku
                    $sku = (string) ( $ctx['linked_sku'] ?? '' );
                    if ( empty( $sku ) && function_exists( 'dinoco_sn_get_pool_row' ) ) {
                        $row = @dinoco_sn_get_pool_row( (string) $ctx['sn'] );
                        if ( is_array( $row ) ) {
                            $sku = (string) ( $row['linked_sku'] ?? '' );
                        } elseif ( is_object( $row ) ) {
                            $sku = (string) ( $row->linked_sku ?? '' );
                        }
                    }
                    if ( ! empty( $sku ) && @dinoco_sn_extension_available( $sku ) ) {
                        // Prefer LIFF URL for in-LINE-app navigation
                        $ctx['extension_url'] = function_exists( 'dinoco_sn_build_warranty_url' )
                            ? dinoco_sn_build_warranty_url( 'extend', (string) $ctx['sn'], true )
                            : home_url( '/warranty/extend?sn=' . rawurlencode( (string) $ctx['sn'] ) );
                    }
                }
            } catch ( \Throwable $e ) {
                // Defensive: don't break Flex render on auto-inject failure
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    @dinoco_obs_capture( $e, array( 'context' => 'sn_flex_extension_url_inject' ) );
                }
            }
        }

        // Map type → builder
        if ( strpos( $type, 'expiry_' ) === 0 ) {
            // expiry_30d / expiry_7d / expiry_1d — derive days_left from suffix
            if ( ! isset( $ctx['days_left'] ) ) {
                if ( preg_match( '/expiry_(\d+)d/', $type, $m ) ) {
                    $ctx['days_left'] = (int) $m[1];
                }
            }
            return dinoco_sn_build_flex_expiry( $ctx );
        }
        if ( strpos( $type, 'anniversary_' ) === 0 ) {
            // anniversary_1y / 2y / 3y / 4y / 5y
            if ( ! isset( $ctx['years'] ) ) {
                if ( preg_match( '/anniversary_(\d+)y/', $type, $m ) ) {
                    $ctx['years'] = (int) $m[1];
                }
            }
            return dinoco_sn_build_flex_anniversary( $ctx );
        }
        if ( $type === 'review_request' ) {
            return dinoco_sn_build_flex_review_request( $ctx );
        }
        return null;
    }
}

/**
 * R9 Pattern 4 — Flag-aware cron registration helper.
 *
 * Problem: 43 wp_schedule_event() hooks across DINOCO have NO unschedule
 * mechanism. When feature flags flip OFF (e.g., dinoco_sn_system_enabled=0),
 * crons keep firing forever — burning DB writes, LINE quota, and observability
 * ingest budget. Only Q21 fraud_aggregate had defensive unschedule (V.0.40).
 *
 * Solution: Reusable wrapper that combines schedule-if-flag-on,
 * unschedule-if-flag-off, AND auto-cleanup on flag flip via update_option
 * action listener. Works alongside existing dinoco_register_cron() heartbeat
 * (Round 28 pattern from Health Monitor) — does NOT replace it; both can be
 * called for the same hook.
 *
 * Usage:
 *   dinoco_register_flag_aware_cron(
 *       'dinoco_sn_low_pool_alert_cron',
 *       'hourly',
 *       'dinoco_sn_system_enabled'
 *   );
 *
 * Behaviour matrix:
 *   flag enabled  + not scheduled → wp_schedule_event
 *   flag enabled  + scheduled     → no-op
 *   flag disabled + scheduled     → wp_unschedule_event (CLEANUP)
 *   flag disabled + not scheduled → no-op
 *   $master_flag === null         → always treat as enabled
 *
 * Pairs with dinoco_sn_reevaluate_crons() listener registered on
 * update_option_dinoco_sn_system_enabled — when admin flips flag from 1 → 0,
 * next admin_init pass auto-cleans the 4 wrapped crons within minutes.
 *
 * R9 Pattern 4 scope: applies to 4 SN crons (low_pool_alert, audit_retention,
 * notification_send, marketplace_timeout) + 1 Push Governance retention cron.
 * Other 38 hooks remain on legacy schedule-only pattern — future rounds will
 * migrate per priority.
 */
if ( ! function_exists( 'dinoco_register_flag_aware_cron' ) ) {
    function dinoco_register_flag_aware_cron( $hook, $interval, $master_flag = null ) {
        if ( ! is_string( $hook ) || $hook === '' ) {
            return false;
        }
        if ( ! is_string( $interval ) || $interval === '' ) {
            return false;
        }
        // function_exists guard: WP scheduler may be unavailable in CLI/early boot
        if ( ! function_exists( 'wp_next_scheduled' ) || ! function_exists( 'wp_schedule_event' ) ) {
            return false;
        }

        $is_enabled = ( $master_flag === null )
            ? true
            : (bool) get_option( $master_flag, false );
        $next = wp_next_scheduled( $hook );

        if ( $is_enabled ) {
            if ( ! $next ) {
                wp_schedule_event( time() + 60, $interval, $hook );
            }
        } else {
            // Defensive cleanup — only unschedule if actually scheduled
            if ( $next ) {
                wp_unschedule_event( $next, $hook );
                // Belt & suspenders: clear ALL future occurrences in case multiple
                // were registered (shouldn't happen, but cheap insurance)
                wp_clear_scheduled_hook( $hook );
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( 'info', '[cron] flag-aware unschedule', array(
                        'hook'        => $hook,
                        'master_flag' => $master_flag,
                        'reason'      => 'flag_disabled',
                    ) );
                }
            }
        }

        return $is_enabled;
    }
}

/**
 * R9 Pattern 4 — Re-evaluate all SN flag-aware crons.
 *
 * Called by:
 *   - update_option_dinoco_sn_system_enabled action (when admin flips flag)
 *   - Initial init bootstrap (idempotent — already gated by wp_next_scheduled)
 *
 * Hook list synced with the inline call sites in the init block below.
 * If you wire a new cron via dinoco_register_flag_aware_cron, ALSO add it to
 * this list so flag-flip cleanup catches it.
 */
if ( ! function_exists( 'dinoco_sn_reevaluate_flag_aware_crons' ) ) {
    function dinoco_sn_reevaluate_flag_aware_crons() {
        if ( ! function_exists( 'wp_get_schedules' ) ) {
            return;
        }
        $sched = wp_get_schedules();
        $hooks = array(
            'dinoco_sn_low_pool_alert_cron'    => 'hourly',
            'dinoco_sn_audit_retention_cron'   => 'daily',
            'dinoco_sn_notification_send_cron' => isset( $sched['fifteen_minutes'] ) ? 'fifteen_minutes' : 'hourly',
            'dinoco_sn_marketplace_timeout_cron' => isset( $sched['five_minutes'] ) ? 'five_minutes'
                : ( isset( $sched['fifteen_minutes'] ) ? 'fifteen_minutes' : 'hourly' ),
        );
        foreach ( $hooks as $hook => $interval ) {
            dinoco_register_flag_aware_cron( $hook, $interval, 'dinoco_sn_system_enabled' );
        }
    }
}

// Auto-cleanup on flag flip — fires when admin toggles dinoco_sn_system_enabled
