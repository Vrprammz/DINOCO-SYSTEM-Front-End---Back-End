/* ═══════════════════════════════════════════════════════════════════════════
 * 5. HIERARCHY RESOLVER (V.0.2 — Phase 1 W2 Day 3)
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * ตอบคำถาม: "1 ชุด {SKU X} ต้องใช้ plate กี่ใบ + ที่ระดับไหน?"
 *
 * ตามที่บอสยกตัวอย่าง:
 *   DNC4537SETGNDPRO002 (sn_attach_level=leaf) → 4 plates (1 ต่อ leaf)
 *   DNCSETNX500EIRNB    (sn_attach_level=child) → 2 plates (children, ข้าม grandchildren)
 *   SET-level                                   → 1 plate ที่ SET เอง
 *   SKU sn_attach_level=none                    → 0 plates
 *
 * Pattern: V.7.1 fix C2 — value-copy $visited per branch + array_unique dedup (DD-3 safe)
 */

if ( ! function_exists( 'dinoco_sn_required_plates_for_sku' ) ) {
    /**
     * Compute plate requirement for a SKU at given quantity.
     *
     * @param string $sku SKU to compute (case-sensitive, will UPPER)
     * @param int    $qty Quantity ordered (default 1)
     * @return array Array of { sku, qty } pairs OR [] if no plates needed
     *
     * Examples:
     *   dinoco_sn_required_plates_for_sku('DNC4537SETGNDPRO002', 1)
     *   → [
     *       ['sku' => 'DNCGND45L002',    'qty' => 1],
     *       ['sku' => 'DNCGNDPROS500',  'qty' => 1],
     *       ['sku' => 'DNCGNDPROT500',  'qty' => 1],
     *       ['sku' => 'DNCGND37LS',      'qty' => 1],
     *     ]
     *
     *   dinoco_sn_required_plates_for_sku('DNCSETNX500EIRNB', 2)
     *   → [
     *       ['sku' => 'DNCNX500E002IRONB', 'qty' => 2],
     *       ['sku' => 'DNCNX500001IRONB',  'qty' => 2],
     *     ]
     */
    function dinoco_sn_required_plates_for_sku( $sku, $qty = 1 ) {
        $sku = strtoupper( trim( (string) $sku ) );
        $qty = max( 1, (int) $qty );

        if ( $sku === '' ) return array();

        // Read sn_attach_level from wp_dinoco_products (Phase 1 W2 ALTER)
        $attach_level = dinoco_sn_get_attach_level_for_sku( $sku );
        $sn_qty_per_unit = dinoco_sn_get_qty_per_unit_for_sku( $sku );

        if ( $attach_level === 'none' || $attach_level === '' ) {
            return array();
        }

        if ( $attach_level === 'set' ) {
            // Single plate at SET level
            return array(
                array(
                    'sku' => $sku,
                    'qty' => $qty * max( 1, $sn_qty_per_unit ),
                ),
            );
        }

        // 'child' or 'leaf' — walk down hierarchy
        $target_level = ( $attach_level === 'child' ) ? 'child' : 'leaf';
        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) || empty( $relations ) ) {
            return array();
        }

        $nodes = dinoco_sn_walk_to_level( $sku, $target_level, $relations );
        if ( empty( $nodes ) ) return array();

        // Apply qty multiplier
        $result = array();
        $seen = array(); // DD-3: shared leaf may appear under multiple parents — dedup
        foreach ( $nodes as $node ) {
            $node_sku = $node['sku'];
            if ( isset( $seen[ $node_sku ] ) ) continue; // dedup (V.7.1 array_unique pattern)
            $seen[ $node_sku ] = true;
            $result[] = array(
                'sku' => $node_sku,
                'qty' => $qty * max( 1, (int) $node['qty_per_set'] ),
            );
        }

        return $result;
    }
}

if ( ! function_exists( 'dinoco_sn_walk_to_level' ) ) {
    /**
     * Recursive walk from $start_sku down to nodes at $target_level.
     *
     * V.7.1 C2 fix pattern: pass $visited by VALUE per branch (NOT reference)
     * to prevent DD-3 shared-child detection loss.
     *
     * @param string $start_sku    Starting SKU
     * @param string $target_level 'child' or 'leaf'
     * @param array  $relations    dinoco_sku_relations wp_option
     * @param array  $visited      (internal) circular-ref guard, value-copy per branch
     * @param int    $depth        (internal) max depth 3
     * @return array Array of { sku, qty_per_set, level }
     */
    function dinoco_sn_walk_to_level( $start_sku, $target_level, $relations, $visited = array(), $depth = 0 ) {
        if ( $depth > 3 ) return array(); // DD-4 max depth guard
        if ( in_array( $start_sku, $visited, true ) ) return array(); // circular ref

        // value-copy $visited per branch (V.7.1 critical)
        $visited[] = $start_sku;

        $children = isset( $relations[ $start_sku ] ) ? $relations[ $start_sku ] : array();
        if ( empty( $children ) ) {
            // Leaf reached
            if ( $target_level === 'leaf' ) {
                return array(
                    array( 'sku' => $start_sku, 'qty_per_set' => 1, 'level' => 'leaf' ),
                );
            }
            return array();
        }

        $results = array();
        foreach ( $children as $child_sku ) {
            $child_sku = strtoupper( trim( (string) $child_sku ) );
            if ( $child_sku === '' ) continue;

            // Determine if this child is at the target level
            $child_has_grandchildren = ! empty( $relations[ $child_sku ] ?? array() );

            if ( $target_level === 'child' && $child_has_grandchildren ) {
                // child level + has grandchildren = stop here (don't walk deeper)
                $results[] = array( 'sku' => $child_sku, 'qty_per_set' => 1, 'level' => 'child' );
            } elseif ( $target_level === 'child' && ! $child_has_grandchildren ) {
                // child level + no grandchildren = treat as child anyway
                $results[] = array( 'sku' => $child_sku, 'qty_per_set' => 1, 'level' => 'child' );
            } elseif ( $target_level === 'leaf' && ! $child_has_grandchildren ) {
                // leaf level + this is leaf
                $results[] = array( 'sku' => $child_sku, 'qty_per_set' => 1, 'level' => 'leaf' );
            } elseif ( $target_level === 'leaf' && $child_has_grandchildren ) {
                // leaf level + child has grandchildren = recurse
                $sub = dinoco_sn_walk_to_level( $child_sku, 'leaf', $relations, $visited, $depth + 1 );
                $results = array_merge( $results, $sub );
            }
        }

        return $results;
    }
}

if ( ! function_exists( 'dinoco_sn_get_attach_level_for_sku' ) ) {
    /**
     * Read sn_attach_level from wp_dinoco_products. Returns 'none' if SKU
     * not found or column doesn't exist (graceful before ALTER applied).
     */
    function dinoco_sn_get_attach_level_for_sku( $sku ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';

        // Check column exists (defensive — ALTER may not have applied yet)
        static $column_exists = null;
        if ( $column_exists === null ) {
            $column_exists = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.columns
                 WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                DB_NAME, $tbl, 'sn_attach_level'
            ) );
        }
        if ( ! $column_exists ) return 'none';

        $val = $wpdb->get_var( $wpdb->prepare(
            "SELECT sn_attach_level FROM {$tbl} WHERE sku = %s",
            strtoupper( $sku )
        ) );

        return $val ?: 'none';
    }
}

if ( ! function_exists( 'dinoco_sn_get_qty_per_unit_for_sku' ) ) {
    function dinoco_sn_get_qty_per_unit_for_sku( $sku ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';

        static $column_exists = null;
        if ( $column_exists === null ) {
            $column_exists = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.columns
                 WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                DB_NAME, $tbl, 'sn_qty_per_unit'
            ) );
        }
        if ( ! $column_exists ) return 1;

        $val = $wpdb->get_var( $wpdb->prepare(
            "SELECT sn_qty_per_unit FROM {$tbl} WHERE sku = %s",
            strtoupper( $sku )
        ) );

        return $val ? max( 1, (int) $val ) : 1;
    }
}

if ( ! function_exists( 'dinoco_sn_set_attach_level' ) ) {
    /**
     * Update sn_attach_level + sn_required + sn_qty_per_unit per SKU.
     * Used by Admin Inventory UI (Phase 1 W3) when admin configures SKU.
     */
    function dinoco_sn_set_attach_level( $sku, $level, $required = false, $qty_per_unit = 1 ) {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';

        $sku = strtoupper( trim( (string) $sku ) );
        $level = in_array( $level, array( 'set', 'child', 'leaf', 'none' ), true ) ? $level : 'none';
        $required = $required ? 1 : 0;
        $qty_per_unit = max( 1, min( 99, (int) $qty_per_unit ) );

        $ok = $wpdb->update( $tbl,
            array(
                'sn_attach_level' => $level,
                'sn_required'     => $required,
                'sn_qty_per_unit' => $qty_per_unit,
            ),
            array( 'sku' => $sku ),
            array( '%s', '%d', '%d' ),
            array( '%s' )
        );

        return $ok !== false;
    }
}

if ( ! function_exists( 'dinoco_sn_preflight_check_batch' ) ) {
    /**
     * Phase 1 W4.2 — Pre-flight check before sending batch to factory.
     *
     * Validates:
     *   - All target SKUs have sn_attach_level ≠ 'none' + sn_required=1
     *   - Hierarchy resolves cleanly (no circular ref + max depth 3)
     *   - Plate count makes sense (qty * sn_qty_per_unit > 0)
     *   - top_set_sku resolvable for customer-facing display (DD-6)
     *   - No collision with existing batch sequences
     *
     * Returns structured report admin can review before confirming batch.
     *
     * @param array $skus_with_qty Array of {sku, qty}
     * @param int   $batch_qty Total plate count requested in batch
     * @return array {
     *   ok: bool,
     *   warnings: [{ sku, code, message }],
     *   errors: [{ sku, code, message }],
     *   plates_required_total: int,
     *   plates_per_sku: [{ sku, qty, hierarchy: [...] }]
     * }
     */
    function dinoco_sn_preflight_check_batch( $skus_with_qty, $batch_qty ) {
        $report = array(
            'ok'                    => true,
            'warnings'              => array(),
            'errors'                => array(),
            'plates_required_total' => 0,
            'plates_per_sku'        => array(),
        );

        if ( ! is_array( $skus_with_qty ) || empty( $skus_with_qty ) ) {
            $report['ok'] = false;
            $report['errors'][] = array(
                'sku'     => '',
                'code'    => 'no_skus',
                'message' => 'ต้องระบุอย่างน้อย 1 SKU',
            );
            return $report;
        }

        $batch_qty = max( 1, (int) $batch_qty );
        $total_plates_needed = 0;

        foreach ( $skus_with_qty as $entry ) {
            $sku = isset( $entry['sku'] ) ? strtoupper( trim( (string) $entry['sku'] ) ) : '';
            $qty = isset( $entry['qty'] ) ? max( 1, (int) $entry['qty'] ) : 1;

            if ( $sku === '' ) {
                $report['errors'][] = array(
                    'sku'     => '',
                    'code'    => 'empty_sku',
                    'message' => 'SKU ว่าง',
                );
                $report['ok'] = false;
                continue;
            }

            // Check sn_attach_level
            $attach = dinoco_sn_get_attach_level_for_sku( $sku );
            if ( $attach === 'none' || $attach === '' ) {
                $report['errors'][] = array(
                    'sku'     => $sku,
                    'code'    => 'sku_attach_level_none',
                    'message' => sprintf( 'SKU %s ตั้ง sn_attach_level=none — ห้ามสร้าง plate ให้ SKU นี้', $sku ),
                );
                $report['ok'] = false;
                continue;
            }

            // Resolve hierarchy
            $required = dinoco_sn_required_plates_for_sku( $sku, $qty );
            if ( empty( $required ) ) {
                $report['warnings'][] = array(
                    'sku'     => $sku,
                    'code'    => 'no_plates_resolved',
                    'message' => sprintf( 'SKU %s ไม่มีลูก/หลานที่ resolve ได้ — ตรวจ dinoco_sku_relations', $sku ),
                );
                continue;
            }

            // Compute plate count
            $sku_plate_count = 0;
            foreach ( $required as $req ) {
                $sku_plate_count += (int) $req['qty'];
            }
            $total_plates_needed += $sku_plate_count;

            $report['plates_per_sku'][] = array(
                'sku'             => $sku,
                'qty_units'       => $qty,
                'attach_level'    => $attach,
                'plates_required' => $sku_plate_count,
                'hierarchy'       => $required,
            );

            // Warn if hierarchy too deep (DD-4)
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( is_array( $relations ) && ! empty( $relations ) ) {
                $depth = dinoco_sn_compute_hierarchy_depth( $sku, $relations );
                if ( $depth > 3 ) {
                    $report['warnings'][] = array(
                        'sku'     => $sku,
                        'code'    => 'depth_exceeds_max',
                        'message' => sprintf( 'SKU %s hierarchy depth=%d เกิน DD-4 max 3', $sku, $depth ),
                    );
                }
            }
        }

        $report['plates_required_total'] = $total_plates_needed;

        // Check batch_qty matches
        if ( $batch_qty < $total_plates_needed ) {
            $report['warnings'][] = array(
                'sku'     => '',
                'code'    => 'batch_qty_too_small',
                'message' => sprintf( 'batch_qty=%d น้อยกว่า plates ที่ต้องการ=%d', $batch_qty, $total_plates_needed ),
            );
        }

        return $report;
    }
}

if ( ! function_exists( 'dinoco_sn_compute_hierarchy_depth' ) ) {
    /**
     * Compute max depth of SKU hierarchy. Pure-logic helper for pre-flight check.
     */
    function dinoco_sn_compute_hierarchy_depth( $sku, $relations, $visited = array(), $depth = 0 ) {
        if ( $depth > 5 ) return $depth; // safety cap (V.7.1 pattern)
        $sku = strtoupper( trim( (string) $sku ) );
        if ( in_array( $sku, $visited, true ) ) return $depth; // circular ref
        $visited[] = $sku;

        $children = isset( $relations[ $sku ] ) && is_array( $relations[ $sku ] )
            ? $relations[ $sku ]
            : array();

        if ( empty( $children ) ) return $depth;

        $max_child = $depth;
        foreach ( $children as $child ) {
            // value-copy $visited per branch (DD-3 pattern)
            $child_depth = dinoco_sn_compute_hierarchy_depth( $child, $relations, $visited, $depth + 1 );
            if ( $child_depth > $max_child ) $max_child = $child_depth;
        }
        return $max_child;
    }
}

if ( ! function_exists( 'dinoco_sn_obs_capture' ) ) {
    /**
     * Phase 1 W4.2 — Wrapper around dinoco_obs_capture for sensitive S/N ops.
     * Defensive: no-op if Observability snippet not synced yet.
     *
     * Use at top of every:
     *   - batch creation
     *   - bulk receive
     *   - customer activate
     *   - swap/void/recall
     *
     * Captures structured context for Sentry/log aggregation.
     */
    function dinoco_sn_obs_capture( $event, $context = array() ) {
        if ( ! function_exists( 'dinoco_obs_capture' ) ) return; // Observability not loaded
        $tag = 'sn_' . sanitize_key( $event );
        $payload = array(
            'event' => $tag,
            'time'  => current_time( 'c' ),
            'user'  => get_current_user_id(),
        );
        if ( is_array( $context ) ) {
            $payload = array_merge( $payload, $context );
        }
        try {
            dinoco_obs_capture( null, $payload );
        } catch ( \Throwable $e ) {
            // Best-effort — never throw from observability
            error_log( '[SN-Obs] capture failed: ' . $e->getMessage() );
        }
    }
}

