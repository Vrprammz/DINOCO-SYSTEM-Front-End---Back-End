            /* Phase 4 W13 — F#16 Demand Forecast handlers */
            window.dncSnLoadForecast = function() {
                var summary  = document.getElementById('dnc-sn-forecast-summary');
                var critWrap = document.getElementById('dnc-sn-forecast-critical');
                var fullWrap = document.getElementById('dnc-sn-forecast-full');
                var critTbody = document.querySelector('#dnc-sn-forecast-critical-table tbody');
                var fullTbody = document.querySelector('#dnc-sn-forecast-full-table tbody');
                if (summary) summary.textContent = 'Loading forecast…';

                fetch(REST_BASE + '/forecast/all', {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data || !Array.isArray(data.skus)) {
                        if (summary) summary.textContent = 'No forecast data';
                        return;
                    }
                    var critical = data.skus.filter(function(s) {
                        return (s.days_until_empty != null) && (s.days_until_empty <= 60);
                    });
                    var allRows = data.skus;

                    // Summary line
                    if (summary) {
                        summary.innerHTML =
                            'SKUs: <strong>' + allRows.length + '</strong>' +
                            ' · Critical (≤60 วัน): <strong style="color:#dc2626">' + critical.length + '</strong>' +
                            ' · Updated: ' + (data.computed_at ? fmtDate(data.computed_at) : '—');
                    }

                    // Render critical table
                    if (critical.length > 0) {
                        critWrap.style.display = 'block';
                        critTbody.innerHTML = critical.map(function(s) {
                            var dayCol = s.days_until_empty != null
                                ? '<strong style="color:#dc2626">' + s.days_until_empty + ' วัน</strong>'
                                : '—';
                            var sugg = s.suggested_order_qty != null
                                ? '<strong>' + s.suggested_order_qty.toLocaleString('th-TH') + '</strong>'
                                : '—';
                            return '<tr>' +
                                '<td><code>' + escapeHtml(s.sku) + '</code></td>' +
                                '<td>' + ((s.current_pool_qty || 0).toLocaleString('th-TH')) + '</td>' +
                                '<td>' + (s.avg_consumption_per_month || 0) + '</td>' +
