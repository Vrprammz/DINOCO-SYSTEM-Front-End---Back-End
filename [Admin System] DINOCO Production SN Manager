            window.dncSnSubmitPasteReceive = function() {
                var batchSel = document.getElementById('dnc-sn-receive-batch');
                var batch_id = parseInt(batchSel.value || '0');
                var sku = (document.getElementById('dnc-sn-receive-sku').value || '').toUpperCase().trim();
                var raw = document.getElementById('dnc-sn-paste-list').value || '';

                if (!batch_id || !sku) { alert('กรุณากรอกข้อมูลให้ครบ'); return; }

                var sns = raw.split(/[\s,]+/)
                    .map(function(s) { return s.toUpperCase().trim(); })
                    .filter(function(s) { return s.match(/^[A-Z0-9]{8,16}$/); });
                sns = Array.from(new Set(sns)); // dedup

                if (!sns.length) { alert('ไม่พบ S/N ที่ถูกต้อง'); return; }
                submitBulkReceive(batch_id, sku, sns, 'paste');
            };

            window.dncSnScanKeydown = function(event) {
                if (event.key !== 'Enter') return;
                event.preventDefault();
                var input = event.target;
                var sn = (input.value || '').toUpperCase().trim();
                if (!sn.match(/^[A-Z0-9]{8,16}$/)) {
                    input.value = '';
                    return;
                }
                var batchSel = document.getElementById('dnc-sn-receive-batch');
                var batch_id = parseInt(batchSel.value || '0');
                var sku = (document.getElementById('dnc-sn-receive-sku').value || '').toUpperCase().trim();
                if (!batch_id || !sku) { alert('เลือก batch + SKU ก่อน'); return; }

                input.value = '';
                input.focus();

                // Single receive
                fetch(REST_BASE + '/receive', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': NONCE,
                        'X-Idempotency-Key': crypto.randomUUID(),
                    },
                    body: JSON.stringify({ sn: sn, linked_sku: sku, batch_id: batch_id }),
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, body: j }; }); })
                .then(function(res) {
                    addRecentScan(sn, res.ok ? 'ok' : 'error', res.ok ? 'received' : (res.body.code || 'error'));
                });
            };

            function submitBulkReceive(batch_id, sku, sns, mode) {
                // Chunks of 100 if >100
                var CHUNK = 100;
                var chunks = [];
                for (var i = 0; i < sns.length; i += CHUNK) {
                    chunks.push(sns.slice(i, i + CHUNK));
                }

                var totalSuccess = 0, totalSkip = 0;
                var promises = chunks.map(function(chunk) {
                    return fetch(REST_BASE + '/receive/bulk', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-WP-Nonce': NONCE,
                            'X-Idempotency-Key': crypto.randomUUID(),
                        },
                        body: JSON.stringify({
                            batch_id: batch_id,
                            linked_sku: sku,
                            sns: chunk,
                            mode: mode,
                        }),
                        credentials: 'same-origin',
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(res) {
                        if (res.success_count !== undefined) {
                            totalSuccess += res.success_count;
                            totalSkip += res.skip_count;
                            (res.results || []).forEach(function(r) {
                                addRecentScan(r.sn, r.status === 'ok' ? 'ok' : 'error', r.code);
                            });
                        }
                    });
                });

                Promise.all(promises).then(function() {
                    alert('รับเสร็จ: ' + totalSuccess + ' สำเร็จ · ' + totalSkip + ' skip');
                });
            }

            var sessionScans = [];
            function addRecentScan(sn, status, code) {
                sessionScans.unshift({ sn: sn, status: status, code: code, time: new Date() });
                if (sessionScans.length > 50) sessionScans = sessionScans.slice(0, 50);
                renderRecentScans();
            }

            function renderRecentScans() {
                document.getElementById('dnc-sn-session-count').textContent = sessionScans.filter(function(s) { return s.status === 'ok'; }).length;
                var listEl = document.getElementById('dnc-sn-recent-list');
                if (!sessionScans.length) {
                    listEl.innerHTML = '<div style="color:#9ca3af;font-size:13px;">ยังไม่มีรายการ</div>';
                    return;
                }
                listEl.innerHTML = sessionScans.slice(0, 10).map(function(s) {
                    var icon = s.status === 'ok' ? '✅' : '❌';
                    var ago = Math.round((Date.now() - s.time.getTime()) / 1000) + 's ago';
                    return '<div class="dnc-sn-scan-row">' + icon + ' ' + escapeHtml(s.sn) + ' <span style="color:#9ca3af;margin-left:auto;">' + escapeHtml(s.code) + ' · ' + ago + '</span></div>';
                }).join('');
            }

