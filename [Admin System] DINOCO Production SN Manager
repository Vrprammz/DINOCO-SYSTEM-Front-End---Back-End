if ( ! function_exists( 'dinoco_sn_alter_pool_sig_bucket_columns' ) ) {
    /**
     * V.0.43 R4 BLOCKER #1 — ADD sn_pool.sig_bucket + idx_sig_bucket on
     * existing installs. Idempotent INFORMATION_SCHEMA precheck per item.
     *
     * Pairs with REST API V.0.32 HMAC V2 (batch-bucket binding). New batches
     * populate sig_bucket on INSERT; backfill of existing batches deferred
     * to maintenance script (out of scope for this fix — Phase 1 only has
     * pilot data so the legacy V1-fallback in verify() is sufficient).
     *
     * Caller (schema_install) holds GET_LOCK so safe vs concurrent installs.
     */
    function dinoco_sn_alter_pool_sig_bucket_columns() {
        global $wpdb;
        $prefix = $wpdb->prefix;
        $tbl_pool = $prefix . 'dinoco_sn_pool';

        // Skip if table doesn't exist yet (first-install path goes through dbDelta)
        $tbl_exists = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl_pool
        ) );
        if ( ! $tbl_exists ) return;

        // 1) ADD COLUMN sig_bucket if missing
        $col_exists = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.columns
             WHERE table_schema = %s AND table_name = %s AND column_name = %s",
            DB_NAME, $tbl_pool, 'sig_bucket'
        ) );
        if ( ! $col_exists ) {
            // Position after batch_id per spec ("AFTER batch_id") — keeps
            // hot-path columns clustered in the table physical order.
            $sql_add = "ALTER TABLE {$tbl_pool} ADD COLUMN sig_bucket SMALLINT UNSIGNED DEFAULT NULL AFTER batch_id";
            $ok = $wpdb->query( $sql_add );
            if ( $ok === false && function_exists( 'b2b_log' ) ) {
                b2b_log( '[SN-Schema] ALTER ADD sig_bucket failed: ' . $wpdb->last_error );
            }
        }

        // 2) ADD KEY idx_sig_bucket if missing
        $idx_exists = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.statistics
             WHERE table_schema = %s AND table_name = %s AND index_name = %s",
            DB_NAME, $tbl_pool, 'idx_sig_bucket'
        ) );
        if ( ! $idx_exists ) {
            // Re-check column actually exists post-ADD (in case ALTER above
            // failed) before attempting index creation — failing index ADD
            // pollutes wpdb->last_error and noisy logs.
            $col_now = (bool) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.columns
                 WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                DB_NAME, $tbl_pool, 'sig_bucket'
            ) );
            if ( $col_now ) {
                $sql_idx = "ALTER TABLE {$tbl_pool} ADD KEY idx_sig_bucket (batch_id, sig_bucket)";
                $ok = $wpdb->query( $sql_idx );
                if ( $ok === false && function_exists( 'b2b_log' ) ) {
                    b2b_log( '[SN-Schema] ALTER ADD KEY idx_sig_bucket failed: ' . $wpdb->last_error );
                }
            }
        }
    }
}

