if ( ! function_exists( 'dinoco_sn_run_low_pool_alert' ) ) {
    /**
     * Hourly low-pool alert. Threshold 30-day demand forecast per linked_sku.
     * Phase 3 W8 stub: simple count threshold (Phase 4 W13 forecast integration).
     */
    function dinoco_sn_run_low_pool_alert() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) return;

        // Guard: dedup 1hr
        if ( get_transient( 'dinoco_sn_low_pool_alert_lock' ) ) return;
        set_transient( 'dinoco_sn_low_pool_alert_lock', 1, HOUR_IN_SECONDS - 60 );

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'pool' );
            $threshold = (int) get_option( 'dinoco_sn_low_pool_threshold', 30 );

            $low = $wpdb->get_results( $wpdb->prepare(
                "SELECT linked_sku, COUNT(*) AS in_pool_qty
                 FROM {$tbl}
                 WHERE status = 'in_pool' AND linked_sku IS NOT NULL AND linked_sku != ''
                 GROUP BY linked_sku
                 HAVING in_pool_qty < %d
                 ORDER BY in_pool_qty ASC
                 LIMIT 50",
                $threshold
            ), ARRAY_A );

            if ( $low ) {
                update_option( 'dinoco_sn_low_pool_last_alert', array(
                    'at'    => current_time( 'mysql' ),
                    'count' => count( $low ),
                    'top'   => array_slice( $low, 0, 10 ),
                ), false );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_low_pool_alert' ) );
            }
        }

        // Heartbeat for Health Monitor (per Round 28 dinoco_register_cron pattern)
        update_option( 'dinoco_cron_sn_low_pool_alert_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_run_audit_retention' ) ) {
    /**
     * Daily 03:30 — chunked delete sn_audit > 5 years (PDPA §17 financial
     * fraud retention). Sensitive ops (is_sensitive=1) keep 5y; non-sensitive
     * keep 3y per v2.4 SHOULD-FIX #5 ux-ui-expert review.
     *
     * Chunked 1000/iter × 20 iter cap to avoid OOM on huge tables.
     */
    function dinoco_sn_run_audit_retention() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) return;

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'audit' );
            $deleted = 0;
            $cap = 20;
            $cutoff_5y = gmdate( 'Y-m-d H:i:s', time() - 5 * 365 * 86400 );
            $cutoff_3y = gmdate( 'Y-m-d H:i:s', time() - 3 * 365 * 86400 );

            for ( $i = 0; $i < $cap; $i++ ) {
                // Sensitive rows: 5y retention
                $sensitive_del = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl}
                     WHERE is_sensitive = 1 AND created_at < %s
                     LIMIT 500",
                    $cutoff_5y
                ) );
                // Non-sensitive: 3y retention
                $nonsensitive_del = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl}
                     WHERE is_sensitive = 0 AND created_at < %s
                     LIMIT 500",
                    $cutoff_3y
                ) );
                $batch = (int) $sensitive_del + (int) $nonsensitive_del;
                $deleted += $batch;
                if ( $batch === 0 ) break;
                usleep( 50000 ); // 50ms gap to avoid hammering DB
            }

            update_option( 'dinoco_sn_audit_retention_last_run', array(
                'at'      => current_time( 'mysql' ),
                'deleted' => $deleted,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_audit_retention' ) );
            }
        }

        update_option( 'dinoco_cron_sn_audit_retention_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_run_batch_reconcile' ) ) {
    /**
     * Weekly batch reconcile — verify sn_batches.qty_received matches
     * actual COUNT in sn_pool grouped by batch_id. Drift > 0 → write
     * `dinoco_sn_batch_drift_report` option for admin review.
     */
    function dinoco_sn_run_batch_reconcile() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'batches' ) || ! dinoco_sn_table_exists( 'pool' ) ) return;

        try {
            global $wpdb;
            $batches = dinoco_sn_table( 'batches' );
            $pool    = dinoco_sn_table( 'pool' );

            $drifts = $wpdb->get_results(
                "SELECT b.id AS batch_id, b.batch_code,
                        b.qty_received AS reported,
                        COUNT( CASE WHEN p.status NOT IN ('reserved') THEN 1 END ) AS actual,
                        ABS( b.qty_received - COUNT( CASE WHEN p.status NOT IN ('reserved') THEN 1 END ) ) AS drift
                 FROM {$batches} b
                 LEFT JOIN {$pool} p ON p.batch_id = b.id
                 WHERE b.status NOT IN ('cancelled', 'closed')
                 GROUP BY b.id, b.batch_code, b.qty_received
                 HAVING drift > 0
                 ORDER BY drift DESC
                 LIMIT 100",
                ARRAY_A
            );

            update_option( 'dinoco_sn_batch_drift_report', array(
                'at'     => current_time( 'mysql' ),
                'count'  => $drifts ? count( $drifts ) : 0,
                'rows'   => $drifts ?: array(),
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_batch_reconcile' ) );
            }
        }

        update_option( 'dinoco_cron_sn_batch_reconcile_last_run', current_time( 'mysql' ) );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 12. PHASE 3 W9 — F#1 EXPIRY REMINDER (additive 2026-05-05)
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * 2 cron jobs:
 *   dinoco_sn_expiry_schedule_cron   daily 02:00 — enqueue expiry notifications
 *                                     (status='scheduled', NO LINE push yet)
 *   dinoco_sn_notification_send_cron  every 15 min — send queued (when boss
 *                                     flips dinoco_sn_notification_send_enabled)
 *
 * Master gate: dinoco_sn_notification_send_enabled (default '0').
 * When OFF: schedule cron still enqueues rows for visibility, but send cron
 * is a no-op. This lets boss verify the queue + answer Q21 (LINE Premium tier)
 * before going live.
 *
 * Default warranty period: 1 year from registered_at (configurable per-SKU
 * via wp_dinoco_products.warranty_years — Phase 4 W9). For Phase 3 W9 stub:
 * use option dinoco_sn_default_warranty_years (default 1).
 *
 * Anti-spam dedup: notification_type + user_id + sn unique index — same
 * combo cannot be scheduled twice (handled via INSERT IGNORE in helper).
 *
 * Reference: v2.13 §F.1 + §K.7
 */

if ( ! function_exists( 'dinoco_sn_warranty_end_for_pool_row' ) ) {
    /**
     * Compute warranty end date for a sn_pool row.
     * Returns DateTime or null if not registered.
     *
     * Phase 3 W9 stub: registered_at + N years (default 1, override via option).
     * Phase 4 W9: read warranty_years from linked SKU + extension records.
     */
    function dinoco_sn_warranty_end_for_pool_row( $row ) {
        $registered_at = is_array( $row ) ? ( $row['registered_at'] ?? null ) : ( $row->registered_at ?? null );
        if ( empty( $registered_at ) ) return null;
        $years = (int) get_option( 'dinoco_sn_default_warranty_years', 1 );
        if ( $years < 1 ) $years = 1;
        try {
            $start = new \DateTime( $registered_at, wp_timezone() );
            $start->modify( '+' . $years . ' years' );
            return $start;
        } catch ( \Throwable $e ) {
            return null;
        }
    }
}

if ( ! function_exists( 'dinoco_sn_schedule_notification' ) ) {
    /**
     * Insert notification row idempotent — composite check on
     * (notification_type, user_id, sn) prevents duplicate scheduling.
     *
     * Returns true if inserted, false if dup or invalid.
     */
    function dinoco_sn_schedule_notification( $sn, $user_id, $notif_type, $scheduled_at, $meta = array() ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'notifications' ) ) {
            return false;
        }
        $sn = strtoupper( trim( (string) $sn ) );
        $user_id = (int) $user_id;
        $notif_type = sanitize_key( $notif_type );
        if ( $sn === '' || $user_id <= 0 || $notif_type === '' || ! $scheduled_at ) {
            return false;
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'notifications' );

        // V.0.11 audit fix (P0-4): UNIQUE KEY uniq_dedup enforces dedup
        // at DB level. INSERT IGNORE skips silently on duplicate. App-level
        // SELECT-first race window eliminated.
        // Use direct query (wpdb->insert escapes but doesn't support IGNORE).
        $sql = $wpdb->prepare(
            "INSERT IGNORE INTO {$tbl}
                (sn, user_id, notification_type, channel, scheduled_at, status, meta_json, created_at)
             VALUES (%s, %d, %s, %s, %s, %s, %s, %s)",
            $sn,
            $user_id,
            $notif_type,
            'line_flex',
            $scheduled_at,
            'scheduled',
            wp_json_encode( $meta ),
            current_time( 'mysql' )
        );
        $rows = $wpdb->query( $sql );
        // INSERT IGNORE: rows = 1 if inserted, 0 if dup, false on real error
        return $rows === 1;
    }
}

if ( ! function_exists( 'dinoco_sn_run_expiry_schedule' ) ) {
    /**
     * Daily 02:00 — scan registered plates approaching expiry and enqueue
     * 3 notifications per plate: expiry_30d, expiry_7d, expiry_1d.
     *
     * Idempotent: helper dedups by (type, user_id, sn). Re-running same day
     * is safe (same rows already exist → skipped).
     *
     * Phase 3 W9 stub:
     *   - 1-year warranty default (Phase 4 W9 reads SKU.warranty_years)
     *   - Skip plates with status NOT IN ('registered', 'claimed')
     *   - LIMIT 5000 plates per run to avoid OOM at 1M+ rows
     */
    function dinoco_sn_run_expiry_schedule() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $years = max( 1, (int) get_option( 'dinoco_sn_default_warranty_years', 1 ) );

            // Fetch rows whose computed warranty_end ∈ [now, now+30d]
            // Window includes 30/7/1 day milestones so single query covers all.
            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, registered_user_id, registered_at, linked_sku
                 FROM {$pool}
                 WHERE status IN ('registered', 'claimed')
                   AND registered_user_id IS NOT NULL
                   AND registered_at IS NOT NULL
                   AND registered_at >= DATE_SUB(NOW(), INTERVAL %d YEAR)
                   AND DATE_ADD(registered_at, INTERVAL %d YEAR)
                       BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 DAY)
                 ORDER BY registered_at ASC
                 LIMIT 5000",
                $years, $years
            ), ARRAY_A );

            $scheduled = 0;
            $skipped = 0;
            $milestones = array(
                'expiry_30d' => 30,
                'expiry_7d'  => 7,
                'expiry_1d'  => 1,
            );

            foreach ( $rows ?: array() as $row ) {
                $end = dinoco_sn_warranty_end_for_pool_row( $row );
                if ( ! $end ) { $skipped++; continue; }
                foreach ( $milestones as $type => $days ) {
                    $send_at = clone $end;
                    $send_at->modify( '-' . $days . ' days' );
                    // Skip if already past send window
                    if ( $send_at->getTimestamp() < time() - 86400 ) continue;

                    $ok = dinoco_sn_schedule_notification(
                        $row['sn'],
                        (int) $row['registered_user_id'],
                        $type,
                        $send_at->format( 'Y-m-d H:i:s' ),
                        array(
                            'linked_sku'    => $row['linked_sku'],
                            'warranty_end'  => $end->format( 'Y-m-d' ),
                            'days_to_expiry' => $days,
                        )
                    );
                    if ( $ok ) $scheduled++; else $skipped++;
                }
            }

            update_option( 'dinoco_sn_expiry_schedule_last_run', array(
                'at'        => current_time( 'mysql' ),
                'scanned'   => count( $rows ?: array() ),
                'scheduled' => $scheduled,
                'skipped'   => $skipped,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_expiry_schedule' ) );
            }
        }

        update_option( 'dinoco_cron_sn_expiry_schedule_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_compute_loyalty_tier' ) ) {
    /**
     * Phase 3 W10 — F#9 LTV bucketing (v2.9 spec).
     * Pure-function (testable). Thresholds in THB.
     *
     *   diamond  ฿100,000+
     *   platinum ฿50,000-100,000
     *   gold     ฿20,000-50,000
     *   silver   ฿5,000-20,000
     *   bronze   <฿5,000 (default)
     */
    function dinoco_sn_compute_loyalty_tier( $total_spent ) {
        $spent = (float) $total_spent;
        if ( $spent >= 100000 ) return 'diamond';
        if ( $spent >= 50000 )  return 'platinum';
        if ( $spent >= 20000 )  return 'gold';
        if ( $spent >= 5000 )   return 'silver';
        return 'bronze';
    }
}

if ( ! function_exists( 'dinoco_sn_run_ltv_snapshot' ) ) {
    /**
     * Phase 3 W10 — F#9 Customer LTV snapshot
     * Daily 03:00 — aggregate per user_id from sn_pool + B2B orders.
     *
     * Aggregation per user:
     *   - plates_count: COUNT(*) all sn_pool with this registered_user_id
     *   - registered_count: COUNT WHERE status='registered'
     *   - active_warranties_count: COUNT WHERE status IN registered/claimed
     *   - claim_count: COUNT WHERE status IN claimed/replaced
     *   - total_lifetime_spent: best-effort B2B order sum (if helper exists)
     *   - first_purchase_date / last_purchase_date: MIN/MAX(registered_at)
     *   - loyalty_tier: bucketed via compute_loyalty_tier
     *
     * Performance: chunked by user_id range (LIMIT 500/iter ×40 iter cap =
     * 20K users/run worst case). For 100K+ user base, schedule slow_run
     * variant or external cron tick.
     *
     * Idempotent: full snapshot rebuild via INSERT ... ON DUPLICATE KEY
     * UPDATE → safe to re-run same day.
     */
    function dinoco_sn_run_ltv_snapshot() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'ltv_snapshot' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $ltv  = dinoco_sn_table( 'ltv_snapshot' );

            $aggregated = 0;
            $last_user_id = 0;
            $cap = 40;

            for ( $i = 0; $i < $cap; $i++ ) {
                $batch = $wpdb->get_results( $wpdb->prepare(
                    "SELECT registered_user_id AS user_id,
                            COUNT(*)                                                                 AS plates_count,
                            SUM(CASE WHEN status = 'registered' THEN 1 ELSE 0 END)                   AS registered_count,
                            SUM(CASE WHEN status IN ('registered', 'claimed') THEN 1 ELSE 0 END)     AS active_warranties_count,
                            SUM(CASE WHEN status IN ('claimed', 'replaced')  THEN 1 ELSE 0 END)      AS claim_count,
                            MIN(registered_at)                                                       AS first_purchase_date,
                            MAX(registered_at)                                                       AS last_purchase_date
                     FROM {$pool}
                     WHERE registered_user_id IS NOT NULL
                       AND registered_user_id > %d
                     GROUP BY registered_user_id
                     ORDER BY registered_user_id ASC
                     LIMIT 500",
                    $last_user_id
                ), ARRAY_A );

                if ( ! $batch ) break;
                foreach ( $batch as $row ) {
                    $user_id = (int) $row['user_id'];
                    if ( $user_id === 0 ) continue;
                    $last_user_id = max( $last_user_id, $user_id );

                    // Best-effort B2B order spend (graceful degrade if helper missing)
                    $total_spent = 0.0;
                    if ( function_exists( 'b2b_get_user_lifetime_spend' ) ) {
                        $total_spent = (float) b2b_get_user_lifetime_spend( $user_id );
                    }

                    $tier = dinoco_sn_compute_loyalty_tier( $total_spent );
                    $first_date = $row['first_purchase_date']
                        ? date( 'Y-m-d', strtotime( $row['first_purchase_date'] ) )
                        : null;
                    $last_date = $row['last_purchase_date']
                        ? date( 'Y-m-d', strtotime( $row['last_purchase_date'] ) )
                        : null;

                    // INSERT ... ON DUPLICATE KEY UPDATE — full overwrite per run
                    $wpdb->query( $wpdb->prepare(
                        "INSERT INTO {$ltv}
                            (user_id, plates_count, registered_count, active_warranties_count,
                             total_lifetime_spent, first_purchase_date, last_purchase_date,
                             claim_count, loyalty_tier, computed_at)
                         VALUES (%d, %d, %d, %d, %f, %s, %s, %d, %s, %s)
                         ON DUPLICATE KEY UPDATE
                            plates_count            = VALUES(plates_count),
                            registered_count        = VALUES(registered_count),
                            active_warranties_count = VALUES(active_warranties_count),
                            total_lifetime_spent    = VALUES(total_lifetime_spent),
                            first_purchase_date     = VALUES(first_purchase_date),
                            last_purchase_date      = VALUES(last_purchase_date),
                            claim_count             = VALUES(claim_count),
                            loyalty_tier            = VALUES(loyalty_tier),
                            computed_at             = VALUES(computed_at)",
                        $user_id,
                        (int) $row['plates_count'],
                        (int) $row['registered_count'],
                        (int) $row['active_warranties_count'],
                        $total_spent,
                        $first_date,
                        $last_date,
                        (int) $row['claim_count'],
                        $tier,
                        current_time( 'mysql' )
                    ) );
                    $aggregated++;
                }
                if ( count( $batch ) < 500 ) break;
                usleep( 50000 ); // 50ms gap between batches
            }

            update_option( 'dinoco_sn_ltv_snapshot_last_run', array(
                'at'         => current_time( 'mysql' ),
                'aggregated' => $aggregated,
                'last_user'  => $last_user_id,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_ltv_snapshot' ) );
            }
        }

        update_option( 'dinoco_cron_sn_ltv_snapshot_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_run_anniversary_schedule' ) ) {
    /**
     * Phase 3 W9 — F#4 Anniversary push
     * Daily 09:00 — find plates registered exactly N years ago today.
     *
     * Anniversary types (capped at 5 to avoid noise):
     *   anniversary_1y / 2y / 3y / 4y / 5y
     *
     * Reuses dinoco_sn_schedule_notification dedup. send_at = now()
     * (anniversary today) so notification_send cron picks it up next tick.
     *
     * Multi-plate same day same user = each plate = separate row. Phase 4
     * may bundle into 1 Flex (group_by user_id) at send time.
     */
    function dinoco_sn_run_anniversary_schedule() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $today = current_time( 'Y-m-d' );
            $now = current_time( 'mysql' );

            $scheduled = 0;
            for ( $years = 1; $years <= 5; $years++ ) {
                // Match plates registered exactly N years ago today
                $rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT sn, registered_user_id, linked_sku, registered_at
                     FROM {$pool}
                     WHERE status IN ('registered', 'claimed')
                       AND registered_user_id IS NOT NULL
                       AND DATE(registered_at) = DATE_SUB(%s, INTERVAL %d YEAR)
                     LIMIT 5000",
                    $today, $years
                ), ARRAY_A );

                foreach ( $rows ?: array() as $row ) {
                    $ok = dinoco_sn_schedule_notification(
                        $row['sn'],
                        (int) $row['registered_user_id'],
                        'anniversary_' . $years . 'y',
                        $now,
                        array(
                            'linked_sku' => $row['linked_sku'],
                            'years'      => $years,
                            'registered_at' => $row['registered_at'],
                        )
                    );
                    if ( $ok ) $scheduled++;
                }
            }

            update_option( 'dinoco_sn_anniversary_schedule_last_run', array(
                'at'        => $now,
                'scheduled' => $scheduled,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_anniversary_schedule' ) );
            }
        }

        update_option( 'dinoco_cron_sn_anniversary_schedule_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_run_review_request_schedule' ) ) {
    /**
     * Phase 3 W9 — F#10 Review Request
     * Daily 10:00 — find plates registered exactly 30 days ago.
     *
     * Skip-if-claim guard: don't pester unhappy customer. Check claim_ticket
     * CPT (existing Service Center system). If any open claim for this user
     * → skip review request.
     *
     * Anti-spam: dedup ensures one review_request per (user, sn). If customer
     * misses + 7 day → no retry (don't pester per v2.13 §F.10 Edge Cases).
     */
    function dinoco_sn_run_review_request_schedule() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $today = current_time( 'Y-m-d' );
            $now = current_time( 'mysql' );

            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, registered_user_id, linked_sku, registered_at
                 FROM {$pool}
                 WHERE status = 'registered'
                   AND registered_user_id IS NOT NULL
                   AND DATE(registered_at) = DATE_SUB(%s, INTERVAL 30 DAY)
                 LIMIT 1000",
                $today
            ), ARRAY_A );

            $scheduled = 0;
            $skipped_claim = 0;

            // Pre-compute users with open claims (cheap dedup vs N+1)
            $user_ids = array_unique( array_filter( array_map( function( $r ) {
                return (int) ( $r['registered_user_id'] ?? 0 );
            }, $rows ?: array() ) ) );

            $users_with_open_claim = array();
            if ( $user_ids ) {
                // Existing Service Center claim_ticket CPT — open if status NOT in completed/closed/rejected/cancelled
                // V.0.11 audit fix (P0-3 + P1-4): use proper placeholders for both
                // user_ids AND status enum (was raw {$closed_in} interpolation).
                $closed_statuses = array( 'completed', 'closed', 'rejected', 'cancelled' );
                $user_ph    = implode( ',', array_fill( 0, count( $user_ids ), '%d' ) );
                $status_ph  = implode( ',', array_fill( 0, count( $closed_statuses ), '%s' ) );

                $sql = "SELECT DISTINCT p.post_author
                        FROM {$wpdb->posts} p
                        LEFT JOIN {$wpdb->postmeta} m ON m.post_id = p.ID AND m.meta_key = 'ticket_status'
                        WHERE p.post_type = 'claim_ticket'
                          AND p.post_status = 'publish'
                          AND p.post_author IN ({$user_ph})
                          AND ( m.meta_value IS NULL OR m.meta_value NOT IN ({$status_ph}) )";

                $args = array_merge( array_map( 'intval', $user_ids ), $closed_statuses );
                $cpt_users = $wpdb->get_col( $wpdb->prepare( $sql, $args ) );
                if ( is_array( $cpt_users ) ) {
                    $users_with_open_claim = array_flip( array_map( 'intval', $cpt_users ) );
                }
            }

            foreach ( $rows ?: array() as $row ) {
                $uid = (int) $row['registered_user_id'];
                if ( isset( $users_with_open_claim[ $uid ] ) ) {
                    $skipped_claim++;
                    continue;
                }
                $ok = dinoco_sn_schedule_notification(
                    $row['sn'],
                    $uid,
                    'review_request',
                    $now,
                    array(
                        'linked_sku'    => $row['linked_sku'],
                        'registered_at' => $row['registered_at'],
                    )
                );
                if ( $ok ) $scheduled++;
            }

            update_option( 'dinoco_sn_review_request_last_run', array(
                'at'             => $now,
                'scanned'        => count( $rows ?: array() ),
                'scheduled'      => $scheduled,
                'skipped_claim'  => $skipped_claim,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_review_request' ) );
            }
        }

        update_option( 'dinoco_cron_sn_review_request_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_run_notification_send' ) ) {
    /**
     * Every 15 min — process scheduled notifications past send time.
     *
     * Phase 3 W9 STUB: gated by dinoco_sn_notification_send_enabled (default 0).
     * When OFF: log skip + heartbeat only (visibility for boss).
     * When ON: dequeue + dispatch via b2b_send_flex_message helper (LINE
     * push) + update status='sent' or 'failed' with error in meta_json.
     *
     * Boss must answer Q21 (LINE Premium tier budget ฿1,500/mo) before
     * flipping ON to avoid quota burn.
     *
     * Rate limit: max 50 sends per run (LINE quota safety per v2.12 §B2).
     */
    function dinoco_sn_run_notification_send() {
        update_option( 'dinoco_cron_sn_notification_send_last_run', current_time( 'mysql' ) );

        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        $send_enabled = (bool) get_option( 'dinoco_sn_notification_send_enabled', false );
        if ( ! $send_enabled ) {
            // Stub mode — record visibility only, no actual push
            return;
        }

        // Phase 4 implementation hook — actual send logic
        // Stub for now: dequeue + log (no push)
        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'notifications' );
            $now = current_time( 'mysql' );

            $batch = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, sn, user_id, notification_type, meta_json
                 FROM {$tbl}
                 WHERE status = 'scheduled' AND scheduled_at <= %s
                 ORDER BY scheduled_at ASC
                 LIMIT 50",
                $now
            ), ARRAY_A );

            foreach ( $batch ?: array() as $n ) {
                // Phase 4 W9: dispatch via b2b_send_flex_message + Flex builder
                // For Phase 3 W9 stub: mark as 'pending_dispatch' so admin can audit
                $wpdb->update( $tbl, array(
                    'status'  => 'pending_dispatch',
                    'sent_at' => $now,
                ), array( 'id' => (int) $n['id'] ) );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_notification_send' ) );
            }
        }
    }
}

// Cron registration via registry wrapper (Round 28 pattern with fallback)
add_action( 'init', function() {
    if ( ! wp_next_scheduled( 'dinoco_sn_low_pool_alert_cron' ) ) {
        wp_schedule_event( time(), 'hourly', 'dinoco_sn_low_pool_alert_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_sn_audit_retention_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_sn_audit_retention_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_sn_batch_reconcile_cron' ) ) {
        wp_schedule_event( time(), 'weekly', 'dinoco_sn_batch_reconcile_cron' );
    }
    // Phase 3 W9 — F#1 Expiry Reminder
    if ( ! wp_next_scheduled( 'dinoco_sn_expiry_schedule_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_sn_expiry_schedule_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_sn_notification_send_cron' ) ) {
        // Use 'fifteen_minutes' if registered (B2B Snippet 1) or fallback hourly
        $sched = wp_get_schedules();
        $recurrence = isset( $sched['fifteen_minutes'] ) ? 'fifteen_minutes' : 'hourly';
        wp_schedule_event( time(), $recurrence, 'dinoco_sn_notification_send_cron' );
    }
    // Phase 3 W9 — F#4 Anniversary + F#10 Review Request
    if ( ! wp_next_scheduled( 'dinoco_sn_anniversary_schedule_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_sn_anniversary_schedule_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_sn_review_request_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_sn_review_request_cron' );
    }
    // Phase 3 W10 — F#9 Customer LTV snapshot
    if ( ! wp_next_scheduled( 'dinoco_sn_ltv_snapshot_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_sn_ltv_snapshot_cron' );
    }

    if ( function_exists( 'dinoco_register_cron' ) ) {
        dinoco_register_cron( 'dinoco_sn_low_pool_alert_cron', 'hourly', 'dinoco_sn_run_low_pool_alert' );
        dinoco_register_cron( 'dinoco_sn_audit_retention_cron', 'daily', 'dinoco_sn_run_audit_retention' );
        dinoco_register_cron( 'dinoco_sn_batch_reconcile_cron', 'weekly', 'dinoco_sn_run_batch_reconcile' );
        dinoco_register_cron( 'dinoco_sn_expiry_schedule_cron', 'daily', 'dinoco_sn_run_expiry_schedule' );
        dinoco_register_cron( 'dinoco_sn_notification_send_cron',
            isset( wp_get_schedules()['fifteen_minutes'] ) ? 'fifteen_minutes' : 'hourly',
            'dinoco_sn_run_notification_send' );
        dinoco_register_cron( 'dinoco_sn_anniversary_schedule_cron', 'daily', 'dinoco_sn_run_anniversary_schedule' );
        dinoco_register_cron( 'dinoco_sn_review_request_cron', 'daily', 'dinoco_sn_run_review_request_schedule' );
        dinoco_register_cron( 'dinoco_sn_ltv_snapshot_cron', 'daily', 'dinoco_sn_run_ltv_snapshot' );
    } else {
        // Fallback when Idempotency Helper / registry wrapper not synced
        if ( ! has_action( 'dinoco_sn_low_pool_alert_cron', 'dinoco_sn_run_low_pool_alert' ) ) {
            add_action( 'dinoco_sn_low_pool_alert_cron', 'dinoco_sn_run_low_pool_alert' );
        }
        if ( ! has_action( 'dinoco_sn_audit_retention_cron', 'dinoco_sn_run_audit_retention' ) ) {
            add_action( 'dinoco_sn_audit_retention_cron', 'dinoco_sn_run_audit_retention' );
        }
        if ( ! has_action( 'dinoco_sn_batch_reconcile_cron', 'dinoco_sn_run_batch_reconcile' ) ) {
            add_action( 'dinoco_sn_batch_reconcile_cron', 'dinoco_sn_run_batch_reconcile' );
        }
        if ( ! has_action( 'dinoco_sn_expiry_schedule_cron', 'dinoco_sn_run_expiry_schedule' ) ) {
            add_action( 'dinoco_sn_expiry_schedule_cron', 'dinoco_sn_run_expiry_schedule' );
        }
        if ( ! has_action( 'dinoco_sn_notification_send_cron', 'dinoco_sn_run_notification_send' ) ) {
            add_action( 'dinoco_sn_notification_send_cron', 'dinoco_sn_run_notification_send' );
        }
        if ( ! has_action( 'dinoco_sn_anniversary_schedule_cron', 'dinoco_sn_run_anniversary_schedule' ) ) {
            add_action( 'dinoco_sn_anniversary_schedule_cron', 'dinoco_sn_run_anniversary_schedule' );
        }
        if ( ! has_action( 'dinoco_sn_review_request_cron', 'dinoco_sn_run_review_request_schedule' ) ) {
            add_action( 'dinoco_sn_review_request_cron', 'dinoco_sn_run_review_request_schedule' );
        }
        if ( ! has_action( 'dinoco_sn_ltv_snapshot_cron', 'dinoco_sn_run_ltv_snapshot' ) ) {
            add_action( 'dinoco_sn_ltv_snapshot_cron', 'dinoco_sn_run_ltv_snapshot' );
        }
    }
} );
