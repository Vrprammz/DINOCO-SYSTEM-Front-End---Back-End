 * 11. PHASE 3 W8 — CRON HEARTBEAT FOUNDATION (additive 2026-05-04)
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * 3 cron jobs:
 *   - dinoco_sn_low_pool_alert_cron      — hourly low-stock alert per SKU
 *   - dinoco_sn_audit_retention_cron     — daily 03:30 chunked delete > 5y
 *   - dinoco_sn_batch_reconcile_cron     — weekly sum drift detect per batch
 *
 * Pattern: dinoco_register_cron() heartbeat (Round 28+ Idempotency Helper)
 * Fallback: plain add_action if registry wrapper not synced.
 * Defensive: all guarded by feature flag dinoco_sn_system_enabled + table_exists.
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_run_low_pool_alert' ) ) {
    /**
     * Hourly low-pool alert. Threshold 30-day demand forecast per linked_sku.
     * Phase 3 W8 stub: simple count threshold (Phase 4 W13 forecast integration).
     */
    function dinoco_sn_run_low_pool_alert() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) return;

        // Guard: dedup 1hr
        if ( get_transient( 'dinoco_sn_low_pool_alert_lock' ) ) return;
        set_transient( 'dinoco_sn_low_pool_alert_lock', 1, HOUR_IN_SECONDS - 60 );

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'pool' );
            $threshold = (int) get_option( 'dinoco_sn_low_pool_threshold', 30 );

            $low = $wpdb->get_results( $wpdb->prepare(
                "SELECT linked_sku, COUNT(*) AS in_pool_qty
                 FROM {$tbl}
                 WHERE status = 'in_pool' AND linked_sku IS NOT NULL AND linked_sku != ''
                 GROUP BY linked_sku
                 HAVING in_pool_qty < %d
                 ORDER BY in_pool_qty ASC
                 LIMIT 50",
                $threshold
            ), ARRAY_A );

            if ( $low ) {
