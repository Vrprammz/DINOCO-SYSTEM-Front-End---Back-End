if ( ! function_exists( 'dinoco_sn_format_thai_date' ) ) {
    /**
     * Format MySQL DATETIME → "4 พ.ค. 2569" (Thai, Buddhist year).
     * Returns empty string on parse fail (defensive — never throws).
     */
    function dinoco_sn_format_thai_date( $mysql_datetime ) {
        if ( empty( $mysql_datetime ) ) return '';
        $ts = strtotime( $mysql_datetime );
        if ( $ts === false ) return '';
        $months = array(
            1 => 'ม.ค.', 2 => 'ก.พ.', 3 => 'มี.ค.', 4 => 'เม.ย.',
            5 => 'พ.ค.', 6 => 'มิ.ย.', 7 => 'ก.ค.', 8 => 'ส.ค.',
            9 => 'ก.ย.', 10 => 'ต.ค.', 11 => 'พ.ย.', 12 => 'ธ.ค.',
        );
        $d = (int) date( 'j', $ts );
        $m = (int) date( 'n', $ts );
        $y = (int) date( 'Y', $ts ) + 543;
        return sprintf( '%d %s %d', $d, $months[ $m ] ?? '?', $y );
    }
}

