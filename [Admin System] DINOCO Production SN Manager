if ( ! function_exists( 'dinoco_sn_marketplace_compute_savings' ) ) {
    /**
     * Compute % savings of a multi-year package vs N × 1y price.
     *
     * Formula:   savings% = (1 − multi_price / (base_1y * years)) × 100
     *
     *   base_1y = 1000, multi (2y) = 1800, years = 2
     *   → naive  = 2000
     *   → saving = 1 − 1800/2000 = 0.10 → 10%
     *
     * Edge cases:
     *   $base_1y NULL or 0     → null  (cannot divide)
     *   $multi_year_price NULL → null  (no offer)
     *   $years not in 2,3      → null  (1y has no savings to itself)
     *   multi > base*years     → 0.0   (no savings, but not an error — clamp)
     *
     * @param float|null $base_1y         The 1-year price (anchor)
     * @param float|null $multi_year_price The N-year price
     * @param int        $years           2 or 3
     * @return float|null Percentage 0..100 (e.g. 18.5 = 18.5%) or null
     */
    function dinoco_sn_marketplace_compute_savings( $base_1y, $multi_year_price, $years ) {
        $years = (int) $years;
        if ( ! in_array( $years, array( 2, 3 ), true ) ) return null;
        if ( $base_1y === null || $base_1y === '' ) return null;
        if ( $multi_year_price === null || $multi_year_price === '' ) return null;
        $base = (float) $base_1y;
        $multi = (float) $multi_year_price;
        if ( $base <= 0 ) return null;
        if ( $multi < 0 ) return null;
        $naive = $base * $years;
        if ( $naive <= 0 ) return null;
        $saving_ratio = 1 - ( $multi / $naive );
        if ( $saving_ratio < 0 ) return 0.0; // multi-year priced HIGHER than naive — clamp 0% (no savings shown)
        if ( $saving_ratio > 1 ) return 100.0; // defensive (shouldn't happen)
        return round( $saving_ratio * 100, 1 );
    }
}

if ( ! function_exists( 'dinoco_sn_marketplace_validate_pricing' ) ) {
    /**
     * Validate a marketplace pricing payload before save.
     *
     * Rules:
     *   - All 3 NULL                       → ok (extensions disabled for SKU)
     *   - Partial NULL                     → ok (e.g. 1y only, or 1y+2y only)
     *   - Negative price                   → reject ("ราคาเป็นลบไม่ได้")
     *   - Price > 1,000,000                → reject ("ราคาเกิน 1M — น่าจะกรอกผิด")
     *   - 2y total < 1y                    → reject ("2y ต้องไม่ถูกกว่า 1y")
     *   - 3y total < 2y total              → reject ("3y ต้องไม่ถูกกว่า 2y")
     *
     * Note "total" means the package price as offered (admin-set). Boss Q8:
     * per-SKU manual pricing → admin chooses absolute amount per duration,
     * not a multiplier. Sanity rule: longer package shouldn't be cheaper
     * than a shorter one (else it's nonsensical to offer 1y).
     *
     * @param array $prices [ 'price_1y' => float|null, 'price_2y' => ..., 'price_3y' => ... ]
     * @return array { ok: bool, errors: string[] }
     */
    function dinoco_sn_marketplace_validate_pricing( $prices ) {
        $errors = array();
        if ( ! is_array( $prices ) ) {
            return array( 'ok' => false, 'errors' => array( 'invalid_payload' ) );
        }

        $normalized = array();
        foreach ( array( 'price_1y', 'price_2y', 'price_3y' ) as $key ) {
            $val = isset( $prices[ $key ] ) ? $prices[ $key ] : null;
            if ( $val === null || $val === '' ) {
                $normalized[ $key ] = null;
                continue;
            }
            if ( ! is_numeric( $val ) ) {
                $errors[] = "{$key}_not_numeric";
                $normalized[ $key ] = null;
                continue;
            }
            $f = (float) $val;
            if ( $f < 0 ) {
                $errors[] = "{$key}_negative";
            }
            if ( $f > 1000000 ) {
                $errors[] = "{$key}_too_high";
            }
            $normalized[ $key ] = $f;
        }

        // Logical-order checks (only when all involved prices are provided)
        if ( $normalized['price_1y'] !== null && $normalized['price_2y'] !== null ) {
            if ( $normalized['price_2y'] < $normalized['price_1y'] ) {
                $errors[] = 'price_2y_below_1y';
            }
        }
        if ( $normalized['price_2y'] !== null && $normalized['price_3y'] !== null ) {
            if ( $normalized['price_3y'] < $normalized['price_2y'] ) {
                $errors[] = 'price_3y_below_2y';
            }
        }
        // Edge: 1y+3y but no 2y — still enforce 3y ≥ 1y
        if ( $normalized['price_1y'] !== null && $normalized['price_3y'] !== null && $normalized['price_2y'] === null ) {
            if ( $normalized['price_3y'] < $normalized['price_1y'] ) {
                $errors[] = 'price_3y_below_1y';
            }
        }

        return array(
            'ok'         => empty( $errors ),
            'errors'     => $errors,
            'normalized' => $normalized,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_run_ltv_snapshot' ) ) {
    /**
     * Phase 3 W10 — F#9 Customer LTV snapshot
     * Daily 03:00 — aggregate per user_id from sn_pool + B2B orders.
     *
     * Aggregation per user:
     *   - plates_count: COUNT(*) all sn_pool with this registered_user_id
     *   - registered_count: COUNT WHERE status='registered'
     *   - active_warranties_count: COUNT WHERE status IN registered/claimed
     *   - claim_count: COUNT WHERE status IN claimed/replaced
     *   - total_lifetime_spent: best-effort B2B order sum (if helper exists)
     *   - first_purchase_date / last_purchase_date: MIN/MAX(registered_at)
     *   - loyalty_tier: bucketed via compute_loyalty_tier
     *
     * Performance: chunked by user_id range (LIMIT 500/iter ×40 iter cap =
     * 20K users/run worst case). For 100K+ user base, schedule slow_run
     * variant or external cron tick.
     *
     * Idempotent: full snapshot rebuild via INSERT ... ON DUPLICATE KEY
     * UPDATE → safe to re-run same day.
     */
    function dinoco_sn_run_ltv_snapshot() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'ltv_snapshot' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $ltv  = dinoco_sn_table( 'ltv_snapshot' );

            $aggregated = 0;
            $last_user_id = 0;
            $cap = 40;

            for ( $i = 0; $i < $cap; $i++ ) {
                $batch = $wpdb->get_results( $wpdb->prepare(
                    "SELECT registered_user_id AS user_id,
                            COUNT(*)                                                                 AS plates_count,
                            SUM(CASE WHEN status = 'registered' THEN 1 ELSE 0 END)                   AS registered_count,
                            SUM(CASE WHEN status IN ('registered', 'claimed') THEN 1 ELSE 0 END)     AS active_warranties_count,
                            SUM(CASE WHEN status IN ('claimed', 'replaced')  THEN 1 ELSE 0 END)      AS claim_count,
                            MIN(registered_at)                                                       AS first_purchase_date,
                            MAX(registered_at)                                                       AS last_purchase_date
                     FROM {$pool}
                     WHERE registered_user_id IS NOT NULL
                       AND registered_user_id > %d
                     GROUP BY registered_user_id
                     ORDER BY registered_user_id ASC
                     LIMIT 500",
                    $last_user_id
                ), ARRAY_A );

                if ( ! $batch ) break;
                foreach ( $batch as $row ) {
                    $user_id = (int) $row['user_id'];
                    if ( $user_id === 0 ) continue;
                    $last_user_id = max( $last_user_id, $user_id );

                    // Best-effort B2B order spend (graceful degrade if helper missing)
                    $total_spent = 0.0;
                    if ( function_exists( 'b2b_get_user_lifetime_spend' ) ) {
                        $total_spent = (float) b2b_get_user_lifetime_spend( $user_id );
                    }

                    $tier = dinoco_sn_compute_loyalty_tier( $total_spent );
                    $first_date = $row['first_purchase_date']
                        ? date( 'Y-m-d', strtotime( $row['first_purchase_date'] ) )
                        : null;
                    $last_date = $row['last_purchase_date']
                        ? date( 'Y-m-d', strtotime( $row['last_purchase_date'] ) )
                        : null;

                    // INSERT ... ON DUPLICATE KEY UPDATE — full overwrite per run
                    $wpdb->query( $wpdb->prepare(
                        "INSERT INTO {$ltv}
                            (user_id, plates_count, registered_count, active_warranties_count,
                             total_lifetime_spent, first_purchase_date, last_purchase_date,
                             claim_count, loyalty_tier, computed_at)
                         VALUES (%d, %d, %d, %d, %f, %s, %s, %d, %s, %s)
                         ON DUPLICATE KEY UPDATE
                            plates_count            = VALUES(plates_count),
                            registered_count        = VALUES(registered_count),
                            active_warranties_count = VALUES(active_warranties_count),
                            total_lifetime_spent    = VALUES(total_lifetime_spent),
                            first_purchase_date     = VALUES(first_purchase_date),
                            last_purchase_date      = VALUES(last_purchase_date),
                            claim_count             = VALUES(claim_count),
                            loyalty_tier            = VALUES(loyalty_tier),
                            computed_at             = VALUES(computed_at)",
                        $user_id,
                        (int) $row['plates_count'],
                        (int) $row['registered_count'],
                        (int) $row['active_warranties_count'],
                        $total_spent,
                        $first_date,
                        $last_date,
                        (int) $row['claim_count'],
                        $tier,
                        current_time( 'mysql' )
                    ) );
                    $aggregated++;
                }
                if ( count( $batch ) < 500 ) break;
                usleep( 50000 ); // 50ms gap between batches
            }

            update_option( 'dinoco_sn_ltv_snapshot_last_run', array(
                'at'         => current_time( 'mysql' ),
                'aggregated' => $aggregated,
                'last_user'  => $last_user_id,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_ltv_snapshot' ) );
            }
        }

        update_option( 'dinoco_cron_sn_ltv_snapshot_last_run', current_time( 'mysql' ), false );
    }
}

if ( ! function_exists( 'dinoco_sn_run_anniversary_schedule' ) ) {
