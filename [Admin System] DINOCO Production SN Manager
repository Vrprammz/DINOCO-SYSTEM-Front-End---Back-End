            window.dncSnTabManageSubmitAction = function() {
                var sn = _dncSnTabManageCurrentSn;
                var action = _dncSnTabManageActiveAction;
                if (!sn || !action) {
                    _dncSnTabManageAlert('ไม่มี S/N หรือ action');
                    return;
                }
                var reasonInput = document.getElementById('dnc-sn-tab-manage-action-reason');
                var urgencySel = document.getElementById('dnc-sn-tab-manage-action-urgency');
                var reason = ((reasonInput && reasonInput.value) || '').trim();
                var urgency = (urgencySel && urgencySel.value) || 'normal';
                if (reason.length < 10) {
                    _dncSnTabManageAlert('เหตุผลต้องมีอย่างน้อย 10 ตัวอักษร');
                    return;
                }
                var context = {};
                if (action === 'recall') {
                    var catSel = document.getElementById('dnc-sn-tab-manage-action-category');
                    context.category = (catSel && catSel.value) || 'defect';
                } else if (action === 'swap') {
                    var snNewIn = document.getElementById('dnc-sn-tab-manage-action-sn-new');
                    var snNew = ((snNewIn && snNewIn.value) || '').trim().toUpperCase();
                    if (!snNew || snNew === sn) {
                        _dncSnTabManageAlert('กรอก S/N ใหม่ที่ไม่ใช่ S/N เดิม');
                        return;
                    }
                    context.sn_target = snNew;
                }
                var current_state = _dncSnTabManageCurrentSnRow && _dncSnTabManageCurrentSnRow.status
                    ? _dncSnTabManageCurrentSnRow.status : 'unknown';

                var btn = document.getElementById('dnc-sn-tab-manage-action-submit');
                if (btn) { btn.disabled = true; btn.textContent = 'กำลังส่ง…'; }

                var body = {
                    action: action,
                    sn: sn,
                    current_state: current_state,
                    urgency: urgency,
                    reason: reason,
                    context: context,
                };
                if (context.sn_target) body.sn_target = context.sn_target;

                fetch(REST_BASE + '/approval/request', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': NONCE,
                        'X-Idempotency-Key': _dncSnTabManageUuid(),
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify(body),
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, data: j }; }); })
                .then(function(res) {
                    if (btn) { btn.disabled = false; btn.textContent = 'ส่งคำขอ'; }
                    if (!res.ok) {
                        // Approval workflow snippet may not be active yet — show informative msg
                        var msg = (res.data && (res.data.message || res.data.code)) || ('HTTP ' + res.status);
                        if (res.status === 404 || res.status === 503) {
                            msg = 'Approval workflow ยังไม่ active (snippet ไม่ได้ load) — ' + msg;
                        }
                        _dncSnTabManageAlert('ส่งคำขอล้มเหลว: ' + msg);
                        return;
                    }
                    var data = res.data || {};
                    var tier = data.tier || 'auto';
                    _dncSnTabManageAlert('✓ ส่งคำขอแล้ว · tier=' + tier +
                        (data.uuid ? ' · uuid=' + data.uuid.slice(0, 8) : '') +
                        (data.expires_at ? '\nหมดอายุ: ' + _dncSnTabManageFmtDate(data.expires_at) : ''));
                    window.dncSnTabManageCloseActionModal();
                    window.dncSnTabManageCloseModal();
                    if (window.dncSnTabManageLoadPendingApprovals) {
                        window.dncSnTabManageLoadPendingApprovals();
                    }
                    // Refresh search to show updated state (if any auto-tier action ran)
                    window.dncSnTabManageSearch();
                })
                .catch(function(e) {
                    if (btn) { btn.disabled = false; btn.textContent = 'ส่งคำขอ'; }
                    _dncSnTabManageAlert('ส่งคำขอล้มเหลว: ' + e.message);
                });
            };

            // Section C — Pending Approvals panel
            window.dncSnTabManageLoadPendingApprovals = function() {
                var body = document.getElementById('dnc-sn-tab-manage-approvals-body');
                var countEl = document.getElementById('dnc-sn-tab-manage-approvals-count');
                if (!body) return; // not approver — panel not rendered
                fetch(REST_BASE + '/approval/pending?limit=10', {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, data: j }; }); })
                .then(function(res) {
                    if (!res.ok) {
                        var msg = (res.data && (res.data.message || res.data.code)) || ('HTTP ' + res.status);
                        if (res.status === 404 || res.status === 503) {
                            body.innerHTML = '<em style="color:#9ca3af;">Approval workflow ยังไม่ active (รอ snippet sync)</em>';
                        } else {
                            body.innerHTML = '<em style="color:#dc2626;">โหลดล้มเหลว: ' + _dncSnTabManageEsc(msg) + '</em>';
                        }
                        if (countEl) countEl.textContent = '—';
                        return;
                    }
                    var rows = (res.data && res.data.rows) || [];
                    if (countEl) countEl.textContent = String(rows.length);
                    if (!rows.length) {
                        body.innerHTML = '<em style="color:#10b981;">✓ ไม่มี pending approvals</em>';
                        return;
                    }
                    body.innerHTML = rows.map(function(p) {
                        var urgency = p.urgency || 'normal';
                        var ageMin = p.created_at ? Math.floor((Date.now() - new Date(p.created_at.replace(' ', 'T')).getTime()) / 60000) : 0;
                        var sla = '';
                        if (p.expires_at) {
                            var rem = Math.max(0, Math.floor((new Date(p.expires_at.replace(' ', 'T')).getTime() - Date.now()) / 60000));
                            sla = '<span class="dnc-sn-pill dnc-sn-pill-mute">SLA: ' + rem + ' นาที</span>';
                        }
                        return '<div class="dnc-sn-tab-manage-pending-row dnc-sn-tab-manage-pending-' + _dncSnTabManageEsc(urgency) + '">' +
                            '<span class="dnc-sn-pill dnc-sn-pill-purple">' + _dncSnTabManageEsc(p.action || '—') + '</span> ' +
                            '<code>' + _dncSnTabManageEsc(p.sn || '—') + '</code> · ' +
                            'จาก <strong>' + _dncSnTabManageEsc(p.actor_display || ('user#' + (p.actor_user_id || ''))) + '</strong> · ' +
                            ageMin + ' นาที ' + sla +
                            ' <button class="dnc-sn-btn dnc-sn-btn-link" onclick="dncSnTabManageApprove(\'' +
                                _dncSnTabManageEsc(p.uuid || '').replace(/'/g, "\\'") + '\')">✓ Approve</button>' +
                            ' <button class="dnc-sn-btn dnc-sn-btn-link" onclick="dncSnTabManageReject(\'' +
                                _dncSnTabManageEsc(p.uuid || '').replace(/'/g, "\\'") + '\')">✗ Reject</button>' +
                            '</div>';
                    }).join('');
                })
                .catch(function(e) {
                    body.innerHTML = '<em style="color:#dc2626;">โหลดล้มเหลว: ' + _dncSnTabManageEsc(e.message) + '</em>';
                });
            };

            window.dncSnTabManageApprove = function(uuid) {
                if (!uuid) return;
                _dncSnTabManageDecide(uuid, 'approve');
            };
            window.dncSnTabManageReject = function(uuid) {
                if (!uuid) return;
                _dncSnTabManageDecide(uuid, 'reject');
            };
            function _dncSnTabManageDecide(uuid, decision) {
                _dncSnTabManageCfm(
                    decision === 'approve' ? 'อนุมัติคำขอนี้?' : 'ปฏิเสธคำขอนี้?',
                    { okLabel: decision === 'approve' ? '✓ Approve' : '✗ Reject' }
                ).then(function(ok) {
                    if (!ok) return;
                    var notes = window.prompt('Notes (optional):', '') || '';
                    fetch(REST_BASE + '/approval/' + encodeURIComponent(uuid) + '/' + decision, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-WP-Nonce': NONCE,
                            'X-Idempotency-Key': _dncSnTabManageUuid(),
                        },
                        credentials: 'same-origin',
                        body: JSON.stringify({ notes: notes }),
                    })
                    .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, data: j }; }); })
                    .then(function(res) {
                        if (!res.ok) {
                            _dncSnTabManageAlert('Decision failed: ' + ((res.data && (res.data.message || res.data.code)) || ('HTTP ' + res.status)));
                            return;
                        }
                        _dncSnTabManageAlert('✓ ' + decision + ' OK');
                        if (window.dncSnTabManageLoadPendingApprovals) window.dncSnTabManageLoadPendingApprovals();
                        if (window.dncSnTabManageSearch) window.dncSnTabManageSearch();
                    })
                    .catch(function(e) {
                        _dncSnTabManageAlert('Decision failed: ' + e.message);
                    });
                });
            }

