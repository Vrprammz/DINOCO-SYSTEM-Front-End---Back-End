// Also handle add_option (first-time set) — same callback
add_action( 'add_option_dinoco_sn_system_enabled', 'dinoco_sn_reevaluate_flag_aware_crons', 10, 0 );

// Cron registration via registry wrapper (Round 28 pattern with fallback)
add_action( 'init', function() {
    // V.0.40 HIGH — cron stagger: each daily/15min job offsets by N minutes
    // from a common anchor (today 02:00 ICT) to prevent thundering herd.
    // Schedule:
    //   audit_retention      02:00 (anchor)
    //   expiry_schedule      02:00 (logically separate, low cost)
    //   anniversary          02:05
    //   review_request       02:10
    //   ltv_snapshot         02:15
    //   demand_forecast      02:20 (weekly)
    //   pool_stats_recompute (every 15min, runs at :00/:15/:30/:45)
    //   orphan_claim_scan    03:30
    $base_offset = (int) strtotime( 'tomorrow 02:00' );
    if ( ! $base_offset ) $base_offset = time() + 60;

    // R9 Pattern 4 — flag-aware: auto-unschedules when dinoco_sn_system_enabled=0
    dinoco_register_flag_aware_cron( 'dinoco_sn_low_pool_alert_cron', 'hourly', 'dinoco_sn_system_enabled' );
    // R9 Pattern 4 — audit_retention: flag-aware. Note: when scheduling fresh,
    // helper uses time()+60 anchor (not 03:30 stagger) — first run will fire
    // ~immediately after deploy, subsequent runs at +24h. Acceptable trade-off
    // since audit_retention is chunked + idempotent + observability-bound.
    dinoco_register_flag_aware_cron( 'dinoco_sn_audit_retention_cron', 'daily', 'dinoco_sn_system_enabled' );
    // V.0.43 R4 HIGH-3 — Pepper rotation quarterly (every 90 days). Cron fires
    // weekly + callback no-ops if last rotation < 90d ago (no native quarterly
    // WP recurrence). Rotation regenerates pepper option (autoload=false). Old
    // hashes remain valid by design — additive only, no re-hash sweep.
    if ( ! wp_next_scheduled( 'dinoco_sn_audit_pepper_rotate_cron' ) ) {
        $rotate_anchor = strtotime( 'tomorrow 03:55' );
        if ( ! $rotate_anchor ) $rotate_anchor = $base_offset + 6900;
        wp_schedule_event( $rotate_anchor, 'weekly', 'dinoco_sn_audit_pepper_rotate_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_sn_batch_reconcile_cron' ) ) {
        wp_schedule_event( time(), 'weekly', 'dinoco_sn_batch_reconcile_cron' );
    }
    // Phase 3 W8 / V.0.22 — Orphan claim scan (Gap D)
    if ( ! wp_next_scheduled( 'dinoco_sn_orphan_claim_scan_cron' ) ) {
        // Already documented as 03:30, keep but offset 5min later to skip audit cleanup contention
        $anchor = strtotime( 'tomorrow 03:35' );
        if ( ! $anchor ) $anchor = $base_offset + 5700;
        wp_schedule_event( $anchor, 'daily', 'dinoco_sn_orphan_claim_scan_cron' );
    }
    // Phase 3 W9 — F#1 Expiry Reminder (offset 0 from base — anchor)
    if ( ! wp_next_scheduled( 'dinoco_sn_expiry_schedule_cron' ) ) {
        wp_schedule_event( $base_offset, 'daily', 'dinoco_sn_expiry_schedule_cron' );
    }
    // R9 Pattern 4 — notification_send: flag-aware. Highest-volume after
    // marketplace_timeout (15min cadence). Fires often → biggest cleanup win.
    {
        $sched_ns = wp_get_schedules();
        $rec_ns   = isset( $sched_ns['fifteen_minutes'] ) ? 'fifteen_minutes' : 'hourly';
        dinoco_register_flag_aware_cron( 'dinoco_sn_notification_send_cron', $rec_ns, 'dinoco_sn_system_enabled' );
    }
    // Phase 3 W9 — F#4 Anniversary (+5min) + F#10 Review Request (+10min)
    if ( ! wp_next_scheduled( 'dinoco_sn_anniversary_schedule_cron' ) ) {
        wp_schedule_event( $base_offset + 300, 'daily', 'dinoco_sn_anniversary_schedule_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_sn_review_request_cron' ) ) {
        wp_schedule_event( $base_offset + 600, 'daily', 'dinoco_sn_review_request_cron' );
    }
    // Phase 3 W10 — F#9 Customer LTV snapshot (+15min)
    if ( ! wp_next_scheduled( 'dinoco_sn_ltv_snapshot_cron' ) ) {
        wp_schedule_event( $base_offset + 900, 'daily', 'dinoco_sn_ltv_snapshot_cron' );
    }
    // Phase 3 W11 — F#13 Gray Market weekly scan
    if ( ! wp_next_scheduled( 'dinoco_sn_gray_market_scan_cron' ) ) {
        wp_schedule_event( time(), 'weekly', 'dinoco_sn_gray_market_scan_cron' );
    }
