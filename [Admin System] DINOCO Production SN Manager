            /* Phase 3 W10.3 — F#9 LTV CSV Export */
            window.dncSnExportLtvCsv = function() {
                var tier = (document.getElementById('dnc-sn-ltv-tier') || {}).value || '';
                var minSpent = (document.getElementById('dnc-sn-ltv-min-spent') || {}).value || '';
                var meta = document.getElementById('dnc-sn-ltv-meta');

                var url = REST_BASE + '/ltv/export?limit=5000&_wpnonce=' + encodeURIComponent(NONCE);
                if (tier) url += '&tier=' + encodeURIComponent(tier);
                if (minSpent && Number(minSpent) > 0) url += '&min_spent=' + encodeURIComponent(minSpent);

                if (meta) meta.textContent = 'กำลังเตรียมไฟล์ CSV…';

                fetch(url, {
                    headers: { 'X-WP-Nonce': NONCE, 'Accept': 'text/csv' },
                    credentials: 'same-origin',
                })
                .then(function(r) {
                    if (r.status === 429) {
                        throw new Error('เกินจำนวน export ที่อนุญาต (5/ชม.) กรุณารอแล้วลองใหม่');
                    }
                    if (r.status === 503) {
                        throw new Error('ระบบยังไม่ติดตั้ง LTV snapshot table (cron daily 03:00 ยังไม่ได้รัน)');
                    }
                    if (!r.ok) {
                        throw new Error('Export failed (HTTP ' + r.status + ')');
                    }
                    var rowCount = r.headers.get('X-Ltv-Row-Count') || '?';
                    var piiVisible = r.headers.get('X-PII-Visible') === '1';
                    return r.blob().then(function(blob) {
                        return { blob: blob, rows: rowCount, pii: piiVisible };
                    });
                })
                .then(function(result) {
                    var dispo = 'sn_ltv_' + (tier || 'all') + '_'
                              + new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-') + '.csv';
                    var link = document.createElement('a');
