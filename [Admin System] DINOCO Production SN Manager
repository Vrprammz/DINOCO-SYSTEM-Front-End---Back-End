if ( ! function_exists( 'dinoco_sn_run_pool_stats_recompute' ) ) {
    /**
     * Pre-compute pool stats GROUP BY linked_sku, status → wp_option cache.
     * Tab 3 Pool Status reads from cache instead of live aggregate query.
     *
     * Cache shape: array(
     *   'computed_at' => 'YYYY-MM-DD HH:MM:SS',
     *   'rows'        => array(
     *      array('sku'=>'DNC...', 'status'=>'reserved', 'cnt'=>123),
     *      ...
     *   ),
     *   'totals_by_status' => array('reserved'=>500, 'in_pool'=>3000, ...),
     *   'total_rows'  => N,
     * )
     */
    function dinoco_sn_run_pool_stats_recompute() {
        global $wpdb;
        try {
            if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                return;
            }
            $tbl = dinoco_sn_table( 'pool' );
            $rows = $wpdb->get_results(
                "SELECT linked_sku, status, COUNT(*) AS cnt
                   FROM {$tbl}
                  GROUP BY linked_sku, status",
                ARRAY_A
            );
            $rows = is_array( $rows ) ? $rows : array();
            $totals_by_status = array();
            $total_rows = 0;
            foreach ( $rows as $r ) {
                $st = isset( $r['status'] ) ? $r['status'] : '_unknown';
                $cnt = (int) ( $r['cnt'] ?? 0 );
                $totals_by_status[ $st ] = ( $totals_by_status[ $st ] ?? 0 ) + $cnt;
                $total_rows += $cnt;
            }

            $cache = array(
                'computed_at'      => current_time( 'mysql' ),
                'rows'             => $rows,
                'totals_by_status' => $totals_by_status,
                'total_rows'       => $total_rows,
            );
            update_option( 'dinoco_sn_pool_stats_cache', $cache, 'no' );
            // Heartbeat for Health Monitor (per Round 28 dinoco_register_cron pattern)
            update_option( 'dinoco_cron_sn_pool_stats_recompute_last_run', current_time( 'mysql' ), 'no' );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_pool_stats_recompute' ) );
            }
        }
    }
}

