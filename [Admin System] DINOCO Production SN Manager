            window.dncSnLoadGeoHeatmap = function() {
                var range = (document.getElementById('dnc-sn-geo-range') || {}).value || '30';
                var from = (document.getElementById('dnc-sn-geo-from') || {}).value || '';
                var to = (document.getElementById('dnc-sn-geo-to') || {}).value || '';
                var sku = (document.getElementById('dnc-sn-geo-sku') || {}).value || '';
                var batch = (document.getElementById('dnc-sn-geo-batch') || {}).value || '';
                var grayOnly = (document.getElementById('dnc-sn-geo-gray-only') || {}).checked || false;
                var meta = document.getElementById('dnc-sn-geo-meta');
                var tbody = document.querySelector('#dnc-sn-geo-table tbody');
                if (meta) meta.textContent = 'Loading…';
                if (tbody) tbody.innerHTML = '<tr><td colspan="5" class="dnc-sn-empty">Loading…</td></tr>';

                // Phase 3 W11.1 — derive from/to from range chip if explicit dates blank
                if (!from && !to && range !== 'all') {
                    var d = parseInt(range, 10);
                    if (!isNaN(d) && d > 0) {
                        var now = new Date();
                        var past = new Date(now.getTime() - d * 86400000);
                        from = past.toISOString().slice(0, 10);
                        to = now.toISOString().slice(0, 10);
                    }
                }

                var url = REST_BASE + '/geo/heatmap';
                var qs = [];
                if (from) qs.push('from=' + encodeURIComponent(from));
                if (to) qs.push('to=' + encodeURIComponent(to));
                if (sku) qs.push('sku=' + encodeURIComponent(sku));
                if (batch) qs.push('batch=' + encodeURIComponent(batch));
                if (grayOnly) qs.push('gray_only=1');
                if (qs.length) url += '?' + qs.join('&');

                fetch(url, {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data || !Array.isArray(data.rows)) {
                        if (meta) meta.textContent = (data && data.note) || 'No data';
                        return;
                    }
                    if (meta) meta.textContent = 'Provinces: ' + data.province_count +
                        ' · Total records: ' + data.total_records;
                    if (!data.rows.length) {
                        tbody.innerHTML = '<tr><td colspan="5" class="dnc-sn-empty">No activations recorded yet (Phase 4 W12 wires IP geo)</td></tr>';
                        return;
