            // Modal helpers shim (try Modal Helpers snippet → fallback native)
            function _dncSnTabManageCfm(message, opts) {
                opts = opts || {};
                try {
                    if (window.dinocoModal && typeof window.dinocoModal.confirm === 'function') {
                        return window.dinocoModal.confirm({
                            title: opts.title || 'ยืนยัน',
                            message: message,
                            okLabel: opts.okLabel || 'ยืนยัน',
                            cancelLabel: opts.cancelLabel || 'ยกเลิก',
                        });
                    }
                } catch (e) { /* fall through */ }
                return Promise.resolve(window.confirm(message));
            }
            function _dncSnTabManageAlert(message, opts) {
                opts = opts || {};
                try {
                    if (window.dinocoModal && typeof window.dinocoModal.alert === 'function') {
                        return window.dinocoModal.alert({
                            title: opts.title || 'แจ้งเตือน',
                            message: message,
                        });
                    }
                } catch (e) { /* fall through */ }
                window.alert(message);
                return Promise.resolve();
            }
            function _dncSnTabManageUuid() {
                try {
                    if (window.crypto && typeof window.crypto.randomUUID === 'function') {
                        return window.crypto.randomUUID();
                    }
                } catch (e) { /* ignore */ }
                // RFC4122-ish fallback (not crypto strong but unique enough for idempotency keys)
                return ('xxxxxxxxxxxx4xxxyxxxxxxxxxxxxxxx').replace(/[xy]/g, function(c) {
                    var r = Math.random() * 16 | 0;
                    return (c === 'y' ? (r & 0x3 | 0x8) : r).toString(16);
                });
            }
            function _dncSnTabManageEsc(s) {
                var d = document.createElement('div');
                d.textContent = s == null ? '' : String(s);
                return d.innerHTML;
            }
            function _dncSnTabManageFmtDate(s) {
                if (!s) return '—';
                try {
                    var d = new Date(String(s).replace(' ', 'T'));
                    if (isNaN(d.getTime())) return s;
                    return d.toLocaleString('th-TH', { hour12: false });
                } catch (e) { return s; }
            }
            function _dncSnTabManageRelTime(s) {
                if (!s) return '—';
                try {
                    var t = new Date(String(s).replace(' ', 'T')).getTime();
                    if (isNaN(t)) return s;
                    var diffSec = Math.max(0, Math.floor((Date.now() - t) / 1000));
                    if (diffSec < 60) return diffSec + 'วิ ที่แล้ว';
                    if (diffSec < 3600) return Math.floor(diffSec / 60) + 'นาที ที่แล้ว';
                    if (diffSec < 86400) return Math.floor(diffSec / 3600) + 'ชม. ที่แล้ว';
                    return Math.floor(diffSec / 86400) + 'วัน ที่แล้ว';
                } catch (e) { return s; }
            }

