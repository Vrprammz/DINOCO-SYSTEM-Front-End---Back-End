if ( ! function_exists( 'dinoco_sn_compute_loyalty_tier' ) ) {
    /**
     * Phase 3 W10 — F#9 LTV bucketing (v2.9 spec).
     * Pure-function (testable). Thresholds in THB.
     *
     *   diamond  ฿100,000+
     *   platinum ฿50,000-100,000
     *   gold     ฿20,000-50,000
     *   silver   ฿5,000-20,000
     *   bronze   <฿5,000 (default)
     */
    function dinoco_sn_compute_loyalty_tier( $total_spent ) {
        $spent = (float) $total_spent;
        if ( $spent >= 100000 ) return 'diamond';
        if ( $spent >= 50000 )  return 'platinum';
        if ( $spent >= 20000 )  return 'gold';
        if ( $spent >= 5000 )   return 'silver';
        return 'bronze';
