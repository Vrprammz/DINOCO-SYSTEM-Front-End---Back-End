if ( ! function_exists( 'dinoco_sn_render_admin_js' ) ) {
    function dinoco_sn_render_admin_js() {
        $rest_base = rest_url( 'dinoco-sn/v1' );
        $nonce = wp_create_nonce( 'wp_rest' );
        ?>
        <script>
        (function() {
            const REST_BASE = <?php echo wp_json_encode( $rest_base ); ?>;
            const NONCE = <?php echo wp_json_encode( $nonce ); ?>;

            // Tab navigation
            document.querySelectorAll('.dnc-sn-tab').forEach(function(tab) {
                tab.addEventListener('click', function() {
                    document.querySelectorAll('.dnc-sn-tab').forEach(function(t) { t.classList.remove('active'); });
                    document.querySelectorAll('.dnc-sn-tab-panel').forEach(function(p) { p.classList.remove('active'); });
                    tab.classList.add('active');
                    var panel = document.querySelector('[data-tab-panel="' + tab.dataset.tab + '"]');
                    if (panel) panel.classList.add('active');
                });
            });

            // ═══════ Tab 1: Batches ═══════
            window.dncSnLoadBatches = function() {
                var listEl = document.getElementById('dnc-sn-batches-list');
                var search = document.getElementById('dnc-sn-batch-search').value;
                var status = document.getElementById('dnc-sn-batch-status-filter').value;
                var url = REST_BASE + '/batches?limit=50';
                if (status) url += '&status=' + encodeURIComponent(status);

                fetch(url, { headers: { 'X-WP-Nonce': NONCE }, credentials: 'same-origin' })
                    .then(function(r) { return r.json(); })
                    .then(function(res) {
                        if (!res.data || !res.data.length) {
                            listEl.innerHTML = '<div class="dnc-sn-empty">' +
                                '<p style="font-size:48px;">📦</p>' +
                                '<p>ยังไม่มี Batch — กดสร้าง Batch แรก</p></div>';
                            return;
                        }
                        var rows = res.data.filter(function(b) {
                            if (!search) return true;
                            var s = search.toLowerCase();
                            return (b.batch_code || '').toLowerCase().includes(s)
                                || (b.prefix || '').toLowerCase().includes(s);
                        });

                        listEl.innerHTML = rows.map(function(b) {
                            var pct = Math.round((b.qty_received / Math.max(1, b.qty_total)) * 100);
                            var statusClass = 'dnc-sn-status-' + (b.status || 'draft').replace('_', '-').replace('received-', '').replace('sent-to-factory', 'sent');
                            return '<div class="dnc-sn-batch-card">' +
                                '<div>' +
                                '<h3>' + escapeHtml(b.batch_code) + ' <code style="font-size:13px;color:#6b7280;">' + escapeHtml(b.prefix) + '</code></h3>' +
                                '<div class="dnc-sn-progress"><div class="dnc-sn-progress-bar" style="width:' + pct + '%"></div></div>' +
                                '<div class="meta">' + b.qty_received + ' / ' + b.qty_total + ' plates · ' + pct + '%</div>' +
                                '<div class="meta">' + (b.factory_name || 'No factory') + ' · created ' + (b.created_at || '').substr(0, 10) + '</div>' +
                                '</div>' +
                                '<div style="text-align:right;">' +
                                '<span class="dnc-sn-batch-status ' + statusClass + '">' + escapeHtml(b.status) + '</span>' +
                                '<div style="margin-top:8px;display:flex;gap:6px;flex-direction:column;">' +
                                (b.status === 'draft' ? '<button class="dnc-sn-btn dnc-sn-btn-secondary" onclick="dncSnMarkSent(' + b.id + ')">▶ ส่งโรงงาน</button>' : '') +
                                '<button class="dnc-sn-btn dnc-sn-btn-secondary" onclick="dncSnDownloadCSV(' + b.id + ')">📥 CSV</button>' +
                                '<button class="dnc-sn-btn dnc-sn-btn-secondary" onclick="dncSnDownloadQrPdf(' + b.id + ')">📄 QR PDF</button>' +
                                '</div></div></div>';
                        }).join('');
                    })
                    .catch(function(err) {
                        listEl.innerHTML = '<div class="dnc-sn-empty">เกิดข้อผิดพลาด: ' + err.message + '</div>';
                    });
            };

            window.dncSnOpenCreateBatchModal = function() {
                document.getElementById('dnc-sn-create-batch-modal').classList.remove('hidden');
            };

            window.dncSnCloseCreateBatchModal = function() {
                document.getElementById('dnc-sn-create-batch-modal').classList.add('hidden');
            };

            // Live preview
            ['dnc-sn-new-batch-prefix', 'dnc-sn-new-batch-qty', 'dnc-sn-new-batch-format'].forEach(function(id) {
                document.getElementById(id).addEventListener('input', updateBatchPreview);
            });

            function updateBatchPreview() {
                var prefix = (document.getElementById('dnc-sn-new-batch-prefix').value || '').toUpperCase();
                var qty = parseInt(document.getElementById('dnc-sn-new-batch-qty').value || '0');
                var format = document.getElementById('dnc-sn-new-batch-format').value;
                var preview = document.getElementById('dnc-sn-new-batch-preview');

                if (!prefix || !qty) {
                    preview.textContent = 'Preview: กรอกข้อมูลเพื่อดู preview';
                    return;
                }

                var seq_pad = 7;
                var m = format.match(/\{SEQ:(\d+)\}/);
                if (m) seq_pad = parseInt(m[1]);

                var first = prefix + String(1).padStart(seq_pad, '0');
                var last = prefix + String(qty).padStart(seq_pad, '0');
                var dbSize = Math.round(qty * 0.0005 * 100) / 100; // ~500B per row

                preview.innerHTML = 'Preview:<br>' +
                    '<strong>' + first + '</strong> .. <strong>' + last + '</strong><br>' +
                    '<small>DB: ~' + dbSize + ' MB · เวลา: ~' + Math.ceil(qty / 50000) + ' นาที</small>';
            }

            window.dncSnSubmitCreateBatch = function() {
                var data = {
                    batch_code: document.getElementById('dnc-sn-new-batch-code').value.trim(),
                    prefix: document.getElementById('dnc-sn-new-batch-prefix').value.trim().toUpperCase(),
                    qty_total: parseInt(document.getElementById('dnc-sn-new-batch-qty').value || '0'),
                    format_pattern: document.getElementById('dnc-sn-new-batch-format').value,
                    allocation_strategy: document.getElementById('dnc-sn-new-batch-strategy').value,
                    factory_name: document.getElementById('dnc-sn-new-batch-factory').value.trim(),
                    factory_po_ref: document.getElementById('dnc-sn-new-batch-po').value.trim(),
                };

                if (!data.batch_code || !data.prefix || !data.qty_total) {
                    alert('กรุณากรอกข้อมูลให้ครบ');
                    return;
                }
                if (!data.prefix.match(/^[A-Z0-9]{3,6}$/)) {
                    alert('Prefix ต้องเป็น A-Z 0-9 ความยาว 3-6 ตัว');
                    return;
                }

                fetch(REST_BASE + '/batches', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': NONCE,
                        'X-Idempotency-Key': crypto.randomUUID(),
                    },
                    body: JSON.stringify(data),
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, body: j }; }); })
                .then(function(res) {
                    if (res.ok) {
                        alert('สร้าง Batch สำเร็จ!\n' + res.body.first_sn + ' .. ' + res.body.last_sn);
                        dncSnCloseCreateBatchModal();
                        dncSnLoadBatches();
                    } else {
                        alert('Error: ' + (res.body.message || 'unknown'));
                    }
                })
                .catch(function(err) {
                    alert('Network error: ' + err.message);
                });
            };

            window.dncSnMarkSent = function(batch_id) {
                if (!confirm('ส่ง Batch นี้ให้โรงงานแล้ว?')) return;
                fetch(REST_BASE + '/batches/' + batch_id + '/status', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': NONCE,
                        'X-Idempotency-Key': crypto.randomUUID(),
                    },
                    body: JSON.stringify({ id: batch_id, status: 'sent_to_factory' }),
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) { dncSnLoadBatches(); }
                    else { alert('Error: ' + (res.message || 'unknown')); }
                });
            };

            window.dncSnDownloadCSV = function(batch_id) {
                // Open in new tab — backend streams CSV with attachment header
                window.open(REST_BASE + '/batches/' + batch_id + '/csv?_wpnonce=' + NONCE, '_blank');
            };

            window.dncSnDownloadQrPdf = function(batch_id) {
                // Phase 1 W3: returns JSON metadata
                // Phase 1 W4: will integrate actual PDF generation
                fetch(REST_BASE + '/batches/' + batch_id + '/qr-pdf?chunk=1', {
                    headers: { 'X-WP-Nonce': NONCE }, credentials: 'same-origin',
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    alert('QR PDF metadata loaded:\n' +
                        'Total chunks: ' + res.total_chunks + '\n' +
                        'Plates in chunk 1: ' + res.qty_in_chunk + '\n\n' +
                        'Phase 1 W4 will serve actual PDF binary.');
                });
            };

            // ═══════ Tab 2: Receive ═══════
            window.dncSnSetReceiveMode = function(mode) {
                document.querySelectorAll('.dnc-sn-mode-btn').forEach(function(b) { b.classList.remove('active'); });
                document.querySelector('[data-mode="' + mode + '"]').classList.add('active');
                document.querySelectorAll('.dnc-sn-receive-mode-panel').forEach(function(p) { p.classList.remove('active'); });
                document.querySelector('[data-mode-panel="' + mode + '"]').classList.add('active');
            };

            // Load batches into receive batch dropdown
            function loadReceiveBatches() {
                fetch(REST_BASE + '/batches?limit=50&status=sent_to_factory', {
                    headers: { 'X-WP-Nonce': NONCE }, credentials: 'same-origin',
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    var sel = document.getElementById('dnc-sn-receive-batch');
                    if (!sel) return;
                    sel.innerHTML = '<option value="">— เลือก batch —</option>' +
                        (res.data || []).map(function(b) {
                            return '<option value="' + b.id + '" data-prefix="' + b.prefix + '">' + escapeHtml(b.batch_code) + ' (' + b.qty_received + '/' + b.qty_total + ')</option>';
                        }).join('');
                });
            }

            // Range mode preview
            ['dnc-sn-range-start', 'dnc-sn-range-qty'].forEach(function(id) {
                document.getElementById(id).addEventListener('input', updateRangePreview);
            });

            function updateRangePreview() {
                var start = (document.getElementById('dnc-sn-range-start').value || '').toUpperCase();
                var qty = parseInt(document.getElementById('dnc-sn-range-qty').value || '0');
                var preview = document.getElementById('dnc-sn-range-preview');

                if (!start || !qty) {
                    preview.textContent = 'Preview: กรอกข้อมูล';
                    return;
                }

                // Parse start S/N — extract prefix + sequence
                var m = start.match(/^([A-Z]+)(\d+)$/);
                if (!m) {
                    preview.innerHTML = '<span style="color:#dc2626;">รูปแบบ S/N ไม่ถูกต้อง</span>';
                    return;
                }

                var prefix = m[1];
                var seq_start = parseInt(m[2]);
                var seq_pad = m[2].length;
                var seq_end = seq_start + qty - 1;
                var last = prefix + String(seq_end).padStart(seq_pad, '0');

                preview.innerHTML = 'จะรับ <strong>' + qty + '</strong> plates: ' +
                    '<strong>' + start + '</strong> .. <strong>' + last + '</strong>';
            }

            window.dncSnSubmitRangeReceive = function() {
                var batchSel = document.getElementById('dnc-sn-receive-batch');
                var batch_id = parseInt(batchSel.value || '0');
                var sku = (document.getElementById('dnc-sn-receive-sku').value || '').toUpperCase().trim();
                var start = (document.getElementById('dnc-sn-range-start').value || '').toUpperCase().trim();
                var qty = parseInt(document.getElementById('dnc-sn-range-qty').value || '0');

                if (!batch_id || !sku || !start || !qty) {
                    alert('กรุณากรอกข้อมูลให้ครบ');
                    return;
                }

                var m = start.match(/^([A-Z]+)(\d+)$/);
                if (!m) { alert('รูปแบบ S/N ไม่ถูกต้อง'); return; }

                var prefix = m[1];
                var seq_start = parseInt(m[2]);
                var seq_pad = m[2].length;
                var sns = [];
                for (var i = 0; i < qty; i++) {
                    sns.push(prefix + String(seq_start + i).padStart(seq_pad, '0'));
                }

                // Cap at 100 (D4 contract)
                if (sns.length > 100) {
                    if (!confirm('กว่า 100 plates — ระบบจะแบ่ง chunks อัตโนมัติ ดำเนินการต่อ?')) return;
                }

                submitBulkReceive(batch_id, sku, sns, 'range');
            };

            window.dncSnSubmitPasteReceive = function() {
                var batchSel = document.getElementById('dnc-sn-receive-batch');
                var batch_id = parseInt(batchSel.value || '0');
                var sku = (document.getElementById('dnc-sn-receive-sku').value || '').toUpperCase().trim();
                var raw = document.getElementById('dnc-sn-paste-list').value || '';

                if (!batch_id || !sku) { alert('กรุณากรอกข้อมูลให้ครบ'); return; }

                var sns = raw.split(/[\s,]+/)
                    .map(function(s) { return s.toUpperCase().trim(); })
                    .filter(function(s) { return s.match(/^[A-Z0-9]{8,16}$/); });
                sns = Array.from(new Set(sns)); // dedup

                if (!sns.length) { alert('ไม่พบ S/N ที่ถูกต้อง'); return; }
                submitBulkReceive(batch_id, sku, sns, 'paste');
            };

            window.dncSnScanKeydown = function(event) {
                if (event.key !== 'Enter') return;
                event.preventDefault();
                var input = event.target;
                var sn = (input.value || '').toUpperCase().trim();
                if (!sn.match(/^[A-Z0-9]{8,16}$/)) {
                    input.value = '';
                    return;
                }
                var batchSel = document.getElementById('dnc-sn-receive-batch');
                var batch_id = parseInt(batchSel.value || '0');
                var sku = (document.getElementById('dnc-sn-receive-sku').value || '').toUpperCase().trim();
                if (!batch_id || !sku) { alert('เลือก batch + SKU ก่อน'); return; }

                input.value = '';
                input.focus();

                // Single receive
                fetch(REST_BASE + '/receive', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-WP-Nonce': NONCE,
                        'X-Idempotency-Key': crypto.randomUUID(),
                    },
                    body: JSON.stringify({ sn: sn, linked_sku: sku, batch_id: batch_id }),
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, body: j }; }); })
                .then(function(res) {
                    addRecentScan(sn, res.ok ? 'ok' : 'error', res.ok ? 'received' : (res.body.code || 'error'));
                });
            };

            function submitBulkReceive(batch_id, sku, sns, mode) {
                // Chunks of 100 if >100
                var CHUNK = 100;
                var chunks = [];
                for (var i = 0; i < sns.length; i += CHUNK) {
                    chunks.push(sns.slice(i, i + CHUNK));
                }

                var totalSuccess = 0, totalSkip = 0;
                var promises = chunks.map(function(chunk) {
                    return fetch(REST_BASE + '/receive/bulk', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-WP-Nonce': NONCE,
                            'X-Idempotency-Key': crypto.randomUUID(),
                        },
                        body: JSON.stringify({
                            batch_id: batch_id,
                            linked_sku: sku,
                            sns: chunk,
                            mode: mode,
                        }),
                        credentials: 'same-origin',
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(res) {
                        if (res.success_count !== undefined) {
                            totalSuccess += res.success_count;
                            totalSkip += res.skip_count;
                            (res.results || []).forEach(function(r) {
                                addRecentScan(r.sn, r.status === 'ok' ? 'ok' : 'error', r.code);
                            });
                        }
                    });
                });

                Promise.all(promises).then(function() {
                    alert('รับเสร็จ: ' + totalSuccess + ' สำเร็จ · ' + totalSkip + ' skip');
                });
            }

            var sessionScans = [];
            function addRecentScan(sn, status, code) {
                sessionScans.unshift({ sn: sn, status: status, code: code, time: new Date() });
                if (sessionScans.length > 50) sessionScans = sessionScans.slice(0, 50);
                renderRecentScans();
            }

            function renderRecentScans() {
                document.getElementById('dnc-sn-session-count').textContent = sessionScans.filter(function(s) { return s.status === 'ok'; }).length;
                var listEl = document.getElementById('dnc-sn-recent-list');
                if (!sessionScans.length) {
                    listEl.innerHTML = '<div style="color:#9ca3af;font-size:13px;">ยังไม่มีรายการ</div>';
                    return;
                }
                listEl.innerHTML = sessionScans.slice(0, 10).map(function(s) {
                    var icon = s.status === 'ok' ? '✅' : '❌';
                    var ago = Math.round((Date.now() - s.time.getTime()) / 1000) + 's ago';
                    return '<div class="dnc-sn-scan-row">' + icon + ' ' + escapeHtml(s.sn) + ' <span style="color:#9ca3af;margin-left:auto;">' + escapeHtml(s.code) + ' · ' + ago + '</span></div>';
                }).join('');
            }

            window.dncSnUndoLastScan = function() {
                if (!sessionScans.length) return;
                if (!confirm('Undo การ scan ล่าสุด? (ระบบจะ unlink S/N กลับเป็น reserved)')) return;
                alert('Phase 1 W4: undo endpoint not yet implemented');
            };

            window.dncSnClearSession = function() {
                if (!confirm('Clear session? (ไม่กระทบข้อมูลในระบบ)')) return;
                sessionScans = [];
                renderRecentScans();
            };

            function escapeHtml(s) {
                var d = document.createElement('div');
                d.textContent = s == null ? '' : String(s);
                return d.innerHTML;
            }

            // Initial load
            dncSnLoadBatches();
            loadReceiveBatches();
        })();
        </script>
        <?php
    }
