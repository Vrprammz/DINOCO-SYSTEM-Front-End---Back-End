                    if (err.message === 'endpoint_not_ready') return;
                    if (meta) meta.textContent = 'Failed: ' + err.message;
                });
            };

            window.dncSnMpSavePriceFromInput = function(input) {
                var sku = input.dataset.sku;
                var years = parseInt(input.dataset.years, 10);
                var rawVal = String(input.value || '').trim();
                if (!sku) return;

                // Get all 3 prices for this SKU
                var row = input.closest('.dnc-sn-mp-pricing-row');
                if (!row) return;
                var allInputs = row.querySelectorAll('.dnc-sn-mp-price-input');
                var prices = { price_1y: null, price_2y: null, price_3y: null };
                allInputs.forEach(function(inp) {
                    var y = parseInt(inp.dataset.years, 10);
                    var v = String(inp.value || '').trim();
                    if (v !== '') prices['price_' + y + 'y'] = parseFloat(v);
                });

                // Client-side validate (mirror PHP dinoco_sn_marketplace_validate_pricing)
                var clientErrs = [];
                if (prices.price_1y !== null && prices.price_2y !== null && prices.price_2y < prices.price_1y) {
                    clientErrs.push('price_2y_below_1y');
                }
                if (prices.price_2y !== null && prices.price_3y !== null && prices.price_3y < prices.price_2y) {
                    clientErrs.push('price_3y_below_2y');
                }
                ['price_1y', 'price_2y', 'price_3y'].forEach(function(k) {
                    if (prices[k] !== null && prices[k] < 0) clientErrs.push(k + '_negative');
                    if (prices[k] !== null && prices[k] > 1000000) clientErrs.push(k + '_too_high');
                });

                var feedback = input.parentNode.querySelector('.dnc-sn-mp-feedback');
                if (feedback) feedback.innerHTML = '<span class="dnc-sn-mp-save-spinner" aria-label="saving"></span>';

                if (clientErrs.length) {
                    if (feedback) feedback.innerHTML = '<span style="color:#dc2626; font-size:11px;">⚠️ ' + clientErrs.join(', ') + '</span>';
                    input.style.borderColor = '#dc2626';
                    return;
                }

                fetch(REST_BASE + '/marketplace/pricing/' + encodeURIComponent(sku), {
                    method: 'POST',
                    headers: {
                        'X-WP-Nonce': NONCE,
                        'Content-Type': 'application/json'
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify(prices)
                })
                .then(function(r) {
                    if (r.status === 404) {
                        if (feedback) feedback.innerHTML = '<span style="color:#dc2626; font-size:11px;">⚠️ Endpoint not deployed</span>';
                        throw new Error('endpoint_not_ready');
                    }
                    return r.json().then(function(j) { return { status: r.status, body: j }; });
                })
                .then(function(res) {
                    if (res.status >= 400) {
                        var msg = (res.body && res.body.message) || 'Save failed';
                        if (feedback) feedback.innerHTML = '<span style="color:#dc2626; font-size:11px;">⚠️ ' + escapeHtml(msg) + '</span>';
                        input.style.borderColor = '#dc2626';
                        return;
                    }
                    if (feedback) feedback.innerHTML = '<span class="dnc-sn-mp-save-ok" aria-label="saved">✓</span>';
                    input.style.borderColor = '';
                    setTimeout(function() {
                        if (feedback) feedback.innerHTML = '';
                    }, 2000);
                    var actor = (window.dnc_admin_name || 'Admin');
                    if (window.console && console.log) {
                        console.log('[mp-pricing] ' + sku + ' ' + years + 'y → ' + (rawVal || 'NULL') + ' (' + actor + ')');
                    }
                })
                .catch(function(err) {
                    if (err.message === 'endpoint_not_ready') return;
                    if (feedback) feedback.innerHTML = '<span style="color:#dc2626; font-size:11px;">⚠️ Network error</span>';
                });
            };

            // ═══════ Sub-tab 2: Pending Review (W15.5) ═══════
            window.dncSnMpRefreshPendingBadge = function() {
                fetch(REST_BASE + '/marketplace/pending-review?count_only=1', {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin'
                })
