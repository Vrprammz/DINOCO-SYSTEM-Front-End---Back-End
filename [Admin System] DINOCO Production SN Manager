        if ( ! function_exists( 'current_user_can' ) || ! current_user_can( 'manage_options' ) ) return;
        $blocked_at = get_option( 'dinoco_sn_schema_alter_blocked_at', '' );
        if ( ! $blocked_at ) return;
        // Auto-clear when schema reaches target version (CLI ran successfully)
        if ( function_exists( 'dinoco_sn_schema_version' )
             && version_compare( dinoco_sn_schema_version(), DINOCO_SN_SCHEMA_VERSION, '>=' ) ) {
            delete_option( 'dinoco_sn_schema_alter_blocked_at' );
            delete_option( 'dinoco_sn_schema_alter_blocked_rowcount' );
            return;
        }
        $rowcount = (int) get_option( 'dinoco_sn_schema_alter_blocked_rowcount', 0 );
        echo '<div class="notice notice-warning is-dismissible"><p><strong>S/N Schema Migration Pending</strong></p>';
        echo '<p>Pool size (~' . esc_html( number_format( $rowcount ) ) . ' rows) is above the safe-auto-migrate threshold (100,000). The web installer was skipped to avoid a multi-second WRITE LOCK on production. Run this from CLI on the server:</p>';
        echo '<p><code>wp eval "dinoco_sn_schema_install();"</code></p>';
        echo '<p>For very large deployments use <code>pt-online-schema-change</code> (Percona Toolkit) instead.</p>';
        echo '<p><em>Blocked at: ' . esc_html( $blocked_at ) . '</em></p></div>';
    }
}

if ( ! function_exists( 'dinoco_sn_maybe_install' ) ) {
    function dinoco_sn_maybe_install() {
        // Only install if version mismatch (cheap check)
        if ( version_compare( dinoco_sn_schema_version(), DINOCO_SN_SCHEMA_VERSION, '>=' ) ) {
            return;
        }
        try {
            dinoco_sn_schema_install();
        } catch ( \Throwable $e ) {
            // Non-throwing — log + continue
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_schema_install' ) );
            } else {
                error_log( '[DINOCO S/N] Schema install failed: ' . $e->getMessage() );
            }
        }
    }
}

