                        '<button class="dnc-sn-btn dnc-sn-btn-secondary" style="min-height:44px;margin-left:auto;" ' +
                            'onclick="dncSnTabManageBulkLinkDealer()">🏪 Link Dealer (bulk)</button>' +
                    '</div>';
