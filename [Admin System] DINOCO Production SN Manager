            /* Phase 2 W5 / V.0.13 — Audit Log CSV Export */
            window.dncSnExportAuditCsv = function() {
                var sn = (document.getElementById('dnc-sn-audit-sn') || {}).value || '';
                var event_type = (document.getElementById('dnc-sn-audit-event') || {}).value || '';
                var days = (document.getElementById('dnc-sn-audit-days') || {}).value || '30';
                var meta = document.getElementById('dnc-sn-audit-meta');

                var url = REST_BASE + '/audit/export?days=' + encodeURIComponent(days) + '&_wpnonce=' + encodeURIComponent(NONCE);
                if (sn) url += '&sn=' + encodeURIComponent(sn);
                if (event_type) url += '&event_type=' + encodeURIComponent(event_type);

                if (meta) meta.textContent = 'กำลังเตรียมไฟล์ CSV…';

                // Use fetch + Blob to handle 429 / 503 gracefully (anchor tag would
                // navigate to error page on failure)
                fetch(url, {
                    headers: { 'X-WP-Nonce': NONCE, 'Accept': 'text/csv' },
                    credentials: 'same-origin',
                })
                .then(function(r) {
                    if (r.status === 429) {
                        throw new Error('เกินจำนวน export ที่อนุญาต (5/ชม.) กรุณารอแล้วลองใหม่');
                    }
                    if (r.status === 503) {
                        throw new Error('ระบบยังไม่ติดตั้ง audit table');
                    }
                    if (!r.ok) {
                        throw new Error('Export failed (HTTP ' + r.status + ')');
                    }
                    var rowCount = r.headers.get('X-Audit-Row-Count') || '?';
                    return r.blob().then(function(blob) {
                        return { blob: blob, rows: rowCount };
                    });
                })
                .then(function(result) {
                    var dispo = 'sn_audit_' + new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-') + '.csv';
                    var link = document.createElement('a');
                    link.href = URL.createObjectURL(result.blob);
                    link.download = dispo;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    setTimeout(function() { URL.revokeObjectURL(link.href); }, 5000);
                    if (meta) meta.textContent = 'Export เสร็จ — ' + result.rows + ' rows ดาวน์โหลด CSV แล้ว';
                })
                .catch(function(e) {
                    if (meta) meta.textContent = 'Export failed: ' + e.message;
                });
            };

