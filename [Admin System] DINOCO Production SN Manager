                        return _dncSnTabManageRenderCard(r);
                    }).join('');
                })
                .catch(function(e) {
                    if (meta) meta.textContent = 'ค้นหาล้มเหลว: ' + e.message;
                    resultsEl.innerHTML = '<div class="dnc-sn-empty" style="padding:24px;color:#dc2626;">ค้นหาล้มเหลว: ' +
                        _dncSnTabManageEsc(e.message) + '</div>';
