     */
    function dinoco_sn_run_notification_send() {
        update_option( 'dinoco_cron_sn_notification_send_last_run', current_time( 'mysql' ), false );

        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        $send_enabled = (bool) get_option( 'dinoco_sn_notification_send_enabled', false );
        if ( ! $send_enabled ) {
            // Stub mode — record visibility only, no actual push
            return;
        }

        // Phase 4 implementation hook — actual send logic
        // Stub for now: dequeue + log (no push)
        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'notifications' );
            $now = current_time( 'mysql' );

            $batch = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, sn, user_id, notification_type, meta_json
                 FROM {$tbl}
                 WHERE status = 'scheduled' AND scheduled_at <= %s
                 ORDER BY scheduled_at ASC
                 LIMIT 50",
