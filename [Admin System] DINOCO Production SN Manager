    /**
     * Plates whose warranty ends within $days_window. Used by Member
     * Dashboard expiry banner (F#1 surfaces the same data through the
     * notifications table — this helper is for instant read).
     *
     * Warranty math: `warranty_until = registered_at + warranty_years YEAR`
     * matches the F#1 schedule cron. Default warranty_years=1 if not
     * stored on plate (per v2.10 §F#1 default).
     *
     * @param int $user_id
     * @param int $days_window  default 30 (clamped 1..365)
     * @return array<object>    sn, top_set_sku, registered_at, days_left
     */
    function dinoco_sn_get_user_expiring_plates( $user_id, $days_window = 30 ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return array();
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return array();
        $days = max( 1, min( 365, (int) $days_window ) );

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT sn,
                    linked_sku,
                    registered_at,
                    DATEDIFF(
                        DATE_ADD( DATE(registered_at), INTERVAL 1 YEAR ),
                        CURDATE()
                    ) AS days_left
             FROM {$tbl}
             WHERE registered_user_id = %d
               AND status = 'registered'
               AND DATE_ADD( DATE(registered_at), INTERVAL 1 YEAR )
                   BETWEEN CURDATE() AND DATE_ADD( CURDATE(), INTERVAL %d DAY )
             ORDER BY days_left ASC",
            $user_id,
            $days
        ) );
        return is_array( $rows ) ? $rows : array();
    }
}

