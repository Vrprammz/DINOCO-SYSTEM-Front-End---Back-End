if ( ! function_exists( 'dinoco_sn_run_gray_market_scan' ) ) {
    /**
     * Phase 3 W11.1 — F#13 Gray Market weekly scan (full worker)
     * Mondays 09:00 — aggregate per-province activations + flag provinces
     * with NO dealer presence but >N activations in window (default 30d).
     *
     * V.0.28 (W11.1) wires:
     *   - Aggregate per-province activations (last N days, default 30)
     *   - Cross-reference dealer territory (b2b_distributor CPT province match)
     *   - Classify each candidate via dinoco_sn_classify_gray_market()
     *   - UPDATE is_gray_market_suspect flag on rows for flagged provinces
     *   - Generate weekly Flex/Telegram report → boss
     *   - Heartbeat: dinoco_cron_sn_gray_market_scan_last_run
     */
    function dinoco_sn_run_gray_market_scan() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'geo_activations' ) ) return;

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'geo_activations' );
            $days = max( 1, min( 365, (int) get_option( 'dinoco_sn_gray_market_window_days', 30 ) ) );
            $threshold = max( 1, (int) get_option( 'dinoco_sn_gray_market_threshold', 20 ) );

            // Step 1 — aggregate per province
            $candidates = $wpdb->get_results( $wpdb->prepare(
                "SELECT province, COUNT(*) AS activations
                 FROM {$tbl}
                 WHERE created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
                 GROUP BY province
                 HAVING activations >= %d
                 ORDER BY activations DESC
                 LIMIT 200",
                $days, $threshold
            ), ARRAY_A );

            $flagged = array();
            $foreign_count = 0;
            $underserved_count = 0;

            // Step 2 — classify each candidate
            foreach ( (array) $candidates as $row ) {
                $province = (string) $row['province'];
                $activations = (int) $row['activations'];

                // Determine country code (heuristic — Phase 4 W12 wires reliably)
                $country_code = function_exists( 'dinoco_sn_province_country_code' )
                    ? dinoco_sn_province_country_code( $province )
                    : 'TH';

                // Has-dealer check via existing helper (defensive)
                $has_dealer = function_exists( 'dinoco_sn_province_has_dealer' )
                    ? dinoco_sn_province_has_dealer( $province )
                    : false;

                $classification = function_exists( 'dinoco_sn_classify_gray_market' )
                    ? dinoco_sn_classify_gray_market( $country_code, $has_dealer )
                    : 'normal';

                if ( $classification === 'normal' ) continue;

                if ( $classification === 'gray_market_suspect' ) $foreign_count++;
                if ( $classification === 'underserved_market' ) $underserved_count++;

                // Step 3 — UPDATE rows for this province within window
                $wpdb->query( $wpdb->prepare(
                    "UPDATE {$tbl}
                     SET is_gray_market_suspect = 1
                     WHERE province = %s
                       AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
                       AND is_gray_market_suspect = 0",
                    $province, $days
                ) );

                $flagged[] = array(
                    'province'      => $province,
                    'activations'   => $activations,
                    'classification'=> $classification,
                    'country_code'  => $country_code,
                    'has_dealer'    => $has_dealer ? 1 : 0,
                );
            }

            $summary = array(
                'at'                => current_time( 'mysql' ),
                'window_days'       => $days,
                'threshold'         => $threshold,
                'candidates'        => $candidates ?: array(),
                'flagged'           => $flagged,
                'flagged_count'     => count( $flagged ),
                'foreign_count'     => $foreign_count,
                'underserved_count' => $underserved_count,
            );
            update_option( 'dinoco_sn_gray_market_last_scan', $summary, false );

            // Step 4 — Telegram alert (defensive function_exists)
            if ( count( $flagged ) > 0 && function_exists( 'b2b_send_telegram_alert' ) ) {
                $lines = array(
                    '⚠️ *DINOCO Gray Market Scan*',
                    sprintf( 'Window: %dd · Threshold: %d activations', $days, $threshold ),
                    sprintf( '🌐 Foreign suspects: %d · 🏪 Underserved: %d',
                        $foreign_count, $underserved_count ),
                    '',
                );
                $top = array_slice( $flagged, 0, 10 );
                foreach ( $top as $f ) {
                    $emoji = ( $f['classification'] === 'gray_market_suspect' ) ? '🌐' : '🏪';
                    $lines[] = sprintf( '%s %s — %d activations (%s)',
                        $emoji, $f['province'], $f['activations'], $f['classification'] );
                }
                @b2b_send_telegram_alert( implode( "\n", $lines ), 'gray_market_scan' );
            }

            // Step 5 — Flex push to boss group (defensive)
            if ( count( $flagged ) > 0 && function_exists( 'b2b_send_flex_message' )
                && defined( 'B2B_ADMIN_GROUP_ID' ) ) {
                // Build minimal Flex (Phase 4 polish: dedicated builder)
                // For now, plain text fallback if helper doesn't accept structured
                if ( function_exists( 'b2b_send_text_to_group' ) ) {
                    $msg = sprintf( "⚠️ Gray Market: %d provinces flagged (last %dd)",
                        count( $flagged ), $days );
                    @b2b_send_text_to_group( B2B_ADMIN_GROUP_ID, $msg );
                }
            }

        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_gray_market_scan' ) );
            }
        }

        update_option( 'dinoco_cron_sn_gray_market_scan_last_run', current_time( 'mysql' ), false );
    }
}

if ( ! function_exists( 'dinoco_sn_resolve_province_from_ip' ) ) {
    /**
     * Phase 3 W11.1 — F#13 defensive IP → province resolver.
     *
     * Returns 'Unknown' when no helper available (Phase 3 W11.1 stub).
     * Phase 4 W12 wires Maxmind GeoIP / IP-API library.
     *
     * Best-effort chain (function_exists guarded):
     *   1. dinoco_get_province_from_ip()  — Brand Voice helper (if synced)
     *   2. b2b_geolocate_ip()             — B2B helper (if synced)
     *   3. 'Unknown'                       — defensive default
     *
     * @param string $ip IPv4/IPv6 address
     * @return string Thai province name OR 'Unknown'
     */
    function dinoco_sn_resolve_province_from_ip( $ip ) {
        $ip = trim( (string) $ip );
        if ( $ip === '' ) return 'Unknown';

        if ( function_exists( 'dinoco_get_province_from_ip' ) ) {
            $p = dinoco_get_province_from_ip( $ip );
            if ( is_string( $p ) && $p !== '' ) return $p;
        }
        if ( function_exists( 'b2b_geolocate_ip' ) ) {
            $loc = b2b_geolocate_ip( $ip );
            if ( is_array( $loc ) && ! empty( $loc['province'] ) ) {
                return (string) $loc['province'];
            }
        }
        return 'Unknown';
    }
}

