    function dinoco_sn_admin_post_toggle() {
        if ( ! current_user_can( 'manage_options' ) ) {
            wp_die( 'ไม่มีสิทธิ์', 403 );
        }
        check_admin_referer( DINOCO_SN_TOGGLE_NONCE );

        $enabled = ! empty( $_POST['enabled'] ) && $_POST['enabled'] !== '0';
        $old = (bool) get_option( 'dinoco_sn_system_enabled', false );
        $new_value = $enabled ? '1' : '0';

        if ( $old !== $enabled ) {
            update_option( 'dinoco_sn_system_enabled', $new_value );
            // Audit log defensive
            if ( function_exists( 'dinoco_flag_audit_log' ) ) {
                @dinoco_flag_audit_log(
                    'dinoco_sn_system_enabled',
                    $old ? '1' : '0',
                    $new_value,
                    $enabled ? 'admin enabled S/N (admin-post fallback)' : 'admin disabled S/N (admin-post fallback)',
                    'sn_manager_ui_admin_post'
                );
            }
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                @dinoco_sn_audit_log( null, 'system_flag_toggled', null, null, array(
                    'flag'  => 'dinoco_sn_system_enabled',
                    'old'   => $old ? '1' : '0',
                    'new'   => $new_value,
                    'actor' => get_current_user_id(),
                    'via'   => 'admin-post-fallback',
                ) );
            }
            // Force-clear option cache (defensive — some hosts have stale caches)
            wp_cache_delete( 'dinoco_sn_system_enabled', 'options' );
        }

        $referer = wp_get_referer();
        $redirect_to = $referer ?: home_url( '/admin-command-center/#inventory.generate' );
        // Append success flag for UI to show toast on next render
        $redirect_to = add_query_arg(
            array( 'sn_toggle' => $enabled ? 'on' : 'off' ),
            $redirect_to
        );
        wp_safe_redirect( $redirect_to );
        exit;
    }
}

