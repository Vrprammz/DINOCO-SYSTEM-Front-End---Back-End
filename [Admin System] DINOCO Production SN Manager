                            '<td><strong>' + escapeHtml(r.province) + '</strong></td>' +
                            '<td>' + r.activations + '</td>' +
                            '<td ' + grayClass + '>' + (r.gray_market_count > 0 ? '⚠️ ' + r.gray_market_count : '—') + '</td>' +
                            '<td>' + (r.avg_lat !== null ? r.avg_lat.toFixed(4) : '—') + '</td>' +
                            '<td>' + (r.avg_lng !== null ? r.avg_lng.toFixed(4) : '—') + '</td>' +
                        '</tr>';
