        // Run dbDelta — order matters for some FKs (we don't have explicit
        // FKs but logical dependencies exist: pool_meta references pool's sn)
        dbDelta( $sql_batches );
        dbDelta( $sql_pool );
        dbDelta( $sql_pool_meta );
        dbDelta( $sql_audit );
        dbDelta( $sql_notifications );
        dbDelta( $sql_promo );
        dbDelta( $sql_ltv );
        dbDelta( $sql_reviews );
