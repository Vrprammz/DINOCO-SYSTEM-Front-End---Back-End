            // Auto-load pending on tab activation + poll every 60s
            (function _dncSnTabManageLazyApprovals() {
                var manageTab = document.querySelector('[data-tab="manage"]');
                if (!manageTab) return;
                var loaded = false;
                manageTab.addEventListener('click', function() {
                    if (loaded) return;
                    loaded = true;
                    if (window.dncSnTabManageLoadPendingApprovals) {
                        window.dncSnTabManageLoadPendingApprovals();
                    }
                    // Poll every 60s while user stays on manage tab
                    if (_dncSnTabManagePendingTimer) clearInterval(_dncSnTabManagePendingTimer);
                    _dncSnTabManagePendingTimer = setInterval(function() {
                        // Only poll if Manage tab still active (don't waste cycles elsewhere)
                        var manageActive = manageTab.classList.contains('active');
                        if (manageActive && window.dncSnTabManageLoadPendingApprovals) {
                            window.dncSnTabManageLoadPendingApprovals();
                        }
                    }, 60000);
                });
            })();

            window.dncSnLoadAudit = function() {
                var sn = (document.getElementById('dnc-sn-audit-sn') || {}).value || '';
                var event_type = (document.getElementById('dnc-sn-audit-event') || {}).value || '';
                var days = (document.getElementById('dnc-sn-audit-days') || {}).value || '30';
                var meta = document.getElementById('dnc-sn-audit-meta');
                var tbody = document.querySelector('#dnc-sn-audit-table tbody');
                if (meta) meta.textContent = 'Loading…';
                if (tbody) tbody.innerHTML = '<tr><td colspan="6" class="dnc-sn-empty">Loading…</td></tr>';

                var url = REST_BASE + '/audit?limit=100&days=' + encodeURIComponent(days);
                if (sn) url += '&sn=' + encodeURIComponent(sn);
                if (event_type) url += '&event_type=' + encodeURIComponent(event_type);

                fetch(url, {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data || !Array.isArray(data.rows)) {
                        if (meta) meta.textContent = 'No data';
                        return;
                    }
                    if (meta) meta.textContent = 'พบ ' + data.total + ' events (แสดง ' + data.rows.length + ')';
                    if (!data.rows.length) {
                        tbody.innerHTML = '<tr><td colspan="6" class="dnc-sn-empty">ไม่มี audit events ตาม filter</td></tr>';
                        return;
                    }
                    tbody.innerHTML = data.rows.map(function(r) {
                        var transition = (r.status_from && r.status_to) ? (escapeHtml(r.status_from) + ' → ' + escapeHtml(r.status_to)) : '—';
                        return '<tr' + (r.is_sensitive ? ' class="dnc-sn-row-sensitive"' : '') + '>' +
                            '<td>' + fmtDate(r.created_at) + '</td>' +
                            '<td><code>' + escapeHtml(r.sn || '—') + '</code></td>' +
                            '<td>' + escapeHtml(r.event_type) + '</td>' +
                            '<td>' + transition + '</td>' +
                            '<td>' + escapeHtml(r.actor_display || ('user#' + (r.actor_user_id || '?'))) + '</td>' +
                            '<td>' + escapeHtml(r.reason || '—') + '</td>' +
                        '</tr>';
                    }).join('');
                })
                .catch(function(e) { if (meta) meta.textContent = 'Load failed: ' + e.message; });
            };

            /* Phase 2 W5 / V.0.13 — Audit Log CSV Export */
            window.dncSnExportAuditCsv = function() {
                var sn = (document.getElementById('dnc-sn-audit-sn') || {}).value || '';
                var event_type = (document.getElementById('dnc-sn-audit-event') || {}).value || '';
                var days = (document.getElementById('dnc-sn-audit-days') || {}).value || '30';
                var meta = document.getElementById('dnc-sn-audit-meta');

                var url = REST_BASE + '/audit/export?days=' + encodeURIComponent(days) + '&_wpnonce=' + encodeURIComponent(NONCE);
                if (sn) url += '&sn=' + encodeURIComponent(sn);
                if (event_type) url += '&event_type=' + encodeURIComponent(event_type);

                if (meta) meta.textContent = 'กำลังเตรียมไฟล์ CSV…';

                // Use fetch + Blob to handle 429 / 503 gracefully (anchor tag would
                // navigate to error page on failure)
                fetch(url, {
                    headers: { 'X-WP-Nonce': NONCE, 'Accept': 'text/csv' },
                    credentials: 'same-origin',
                })
                .then(function(r) {
                    if (r.status === 429) {
                        throw new Error('เกินจำนวน export ที่อนุญาต (5/ชม.) กรุณารอแล้วลองใหม่');
                    }
                    if (r.status === 503) {
                        throw new Error('ระบบยังไม่ติดตั้ง audit table');
                    }
                    if (!r.ok) {
                        throw new Error('Export failed (HTTP ' + r.status + ')');
                    }
                    var rowCount = r.headers.get('X-Audit-Row-Count') || '?';
                    return r.blob().then(function(blob) {
                        return { blob: blob, rows: rowCount };
                    });
                })
                .then(function(result) {
                    var dispo = 'sn_audit_' + new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-') + '.csv';
                    var link = document.createElement('a');
                    link.href = URL.createObjectURL(result.blob);
                    link.download = dispo;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    setTimeout(function() { URL.revokeObjectURL(link.href); }, 5000);
                    if (meta) meta.textContent = 'Export เสร็จ — ' + result.rows + ' rows ดาวน์โหลด CSV แล้ว';
