                    link.download = dispo;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    setTimeout(function() { URL.revokeObjectURL(link.href); }, 5000);
                    if (meta) meta.textContent = 'Export เสร็จ — ' + result.rows + ' rows ดาวน์โหลด CSV แล้ว'
                        + (result.pii ? '' : ' · PII masked (email + phone)');
                })
                .catch(function(e) {
                    if (meta) meta.textContent = 'Export failed: ' + e.message;
                });
            };

