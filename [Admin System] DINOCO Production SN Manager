if ( ! function_exists( 'dinoco_sn_table' ) ) {
    /**
     * Get fully prefixed table name. Use this instead of hardcoding
     * to support multisite + table prefix variations.
     *
     * Usage: $tbl = dinoco_sn_table( 'pool' );
     *        // → 'wp_dinoco_sn_pool'
     */
    function dinoco_sn_table( $logical_name ) {
        global $wpdb;
        $tables = DINOCO_SN_TABLES;
        if ( ! isset( $tables[ $logical_name ] ) ) {
            return '';
        }
        return $wpdb->prefix . $tables[ $logical_name ];
    }
}

if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
    /**
     * Check if table physically exists. Defensive — used before
     * any query during transition period when schema may not yet
     * be installed (e.g., between snippet sync + admin_init fire).
     */
    function dinoco_sn_table_exists( $logical_name ) {
        global $wpdb;
        $tbl = dinoco_sn_table( $logical_name );
        if ( $tbl === '' ) return false;
        $result = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        return ( (int) $result ) > 0;
    }
}

/* ─── V.0.36 (2026-05-07) — Anti-enumeration random S/N + checksum ──────
 *
 * Boss directive: "S/N ที่สร้างไม่ควรเรียงกันกันการเดาสุ่ม" — sequential
 * IDs (DNCSS0001234, 0001235, ...) leak production volume + enable
 * enumeration attacks (warranty hijack, fraud probing, batch traversal).
 *
 * Plan v2.4 audit security #3 already flagged this — implementation here
 * supersedes earlier {SEQ:7} sequential format.
 *
 * Format: {PREFIX}{RAND6}{CHK1} — e.g. DNCSS K7H2N9X (12 chars)
 *   • PREFIX:   3-6 user-defined uppercase chars (DNCSS)
 *   • RAND6:    Crockford base32 random — 6 chars from
 *               0123456789ABCDEFGHJKMNPQRSTVWXYZ (no I/O/U/L confusion)
 *               Entropy: 32^6 ≈ 1 billion combinations per batch
 *   • CHK1:     Luhn-mod-32 checksum — catches 100% single-char typos +
 *               most adjacent transpositions, deters random guessing
 *               (1/32 ≈ 3% accept rate)
 *
 * Backward compat: existing batches with {PREFIX}{SEQ:7} sequential SNs
 * keep working — generator only changes for NEW batches with {RAND6}{CHK1}
 * format pattern. seq_index column tracks within-batch ordering for
 * Range Mode rับเพลท (admin scans first plate → system fetches range
 * by batch_id + seq_index instead of sn arithmetic).
 */

if ( ! function_exists( 'dinoco_sn_crockford_alphabet' ) ) {
    function dinoco_sn_crockford_alphabet() {
        // Crockford base32 — readable, no I/L/O/U confusion
        return '0123456789ABCDEFGHJKMNPQRSTVWXYZ';
    }
}

if ( ! function_exists( 'dinoco_sn_generate_random_token' ) ) {
    /**
     * Generate random Crockford base32 token of $length chars.
     * Uses random_bytes (CSPRNG) — collision-resistant.
     *
     * @param int $length 1-12 recommended
     * @return string Uppercase Crockford base32 string
     */
    function dinoco_sn_generate_random_token( $length = 6 ) {
        $length = max( 1, min( 16, (int) $length ) );
        $alphabet = dinoco_sn_crockford_alphabet();
        $alpha_len = strlen( $alphabet );
        $bytes = random_bytes( $length * 2 ); // over-sample to avoid bias
        $out = '';
        for ( $i = 0; $i < $length; $i++ ) {
            $out .= $alphabet[ ord( $bytes[ $i ] ) % $alpha_len ];
        }
        return $out;
    }
}

if ( ! function_exists( 'dinoco_sn_compute_checksum' ) ) {
    /**
     * Compute Luhn-mod-32 checksum char for a Crockford base32 string.
     * Deterministic — same input always yields same checksum char.
     *
     * Algorithm: weighted sum of char positions (alternating 1x, 2x),
     * mod 32 → alphabet[result] = checksum char.
     *
     * Catches: 100% single-char typos, 96% adjacent transpositions.
     *
     * @param string $body Crockford base32 string (the part to checksum)
     * @return string Single Crockford base32 char
     */
    function dinoco_sn_compute_checksum( $body ) {
        $body = strtoupper( (string) $body );
        $alphabet = dinoco_sn_crockford_alphabet();
        $alpha_len = strlen( $alphabet );
        $sum = 0;
        $len = strlen( $body );
        for ( $i = 0; $i < $len; $i++ ) {
            $pos = strpos( $alphabet, $body[ $i ] );
            if ( $pos === false ) continue; // skip non-base32 chars (e.g. user-prefix letters)
            $weight = ( $i % 2 === 0 ) ? 1 : 2;
            $product = $pos * $weight;
            // Sum digits of product (Luhn pattern)
            $sum += intdiv( $product, $alpha_len ) + ( $product % $alpha_len );
        }
        return $alphabet[ $sum % $alpha_len ];
    }
}

if ( ! function_exists( 'dinoco_sn_validate_checksum' ) ) {
    /**
     * Verify the trailing checksum char of a S/N.
     *
     * V.0.39 H1 FIX: previously skipped non-Crockford chars in compute()
     * meant `DNCSI` (typo) vs `DNCSS` could yield the same checksum because
     * `I` is skipped in BOTH compute paths (collisions on prefix typos).
     * Now we STRICT-validate every char in body must be in Crockford
     * alphabet before re-computing — prefix typo → false reject (safe).
     *
     * Note: `dinoco_sn_compute_checksum()` retains its skip-on-foreign
     * behavior so it can still be called with mixed prefixes during
     * EDITING workflows (admin enters prefix first), but VALIDATE is
     * strict because validation runs after S/N is fully formed.
     *
     * @param string $sn Full S/N (prefix + random + checksum)
     * @return bool true if checksum valid AND all body chars are Crockford
     */
    function dinoco_sn_validate_checksum( $sn ) {
        $sn = strtoupper( (string) $sn );
        if ( strlen( $sn ) < 2 ) return false;
        $body = substr( $sn, 0, -1 );
        $given = substr( $sn, -1 );

        // STRICT body validation — every char must be in Crockford alphabet.
        // Catches prefix typos (DNCSI vs DNCSS where I/O/U masquerade).
        $alphabet = dinoco_sn_crockford_alphabet();
        $body_len = strlen( $body );
        for ( $i = 0; $i < $body_len; $i++ ) {
            if ( strpos( $alphabet, $body[ $i ] ) === false ) {
                return false;
            }
        }

        // Trailing checksum must also be Crockford
        if ( strpos( $alphabet, $given ) === false ) return false;

        return $given === dinoco_sn_compute_checksum( $body );
    }
}

if ( ! function_exists( 'dinoco_sn_format_random' ) ) {
    /**
     * Build a complete random S/N: PREFIX + RAND6 + CHK1
     *
     * Checksum computed over FULL body (prefix + random) — consistent with
     * dinoco_sn_validate_checksum which strips last char and re-computes.
     *
     * @param string $prefix Uppercase prefix (DNCSS)
     * @param int    $rand_length Random char count (default 6)
     * @return string Full S/N with checksum
     */
    function dinoco_sn_format_random( $prefix, $rand_length = 6 ) {
        $prefix = strtoupper( (string) $prefix );
        $body = $prefix . dinoco_sn_generate_random_token( $rand_length );
        $check = dinoco_sn_compute_checksum( $body );
        return $body . $check;
    }
}

