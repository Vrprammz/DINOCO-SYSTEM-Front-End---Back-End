if ( ! function_exists( 'dinoco_sn_build_warranty_url' ) ) {
    /**
     * V.0.35 (2026-05-07) — Build warranty URL with LIFF preference
     *
     * @param string $type   'activate' | 'extend'
     * @param string $sn     S/N (e.g. DNCSS0001234)
     * @param bool   $prefer_liff  true = use LIFF URL (in-LINE app), false = web URL
     *
     * Resolution order for LIFF ID:
     *   1. wp_option 'dinoco_sn_liff_<type>_id' (admin-configurable)
     *   2. WP constant DINOCO_SN_LIFF_<TYPE>_ID (wp-config.php fallback)
     *   3. Hardcoded default (today's provisioned LIFF IDs in DINOCO LOGIN SYSTEM channel)
     *   4. Web URL fallback via home_url() if no LIFF ID anywhere
     *
     * Use cases:
     *   - QR code printed on plate (factory) → prefer_liff=false (camera scan opens browser)
     *   - LINE Flex card "🔄 ต่อประกัน" → prefer_liff=true (stays in LINE app)
     *   - Admin "💬 ส่ง LINE หา customer" → prefer_liff=true
     */
    function dinoco_sn_build_warranty_url( $type, $sn, $prefer_liff = true ) {
        $type = ( $type === 'activate' ) ? 'activate' : 'extend';
        $sn   = strtoupper( trim( (string) $sn ) );

        // V.0.29 CRIT-2 — always append &sig= when REST API V.0.29+ HMAC helper
        // is synced. URLs printed today on QR codes / sent in Notifier Flex /
        // Marketplace LIFF entry remain valid even after admin promotes
        // dinoco_sn_hmac_required=1. Backward compat: when helper missing the
        // raw URL is emitted (current pre-V.0.29 behavior).
        $sig_q = '';
        if ( $sn !== '' && function_exists( 'dinoco_sn_hmac_sign' ) ) {
            $sig = dinoco_sn_hmac_sign( $sn );
            if ( is_string( $sig ) && $sig !== '' ) {
                $sig_q = '&sig=' . rawurlencode( $sig );
            }
        }
        $sn_q = '?sn=' . rawurlencode( $sn ) . $sig_q;

        // Hardcoded defaults (DINOCO LOGIN SYSTEM channel 2008686775, provisioned 2026-05-07)
        $default_liff_ids = array(
            'activate' => '2008686775-WzPnX7dB',
            'extend'   => '2008686775-bJp0ljpM',
        );

        if ( $prefer_liff ) {
            $opt_key  = 'dinoco_sn_liff_' . $type . '_id';
            $const_key = 'DINOCO_SN_LIFF_' . strtoupper( $type ) . '_ID';
            $liff_id  = (string) get_option( $opt_key, '' );
            if ( $liff_id === '' && defined( $const_key ) ) {
                $liff_id = (string) constant( $const_key );
            }
            if ( $liff_id === '' && isset( $default_liff_ids[ $type ] ) ) {
                $liff_id = $default_liff_ids[ $type ];
            }
            if ( $liff_id !== '' ) {
                return 'https://liff.line.me/' . $liff_id . $sn_q;
            }
        }

        // Web URL fallback (used by QR codes printed on plates)
        $path = ( $type === 'activate' ) ? '/warranty/activate/' : '/warranty/extend/';
        return home_url( $path . $sn_q );
    }
}

