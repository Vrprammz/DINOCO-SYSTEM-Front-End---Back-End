if ( ! function_exists( 'dinoco_sn_apply_bin_collations' ) ) {
    /**
     * Apply utf8mb4_bin collation to S/N + SKU columns. Idempotent —
     * checks current collation via INFORMATION_SCHEMA before ALTER.
     *
     * Tables/columns affected:
     *   sn_pool.sn, sn_pool.linked_sku
     *   sn_pool_meta.sn, sn_pool_meta.top_set_sku, replaced_by_sn, replaces_sn
     *   sn_audit.sn
     *   sn_notifications.sn
     *   sn_promo_codes.source_sn
     *   sn_review_requests.sn
     *   sn_fraud_scores.sn
     *   sn_geo_activations.sn
     *   sn_stolen_log.sn
     *   sn_demand_forecast.sku
     *   sn_warranty_extensions.sn
     */
    function dinoco_sn_apply_bin_collations() {
        global $wpdb;
        $prefix = $wpdb->prefix;

        $bin_columns = array(
            // table => array( column => 'TYPE' )
            'pool'             => array(
                'sn'         => 'VARCHAR(40)',
                'linked_sku' => 'VARCHAR(50)',
            ),
            'pool_meta'        => array(
                'sn'             => 'VARCHAR(40)',
                'top_set_sku'    => 'VARCHAR(50)',
                'replaced_by_sn' => 'VARCHAR(40)',
                'replaces_sn'    => 'VARCHAR(40)',
            ),
            'audit'            => array( 'sn' => 'VARCHAR(40)' ),
            'notifications'    => array( 'sn' => 'VARCHAR(40)' ),
            'promo_codes'      => array( 'source_sn' => 'VARCHAR(40)' ),
            'review_requests'  => array( 'sn' => 'VARCHAR(40)' ),
            'fraud_scores'     => array( 'sn' => 'VARCHAR(40)' ),
            'geo_activations'  => array( 'sn' => 'VARCHAR(40)' ),
            'stolen_log'       => array( 'sn' => 'VARCHAR(40)' ),
            'demand_forecast'  => array( 'sku' => 'VARCHAR(50)' ),
            'extensions'       => array( 'sn' => 'VARCHAR(40)' ),
        );

        foreach ( $bin_columns as $logical => $cols ) {
            $tbl = dinoco_sn_table( $logical );
            if ( ! dinoco_sn_table_exists( $logical ) ) continue;

            foreach ( $cols as $col => $type ) {
                $current_col = $wpdb->get_row( $wpdb->prepare(
                    "SELECT COLLATION_NAME FROM information_schema.columns
                     WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                    DB_NAME, $tbl, $col
                ) );
                if ( ! $current_col ) continue;
                if ( $current_col->COLLATION_NAME === 'utf8mb4_bin' ) continue;

                // Apply collation — preserve nullability default
                $is_nullable_query = $wpdb->prepare(
                    "SELECT IS_NULLABLE FROM information_schema.columns
                     WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                    DB_NAME, $tbl, $col
                );
                $is_nullable = $wpdb->get_var( $is_nullable_query );
                $null_clause = ( $is_nullable === 'YES' ) ? 'DEFAULT NULL' : 'NOT NULL';

                $sql = "ALTER TABLE {$tbl} MODIFY COLUMN {$col} {$type} CHARACTER SET utf8mb4 COLLATE utf8mb4_bin {$null_clause}";
                $wpdb->query( $sql );
            }
        }
    }
}

if ( ! function_exists( 'dinoco_sn_alter_products_table' ) ) {
    /**
     * Add sn_attach_level + sn_required + sn_qty_per_unit columns to
     * wp_dinoco_products. Idempotent — checks INFORMATION_SCHEMA before ALTER.
     *
     * Per Q recommended preset: sn_attach_level enum(set/child/leaf/none).
     */
    function dinoco_sn_alter_products_table() {
        global $wpdb;
        $tbl = $wpdb->prefix . 'dinoco_products';

        // Check if products table exists (Inventory Snippet 15 must be deployed)
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        if ( ! $exists ) return; // Inventory not yet deployed — skip silently

        $alters = array(
            'sn_attach_level' => "ADD COLUMN sn_attach_level VARCHAR(20) NOT NULL DEFAULT 'none' AFTER ui_role_override",
            'sn_required'     => "ADD COLUMN sn_required TINYINT(1) NOT NULL DEFAULT 0 AFTER sn_attach_level",
            'sn_qty_per_unit' => "ADD COLUMN sn_qty_per_unit TINYINT(1) NOT NULL DEFAULT 1 AFTER sn_required",
        );

        foreach ( $alters as $col => $alter_sql ) {
            $col_exists = $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.columns
                 WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                DB_NAME, $tbl, $col
            ) );
            if ( $col_exists ) continue;
            $wpdb->query( "ALTER TABLE {$tbl} {$alter_sql}" );
        }

        // Add composite index if missing
        $idx_exists = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.statistics
             WHERE table_schema = %s AND table_name = %s AND index_name = %s",
            DB_NAME, $tbl, 'idx_sn_attach'
        ) );
        if ( ! $idx_exists ) {
            $wpdb->query( "ALTER TABLE {$tbl} ADD KEY idx_sn_attach (sn_attach_level, sn_required)" );
        }
    }
}

