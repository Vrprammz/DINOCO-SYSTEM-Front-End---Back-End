            window.dncSnSubmitRangeReceive = function() {
                var batchSel = document.getElementById('dnc-sn-receive-batch');
                var batch_id = parseInt(batchSel.value || '0');
                var sku = (document.getElementById('dnc-sn-receive-sku').value || '').toUpperCase().trim();
                var start = (document.getElementById('dnc-sn-range-start').value || '').toUpperCase().trim();
                var qty = parseInt(document.getElementById('dnc-sn-range-qty').value || '0');

                if (!batch_id || !sku || !start || !qty) {
                    alert('กรุณากรอกข้อมูลให้ครบ');
                    return;
                }

                var m = start.match(/^([A-Z]+)(\d+)$/);
                if (!m) { alert('รูปแบบ S/N ไม่ถูกต้อง'); return; }

                var prefix = m[1];
                var seq_start = parseInt(m[2]);
                var seq_pad = m[2].length;
                var sns = [];
                for (var i = 0; i < qty; i++) {
                    sns.push(prefix + String(seq_start + i).padStart(seq_pad, '0'));
                }

                // Cap at 100 (D4 contract)
                if (sns.length > 100) {
                    if (!confirm('กว่า 100 plates — ระบบจะแบ่ง chunks อัตโนมัติ ดำเนินการต่อ?')) return;
                }

                submitBulkReceive(batch_id, sku, sns, 'range');
