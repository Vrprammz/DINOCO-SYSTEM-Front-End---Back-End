if ( ! function_exists( 'dinoco_sn_get_user_anniversaries' ) ) {
    /**
     * Plates whose anniversary falls within $days_window from today.
     * Used by F#4 dashboard banner (preview anniversary before LINE Flex push).
     *
     * Mirrors `dinoco_sn_run_anniversary_schedule` cron logic — month-day
     * match against today (across N years). Caps at 5y to align with cron.
     *
     * @param int $user_id
     * @param int $days_window  default 7 (clamped 1..30)
     * @return array<object>    sn, registered_at, years_diff
     */
    function dinoco_sn_get_user_anniversaries( $user_id, $days_window = 7 ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return array();
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return array();
        $days = max( 1, min( 30, (int) $days_window ) );

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        // Find plates registered N years ago (1..5) on a date within +/- $days from today
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT sn, linked_sku, registered_at,
                    TIMESTAMPDIFF(YEAR, registered_at, CURDATE()) AS years_diff
             FROM {$tbl}
             WHERE registered_user_id = %d
               AND status = 'registered'
               AND TIMESTAMPDIFF(YEAR, registered_at, CURDATE()) BETWEEN 1 AND 5
               AND ABS(DATEDIFF(
                   DATE_ADD( DATE(registered_at),
                             INTERVAL TIMESTAMPDIFF(YEAR, registered_at, CURDATE()) YEAR ),
                   CURDATE()
               )) <= %d
             ORDER BY years_diff DESC",
            $user_id,
            $days
        ) );
        return is_array( $rows ) ? $rows : array();
    }
}

if ( ! function_exists( 'dinoco_sn_get_user_stats' ) ) {
    /**
     * Stats grid for dashboard hero — plates_count / active_count /
     * claim_count / member_years.
     *
     * Single SQL query — fast. Member dashboard renders 4 cells; if user
     * has no plates yet (legacy fallback) returns zeros.
     *
     * @return array{plates_count:int,active_count:int,claim_count:int,member_years:int}
     */
    function dinoco_sn_get_user_stats( $user_id ) {
        $user_id = (int) $user_id;
        $base = array(
            'plates_count' => 0,
            'active_count' => 0,
            'claim_count'  => 0,
            'member_years' => 0,
        );
        if ( $user_id <= 0 ) return $base;
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return $base;

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT
                COUNT(*) AS plates_count,
                SUM( CASE WHEN status = 'registered' THEN 1 ELSE 0 END ) AS active_count,
                SUM( CASE WHEN status = 'claimed' THEN 1 ELSE 0 END ) AS claim_count,
                MIN(registered_at) AS first_registered_at
             FROM {$tbl}
             WHERE registered_user_id = %d",
            $user_id
        ), ARRAY_A );

        if ( ! is_array( $row ) ) return $base;

        $stats = array(
            'plates_count' => (int) ( $row['plates_count'] ?? 0 ),
            'active_count' => (int) ( $row['active_count'] ?? 0 ),
            'claim_count'  => (int) ( $row['claim_count'] ?? 0 ),
            'member_years' => 0,
        );

        if ( ! empty( $row['first_registered_at'] ) ) {
            $first = strtotime( $row['first_registered_at'] );
            if ( $first !== false ) {
                $stats['member_years'] = (int) floor( ( time() - $first ) / ( 365 * 86400 ) );
            }
        }

        return $stats;
    }
}

