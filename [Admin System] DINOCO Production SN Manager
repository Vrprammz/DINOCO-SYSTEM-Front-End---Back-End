if ( ! function_exists( 'dinoco_sn_run_review_request_schedule' ) ) {
    /**
     * Phase 3 W9 — F#10 Review Request
     * Daily 10:00 — find plates registered exactly 30 days ago.
     *
     * Skip-if-claim guard: don't pester unhappy customer. Check claim_ticket
     * CPT (existing Service Center system). If any open claim for this user
     * → skip review request.
     *
     * Anti-spam: dedup ensures one review_request per (user, sn). If customer
     * misses + 7 day → no retry (don't pester per v2.13 §F.10 Edge Cases).
     */
    function dinoco_sn_run_review_request_schedule() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $today = current_time( 'Y-m-d' );
            $now = current_time( 'mysql' );

            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, registered_user_id, linked_sku, registered_at
                 FROM {$pool}
                 WHERE status = 'registered'
                   AND registered_user_id IS NOT NULL
                   AND DATE(registered_at) = DATE_SUB(%s, INTERVAL 30 DAY)
                 LIMIT 1000",
                $today
            ), ARRAY_A );

            $scheduled = 0;
            $skipped_claim = 0;

            // Pre-compute users with open claims (cheap dedup vs N+1)
            $user_ids = array_unique( array_filter( array_map( function( $r ) {
                return (int) ( $r['registered_user_id'] ?? 0 );
            }, $rows ?: array() ) ) );

            $users_with_open_claim = array();
            if ( $user_ids ) {
                // Existing Service Center claim_ticket CPT — open if status NOT in completed/closed/rejected/cancelled
                // V.0.11 audit fix (P0-3 + P1-4): use proper placeholders for both
                // user_ids AND status enum (was raw {$closed_in} interpolation).
                $closed_statuses = array( 'completed', 'closed', 'rejected', 'cancelled' );
                $user_ph    = implode( ',', array_fill( 0, count( $user_ids ), '%d' ) );
                $status_ph  = implode( ',', array_fill( 0, count( $closed_statuses ), '%s' ) );

                $sql = "SELECT DISTINCT p.post_author
                        FROM {$wpdb->posts} p
                        LEFT JOIN {$wpdb->postmeta} m ON m.post_id = p.ID AND m.meta_key = 'ticket_status'
                        WHERE p.post_type = 'claim_ticket'
                          AND p.post_status = 'publish'
                          AND p.post_author IN ({$user_ph})
                          AND ( m.meta_value IS NULL OR m.meta_value NOT IN ({$status_ph}) )";

                $args = array_merge( array_map( 'intval', $user_ids ), $closed_statuses );
                $cpt_users = $wpdb->get_col( $wpdb->prepare( $sql, $args ) );
                if ( is_array( $cpt_users ) ) {
                    $users_with_open_claim = array_flip( array_map( 'intval', $cpt_users ) );
                }
            }

            foreach ( $rows ?: array() as $row ) {
                $uid = (int) $row['registered_user_id'];
                if ( isset( $users_with_open_claim[ $uid ] ) ) {
                    $skipped_claim++;
                    continue;
                }
                $ok = dinoco_sn_schedule_notification(
                    $row['sn'],
                    $uid,
                    'review_request',
                    $now,
                    array(
                        'linked_sku'    => $row['linked_sku'],
                        'registered_at' => $row['registered_at'],
                    )
                );
                if ( $ok ) $scheduled++;
            }

            update_option( 'dinoco_sn_review_request_last_run', array(
                'at'             => $now,
                'scanned'        => count( $rows ?: array() ),
                'scheduled'      => $scheduled,
                'skipped_claim'  => $skipped_claim,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_review_request' ) );
            }
        }

        update_option( 'dinoco_cron_sn_review_request_last_run', current_time( 'mysql' ) );
    }
}

