        dbDelta( $sql_geo );
        dbDelta( $sql_stolen );
        dbDelta( $sql_api_tokens );
        dbDelta( $sql_api_log );
        dbDelta( $sql_forecast );
        dbDelta( $sql_extensions );

        // Apply utf8mb4_bin collation on key columns (case-sensitive S/N + SKU).
        // dbDelta doesn't support COLLATE per-column, so ALTER post-create.
        // Idempotent: checks current collation before changing.
        dinoco_sn_apply_bin_collations();

        // ALTER wp_dinoco_products — add sn_attach_level columns
        // (already serialized by outer GET_LOCK 'dinoco_sn_schema_install')
        dinoco_sn_alter_products_table();

        // Phase 5 W17.2 (V.0.33): ALTER sn_warranty_extensions — refund columns
        dinoco_sn_alter_extensions_refund_columns();

        // V.0.43 R4 BLOCKER #1 — sig_bucket column ALTER for HMAC V2.
        // dbDelta may not always pick up the new column on existing tables
        // when the trailing index list also changes — explicit precheck +
        // ADD COLUMN gives us idempotent guarantees + matches the pattern
        // used for warranty-extension refund columns + perf indexes.
        dinoco_sn_alter_pool_sig_bucket_columns();

        // V.0.39 PERF: 3 covering indexes (idempotent INFORMATION_SCHEMA precheck)
        dinoco_sn_install_perf_indexes();

        // Persist version + activation timestamp
        update_option( 'dinoco_sn_schema_version', DINOCO_SN_SCHEMA_VERSION, 'no' );
        update_option( 'dinoco_sn_schema_activated_at', current_time( 'mysql' ), 'no' );

        // Log to obs if available
        if ( function_exists( 'dinoco_obs_capture' ) ) {
            // Not an exception, just an event log
        }
        } finally {
            // V.0.39 HIGH-5 Sec FIX: always release GET_LOCK even on exceptions
            if ( $lock_acquired ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", 'dinoco_sn_schema_install' ) );
            }
        }
    }
}

if ( ! function_exists( 'dinoco_sn_apply_bin_collations' ) ) {
    /**
     * Apply utf8mb4_bin collation to S/N + SKU columns. Idempotent —
     * checks current collation via INFORMATION_SCHEMA before ALTER.
     *
     * Tables/columns affected:
     *   sn_pool.sn, sn_pool.linked_sku
     *   sn_pool_meta.sn, sn_pool_meta.top_set_sku, replaced_by_sn, replaces_sn
     *   sn_audit.sn
     *   sn_notifications.sn
     *   sn_promo_codes.source_sn
     *   sn_review_requests.sn
     *   sn_fraud_scores.sn
     *   sn_geo_activations.sn
     *   sn_stolen_log.sn
     *   sn_demand_forecast.sku
     *   sn_warranty_extensions.sn
     */
    function dinoco_sn_apply_bin_collations() {
        global $wpdb;
        $prefix = $wpdb->prefix;

        $bin_columns = array(
            // table => array( column => 'TYPE' )
            'pool'             => array(
                'sn'         => 'VARCHAR(40)',
                'linked_sku' => 'VARCHAR(50)',
            ),
            'pool_meta'        => array(
                'sn'             => 'VARCHAR(40)',
                'top_set_sku'    => 'VARCHAR(50)',
                'replaced_by_sn' => 'VARCHAR(40)',
                'replaces_sn'    => 'VARCHAR(40)',
            ),
            'audit'            => array( 'sn' => 'VARCHAR(40)' ),
            'notifications'    => array( 'sn' => 'VARCHAR(40)' ),
            'promo_codes'      => array( 'source_sn' => 'VARCHAR(40)' ),
            'review_requests'  => array( 'sn' => 'VARCHAR(40)' ),
            'fraud_scores'     => array( 'sn' => 'VARCHAR(40)' ),
            'geo_activations'  => array( 'sn' => 'VARCHAR(40)' ),
            'stolen_log'       => array( 'sn' => 'VARCHAR(40)' ),
            'demand_forecast'  => array( 'sku' => 'VARCHAR(50)' ),
            'extensions'       => array( 'sn' => 'VARCHAR(40)' ),
        );

        foreach ( $bin_columns as $logical => $cols ) {
            $tbl = dinoco_sn_table( $logical );
            if ( ! dinoco_sn_table_exists( $logical ) ) continue;

            foreach ( $cols as $col => $type ) {
                $current_col = $wpdb->get_row( $wpdb->prepare(
                    "SELECT COLLATION_NAME FROM information_schema.columns
                     WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                    DB_NAME, $tbl, $col
                ) );
                if ( ! $current_col ) continue;
                if ( $current_col->COLLATION_NAME === 'utf8mb4_bin' ) continue;

                // Apply collation — preserve nullability default
                $is_nullable_query = $wpdb->prepare(
                    "SELECT IS_NULLABLE FROM information_schema.columns
                     WHERE table_schema = %s AND table_name = %s AND column_name = %s",
                    DB_NAME, $tbl, $col
                );
                $is_nullable = $wpdb->get_var( $is_nullable_query );
                $null_clause = ( $is_nullable === 'YES' ) ? 'DEFAULT NULL' : 'NOT NULL';

                $sql = "ALTER TABLE {$tbl} MODIFY COLUMN {$col} {$type} CHARACTER SET utf8mb4 COLLATE utf8mb4_bin {$null_clause}";
                $wpdb->query( $sql );
            }
        }
    }
}

