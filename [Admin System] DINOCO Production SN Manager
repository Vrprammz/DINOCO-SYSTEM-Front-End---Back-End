            // expose alias for inline onclick
            function _dncSnTabManageBulkUpdateCount() { window._dncSnTabManageBulkUpdateCount(); }

            window.dncSnTabManageBulkLinkDealer = function() {
                var boxes = document.querySelectorAll('.dnc-sn-tab-manage-bulk-cb:checked');
                if (!boxes.length) {
                    _dncSnTabManageAlert('กรุณาเลือก S/N ก่อน (ติ๊ก checkbox)');
                    return;
                }
                var sns = Array.prototype.slice.call(boxes).map(function(b) { return b.getAttribute('data-sn') || ''; }).filter(Boolean);
                if (!sns.length) return;
                _dncSnTabManageCfm(
                    'จะ Link Dealer ให้ ' + sns.length + ' S/N เลือก dealer ใน modal ถัดไป (จะเรียก /dealer-link เป็น loop ต่อ S/N — atomic ต่อ row)',
                    { okLabel: 'ดำเนินการ' }
                ).then(function(ok) {
                    if (!ok) return;
                    // Reuse single-link modal — set first SN, queue the rest
                    window._dncSnTabManageBulkQueue = sns.slice();
                    window.dncSnTabManageOpenDealerLinkModal('[BULK ' + sns.length + ']');
                    // Override submit to loop
                    var origSubmit = window.dncSnTabManageSubmitDealerLink;
                    window.dncSnTabManageSubmitDealerLink = function() {
                        var did = window._dncSnTabManageSelectedDealerId | 0;
                        if (did <= 0) { _dncSnTabManageAlert('กรุณาเลือกร้าน'); return; }
                        var dt = document.getElementById('dnc-sn-tab-manage-dealer-date');
                        var notes = document.getElementById('dnc-sn-tab-manage-dealer-notes');
                        var btn = document.getElementById('dnc-sn-tab-manage-dealer-submit');
                        if (btn) { btn.disabled = true; btn.textContent = 'กำลังบันทึก…'; }
                        var queue = (window._dncSnTabManageBulkQueue || []).slice();
                        var success = 0, failed = 0;
                        var processNext = function() {
                            if (!queue.length) {
                                _dncSnTabManageAlert('✓ สำเร็จ ' + success + ' / ล้มเหลว ' + failed);
                                window.dncSnTabManageCloseDealerLinkModal();
                                window.dncSnTabManageSubmitDealerLink = origSubmit;
                                window.dncSnTabManageSearch();
                                return;
                            }
                            var sn = queue.shift();
                            fetch(REST_BASE + '/dealer-link', {
                                method: 'POST',
                                headers: {
                                    'X-WP-Nonce': NONCE,
                                    'Content-Type': 'application/json',
                                    'X-Idempotency-Key': 'dlink-bulk-' + sn + '-' + Date.now(),
                                },
                                credentials: 'same-origin',
                                body: JSON.stringify({
                                    sn: sn,
                                    dealer_id: did,
                                    purchase_date: dt && dt.value ? dt.value : '',
                                    notes: notes && notes.value ? notes.value : '',
                                }),
                            })
                            .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, data: j }; }); })
                            .then(function(res) {
                                if (res.ok) success++; else failed++;
                                processNext();
                            })
                            .catch(function() { failed++; processNext(); });
                        };
                        processNext();
                    };
                });
            };

