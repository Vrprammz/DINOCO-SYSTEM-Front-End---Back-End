if ( ! function_exists( 'dinoco_sn_run_audit_retention' ) ) {
    /**
     * Daily 03:30 — chunked delete sn_audit > 5 years (PDPA §17 financial
     * fraud retention). Sensitive ops (is_sensitive=1) keep 5y; non-sensitive
     * keep 3y per v2.4 SHOULD-FIX #5 ux-ui-expert review.
     *
     * Chunked 1000/iter × 20 iter cap to avoid OOM on huge tables.
     */
    function dinoco_sn_run_audit_retention() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) return;

        try {
            global $wpdb;
            $tbl = dinoco_sn_table( 'audit' );
            $deleted = 0;
            $cap = 20;
            $cutoff_5y = gmdate( 'Y-m-d H:i:s', time() - 5 * 365 * 86400 );
            $cutoff_3y = gmdate( 'Y-m-d H:i:s', time() - 3 * 365 * 86400 );

            for ( $i = 0; $i < $cap; $i++ ) {
                // Sensitive rows: 5y retention
                $sensitive_del = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl}
                     WHERE is_sensitive = 1 AND created_at < %s
                     LIMIT 500",
                    $cutoff_5y
                ) );
                // Non-sensitive: 3y retention
                $nonsensitive_del = $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$tbl}
                     WHERE is_sensitive = 0 AND created_at < %s
                     LIMIT 500",
                    $cutoff_3y
                ) );
                $batch = (int) $sensitive_del + (int) $nonsensitive_del;
                $deleted += $batch;
                if ( $batch === 0 ) break;
                usleep( 50000 ); // 50ms gap to avoid hammering DB
            }

            update_option( 'dinoco_sn_audit_retention_last_run', array(
                'at'      => current_time( 'mysql' ),
                'deleted' => $deleted,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_audit_retention' ) );
            }
        }

        update_option( 'dinoco_cron_sn_audit_retention_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_run_batch_reconcile' ) ) {
    /**
     * Weekly batch reconcile — verify sn_batches.qty_received matches
     * actual COUNT in sn_pool grouped by batch_id. Drift > 0 → write
     * `dinoco_sn_batch_drift_report` option for admin review.
     */
    function dinoco_sn_run_batch_reconcile() {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'batches' ) || ! dinoco_sn_table_exists( 'pool' ) ) return;

        try {
            global $wpdb;
            $batches = dinoco_sn_table( 'batches' );
            $pool    = dinoco_sn_table( 'pool' );

            $drifts = $wpdb->get_results(
                "SELECT b.id AS batch_id, b.batch_code,
                        b.qty_received AS reported,
                        COUNT( CASE WHEN p.status NOT IN ('reserved') THEN 1 END ) AS actual,
                        ABS( b.qty_received - COUNT( CASE WHEN p.status NOT IN ('reserved') THEN 1 END ) ) AS drift
                 FROM {$batches} b
                 LEFT JOIN {$pool} p ON p.batch_id = b.id
                 WHERE b.status NOT IN ('cancelled', 'closed')
                 GROUP BY b.id, b.batch_code, b.qty_received
                 HAVING drift > 0
                 ORDER BY drift DESC
                 LIMIT 100",
                ARRAY_A
            );

            update_option( 'dinoco_sn_batch_drift_report', array(
                'at'     => current_time( 'mysql' ),
                'count'  => $drifts ? count( $drifts ) : 0,
                'rows'   => $drifts ?: array(),
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_batch_reconcile' ) );
            }
        }

        update_option( 'dinoco_cron_sn_batch_reconcile_last_run', current_time( 'mysql' ) );
