if ( ! function_exists( 'dinoco_sn_classify_gray_market' ) ) {
    /**
     * Phase 3 W11.1 — F#13 pure-logic gray market classifier.
     *
     * Decision matrix (per plan v2.13 §F#13):
     *   foreign country (CN/LA/KH/MY/MM)  → 'gray_market_suspect'
     *   TH + no dealer in province        → 'underserved_market'
     *   TH + has dealer                   → 'normal'
     *   Unknown / empty country code      → 'normal' (defensive default)
     *
     * Pure-function (no DB / no I/O) — fully testable.
     *
     * @param string $country_code 2-letter ISO (TH/CN/LA/KH/MY/MM/...)
     * @param bool   $has_dealer   true if a registered DINOCO dealer covers this province
     * @return string 'normal' | 'gray_market_suspect' | 'underserved_market'
     */
    function dinoco_sn_classify_gray_market( $country_code, $has_dealer ) {
        $cc = strtoupper( trim( (string) $country_code ) );
        if ( $cc === '' ) return 'normal';

        $foreign = array( 'CN', 'LA', 'KH', 'MY', 'MM' );
        if ( in_array( $cc, $foreign, true ) ) {
            return 'gray_market_suspect';
        }
        if ( $cc === 'TH' && ! $has_dealer ) {
            return 'underserved_market';
        }
        return 'normal';
    }
}

if ( ! function_exists( 'dinoco_sn_province_country_code' ) ) {
    /**
     * Phase 3 W11.1 — F#13 province name → country code heuristic.
     * Thai provinces (whitelist) → 'TH'. Anything else (Chinese/Lao/etc.) → 'XX' fallback.
     * Phase 4 W12 expands with proper foreign province list.
     */
    function dinoco_sn_province_country_code( $province ) {
        $p = trim( (string) $province );
        if ( $p === '' || $p === 'Unknown' ) return 'TH';
        // Thai script range OR known TH transliteration prefix → TH
        // Heuristic: pure-ASCII upper-case strings outside latin Thai are often foreign
        // For Phase 3 W11.1 stub: assume TH unless explicitly tagged
        // Foreign markers (case-insensitive substring)
        $foreign_markers = array(
            'CN:' => 'CN', 'LA:' => 'LA', 'KH:' => 'KH', 'MY:' => 'MY', 'MM:' => 'MM',
        );
        foreach ( $foreign_markers as $marker => $code ) {
            if ( stripos( $p, $marker ) === 0 ) return $code;
        }
        return 'TH';
    }
}

if ( ! function_exists( 'dinoco_sn_province_has_dealer' ) ) {
    /**
     * Phase 3 W11.1 — F#13 dealer presence check by province.
     *
     * Best-effort lookup against b2b_distributor CPT meta `dealer_province`
     * (or falls back to ACF field `province` if present).
     *
     * Cached per-request (static memo) to avoid repeat WP_Query in cron.
     */
    function dinoco_sn_province_has_dealer( $province ) {
        static $memo = array();
        $province = trim( (string) $province );
        if ( $province === '' || $province === 'Unknown' ) return false;
        if ( isset( $memo[ $province ] ) ) return $memo[ $province ];

        $args = array(
            'post_type'      => 'b2b_distributor',
            'post_status'    => 'publish',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'no_found_rows'  => true,
            'meta_query'     => array(
                'relation' => 'OR',
                array( 'key' => 'dealer_province', 'value' => $province, 'compare' => '=' ),
                array( 'key' => 'province',         'value' => $province, 'compare' => '=' ),
            ),
        );
        $q = new WP_Query( $args );
        $has = ! empty( $q->posts );
        $memo[ $province ] = $has;
        return $has;
    }
}

