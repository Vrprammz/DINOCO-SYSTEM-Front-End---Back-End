            function _dncSnTabManageDateNDaysAgo(n) {
                var d = new Date(Date.now() - (n * 86400000));
                return d.toISOString().slice(0, 10);
            }

            // Wire up debounce input listener (300ms)
            (function _dncSnTabManageInit() {
                var input = document.getElementById('dnc-sn-tab-manage-q');
                if (!input) return;
                input.addEventListener('input', function() {
                    if (_dncSnTabManageDebounce) clearTimeout(_dncSnTabManageDebounce);
                    _dncSnTabManageDebounce = setTimeout(function() {
                        if (input.value && input.value.length >= 2) {
                            window.dncSnTabManageSearch();
                        }
                    }, 300);
                });
                input.addEventListener('keydown', function(ev) {
                    if (ev.key === 'Enter') {
                        ev.preventDefault();
                        if (_dncSnTabManageDebounce) clearTimeout(_dncSnTabManageDebounce);
                        window.dncSnTabManageSearch();
                    }
                });
                // Wire up overlay backdrop click for both modals
                var ov1 = document.getElementById('dnc-sn-tab-manage-modal-overlay');
                if (ov1) {
                    ov1.addEventListener('click', function(e) {
                        if (e.target === ov1) window.dncSnTabManageCloseModal();
                    });
                }
                var ov2 = document.getElementById('dnc-sn-tab-manage-action-overlay');
                if (ov2) {
                    ov2.addEventListener('click', function(e) {
                        if (e.target === ov2) window.dncSnTabManageCloseActionModal();
                    });
                }
                // ESC closes top-most overlay
                document.addEventListener('keydown', function(ev) {
                    if (ev.key !== 'Escape') return;
                    var actionOpen = ov2 && ov2.style.display !== 'none';
                    var modalOpen = ov1 && ov1.style.display !== 'none';
                    if (actionOpen) window.dncSnTabManageCloseActionModal();
                    else if (modalOpen) window.dncSnTabManageCloseModal();
                });
            })();

            // Universal search (Section A)
            window.dncSnTabManageSearch = function() {
                var input = document.getElementById('dnc-sn-tab-manage-q');
                var meta = document.getElementById('dnc-sn-tab-manage-meta');
                var resultsEl = document.getElementById('dnc-sn-tab-manage-results');
                if (!input || !resultsEl) return;
                var q = (input.value || '').trim();
                if (q === '') {
                    if (meta) meta.textContent = '';
                    resultsEl.innerHTML = '<div class="dnc-sn-empty" style="padding:32px;text-align:center;color:#6b7280;">' +
                        'กรอก query แล้วกด <strong>ค้นหา</strong> หรือเลือก quick filter chip ด้านบน</div>';
                    return;
                }
                if (meta) meta.textContent = 'กำลังค้นหา…';
                resultsEl.innerHTML = '<div class="dnc-sn-empty" style="padding:24px;text-align:center;">Loading…</div>';

                var url = REST_BASE + '/search?limit=50&q=' + encodeURIComponent(q);
                fetch(url, {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin',
                })
                .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, data: j }; }); })
                .then(function(res) {
                    if (!res.ok) {
                        if (meta) meta.textContent = 'ค้นหาล้มเหลว: ' + (res.data && (res.data.message || res.data.code) || res.status);
                        resultsEl.innerHTML = '<div class="dnc-sn-empty" style="padding:24px;color:#dc2626;">ค้นหาล้มเหลว</div>';
                        return;
                    }
                    var data = res.data || {};
                    var rows = data.rows || [];
                    if (meta) {
                        meta.textContent = 'พบ ' + (data.total || rows.length) + ' รายการ' +
                            (rows.length < (data.total || 0) ? ' (แสดง ' + rows.length + ')' : '');
                    }
                    if (!rows.length) {
                        resultsEl.innerHTML = '<div class="dnc-sn-empty" style="padding:32px;text-align:center;color:#6b7280;">' +
                            'ไม่พบ S/N ที่ตรงกับ query</div>';
                        return;
                    }
                    // V.0.27 — Bulk action toolbar (Link Dealer)
                    var toolbar = '<div class="dnc-sn-tab-manage-bulk-toolbar" style="display:flex;align-items:center;gap:12px;margin-bottom:12px;padding:8px 12px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;">' +
                        '<label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;">' +
                            '<input type="checkbox" id="dnc-sn-tab-manage-bulk-all" onclick="dncSnTabManageBulkToggleAll(this.checked)"> เลือกทั้งหมด' +
                        '</label>' +
