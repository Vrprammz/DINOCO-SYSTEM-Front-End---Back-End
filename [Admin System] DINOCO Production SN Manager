    }
}

if ( ! function_exists( 'dinoco_sn_is_enabled' ) ) {
    /**
     * Master kill switch. Phase 1 W2 = OFF default.
     * Boss flips ON after Pre-Phase 1 sign-off.
     */
    function dinoco_sn_is_enabled() {
        return (bool) get_option( 'dinoco_sn_system_enabled', false );
    }
}

if ( ! function_exists( 'dinoco_sn_table' ) ) {
    /**
     * Get fully prefixed table name. Use this instead of hardcoding
     * to support multisite + table prefix variations.
     *
     * Usage: $tbl = dinoco_sn_table( 'pool' );
     *        // → 'wp_dinoco_sn_pool'
     */
    function dinoco_sn_table( $logical_name ) {
        global $wpdb;
        $tables = DINOCO_SN_TABLES;
        if ( ! isset( $tables[ $logical_name ] ) ) {
            return '';
        }
        return $wpdb->prefix . $tables[ $logical_name ];
    }
}

if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
    /**
     * Check if table physically exists. Defensive — used before
     * any query during transition period when schema may not yet
     * be installed (e.g., between snippet sync + admin_init fire).
     */
    function dinoco_sn_table_exists( $logical_name ) {
        global $wpdb;
        $tbl = dinoco_sn_table( $logical_name );
        if ( $tbl === '' ) return false;
        $result = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name = %s",
            DB_NAME, $tbl
        ) );
        return ( (int) $result ) > 0;
    }
}

if ( ! function_exists( 'dinoco_sn_get_plate_data' ) ) {
    /**
     * Read plate from sn_pool. Returns object with hot path columns
     * only. Use dinoco_sn_get_plate_meta() separately if cold meta needed.
     *
     * @param string $sn Plate S/N (case-sensitive UPPER)
     * @return object|null
     */
    function dinoco_sn_get_plate_data( $sn ) {
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return null;
        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        $sn_upper = strtoupper( trim( (string) $sn ) );
        if ( $sn_upper === '' ) return null;
        return $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$tbl} WHERE sn = %s",
            $sn_upper
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_get_plate_meta' ) ) {
    /**
     * Read cold meta path. Use only when needed (purchase_dealer,
     * stolen_at, replacement chain, etc.) — adds 1 query.
     */
    function dinoco_sn_get_plate_meta( $sn ) {
        if ( ! dinoco_sn_table_exists( 'pool_meta' ) ) return null;
        global $wpdb;
        $tbl = dinoco_sn_table( 'pool_meta' );
        $sn_upper = strtoupper( trim( (string) $sn ) );
        if ( $sn_upper === '' ) return null;
        return $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$tbl} WHERE sn = %s",
            $sn_upper
        ) );
    }
}

