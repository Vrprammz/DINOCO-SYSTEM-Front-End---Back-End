                };
                if (chip === 'pending_approval') {
                    // Scroll to approvals panel; if approver, that panel is the canonical view
                    var panel = document.getElementById('dnc-sn-tab-manage-approvals');
                    if (panel) {
                        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
