    function dinoco_sn_get_user_ltv( $user_id ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return null;
        if ( ! dinoco_sn_table_exists( 'ltv_snapshot' ) ) return null;

        $cache_key = 'dinoco_sn_ltv_' . $user_id;
        $cached = get_transient( $cache_key );
        if ( $cached !== false ) {
            return $cached === '__null__' ? null : $cached;
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'ltv_snapshot' );
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$tbl} WHERE user_id = %d",
            $user_id
        ) );

        // Cache null too — prevent repeated SELECT on no-snapshot users
        set_transient( $cache_key, $row ?: '__null__', HOUR_IN_SECONDS );
        return $row;
    }
}

