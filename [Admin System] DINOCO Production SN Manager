                'columns' => '(sn, created_at)',
            ),
        );

        foreach ( $idx_specs as $spec ) {
            $tbl_exists = $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM information_schema.tables
                 WHERE table_schema = %s AND table_name = %s",
                DB_NAME, $spec['table']
