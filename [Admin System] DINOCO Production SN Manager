            }
            function _dncSnTabManageAlert(message, opts) {
                opts = opts || {};
                try {
                    if (window.dinocoModal && typeof window.dinocoModal.alert === 'function') {
                        return window.dinocoModal.alert({
                            title: opts.title || 'แจ้งเตือน',
