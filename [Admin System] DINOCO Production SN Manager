        if ( ! dinoco_sn_table_exists( 'pool' ) ) return $base;

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT
                COUNT(*) AS plates_count,
                SUM( CASE WHEN status = 'registered' THEN 1 ELSE 0 END ) AS active_count,
