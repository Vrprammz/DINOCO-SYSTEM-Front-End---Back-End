        // ═══════════════════════════════════════════════════════
        // TABLE 15: sn_warranty_extensions — Phase 5 (F#8)
        // ═══════════════════════════════════════════════════════
        $sql_extensions = "CREATE TABLE {$prefix}dinoco_sn_warranty_extensions (
            id BIGINT UNSIGNED AUTO_INCREMENT,
            sn VARCHAR(40) NOT NULL,
            user_id BIGINT UNSIGNED NOT NULL,
