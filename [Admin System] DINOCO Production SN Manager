 * 12. PHASE 3 W9 — F#1 EXPIRY REMINDER (additive 2026-05-05)
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * 2 cron jobs:
 *   dinoco_sn_expiry_schedule_cron   daily 02:00 — enqueue expiry notifications
 *                                     (status='scheduled', NO LINE push yet)
 *   dinoco_sn_notification_send_cron  every 15 min — send queued (when boss
 *                                     flips dinoco_sn_notification_send_enabled)
 *
 * Master gate: dinoco_sn_notification_send_enabled (default '0').
 * When OFF: schedule cron still enqueues rows for visibility, but send cron
 * is a no-op. This lets boss verify the queue + answer Q21 (LINE Premium tier)
 * before going live.
 *
 * Default warranty period: 1 year from registered_at (configurable per-SKU
 * via wp_dinoco_products.warranty_years — Phase 4 W9). For Phase 3 W9 stub:
 * use option dinoco_sn_default_warranty_years (default 1).
 *
 * Anti-spam dedup: notification_type + user_id + sn unique index — same
 * combo cannot be scheduled twice (handled via INSERT IGNORE in helper).
 *
 * Reference: v2.13 §F.1 + §K.7
 */

if ( ! function_exists( 'dinoco_sn_warranty_end_for_pool_row' ) ) {
    /**
     * Compute warranty end date for a sn_pool row.
     * Returns DateTime or null if not registered.
     *
     * Phase 3 W9 stub: registered_at + N years (default 1, override via option).
     * Phase 4 W9: read warranty_years from linked SKU + extension records.
     */
    function dinoco_sn_warranty_end_for_pool_row( $row ) {
        $registered_at = is_array( $row ) ? ( $row['registered_at'] ?? null ) : ( $row->registered_at ?? null );
        if ( empty( $registered_at ) ) return null;
        $years = (int) get_option( 'dinoco_sn_default_warranty_years', 1 );
        if ( $years < 1 ) $years = 1;
        try {
            $start = new \DateTime( $registered_at, wp_timezone() );
            $start->modify( '+' . $years . ' years' );
            return $start;
        } catch ( \Throwable $e ) {
            return null;
        }
    }
}

if ( ! function_exists( 'dinoco_sn_schedule_notification' ) ) {
    /**
     * Insert notification row idempotent — composite check on
     * (notification_type, user_id, sn) prevents duplicate scheduling.
     *
     * Returns true if inserted, false if dup or invalid.
     */
    function dinoco_sn_schedule_notification( $sn, $user_id, $notif_type, $scheduled_at, $meta = array() ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'notifications' ) ) {
            return false;
        }
        $sn = strtoupper( trim( (string) $sn ) );
        $user_id = (int) $user_id;
        $notif_type = sanitize_key( $notif_type );
        if ( $sn === '' || $user_id <= 0 || $notif_type === '' || ! $scheduled_at ) {
            return false;
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'notifications' );

        // V.0.11 audit fix (P0-4): UNIQUE KEY uniq_dedup enforces dedup
        // at DB level. INSERT IGNORE skips silently on duplicate. App-level
        // SELECT-first race window eliminated.
        // Use direct query (wpdb->insert escapes but doesn't support IGNORE).
        $sql = $wpdb->prepare(
            "INSERT IGNORE INTO {$tbl}
                (sn, user_id, notification_type, channel, scheduled_at, status, meta_json, created_at)
             VALUES (%s, %d, %s, %s, %s, %s, %s, %s)",
            $sn,
            $user_id,
            $notif_type,
            'line_flex',
            $scheduled_at,
            'scheduled',
            wp_json_encode( $meta ),
            current_time( 'mysql' )
        );
        $rows = $wpdb->query( $sql );
        // INSERT IGNORE: rows = 1 if inserted, 0 if dup, false on real error
        return $rows === 1;
    }
}

if ( ! function_exists( 'dinoco_sn_run_expiry_schedule' ) ) {
    /**
     * Daily 02:00 — scan registered plates approaching expiry and enqueue
     * 3 notifications per plate: expiry_30d, expiry_7d, expiry_1d.
     *
     * Idempotent: helper dedups by (type, user_id, sn). Re-running same day
     * is safe (same rows already exist → skipped).
     *
     * Phase 3 W9 stub:
     *   - 1-year warranty default (Phase 4 W9 reads SKU.warranty_years)
     *   - Skip plates with status NOT IN ('registered', 'claimed')
     *   - LIMIT 5000 plates per run to avoid OOM at 1M+ rows
     */
    function dinoco_sn_run_expiry_schedule() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'notifications' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $years = max( 1, (int) get_option( 'dinoco_sn_default_warranty_years', 1 ) );

            // Fetch rows whose computed warranty_end ∈ [now, now+30d]
            // Window includes 30/7/1 day milestones so single query covers all.
            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, registered_user_id, registered_at, linked_sku
                 FROM {$pool}
                 WHERE status IN ('registered', 'claimed')
                   AND registered_user_id IS NOT NULL
                   AND registered_at IS NOT NULL
                   AND registered_at >= DATE_SUB(NOW(), INTERVAL %d YEAR)
                   AND DATE_ADD(registered_at, INTERVAL %d YEAR)
                       BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 30 DAY)
                 ORDER BY registered_at ASC
                 LIMIT 5000",
                $years, $years
            ), ARRAY_A );

            $scheduled = 0;
            $skipped = 0;
            $milestones = array(
                'expiry_30d' => 30,
                'expiry_7d'  => 7,
                'expiry_1d'  => 1,
            );

            foreach ( $rows ?: array() as $row ) {
                $end = dinoco_sn_warranty_end_for_pool_row( $row );
                if ( ! $end ) { $skipped++; continue; }
                foreach ( $milestones as $type => $days ) {
                    $send_at = clone $end;
                    $send_at->modify( '-' . $days . ' days' );
                    // Skip if already past send window
                    if ( $send_at->getTimestamp() < time() - 86400 ) continue;

                    $ok = dinoco_sn_schedule_notification(
                        $row['sn'],
                        (int) $row['registered_user_id'],
                        $type,
                        $send_at->format( 'Y-m-d H:i:s' ),
                        array(
                            'linked_sku'    => $row['linked_sku'],
                            'warranty_end'  => $end->format( 'Y-m-d' ),
                            'days_to_expiry' => $days,
                        )
                    );
                    if ( $ok ) $scheduled++; else $skipped++;
                }
            }

            update_option( 'dinoco_sn_expiry_schedule_last_run', array(
                'at'        => current_time( 'mysql' ),
                'scanned'   => count( $rows ?: array() ),
                'scheduled' => $scheduled,
                'skipped'   => $skipped,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_expiry_schedule' ) );
            }
        }

        update_option( 'dinoco_cron_sn_expiry_schedule_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_compute_demand_forecast' ) ) {
    /**
     * Phase 4 W13 — F#16 Demand Forecasting
     *
     * Pure-PHP time-series forecast using:
     *   - Moving average (last 6 months) for trend
     *   - Single exponential smoothing (alpha=0.3 default) for level
     *   - Combined: weighted blend of MA + ES with confidence based on
     *     data variance + sample size
     *
     * Inputs:
     *   $history = [['month' => 'YYYY-MM-01', 'qty' => N], ...]
     *   $forecast_months = 6 (default)
     *
     * Output: [
     *   ['month' => YYYY-MM-01, 'predicted_qty' => N, 'confidence_pct' => P],
     *   ...
     * ]
     *
     * Confidence model (deterministic):
     *   confidence = max(0, min(100, 100 - (cv_percent + (12 - sample_size)*5)))
     *   where cv_percent = (stddev / mean) * 100
     *   Lower variance + more data → higher confidence.
     *
     * Boss can verify math (testable). Phase 5+ ML is overkill — boss
     * needs explainable + auditable forecasts.
     */
    function dinoco_sn_compute_demand_forecast( array $history, int $forecast_months = 6, float $alpha = 0.3 ): array {
        if ( empty( $history ) ) {
            return array();
        }

        // Sort ascending by month
        usort( $history, function( $a, $b ) {
            return strcmp( (string) $a['month'], (string) $b['month'] );
        } );

        $qtys = array_map( function( $r ) { return (float) ( $r['qty'] ?? 0 ); }, $history );
        $n = count( $qtys );

        // Moving average over last min(6, n) periods
        $ma_window = min( 6, $n );
        $ma_slice = array_slice( $qtys, -$ma_window );
        $ma = array_sum( $ma_slice ) / max( 1, count( $ma_slice ) );

        // Exponential smoothing — initialize with first value, run through
        $level = $qtys[0];
        for ( $i = 1; $i < $n; $i++ ) {
            $level = $alpha * $qtys[ $i ] + ( 1 - $alpha ) * $level;
        }

        // Confidence: variance + sample size
        $mean = array_sum( $qtys ) / $n;
        $variance = 0.0;
        foreach ( $qtys as $q ) {
            $variance += ( $q - $mean ) ** 2;
        }
        $variance = $variance / max( 1, $n );
        $stddev = sqrt( $variance );
        $cv_percent = $mean > 0 ? ( $stddev / $mean ) * 100 : 0;
        $sample_penalty = max( 0, 12 - $n ) * 5;
        $confidence = max( 0, min( 100, 100 - $cv_percent - $sample_penalty ) );

        // Blend MA + ES (50/50 weight) for prediction
        $predicted_base = ( $ma + $level ) / 2;

        // Build forecast for next N months from last history month
        $last_month = $history[ count( $history ) - 1 ]['month'];
        $forecasts = array();
        for ( $i = 1; $i <= $forecast_months; $i++ ) {
            try {
                $dt = new \DateTime( $last_month );
                $dt->modify( '+' . $i . ' months' );
                $forecast_month = $dt->format( 'Y-m-01' );
            } catch ( \Throwable $_e ) {
                continue;
            }
            $forecasts[] = array(
                'month'          => $forecast_month,
                'predicted_qty'  => max( 0, (int) round( $predicted_base ) ),
                'confidence_pct' => (int) round( $confidence ),
            );
        }
        return $forecasts;
    }
}

if ( ! function_exists( 'dinoco_sn_run_demand_forecast' ) ) {
    /**
     * Phase 4 W13 — Weekly Sunday 02:00 demand forecast cron.
     *
     * For each linked_sku in sn_pool with ≥3 months of activation history:
     *   1. Aggregate monthly activation count from registered_at
     *   2. Compute 6-month forecast via dinoco_sn_compute_demand_forecast
     *   3. UPSERT into wp_dinoco_sn_demand_forecast
     *
     * Idempotent — UNIQUE KEY (sku, forecast_month) ensures
     * INSERT...ON DUPLICATE KEY overwrites stale forecasts.
     */
    function dinoco_sn_run_demand_forecast() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) return;
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) return;
        if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'demand_forecast' ) ) return;

        try {
            global $wpdb;
            $pool = dinoco_sn_table( 'pool' );
            $forecast_tbl = dinoco_sn_table( 'demand_forecast' );

            // Find SKUs with at least 3 months of activation history
            $skus = $wpdb->get_col(
                "SELECT linked_sku
                 FROM {$pool}
                 WHERE registered_user_id IS NOT NULL
                   AND linked_sku IS NOT NULL AND linked_sku != ''
                   AND status IN ('registered', 'claimed', 'replaced', 'transferred', 'recalled')
                 GROUP BY linked_sku
                 HAVING COUNT(DISTINCT DATE_FORMAT(registered_at, '%Y-%m')) >= 3
                 ORDER BY linked_sku ASC
                 LIMIT 200"
            );

            $now = current_time( 'mysql' );
            $sku_count = 0;
            $row_count = 0;

            foreach ( $skus ?: array() as $sku ) {
                // 12-month rolling history per SKU
                $history_rows = $wpdb->get_results( $wpdb->prepare(
                    "SELECT DATE_FORMAT(registered_at, '%%Y-%%m-01') AS month,
                            COUNT(*) AS qty
                     FROM {$pool}
                     WHERE linked_sku = %s
                       AND registered_at IS NOT NULL
                       AND registered_at >= DATE_SUB(NOW(), INTERVAL 12 MONTH)
                       AND status IN ('registered', 'claimed', 'replaced', 'transferred', 'recalled')
                     GROUP BY DATE_FORMAT(registered_at, '%%Y-%%m-01')
                     ORDER BY month ASC",
                    $sku
                ), ARRAY_A );

                if ( count( $history_rows ?: array() ) < 3 ) continue;

                $forecasts = dinoco_sn_compute_demand_forecast( $history_rows, 6 );
                if ( empty( $forecasts ) ) continue;

                // Current pool qty for SKU
                $current_pool = (int) $wpdb->get_var( $wpdb->prepare(
                    "SELECT COUNT(*) FROM {$pool}
                     WHERE linked_sku = %s AND status = 'in_pool'",
                    $sku
                ) );

                foreach ( $forecasts as $f ) {
                    $suggested = max( 0, $f['predicted_qty'] - $current_pool );
                    $wpdb->query( $wpdb->prepare(
                        "INSERT INTO {$forecast_tbl}
                            (sku, forecast_month, predicted_qty, confidence_pct,
                             current_pool_qty, suggested_order_qty, computed_at)
                         VALUES (%s, %s, %d, %d, %d, %d, %s)
                         ON DUPLICATE KEY UPDATE
                            predicted_qty       = VALUES(predicted_qty),
                            confidence_pct      = VALUES(confidence_pct),
                            current_pool_qty    = VALUES(current_pool_qty),
                            suggested_order_qty = VALUES(suggested_order_qty),
                            computed_at         = VALUES(computed_at)",
                        $sku,
                        $f['month'],
                        $f['predicted_qty'],
                        $f['confidence_pct'],
                        $current_pool,
                        $suggested,
                        $now
                    ) );
                    $row_count++;
                }
                $sku_count++;
            }

            update_option( 'dinoco_sn_demand_forecast_last_run', array(
                'at'         => $now,
                'sku_count'  => $sku_count,
                'row_count'  => $row_count,
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_demand_forecast' ) );
            }
        }

        update_option( 'dinoco_cron_sn_demand_forecast_last_run', current_time( 'mysql' ) );
    }
}

