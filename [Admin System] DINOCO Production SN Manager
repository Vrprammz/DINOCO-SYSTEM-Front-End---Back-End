            var MP_REFUND_4EYES_THRESHOLD = 5000;
            var _mpAutoRefreshTimer = null;
            var _mpPendingRow = null;     // for reject modal context
            var _mpRefundRow = null;      // for refund modal context
            var _mpTxPage = 1;
            var _mpTxLimit = 50;

            function mpFmtBaht(v) {
                if (v === null || v === undefined || v === '') return '—';
                var n = Number(v);
                if (!isFinite(n)) return '—';
                if (n === 0) return '฿0';
                return '฿' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
            }

            function mpStatusBadgeHtml(status) {
                // Mirror PHP dinoco_sn_marketplace_classify_status — must stay in sync
                var map = {
                    'pending_payment':      { label: 'รอชำระ',          emoji: '⏳', cls: 'dnc-sn-mp-status-pending-payment' },
                    'pending_admin_review': { label: 'รอ Admin ตรวจ',   emoji: '🔍', cls: 'dnc-sn-mp-status-pending-review' },
                    'paid':                 { label: 'จ่ายแล้ว',         emoji: '✅', cls: 'dnc-sn-mp-status-paid' },
                    'expired':              { label: 'หมดอายุ',         emoji: '⌛', cls: 'dnc-sn-mp-status-expired' },
                    'refunded':             { label: 'คืนเงินแล้ว',       emoji: '💸', cls: 'dnc-sn-mp-status-refunded' },
                    'rejected':             { label: 'ปฏิเสธ',           emoji: '❌', cls: 'dnc-sn-mp-status-rejected' },
                    'cancelled':            { label: 'ยกเลิก',           emoji: '🚫', cls: 'dnc-sn-mp-status-cancelled' }
                };
                var m = map[status] || { label: 'ไม่ทราบ', emoji: '❓', cls: 'dnc-sn-mp-status-unknown' };
                return '<span class="dnc-sn-mp-status-badge ' + m.cls + '">' + m.emoji + ' ' + escapeHtml(m.label) + '</span>';
            }

            function mpComputeSavingsPct(base1y, multi, years) {
                // Mirror PHP dinoco_sn_marketplace_compute_savings
                if (years !== 2 && years !== 3) return null;
                if (base1y === null || base1y === undefined || base1y === '') return null;
                if (multi === null || multi === undefined || multi === '') return null;
                base1y = Number(base1y);
                multi  = Number(multi);
                if (!isFinite(base1y) || !isFinite(multi)) return null;
                if (base1y <= 0) return null;
                var naive = base1y * years;
                if (naive <= 0) return null;
                var ratio = 1 - (multi / naive);
                if (ratio < 0) return 0;
                if (ratio > 1) return 100;
                return Math.round(ratio * 1000) / 10;
            }

            // ═══════ Sub-tab navigation (event-delegated) ═══════
            window.dncSnMpInit = function() {
                var root = document.querySelector('.dnc-sn-mp-root');
                if (!root) return;

                // Sub-tab pill clicks (delegated)
                root.addEventListener('click', function(e) {
                    var pill = e.target.closest('.dnc-sn-mp-subtab');
                    if (pill) {
                        root.querySelectorAll('.dnc-sn-mp-subtab').forEach(function(p) {
                            p.classList.remove('active');
                            p.setAttribute('aria-selected', 'false');
                        });
                        root.querySelectorAll('.dnc-sn-mp-subpanel').forEach(function(s) {
                            s.classList.remove('active');
                            s.hidden = true;
                        });
                        pill.classList.add('active');
                        pill.setAttribute('aria-selected', 'true');
                        var which = pill.dataset.mpSubtab;
                        var panel = root.querySelector('[data-mp-panel="' + which + '"]');
                        if (panel) {
                            panel.classList.add('active');
                            panel.hidden = false;
                        }
                        // Stop auto-refresh when leaving Pending Review
                        if (which !== 'pending-review' && _mpAutoRefreshTimer) {
                            clearInterval(_mpAutoRefreshTimer);
                            _mpAutoRefreshTimer = null;
                        }
                        // Re-arm auto-refresh on Pending Review
                        if (which === 'pending-review') {
                            mpStartPendingAutoRefresh();
                        }
                        return;
                    }

                    // Action delegate (data-action="…")
                    var actionEl = e.target.closest('[data-action]');
                    if (!actionEl || !root.contains(actionEl)) return;
                    var action = actionEl.dataset.action;
                    switch (action) {
                        case 'mp-pricing-load': dncSnMpLoadPricing(); break;
                        case 'mp-pending-load': dncSnMpLoadPending(); break;
                        case 'mp-tx-load': dncSnMpLoadTransactions(); break;
                        case 'mp-tx-export': dncSnMpExportTransactions(); break;
                        case 'mp-tx-detail-close': dncSnMpCloseTxDetail(); break;
                        case 'mp-reject-cancel': dncSnMpCloseRejectModal(); break;
                        case 'mp-reject-submit': dncSnMpSubmitReject(); break;
                        case 'mp-refund-search': dncSnMpRefundSearch(); break;
                        case 'mp-refund-cancel': dncSnMpCloseRefundModal(); break;
                        case 'mp-refund-submit': dncSnMpSubmitRefund(); break;
                    }
                });

                // Inline-edit price (delegated change/blur)
                root.addEventListener('change', function(e) {
                    if (e.target.classList && e.target.classList.contains('dnc-sn-mp-price-input')) {
                        dncSnMpSavePriceFromInput(e.target);
                    }
                });

                // Refund amount listener — toggle approver row at threshold
                var refundAmtEl = document.getElementById('dnc-sn-mp-refund-amount');
                if (refundAmtEl) {
                    refundAmtEl.addEventListener('input', function() {
                        var amt = parseFloat(refundAmtEl.value || '0');
                        var approverRow = document.getElementById('dnc-sn-mp-refund-approver-row');
                        if (approverRow) {
                            approverRow.style.display = (amt >= MP_REFUND_4EYES_THRESHOLD) ? 'block' : 'none';
                        }
                    });
                }

                // Pre-load pricing on first activation
                dncSnMpLoadPricing();
                // Probe pending count for badge
                dncSnMpRefreshPendingBadge();
            };

            // ═══════ Sub-tab 1: Pricing (W15.1) ═══════
            window.dncSnMpLoadPricing = function() {
                var meta = document.getElementById('dnc-sn-mp-pricing-meta');
                var tbody = document.querySelector('#dnc-sn-mp-pricing-table tbody');
                var search = (document.getElementById('dnc-sn-mp-pricing-search') || {}).value || '';
                var onlyEnabled = (document.getElementById('dnc-sn-mp-pricing-only-enabled') || {}).checked;
                var onlyPlate   = (document.getElementById('dnc-sn-mp-pricing-only-plate') || {}).checked;
                if (meta) meta.textContent = 'Loading…';
                if (tbody) tbody.innerHTML = '<tr><td colspan="7" class="dnc-sn-empty">Loading…</td></tr>';

                var qs = '?limit=500';
                if (search) qs += '&search=' + encodeURIComponent(search);
                if (onlyEnabled) qs += '&only_enabled=1';
                if (onlyPlate) qs += '&only_plate=1';

                fetch(REST_BASE + '/marketplace/pricing' + qs, {
                    headers: { 'X-WP-Nonce': NONCE },
                    credentials: 'same-origin'
                })
                .then(function(r) {
                    if (r.status === 404) {
                        if (meta) meta.textContent = 'ℹ️ ระบบ Marketplace ยังไม่พร้อม รอ deploy Phase 5 REST API';
                        if (tbody) tbody.innerHTML = '<tr><td colspan="7" class="dnc-sn-empty">REST endpoint not yet deployed</td></tr>';
                        throw new Error('endpoint_not_ready');
                    }
                    return r.json();
                })
                .then(function(res) {
                    var rows = (res && res.data) || [];
                    if (!rows.length) {
                        if (tbody) tbody.innerHTML = '<tr><td colspan="7" class="dnc-sn-empty">ไม่พบสินค้า</td></tr>';
                        if (meta) meta.textContent = 'ไม่พบสินค้า (ปรับ filter อีกครั้ง)';
                        return;
                    }
                    if (meta) meta.textContent = rows.length + ' SKU · กรอกราคาแล้วกด Tab/คลิกข้างนอก = บันทึกอัตโนมัติ';
                    if (tbody) {
                        tbody.innerHTML = rows.map(function(p) {
                            var sku = String(p.sku || '');
                            // Note: image fallback handled via CSS background (gray box) when img fails;
                            // no inline onerror — UX-H3 compliant (event delegation pattern is overkill
                            // for noisy 404s; just use bg placeholder).
                            var img = p.image_url
                                ? '<img class="dnc-sn-mp-thumb" src="' + escapeHtml(p.image_url) + '" alt="" loading="lazy">'
                                : '<div class="dnc-sn-mp-thumb"></div>';
                            var priceCell = function(years, val) {
                                var input = '<input type="number" class="dnc-sn-mp-price-input" min="0" step="1" '
                                    + 'data-sku="' + escapeHtml(sku) + '" '
                                    + 'data-years="' + years + '" '
                                    + 'value="' + (val === null || val === undefined || val === '' ? '' : Number(val)) + '" '
                                    + 'placeholder="ปิดขาย" aria-label="' + years + 'y price for ' + escapeHtml(sku) + '">';
                                var saving = mpComputeSavingsPct(p.sn_ext_price_1y, val, years);
                                var savingHtml = (saving !== null && saving > 0)
                                    ? '<span class="dnc-sn-mp-saving-badge">−' + saving.toFixed(1) + '%</span>'
                                    : '';
                                return '<td>' + input + savingHtml + '<span class="dnc-sn-mp-feedback"></span></td>';
                            };

                            // Status: any 1y/2y/3y enabled?
                            var anyEnabled = (p.sn_ext_price_1y !== null && p.sn_ext_price_1y !== '')
                                          || (p.sn_ext_price_2y !== null && p.sn_ext_price_2y !== '')
                                          || (p.sn_ext_price_3y !== null && p.sn_ext_price_3y !== '');
                            var statusHtml = anyEnabled
                                ? '<span class="dnc-sn-mp-status-badge dnc-sn-mp-status-paid">✅ เปิดขาย</span>'
                                : '<span class="dnc-sn-mp-status-badge dnc-sn-mp-status-expired">⚫ ปิด</span>';

                            return '<tr class="dnc-sn-mp-pricing-row" data-sku="' + escapeHtml(sku) + '">'
                                 + '<td>' + img + '</td>'
                                 + '<td><strong>' + escapeHtml(sku) + '</strong><br><small style="color:#6b7280;">' + escapeHtml(p.name || '—') + '</small></td>'
                                 + '<td>' + mpFmtBaht(p.retail_price) + '</td>'
                                 + priceCell(1, p.sn_ext_price_1y)
                                 + priceCell(2, p.sn_ext_price_2y)
                                 + priceCell(3, p.sn_ext_price_3y)
                                 + '<td>' + statusHtml + '</td>'
                                 + '</tr>';
                        }).join('');
