            // Modal helpers shim (try Modal Helpers snippet → fallback native)
            function _dncSnTabManageCfm(message, opts) {
                opts = opts || {};
                try {
                    if (window.dinocoModal && typeof window.dinocoModal.confirm === 'function') {
                        return window.dinocoModal.confirm({
