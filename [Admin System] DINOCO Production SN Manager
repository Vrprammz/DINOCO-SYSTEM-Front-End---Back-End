if ( ! function_exists( 'dinoco_sn_get_user_plates' ) ) {
    /**
     * List plates owned by a user. Read-only helper for Member Dashboard
     * "My Warranties" panel + Asset List card. Returns plates with status
     * in given whitelist (default: registered + claimed).
     *
     * Backward compat: returns empty array if user has no plates yet
     * (legacy users still on serial_code ACF — Phase 2 W7 V.31.0 dual
     * source migration). Member Dashboard uses graceful fallback when
     * empty — never throws.
     *
     * @param int   $user_id    WP user ID
     * @param array $statuses   Whitelist (default: registered + claimed)
     * @return array<object>    Array of plate rows (hot path only)
     */
    function dinoco_sn_get_user_plates( $user_id, $statuses = array( 'registered', 'claimed' ) ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return array();
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return array();

        // Whitelist sanitize — accept only known states
        $allowed_states = array(
            'reserved', 'in_pool', 'registered', 'claimed', 'replaced',
            'transferred', 'voided', 'recalled', 'reserved_for_legacy',
            'shipped_legacy', 'cancelled_batch',
        );
        $clean = array();
        foreach ( (array) $statuses as $s ) {
            $s = (string) $s;
            if ( in_array( $s, $allowed_states, true ) ) {
                $clean[] = $s;
            }
        }
        if ( empty( $clean ) ) return array();

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        $placeholders = implode( ',', array_fill( 0, count( $clean ), '%s' ) );
        $args = array_merge( array( $user_id ), $clean );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT sn, status, linked_sku, registered_at, claim_id, batch_id, prev_status, lock_version
             FROM {$tbl}
             WHERE registered_user_id = %d
               AND status IN ( {$placeholders} )
             ORDER BY registered_at DESC",
            $args
        ) );
        return is_array( $rows ) ? $rows : array();
    }
}

if ( ! function_exists( 'dinoco_sn_get_user_expiring_plates' ) ) {
    /**
     * Plates whose warranty ends within $days_window. Used by Member
     * Dashboard expiry banner (F#1 surfaces the same data through the
     * notifications table — this helper is for instant read).
     *
     * Warranty math: `warranty_until = registered_at + warranty_years YEAR`
     * matches the F#1 schedule cron. Default warranty_years=1 if not
     * stored on plate (per v2.10 §F#1 default).
     *
     * @param int $user_id
     * @param int $days_window  default 30 (clamped 1..365)
     * @return array<object>    sn, top_set_sku, registered_at, days_left
     */
    function dinoco_sn_get_user_expiring_plates( $user_id, $days_window = 30 ) {
        $user_id = (int) $user_id;
        if ( $user_id <= 0 ) return array();
        if ( ! dinoco_sn_table_exists( 'pool' ) ) return array();
        $days = max( 1, min( 365, (int) $days_window ) );

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT sn,
                    linked_sku,
                    registered_at,
                    DATEDIFF(
                        DATE_ADD( DATE(registered_at), INTERVAL 1 YEAR ),
                        CURDATE()
                    ) AS days_left
             FROM {$tbl}
             WHERE registered_user_id = %d
               AND status = 'registered'
               AND DATE_ADD( DATE(registered_at), INTERVAL 1 YEAR )
                   BETWEEN CURDATE() AND DATE_ADD( CURDATE(), INTERVAL %d DAY )
             ORDER BY days_left ASC",
            $user_id,
            $days
        ) );
        return is_array( $rows ) ? $rows : array();
    }
}

if ( ! function_exists( 'dinoco_sn_get_user_ltv' ) ) {
    /**
     * Read pre-aggregated LTV snapshot. Cron `dinoco_sn_ltv_snapshot_cron`
     * keeps this fresh (daily 03:00). Cached 1hr in transient to absorb
     * dashboard reload spam.
     *
     * @return object|null  Row from sn_customer_ltv_snapshot, or null
