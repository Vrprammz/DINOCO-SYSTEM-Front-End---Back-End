            window.dncSnMpSubmitRefund = function() {
                if (!_mpRefundRow) return;
                var reason = (document.getElementById('dnc-sn-mp-refund-reason') || {}).value || '';
                var amount = parseFloat((document.getElementById('dnc-sn-mp-refund-amount') || {}).value || '0');
                var confirmText = (document.getElementById('dnc-sn-mp-refund-confirm') || {}).value || '';
                var approver = (document.getElementById('dnc-sn-mp-refund-approver') || {}).value || '';

                reason = String(reason).trim();
                if (reason.length < 10) {
                    alert('กรุณากรอกเหตุผลอย่างน้อย 10 ตัวอักษร');
                    return;
                }
                if (!isFinite(amount) || amount <= 0) {
                    alert('จำนวนเงินไม่ถูกต้อง');
