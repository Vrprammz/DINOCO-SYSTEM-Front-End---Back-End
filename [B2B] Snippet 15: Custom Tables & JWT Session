// ════════════════════════════════════════════
// PART 1B: STOCK CORE FUNCTIONS (V.3.0)
// ════════════════════════════════════════════

/**
 * Atomic stock operations — FOR UPDATE lock per SKU
 * Pattern เหมือน b2b_debt_add/subtract ที่พิสูจน์แล้ว
 */

if ( ! function_exists( 'dinoco_stock_add' ) ) {
    /**
     * เพิ่มสต็อก (B2F receive, manual add, cancel return)
     */
    function dinoco_stock_add( $sku, $qty, $type = 'manual_add', $ref_type = '', $ref_id = 0, $reason = '', $batch_id = '', $warehouse_id = null, $unit_cost_thb = null ) {
        if ( $qty <= 0 ) return new WP_Error( 'invalid_qty', 'จำนวนต้องมากกว่า 0' );

        global $wpdb;
        $table     = $wpdb->prefix . 'dinoco_products';
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
        $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
        $sku       = strtoupper( trim( $sku ) );

        // V.7.1 [H2 FIX]: DD-2 leaf-only guard — block parent/intermediate SKU
        // caller ต้อง expand leaf ก่อนด้วย dinoco_get_leaf_skus() ถ้าเป็น SET
        if ( function_exists( 'dinoco_is_leaf_sku' ) && ! dinoco_is_leaf_sku( $sku ) ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[Stock] CRITICAL: add blocked — {$sku} ไม่ใช่ leaf (DD-2 violation). caller ต้องเรียก dinoco_get_leaf_skus() ก่อน. type={$type} ref={$ref_type}:{$ref_id}" );
            }
            return new WP_Error( 'not_leaf', "SKU {$sku} เป็น SET/intermediate — ต้องเพิ่มสต็อกที่ leaf เท่านั้น (DD-2)" );
        }

        // Resolve warehouse (default if not specified)
        if ( ! $warehouse_id && function_exists( 'dinoco_get_default_warehouse_id' ) ) {
            $warehouse_id = dinoco_get_default_warehouse_id();
        }

        // CRIT-03: ย้าย SHOW TABLES ออกมาก่อน transaction (ใช้ static cache)
        static $whs_exists_add = null;
        if ( $whs_exists_add === null ) {
            $whs_exists_add = (bool) $wpdb->get_var( "SHOW TABLES LIKE '{$whs_table}'" );
        }

        $wpdb->query( 'START TRANSACTION' );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, stock_qty FROM {$table} WHERE sku = %s FOR UPDATE", $sku
        ) );

        if ( ! $row ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[Stock] WARNING: SKU {$sku} not in catalog, skip add" );
            return new WP_Error( 'sku_not_found', "SKU {$sku} ไม่อยู่ใน catalog" );
        }

        $old_qty = (int) $row->stock_qty;
        $new_qty = $old_qty + (int) $qty;

        $updated = $wpdb->update( $table, array(
            'stock_qty'        => $new_qty,
            'stock_updated_at' => current_time( 'mysql' ),
        ), array( 'sku' => $sku ) );

        $txn_data = array(
            'sku'            => $sku,
            'type'           => $type,
            'qty_change'     => (int) $qty,
            'qty_before'     => $old_qty,
            'qty_after'      => $new_qty,
            'reference_type' => $ref_type ?: null,
            'reference_id'   => $ref_id ?: null,
            'reason'         => $reason,
            'user_id'        => get_current_user_id() ?: null,
            'batch_id'       => $batch_id ?: null,
            'warehouse_id'   => $warehouse_id ?: null,
            'unit_cost_thb'  => $unit_cost_thb !== null ? (float) $unit_cost_thb : null,
        );
        $inserted = $wpdb->insert( $txn_table, $txn_data );

        // Phase 5: Update warehouse_stock (if table exists) — CRIT-02: track wh_ok
        $wh_ok = true;
        if ( $warehouse_id && $whs_exists_add ) {
            $wh_row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, stock_qty FROM {$whs_table} WHERE warehouse_id = %d AND sku = %s FOR UPDATE",
                $warehouse_id, $sku
            ) );
            if ( $wh_row ) {
                $wpdb->update( $whs_table,
                    array( 'stock_qty' => (int) $wh_row->stock_qty + (int) $qty ),
                    array( 'id' => $wh_row->id )
                );
            } else {
                $wpdb->insert( $whs_table, array(
                    'warehouse_id' => $warehouse_id,
                    'sku'          => $sku,
                    'stock_qty'    => (int) $qty,
                ) );
            }
            if ( $wpdb->last_error ) $wh_ok = false;
        }

        if ( $updated === false || $inserted === false || ! $wh_ok ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_Error( 'db_error', 'Stock update failed' );
        }

        $wpdb->query( 'COMMIT' );
        delete_transient( 'b2b_sku_data_map' ); // DD-5: invalidate cache ทุกครั้ง

        // V.7.2 [V.42.17 HIGH #4 FIX]: ถ้าเป็น b2f_receive → invalidate WAC cache ของ SKU นี้
        // (defense in depth — ไม่ rely on do_action hook อย่างเดียว)
        if ( $type === 'b2f_receive' && function_exists( 'dinoco_invalidate_wac_cache' ) ) {
            dinoco_invalidate_wac_cache( array( $sku ) );
        }

        // Auto-update stock_status (outside transaction)
        dinoco_stock_auto_status( $sku );

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] ADD %s +%d (%d->%d) type=%s ref=%s:%d wh=%s', $sku, $qty, $old_qty, $new_qty, $type, $ref_type, $ref_id, $warehouse_id ?: 'default' ) );
        }

        return array( 'sku' => $sku, 'old_qty' => $old_qty, 'new_qty' => $new_qty );
    }
}

if ( ! function_exists( 'dinoco_stock_subtract' ) ) {
    /**
     * ลดสต็อก (B2B reserved, manual subtract)
     * V.7.1 [C3 FIX]: เพิ่ม $allow_negative — walk-in order สั่งเกิน stock ได้ (DD-5)
     * V.7.1 [H2 FIX]: เพิ่ม defensive leaf guard — DD-2 (ตัดสต็อกเฉพาะ leaf)
     */
    function dinoco_stock_subtract( $sku, $qty, $type = 'manual_subtract', $ref_type = '', $ref_id = 0, $reason = '', $batch_id = '', $warehouse_id = null, $allow_negative = false ) {
        if ( $qty <= 0 ) return new WP_Error( 'invalid_qty', 'จำนวนต้องมากกว่า 0' );

        global $wpdb;
        $table     = $wpdb->prefix . 'dinoco_products';
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
        $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
        $sku       = strtoupper( trim( $sku ) );

        // V.7.1 [H2 FIX]: DD-2 leaf-only guard — block parent/intermediate SKU
        // caller ต้อง expand leaf ก่อนด้วย dinoco_get_leaf_skus() ถ้าเป็น SET
        if ( function_exists( 'dinoco_is_leaf_sku' ) && ! dinoco_is_leaf_sku( $sku ) ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[Stock] CRITICAL: subtract blocked — {$sku} ไม่ใช่ leaf (DD-2 violation). caller ต้องเรียก dinoco_get_leaf_skus() ก่อน. type={$type} ref={$ref_type}:{$ref_id}" );
            }
            return new WP_Error( 'not_leaf', "SKU {$sku} เป็น SET/intermediate — ต้องตัดสต็อกที่ leaf เท่านั้น (DD-2)" );
        }

        // Resolve warehouse
        if ( ! $warehouse_id && function_exists( 'dinoco_get_default_warehouse_id' ) ) {
            $warehouse_id = dinoco_get_default_warehouse_id();
        }

        // CRIT-03: ย้าย SHOW TABLES ออกมาก่อน transaction (ใช้ static cache)
        static $whs_exists_sub = null;
        if ( $whs_exists_sub === null ) {
            $whs_exists_sub = (bool) $wpdb->get_var( "SHOW TABLES LIKE '{$whs_table}'" );
        }

        $wpdb->query( 'START TRANSACTION' );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, stock_qty FROM {$table} WHERE sku = %s FOR UPDATE", $sku
        ) );

        if ( ! $row ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[Stock] WARNING: SKU {$sku} not in catalog, skip subtract" );
            return new WP_Error( 'sku_not_found', "SKU {$sku} ไม่อยู่ใน catalog" );
        }

        $old_qty = (int) $row->stock_qty;
        // V.7.1 [C3 FIX]: walk-in order (allow_negative=true) → stock ติดลบได้ตาม DD-5
        $new_qty = $allow_negative ? ( $old_qty - (int) $qty ) : max( 0, $old_qty - (int) $qty );

        if ( $old_qty < (int) $qty && function_exists( 'b2b_log' ) ) {
            if ( $allow_negative ) {
                b2b_log( sprintf( '[Stock] NOTICE: %s stock=%d < requested=%d → allow_negative=true → new=%d (walk-in DD-5)', $sku, $old_qty, $qty, $new_qty ) );
            } else {
                b2b_log( sprintf( '[Stock] WARNING: %s stock=%d < requested=%d, cap at 0', $sku, $old_qty, $qty ) );
            }
        }

        $updated = $wpdb->update( $table, array(
            'stock_qty'        => $new_qty,
            'stock_updated_at' => current_time( 'mysql' ),
        ), array( 'sku' => $sku ) );

        $inserted = $wpdb->insert( $txn_table, array(
            'sku'            => $sku,
            'type'           => $type,
            'qty_change'     => -1 * abs( (int) $qty ),
            'qty_before'     => $old_qty,
            'qty_after'      => $new_qty,
            'reference_type' => $ref_type ?: null,
            'reference_id'   => $ref_id ?: null,
            'reason'         => $reason,
            'user_id'        => get_current_user_id() ?: null,
            'batch_id'       => $batch_id ?: null,
            'warehouse_id'   => $warehouse_id ?: null,
        ) );

        // Phase 5: Update warehouse_stock — CRIT-02: track wh_ok
        $wh_ok = true;
        if ( $warehouse_id && $whs_exists_sub ) {
            $wh_row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, stock_qty FROM {$whs_table} WHERE warehouse_id = %d AND sku = %s FOR UPDATE",
                $warehouse_id, $sku
            ) );
            if ( $wh_row ) {
                // V.7.1 [C3 FIX]: honor allow_negative บน warehouse_stock ด้วย
                $new_wh_qty = $allow_negative ? ( (int) $wh_row->stock_qty - (int) $qty ) : max( 0, (int) $wh_row->stock_qty - (int) $qty );
                $wpdb->update( $whs_table, array( 'stock_qty' => $new_wh_qty ), array( 'id' => $wh_row->id ) );
            }
            if ( $wpdb->last_error ) $wh_ok = false;
        }

        if ( $updated === false || $inserted === false || ! $wh_ok ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_Error( 'db_error', 'Stock update failed' );
        }

        $wpdb->query( 'COMMIT' );
        delete_transient( 'b2b_sku_data_map' ); // DD-5: invalidate cache ทุกครั้ง

        dinoco_stock_auto_status( $sku );

        // Phase 4: Stock conflict detection
        if ( function_exists( 'dinoco_check_stock_conflict' ) ) {
            dinoco_check_stock_conflict( $sku );
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] SUBTRACT %s -%d (%d->%d) type=%s ref=%s:%d wh=%s', $sku, $qty, $old_qty, $new_qty, $type, $ref_type, $ref_id, $warehouse_id ?: 'default' ) );
        }

        return array( 'sku' => $sku, 'old_qty' => $old_qty, 'new_qty' => $new_qty );
    }
}

// V.7.0 [C-8]: Batch SKU → b2b_product post_id map (avoid N+1 get_posts per SKU)
if ( ! function_exists( 'b2b_get_sku_to_post_id_map' ) ) {
    function b2b_get_sku_to_post_id_map() {
        static $map = null;
        if ( $map !== null ) return $map;
        $cached = wp_cache_get( 'b2b_sku_pid_map' );
        if ( $cached !== false ) { $map = $cached; return $map; }
        global $wpdb;
        $rows = $wpdb->get_results( "
            SELECT pm.meta_value AS sku, pm.post_id
            FROM {$wpdb->postmeta} pm
            INNER JOIN {$wpdb->posts} p ON p.ID = pm.post_id
            WHERE pm.meta_key = 'product_sku' AND p.post_type = 'b2b_product' AND p.post_status = 'publish'
        " );
        $map = array();
        foreach ( $rows as $r ) $map[ strtoupper( $r->sku ) ] = (int) $r->post_id;
        wp_cache_set( 'b2b_sku_pid_map', $map, '', 600 );
        return $map;
    }
}

if ( ! function_exists( 'dinoco_stock_auto_status' ) ) {
    /**
     * Auto-update stock_status ตาม stock_qty + threshold + manual_hold
     * เรียกหลัง add/subtract (outside transaction)
     */
    function dinoco_stock_auto_status( $sku ) {
        // Guard: ยังไม่ initialized → skip (DD-3)
        if ( ! get_option( 'dinoco_inv_initialized', false ) ) return;

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';

        $product = $wpdb->get_row( $wpdb->prepare(
            "SELECT stock_qty, low_stock_threshold, manual_hold FROM {$table} WHERE sku = %s", $sku
        ) );
        if ( ! $product ) return;

        $qty       = (int) $product->stock_qty;
        $threshold = (int) $product->low_stock_threshold;

        // Phase 4: ใช้ available_qty (stock - reserved) แทน stock_qty สำหรับ display
        $reserved  = function_exists( 'dinoco_get_reserved_qty' ) ? dinoco_get_reserved_qty( $sku ) : 0;
        $available = max( 0, $qty - $reserved );

        if ( $available <= 0 ) {
            $new_status = 'out_of_stock';
        } else {
            $new_status = 'in_stock';
        }

        // manual_hold = 1 → force out_of_stock (Admin ล็อกเอง)
        if ( (int) $product->manual_hold ) {
            $new_status = 'out_of_stock';
        }

        $wpdb->update( $table, array(
            'stock_status'     => $new_status,
            'stock_updated_at' => current_time( 'mysql' ),
        ), array( 'sku' => $sku ) );

        // V.7.0 [C-8]: Dual-write via SKU → post_id map (no get_posts N+1)
        $pid_map = function_exists( 'b2b_get_sku_to_post_id_map' ) ? b2b_get_sku_to_post_id_map() : array();
        $pid = $pid_map[ strtoupper( $sku ) ] ?? 0;
        if ( $pid ) {
            update_post_meta( $pid, 'stock_status', $new_status );
        }

        // Cache invalidation (DD-5)
        delete_transient( 'b2b_sku_data_map' );

        // V.7.0 [C-8]: Cascade ancestor ใช้ full status logic (threshold + manual_hold + reserved)
        // V.7.4 Phase 0 Hotfix: auto-unlock manual_hold ถ้าของกลับมา + whitelist reason + 72h buffer
        if ( function_exists( 'dinoco_get_ancestor_skus' ) && function_exists( 'dinoco_compute_hierarchy_stock' ) ) {
            $relations         = get_option( 'dinoco_sku_relations', array() );
            $ancestors         = dinoco_get_ancestor_skus( $sku, $relations );
            $auto_unlock_flag  = (bool) get_option( 'dinoco_auto_unlock_enabled', false );
            $reserved_invalidated = false;

            foreach ( $ancestors as $ancestor_sku ) {
                // V.7.4: invalidate reserved cache ก่อน compute (ครั้งเดียวต่อ auto_status call)
                // V.7.5 H1 CAVEAT: delete_transient invalidate transient เท่านั้น — dinoco_get_reserved_qty()
                // ใช้ static $bulk_map ภายใน request ที่ไม่ถูก reset ตรงนี้. ถ้า caller ก่อนหน้าเรียก helper แล้ว
                // static จะยัง stale. Acceptable สำหรับ Phase 0 canary (OFF default + 72h buffer) + Phase B
                // opaque accept จะ refactor ลบ call chain นี้.
                if ( $auto_unlock_flag && ! $reserved_invalidated ) {
                    delete_transient( 'b2b_reserved_map_bulk' );
                    $reserved_invalidated = true;
                }

                $anc_stock     = dinoco_compute_hierarchy_stock( $ancestor_sku, $relations );
                $anc_reserved  = function_exists( 'dinoco_get_reserved_qty' ) ? dinoco_get_reserved_qty( $ancestor_sku ) : 0;
                $anc_available = max( 0, $anc_stock - $anc_reserved );

                // V.7.4: SELECT manual_hold_reason + stock_updated_at เพิ่มสำหรับ auto-unlock logic
                $anc_row = $wpdb->get_row( $wpdb->prepare(
                    "SELECT low_stock_threshold, manual_hold, manual_hold_reason, stock_updated_at FROM {$table} WHERE sku = %s",
                    $ancestor_sku
                ) );
                $anc_manual_hold = $anc_row ? (int) $anc_row->manual_hold : 0;

                // V.7.4 Phase 0 Hotfix: auto-unlock manual_hold
                // เงื่อนไขทั้งหมดต้องเป็น true:
                //   1. flag dinoco_auto_unlock_enabled = true (opt-in canary)
                //   2. anc_manual_hold = 1
                //   3. reason ∈ whitelist (admin custom reason ไม่ clear)
                //   4. anc_available > 0 (ของกลับมาแล้ว)
                //   5. NOW() - stock_updated_at >= 72h (safety buffer admin ตั้งใจ hold ได้)
                if ( $auto_unlock_flag
                    && $anc_manual_hold === 1
                    && $anc_row
                    && in_array( $anc_row->manual_hold_reason, array( 'Admin manual OOS', 'migrated from OOS timer' ), true )
                    && $anc_available > 0
                ) {
                    $hours_elapsed = $anc_row->stock_updated_at
                        ? ( time() - strtotime( $anc_row->stock_updated_at ) ) / 3600
                        : 0;

                    if ( $hours_elapsed >= 72 && function_exists( 'b2b_unlock_product_oos' ) ) {
                        // Reuse helper (dual-write custom table + ACF + recursive auto_status + cache invalidation)
                        b2b_unlock_product_oos( $ancestor_sku );

                        if ( function_exists( 'b2b_log' ) ) {
                            b2b_log( sprintf(
                                '[Stock] AUTO-UNLOCK %s reason=%s available=%d hours=%.1f',
                                $ancestor_sku, $anc_row->manual_hold_reason, $anc_available, $hours_elapsed
                            ) );
                        }

                        // b2b_unlock_product_oos() เรียก dinoco_stock_auto_status() อีกครั้ง
                        // (recursive — ancestor ยังอยู่ใน outer loop แต่ manual_hold = 0 แล้ว)
                        // continue ต่อ ancestor ตัวถัดไป (ข้าม update ตรง)
                        continue;
                    }
                }

                if ( $anc_manual_hold || $anc_available <= 0 ) {
                    $anc_status = 'out_of_stock';
                } else {
                    $anc_status = 'in_stock';
                }

                $wpdb->update( $table, array(
                    'stock_status'     => $anc_status,
                    'stock_updated_at' => current_time( 'mysql' ),
                ), array( 'sku' => $ancestor_sku ) );

                // Dual-write ancestor via post_id map (no get_posts)
                $anc_pid = $pid_map[ strtoupper( $ancestor_sku ) ] ?? 0;
                if ( $anc_pid ) {
                    update_post_meta( $anc_pid, 'stock_status', $anc_status );
                }
            }
        }
    }
}

if ( ! function_exists( 'dinoco_stock_get' ) ) {
    /**
     * ดึง stock info สำหรับ SKU (admin view)
     */
    function dinoco_stock_get( $sku ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $sku   = strtoupper( trim( $sku ) );
        $row   = $wpdb->get_row( $wpdb->prepare(
            "SELECT sku, name, stock_qty, stock_status, low_stock_threshold, reorder_point,
                    manual_hold, manual_hold_reason, bo_eta_override, bo_eta_buffer_days, bo_note, stock_updated_at
             FROM {$table} WHERE sku = %s", $sku
        ), ARRAY_A );
        if ( ! $row ) return null;

        // V.6.0 [M-1 FIX]: non-leaf stock = recursive MIN via dinoco_compute_hierarchy_stock()
        $relations = get_option( 'dinoco_sku_relations', [] );
        $is_set = ! dinoco_is_leaf_sku( $sku, $relations );
        $row['is_set'] = $is_set;
        $row['is_leaf'] = ! $is_set;

        if ( $is_set && function_exists( 'dinoco_compute_hierarchy_stock' ) ) {
            $row['stock_qty'] = dinoco_compute_hierarchy_stock( $sku, $relations );
            $row['stock_qty_source'] = 'computed_from_children';
        }

        // Phase 4: compute reserved_qty + available_qty
        $reserved = function_exists( 'dinoco_get_reserved_qty' ) ? dinoco_get_reserved_qty( $sku ) : 0;
        $available = max( 0, (int) $row['stock_qty'] - $reserved );
        $row['reserved_qty']  = $reserved;
        $row['available_qty'] = $available;

        // Compute stock_display ใช้ available_qty (Phase 4)
        $threshold = (int) $row['low_stock_threshold'];
        if ( (int) $row['manual_hold'] || $available <= 0 ) {
            $row['stock_display'] = 'out_of_stock';
        } elseif ( $threshold > 0 && $available <= $threshold ) {
            $row['stock_display'] = 'low_stock';
        } else {
            $row['stock_display'] = 'in_stock';
        }

        return $row;
    }
}

// ════════════════════════════════════════════════════════════
// PART 1.35: SKU HIERARCHY HELPERS (V.6.0 — 3-Level Product Hierarchy)
// ════════════════════════════════════════════════════════════
// 7 helper functions สำหรับระบบ 3 ระดับ (แม่→ลูก→ชิ้นส่วนย่อย)
// flat format: wp_options 'dinoco_sku_relations' = { parent: [children], child: [grandchildren] }
// Max depth = 3, leaf-only stock deduction, shared child allowed

/**
 * ดึง leaf nodes ทั้งหมดของ SKU (recursive, max depth 3)
 * leaf = SKU ที่ไม่มี children → ตัดสต็อกเฉพาะ leaf เท่านั้น [DD-2]
 *
 * dinoco_get_leaf_skus('SET_A')    → ['CHILD_C', 'GRAND_B1', 'GRAND_B2']
 * dinoco_get_leaf_skus('CHILD_B')  → ['GRAND_B1', 'GRAND_B2']
 * dinoco_get_leaf_skus('GRAND_B1') → ['GRAND_B1']
 */
if ( ! function_exists( 'dinoco_get_leaf_skus' ) ) {
    // V.7.1 [C1 FIX]: $visited เป็น value-copy (ไม่ใช่ reference) — sibling branches ต้องไม่ share visited
    //   → DD-3 shared child ผ่าน 2 paths จะคืน leaf ถูกต้อง (เดิม sibling รอบสองเจอ visited → return [])
    //   → dedup output ด้วย array_unique ป้องกัน double-subtract เมื่อ shared leaf ปรากฏหลาย path
    function dinoco_get_leaf_skus( $sku, $relations = null, $depth = 0, $visited = array() ) {
        if ( $depth > 3 ) return array( strtoupper( trim( $sku ) ) ); // hard limit [DD-4]

        if ( $relations === null ) {
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
        }

        $sku_upper = strtoupper( trim( $sku ) );

        // circular ref guard (cycle ใน current DFS path เท่านั้น — value-copy ทำให้ sibling branch มี visited ของตัวเอง)
        if ( in_array( $sku_upper, $visited, true ) ) return array();
        $visited[] = $sku_upper;

        // ถ้าไม่มี children → เป็น leaf
        if ( ! isset( $relations[ $sku_upper ] ) || empty( $relations[ $sku_upper ] ) ) {
            // ลอง original case ด้วย
            if ( ! isset( $relations[ $sku ] ) || empty( $relations[ $sku ] ) ) {
                return array( $sku_upper );
            }
            $children = $relations[ $sku ];
        } else {
            $children = $relations[ $sku_upper ];
        }

        if ( ! is_array( $children ) || empty( $children ) ) {
            return array( $sku_upper );
        }

        // recursive resolve children → leaf nodes (ส่ง $visited เป็น value-copy ทุกครั้ง)
        $leaves = array();
        foreach ( $children as $child ) {
            $child_leaves = dinoco_get_leaf_skus( $child, $relations, $depth + 1, $visited );
            $leaves = array_merge( $leaves, $child_leaves );
        }

        // V.7.1: dedup — shared leaf ผ่านหลาย path จะนับครั้งเดียว (ป้องกัน double-subtract)
        return array_values( array_unique( $leaves ) );
    }
}

/**
 * เช็คว่า SKU เป็น leaf (ไม่มี children) → ใช้ filter Dip Stock snapshot
 */
if ( ! function_exists( 'dinoco_is_leaf_sku' ) ) {
    function dinoco_is_leaf_sku( $sku, $relations = null ) {
        if ( $relations === null ) {
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
        }
        $sku_upper = strtoupper( trim( $sku ) );
        if ( isset( $relations[ $sku_upper ] ) && ! empty( $relations[ $sku_upper ] ) ) return false;
        if ( isset( $relations[ $sku ] ) && ! empty( $relations[ $sku ] ) ) return false;
        return true;
    }
}

/**
 * V.7.0 [H-12]: สร้าง child → parent map (O(1) lookup) แทน loop ผ่าน relations ทุกครั้ง
 * Static cache ต่อ request
 */
if ( ! function_exists( 'dinoco_get_child_to_parent_map' ) ) {
    function dinoco_get_child_to_parent_map() {
        static $map = null;
        if ( $map !== null ) return $map;
        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) ) $relations = array();
        $map = array();
        foreach ( $relations as $p => $ch ) {
            if ( ! is_array( $ch ) ) continue;
            $pu = strtoupper( trim( $p ) );
            foreach ( $ch as $c ) {
                $map[ strtoupper( trim( $c ) ) ] = $pu;
            }
        }
        return $map;
    }
}

/**
 * หา ancestor (parent) ทุกระดับของ SKU [C-2, C-3 FIX, V.7.0 H-12: O(depth) ผ่าน child→parent map]
 *
 * dinoco_get_ancestor_skus('GRAND_B1') → ['CHILD_B', 'SET_A']
 * dinoco_get_ancestor_skus('CHILD_C')  → ['SET_A']
 * dinoco_get_ancestor_skus('SET_A')    → []
 */
if ( ! function_exists( 'dinoco_get_ancestor_skus' ) ) {
    function dinoco_get_ancestor_skus( $sku, $relations = null ) {
        // V.7.0: ใช้ child→parent map (O(1) lookup) — $relations param kept for back-compat
        $map = dinoco_get_child_to_parent_map();
        $ancestors = array();
        $current = strtoupper( trim( $sku ) );
        for ( $i = 0; $i < 3; $i++ ) {
            if ( ! isset( $map[ $current ] ) ) break;
            $p = $map[ $current ];
            if ( in_array( $p, $ancestors, true ) ) break; // circular guard
            $ancestors[] = $p;
            $current = $p;
        }
        return $ancestors;
    }
}

/**
 * คำนวณ stock สำหรับ SKU (recursive MIN) [M-1 FIX — centralize]
 * leaf → return stock_qty จาก DB
 * non-leaf → return MIN(children computed stock)
 */
if ( ! function_exists( 'dinoco_compute_hierarchy_stock' ) ) {
    // V.7.1 [C1 FIX]: $visited เป็น value-copy — DD-3 shared child ทำให้ MIN() คำนวณถูก
    //   Repro เดิม: SET → [CHILD_B, CHILD_C] ทั้งคู่มี LEAF_X → รอบสอง LEAF_X เจอ visited → return 0 → SET=0 ผิด
    function dinoco_compute_hierarchy_stock( $sku, $relations = null, $depth = 0, $visited = array(), $stock_map = null ) {
        if ( $depth > 3 ) return 0;

        if ( $relations === null ) {
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
        }

        // V.7.0 [H-13]: batch-load stock_qty for all active SKUs (1 query) แทน query per leaf
        if ( $stock_map === null ) {
            static $cached_map = null;
            if ( $cached_map === null ) {
                global $wpdb;
                $rows = $wpdb->get_results( "SELECT sku, stock_qty FROM {$wpdb->prefix}dinoco_products WHERE is_active = 1", OBJECT_K );
                $cached_map = array();
                if ( is_array( $rows ) ) {
                    foreach ( $rows as $s => $r ) {
                        $cached_map[ strtoupper( $s ) ] = (int) $r->stock_qty;
                    }
                }
            }
            $stock_map = $cached_map;
        }

        $sku_upper = strtoupper( trim( $sku ) );

        // C-1: circular reference guard
        if ( in_array( $sku_upper, $visited, true ) ) return 0;
        $visited[] = $sku_upper;

        // หา children
        $children = null;
        if ( isset( $relations[ $sku_upper ] ) && ! empty( $relations[ $sku_upper ] ) ) {
            $children = $relations[ $sku_upper ];
        } elseif ( isset( $relations[ $sku ] ) && ! empty( $relations[ $sku ] ) ) {
            $children = $relations[ $sku ];
        }

        // leaf → return stock_qty จาก stock_map (O(1))
        if ( ! is_array( $children ) || empty( $children ) ) {
            return $stock_map[ $sku_upper ] ?? 0;
        }

        // non-leaf → MIN(children computed stock)
        $min_stock = PHP_INT_MAX;
        foreach ( $children as $child ) {
            $child_stock = dinoco_compute_hierarchy_stock( $child, $relations, $depth + 1, $visited, $stock_map );
            if ( $child_stock < $min_stock ) $min_stock = $child_stock;
        }

        return $min_stock === PHP_INT_MAX ? 0 : $min_stock;
    }
}

/**
 * เช็คว่า SKU เป็น top-level SET (เป็น parent แต่ไม่เป็น child ของใคร) [DD-6]
 * ใช้ filter B2C pages — ไม่แสดง sub-SET เป็น standalone bundle
 */
if ( ! function_exists( 'dinoco_is_top_level_set' ) ) {
    function dinoco_is_top_level_set( $sku, $relations = null ) {
        if ( $relations === null ) {
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
        }
        $sku_upper = strtoupper( trim( $sku ) );

        // ต้องเป็น parent (มี children)
        $is_parent = ( isset( $relations[ $sku_upper ] ) && ! empty( $relations[ $sku_upper ] ) )
                  || ( isset( $relations[ $sku ] ) && ! empty( $relations[ $sku ] ) );
        if ( ! $is_parent ) return false;

        // ต้องไม่เป็น child ของ parent อื่น
        foreach ( $relations as $parent => $children ) {
            if ( ! is_array( $children ) ) continue;
            $children_upper = array_map( function( $c ) { return strtoupper( trim( $c ) ); }, $children );
            if ( in_array( $sku_upper, $children_upper, true ) ) {
                return false; // เป็น child ของ $parent → ไม่ใช่ top-level
            }
        }

        return true;
    }
}

/**
 * Validate ว่าเพิ่ม child ได้หรือไม่ (ก่อน save) [DD-4]
 * - ห้าม self reference
 * - ห้าม circular reference
 * - ห้าม depth > 3
 * - Allow shared child [DD-3]
 */
if ( ! function_exists( 'dinoco_validate_sku_hierarchy' ) ) {
    function dinoco_validate_sku_hierarchy( $parent_sku, $child_sku, $relations = null ) {
        if ( $relations === null ) {
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
        }
        $parent_upper = strtoupper( trim( $parent_sku ) );
        $child_upper  = strtoupper( trim( $child_sku ) );

        // self reference
        if ( $parent_upper === $child_upper ) return false;

        // circular: child ต้องไม่เป็น ancestor ของ parent
        $parent_ancestors = dinoco_get_ancestor_skus( $parent_upper, $relations );
        if ( in_array( $child_upper, $parent_ancestors, true ) ) return false;

        // depth: สมมุติ parent อยู่ depth X → child จะอยู่ depth X+1
        // ถ้า child มี children อยู่แล้ว → depth X+2 ต้อง <= 3
        $parent_depth = count( dinoco_get_ancestor_skus( $parent_upper, $relations ) ) + 1; // parent's own depth
        $child_max_depth = 0;
        if ( isset( $relations[ $child_upper ] ) && ! empty( $relations[ $child_upper ] ) ) {
            $child_max_depth = 1; // child มี children = อย่างน้อย 1 ระดับลง
            foreach ( $relations[ $child_upper ] as $gc ) {
                $gc_upper = strtoupper( trim( $gc ) );
                if ( isset( $relations[ $gc_upper ] ) && ! empty( $relations[ $gc_upper ] ) ) {
                    $child_max_depth = 2;
                    break;
                }
            }
        }

        // total depth = parent_depth + 1 (child) + child_max_depth
        if ( $parent_depth + 1 + $child_max_depth > 3 ) return false;

        return true;
    }
}

/**
 * ดึง hierarchy tree ของ SKU (สำหรับ Admin UI + B2B detail)
 * Return: ['sku'=>'X', 'children'=>[['sku'=>'A','children'=>[...]], ...]]
 */
if ( ! function_exists( 'dinoco_get_sku_tree' ) ) {
    // V.7.1 [C2 FIX]: $visited เป็น value-copy — shared child ผ่านหลาย path จะแสดง tree ถูก
    function dinoco_get_sku_tree( $sku, $relations = null, $depth = 0, $visited = array() ) {
        if ( $depth > 3 ) return array( 'sku' => $sku, 'children' => array() );

        if ( $relations === null ) {
            $relations = get_option( 'dinoco_sku_relations', array() );
            if ( ! is_array( $relations ) ) $relations = array();
        }
        $sku_upper = strtoupper( trim( $sku ) );

        // C-1: circular reference guard
        if ( in_array( $sku_upper, $visited, true ) ) return array( 'sku' => $sku_upper, 'children' => array() );
        $visited[] = $sku_upper;

        $children_skus = null;
        if ( isset( $relations[ $sku_upper ] ) && ! empty( $relations[ $sku_upper ] ) ) {
            $children_skus = $relations[ $sku_upper ];
        } elseif ( isset( $relations[ $sku ] ) && ! empty( $relations[ $sku ] ) ) {
            $children_skus = $relations[ $sku ];
        }

        $tree = array( 'sku' => $sku_upper, 'children' => array() );

        if ( is_array( $children_skus ) && ! empty( $children_skus ) ) {
            foreach ( $children_skus as $child ) {
                $tree['children'][] = dinoco_get_sku_tree( $child, $relations, $depth + 1, $visited );
            }
        }

        return $tree;
    }
}

// ════════════════════════════════════════════════════════════
// PART 1.4: RESERVED QTY + AVAILABLE QTY + CONFLICT (V.4.0 — Phase 4)
// ════════════════════════════════════════════════════════════

/**
 * V.7.0 [C-7]: Bulk reserved map builder — single JOIN query over all active reserved orders
 *   → return map: sku → reserved_qty (รวม leaf + ancestor + self charges)
 * Cache 60 วินาที (transient `b2b_reserved_map_bulk`)
 * แทนที่การ query get_posts() ต่อ SKU (N+1)
 */
if ( ! function_exists( 'b2b_build_reserved_map_bulk' ) ) {
    function b2b_build_reserved_map_bulk() {
        $cache = get_transient( 'b2b_reserved_map_bulk' );
        if ( $cache !== false ) return $cache;

        global $wpdb;
        $rows = $wpdb->get_results( "
            SELECT pm.meta_value AS items
            FROM {$wpdb->postmeta} pm
            INNER JOIN {$wpdb->postmeta} pm2 ON pm.post_id = pm2.post_id
            INNER JOIN {$wpdb->posts} p ON p.ID = pm.post_id
            WHERE pm.meta_key = 'order_items'
              AND pm2.meta_key = 'order_status'
              AND pm2.meta_value IN ('checking_stock','awaiting_confirm','awaiting_payment','paid','packed')
              AND p.post_type = 'b2b_order' AND p.post_status = 'publish'
        " );

        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) ) $relations = array();

        $map = array();
        if ( ! is_array( $rows ) ) $rows = array();

        foreach ( $rows as $r ) {
            if ( empty( $r->items ) ) continue;
            if ( ! preg_match_all( '/\(([A-Za-z0-9_\-]+)\)\s*x(\d+)/i', $r->items, $m, PREG_SET_ORDER ) ) continue;

            foreach ( $m as $hit ) {
                $sku_hit = strtoupper( $hit[1] );
                $qty     = (int) $hit[2];
                if ( $qty <= 0 ) continue;

                // Charge leaves (ตัดสต็อกจริงอยู่ที่ leaf)
                $leaves = function_exists( 'dinoco_get_leaf_skus' )
                    ? dinoco_get_leaf_skus( $sku_hit, $relations )
                    : array( $sku_hit );
                foreach ( $leaves as $leaf ) {
                    $lu = strtoupper( $leaf );
                    $map[ $lu ] = ( $map[ $lu ] ?? 0 ) + $qty;
                }

                // Charge ancestors (parent/grandparent — display layer)
                if ( function_exists( 'dinoco_get_ancestor_skus' ) ) {
                    $ancestors = dinoco_get_ancestor_skus( $sku_hit, $relations );
                    foreach ( $ancestors as $anc ) {
                        $map[ $anc ] = ( $map[ $anc ] ?? 0 ) + $qty;
                    }
                }

                // Charge self (กรณี hit เป็น parent หรือ leaf ตรง — leaf จะถูก charge ซ้ำแต่เราใช้ +=)
                // leaf ถูก charge แล้ว, parent ยังไม่ถูก charge → เพิ่ม self ถ้ายังไม่ใช่ leaf
                if ( ! in_array( $sku_hit, array_map( 'strtoupper', $leaves ), true ) ) {
                    $map[ $sku_hit ] = ( $map[ $sku_hit ] ?? 0 ) + $qty;
                }
            }
        }

        set_transient( 'b2b_reserved_map_bulk', $map, 60 );
        return $map;
    }
}

/**
 * คำนวณ reserved_qty สำหรับ SKU (computed — ไม่เก็บ field แยก)
