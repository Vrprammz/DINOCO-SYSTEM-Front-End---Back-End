        update_option( '_dinoco_warehouse_mapping_seeded', '1' );
        if ( function_exists( 'b2b_log' ) ) b2b_log( '[Shipping V.8.0] Seeded 2 warehouse mappings' );
    }

    // ─────────────────────────────────────────────────────────────
    // 10. Init wp_option: dinoco_shipping_defaults
    // ─────────────────────────────────────────────────────────────
    if ( ! get_option( 'dinoco_shipping_defaults' ) ) {
