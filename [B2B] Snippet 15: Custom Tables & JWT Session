 */
if ( ! function_exists( 'dinoco_get_box_template' ) ) {
    function dinoco_get_box_template( $id ) {
        if ( ! $id ) return null;
        $id = absint( $id );
        $cache_key = 'dinoco_box_tpl_' . $id;
        $cached = wp_cache_get( $cache_key, 'dinoco_shipping' );
        if ( $cached !== false ) return $cached;

        global $wpdb;
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$wpdb->prefix}dinoco_box_templates WHERE id = %d AND is_active = 1",
