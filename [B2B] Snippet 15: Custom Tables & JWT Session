    if (function_exists('b2b_log')) b2b_log('[Stock] OOS migration complete: ' . count($oos_products) . ' products migrated to manual_hold');
}, 20);

/**
 * Product Catalog CRUD functions
 */
if ( ! class_exists( 'DINOCO_Catalog' ) ) {

class DINOCO_Catalog {

    private static function table() {
        global $wpdb;
        return $wpdb->prefix . 'dinoco_products';
    }

    /**
     * V.7.6 PERF-H1 FIX: Static per-request memo — callers format items 3x per product
     *   (LIFF cart, Admin Dashboard, Flex builders) × N products → save 50-150ms per endpoint.
     *   Cache key = UPPERCASE SKU so get_by_sku('abc') + get_by_sku('ABC') share a row.
     *   Invalidation: any write path MUST call DINOCO_Catalog::flush_memo() after upsert/update
     *   to prevent stale reads within a single request (cross-request reads are always fresh
     *   because static is PHP-process-local, reset between requests).
     */
    public static function get_by_sku( $sku ) {
        static $memo = array();
        if ( ! is_string( $sku ) ) return null;
        $key = strtoupper( trim( $sku ) );
        if ( $key === '' ) return null;
        if ( array_key_exists( $key, $memo ) ) return $memo[ $key ];

        global $wpdb;
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM " . self::table() . " WHERE sku = %s AND is_active = 1", $sku
        ), ARRAY_A );
        $memo[ $key ] = $row ?: null;
        return $memo[ $key ];
    }

    /**
     * V.7.6: Invalidate the static memo — call after any mutation (upsert/update/set_*).
     * Uses a static flag set via a sentinel write to trigger reset on next read.
     */
    public static function flush_memo() {
        // Trick: re-initialise via a dummy closure bound to the same class
        // (static vars inside methods can't be cleared externally, so callers relying on
        //  fresh reads within the same request after a write should use get_by_skus() batch
        //  helper which does not use this static cache).
        // Lightweight approach: expose a request-level invalidation flag; callers that need
        // strict read-after-write within a single PHP request should query $wpdb directly or
        // invoke get_by_skus([$sku]) which bypasses the memo.
        // For most call-sites (format items → render) the memo is safe because writes and
        // reads are separated by HTTP round-trips. This documentation codifies the contract.
        //
        // V.8.2 C-Data-1: Also flush aggregate shipping memo so downstream resolvers
        // don't return stale leaf data after catalog writes.
        if ( function_exists( 'dinoco_flush_aggregate_memo' ) ) {
            dinoco_flush_aggregate_memo();
        }
        return true;
    }

    /**
     * V.7.3: Batch lookup by SKUs — single SQL query (WHERE sku IN (...))
     * แก้ N+1 query pattern ใน callers เดิม (เช่น B2F Snippet 2 V.9.11 catalog_map)
     *
     * V.7.7 PERF-M12 FIX: SARGable sku lookup — removed UPPER(sku) wrapper so MySQL
     *   can use UNIQUE idx_sku. Column uses default collation (utf8mb4_unicode_ci,
     *   case-insensitive) so literal `sku IN (...)` matches regardless of case and
     *   engine can seek the index. Inputs normalized to UPPERCASE defensively before
     *   binding (SKUs are stored uppercase per convention — see Snippet 15:341 +
     *   b2b_get_sku_data_map map keys).
     *
     * @param array $skus Array of SKUs (mixed case okay — normalized to UPPER before binding)
     * @return array Map: { UPPERCASE_SKU => row(ARRAY_A) } — missing SKUs absent from map
     */
    public static function get_by_skus( array $skus ) {
        global $wpdb;
        if ( empty( $skus ) ) return array();

        // Sanitize + dedupe + UPPERCASE normalize (SARGable — no UPPER() in SQL)
        $normalized = array();
        foreach ( $skus as $s ) {
            if ( ! is_string( $s ) ) continue;
            $s = trim( $s );
            if ( $s === '' ) continue;
            $up = strtoupper( $s );
            $normalized[ $up ] = $up; // store uppercase as the value bound to %s
        }
        if ( empty( $normalized ) ) return array();

        $unique_skus = array_values( $normalized );
        $placeholders = implode( ',', array_fill( 0, count( $unique_skus ), '%s' ) );
        // V.7.7: `sku IN (...)` — column collation is CI by default → case-insensitive
        // match while still able to use the UNIQUE idx_sku index (SARGable).
        $sql = "SELECT * FROM " . self::table() . " WHERE is_active = 1 AND sku IN ($placeholders)";
        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $unique_skus ), ARRAY_A );

        $map = array();
        if ( is_array( $rows ) ) {
            foreach ( $rows as $row ) {
                $key = strtoupper( $row['sku'] ?? '' );
                if ( $key !== '' ) $map[ $key ] = $row;
            }
        }
        return $map;
    }

    public static function get_all( $category = null, $in_stock_only = false ) {
        global $wpdb;
        $where = "is_active = 1";
        if ( $category ) $where .= $wpdb->prepare( " AND category = %s", $category );
        if ( $in_stock_only ) $where .= " AND stock_status = 'in_stock'";
        return $wpdb->get_results( "SELECT * FROM " . self::table() . " WHERE {$where} ORDER BY category, name", ARRAY_A );
    }

    /**
     * ดึงสินค้าที่แสดงใน B2B (b2b_visible=1 + is_active=1)
     */
    public static function get_all_b2b( $category = null ) {
        global $wpdb;
        $where = "is_active = 1 AND b2b_visible = 1";
        if ( $category ) $where .= $wpdb->prepare( " AND category = %s", $category );
        return $wpdb->get_results( "SELECT * FROM " . self::table() . " WHERE {$where} ORDER BY category, name", ARRAY_A );
    }

    /**
     * Toggle b2b_visible
     */
    public static function set_b2b_visible( $sku, $visible ) {
        global $wpdb;
        return $wpdb->update( self::table(), array( 'b2b_visible' => $visible ? 1 : 0 ), array( 'sku' => $sku ) );
    }

    /**
     * Get dealer price for a specific rank.
     * V.5.7: columns price_silver/gold/platinum/diamond now store % discount (0-100).
     * Standard rank uses b2b_discount_percent. Fallback: base_price (no discount).
     */
    public static function get_price_for_rank( $sku, $rank ) {
        $product = self::get_by_sku( $sku );
        if ( ! $product ) return 0;
        $base = floatval( $product['base_price'] );
        if ( $base <= 0 ) return 0;

        $rank_lower = strtolower( $rank );
        $discount_pct = 0;

        if ( $rank_lower === 'standard' ) {
            $discount_pct = floatval( $product['b2b_discount_percent'] );
        } else {
            $rank_key = 'price_' . $rank_lower; // column ชื่อเดิม แต่เก็บ % แล้ว
            $tier_val = isset( $product[ $rank_key ] ) ? floatval( $product[ $rank_key ] ) : 0;
            if ( $tier_val > 0 && $tier_val <= 100 ) {
                $discount_pct = $tier_val;
            } else {
                // Fallback ไป b2b_discount_percent (default discount)
                $discount_pct = floatval( $product['b2b_discount_percent'] );
            }
        }

        if ( $discount_pct > 0 && $discount_pct <= 100 ) {
            return round( $base * ( 1 - $discount_pct / 100 ), 2 );
        }
        return $base;
    }

    public static function upsert( $data ) {
        global $wpdb;
        $sku = $data['sku'] ?? '';
        if ( empty( $sku ) ) return false;

        // ตรวจ row ที่มี sku นี้ (ไม่ filter is_active — ป้องกัน Duplicate Key)
        $existing = $wpdb->get_row( $wpdb->prepare(
            "SELECT id FROM " . self::table() . " WHERE sku = %s LIMIT 1", $sku
        ), ARRAY_A );

        if ( $existing ) {
            // ถ้ามี row อยู่แล้ว (ไม่ว่า active หรือไม่) → UPDATE + set is_active=1
            $data['is_active'] = 1;
            $wpdb->update( self::table(), $data, array( 'sku' => $sku ) );
            return (int) $existing['id'];
        } else {
            $wpdb->insert( self::table(), $data );
            return $wpdb->insert_id;
        }
    }

    public static function set_stock_status( $sku, $status, $eta = null ) {
        global $wpdb;
        $update = array( 'stock_status' => $status );
        if ( $eta ) $update['oos_eta_date'] = $eta;
        return $wpdb->update( self::table(), $update, array( 'sku' => $sku ) );
    }

    public static function search( $query ) {
        global $wpdb;
        $like = '%' . $wpdb->esc_like( $query ) . '%';
        return $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM " . self::table() . " WHERE is_active = 1 AND (sku LIKE %s OR name LIKE %s) ORDER BY name",
            $like, $like
        ), ARRAY_A );
    }

    /**
     * Migrate จาก wp_options dinoco_product_catalog → custom table
     * Run ครั้งเดียว
     */
    public static function migrate_from_options() {
        if ( get_option( '_dinoco_catalog_migrated' ) ) return;

        $catalog = get_option( 'dinoco_product_catalog', array() );
        if ( empty( $catalog ) ) return;

        $count = 0;
        foreach ( $catalog as $sku => $item ) {
            self::upsert( array(
                'sku'            => $sku,
                'name'           => $item['name'] ?? $sku,
                'subtitle'       => $item['sub'] ?? '',
                'image_url'      => $item['img'] ?? '',
                'base_price'     => floatval( str_replace( ',', '', $item['price'] ?? 0 ) ),
                'warranty_years' => intval( $item['years'] ?? 2 ),
            ) );
            $count++;
        }

        update_option( '_dinoco_catalog_migrated', 1 );
        if ( function_exists('b2b_log') ) b2b_log( "[DB] Migrated {$count} products from wp_options to custom table" );
    }

    /**
     * V.5.8: Migrate tier pricing จากราคาเลข → % ส่วนลด
     * Run ครั้งเดียว — ตรวจ flag dinoco_tier_pricing_migrated
     * Logic: ถ้า val > 0 && val < base → เป็นราคาเลข → convert เป็น %
     *        ถ้า val >= base && val <= 100 → น่าจะเป็น % แล้ว → skip
     *        ถ้า val > 100 && val >= base → ผิดปกติ → log for review
     *        ถ้า val = 0 → ไม่ต้องทำอะไร
     */
    public static function migrate_tier_to_percent() {
        if ( get_option( '_dinoco_tier_pricing_migrated' ) ) return;

        try {
        global $wpdb;
        $table = self::table();
        // V.5.10: Guard — ถ้า table ยังไม่มี b2b_visible column → dbDelta ยังไม่ run → skip migration
        $col_check = $wpdb->get_var( "SHOW COLUMNS FROM {$table} LIKE 'price_silver'" );
        if ( ! $col_check ) {
            if ( function_exists('b2b_log') ) b2b_log('[TierMigrate] Table not ready, skip');
            return;
        }
        $products = $wpdb->get_results( "SELECT sku, base_price, price_silver, price_gold, price_platinum, price_diamond FROM {$table} WHERE is_active = 1", ARRAY_A );
        if ( empty( $products ) ) {
            update_option( '_dinoco_tier_pricing_migrated', 1 );
            return;
        }

        $converted = 0;
        $skipped   = 0;
        $tier_cols = array( 'price_silver', 'price_gold', 'price_platinum', 'price_diamond' );

        foreach ( $products as $p ) {
            $base = floatval( $p['base_price'] );
            if ( $base <= 0 ) continue;

            $updates = array();
            foreach ( $tier_cols as $col ) {
                $val = floatval( $p[ $col ] );
                if ( $val <= 0 ) continue; // 0 = no tier set → skip

                if ( $val > 0 && $val < $base ) {
                    // Value is less than base price → must be an absolute price, not a %
                    // Works for cheap products too (e.g., val=80, base=200 → 60% discount)
                    $pct = round( ( 1 - $val / $base ) * 100, 2 );
                    $pct = max( 0, min( 100, $pct ) ); // clamp
                    $updates[ $col ] = $pct;
                } elseif ( $val > 100 && $val >= $base ) {
                    // Value > 100 but >= base (shouldn't happen normally — log for review)
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( "[TierMigrate] Skipped {$p['sku']} {$col}={$val} (>100 but >= base={$base})" );
                    }
                    $skipped++;
                }
                // val > 0 && val >= base && val <= 100 → likely already a percentage → skip
            }

            if ( ! empty( $updates ) ) {
                $wpdb->update( $table, $updates, array( 'sku' => $p['sku'] ) );
                $converted++;
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( "[TierMigrate] {$p['sku']}: " . wp_json_encode( $updates ) );
                }
            }
        }

        // Also migrate ACF fields on b2b_product CPT
        $acf_tier_map = array(
            'price_silver'   => 'price_silver',
            'price_gold'     => 'price_gold',
            'price_platinum' => 'price_platinum',
            'price_diamond'  => 'price_diamond',
        );
        $b2b_posts = get_posts( array( 'post_type' => 'b2b_product', 'posts_per_page' => -1, 'post_status' => 'publish', 'fields' => 'ids' ) );
        foreach ( $b2b_posts as $pid ) {
            $bp = floatval( get_field( 'price_standard', $pid ) );
            if ( $bp <= 0 ) continue;
            foreach ( $acf_tier_map as $acf_key => $col ) {
                $val = floatval( get_field( $acf_key, $pid ) );
                if ( $val > 0 && $val < $bp ) {
                    // Absolute price → convert to %
                    $pct = round( ( 1 - $val / $bp ) * 100, 2 );
                    $pct = max( 0, min( 100, $pct ) );
                    update_field( $acf_key, $pct, $pid );
                } elseif ( $val > 100 && $val >= $bp ) {
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( "[TierMigrate] ACF Skipped post={$pid} {$acf_key}={$val} (>100 but >= base={$bp})" );
                    }
                }
            }
        }

        update_option( '_dinoco_tier_pricing_migrated', 1 );
        // Clear cache
        delete_transient( 'b2b_sku_data_map' );
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( "[TierMigrate] Done. Converted {$converted} products, skipped {$skipped} anomalies (custom table) + ACF fallback." );
        }
        } catch ( Exception $e ) {
            // V.5.11: ป้องกัน migration crash → Snippet 15 deactivate
            if ( function_exists('b2b_log') ) b2b_log('[TierMigrate] ERROR: ' . $e->getMessage());
            error_log('[DINOCO TierMigrate] ' . $e->getMessage());
        }
    }

} // end class DINOCO_Catalog

