/**
 * Estimate weight from leaves (FR-3 — for assembled_set pack_mode).
 * Sum weight_per_unit_g of leaves (content-only, no tare — caller adds parent tare).
 */
if ( ! function_exists( 'dinoco_estimate_weight_from_leaves' ) ) {
    function dinoco_estimate_weight_from_leaves( $sku ) {
        if ( ! $sku ) return 0;
        if ( function_exists( 'dinoco_is_leaf_sku' ) && dinoco_is_leaf_sku( $sku ) ) {
            $cat = DINOCO_Catalog::get_by_sku( $sku );
            return intval( $cat['weight_per_unit_g'] ?? 0 );
        }
        $leaves = function_exists( 'dinoco_get_leaf_skus' ) ? dinoco_get_leaf_skus( $sku ) : array();
        if ( empty( $leaves ) ) return 0;
        $total = 0;
        foreach ( $leaves as $leaf ) {
            $cat = DINOCO_Catalog::get_by_sku( $leaf );
            $total += intval( $cat['weight_per_unit_g'] ?? 0 );
        }
        return $total;
    }
}

/**
 * API retry wrapper with exp backoff + jitter (FR-2).
 * Retryable: 1003/500/502/504/timeout. Non-retryable (400/401/403/409/422) → abandon.
 * Caller inserts DLQ on retry_exhausted or retry_abandoned.
 */
if ( ! function_exists( 'dinoco_api_retry' ) ) {
    function dinoco_api_retry( $callback, $max = 3, $delays = array( 1, 2, 5 ) ) {
        // R5 FIX: 429 backoff can total 100s. Bump execution time to survive
        // PHP-FPM default 30s timeout (best-effort; some hosts ignore).
        if ( function_exists( 'set_time_limit' ) ) @set_time_limit( 120 );
        $attempt = 0;
        $last_result = null;
        while ( $attempt < $max ) {
            $last_result = call_user_func( $callback );
            if ( is_array( $last_result ) && ! empty( $last_result['ok'] ) ) return $last_result;

            $code = '';
            if ( is_array( $last_result ) ) {
                if ( isset( $last_result['status_code'] ) ) $code = (string) $last_result['status_code'];
                elseif ( isset( $last_result['error_code'] ) ) $code = (string) $last_result['error_code'];
            }

            // Non-retryable → straight to DLQ via caller
            if ( in_array( $code, array( '400', '401', '403', '409', '422' ), true ) ) {
                if ( is_array( $last_result ) ) $last_result['retry_abandoned'] = true;
                return $last_result;
            }

            // V.8.2 H-R3: 429 rate limit needs much longer backoff (10s/30s/60s)
            // to avoid hammering Flash API during rate-limit enforcement.
            $is_rate_limit = ( $code === '429' );
            $effective_delays = $is_rate_limit ? array( 10, 30, 60 ) : $delays;

            // Retryable: exp backoff + jitter 50-150ms
            if ( $attempt < $max - 1 ) {
                $delay_sec = isset( $effective_delays[ $attempt ] ) ? intval( $effective_delays[ $attempt ] ) : 5;
                $jitter_us = mt_rand( 50, 150 ) * 1000;
                usleep( $delay_sec * 1000000 + $jitter_us );
            }
            $attempt++;
        }
        if ( is_array( $last_result ) ) $last_result['retry_exhausted'] = true;
        return $last_result;
    }
}

/**
 * P1 batch helper — loads catalog + templates + slots for multiple SKUs in 3 queries.
 * Caller passes list of SKUs (mixed case), returns map keyed by UPPERCASE SKU.
 * Each entry: { catalog: ARRAY_A|null, template: ARRAY_A|null, slots: array }
 */
if ( ! function_exists( 'dinoco_get_shipping_data_map' ) ) {
    function dinoco_get_shipping_data_map( array $skus ) {
        if ( empty( $skus ) ) return array();
        global $wpdb;

        $normalized = array();
        foreach ( $skus as $s ) {
            if ( ! is_string( $s ) ) continue;
            $u = strtoupper( trim( $s ) );
            if ( $u !== '' ) $normalized[ $u ] = $u;
        }
        if ( empty( $normalized ) ) return array();

        $sku_list = array_values( $normalized );
        $cache_key = 'dinoco_shipping_map_' . md5( implode( ',', $sku_list ) );
        $cached = wp_cache_get( $cache_key, 'dinoco_shipping' );
        if ( $cached !== false ) return $cached;

        // Query 1: catalogs (reuse existing batch helper)
        $catalogs = DINOCO_Catalog::get_by_skus( $sku_list );

        // Query 2: box templates referenced by catalogs
        $template_ids = array();
        foreach ( $catalogs as $row ) {
            if ( ! empty( $row['box_template_id'] ) ) $template_ids[ (int) $row['box_template_id'] ] = (int) $row['box_template_id'];
        }
        $templates = array();
        if ( ! empty( $template_ids ) ) {
            $ids = array_values( $template_ids );
            $ph  = implode( ',', array_fill( 0, count( $ids ), '%d' ) );
            $rows = $wpdb->get_results( $wpdb->prepare(
                "SELECT * FROM {$wpdb->prefix}dinoco_box_templates WHERE id IN ({$ph})",
                $ids
            ), ARRAY_A );
            foreach ( (array) $rows as $r ) {
                $templates[ (int) $r['id'] ] = $r;
            }
        }

        // Query 3: pack slots for all SKUs
        $ph_sku = implode( ',', array_fill( 0, count( $sku_list ), '%s' ) );
        $slot_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM {$wpdb->prefix}dinoco_pack_slots WHERE product_sku IN ({$ph_sku}) ORDER BY product_sku, slot_index",
            $sku_list
        ), ARRAY_A );
        $slots_map = array();
        foreach ( (array) $slot_rows as $r ) {
            $slots_map[ strtoupper( $r['product_sku'] ) ][] = $r;
        }

        // Build final map
        $map = array();
        foreach ( $sku_list as $sku ) {
            $cat = $catalogs[ $sku ] ?? null;
            $tpl = ( $cat && ! empty( $cat['box_template_id'] ) ) ? ( $templates[ (int) $cat['box_template_id'] ] ?? null ) : null;
            $map[ $sku ] = array(
                'catalog'  => $cat,
                'template' => $tpl,
                'slots'    => $slots_map[ $sku ] ?? array(),
            );
        }

        wp_cache_set( $cache_key, $map, 'dinoco_shipping', 300 );
        return $map;
    }
}

/**
 * Smart pack_mode auto-detect (M3) — derive from bpu/upb + hierarchy.
 * Used by migration tool to suggest pack_mode for legacy SKUs.
 */
if ( ! function_exists( 'dinoco_smart_detect_pack_mode' ) ) {
    function dinoco_smart_detect_pack_mode( $sku ) {
        $cat = DINOCO_Catalog::get_by_sku( $sku );
        if ( ! $cat ) return 'auto';

        $bpu = intval( $cat['boxes_per_unit'] ?? 1 );
        $upb = intval( $cat['units_per_box'] ?? 1 );
        $is_leaf = function_exists( 'dinoco_is_leaf_sku' ) ? dinoco_is_leaf_sku( $sku ) : true;
        $has_children = ! $is_leaf;

        if ( $upb > 1 ) return 'bulk_pack';
        if ( $bpu > 1 ) return 'multi_box';  // SET แยกหลายกล่อง or leaf with 1 item split
        if ( $has_children && $bpu === 1 ) return 'assembled_set';  // SET ประกอบแล้ว 1 กล่อง
        if ( $is_leaf && $bpu === 1 ) return 'single_box';
        return 'auto';
    }
}

/**
 * Recursive SET aggregate (C-A3 fix — tare counted once, not per-leaf).
 * Static memo for DD-3 shared leaf (P3). Return content weight only; caller adds parent tare.
 */
/**
 * V.8.2 C-Data-1 FIX: Flush aggregate memo — bumps global version key so existing
 * memo entries become unreachable (cache-busted on next read). Call after any write
 * that affects leaf SKU shipping data within a single request. DINOCO_Catalog::flush_memo()
 * also calls this so catalog mutations invalidate aggregate caches transitively.
 */
if ( ! function_exists( 'dinoco_flush_aggregate_memo' ) ) {
    function dinoco_flush_aggregate_memo() {
        $GLOBALS['__dinoco_agg_memo_v'] = ( isset( $GLOBALS['__dinoco_agg_memo_v'] ) ? intval( $GLOBALS['__dinoco_agg_memo_v'] ) : 0 ) + 1;
    }
}

if ( ! function_exists( 'dinoco_aggregate_children_shipping' ) ) {
    function dinoco_aggregate_children_shipping( $leaves, $parent_sku ) {
        static $memo = array();
        // V.8.2 C-Data-1 FIX: include global version in memo key so dinoco_flush_aggregate_memo()
        // can invalidate stale entries mid-request after catalog mutations.
        $version  = isset( $GLOBALS['__dinoco_agg_memo_v'] ) ? intval( $GLOBALS['__dinoco_agg_memo_v'] ) : 0;
        $memo_key = md5( serialize( $leaves ) . '|' . $parent_sku . '|v' . $version );
        if ( isset( $memo[ $memo_key ] ) ) return $memo[ $memo_key ];

        $total_content_g = 0;
        $max_L = 0; $max_W = 0; $sum_H = 0;
        foreach ( (array) $leaves as $leaf ) {
            $cat = DINOCO_Catalog::get_by_sku( $leaf );
            if ( ! $cat ) continue;
            // content weight only (leaf content, no tare)
            $w = intval( $cat['weight_per_unit_g'] ?? $cat['weight_grams'] ?? 0 );
            $total_content_g += $w;
            // bounding box heuristic: max L, max W, sum H (vertical stacking)
            $max_L = max( $max_L, intval( $cat['length_cm'] ?? 0 ) );
            $max_W = max( $max_W, intval( $cat['width_cm']  ?? 0 ) );
            $sum_H += intval( $cat['height_cm'] ?? 0 );
        }

        $result = array(
            'weight_g'         => $total_content_g,
            'length_cm'        => $max_L,
            'width_cm'         => $max_W,
            'height_cm'        => $sum_H,
            'article_category' => 6,
            'express_category' => dinoco_suggest_express_category(
                $total_content_g,
                array( 'length_cm' => $max_L, 'width_cm' => $max_W, 'height_cm' => $sum_H )
            ),
            'source' => 'aggregated_from_' . count( (array) $leaves ) . '_leaves',
        );
        $memo[ $memo_key ] = $result;
        return $result;
    }
}

/**
 * Core resolver — weight/dims/category for a single PNO (or manifest entry).
 * Priority chain: pack_mode-based resolution → fallback to defaults.
 *
 * @param array $manifest_entry { sku, slot_index?, total_qty?, box_index?, num_boxes? }
 * @param int   $qty_in_box     Qty packed in THIS box (for bulk_pack partial box)
 * @return array { weight_g, length_cm, width_cm, height_cm, article_category, express_category, source }
 */
if ( ! function_exists( 'dinoco_resolve_pno_shipping' ) ) {
    function dinoco_resolve_pno_shipping( $manifest_entry, $qty_in_box = 1 ) {
        $sku = strtoupper( trim( $manifest_entry['sku'] ?? '' ) );
        if ( $sku === '' ) return array_merge( dinoco_shipping_defaults_resolved(), array( 'source' => 'empty_sku' ) );

        $catalog = DINOCO_Catalog::get_by_sku( $sku );
        $defaults = dinoco_shipping_defaults();
        $defaults_resolved = dinoco_shipping_defaults_resolved();

        if ( ! $catalog ) {
            dinoco_log_missing_shipping_data( $sku );
            return array_merge( $defaults_resolved, array( 'source' => 'no_catalog' ) );
        }

        $mode = isset( $catalog['pack_mode'] ) ? $catalog['pack_mode'] : 'auto';

        // Helper: resolve effective dims from template + SKU overrides
        $resolve_dims = function( $tpl, $overrides ) use ( $defaults ) {
            $L = ( isset( $overrides['length_cm_override'] ) && $overrides['length_cm_override'] !== null )
                ? intval( $overrides['length_cm_override'] )
                : ( $tpl ? intval( $tpl['length_cm'] ) : intval( $defaults['length_cm'] ?? 30 ) );
            $W = ( isset( $overrides['width_cm_override'] ) && $overrides['width_cm_override'] !== null )
                ? intval( $overrides['width_cm_override'] )
                : ( $tpl ? intval( $tpl['width_cm'] ) : intval( $defaults['width_cm'] ?? 20 ) );
            $H = ( isset( $overrides['height_cm_override'] ) && $overrides['height_cm_override'] !== null )
                ? intval( $overrides['height_cm_override'] )
                : ( $tpl ? intval( $tpl['height_cm'] ) : intval( $defaults['height_cm'] ?? 10 ) );
            $tare = ( isset( $overrides['tare_weight_override_g'] ) && $overrides['tare_weight_override_g'] !== null )
                ? intval( $overrides['tare_weight_override_g'] )
                : ( $tpl ? intval( $tpl['tare_weight_g'] ) : 0 );
            return array( 'L' => $L, 'W' => $W, 'H' => $H, 'tare' => $tare );
        };

        switch ( $mode ) {
            case 'single_box':
            case 'assembled_set': {
                $tpl = ! empty( $catalog['box_template_id'] ) ? dinoco_get_box_template( $catalog['box_template_id'] ) : null;
                if ( ! $tpl ) {
                    // fall through to plain dims below if no template
                    break;
                }
                $content_weight = intval( $catalog['weight_per_unit_g'] ?? 0 );
                if ( $content_weight === 0 && $mode === 'assembled_set' ) {
                    $content_weight = dinoco_estimate_weight_from_leaves( $sku );
                }
                $d = $resolve_dims( $tpl, $catalog );
                $weight_g = $content_weight + $d['tare'];
                return array(
                    'weight_g'         => $weight_g,
                    'length_cm'        => $d['L'],
                    'width_cm'         => $d['W'],
                    'height_cm'        => $d['H'],
                    'article_category' => intval( $catalog['article_category'] ?? 6 ) ?: 6,
                    'express_category' => ! empty( $catalog['express_category_override'] )
                        ? intval( $catalog['express_category_override'] )
                        : dinoco_suggest_express_category( $weight_g, array( 'length_cm' => $d['L'], 'width_cm' => $d['W'], 'height_cm' => $d['H'] ) ),
                    'source' => "sku_{$mode}_tpl_{$tpl['code']}",
                );
            }

            case 'multi_box': {
                $slot_idx = isset( $manifest_entry['slot_index'] ) ? intval( $manifest_entry['slot_index'] ) : 0;
                $slot = dinoco_get_pack_slot( $sku, $slot_idx );
                if ( ! $slot ) {
                    return array_merge( $defaults_resolved, array( 'source' => "multi_box_slot_{$slot_idx}_missing" ) );
                }
                $tpl = dinoco_get_box_template( $slot['box_template_id'] );
                if ( ! $tpl ) {
                    return array_merge( $defaults_resolved, array( 'source' => "multi_box_slot_{$slot_idx}_no_tpl" ) );
                }
                // C-A4 fix: read slot-level overrides
                $d = $resolve_dims( $tpl, $slot );
                $content = intval( $slot['content_weight_g'] ?? 0 );
                $weight_g = $content + $d['tare'];
                return array(
                    'weight_g'         => $weight_g,
                    'length_cm'        => $d['L'],
                    'width_cm'         => $d['W'],
                    'height_cm'        => $d['H'],
                    'article_category' => intval( $catalog['article_category'] ?? 6 ) ?: 6,
                    'express_category' => ! empty( $catalog['express_category_override'] )
                        ? intval( $catalog['express_category_override'] )
                        : dinoco_suggest_express_category( $weight_g, array( 'length_cm' => $d['L'], 'width_cm' => $d['W'], 'height_cm' => $d['H'] ) ),
                    'source' => "multi_box_slot_{$slot_idx}_tpl_{$tpl['code']}",
                );
            }

            case 'bulk_pack': {
                $tpl = ! empty( $catalog['box_template_id'] ) ? dinoco_get_box_template( $catalog['box_template_id'] ) : null;
                if ( ! $tpl ) break;  // fall through
                // V.8.2 H-D2 FIX: bulk_pack requires explicit weight_per_unit_g.
                // Previous silent 50g default caused massive under-declaration for heavy parts.
                $wpu = intval( $catalog['weight_per_unit_g'] ?? 0 );
                if ( $wpu <= 0 ) {
                    dinoco_log_missing_shipping_data( $sku . ' [bulk_pack missing weight_per_unit_g]' );
                    return array_merge( $defaults_resolved, array( 'source' => 'bulk_pack_weight_missing' ) );
                }
                $qib = max( 1, intval( $qty_in_box ) );
                $d = $resolve_dims( $tpl, $catalog );
                $weight_g = ( $qib * $wpu ) + $d['tare'];
                return array(
                    'weight_g'         => $weight_g,
                    'length_cm'        => $d['L'],
                    'width_cm'         => $d['W'],
                    'height_cm'        => $d['H'],
                    'article_category' => intval( $catalog['article_category'] ?? 6 ) ?: 6,
                    'express_category' => ! empty( $catalog['express_category_override'] )
                        ? intval( $catalog['express_category_override'] )
                        : dinoco_suggest_express_category( $weight_g, array( 'length_cm' => $d['L'], 'width_cm' => $d['W'], 'height_cm' => $d['H'] ) ),
                    'source' => "bulk_pack_qty{$qib}_tpl_{$tpl['code']}",
                );
            }

            case 'unknown': {
                // C-A1 fix: pack_mode=unknown = ad-hoc SKU via manual-ship save-back
                // Use plain dims columns (B1 fix) or fall back to defaults
                $weight_g = intval( $catalog['weight_grams'] ?? 0 ) ?: intval( $defaults['weight_grams'] ?? 1000 );
                $L = intval( $catalog['length_cm'] ?? 0 ) ?: intval( $defaults['length_cm'] ?? 30 );
                $W = intval( $catalog['width_cm']  ?? 0 ) ?: intval( $defaults['width_cm']  ?? 20 );
                $H = intval( $catalog['height_cm'] ?? 0 ) ?: intval( $defaults['height_cm'] ?? 10 );
                return array(
                    'weight_g'         => $weight_g,
                    'length_cm'        => $L,
                    'width_cm'         => $W,
                    'height_cm'        => $H,
                    'article_category' => intval( $catalog['article_category'] ?? 6 ) ?: 6,
                    'express_category' => ! empty( $catalog['express_category_override'] )
                        ? intval( $catalog['express_category_override'] )
                        : dinoco_suggest_express_category( $weight_g, array( 'length_cm' => $L, 'width_cm' => $W, 'height_cm' => $H ) ),
                    'source' => 'plain_dims_unknown_mode',
                );
            }

            case 'auto':
            default:
                // SET → aggregate from leaves; leaf with no pack_mode → defaults + log
                $leaves = function_exists( 'dinoco_get_leaf_skus' ) ? dinoco_get_leaf_skus( $sku ) : array( $sku );
                if ( count( $leaves ) === 1 && $leaves[0] === $sku ) {
                    // leaf with no explicit pack_mode → fall through to plain dims
                    break;
                }
                return dinoco_aggregate_children_shipping( $leaves, $sku );
        }

        // ── Fallback: plain dims columns (B1 fix — when no template or auto-leaf no data)
        $weight_g = intval( $catalog['weight_grams'] ?? 0 );
        $L = intval( $catalog['length_cm'] ?? 0 );
        $W = intval( $catalog['width_cm']  ?? 0 );
        $H = intval( $catalog['height_cm'] ?? 0 );
        if ( $weight_g === 0 && $L === 0 && $W === 0 && $H === 0 ) {
            dinoco_log_missing_shipping_data( $sku );
            return array_merge( $defaults_resolved, array( 'source' => 'defaults_fallback' ) );
        }
        $weight_g = $weight_g ?: intval( $defaults['weight_grams'] ?? 1000 );
        $L = $L ?: intval( $defaults['length_cm'] ?? 30 );
        $W = $W ?: intval( $defaults['width_cm']  ?? 20 );
        $H = $H ?: intval( $defaults['height_cm'] ?? 10 );
        return array(
            'weight_g'         => $weight_g,
            'length_cm'        => $L,
            'width_cm'         => $W,
            'height_cm'        => $H,
            'article_category' => intval( $catalog['article_category'] ?? 6 ) ?: 6,
            'express_category' => ! empty( $catalog['express_category_override'] )
                ? intval( $catalog['express_category_override'] )
                : dinoco_suggest_express_category( $weight_g, array( 'length_cm' => $L, 'width_cm' => $W, 'height_cm' => $H ) ),
            'source' => 'plain_dims_fallback',
        );
    }
}

/**
 * Resolve shipping per manifest entry (per-PNO) for a full ticket manifest.
 * Tracks slot_index per SKU for multi_box, qty_in_box for bulk_pack.
 * Applies ticket-level override (legacy _flash_weight_grams escape hatch per decision #16).
 *
 * @param array $manifest Array of entries { sku, total_qty?, box_index?, num_boxes? }
 * @param int   $ticket_id Optional — for ticket-level override lookup
 * @return array Per-index map: [ 0 => { weight_g, L, W, H, article_cat, express_cat, source }, ... ]
 */
if ( ! function_exists( 'dinoco_resolve_manifest_shipping' ) ) {
    function dinoco_resolve_manifest_shipping( $manifest, $ticket_id = 0 ) {
        $per_pno = array();
        $sku_counter = array();
        $sku_remaining = array();  // for bulk_pack

        foreach ( (array) $manifest as $i => $entry ) {
            $sku = strtoupper( trim( $entry['sku'] ?? '' ) );
            if ( $sku === '' ) {
                $per_pno[ $i ] = array_merge( dinoco_shipping_defaults_resolved(), array( 'source' => 'empty_sku' ) );
                continue;
            }
            // track slot_index for multi_box
            $sku_counter[ $sku ] = ( $sku_counter[ $sku ] ?? -1 ) + 1;
            $entry['slot_index'] = $sku_counter[ $sku ];

            // bulk_pack: compute qty_in_this_box
            $qty_in_box = 1;
            $cat = DINOCO_Catalog::get_by_sku( $sku );
            if ( $cat && ( $cat['pack_mode'] ?? '' ) === 'bulk_pack' ) {
                $upb = intval( $cat['units_per_box'] ?? 1 );
                $total_qty = intval( $entry['total_qty'] ?? $upb );
                $remaining = $sku_remaining[ $sku ] ?? $total_qty;
                $qty_in_box = $upb > 0 ? min( $upb, $remaining ) : $total_qty;
                $sku_remaining[ $sku ] = $remaining - $qty_in_box;
            }

            $per_pno[ $i ] = dinoco_resolve_pno_shipping( $entry, $qty_in_box );
        }

        // Ticket-level legacy override (decision #16: keep as escape hatch)
        // V.8.2 C-Data-3 FIX: _flash_weight_grams is TOTAL weight, not per-PNO.
        // Divide evenly across PNOs (floor division + remainder to first PNO) to prevent
        // 10x overbilling on multi-box orders (e.g. 5000g override on 10 PNOs should be
        // 500g/PNO = 5kg total, NOT 5000g × 10 = 50kg declared).
        if ( $ticket_id ) {
            $override_weight = get_post_meta( $ticket_id, '_flash_weight_grams', true );
            $override_ec     = get_post_meta( $ticket_id, '_flash_express_category', true );

            if ( $override_weight !== '' && $override_weight !== null && ! empty( $per_pno ) ) {
                $ow             = intval( $override_weight );
                $pno_count      = count( $per_pno );
                $per_pno_weight = intval( $ow / $pno_count );
                // R3 FIX: Flash rejects 0g parcels. Enforce 100g minimum per PNO.
                // If override too small to distribute, scale total up to ensure all
                // PNOs get >= 100g (admin's override was clearly wrong — log + clamp).
                $MIN_PNO_WEIGHT = 100;
                if ( $per_pno_weight < $MIN_PNO_WEIGHT ) {
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( sprintf(
                            '[V42] _flash_weight_grams=%d too small for %d PNOs (each=%dg < %dg min). Clamped to %dg/PNO.',
                            $ow, $pno_count, $per_pno_weight, $MIN_PNO_WEIGHT, $MIN_PNO_WEIGHT
                        ), 'warn' );
                    }
                    $per_pno_weight = $MIN_PNO_WEIGHT;
                    $remainder      = 0;  // no remainder when we clamped up
                } else {
                    // Floor division — leftover grams added to first PNO for integrity
                    $remainder = $ow - ( $per_pno_weight * $pno_count );
                }
                $first_key = array_key_first( $per_pno );
                foreach ( $per_pno as $key => &$p ) {
                    $p['weight_g'] = $per_pno_weight + ( $key === $first_key ? $remainder : 0 );
                    $p['source']   = ( isset( $p['source'] ) ? $p['source'] : 'unknown' ) . '_weight_overridden';
                }
                unset( $p );
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( sprintf(
                        '[V42] _flash_weight_grams=%d override applied as TOTAL, divided %d ways = %dg/PNO (ticket #%d)',
                        $ow, $pno_count, $per_pno_weight, $ticket_id
                    ), 'info' );
                }
            }
            if ( $override_ec !== '' && $override_ec !== null ) {
                $oe = intval( $override_ec );
                foreach ( $per_pno as &$p ) $p['express_category'] = $oe;
                unset( $p );
            }
        }

        return $per_pno;
    }
}

/**
 * M1 snapshot — immutable ticket-level snapshot at confirm_bill.
 * Prevents edge cases E1/E2/E5 (admin flip flag/pack_mode mid-order, BO fulfill race).
 */
if ( ! function_exists( 'dinoco_snapshot_ticket_shipping' ) ) {
    function dinoco_snapshot_ticket_shipping( $ticket_id, $manifest ) {
        $ticket_id = absint( $ticket_id );
        if ( ! $ticket_id ) return null;
        $per_pno = dinoco_resolve_manifest_shipping( $manifest, $ticket_id );
        update_post_meta( $ticket_id, '_flash_shipping_snapshot', array(
            'version'       => '42.0',
            'snapshotted_at'=> current_time( 'mysql' ),
            'flag_state'    => (bool) get_option( 'dinoco_shipping_meta_enabled', '0' ),
            'per_pno'       => $per_pno,
            // M-11 FIX: use wp_json_encode (stable across PHP versions + order-independent
            // for associative arrays) instead of serialize() which embeds class names.
            'manifest_hash' => md5( (string) wp_json_encode( $manifest ) ),
        ) );
        return $per_pno;
    }
}

/**
 * Read ticket snapshot (if exists) — returns null if never snapshotted.
 */
if ( ! function_exists( 'dinoco_get_ticket_shipping_snapshot' ) ) {
    function dinoco_get_ticket_shipping_snapshot( $ticket_id ) {
        $snap = get_post_meta( absint( $ticket_id ), '_flash_shipping_snapshot', true );
        return is_array( $snap ) ? $snap : null;
    }
}

/**
 * Convenience: get single SKU shipping (for UI display, REST response).
 */
if ( ! function_exists( 'dinoco_get_sku_shipping' ) ) {
    function dinoco_get_sku_shipping( $sku ) {
        return dinoco_resolve_pno_shipping( array( 'sku' => $sku ) );
    }
}

/**
 * Compute total shipping for a SET (expand leaves × qty).
 */
if ( ! function_exists( 'dinoco_compute_set_shipping' ) ) {
    function dinoco_compute_set_shipping( $sku, $qty = 1 ) {
        $qty = max( 1, intval( $qty ) );
        $shipping = dinoco_resolve_pno_shipping( array( 'sku' => $sku ) );
        // scale by qty for bulk_pack or multi-unit orders
        if ( $qty > 1 ) {
            $shipping['weight_g'] = intval( $shipping['weight_g'] ) * $qty;
        }
        return $shipping;
    }
}

/**
 * Compute shipping for an order (list of {sku, qty}).
 */
if ( ! function_exists( 'dinoco_compute_order_shipping' ) ) {
    function dinoco_compute_order_shipping( $items ) {
        $manifest = array();
        foreach ( (array) $items as $it ) {
            $manifest[] = array(
                'sku'       => $it['sku'] ?? '',
                'total_qty' => intval( $it['qty'] ?? 1 ),
            );
        }
        return dinoco_resolve_manifest_shipping( $manifest );
    }
}

