/**
 * สร้างตาราง dinoco_moto_brands + dinoco_moto_models
 */
add_action( 'init', function() {
    $db_version = '1.0';
    if ( get_option( '_dinoco_moto_table_version' ) === $db_version ) return;

    global $wpdb;
    $charset = $wpdb->get_charset_collate();
    $t_brands = $wpdb->prefix . 'dinoco_moto_brands';
    $t_models = $wpdb->prefix . 'dinoco_moto_models';

    $sql_brands = "CREATE TABLE IF NOT EXISTS {$t_brands} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        slug VARCHAR(50) NOT NULL,
        name VARCHAR(100) NOT NULL,
        logo_url VARCHAR(500) DEFAULT '',
        sort_order INT DEFAULT 0,
        is_active TINYINT(1) DEFAULT 1,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY idx_slug (slug),
        KEY idx_active_sort (is_active, sort_order)
    ) {$charset};";

    $sql_models = "CREATE TABLE IF NOT EXISTS {$t_models} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        brand_slug VARCHAR(50) NOT NULL,
        slug VARCHAR(100) NOT NULL,
        name VARCHAR(200) NOT NULL,
        image_url VARCHAR(500) DEFAULT '',
        aliases TEXT DEFAULT '',
        sort_order INT DEFAULT 0,
        is_active TINYINT(1) DEFAULT 1,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY idx_slug (slug),
        KEY idx_brand_sort (brand_slug, sort_order),
        KEY idx_active (is_active)
    ) {$charset};";

    require_once ABSPATH . 'wp-admin/includes/upgrade.php';
    dbDelta( $sql_brands );
    dbDelta( $sql_models );
    update_option( '_dinoco_moto_table_version', $db_version );
    if ( function_exists('b2b_log') ) b2b_log( '[DB] Created moto catalog tables v' . $db_version );
}, 5 );


if ( ! class_exists( 'DINOCO_MotoDB' ) ) {

class DINOCO_MotoDB {

    private static $brands_cache = null;
    private static $models_cache = [];

    private static function t_brands() { global $wpdb; return $wpdb->prefix . 'dinoco_moto_brands'; }
    private static function t_models() { global $wpdb; return $wpdb->prefix . 'dinoco_moto_models'; }

    // ─── BRANDS ─────────────────────────────────

    public static function get_brands( $active_only = true ) {
        if ( self::$brands_cache !== null && $active_only ) return self::$brands_cache;
        global $wpdb;
        $where = $active_only ? "WHERE is_active = 1" : "";
        $result = $wpdb->get_results( "SELECT * FROM " . self::t_brands() . " {$where} ORDER BY sort_order, name", ARRAY_A ) ?: [];
        if ( $active_only ) self::$brands_cache = $result;
        return $result;
    }

    public static function get_brands_list() { return array_column( self::get_brands(), 'name' ); }

    public static function get_brand_logos() {
        $map = [];
        foreach ( self::get_brands() as $b ) { if ( !empty($b['logo_url']) ) $map[$b['name']] = $b['logo_url']; }
        return $map;
    }

    public static function get_brand_by_slug( $slug ) {
        global $wpdb;
        return $wpdb->get_row( $wpdb->prepare( "SELECT * FROM " . self::t_brands() . " WHERE slug = %s", $slug ), ARRAY_A );
    }

    public static function upsert_brand( $data ) {
        global $wpdb;
        $slug = sanitize_title( $data['slug'] ?? $data['name'] ?? '' );
        if ( empty($slug) ) return false;
        $data['slug'] = $slug;
        if ( isset($data['logo_url']) ) $data['logo_url'] = esc_url_raw( $data['logo_url'] );
        $existing = self::get_brand_by_slug( $slug );
        if ( $existing ) {
            unset($data['created_at']);
            $wpdb->update( self::t_brands(), $data, ['slug' => $slug] );
        } else {
            $wpdb->insert( self::t_brands(), $data );
        }
        self::$brands_cache = null;
        return $existing ? (int)$existing['id'] : (int)$wpdb->insert_id;
    }

    public static function delete_brand( $slug ) {
        global $wpdb;
        $count = self::count_users_by_brand( $slug );
        if ( $count > 0 ) return new WP_Error( 'has_users', "มี {$count} สมาชิกใช้ brand นี้" );
        $wpdb->update( self::t_brands(), ['is_active' => 0], ['slug' => $slug] );
        $wpdb->update( self::t_models(), ['is_active' => 0], ['brand_slug' => $slug] );
        self::$brands_cache = null;
        self::$models_cache = [];
        return true;
    }

    // ─── MODELS ─────────────────────────────────

    public static function get_models( $brand_slug, $active_only = true ) {
        $ck = $brand_slug . ($active_only ? '_a' : '_all');
        if ( isset(self::$models_cache[$ck]) ) return self::$models_cache[$ck];
        global $wpdb;
        $where = $wpdb->prepare( "WHERE brand_slug = %s", $brand_slug );
        if ( $active_only ) $where .= " AND is_active = 1";
        $rows = $wpdb->get_results( "SELECT * FROM " . self::t_models() . " {$where} ORDER BY sort_order, name", ARRAY_A ) ?: [];
        foreach ( $rows as &$m ) { $m['aliases_arr'] = !empty($m['aliases']) ? json_decode($m['aliases'], true) : []; }
        self::$models_cache[$ck] = $rows;
        return $rows;
    }

    public static function get_models_list( $brand_slug ) { return array_column( self::get_models($brand_slug), 'name' ); }

    public static function get_model_by_slug( $slug ) {
        global $wpdb;
        return $wpdb->get_row( $wpdb->prepare( "SELECT * FROM " . self::t_models() . " WHERE slug = %s", $slug ), ARRAY_A );
    }

    /** หารูปรถ (fuzzy match) — fallback: model → brand logo → default */
    public static function get_model_image( $model_name, $brand_name = '' ) {
        if ( empty($model_name) ) return self::default_image();
        global $wpdb;
        $clean = strtolower( trim($model_name) );
        // Exact
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT image_url, brand_slug FROM " . self::t_models() . " WHERE LOWER(name) = %s AND is_active = 1 LIMIT 1", $clean
        ), ARRAY_A );
        if ( $row && !empty($row['image_url']) ) return $row['image_url'];
        // Partial/alias
        $like = '%' . $wpdb->esc_like($clean) . '%';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT image_url, brand_slug FROM " . self::t_models() . " WHERE (LOWER(name) LIKE %s OR aliases LIKE %s) AND is_active = 1 LIMIT 1", $like, $like
        ), ARRAY_A );
        if ( $row && !empty($row['image_url']) ) return $row['image_url'];
        // Brand logo
        if ( !empty($brand_name) ) {
            $b = self::get_brand_by_slug( sanitize_title($brand_name) );
            if ( $b && !empty($b['logo_url']) ) return $b['logo_url'];
        }
        return self::default_image();
    }

    private static function default_image() {
        return 'https://www.dinoco.in.th/wp-content/uploads/elementor/thumbs/800x800-pxou1gkonhphkw4peesozhjgbqhvyueyia1k904zxk.png';
    }

    public static function upsert_model( $data ) {
        global $wpdb;
        $slug = sanitize_title( $data['slug'] ?? $data['name'] ?? '' );
        if ( empty($slug) || empty($data['brand_slug']) ) return false;
        $data['slug'] = $slug;
        if ( isset($data['image_url']) ) $data['image_url'] = esc_url_raw( $data['image_url'] );
        if ( isset($data['aliases']) && is_string($data['aliases']) && !empty($data['aliases']) ) {
            if ( json_decode($data['aliases'], true) === null && json_last_error() !== JSON_ERROR_NONE ) {
                return new WP_Error( 'invalid_aliases', 'Aliases ต้องเป็น JSON array' );
            }
        }
        $existing = self::get_model_by_slug( $slug );
        if ( $existing ) {
            unset($data['created_at']);
            $wpdb->update( self::t_models(), $data, ['slug' => $slug] );
        } else {
            $wpdb->insert( self::t_models(), $data );
        }
        self::$models_cache = [];
        wp_cache_delete('dinoco_moto_ai_aliases');
        wp_cache_delete('dinoco_moto_catalog_json');
        return $existing ? (int)$existing['id'] : (int)$wpdb->insert_id;
    }

    public static function delete_model( $slug ) {
        global $wpdb;
        $wpdb->update( self::t_models(), ['is_active' => 0], ['slug' => $slug] );
        self::$models_cache = [];
        wp_cache_delete('dinoco_moto_ai_aliases');
        wp_cache_delete('dinoco_moto_catalog_json');
        return true;
    }

    // ─── AI ALIASES ─────────────────────────────

    public static function get_ai_aliases() {
        $cached = wp_cache_get('dinoco_moto_ai_aliases');
        if ( $cached !== false ) return $cached;
        global $wpdb;
        $rows = $wpdb->get_results( "SELECT slug, name, aliases FROM " . self::t_models() . " WHERE is_active = 1", ARRAY_A ) ?: [];
        $map = [];
        foreach ( $rows as $r ) {
            $key = str_replace('-', '', $r['slug']);
            $aliases = !empty($r['aliases']) ? json_decode($r['aliases'], true) : [];
            $map[$key] = array_unique( array_merge( [$key, strtolower($r['name'])], $aliases ?: [] ) );
        }
        wp_cache_set('dinoco_moto_ai_aliases', $map, '', 3600);
        return $map;
    }

    // ─── FULL CATALOG JSON (client-side filtering) ───

    public static function get_full_catalog_json() {
        $cached = wp_cache_get('dinoco_moto_catalog_json');
        if ( $cached !== false ) return $cached;
        $catalog = [];
        foreach ( self::get_brands() as $b ) {
            $models = [];
            foreach ( self::get_models($b['slug']) as $m ) {
                $models[] = ['slug'=>$m['slug'], 'name'=>$m['name'], 'image'=>$m['image_url']];
            }
            $catalog[$b['slug']] = ['name'=>$b['name'], 'logo'=>$b['logo_url'], 'models'=>$models];
        }
        wp_cache_set('dinoco_moto_catalog_json', $catalog, '', 3600);
        return $catalog;
    }

    // ─── HELPERS ────────────────────────────────

    public static function get_year_range() {
        return get_option('dinoco_moto_year_range', ['min'=>2010, 'max'=>(int)wp_date('Y')+1]);
    }
    public static function set_year_range( $min, $max ) {
        update_option('dinoco_moto_year_range', ['min'=>(int)$min, 'max'=>(int)$max]);
    }
    public static function count_users_by_brand( $brand_slug ) {
        $b = self::get_brand_by_slug($brand_slug);
        if (!$b) return 0;
        return count(get_users(['meta_key'=>'user_moto_brand','meta_value'=>$b['name'],'number'=>9999,'fields'=>'ID']));
    }
    public static function count_users_by_model( $model_name ) {
        return count(get_users(['meta_key'=>'user_moto_model','meta_value'=>$model_name,'number'=>9999,'fields'=>'ID']));
    }

