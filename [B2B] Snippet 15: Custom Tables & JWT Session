/**
 * สร้างตาราง dinoco_moto_brands + dinoco_moto_models
 */
add_action( 'init', function() {
    $db_version = '1.0';
    if ( get_option( '_dinoco_moto_table_version' ) === $db_version ) return;

    global $wpdb;
    $charset = $wpdb->get_charset_collate();
    $t_brands = $wpdb->prefix . 'dinoco_moto_brands';
    $t_models = $wpdb->prefix . 'dinoco_moto_models';

    $sql_brands = "CREATE TABLE {$t_brands} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        slug VARCHAR(50) NOT NULL,
        name VARCHAR(100) NOT NULL,
        logo_url VARCHAR(500) DEFAULT '',
