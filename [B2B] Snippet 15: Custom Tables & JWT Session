/**
 * Transfer stock between warehouses (atomic)
 */
if ( ! function_exists( 'dinoco_transfer_stock' ) ) {
    function dinoco_transfer_stock( $sku, $from_wh, $to_wh, $qty, $reason = '' ) {
        if ( $qty <= 0 ) return new WP_Error( 'invalid_qty', 'จำนวนต้องมากกว่า 0' );
        if ( $from_wh == $to_wh ) return new WP_Error( 'same_warehouse', 'คลังต้นทางและปลายทางเหมือนกัน' );

        global $wpdb;
        $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
        $sku       = strtoupper( trim( $sku ) );
        $batch_id  = 'TRF-' . wp_generate_uuid4();

        $wpdb->query( 'START TRANSACTION' );

        $source = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, stock_qty FROM {$whs_table} WHERE sku = %s AND warehouse_id = %d FOR UPDATE",
            $sku, $from_wh
        ) );

        if ( ! $source || (int) $source->stock_qty < $qty ) {
            $wpdb->query( 'ROLLBACK' );
            $avail = $source ? (int) $source->stock_qty : 0;
            return new WP_Error( 'insufficient_stock', "สต็อกไม่พอ (มี {$avail}, ต้องการ {$qty})" );
        }

        $old_src = (int) $source->stock_qty;
        $new_src = $old_src - $qty;
        $wpdb->update( $whs_table, array( 'stock_qty' => $new_src ), array( 'id' => $source->id ) );

        $dest = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, stock_qty FROM {$whs_table} WHERE sku = %s AND warehouse_id = %d FOR UPDATE",
            $sku, $to_wh
        ) );

        if ( $dest ) {
            $old_dst = (int) $dest->stock_qty;
            $new_dst = $old_dst + $qty;
            $wpdb->update( $whs_table, array( 'stock_qty' => $new_dst ), array( 'id' => $dest->id ) );
        } else {
            $old_dst = 0;
            $new_dst = $qty;
            $wpdb->insert( $whs_table, array(
                'warehouse_id' => $to_wh,
                'sku'          => $sku,
                'stock_qty'    => $new_dst,
            ) );
        }

        $wpdb->insert( $txn_table, array(
            'sku' => $sku, 'type' => 'transfer_out', 'qty_change' => -1 * abs( $qty ),
            'qty_before' => $old_src, 'qty_after' => $new_src,
            'reason' => $reason ?: 'โอนสต็อกระหว่างคลัง',
            'user_id' => get_current_user_id() ?: null, 'batch_id' => $batch_id,
            'warehouse_id' => $from_wh, 'created_at' => current_time( 'mysql' ),
        ) );

        $wpdb->insert( $txn_table, array(
            'sku' => $sku, 'type' => 'transfer_in', 'qty_change' => abs( $qty ),
            'qty_before' => $old_dst, 'qty_after' => $new_dst,
            'reason' => $reason ?: 'โอนสต็อกระหว่างคลัง',
            'user_id' => get_current_user_id() ?: null, 'batch_id' => $batch_id,
            'warehouse_id' => $to_wh, 'created_at' => current_time( 'mysql' ),
        ) );

        $wpdb->query( 'COMMIT' );

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] TRANSFER %s qty=%d wh:%d->%d batch=%s', $sku, $qty, $from_wh, $to_wh, $batch_id ) );
        }

        return array( 'sku' => $sku, 'qty' => $qty, 'from_wh' => $from_wh, 'to_wh' => $to_wh, 'batch_id' => $batch_id );
    }
}

/**
 * Get all warehouses (active only by default)
 */
if ( ! function_exists( 'dinoco_get_warehouses' ) ) {
    function dinoco_get_warehouses( $active_only = true ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_warehouses';

        $exists = $wpdb->get_var( "SHOW TABLES LIKE '{$table}'" );
        if ( ! $exists ) return array();

        $where = $active_only ? 'WHERE is_active = 1' : '';
        return $wpdb->get_results( "SELECT * FROM {$table} {$where} ORDER BY is_default DESC, name ASC", ARRAY_A ) ?: array();
    }
}

// ════════════════════════════════════════════════════════════
// PART 1.46: INVENTORY VALUATION (V.5.0 — Phase 5 Task 5.4)
// ════════════════════════════════════════════════════════════

/**
 * Get inventory valuation — ดึงต้นทุนจากหลายแหล่ง:
 * 1. WAC จาก B2F receive transactions (unit_cost_thb)
 * 2. Fallback: B2F maker_product (mp_unit_cost × exchange_rate)
 * 3. ถ้าไม่มีเลย → cost = 0
 */
if ( ! function_exists( 'dinoco_get_inventory_valuation' ) ) {
    function dinoco_get_inventory_valuation() {
        global $wpdb;
        $p_table   = $wpdb->prefix . 'dinoco_products';
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';

        // Source 1: WAC จาก B2F receive transactions
        $txn_exists = (bool) $wpdb->get_var( "SHOW TABLES LIKE '{$txn_table}'" );
        $costs = array();
        if ( $txn_exists ) {
            $has_cost_col = (bool) $wpdb->get_var( "SHOW COLUMNS FROM {$txn_table} LIKE 'unit_cost_thb'" );
            if ( $has_cost_col ) {
                $costs = $wpdb->get_results(
                    "SELECT sku,
                            SUM(unit_cost_thb * qty_change) / NULLIF(SUM(qty_change), 0) AS avg_cost,
                            SUM(qty_change) AS total_received
                     FROM {$txn_table}
                     WHERE type = 'b2f_receive'
                       AND qty_change > 0
                       AND unit_cost_thb IS NOT NULL
                       AND unit_cost_thb > 0
                     GROUP BY sku",
                    OBJECT_K
                ) ?: array();
            }
        }

        // Source 2: Fallback — B2F maker_product (mp_unit_cost × exchange_rate → THB)
        $b2f_costs = array();
        $b2f_cost_all = array(); // เก็บทุกราคาก่อนเฉลี่ย

        // Pre-load: Maker → currency + exchange rate ล่าสุดจาก PO
        $maker_rates = array();
        $makers = get_posts( array( 'post_type' => 'b2f_maker', 'posts_per_page' => -1, 'post_status' => 'publish', 'fields' => 'ids' ) );
        foreach ( $makers as $mid ) {
            $cur = get_field( 'maker_currency', $mid ) ?: 'THB';
            $rate = 1.0;
            if ( $cur !== 'THB' ) {
                $latest = $wpdb->get_var( $wpdb->prepare(
                    "SELECT pm.meta_value FROM {$wpdb->posts} p
                     JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'po_exchange_rate'
                     JOIN {$wpdb->postmeta} pm2 ON p.ID = pm2.post_id AND pm2.meta_key = 'po_maker_id' AND pm2.meta_value = %s
                     WHERE p.post_type = 'b2f_order' AND p.post_status = 'publish'
                     ORDER BY p.post_date DESC LIMIT 1",
                    $mid
                ) );
                $rate = $latest ? floatval( $latest ) : 1.0;
                if ( $rate <= 0 ) $rate = 1.0;
            }
            $maker_rates[ $mid ] = array( 'currency' => $cur, 'rate' => $rate );
        }

        $mp_posts = get_posts( array(
            'post_type' => 'b2f_maker_product',
            'posts_per_page' => -1,
            'post_status' => 'publish',
            'fields' => 'ids',
        ) );
        foreach ( $mp_posts as $mp_id ) {
            $mp_sku  = get_field( 'mp_product_sku', $mp_id );
            $mp_cost = floatval( get_field( 'mp_unit_cost', $mp_id ) ?: 0 );
            if ( ! $mp_sku || $mp_cost <= 0 ) continue;

            // แปลงเป็น THB ด้วย exchange rate ล่าสุดของ Maker
            $maker_id = intval( get_field( 'mp_maker_id', $mp_id ) ?: 0 );
            $rate = isset( $maker_rates[ $maker_id ] ) ? $maker_rates[ $maker_id ]['rate'] : 1.0;
            $cost_thb = round( $mp_cost * $rate, 2 );

            // หลาย maker → เก็บทั้งหมดแล้วเฉลี่ย
            if ( ! isset( $b2f_cost_all[ $mp_sku ] ) ) $b2f_cost_all[ $mp_sku ] = array();
            $b2f_cost_all[ $mp_sku ][] = $cost_thb;
        }
        // คำนวณเฉลี่ยถ้ามีหลาย Maker per SKU
        foreach ( $b2f_cost_all as $sku => $prices ) {
            $b2f_costs[ $sku ] = round( array_sum( $prices ) / count( $prices ), 2 );
        }

        // SET (แม่) relations
        $relations = get_option( 'dinoco_sku_relations', [] );

        $products = $wpdb->get_results(
            "SELECT sku, name, stock_qty, image_url FROM {$p_table} WHERE is_active = 1 ORDER BY name ASC",
            ARRAY_A
        );

        $result      = array();
        $total_value = 0;
        $costed      = 0;

        foreach ( $products as $p ) {
            $sku  = $p['sku'];
            $is_set = isset( $relations[ $sku ] ) && ! empty( $relations[ $sku ] );

            // SET (แม่): stock = MIN(children) — ไม่นับ stock ของตัวเอง
            if ( $is_set ) {
                $min_child = PHP_INT_MAX;
                foreach ( $relations[ $sku ] as $c ) {
                    $cq = $wpdb->get_var( $wpdb->prepare( "SELECT stock_qty FROM {$p_table} WHERE sku = %s AND is_active = 1", $c ) );
                    $cq = $cq !== null ? (int) $cq : 0;
                    if ( $cq < $min_child ) $min_child = $cq;
                }
                $qty = $min_child === PHP_INT_MAX ? 0 : $min_child;
            } else {
                $qty = (int) $p['stock_qty'];
            }

            // ต้นทุน: WAC > B2F maker_product > 0
            $cost = 0;
            $cost_source = 'none';
            if ( isset( $costs[ $sku ] ) && (float) $costs[ $sku ]->avg_cost > 0 ) {
                $cost = round( (float) $costs[ $sku ]->avg_cost, 2 );
                $cost_source = 'wac';
            } elseif ( isset( $b2f_costs[ $sku ] ) ) {
                $cost = round( $b2f_costs[ $sku ], 2 );
                $cost_source = 'b2f_maker';
            }
            $val = round( $cost * $qty, 2 );

            if ( $cost > 0 ) $costed++;
            $total_value += $val;

            $result[] = array(
                'sku'         => $sku,
                'name'        => $p['name'],
                'image_url'   => $p['image_url'] ?? '',
                'stock_qty'   => $qty,
                'avg_cost'    => $cost,
                'cost_source' => $cost_source,
                'total_value' => $val,
                'is_set'      => $is_set,
            );
        }

        return array(
            'items'       => $result,
            'total_value' => round( $total_value, 2 ),
            'total_skus'  => count( $result ),
            'costed_skus' => $costed,
        );
    }
}

// ════════════════════════════════════════════════════════════
// PART 1.47: STOCK FORECASTING (V.5.0 — Phase 5 Task 5.5)
// ════════════════════════════════════════════════════════════

/**
 * Forecast stock for a single SKU
 */
if ( ! function_exists( 'dinoco_get_stock_forecast' ) ) {
    function dinoco_get_stock_forecast( $sku, $days = 30 ) {
        global $wpdb;
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
        $p_table   = $wpdb->prefix . 'dinoco_products';
        $sku       = strtoupper( trim( $sku ) );

        $cutoff = wp_date( 'Y-m-d H:i:s', time() - ( $days * DAY_IN_SECONDS ) ); // WARN-06: Asia/Bangkok

        $first_txn = $wpdb->get_var( $wpdb->prepare(
            "SELECT MIN(created_at) FROM {$txn_table} WHERE sku = %s AND type IN ('b2b_reserved','b2b_shipped','manual_subtract')", $sku
        ) );

        $has_enough_data = false;
        if ( $first_txn ) {
            $data_days = (int) ( ( time() - strtotime( $first_txn ) ) / DAY_IN_SECONDS );
            $has_enough_data = ( $data_days >= $days );
        }

        $total_out = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COALESCE(SUM(ABS(qty_change)), 0) FROM {$txn_table}
             WHERE sku = %s AND type IN ('b2b_reserved','b2b_shipped','manual_subtract') AND created_at >= %s",
            $sku, $cutoff
        ) );

        $avg_daily = $days > 0 ? round( $total_out / $days, 2 ) : 0;

        $stock_qty = (int) $wpdb->get_var( $wpdb->prepare( "SELECT stock_qty FROM {$p_table} WHERE sku = %s", $sku ) );

        $product = $wpdb->get_row( $wpdb->prepare(
            "SELECT name, reorder_point, bo_eta_buffer_days FROM {$p_table} WHERE sku = %s", $sku
        ) );

        $lead_time_days = $product ? max( 1, (int) $product->bo_eta_buffer_days ) : 7;

        $days_of_stock   = $avg_daily > 0 ? round( $stock_qty / $avg_daily, 1 ) : null;
        $reorder_in_days = $days_of_stock !== null ? round( $days_of_stock - $lead_time_days, 1 ) : null;
        $suggested_qty   = $avg_daily > 0 ? (int) ceil( $avg_daily * 30 ) : 0;

        return array(
            'sku'                 => $sku,
            'name'                => $product ? $product->name : '',
            'stock_qty'           => $stock_qty,
            'avg_daily_usage'     => $avg_daily,
            'days_of_stock'       => $days_of_stock,
            'reorder_in_days'     => $reorder_in_days,
            'lead_time_days'      => $lead_time_days,
            'suggested_order_qty' => $suggested_qty,
            'has_enough_data'     => $has_enough_data,
            'period_days'         => $days,
            'total_out'           => $total_out,
        );
    }
}

/**
 * Forecast all active SKUs, sorted by days_of_stock ASC (most urgent first)
 */
if ( ! function_exists( 'dinoco_get_stock_forecast_all' ) ) {
    function dinoco_get_stock_forecast_all( $days = 30, $limit = 50 ) {
        global $wpdb;
        $p_table = $wpdb->prefix . 'dinoco_products';

        $skus = $wpdb->get_col( "SELECT sku FROM {$p_table} WHERE is_active = 1 AND stock_qty > 0 ORDER BY name ASC" );

        $forecasts = array();
        foreach ( $skus as $sku ) {
            $f = dinoco_get_stock_forecast( $sku, $days );
            if ( $f['avg_daily_usage'] > 0 ) {
                $forecasts[] = $f;
            }
        }

        usort( $forecasts, function( $a, $b ) {
            $ad = $a['days_of_stock'] ?? PHP_INT_MAX;
            $bd = $b['days_of_stock'] ?? PHP_INT_MAX;
            return $ad <=> $bd;
        } );

        return array_slice( $forecasts, 0, $limit );
    }
}

// ════════════════════════════════════════════════════════════
// PART 1.5: LOW STOCK ALERT CRON (V.4.0 — Inventory Phase 2+4)
// ════════════════════════════════════════════════════════════

/**
 * Daily cron: สรุปสินค้าใกล้หมด + หมดสต็อก → push LINE Admin Group
 * Hook: dinoco_stock_low_alert_cron
 * Schedule: daily
 * Guard: transient ป้องกันส่งซ้ำ (TTL 20 ชม.)
 */
add_action( 'init', function () {
    if ( ! wp_next_scheduled( 'dinoco_stock_low_alert_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_stock_low_alert_cron' );
    }
} );

add_action( 'dinoco_stock_low_alert_cron', 'dinoco_run_stock_low_alert' );

if ( ! function_exists( 'dinoco_run_stock_low_alert' ) ) {
    function dinoco_run_stock_low_alert() {
        // Guard: ไม่ส่งซ้ำภายใน 20 ชม.
        if ( get_transient( 'dinoco_stock_alert_sent_today' ) ) return;

        // Guard: ต้อง initialized
        if ( ! get_option( 'dinoco_inv_initialized', false ) ) return;

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';

        // Query low stock: qty > 0 AND qty <= threshold AND not held
        $low_items = $wpdb->get_results(
            "SELECT sku, name, stock_qty, low_stock_threshold
             FROM {$table}
             WHERE is_active = 1
               AND manual_hold = 0
               AND stock_qty > 0
               AND low_stock_threshold > 0
               AND stock_qty <= low_stock_threshold
             ORDER BY stock_qty ASC
             LIMIT 50"
        );

        // Query out of stock: qty = 0 AND not held
        $oos_items = $wpdb->get_results(
            "SELECT sku, name, stock_qty
             FROM {$table}
             WHERE is_active = 1
               AND manual_hold = 0
               AND stock_qty = 0
             ORDER BY name ASC
             LIMIT 50"
        );

        // Phase 4: Reorder Point Alert — query SKU ที่ available_qty <= reorder_point
        $reorder_items = array();
        $all_active = $wpdb->get_results(
            "SELECT sku, name, stock_qty, reorder_point
             FROM {$table}
             WHERE is_active = 1
               AND manual_hold = 0
               AND reorder_point > 0
               AND stock_qty > 0
             ORDER BY stock_qty ASC
             LIMIT 50"
        );
        foreach ( $all_active as $item ) {
            $available = max( 0, (int) $item->stock_qty - ( function_exists( 'dinoco_get_reserved_qty' ) ? dinoco_get_reserved_qty( $item->sku ) : 0 ) );
            if ( $available <= (int) $item->reorder_point ) {
                $reorder_items[] = $item;
                $item->_available = $available;
            }
        }

        if ( empty( $low_items ) && empty( $oos_items ) && empty( $reorder_items ) ) return; // ไม่มีอะไรต้องแจ้ง

        $lines = array();

        if ( ! empty( $low_items ) ) {
            $lines[] = "สต็อกใกล้หมด (" . count( $low_items ) . " รายการ):";
            foreach ( $low_items as $item ) {
                $lines[] = "- " . $item->sku . " " . $item->name . ": เหลือ " . $item->stock_qty . " ชิ้น";
            }
        }

        if ( ! empty( $oos_items ) ) {
            if ( ! empty( $lines ) ) $lines[] = "";
            $lines[] = "หมดสต็อก (" . count( $oos_items ) . " รายการ):";
            foreach ( $oos_items as $item ) {
                $lines[] = "- " . $item->sku . " " . $item->name . ": 0 ชิ้น";
            }
        }

        // Phase 4: Reorder point section
        if ( ! empty( $reorder_items ) ) {
            if ( ! empty( $lines ) ) $lines[] = "";
            $lines[] = "ควรสั่งผลิตเพิ่ม (" . count( $reorder_items ) . " รายการ):";
            foreach ( $reorder_items as $item ) {
                $avail = isset( $item->_available ) ? $item->_available : (int) $item->stock_qty;
                $lines[] = "- " . $item->sku . " " . $item->name . ": เหลือ " . $avail . " ชิ้น (reorder: " . $item->reorder_point . ")";
            }
        }

        $message = implode( "\n", $lines );

        // Push to Admin LINE Group
        if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2b_line_push' ) ) {
            b2b_line_push( B2B_ADMIN_GROUP_ID, $message );
        }

        // ป้องกันส่งซ้ำ 20 ชม.
        set_transient( 'dinoco_stock_alert_sent_today', 1, 20 * HOUR_IN_SECONDS );
    }
}

