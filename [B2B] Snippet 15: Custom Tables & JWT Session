/**
 * Cron 1: Reminder — ทุก 30 วันหลังนับครั้งล่าสุด → LINE push "ถึงรอบนับสต็อก"
 * Cron 2: Expire — session in_progress > 48 ชม. → auto set expired
 */
add_action( 'init', function () {
    if ( ! wp_next_scheduled( 'dinoco_dip_stock_reminder_cron' ) ) {
        wp_schedule_event( time(), 'daily', 'dinoco_dip_stock_reminder_cron' );
    }
    if ( ! wp_next_scheduled( 'dinoco_dip_stock_expire_cron' ) ) {
        wp_schedule_event( time(), 'twicedaily', 'dinoco_dip_stock_expire_cron' );
    }
} );

// Cron 1: Reminder
add_action( 'dinoco_dip_stock_reminder_cron', function () {
    if ( ! get_option( 'dinoco_inv_initialized', false ) ) return;

    $interval = (int) get_option( 'dinoco_stock_dip_interval', 30 );
    if ( $interval <= 0 ) $interval = 30;

    global $wpdb;
    $dip_table = $wpdb->prefix . 'dinoco_dip_stock';

    // หา session สำเร็จครั้งล่าสุด
    $last = $wpdb->get_var( "SELECT MAX(session_date) FROM {$dip_table} WHERE status = 'completed'" );

    $should_remind = false;
    if ( ! $last ) {
        // ยังไม่เคยนับเลย → remind
        $should_remind = true;
    } else {
        $days_ago = (int) ( ( time() - strtotime( $last ) ) / DAY_IN_SECONDS );
        if ( $days_ago >= $interval ) {
            $should_remind = true;
        }
    }

    if ( ! $should_remind ) return;

    // Guard ไม่ส่งซ้ำภายใน 24 ชม.
    if ( get_transient( 'dinoco_dip_stock_reminder_sent' ) ) return;

    $msg = "ถึงรอบนับสต็อก (Dip Stock)\n";
    if ( $last ) {
        $msg .= "นับล่าสุด: " . wp_date( 'd/m/Y', strtotime( $last ) ) . " (" . $days_ago . " วันที่แล้ว)\n";
    } else {
        $msg .= "ยังไม่เคยนับสต็อก\n";
    }
    $msg .= "กรุณาเข้าหน้า Inventory > นับสต็อก เพื่อเริ่มนับ";

    if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2b_line_push' ) ) {
        b2b_line_push( B2B_ADMIN_GROUP_ID, $msg );
    }

    set_transient( 'dinoco_dip_stock_reminder_sent', 1, 24 * HOUR_IN_SECONDS );
} );

// Cron 2: Expire stuck sessions (> 48 ชม.)
add_action( 'dinoco_dip_stock_expire_cron', function () {
    global $wpdb;
    $dip_table = $wpdb->prefix . 'dinoco_dip_stock';

    $cutoff = gmdate( 'Y-m-d H:i:s', time() - ( 48 * HOUR_IN_SECONDS ) );

    $expired = $wpdb->query( $wpdb->prepare(
        "UPDATE {$dip_table} SET status = 'expired', updated_at = %s WHERE status = 'in_progress' AND created_at < %s",
        current_time( 'mysql' ),
        $cutoff
    ) );

    if ( $expired > 0 && function_exists( 'b2b_log' ) ) {
        b2b_log( "[DipStock] Auto-expired {$expired} stuck sessions (>48h)" );

        // แจ้ง Admin
        if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2b_line_push' ) ) {
            b2b_line_push( B2B_ADMIN_GROUP_ID, "Dip Stock: มี {$expired} session หมดอายุอัตโนมัติ (เกิน 48 ชม.)" );
        }
    }
} );

// ════════════════════════════════════════════
// PART 2: JWT-LIKE SESSION TOKENS (HMAC-based)
// ════════════════════════════════════════════

/**
 * ไม่ต้อง composer / ไม่ต้องลง library
 * ใช้ HMAC-SHA256 + base64 สร้าง token เอง
 * Token = base64(payload) . '.' . hmac(payload, secret)
 */
if ( ! class_exists( 'DINOCO_JWT' ) ) {

class DINOCO_JWT {

    private static function secret() {
        return defined( 'B2B_LINE_CHANNEL_SECRET' ) ? B2B_LINE_CHANNEL_SECRET : AUTH_SALT;
    }

    /**
     * สร้าง session token
     *
     * @param array $payload  Data to encode (e.g. ['dist_id'=>123, 'group_id'=>'Cxxx'])
     * @param int   $ttl      Time-to-live in seconds (default 1 hour)
     * @return string          Token string
     */
    public static function create( $payload, $ttl = 3600 ) {
        $payload['iat'] = time();
        $payload['exp'] = time() + $ttl;

        $json = json_encode( $payload );
        $b64  = rtrim( base64_encode( $json ), '=' );
        $sig  = hash_hmac( 'sha256', $b64, self::secret() );

        return $b64 . '.' . $sig;
    }

    /**
     * Verify & decode token
     *
     * @param string $token    Token string
     * @return array|false     Payload if valid, false if invalid/expired
     */
    public static function verify( $token ) {
        if ( empty( $token ) || strpos( $token, '.' ) === false ) return false;

        $parts = explode( '.', $token );
        if ( count( $parts ) !== 2 ) return false;

        list( $b64, $sig ) = $parts;
        $expected = hash_hmac( 'sha256', $b64, self::secret() );

        if ( ! hash_equals( $expected, $sig ) ) return false;

        // Pad base64
        $json = base64_decode( $b64 . str_repeat( '=', ( 4 - strlen( $b64 ) % 4 ) % 4 ) );
        $payload = json_decode( $json, true );

        if ( ! $payload || ! isset( $payload['exp'] ) ) return false;
        if ( time() > $payload['exp'] ) return false;

        return $payload;
    }

    /**
     * สร้าง refresh token (longer TTL, stored in DB for revocation)
     */
    public static function create_refresh( $payload, $ttl = 86400 ) {
        $refresh_id = bin2hex( random_bytes( 16 ) );
        $payload['refresh_id'] = $refresh_id;
        $token = self::create( $payload, $ttl );

        // Store in transient for revocation capability
        set_transient( 'b2b_refresh_' . $refresh_id, $payload, $ttl );

        return array( 'token' => $token, 'refresh_id' => $refresh_id );
    }

    /**
     * Revoke a refresh token
     */
    public static function revoke( $refresh_id ) {
        delete_transient( 'b2b_refresh_' . $refresh_id );
    }

    /**
     * Refresh: verify refresh token → issue new access token
     */
    public static function refresh( $refresh_token, $access_ttl = 3600 ) {
        $payload = self::verify( $refresh_token );
        if ( ! $payload || ! isset( $payload['refresh_id'] ) ) return false;

        // Check if revoked
        $stored = get_transient( 'b2b_refresh_' . $payload['refresh_id'] );
        if ( ! $stored ) return false;

        // Issue new access token
        unset( $payload['iat'], $payload['exp'], $payload['refresh_id'] );
        return self::create( $payload, $access_ttl );
    }
}

} // end class_exists DINOCO_JWT

