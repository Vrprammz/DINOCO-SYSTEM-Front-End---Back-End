// ════════════════════════════════════════════════════════════════════
// V.7.7 PERF-M7: private Cache-Control on internal REST namespaces
// ────────────────────────────────────────────────────────────────────
// Private, auth-gated endpoints must NEVER be cached by intermediaries
// (shared proxies, Cloudflare, CDN). Responses often contain per-distributor
// pricing, PII, stock, debt, and session tokens — any cross-user cache
// contamination = privacy/financial-data leak.
//
// Applied only to internal namespaces (WordPress core + public WP REST
// untouched to preserve WP defaults):
//   /wp-json/b2b/v1/          — B2B distributor (LIFF + admin)
//   /wp-json/b2f/v1/          — B2F factory PO
//   /wp-json/liff-ai/v1/      — LIFF AI lead/claim center
//   /wp-json/dinoco-stock/v1/ — Inventory admin
//   /wp-json/dinoco-b2f-audit/v1/ — Migration audit
//
// Header chosen: `private, no-store, max-age=0` + `Pragma: no-cache`
//   - `no-store` = neither client nor intermediaries may store copy
//   - `private`  = belt-and-suspenders for legacy CDNs honoring private-only
//   - Pragma    = HTTP/1.0 back-compat
// ════════════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_rest_private_cache_control' ) ) {
    function dinoco_rest_private_cache_control( $response, $server, $request ) {
        if ( ! ( $response instanceof WP_REST_Response ) ) return $response;
        $route = $request->get_route();
        if ( ! is_string( $route ) || $route === '' ) return $response;
        static $private_ns = array(
            '/b2b/v1/',
            '/b2f/v1/',
            '/liff-ai/v1/',
            '/dinoco-stock/v1/',
            '/dinoco-b2f-audit/v1/',
        );
        foreach ( $private_ns as $ns ) {
            if ( strpos( $route, $ns ) === 0 ) {
                $response->header( 'Cache-Control', 'private, no-store, max-age=0' );
                $response->header( 'Pragma', 'no-cache' );
                break;
            }
        }
        return $response;
    }
    // Priority 99 so it runs after any per-endpoint header writer (e.g. b2f_rest_api_version_header)
    add_filter( 'rest_post_dispatch', 'dinoco_rest_private_cache_control', 99, 3 );
}

