/**
 * คำนวณ available_qty = max(0, stock_qty - reserved_qty)
 */
if ( ! function_exists( 'dinoco_get_available_qty' ) ) {
    function dinoco_get_available_qty( $sku ) {
        $sku = strtoupper( trim( $sku ) );
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $stock_qty = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT stock_qty FROM {$table} WHERE sku = %s", $sku
        ) );
        $reserved = dinoco_get_reserved_qty( $sku );
        return max( 0, $stock_qty - $reserved );
    }
}

/**
 * Stock Conflict Detection (Task 4.3)
 * เรียกหลัง dinoco_stock_subtract() — ตรวจว่า stock_qty < reserved_qty หรือไม่
 * ถ้าใช่ → flag orders + push LINE alert
 */
if ( ! function_exists( 'dinoco_check_stock_conflict' ) ) {
    function dinoco_check_stock_conflict( $sku ) {
        $sku = strtoupper( trim( $sku ) );

        // ล้าง cache เพื่อให้ reserved_qty เป็นปัจจุบัน (V.7.0: bulk map cache)
        delete_transient( 'b2b_reserved_map_bulk' );
        delete_transient( 'dinoco_reserved_' . $sku ); // legacy key cleanup

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $stock_qty = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT stock_qty FROM {$table} WHERE sku = %s", $sku
        ) );

        $reserved_qty = dinoco_get_reserved_qty( $sku );

        if ( $stock_qty >= $reserved_qty ) return; // ไม่มี conflict

        // หา orders ที่ reserve SKU นี้
        $reserve_statuses = array( 'checking_stock', 'awaiting_confirm', 'awaiting_payment', 'paid', 'packed' );
        $relations = get_option( 'dinoco_sku_relations', array() );

        $orders = get_posts( array(
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => array(
                array(
                    'key'     => 'order_status',
                    'value'   => $reserve_statuses,
                    'compare' => 'IN',
                ),
            ),
            'orderby' => 'date',
            'order'   => 'DESC',
        ) );

        $conflict_orders = array();

        foreach ( $orders as $order_id ) {
            $order_text = get_field( 'order_items', $order_id ) ?: '';
            if ( ! preg_match_all( '/\(([A-Za-z0-9_\-]+)\)\s*x(\d+)/i', $order_text, $matches, PREG_SET_ORDER ) ) {
                continue;
            }

            foreach ( $matches as $m ) {
                $item_sku = strtoupper( trim( $m[1] ) );
                $item_qty = intval( $m[2] );
                if ( $item_qty <= 0 ) continue;

                $is_match = false;

                if ( $item_sku === $sku ) {
                    $is_match = true;
                } elseif ( function_exists( 'dinoco_get_leaf_skus' ) ) {
                    // V.6.0 [M-2 FIX]: resolve leaf nodes 3 ระดับ
                    $item_leaves = array_map( 'strtoupper', dinoco_get_leaf_skus( $item_sku, $relations ) );
                    if ( in_array( $sku, $item_leaves, true ) ) {
                        $is_match = true;
                    }
                } elseif ( isset( $relations[ $item_sku ] ) ) {
                    $children = array_map( 'strtoupper', $relations[ $item_sku ] );
                    if ( in_array( $sku, $children, true ) ) {
                        $is_match = true;
                    }
                }

                if ( $is_match ) {
                    update_post_meta( $order_id, '_stock_conflict', 1 );
                    $ticket_no = get_field( 'ticket_number', $order_id ) ?: '#' . $order_id;
                    $dist_name = get_field( 'distributor_name', $order_id ) ?: '-';
                    $conflict_orders[] = "- {$ticket_no} ({$dist_name}) x{$item_qty}";
                    break; // 1 order match ก็พอ
                }
            }
        }

        if ( empty( $conflict_orders ) ) return;

        // Push LINE alert ไป Admin group
        $n = count( $conflict_orders );
        $order_list = implode( "\n", array_slice( $conflict_orders, 0, 10 ) );
        $message = "สต็อก {$sku} ไม่พอ!\n"
                 . "สต็อก: {$stock_qty} ชิ้น แต่มี {$n} order ค้าง (จอง {$reserved_qty})\n"
                 . "{$order_list}\n"
                 . "กรุณาตรวจสอบและยกเลิก/backorder";

        if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2b_line_push' ) ) {
            b2b_line_push( B2B_ADMIN_GROUP_ID, $message );
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] CONFLICT: %s stock=%d reserved=%d orders=%d', $sku, $stock_qty, $reserved_qty, $n ) );
        }
    }
}

