}

/**
 * V.8.5 HIGH-1 FIX: Guarded wrapper around wp_cache_flush_group().
 * wp_cache_flush_group() requires WP 6.1+ + compatible object cache drop-in.
 * Legacy Redis/Memcached plugins lack this method → PHP fatal on call.
 * Fallback: full wp_cache_flush() — heavier but safer than a fatal error.
 * Callers should prefer this helper over direct wp_cache_flush_group().
 */
if ( ! function_exists( 'dinoco_cache_flush_group' ) ) {
    function dinoco_cache_flush_group( $group ) {
        if ( function_exists( 'wp_cache_flush_group' ) ) {
            wp_cache_flush_group( $group );
        } else {
            // Fallback: full flush is heavy but safer than fatal on legacy drop-ins.
            wp_cache_flush();
        }
    }
}

/**
 * V.8.2 H-R6 FIX: Invalidate box template cache — callers (Admin Inventory REST
 * endpoints on soft-delete / edit) should invoke this after mutations so the 3600s
 * cached entry doesn't serve stale data. If $id is null, flushes the entire
 * dinoco_shipping group (covers dinoco_box_tpls_* listing caches too).
 */
if ( ! function_exists( 'dinoco_invalidate_box_template_cache' ) ) {
    function dinoco_invalidate_box_template_cache( $id = null ) {
        if ( $id ) {
            wp_cache_delete( 'dinoco_box_tpl_' . absint( $id ), 'dinoco_shipping' );
        } else {
            // V.8.5 HIGH-1: use guarded helper
            dinoco_cache_flush_group( 'dinoco_shipping' );
        }
        // Always nuke the "all templates" list caches since any per-id mutation affects them.
        wp_cache_delete( 'dinoco_box_tpls_all', 'dinoco_shipping' );
        wp_cache_delete( 'dinoco_box_tpls_distributor', 'dinoco_shipping' );
        wp_cache_delete( 'dinoco_box_tpls_maker', 'dinoco_shipping' );
        wp_cache_delete( 'dinoco_box_tpls_either', 'dinoco_shipping' );
    }
}

