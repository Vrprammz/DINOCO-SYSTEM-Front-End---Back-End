/**
 * สร้างตาราง dinoco_products เมื่อ activate
 * Run ครั้งเดียว — ตรวจ version ก่อนสร้าง
 */
add_action( 'init', function() {
    $db_version = '5.6';
    $current = get_option( '_dinoco_catalog_table_version', '0' );
    if ( version_compare( $current, $db_version, '>=' ) ) return;

    global $wpdb;
    $table = $wpdb->prefix . 'dinoco_products';
    $charset = $wpdb->get_charset_collate();

    // dbDelta: full CREATE TABLE — จะ ADD COLUMN ที่ขาดอัตโนมัติ
    $sql = "CREATE TABLE {$table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        sku VARCHAR(50) NOT NULL,
        name VARCHAR(255) NOT NULL,
        subtitle VARCHAR(255) DEFAULT '',
        category VARCHAR(100) DEFAULT '',
        image_url VARCHAR(500) DEFAULT '',
        base_price DECIMAL(10,2) DEFAULT 0,
        price_silver DECIMAL(10,2) DEFAULT 0,
        price_gold DECIMAL(10,2) DEFAULT 0,
        price_platinum DECIMAL(10,2) DEFAULT 0,
        price_diamond DECIMAL(10,2) DEFAULT 0,
        warranty_years INT DEFAULT 2,
        stock_status ENUM('in_stock','out_of_stock') DEFAULT 'in_stock',
        b2b_discount_percent DECIMAL(5,2) DEFAULT 0,
        boxes_per_unit INT DEFAULT 1,
        min_order_qty INT DEFAULT 1,
        oos_eta_date DATE DEFAULT NULL,
        is_active TINYINT(1) DEFAULT 1,
        b2b_visible TINYINT(1) NOT NULL DEFAULT 1,
        stock_qty INT UNSIGNED NOT NULL DEFAULT 0,
        low_stock_threshold INT UNSIGNED NOT NULL DEFAULT 10,
        reorder_point INT UNSIGNED NOT NULL DEFAULT 5,
        last_dip_stock_date DATE DEFAULT NULL,
        last_dip_stock_qty INT UNSIGNED DEFAULT NULL,
        bo_eta_buffer_days TINYINT UNSIGNED NOT NULL DEFAULT 0,
        bo_eta_override DATE DEFAULT NULL,
        bo_note VARCHAR(255) DEFAULT NULL,
        manual_hold TINYINT(1) NOT NULL DEFAULT 0,
        manual_hold_reason VARCHAR(255) DEFAULT NULL,
        manual_hold_by INT UNSIGNED DEFAULT NULL,
        compatible_models TEXT DEFAULT NULL,
        oos_timestamp INT DEFAULT NULL,
        oos_duration_hours INT DEFAULT NULL,
        stock_updated_at DATETIME DEFAULT NULL,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY idx_sku (sku),
        KEY idx_category (category),
        KEY idx_active_stock (is_active, stock_status, stock_qty)
    ) {$charset};";

    require_once ABSPATH . 'wp-admin/includes/upgrade.php';
    dbDelta( $sql );

    // V.5.5: Explicit ALTER TABLE fallback — dbDelta may skip TEXT DEFAULT NULL + TINYINT columns
    $needed_cols = array(
        'b2b_visible'       => "TINYINT(1) NOT NULL DEFAULT 1 AFTER is_active",
        'compatible_models' => "TEXT DEFAULT NULL AFTER manual_hold_by",
        'oos_timestamp'     => "INT DEFAULT NULL AFTER compatible_models",
        'oos_duration_hours'=> "INT DEFAULT NULL AFTER oos_timestamp",
    );
    foreach ( $needed_cols as $col_name => $col_def ) {
        $col_check = $wpdb->get_var( "SHOW COLUMNS FROM {$table} LIKE '{$col_name}'" );
        if ( ! $col_check ) {
            $wpdb->query( "ALTER TABLE {$table} ADD COLUMN {$col_name} {$col_def}" );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[DB] ALTER TABLE: added {$col_name} to dinoco_products" );
        }
    }

    // Stock transactions table
    $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
    $sql2 = "CREATE TABLE {$txn_table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        sku VARCHAR(50) NOT NULL,
        type VARCHAR(30) NOT NULL,
        qty_change INT NOT NULL,
        qty_before INT UNSIGNED NOT NULL DEFAULT 0,
        qty_after INT UNSIGNED NOT NULL DEFAULT 0,
        reference_type VARCHAR(30) DEFAULT NULL,
        reference_id BIGINT UNSIGNED DEFAULT NULL,
        reason VARCHAR(500) DEFAULT '',
        user_id BIGINT UNSIGNED DEFAULT NULL,
        batch_id VARCHAR(50) DEFAULT NULL,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        KEY idx_sku_created (sku, created_at),
        KEY idx_created (created_at),
        KEY idx_ref (reference_type, reference_id),
        KEY idx_batch (batch_id)
    ) {$charset};";
    dbDelta( $sql2 );

    // Dip Stock sessions table (Phase 3)
    $dip_table = $wpdb->prefix . 'dinoco_dip_stock';
    $sql3 = "CREATE TABLE {$dip_table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        session_date DATE NOT NULL,
        status ENUM('in_progress','completed','expired') DEFAULT 'in_progress',
        started_by BIGINT UNSIGNED DEFAULT NULL,
        completed_at DATETIME DEFAULT NULL,
        total_skus INT UNSIGNED DEFAULT 0,
        counted_skus INT UNSIGNED DEFAULT 0,
        adjusted_skus INT UNSIGNED DEFAULT 0,
        notes TEXT DEFAULT NULL,
        snapshot_at DATETIME DEFAULT NULL,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        KEY idx_status (status),
        KEY idx_date (session_date)
    ) {$charset};";
    dbDelta( $sql3 );

    // Dip Stock items table (Phase 3)
    $dip_items_table = $wpdb->prefix . 'dinoco_dip_stock_items';
    $sql4 = "CREATE TABLE {$dip_items_table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        dip_stock_id BIGINT UNSIGNED NOT NULL,
        sku VARCHAR(50) NOT NULL,
        expected_qty INT UNSIGNED NOT NULL DEFAULT 0,
        actual_qty INT UNSIGNED DEFAULT NULL,
        variance INT DEFAULT NULL,
        variance_pct DECIMAL(5,2) DEFAULT NULL,
        adjusted TINYINT(1) DEFAULT 0,
        note VARCHAR(500) DEFAULT '',
        PRIMARY KEY (id),
        UNIQUE KEY idx_session_sku (dip_stock_id, sku),
        KEY idx_sku (sku)
    ) {$charset};";
    dbDelta( $sql4 );

    // Phase 5: Warehouses table
    $wh_table = $wpdb->prefix . 'dinoco_warehouses';
    $sql5 = "CREATE TABLE {$wh_table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        name VARCHAR(100) NOT NULL,
        code VARCHAR(20) NOT NULL,
        address TEXT DEFAULT NULL,
        is_default TINYINT(1) NOT NULL DEFAULT 0,
        is_active TINYINT(1) NOT NULL DEFAULT 1,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY idx_code (code)
    ) {$charset};";
    dbDelta( $sql5 );

    // Phase 5: Warehouse stock table
    $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
    $sql6 = "CREATE TABLE {$whs_table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        warehouse_id BIGINT UNSIGNED NOT NULL,
        sku VARCHAR(50) NOT NULL,
        stock_qty INT UNSIGNED NOT NULL DEFAULT 0,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY idx_wh_sku (warehouse_id, sku),
        KEY idx_sku (sku)
    ) {$charset};";
    dbDelta( $sql6 );

    // Phase 5: ALTER stock_transactions — add warehouse_id + unit_cost_thb
    $col_check = $wpdb->get_results( "SHOW COLUMNS FROM {$txn_table} LIKE 'warehouse_id'" );
    if ( empty( $col_check ) ) {
        $wpdb->query( "ALTER TABLE {$txn_table} ADD COLUMN warehouse_id BIGINT UNSIGNED DEFAULT NULL AFTER batch_id" );
        $wpdb->query( "ALTER TABLE {$txn_table} ADD KEY idx_warehouse (warehouse_id)" );
    }
    $col_check2 = $wpdb->get_results( "SHOW COLUMNS FROM {$txn_table} LIKE 'unit_cost_thb'" );
    if ( empty( $col_check2 ) ) {
        $wpdb->query( "ALTER TABLE {$txn_table} ADD COLUMN unit_cost_thb DECIMAL(12,2) DEFAULT NULL AFTER warehouse_id" );
    }

    // Phase 5 Migration: create default warehouse + copy stock
    $default_wh = $wpdb->get_var( "SELECT id FROM {$wh_table} WHERE code = 'MAIN' LIMIT 1" );
    if ( ! $default_wh ) {
        $wpdb->insert( $wh_table, array(
            'name'       => 'โกดังหลัก',
            'code'       => 'MAIN',
            'address'    => '',
            'is_default' => 1,
            'is_active'  => 1,
            'created_at' => current_time( 'mysql' ),
        ) );
        $default_wh = $wpdb->insert_id;

        // Copy stock_qty from dinoco_products to warehouse_stock
        $wpdb->query( "INSERT INTO {$whs_table} (warehouse_id, sku, stock_qty, updated_at)
            SELECT {$default_wh}, sku, stock_qty, NOW()
            FROM {$table}
            WHERE is_active = 1 AND stock_qty > 0
            ON DUPLICATE KEY UPDATE stock_qty = VALUES(stock_qty)" );

        if ( function_exists( 'b2b_log' ) ) b2b_log( '[DB] Phase 5: Created default warehouse MAIN (id=' . $default_wh . ') + migrated stock' );
    }

    // Set initialized flag = false (Admin ต้องทำ Dip Stock ก่อน)
    if ( ! get_option( 'dinoco_inv_initialized' ) ) {
        update_option( 'dinoco_inv_initialized', false );
    }

    update_option( '_dinoco_catalog_table_version', $db_version );
    if ( function_exists( 'b2b_log' ) ) b2b_log( '[DB] Updated tables v' . $db_version . ' (Phase 5 + oos_timestamp/oos_duration_hours)' );
}, 5 );

// OOS Migration: ย้าย OOS timer data → manual_hold (DD-2)
add_action('init', function() {
    if (get_option('_dinoco_oos_migrated')) return;

    global $wpdb;
    $table = $wpdb->prefix . 'dinoco_products';

    // ถ้า table ยังไม่มี manual_hold column → skip (dbDelta ยังไม่ run)
    $col = $wpdb->get_var("SHOW COLUMNS FROM {$table} LIKE 'manual_hold'");
    if (!$col) return;

    // หา SKU ที่ OOS + มี duration > 0 จาก b2b_product postmeta
    $oos_products = get_posts(array(
        'post_type' => 'b2b_product',
        'posts_per_page' => -1,
        'meta_query' => array(
            array('key' => 'stock_status', 'value' => 'out_of_stock'),
            array('key' => 'oos_duration_hours', 'value' => '0', 'compare' => '>'),
        ),
        'fields' => 'ids',
    ));

    foreach ($oos_products as $pid) {
        $sku = get_field('product_sku', $pid);
        if (!$sku) continue;

        $eta = get_field('oos_eta_date', $pid);

        // Set manual_hold ใน custom table
        $wpdb->update($table, array(
            'manual_hold' => 1,
            'manual_hold_reason' => 'migrated from OOS timer',
            'stock_status' => 'out_of_stock',
        ), array('sku' => $sku));

        // Copy ETA
        if ($eta) {
            $wpdb->update($table, array('bo_eta_override' => $eta), array('sku' => $sku));
        }
    }

    update_option('_dinoco_oos_migrated', 1);
    if (function_exists('b2b_log')) b2b_log('[Stock] OOS migration complete: ' . count($oos_products) . ' products migrated to manual_hold');
}, 20);

/**
 * Product Catalog CRUD functions
 */
if ( ! class_exists( 'DINOCO_Catalog' ) ) {

class DINOCO_Catalog {

    private static function table() {
        global $wpdb;
        return $wpdb->prefix . 'dinoco_products';
    }

    public static function get_by_sku( $sku ) {
        global $wpdb;
        return $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM " . self::table() . " WHERE sku = %s AND is_active = 1", $sku
        ), ARRAY_A );
    }

    public static function get_all( $category = null, $in_stock_only = false ) {
        global $wpdb;
        $where = "is_active = 1";
        if ( $category ) $where .= $wpdb->prepare( " AND category = %s", $category );
        if ( $in_stock_only ) $where .= " AND stock_status = 'in_stock'";
        return $wpdb->get_results( "SELECT * FROM " . self::table() . " WHERE {$where} ORDER BY category, name", ARRAY_A );
    }

    /**
     * ดึงสินค้าที่แสดงใน B2B (b2b_visible=1 + is_active=1)
     */
    public static function get_all_b2b( $category = null ) {
        global $wpdb;
        $where = "is_active = 1 AND b2b_visible = 1";
        if ( $category ) $where .= $wpdb->prepare( " AND category = %s", $category );
        return $wpdb->get_results( "SELECT * FROM " . self::table() . " WHERE {$where} ORDER BY category, name", ARRAY_A );
    }

    /**
     * Toggle b2b_visible
     */
    public static function set_b2b_visible( $sku, $visible ) {
        global $wpdb;
        return $wpdb->update( self::table(), array( 'b2b_visible' => $visible ? 1 : 0 ), array( 'sku' => $sku ) );
    }

    public static function get_price_for_rank( $sku, $rank ) {
        $product = self::get_by_sku( $sku );
        if ( ! $product ) return 0;
        $rank_key = 'price_' . strtolower( $rank );
        if ( isset( $product[ $rank_key ] ) && floatval( $product[ $rank_key ] ) > 0 ) {
            return floatval( $product[ $rank_key ] );
        }
        return floatval( $product['base_price'] );
    }

    public static function upsert( $data ) {
        global $wpdb;
        $sku = $data['sku'] ?? '';
        if ( empty( $sku ) ) return false;

        // ตรวจ row ที่มี sku นี้ (ไม่ filter is_active — ป้องกัน Duplicate Key)
        $existing = $wpdb->get_row( $wpdb->prepare(
            "SELECT id FROM " . self::table() . " WHERE sku = %s LIMIT 1", $sku
        ), ARRAY_A );

        if ( $existing ) {
            // ถ้ามี row อยู่แล้ว (ไม่ว่า active หรือไม่) → UPDATE + set is_active=1
            $data['is_active'] = 1;
            $wpdb->update( self::table(), $data, array( 'sku' => $sku ) );
            return (int) $existing['id'];
        } else {
            $wpdb->insert( self::table(), $data );
            return $wpdb->insert_id;
        }
    }

    public static function set_stock_status( $sku, $status, $eta = null ) {
        global $wpdb;
        $update = array( 'stock_status' => $status );
        if ( $eta ) $update['oos_eta_date'] = $eta;
        return $wpdb->update( self::table(), $update, array( 'sku' => $sku ) );
    }

    public static function search( $query ) {
        global $wpdb;
        $like = '%' . $wpdb->esc_like( $query ) . '%';
        return $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM " . self::table() . " WHERE is_active = 1 AND (sku LIKE %s OR name LIKE %s) ORDER BY name",
            $like, $like
        ), ARRAY_A );
    }

    /**
     * Migrate จาก wp_options dinoco_product_catalog → custom table
     * Run ครั้งเดียว
     */
    public static function migrate_from_options() {
        if ( get_option( '_dinoco_catalog_migrated' ) ) return;

        $catalog = get_option( 'dinoco_product_catalog', array() );
        if ( empty( $catalog ) ) return;

        $count = 0;
        foreach ( $catalog as $sku => $item ) {
            self::upsert( array(
                'sku'            => $sku,
                'name'           => $item['name'] ?? $sku,
                'subtitle'       => $item['sub'] ?? '',
                'image_url'      => $item['img'] ?? '',
                'base_price'     => floatval( str_replace( ',', '', $item['price'] ?? 0 ) ),
                'warranty_years' => intval( $item['years'] ?? 2 ),
            ) );
            $count++;
        }

        update_option( '_dinoco_catalog_migrated', 1 );
        b2b_log( "[DB] Migrated {$count} products from wp_options to custom table" );
    }
}

} // end class_exists DINOCO_Catalog

// Auto-migrate on first load
add_action( 'init', array( 'DINOCO_Catalog', 'migrate_from_options' ), 10 );

