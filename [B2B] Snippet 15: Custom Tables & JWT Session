/**
 * Get default warehouse ID (the one with is_default=1)
 * Cached per request via static variable.
 */
if ( ! function_exists( 'dinoco_get_default_warehouse_id' ) ) {
    function dinoco_get_default_warehouse_id() {
        static $cached_id = null;
        if ( $cached_id !== null ) return $cached_id;

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_warehouses';

        // Check if table exists (backward compat)
        $exists = $wpdb->get_var( "SHOW TABLES LIKE '{$table}'" );
        if ( ! $exists ) return null;

        $id = $wpdb->get_var( "SELECT id FROM {$table} WHERE is_default = 1 AND is_active = 1 LIMIT 1" );
        $cached_id = $id ? (int) $id : null;
        return $cached_id;
    }
}

/**
 * Get total stock across all warehouses for a SKU
 * Falls back to dinoco_products.stock_qty if warehouse table doesn't exist
 */
if ( ! function_exists( 'dinoco_get_total_stock' ) ) {
    function dinoco_get_total_stock( $sku ) {
        global $wpdb;
        $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
        $sku = strtoupper( trim( $sku ) );

        $exists = $wpdb->get_var( "SHOW TABLES LIKE '{$whs_table}'" );
        if ( ! $exists ) {
            $table = $wpdb->prefix . 'dinoco_products';
            return (int) $wpdb->get_var( $wpdb->prepare( "SELECT stock_qty FROM {$table} WHERE sku = %s", $sku ) );
        }

        return (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COALESCE(SUM(stock_qty), 0) FROM {$whs_table} WHERE sku = %s", $sku
        ) );
    }
}

/**
 * Get stock for a specific warehouse + SKU
 */
