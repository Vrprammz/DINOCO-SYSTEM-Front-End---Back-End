/**
 * Defaults in resolver schema — fallback paths must return this shape, NOT the
 * raw wp_option (which uses plain-dims keys: weight_grams vs weight_g).
 * V.8.1 fix: Phase 1 bug — all fallback array_merge($defaults, ...) sites
 * returned {weight_grams, length_cm, ...} instead of {weight_g, length_cm, ...
 * express_category, article_category} → smoke test multi_box fail.
 */
if ( ! function_exists( 'dinoco_shipping_defaults_resolved' ) ) {
    function dinoco_shipping_defaults_resolved() {
        $d = dinoco_shipping_defaults();
        $weight_g = intval( $d['weight_grams'] ?? 1000 ) ?: 1000;
        $L = intval( $d['length_cm'] ?? 30 ) ?: 30;
        $W = intval( $d['width_cm']  ?? 20 ) ?: 20;
        $H = intval( $d['height_cm'] ?? 10 ) ?: 10;
        $ec = function_exists( 'dinoco_suggest_express_category' )
            ? dinoco_suggest_express_category( $weight_g, array( 'length_cm' => $L, 'width_cm' => $W, 'height_cm' => $H ) )
            : 1;
        return array(
            'weight_g'         => $weight_g,
            'length_cm'        => $L,
            'width_cm'         => $W,
            'height_cm'        => $H,
            'article_category' => intval( $d['article_category'] ?? 6 ) ?: 6,
            'express_category' => $ec,
        );
    }
}

/**
