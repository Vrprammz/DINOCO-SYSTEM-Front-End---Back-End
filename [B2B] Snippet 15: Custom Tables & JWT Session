/**
 * Phase 1 Schema Migration — runs on init priority 7 (after main catalog @ 5,
 * before OOS migration @ 20). Idempotent via _dinoco_shipping_v42_schema_version flag.
 */
add_action( 'init', function() {
    $schema_version = '1.0';  // bump when adding more cols/tables
    $current = get_option( '_dinoco_shipping_v42_schema_version', '0' );
    if ( version_compare( $current, $schema_version, '>=' ) ) return;

    global $wpdb;
    $charset = $wpdb->get_charset_collate();
    require_once ABSPATH . 'wp-admin/includes/upgrade.php';

    // ─────────────────────────────────────────────────────────────
    // 1. wp_dinoco_box_templates — reusable box sizes (S/M/L/XL/AL37)
    // ─────────────────────────────────────────────────────────────
    $tpl_table = $wpdb->prefix . 'dinoco_box_templates';
    $sql_tpl = "CREATE TABLE {$tpl_table} (
        id INT UNSIGNED NOT NULL AUTO_INCREMENT,
        name VARCHAR(100) NOT NULL,
        code VARCHAR(20) NOT NULL,
        length_cm SMALLINT UNSIGNED NOT NULL,
        width_cm SMALLINT UNSIGNED NOT NULL,
        height_cm SMALLINT UNSIGNED NOT NULL,
        tare_weight_g SMALLINT UNSIGNED NOT NULL DEFAULT 0,
        max_weight_g INT UNSIGNED NOT NULL DEFAULT 30000,
        owner_type VARCHAR(20) NOT NULL DEFAULT 'warehouse',
        is_active TINYINT UNSIGNED NOT NULL DEFAULT 1,
        sort_order SMALLINT UNSIGNED NOT NULL DEFAULT 0,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY idx_code (code),
        KEY idx_owner_active (owner_type, is_active)
    ) {$charset};";
    dbDelta( $sql_tpl );

    // ─────────────────────────────────────────────────────────────
    // 2. wp_dinoco_pack_slots — multi_box pack_mode per-slot data
    // ─────────────────────────────────────────────────────────────
    // BLK-2: product_sku = VARCHAR(50) utf8mb4_bin (matches wp_dinoco_products.sku)
    $slots_table = $wpdb->prefix . 'dinoco_pack_slots';
    $sql_slots = "CREATE TABLE {$slots_table} (
        id INT UNSIGNED NOT NULL AUTO_INCREMENT,
        product_sku VARCHAR(50) NOT NULL,
        slot_index TINYINT UNSIGNED NOT NULL,
        slot_label VARCHAR(50) DEFAULT NULL,
        box_template_id INT UNSIGNED NOT NULL,
        content_weight_g INT UNSIGNED DEFAULT NULL,
        length_cm_override SMALLINT UNSIGNED DEFAULT NULL,
        width_cm_override SMALLINT UNSIGNED DEFAULT NULL,
        height_cm_override SMALLINT UNSIGNED DEFAULT NULL,
        tare_weight_override_g SMALLINT UNSIGNED DEFAULT NULL,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY uq_sku_slot (product_sku, slot_index),
        KEY idx_template (box_template_id)
    ) {$charset};";
    dbDelta( $sql_slots );

    // ─────────────────────────────────────────────────────────────
    // 3. wp_dinoco_warehouse_mapping — F4 expressCategory → warehouseNo
    // ─────────────────────────────────────────────────────────────
    $wm_table = $wpdb->prefix . 'dinoco_warehouse_mapping';
    $sql_wm = "CREATE TABLE {$wm_table} (
        id INT UNSIGNED NOT NULL AUTO_INCREMENT,
        express_category TINYINT UNSIGNED NOT NULL,
        warehouse_no VARCHAR(50) NOT NULL,
        is_primary TINYINT UNSIGNED NOT NULL DEFAULT 0,
        is_fallback_to_method1 TINYINT UNSIGNED NOT NULL DEFAULT 0,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        UNIQUE KEY uq_ec_primary (express_category, is_primary)
    ) {$charset};";
    dbDelta( $sql_wm );

    // ─────────────────────────────────────────────────────────────
    // 4. wp_dinoco_flash_audit — F2 audit trail (Flash req/resp + bumps)
    // ─────────────────────────────────────────────────────────────
    // V.8.2 H-D4 FIX: request_summary/response_summary TEXT → MEDIUMTEXT (TEXT max 64KB,
    // MEDIUMTEXT max 16MB) — prevents truncation on large subParcel payloads during
    // incident floods. dbDelta is idempotent for new tables; ALTER migration below
    // upgrades existing TEXT columns on older installs.
    $audit_table = $wpdb->prefix . 'dinoco_flash_audit';
    $sql_audit = "CREATE TABLE {$audit_table} (
        id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
        ticket_id BIGINT UNSIGNED NOT NULL,
        event_type VARCHAR(32) NOT NULL,
        pno_index TINYINT UNSIGNED DEFAULT NULL,
        expected_ec TINYINT UNSIGNED DEFAULT NULL,
        actual_ec TINYINT UNSIGNED DEFAULT NULL,
        request_summary MEDIUMTEXT DEFAULT NULL,
        response_summary MEDIUMTEXT DEFAULT NULL,
        user_id BIGINT UNSIGNED DEFAULT NULL,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (id),
        KEY idx_ticket (ticket_id),
        KEY idx_event_created (event_type, created_at)
    ) {$charset};";
    dbDelta( $sql_audit );

    // V.8.2 H-D4 migration: upgrade existing TEXT columns to MEDIUMTEXT (idempotent —
    // uses SHOW COLUMNS + stripos check; ALTER only runs if not already MEDIUMTEXT).
    if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $audit_table ) ) ) === $audit_table ) {
        $cols = $wpdb->get_results( "SHOW COLUMNS FROM {$audit_table}", OBJECT_K );
        foreach ( array( 'request_summary', 'response_summary' ) as $col_name ) {
            if ( isset( $cols[ $col_name ] ) && stripos( $cols[ $col_name ]->Type, 'mediumtext' ) === false ) {
                $wpdb->query( "ALTER TABLE {$audit_table} MODIFY COLUMN {$col_name} MEDIUMTEXT" );
                if ( function_exists( 'b2b_log' ) ) b2b_log( "[V.8.2] ALTER flash_audit.{$col_name} TEXT → MEDIUMTEXT" );
            }
        }
    }

    // V.8.3 M-1 migration: box_templates.name VARCHAR(50) → VARCHAR(100) — Thai chars
    // at 3 bytes/char utf8mb4 could truncate names like "กล่องกันล้มใหญ่พิเศษสำหรับ NX500".
    $box_tpl_table = $wpdb->prefix . 'dinoco_box_templates';
    if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $box_tpl_table ) ) ) === $box_tpl_table ) {
        $cols = $wpdb->get_results( "SHOW COLUMNS FROM {$box_tpl_table}", OBJECT_K );
        if ( isset( $cols['name'] ) && stripos( $cols['name']->Type, 'varchar(50)' ) !== false ) {
            $wpdb->query( "ALTER TABLE {$box_tpl_table} MODIFY COLUMN name VARCHAR(100) NOT NULL" );
            if ( function_exists( 'b2b_log' ) ) b2b_log( '[V.8.3] ALTER box_templates.name VARCHAR(50) → VARCHAR(100)' );
        }
    }

    // ─────────────────────────────────────────────────────────────
    // 5. wp_dinoco_flash_dead_letter — F7 DLQ for Flash create failures
    // ─────────────────────────────────────────────────────────────
    $dlq_table = $wpdb->prefix . 'dinoco_flash_dead_letter';
    $sql_dlq = "CREATE TABLE {$dlq_table} (
        id INT UNSIGNED NOT NULL AUTO_INCREMENT,
        ticket_id BIGINT UNSIGNED NOT NULL,
        endpoint VARCHAR(64) NOT NULL,
        request_body LONGTEXT NOT NULL,
        last_error_code VARCHAR(32) DEFAULT NULL,
        last_error_message TEXT DEFAULT NULL,
        retry_count TINYINT UNSIGNED NOT NULL DEFAULT 0,
        status VARCHAR(20) NOT NULL DEFAULT 'pending',
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        resolved_at DATETIME DEFAULT NULL,
        resolved_by BIGINT UNSIGNED DEFAULT NULL,
        PRIMARY KEY (id),
        UNIQUE KEY uq_ticket_endpoint (ticket_id, endpoint),
        KEY idx_status_created (status, created_at)
    ) {$charset};";
    dbDelta( $sql_dlq );

    // V.8.4 M-10: verify UNIQUE (ticket_id, endpoint) on flash_dead_letter —
    // Snippet 1 H-C2 fix uses INSERT ON DUPLICATE KEY UPDATE which requires this.
    // Add if missing (idempotent — legacy installs created pre-V.8.0 may lack it).
    $dlq_tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
    if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $dlq_tbl ) ) ) === $dlq_tbl ) {
        $has_unique = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.STATISTICS
             WHERE TABLE_SCHEMA = DATABASE()
             AND TABLE_NAME = %s
             AND INDEX_NAME = 'uq_ticket_endpoint'",
            $wpdb->prefix . 'dinoco_flash_dead_letter'
        ) );
        if ( ! $has_unique ) {
            // Clean any duplicates first to allow unique constraint creation
            $wpdb->query( "
                DELETE t1 FROM {$dlq_tbl} t1
                INNER JOIN {$dlq_tbl} t2
                WHERE t1.id > t2.id
                  AND t1.ticket_id = t2.ticket_id
                  AND t1.endpoint = t2.endpoint
            " );
            // Add unique constraint
            $wpdb->query( "ALTER TABLE {$dlq_tbl} ADD UNIQUE KEY uq_ticket_endpoint (ticket_id, endpoint)" );
            if ( function_exists( 'b2b_log' ) ) b2b_log( '[V.8.4] ALTER flash_dead_letter ADD UNIQUE uq_ticket_endpoint', 'info' );
        }
    }

    // ─────────────────────────────────────────────────────────────
    // 6. ALTER wp_dinoco_products — add 16 shipping columns
    //    (idempotent via SHOW COLUMNS LIKE loop — matches Snippet 15:111-125 pattern)
    // ─────────────────────────────────────────────────────────────
    $products_table = $wpdb->prefix . 'dinoco_products';
    $shipping_cols = array(
        // CORE 6
        'pack_mode'                 => "VARCHAR(24) NOT NULL DEFAULT 'auto'",
        'packaging_source'          => "VARCHAR(20) NOT NULL DEFAULT 'unknown'",
        'box_template_id'           => "INT UNSIGNED NULL",
        'weight_per_unit_g'         => "INT UNSIGNED DEFAULT NULL",
        'article_category'          => "TINYINT UNSIGNED DEFAULT 6",
        'express_category_override' => "TINYINT UNSIGNED DEFAULT NULL",
        // PLAIN DIMS 4 (B1 fix — for SKU without box_template: ad-hoc/unknown/legacy)
        'weight_grams'              => "INT UNSIGNED DEFAULT NULL",
        'length_cm'                 => "SMALLINT UNSIGNED DEFAULT NULL",
        'width_cm'                  => "SMALLINT UNSIGNED DEFAULT NULL",
        'height_cm'                 => "SMALLINT UNSIGNED DEFAULT NULL",
        // TEMPLATE-OVERRIDE 4 (optional — override template per SKU)
        'length_cm_override'        => "SMALLINT UNSIGNED DEFAULT NULL",
        'width_cm_override'         => "SMALLINT UNSIGNED DEFAULT NULL",
        'height_cm_override'        => "SMALLINT UNSIGNED DEFAULT NULL",
        'tare_weight_override_g'    => "SMALLINT UNSIGNED DEFAULT NULL",
        // AUDIT 2 (M8)
        'shipping_updated_by'       => "BIGINT UNSIGNED DEFAULT NULL",
        'shipping_updated_at'       => "DATETIME DEFAULT NULL",
    );
    foreach ( $shipping_cols as $col => $def ) {
        $exists = $wpdb->get_var( "SHOW COLUMNS FROM {$products_table} LIKE '{$col}'" );
        if ( ! $exists ) {
            $wpdb->query( "ALTER TABLE {$products_table} ADD COLUMN {$col} {$def}" );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[Shipping V.8.0] ALTER: added {$col} to dinoco_products" );
        }
    }

    // Index for coverage widget (box_template_id + pack_mode query)
    $idx_exists = $wpdb->get_var( "SHOW INDEX FROM {$products_table} WHERE Key_name = 'idx_shipping_coverage'" );
    if ( ! $idx_exists ) {
        $wpdb->query( "ALTER TABLE {$products_table} ADD INDEX idx_shipping_coverage (box_template_id, pack_mode)" );
    }

    // ─────────────────────────────────────────────────────────────
    // 7. CHECK constraints (MySQL 8.0.16+ only — probe via INFORMATION_SCHEMA)
    //    B4/B5 fix: PHP validator = primary defense. CHECK = defense-in-depth.
    // ─────────────────────────────────────────────────────────────
    $mysql_version = $wpdb->get_var( "SELECT VERSION()" );
    $is_mysql_8016 = ( is_string( $mysql_version ) && version_compare( preg_replace( '/[^0-9.].*/', '', $mysql_version ), '8.0.16', '>=' ) );
    if ( $is_mysql_8016 ) {
        $checks = array(
            'chk_pack_mode'        => "CHECK (pack_mode IN ('auto','single_box','multi_box','bulk_pack','assembled_set'))",
            'chk_packaging_source' => "CHECK (packaging_source IN ('warehouse_packed','factory_packed','unknown'))",
            'chk_express_override' => "CHECK (express_category_override IS NULL OR express_category_override IN (1,4))",
        );
        foreach ( $checks as $name => $clause ) {
            $exists = $wpdb->get_var( $wpdb->prepare(
                "SELECT CONSTRAINT_NAME FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS
                 WHERE TABLE_SCHEMA = %s AND TABLE_NAME = %s AND CONSTRAINT_NAME = %s",
                DB_NAME, $products_table, $name
            ) );
            if ( ! $exists ) {
                @$wpdb->query( "ALTER TABLE {$products_table} ADD CONSTRAINT {$name} {$clause}" );
            }
        }
    }

    // ─────────────────────────────────────────────────────────────
    // 8. Seed box templates (INSERT IGNORE — idempotent)
    // ─────────────────────────────────────────────────────────────
    $seed_flag = get_option( '_dinoco_box_templates_seeded', '0' );
    if ( $seed_flag !== '1' ) {
        $seeds = array(
            array( 'code' => 'S',    'name' => 'กล่องเล็ก S',         'length_cm' => 20, 'width_cm' => 15, 'height_cm' => 10, 'tare_weight_g' =>   50, 'max_weight_g' =>  1000, 'owner_type' => 'warehouse', 'sort_order' => 10 ),
            array( 'code' => 'M',    'name' => 'กล่องกลาง M',         'length_cm' => 30, 'width_cm' => 25, 'height_cm' => 20, 'tare_weight_g' =>  150, 'max_weight_g' =>  3000, 'owner_type' => 'warehouse', 'sort_order' => 20 ),
            array( 'code' => 'L',    'name' => 'กล่องใหญ่ L',         'length_cm' => 50, 'width_cm' => 40, 'height_cm' => 35, 'tare_weight_g' =>  400, 'max_weight_g' => 10000, 'owner_type' => 'warehouse', 'sort_order' => 30 ),
            array( 'code' => 'XL',   'name' => 'กล่องยาว XL',         'length_cm' => 80, 'width_cm' => 20, 'height_cm' => 15, 'tare_weight_g' =>  250, 'max_weight_g' =>  5000, 'owner_type' => 'warehouse', 'sort_order' => 40 ),
            array( 'code' => 'AL37', 'name' => 'กล่องอลูมิเนียม 37L',  'length_cm' => 50, 'width_cm' => 40, 'height_cm' => 30, 'tare_weight_g' => 1500, 'max_weight_g' => 15000, 'owner_type' => 'factory',   'sort_order' => 50 ),
        );
        foreach ( $seeds as $s ) {
            $exists = $wpdb->get_var( $wpdb->prepare( "SELECT id FROM {$tpl_table} WHERE code = %s", $s['code'] ) );
            if ( ! $exists ) {
                $wpdb->insert( $tpl_table, array_merge( $s, array(
                    'is_active'  => 1,
                    'created_at' => current_time( 'mysql' ),
                    'updated_at' => current_time( 'mysql' ),
                ) ) );
            }
        }
        update_option( '_dinoco_box_templates_seeded', '1' );
        if ( function_exists( 'b2b_log' ) ) b2b_log( '[Shipping V.8.0] Seeded 5 box templates (S/M/L/XL/AL37)' );
    }

    // ─────────────────────────────────────────────────────────────
    // 9. Seed warehouse mapping (F4 — Flash Q6-Q8 confirmed routing)
    // ─────────────────────────────────────────────────────────────
    $wm_seed_flag = get_option( '_dinoco_warehouse_mapping_seeded', '0' );
    if ( $wm_seed_flag !== '1' ) {
        $wm_seeds = array(
            array( 'express_category' => 1, 'warehouse_no' => 'BKN_SP-บางเขน',   'is_primary' => 1 ),  // bike
            array( 'express_category' => 4, 'warehouse_no' => '5BKN_PDC-บางเขน', 'is_primary' => 1 ),  // truck
        );
        foreach ( $wm_seeds as $row ) {
            $exists = $wpdb->get_var( $wpdb->prepare(
                "SELECT id FROM {$wm_table} WHERE express_category = %d AND is_primary = %d",
                $row['express_category'], $row['is_primary']
            ) );
            if ( ! $exists ) {
                $wpdb->insert( $wm_table, array_merge( $row, array( 'created_at' => current_time( 'mysql' ) ) ) );
            }
