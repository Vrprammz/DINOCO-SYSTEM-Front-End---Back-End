/**
 * ไม่ต้อง composer / ไม่ต้องลง library
 * ใช้ HMAC-SHA256 + base64 สร้าง token เอง
 * Token = base64(payload) . '.' . hmac(payload, secret)
 */
if ( ! class_exists( 'DINOCO_JWT' ) ) {

class DINOCO_JWT {

    private static function secret() {
        return defined( 'B2B_LINE_CHANNEL_SECRET' ) ? B2B_LINE_CHANNEL_SECRET : AUTH_SALT;
    }

    /**
     * สร้าง session token
     *
     * @param array $payload  Data to encode (e.g. ['dist_id'=>123, 'group_id'=>'Cxxx'])
     * @param int   $ttl      Time-to-live in seconds (default 1 hour)
     * @return string          Token string
     */
    public static function create( $payload, $ttl = 3600 ) {
        $payload['iat'] = time();
        $payload['exp'] = time() + $ttl;

        $json = json_encode( $payload );
        $b64  = rtrim( base64_encode( $json ), '=' );
        $sig  = hash_hmac( 'sha256', $b64, self::secret() );

        return $b64 . '.' . $sig;
    }

    /**
     * Verify & decode token
     *
     * @param string $token    Token string
     * @return array|false     Payload if valid, false if invalid/expired
     */
    public static function verify( $token ) {
        if ( empty( $token ) || strpos( $token, '.' ) === false ) return false;

        $parts = explode( '.', $token );
        if ( count( $parts ) !== 2 ) return false;

        list( $b64, $sig ) = $parts;
        $expected = hash_hmac( 'sha256', $b64, self::secret() );

        if ( ! hash_equals( $expected, $sig ) ) return false;

        // Pad base64
        $json = base64_decode( $b64 . str_repeat( '=', ( 4 - strlen( $b64 ) % 4 ) % 4 ) );
        $payload = json_decode( $json, true );

        if ( ! $payload || ! isset( $payload['exp'] ) ) return false;
        if ( time() > $payload['exp'] ) return false;

        return $payload;
    }

    /**
     * สร้าง refresh token (longer TTL, stored in DB for revocation)
     */
    public static function create_refresh( $payload, $ttl = 86400 ) {
        $refresh_id = bin2hex( random_bytes( 16 ) );
        $payload['refresh_id'] = $refresh_id;
        $token = self::create( $payload, $ttl );

        // Store in transient for revocation capability
        set_transient( 'b2b_refresh_' . $refresh_id, $payload, $ttl );

        return array( 'token' => $token, 'refresh_id' => $refresh_id );
    }

    /**
     * Revoke a refresh token
     */
    public static function revoke( $refresh_id ) {
        delete_transient( 'b2b_refresh_' . $refresh_id );
    }

    /**
     * Refresh: verify refresh token → issue new access token
     */
    public static function refresh( $refresh_token, $access_ttl = 3600 ) {
        $payload = self::verify( $refresh_token );
        if ( ! $payload || ! isset( $payload['refresh_id'] ) ) return false;

        // Check if revoked
        $stored = get_transient( 'b2b_refresh_' . $payload['refresh_id'] );
        if ( ! $stored ) return false;

        // Issue new access token
        unset( $payload['iat'], $payload['exp'], $payload['refresh_id'] );
        return self::create( $payload, $access_ttl );
    }
}

} // end class_exists DINOCO_JWT

