/**
 * Atomic stock operations — FOR UPDATE lock per SKU
 * Pattern เหมือน b2b_debt_add/subtract ที่พิสูจน์แล้ว
 */

if ( ! function_exists( 'dinoco_stock_add' ) ) {
    /**
     * เพิ่มสต็อก (B2F receive, manual add, cancel return)
     */
    function dinoco_stock_add( $sku, $qty, $type = 'manual_add', $ref_type = '', $ref_id = 0, $reason = '', $batch_id = '', $warehouse_id = null, $unit_cost_thb = null ) {
        if ( $qty <= 0 ) return new WP_Error( 'invalid_qty', 'จำนวนต้องมากกว่า 0' );

        global $wpdb;
        $table     = $wpdb->prefix . 'dinoco_products';
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
        $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
        $sku       = strtoupper( trim( $sku ) );

        // Resolve warehouse (default if not specified)
        if ( ! $warehouse_id && function_exists( 'dinoco_get_default_warehouse_id' ) ) {
            $warehouse_id = dinoco_get_default_warehouse_id();
        }

        // CRIT-03: ย้าย SHOW TABLES ออกมาก่อน transaction (ใช้ static cache)
        static $whs_exists_add = null;
        if ( $whs_exists_add === null ) {
            $whs_exists_add = (bool) $wpdb->get_var( "SHOW TABLES LIKE '{$whs_table}'" );
        }

        $wpdb->query( 'START TRANSACTION' );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, stock_qty FROM {$table} WHERE sku = %s FOR UPDATE", $sku
        ) );

        if ( ! $row ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[Stock] WARNING: SKU {$sku} not in catalog, skip add" );
            return new WP_Error( 'sku_not_found', "SKU {$sku} ไม่อยู่ใน catalog" );
        }

        $old_qty = (int) $row->stock_qty;
        $new_qty = $old_qty + (int) $qty;

        $updated = $wpdb->update( $table, array(
            'stock_qty'        => $new_qty,
            'stock_updated_at' => current_time( 'mysql' ),
        ), array( 'sku' => $sku ) );

        $txn_data = array(
            'sku'            => $sku,
            'type'           => $type,
            'qty_change'     => (int) $qty,
            'qty_before'     => $old_qty,
            'qty_after'      => $new_qty,
            'reference_type' => $ref_type ?: null,
            'reference_id'   => $ref_id ?: null,
            'reason'         => $reason,
            'user_id'        => get_current_user_id() ?: null,
            'batch_id'       => $batch_id ?: null,
            'warehouse_id'   => $warehouse_id ?: null,
            'unit_cost_thb'  => $unit_cost_thb !== null ? (float) $unit_cost_thb : null,
        );
        $inserted = $wpdb->insert( $txn_table, $txn_data );

        // Phase 5: Update warehouse_stock (if table exists) — CRIT-02: track wh_ok
        $wh_ok = true;
        if ( $warehouse_id && $whs_exists_add ) {
            $wh_row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, stock_qty FROM {$whs_table} WHERE warehouse_id = %d AND sku = %s FOR UPDATE",
                $warehouse_id, $sku
            ) );
            if ( $wh_row ) {
                $wpdb->update( $whs_table,
                    array( 'stock_qty' => (int) $wh_row->stock_qty + (int) $qty ),
                    array( 'id' => $wh_row->id )
                );
            } else {
                $wpdb->insert( $whs_table, array(
                    'warehouse_id' => $warehouse_id,
                    'sku'          => $sku,
                    'stock_qty'    => (int) $qty,
                ) );
            }
            if ( $wpdb->last_error ) $wh_ok = false;
        }

        if ( $updated === false || $inserted === false || ! $wh_ok ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_Error( 'db_error', 'Stock update failed' );
        }

        $wpdb->query( 'COMMIT' );
        delete_transient( 'b2b_sku_data_map' ); // DD-5: invalidate cache ทุกครั้ง

        // Auto-update stock_status (outside transaction)
        dinoco_stock_auto_status( $sku );

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] ADD %s +%d (%d->%d) type=%s ref=%s:%d wh=%s', $sku, $qty, $old_qty, $new_qty, $type, $ref_type, $ref_id, $warehouse_id ?: 'default' ) );
        }

        return array( 'sku' => $sku, 'old_qty' => $old_qty, 'new_qty' => $new_qty );
    }
}

if ( ! function_exists( 'dinoco_stock_subtract' ) ) {
    /**
     * ลดสต็อก (B2B reserved, manual subtract)
     */
    function dinoco_stock_subtract( $sku, $qty, $type = 'manual_subtract', $ref_type = '', $ref_id = 0, $reason = '', $batch_id = '', $warehouse_id = null ) {
        if ( $qty <= 0 ) return new WP_Error( 'invalid_qty', 'จำนวนต้องมากกว่า 0' );

        global $wpdb;
        $table     = $wpdb->prefix . 'dinoco_products';
        $txn_table = $wpdb->prefix . 'dinoco_stock_transactions';
        $whs_table = $wpdb->prefix . 'dinoco_warehouse_stock';
        $sku       = strtoupper( trim( $sku ) );

        // Resolve warehouse
        if ( ! $warehouse_id && function_exists( 'dinoco_get_default_warehouse_id' ) ) {
            $warehouse_id = dinoco_get_default_warehouse_id();
        }

        // CRIT-03: ย้าย SHOW TABLES ออกมาก่อน transaction (ใช้ static cache)
        static $whs_exists_sub = null;
        if ( $whs_exists_sub === null ) {
            $whs_exists_sub = (bool) $wpdb->get_var( "SHOW TABLES LIKE '{$whs_table}'" );
        }

        $wpdb->query( 'START TRANSACTION' );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, stock_qty FROM {$table} WHERE sku = %s FOR UPDATE", $sku
        ) );

        if ( ! $row ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'b2b_log' ) ) b2b_log( "[Stock] WARNING: SKU {$sku} not in catalog, skip subtract" );
            return new WP_Error( 'sku_not_found', "SKU {$sku} ไม่อยู่ใน catalog" );
        }

        $old_qty = (int) $row->stock_qty;
        $new_qty = max( 0, $old_qty - (int) $qty );

        if ( $old_qty < (int) $qty && function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] WARNING: %s stock=%d < requested=%d, cap at 0', $sku, $old_qty, $qty ) );
        }

        $updated = $wpdb->update( $table, array(
            'stock_qty'        => $new_qty,
            'stock_updated_at' => current_time( 'mysql' ),
        ), array( 'sku' => $sku ) );

        $inserted = $wpdb->insert( $txn_table, array(
            'sku'            => $sku,
            'type'           => $type,
            'qty_change'     => -1 * abs( (int) $qty ),
            'qty_before'     => $old_qty,
            'qty_after'      => $new_qty,
            'reference_type' => $ref_type ?: null,
            'reference_id'   => $ref_id ?: null,
            'reason'         => $reason,
            'user_id'        => get_current_user_id() ?: null,
            'batch_id'       => $batch_id ?: null,
            'warehouse_id'   => $warehouse_id ?: null,
        ) );

        // Phase 5: Update warehouse_stock — CRIT-02: track wh_ok
        $wh_ok = true;
        if ( $warehouse_id && $whs_exists_sub ) {
            $wh_row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, stock_qty FROM {$whs_table} WHERE warehouse_id = %d AND sku = %s FOR UPDATE",
                $warehouse_id, $sku
            ) );
            if ( $wh_row ) {
                $new_wh_qty = max( 0, (int) $wh_row->stock_qty - (int) $qty );
                $wpdb->update( $whs_table, array( 'stock_qty' => $new_wh_qty ), array( 'id' => $wh_row->id ) );
            }
            if ( $wpdb->last_error ) $wh_ok = false;
        }

        if ( $updated === false || $inserted === false || ! $wh_ok ) {
            $wpdb->query( 'ROLLBACK' );
            return new WP_Error( 'db_error', 'Stock update failed' );
        }

        $wpdb->query( 'COMMIT' );
        delete_transient( 'b2b_sku_data_map' ); // DD-5: invalidate cache ทุกครั้ง

        dinoco_stock_auto_status( $sku );

        // Phase 4: Stock conflict detection
        if ( function_exists( 'dinoco_check_stock_conflict' ) ) {
            dinoco_check_stock_conflict( $sku );
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] SUBTRACT %s -%d (%d->%d) type=%s ref=%s:%d wh=%s', $sku, $qty, $old_qty, $new_qty, $type, $ref_type, $ref_id, $warehouse_id ?: 'default' ) );
        }

        return array( 'sku' => $sku, 'old_qty' => $old_qty, 'new_qty' => $new_qty );
    }
}

if ( ! function_exists( 'dinoco_stock_auto_status' ) ) {
    /**
     * Auto-update stock_status ตาม stock_qty + threshold + manual_hold
     * เรียกหลัง add/subtract (outside transaction)
     */
    function dinoco_stock_auto_status( $sku ) {
        // Guard: ยังไม่ initialized → skip (DD-3)
        if ( ! get_option( 'dinoco_inv_initialized', false ) ) return;

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';

        $product = $wpdb->get_row( $wpdb->prepare(
            "SELECT stock_qty, low_stock_threshold, manual_hold FROM {$table} WHERE sku = %s", $sku
        ) );
        if ( ! $product ) return;

        $qty       = (int) $product->stock_qty;
        $threshold = (int) $product->low_stock_threshold;

        // Phase 4: ใช้ available_qty (stock - reserved) แทน stock_qty สำหรับ display
        $reserved  = function_exists( 'dinoco_get_reserved_qty' ) ? dinoco_get_reserved_qty( $sku ) : 0;
        $available = max( 0, $qty - $reserved );

        if ( $available <= 0 ) {
            $new_status = 'out_of_stock';
        } else {
            $new_status = 'in_stock';
        }

        // manual_hold = 1 → force out_of_stock (Admin ล็อกเอง)
        if ( (int) $product->manual_hold ) {
            $new_status = 'out_of_stock';
        }

        $wpdb->update( $table, array(
            'stock_status'     => $new_status,
            'stock_updated_at' => current_time( 'mysql' ),
        ), array( 'sku' => $sku ) );

        // Dual-write: sync to b2b_product CPT postmeta (DD-1)
        $b2b_post = get_posts( array(
            'post_type'      => 'b2b_product',
            'meta_query'     => array( array( 'key' => 'product_sku', 'value' => $sku ) ),
            'posts_per_page' => 1,
            'fields'         => 'ids',
        ) );
        if ( ! empty( $b2b_post ) ) {
            update_field( 'stock_status', $new_status, $b2b_post[0] );
        }

        // Cache invalidation (DD-5)
        delete_transient( 'b2b_sku_data_map' );

        // SET parent update: ถ้า $sku เป็น child ของ SET → update parent status ด้วย
        $relations = get_option( 'dinoco_sku_relations', [] );
        foreach ( $relations as $parent_sku => $children ) {
            if ( in_array( $sku, $children ) ) {
                // คำนวณ parent stock = MIN(children)
                $min_child = PHP_INT_MAX;
                foreach ( $children as $c ) {
                    $cq = $wpdb->get_var( $wpdb->prepare(
                        "SELECT stock_qty FROM {$table} WHERE sku = %s AND is_active = 1", $c
                    ) );
                    $cq = $cq !== null ? (int) $cq : 0;
                    if ( $cq < $min_child ) $min_child = $cq;
                }
                $parent_qty = $min_child === PHP_INT_MAX ? 0 : $min_child;
                $parent_status = $parent_qty > 0 ? 'in_stock' : 'out_of_stock';

                // Update parent stock_status
                $wpdb->update( $table, array(
                    'stock_status'     => $parent_status,
                    'stock_updated_at' => current_time( 'mysql' ),
                ), array( 'sku' => $parent_sku ) );

                // Dual-write parent to ACF
                $parent_b2b = get_posts( array(
                    'post_type' => 'b2b_product',
                    'meta_query' => array( array( 'key' => 'product_sku', 'value' => $parent_sku ) ),
                    'posts_per_page' => 1, 'fields' => 'ids',
                ) );
                if ( ! empty( $parent_b2b ) ) {
                    update_field( 'stock_status', $parent_status, $parent_b2b[0] );
                }
            }
        }
    }
}

if ( ! function_exists( 'dinoco_stock_get' ) ) {
    /**
     * ดึง stock info สำหรับ SKU (admin view)
     */
    function dinoco_stock_get( $sku ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $sku   = strtoupper( trim( $sku ) );
        $row   = $wpdb->get_row( $wpdb->prepare(
            "SELECT sku, name, stock_qty, stock_status, low_stock_threshold, reorder_point,
                    manual_hold, manual_hold_reason, bo_eta_override, bo_eta_buffer_days, bo_note, stock_updated_at
             FROM {$table} WHERE sku = %s", $sku
        ), ARRAY_A );
        if ( ! $row ) return null;

        // SET (แม่): stock = MIN(children stock) — ไม่ใช้ stock_qty ของตัวเอง
        $relations = get_option( 'dinoco_sku_relations', [] );
        $is_set = isset( $relations[ $sku ] ) && ! empty( $relations[ $sku ] );
        $row['is_set'] = $is_set;

        if ( $is_set ) {
            $children = $relations[ $sku ];
            $min_child_stock = PHP_INT_MAX;
            foreach ( $children as $child_sku ) {
                $child = $wpdb->get_var( $wpdb->prepare(
                    "SELECT stock_qty FROM {$table} WHERE sku = %s AND is_active = 1", $child_sku
                ) );
                $child_stock = $child !== null ? (int) $child : 0;
                if ( $child_stock < $min_child_stock ) $min_child_stock = $child_stock;
            }
            if ( $min_child_stock === PHP_INT_MAX ) $min_child_stock = 0;
            $row['stock_qty'] = $min_child_stock; // override กับค่าที่คำนวณ
            $row['stock_qty_source'] = 'computed_from_children';
        }

        // Phase 4: compute reserved_qty + available_qty
        $reserved = function_exists( 'dinoco_get_reserved_qty' ) ? dinoco_get_reserved_qty( $sku ) : 0;
        $available = max( 0, (int) $row['stock_qty'] - $reserved );
        $row['reserved_qty']  = $reserved;
        $row['available_qty'] = $available;

        // Compute stock_display ใช้ available_qty (Phase 4)
        $threshold = (int) $row['low_stock_threshold'];
        if ( (int) $row['manual_hold'] || $available <= 0 ) {
            $row['stock_display'] = 'out_of_stock';
        } elseif ( $threshold > 0 && $available <= $threshold ) {
            $row['stock_display'] = 'low_stock';
        } else {
            $row['stock_display'] = 'in_stock';
        }

        return $row;
    }
}

// ════════════════════════════════════════════════════════════
// PART 1.4: RESERVED QTY + AVAILABLE QTY + CONFLICT (V.4.0 — Phase 4)
// ════════════════════════════════════════════════════════════

/**
 * คำนวณ reserved_qty สำหรับ SKU (computed — ไม่เก็บ field แยก)
 * Query จาก b2b_order ที่ status IN (checking_stock, awaiting_confirm, awaiting_payment, paid, packed)
 * Parse order_items text ด้วย regex เพื่อหา SKU + qty
 * SKU Set: ถ้า SKU เป็น child → หา parent ที่มี child ตรง → sum
 * Cache ด้วย transient 60 วินาที (PO-3)
 */
if ( ! function_exists( 'dinoco_get_reserved_qty' ) ) {
    function dinoco_get_reserved_qty( $sku ) {
        $sku = strtoupper( trim( $sku ) );
        $cache_key = 'dinoco_reserved_' . $sku;
        $cached = get_transient( $cache_key );
        if ( $cached !== false ) return (int) $cached;

        $reserve_statuses = array( 'checking_stock', 'awaiting_confirm', 'awaiting_payment', 'paid', 'packed' );
        $relations = get_option( 'dinoco_sku_relations', array() );

        // สร้าง list ของ SKU ที่ต้อง match: ตัวเอง + parent ที่มี child = ตัวเอง
        $match_skus = array( $sku ); // direct match
        foreach ( $relations as $parent_sku => $children ) {
            if ( is_array( $children ) && in_array( $sku, array_map( 'strtoupper', $children ), true ) ) {
                $match_skus[] = strtoupper( $parent_sku );
            }
        }
        $match_skus = array_unique( $match_skus );

        // Query all active orders with reserve statuses
        $orders = get_posts( array(
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => array(
                array(
                    'key'     => 'order_status',
                    'value'   => $reserve_statuses,
                    'compare' => 'IN',
                ),
            ),
        ) );

        $total_reserved = 0;

        foreach ( $orders as $order_id ) {
            $order_text = get_field( 'order_items', $order_id ) ?: '';
            if ( ! preg_match_all( '/\(([A-Za-z0-9_\-]+)\)\s*x(\d+)/i', $order_text, $matches, PREG_SET_ORDER ) ) {
                continue;
            }

            foreach ( $matches as $m ) {
                $item_sku = strtoupper( trim( $m[1] ) );
                $item_qty = intval( $m[2] );
                if ( $item_qty <= 0 ) continue;

                // Direct SKU match
                if ( $item_sku === $sku ) {
                    $total_reserved += $item_qty;
                    continue;
                }

                // ถ้า item_sku เป็น parent set ที่มี child = $sku → reserved
                if ( in_array( $item_sku, $match_skus, true ) && isset( $relations[ $item_sku ] ) ) {
                    $children = array_map( 'strtoupper', $relations[ $item_sku ] );
                    if ( in_array( $sku, $children, true ) ) {
                        $total_reserved += $item_qty;
                    }
                }
            }
        }

        set_transient( $cache_key, $total_reserved, 60 ); // cache 1 นาที
        return $total_reserved;
    }
}

/**
 * คำนวณ available_qty = max(0, stock_qty - reserved_qty)
 */
if ( ! function_exists( 'dinoco_get_available_qty' ) ) {
    function dinoco_get_available_qty( $sku ) {
        $sku = strtoupper( trim( $sku ) );
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $stock_qty = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT stock_qty FROM {$table} WHERE sku = %s", $sku
        ) );
        $reserved = dinoco_get_reserved_qty( $sku );
        return max( 0, $stock_qty - $reserved );
    }
}

/**
 * Stock Conflict Detection (Task 4.3)
 * เรียกหลัง dinoco_stock_subtract() — ตรวจว่า stock_qty < reserved_qty หรือไม่
 * ถ้าใช่ → flag orders + push LINE alert
 */
if ( ! function_exists( 'dinoco_check_stock_conflict' ) ) {
    function dinoco_check_stock_conflict( $sku ) {
        $sku = strtoupper( trim( $sku ) );

        // ล้าง cache เพื่อให้ reserved_qty เป็นปัจจุบัน
        delete_transient( 'dinoco_reserved_' . $sku );

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_products';
        $stock_qty = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT stock_qty FROM {$table} WHERE sku = %s", $sku
        ) );

        $reserved_qty = dinoco_get_reserved_qty( $sku );

        if ( $stock_qty >= $reserved_qty ) return; // ไม่มี conflict

        // หา orders ที่ reserve SKU นี้
        $reserve_statuses = array( 'checking_stock', 'awaiting_confirm', 'awaiting_payment', 'paid', 'packed' );
        $relations = get_option( 'dinoco_sku_relations', array() );

        $orders = get_posts( array(
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => array(
                array(
                    'key'     => 'order_status',
                    'value'   => $reserve_statuses,
                    'compare' => 'IN',
                ),
            ),
            'orderby' => 'date',
            'order'   => 'DESC',
        ) );

        $conflict_orders = array();

        foreach ( $orders as $order_id ) {
            $order_text = get_field( 'order_items', $order_id ) ?: '';
            if ( ! preg_match_all( '/\(([A-Za-z0-9_\-]+)\)\s*x(\d+)/i', $order_text, $matches, PREG_SET_ORDER ) ) {
                continue;
            }

            foreach ( $matches as $m ) {
                $item_sku = strtoupper( trim( $m[1] ) );
                $item_qty = intval( $m[2] );
                if ( $item_qty <= 0 ) continue;

                $is_match = false;

                if ( $item_sku === $sku ) {
                    $is_match = true;
                } elseif ( isset( $relations[ $item_sku ] ) ) {
                    $children = array_map( 'strtoupper', $relations[ $item_sku ] );
                    if ( in_array( $sku, $children, true ) ) {
                        $is_match = true;
                    }
                }

                if ( $is_match ) {
                    update_post_meta( $order_id, '_stock_conflict', 1 );
                    $ticket_no = get_field( 'ticket_number', $order_id ) ?: '#' . $order_id;
                    $dist_name = get_field( 'distributor_name', $order_id ) ?: '-';
                    $conflict_orders[] = "- {$ticket_no} ({$dist_name}) x{$item_qty}";
                    break; // 1 order match ก็พอ
                }
            }
        }

        if ( empty( $conflict_orders ) ) return;

        // Push LINE alert ไป Admin group
        $n = count( $conflict_orders );
        $order_list = implode( "\n", array_slice( $conflict_orders, 0, 10 ) );
        $message = "สต็อก {$sku} ไม่พอ!\n"
                 . "สต็อก: {$stock_qty} ชิ้น แต่มี {$n} order ค้าง (จอง {$reserved_qty})\n"
                 . "{$order_list}\n"
                 . "กรุณาตรวจสอบและยกเลิก/backorder";

        if ( defined( 'B2B_ADMIN_GROUP_ID' ) && function_exists( 'b2b_line_push' ) ) {
            b2b_line_push( B2B_ADMIN_GROUP_ID, $message );
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( sprintf( '[Stock] CONFLICT: %s stock=%d reserved=%d orders=%d', $sku, $stock_qty, $reserved_qty, $n ) );
        }
    }
}

