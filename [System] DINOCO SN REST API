if ( ! function_exists( 'dinoco_sn_get_extension_price' ) ) {
    /**
     * Get extension price for SKU + duration (Q8 per-SKU manual pricing).
     *
     * @param string $sku
     * @param int    $years 1|2|3
     * @return float|null Price THB inc-VAT, or null if SKU doesn't offer that option
     */
    function dinoco_sn_get_extension_price( $sku, $years ) {
        if ( ! in_array( (int) $years, array( 1, 2, 3 ), true ) ) return null;
        if ( empty( $sku ) ) return null;
        $col = "sn_ext_price_{$years}y";

        // Phase 4 W12: column exists in wp_dinoco_products via DINOCO_Catalog memo
        if ( ! class_exists( 'DINOCO_Catalog' ) ) return null;
        $product = DINOCO_Catalog::get_by_sku( strtoupper( $sku ) );
        if ( ! $product ) return null;
        // Defensive: column may not exist yet (Phase 1-3 — pre-ALTER)
        if ( ! isset( $product->{$col} ) ) return null;
        $price = $product->{$col};
        if ( $price === null || $price === '' ) return null;
        $price = (float) $price;
        return $price >= 0 ? $price : null;
    }
}

if ( ! function_exists( 'dinoco_sn_extension_available' ) ) {
    /**
     * Check if any extension option is offered for SKU (1y/2y/3y).
     * Returns array of available options:
     *   array( 1 => 1200.00, 2 => 2160.00 )  // 1y + 2y offered, 3y not offered
     *   array()                                // none offered
     */
    function dinoco_sn_extension_available( $sku ) {
        $available = array();
        foreach ( array( 1, 2, 3 ) as $years ) {
            $price = dinoco_sn_get_extension_price( $sku, $years );
            if ( $price !== null ) {
                $available[ $years ] = $price;
            }
        }
        return $available;
    }
}

