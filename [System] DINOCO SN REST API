if ( ! function_exists( 'dinoco_sn_rest_fraud_queue' ) ) {
    function dinoco_sn_rest_fraud_queue( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'fraud_scores' ) ) {
            return rest_ensure_response( array( 'rows' => array(), 'total' => 0 ) );
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'fraud_scores' );

        $min_score = max( 0, min( 100, (int) $req->get_param( 'min_score' ) ) );
        $limit     = max( 1, min( 200, (int) $req->get_param( 'limit' ) ) );
        $offset    = max( 0, (int) $req->get_param( 'offset' ) );

        // Show only unreviewed events with score >= min_score
        $where = "WHERE outcome IS NULL AND score >= %d";

        $total = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$tbl} {$where}",
            $min_score
        ) );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, sn, event_type, score, factors_json,
                    ip_address, geo_country, geo_province, created_at
             FROM {$tbl}
             {$where}
             ORDER BY score DESC, created_at DESC
             LIMIT %d OFFSET %d",
            $min_score, $limit, $offset
        ), ARRAY_A );

        // Decode factors_json + classify tier per-row
        $rows = array_map( function( $r ) {
            $r['score'] = (int) $r['score'];
            $r['factors'] = ! empty( $r['factors_json'] )
                ? json_decode( $r['factors_json'], true )
                : null;
            unset( $r['factors_json'] );
            $r['tier'] = $r['score'] >= 70 ? 'block'
                       : ( $r['score'] >= 50 ? 'monitor' : 'safe' );
            return $r;
        }, $rows ?: array() );

        return rest_ensure_response( array(
            'rows'      => $rows,
            'total'     => $total,
            'limit'     => $limit,
            'offset'    => $offset,
            'min_score' => $min_score,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_fraud_stats' ) ) {
    function dinoco_sn_rest_fraud_stats( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'fraud_scores' ) ) {
            return rest_ensure_response( array( 'available' => false ) );
        }
        global $wpdb;
        $tbl = dinoco_sn_table( 'fraud_scores' );

        // Last 7 days outcome distribution
        $outcome_dist = $wpdb->get_results(
            "SELECT outcome, COUNT(*) AS n
             FROM {$tbl}
             WHERE created_at >= DATE_SUB(NOW(), INTERVAL 7 DAY)
             GROUP BY outcome",
            ARRAY_A
        );
        $outcomes = array( 'pending' => 0, 'legit' => 0, 'fraud' => 0, 'suspicious' => 0 );
        foreach ( $outcome_dist ?: array() as $od ) {
            $key = $od['outcome'] ?: 'pending';
            if ( isset( $outcomes[ $key ] ) ) $outcomes[ $key ] = (int) $od['n'];
        }

        // Risk tier distribution last 7d
        $tier_rows = $wpdb->get_row(
            "SELECT
                SUM(CASE WHEN score < 50 THEN 1 ELSE 0 END)              AS safe,
                SUM(CASE WHEN score >= 50 AND score < 70 THEN 1 ELSE 0 END) AS monitor,
                SUM(CASE WHEN score >= 70 THEN 1 ELSE 0 END)             AS block,
                COUNT(*)                                                  AS total
             FROM {$tbl}
             WHERE created_at >= DATE_SUB(NOW(), INTERVAL 7 DAY)",
            ARRAY_A
        );
        $tier_summary = $tier_rows
            ? array_map( 'intval', $tier_rows )
            : array( 'safe' => 0, 'monitor' => 0, 'block' => 0, 'total' => 0 );

        // Last 24h confirmed fraud (mass-attack signal)
        $confirmed_24h = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$tbl}
             WHERE outcome = 'fraud'
               AND reviewed_at >= DATE_SUB(NOW(), INTERVAL 24 HOUR)"
