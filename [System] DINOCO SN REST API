     * Public lookup endpoint (S/N → top SET name only). Rate-limited.
     * Phase 2+ adds HMAC URL signing (v2.7 BLOCKER B3 promote).
     */
    function dinoco_sn_perm_public( $request ) {
        // Rate limit — reuse b2b_rate_limit if available
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $ip = $_SERVER['REMOTE_ADDR'] ?? 'unknown';
            $rl = b2b_rate_limit( $ip, 'sn_lookup', 30, 60 ); // 30/min/IP
