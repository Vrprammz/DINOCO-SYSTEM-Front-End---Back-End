if ( ! function_exists( 'dinoco_sn_handler_marketplace_pricing_save' ) ) {
    function dinoco_sn_handler_marketplace_pricing_save( $req ) {
        global $wpdb;
        $sku = strtoupper( trim( (string) $req->get_param( 'sku' ) ) );
        $p1  = $req->get_param( 'price_1y' );
        $p2  = $req->get_param( 'price_2y' );
        $p3  = $req->get_param( 'price_3y' );
        if ( $sku === '' ) {
            return new WP_Error( 'invalid_input', __( 'sku required', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        $check = dinoco_sn_marketplace_validate_pricing( $p1, $p2, $p3 );
        if ( is_wp_error( $check ) ) return $check;

        // Verify product exists
        $tbl_products = $wpdb->prefix . 'dinoco_products';
        $exists = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$tbl_products} WHERE sku = %s", $sku
        ) );
        if ( $exists === 0 ) {
            return new WP_Error( 'sku_not_found', __( 'SKU not found in catalog', 'dinoco-sn' ), array( 'status' => 404 ) );
        }

        // Check columns exist (defensive — Phase 4 W12 ALTER may not have landed)
        $cols = $wpdb->get_col( "SHOW COLUMNS FROM {$tbl_products} LIKE 'sn_ext_price_%'" );
        if ( ! is_array( $cols ) || count( $cols ) < 3 ) {
            return new WP_Error( 'schema_not_ready',
                __( 'Pricing columns not yet installed (Phase 4 W12 ALTER pending)', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $update = array();
        $format = array();
        if ( $p1 === null || $p1 === '' ) { $update['sn_ext_price_1y'] = null; $format[] = '%s'; }
        else { $update['sn_ext_price_1y'] = (float) $p1; $format[] = '%f'; }
        if ( $p2 === null || $p2 === '' ) { $update['sn_ext_price_2y'] = null; $format[] = '%s'; }
        else { $update['sn_ext_price_2y'] = (float) $p2; $format[] = '%f'; }
        if ( $p3 === null || $p3 === '' ) { $update['sn_ext_price_3y'] = null; $format[] = '%s'; }
        else { $update['sn_ext_price_3y'] = (float) $p3; $format[] = '%f'; }

        $wpdb->update( $tbl_products, $update, array( 'sku' => $sku ), $format, array( '%s' ) );

        // Invalidate catalog memo
        if ( class_exists( 'DINOCO_Catalog' ) && method_exists( 'DINOCO_Catalog', 'flush_memo' ) ) {
            try { DINOCO_Catalog::flush_memo(); } catch ( \Throwable $e ) {}
        }

        if ( function_exists( 'dinoco_sn_audit_log' ) ) {
            dinoco_sn_audit_log( null, 'marketplace_pricing_updated', null, null, array(
                'sku'      => $sku,
                'price_1y' => $update['sn_ext_price_1y'],
                'price_2y' => $update['sn_ext_price_2y'],
                'price_3y' => $update['sn_ext_price_3y'],
            ), get_current_user_id(), null, '', 'admin_pricing', false );
        }

        return rest_ensure_response( array(
            'success'  => true,
            'sku'      => $sku,
            'price_1y' => $update['sn_ext_price_1y'],
            'price_2y' => $update['sn_ext_price_2y'],
            'price_3y' => $update['sn_ext_price_3y'],
        ) );
    }
}

