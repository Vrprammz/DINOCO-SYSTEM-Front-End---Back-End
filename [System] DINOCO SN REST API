/* ═══════════════════════════════════════════════════════════════════════════
 * 4. IDEMPOTENCY WRAPPER (delegates to Idempotency Helper V.1.0+)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_with_idempotency' ) ) {
    /**
     * Standard wrapper for POST endpoints. Pattern from Round 19+ DINOCO
     * (e.g., place-order, manual-flash-create).
     *
     * Body hash includes actor_user_id (Round 30+ pattern, fullstack
     * SHOULD-FIX #1 from v2.12 review).
     *
     * Usage:
     *   register_rest_route( DINOCO_SN_REST_NAMESPACE, '/batches', array(
     *     'methods'  => 'POST',
     *     'callback' => 'dinoco_sn_rest_create_batch',
     *     'permission_callback' => 'dinoco_sn_perm_admin',
     *   ) );
     *
     *   function dinoco_sn_rest_create_batch( $req ) {
     *       return dinoco_sn_with_idempotency( $req, 'sn-batch-create',
     *           array( 'batch_code', 'prefix', 'qty_total', 'format_pattern' ),
     *           function( $req ) { return dinoco_sn_handler_create_batch( $req ); }
     *       );
     *   }
     */
    function dinoco_sn_with_idempotency( $req, $namespace_suffix, $body_keys, $handler ) {
        if ( ! function_exists( 'dinoco_idempotency_extract_key' )
          || ! function_exists( 'dinoco_idempotency_check' )
          || ! function_exists( 'dinoco_idempotency_store' )
          || ! function_exists( 'dinoco_idempotency_hash' ) ) {
            // Idempotency Helper not synced — fall through (defensive)
            return call_user_func( $handler, $req );
        }

        $key = dinoco_idempotency_extract_key( $req );
        $namespace = DINOCO_SN_REST_NAMESPACE . '::' . $namespace_suffix;

        // Build body hash from declared keys + actor_user_id
        $body = array();
        foreach ( $body_keys as $k ) {
            $body[ $k ] = $req->get_param( $k );
        }
        $body['_actor_user_id'] = get_current_user_id();
        $body_hash = dinoco_idempotency_hash( $body );

        if ( $key !== '' ) {
            $cached = dinoco_idempotency_check( $key, $namespace, $body_hash );
            if ( is_wp_error( $cached ) ) return $cached; // 409 hash mismatch
            if ( is_array( $cached ) ) return rest_ensure_response( $cached );
        }

        $result = call_user_func( $handler, $req );

        if ( $key !== '' && ! is_wp_error( $result ) ) {
            $resp_data = is_a( $result, 'WP_REST_Response' ) ? $result->get_data() : $result;
            $resp_code = is_a( $result, 'WP_REST_Response' ) ? $result->get_status() : 200;
            dinoco_idempotency_store( $key, $namespace, $body_hash, $resp_data, $resp_code );
        }

        return $result;
    }
}

