if ( ! function_exists( 'dinoco_sn_handler_marketplace_approve' ) ) {
    function dinoco_sn_handler_marketplace_approve( $req ) {
        global $wpdb;
        $extension_id = (int) $req->get_param( 'id' );
        $reason       = sanitize_textarea_field( (string) $req->get_param( 'reason' ) );
        $admin_id     = get_current_user_id();

        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'extensions' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'extensions table missing', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        $tbl = dinoco_sn_table( 'extensions' );

        $lock_name = "dinoco_sn_extend_approve_{$extension_id}";
        $lock_acquired = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_name, 5 ) );
        if ( $lock_acquired !== '1' ) {
            return new WP_Error( 'db_lock_timeout', __( 'Approve lock busy', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        $wpdb->query( 'START TRANSACTION' );
        try {
            $ext = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl} WHERE id = %d FOR UPDATE", $extension_id
            ) );
            if ( ! $ext ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return new WP_Error( 'not_found', __( 'Extension not found', 'dinoco-sn' ), array( 'status' => 404 ) );
            }
            if ( $ext->payment_status !== 'pending_admin_review' ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return new WP_Error( 'wrong_state',
                    sprintf( __( 'Cannot approve from status %s', 'dinoco-sn' ), $ext->payment_status ),
                    array( 'status' => 409, 'current_status' => $ext->payment_status ) );
            }
            $now = current_time( 'mysql' );
            $upd = $wpdb->update( $tbl, array(
                'payment_status' => 'paid',
                'paid_at'        => $now,
            ), array( 'id' => $extension_id, 'payment_status' => 'pending_admin_review' ),
               array( '%s', '%s' ),
               array( '%d', '%s' ) );
            if ( $upd === false || $upd === 0 ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return new WP_Error( 'concurrent_modification',
                    __( 'Status changed during approve. Retry.', 'dinoco-sn' ),
                    array( 'status' => 409 ) );
            }
            $wpdb->query( 'COMMIT' );

            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $ext->sn, 'extension_paid', 'pending_admin_review', 'paid', array(
                    'extension_id' => $extension_id,
                    'approved_by'  => $admin_id,
                ), $admin_id, null, $reason, 'admin_approve', false );
            }
            // Apply atomic warranty extension
            $apply_result = function_exists( 'dinoco_sn_apply_warranty_extension' )
                ? dinoco_sn_apply_warranty_extension( $extension_id )
                : array( 'success' => false, 'error' => 'apply_helper_missing' );

            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            return rest_ensure_response( array(
                'success'      => true,
                'extension_id' => $extension_id,
                'status'       => 'paid',
                'apply_result' => $apply_result,
            ) );
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'marketplace_approve', 'extension_id' => $extension_id ) );
            }
            return new WP_Error( 'approve_failed', $e->getMessage(), array( 'status' => 500 ) );
        }
    }
}

