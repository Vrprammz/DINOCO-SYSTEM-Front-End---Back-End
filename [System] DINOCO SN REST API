if ( ! function_exists( 'dinoco_sn_handler_marketplace_checkout' ) ) {
    function dinoco_sn_handler_marketplace_checkout( $req ) {
        global $wpdb;
        if ( ! function_exists( 'dinoco_sn_table_exists' )
          || ! dinoco_sn_table_exists( 'pool' )
          || ! dinoco_sn_table_exists( 'extensions' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'Marketplace schema missing', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        $sn      = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        $years   = (int) $req->get_param( 'years' );
        $coupon  = sanitize_text_field( (string) $req->get_param( 'coupon_code' ) );
        $user_id = get_current_user_id();

        if ( $sn === '' || ! in_array( $years, array( 1, 2, 3 ), true ) ) {
            return new WP_Error( 'invalid_input', __( 'sn + years (1|2|3) required', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        $row = function_exists( 'dinoco_sn_get_plate_data' ) ? dinoco_sn_get_plate_data( $sn ) : null;
        if ( ! $row ) {
            return new WP_Error( 'sn_not_found', __( 'S/N not found', 'dinoco-sn' ), array( 'status' => 404 ) );
        }
        if ( $row->status !== 'registered' ) {
            return new WP_Error( 'not_eligible',
                __( 'Plate must be registered', 'dinoco-sn' ),
                array( 'status' => 403, 'current_status' => $row->status ) );
        }
        if ( (int) $row->registered_user_id !== $user_id ) {
            return new WP_Error( 'not_owner',
                __( 'Not the registered owner', 'dinoco-sn' ),
                array( 'status' => 403 ) );
        }
        $current_end = dinoco_sn_marketplace_resolve_warranty_end( $row );
        $w_status = dinoco_sn_marketplace_warranty_status( $current_end );
        if ( $w_status === 'expired_no_grace' ) {
            return new WP_Error( 'expired', __( 'Warranty expired beyond grace', 'dinoco-sn' ),
                array( 'status' => 403, 'reason' => 'expired_no_grace' ) );
        }

        $linked_sku = strtoupper( (string) ( $row->linked_sku ?? '' ) );
        $base_price = function_exists( 'dinoco_sn_get_extension_price' ) ? dinoco_sn_get_extension_price( $linked_sku, $years ) : null;
        if ( $base_price === null ) {
            return new WP_Error( 'not_available',
                sprintf( __( 'Extension %dy not offered for this SKU', 'dinoco-sn' ), $years ),
                array( 'status' => 422, 'sku' => $linked_sku, 'years' => $years ) );
        }

        // Coupon resolution — defensive reuse of F#1 promo system if available
        $coupon_discount = 0.0;
        $coupon_applied = '';
        if ( $coupon !== '' ) {
            // Phase 5 W15.4: best-effort coupon lookup. Promo system may not be wired yet.
            // For now: stash code in payment_ref for audit; admin can manually approve discount via Manager tab.
            $coupon_applied = mb_substr( $coupon, 0, 32 );
        }

        $quote = dinoco_sn_marketplace_compute_quote( $base_price, $years );
        $amount_total = $quote['total'] - $coupon_discount;
        if ( $amount_total < 0 ) $amount_total = 0;

        // payment_ref format: EXT-{user}-{sn8}-{ts8} (unique-ish, easy to grep in slip text)
        $payment_ref = 'EXT-' . $user_id . '-' . substr( $sn, 0, 8 ) . '-' . substr( (string) time(), -8 );

        $tbl = dinoco_sn_table( 'extensions' );
        $now = current_time( 'mysql' );
        $extension_months = $years * 12;

        // Best-effort: prefer current_end as baseline. If null, use today (defensive).
        $warranty_until_old = $current_end ?: gmdate( 'Y-m-d' );
        $warranty_until_new = dinoco_sn_marketplace_compute_new_warranty_end( $warranty_until_old, $years );
        if ( ! $warranty_until_new ) {
            return new WP_Error( 'date_compute_failed',
                __( 'Cannot compute new warranty end', 'dinoco-sn' ),
                array( 'status' => 500 ) );
        }

        $ok = $wpdb->insert( $tbl, array(
            'sn'                 => $sn,
            'user_id'            => $user_id,
            'extension_months'   => $extension_months,
            'price_paid'         => $amount_total,
            'payment_method'     => 'promptpay',
            'payment_ref'        => $payment_ref,
            'payment_status'     => 'pending_payment',
            'warranty_until_old' => $warranty_until_old,
            'warranty_until_new' => $warranty_until_new,
            'created_at'         => $now,
        ), array( '%s', '%d', '%d', '%f', '%s', '%s', '%s', '%s', '%s', '%s' ) );
        if ( $ok === false ) {
            return new WP_Error( 'db_insert_failed', __( 'Failed to create extension', 'dinoco-sn' ), array( 'status' => 500 ) );
        }
        $extension_id = (int) $wpdb->insert_id;

        // Audit log
        if ( function_exists( 'dinoco_sn_audit_log' ) ) {
            dinoco_sn_audit_log( $sn, 'extension_created', null, 'pending_payment', array(
                'extension_id'   => $extension_id,
                'years'          => $years,
                'amount_total'   => $amount_total,
                'coupon_applied' => $coupon_applied,
                'payment_ref'    => $payment_ref,
            ), $user_id, null, '', 'marketplace_checkout', false );
        }

        // PromptPay QR — defensive (b2b_generate_promptpay_qr exists in B2B Snippet 1+10)
        $qr_base64 = '';
        $qr_note = '';
        if ( function_exists( 'b2b_generate_promptpay_qr' ) ) {
            try {
                $qr_base64 = (string) b2b_generate_promptpay_qr( $amount_total, $payment_ref );
            } catch ( \Throwable $e ) {
                $qr_note = 'QR generation pending — admin will contact you';
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( $e, array( 'context' => 'marketplace_qr_gen', 'extension_id' => $extension_id ) );
                }
            }
        } else {
            $qr_note = 'QR generation pending — admin will contact you';
        }

        // Bank account info (Q7: reuse B2B_BANK_*)
        $bank_account = defined( 'B2B_BANK_ACCOUNT' ) ? (string) B2B_BANK_ACCOUNT : '';
        $bank_name    = defined( 'B2B_BANK_NAME' )    ? (string) B2B_BANK_NAME    : '';
        $bank_holder  = defined( 'B2B_BANK_HOLDER' )  ? (string) B2B_BANK_HOLDER  : '';

        // 24h expiry (cron auto-cancels per W16.3)
        $expires_at = gmdate( 'Y-m-d H:i:s', time() + 86400 );

        $resp = array(
            'success'          => true,
            'extension_id'     => $extension_id,
            'sn'               => $sn,
            'years'            => $years,
            'extension_months' => $extension_months,
            'amount_total'     => $amount_total,
            'base_price'       => $quote['base_price'],
            'vat'              => $quote['vat'],
            'qr_base64_png'    => $qr_base64,
            'bank_account'     => $bank_account,
            'bank_name'        => $bank_name,
            'holder'           => $bank_holder,
            'payment_ref'      => $payment_ref,
            'expires_at'       => $expires_at,
            'status'           => 'pending_payment',
            'warranty_until_old' => $warranty_until_old,
            'warranty_until_new' => $warranty_until_new,
        );
        if ( $qr_note !== '' ) {
            $resp['qr_note'] = $qr_note;
        }
        return rest_ensure_response( $resp );
    }
}

