if ( ! function_exists( 'dinoco_sn_classify_approval_tier' ) ) {
    /**
     * Phase 2 W5 — 3-tier approval matrix (per v2.13 §2.7).
     *
     * Returns tier classification for an action based on plate state + scope:
     *   'auto'         — no approval (single-admin can execute)
     *   'single_admin' — actor + 1 admin (≠ self) confirms
     *   '4_eyes'       — actor + 1 specific approver from delegate list
     *
     * @param string $action 'swap'|'void'|'recall'|'relink'|'reissue'
     * @param string $current_state Plate.status (in_pool/registered/claimed/voided/...)
     * @param int    $bulk_count How many plates affected (for bulk ops)
     * @return string 'auto' | 'single_admin' | '4_eyes'
     */
    function dinoco_sn_classify_approval_tier( $action, $current_state, $bulk_count = 1 ) {
        $action = strtolower( trim( (string) $action ) );
        $current_state = strtolower( trim( (string) $current_state ) );
        $bulk_count = max( 1, (int) $bulk_count );

        // Bulk void/recall > 100 plates → always 4-eyes regardless of state
        if ( in_array( $action, array( 'void', 'recall' ), true ) && $bulk_count > 100 ) {
            return '4_eyes';
        }

        // Recall is always 4-eyes (impacts customer + brand)
        if ( $action === 'recall' ) {
            return '4_eyes';
        }

        // Swap registered/claimed = customer-impacting → 4-eyes
        if ( $action === 'swap' && in_array( $current_state, array( 'registered', 'claimed' ), true ) ) {
            return '4_eyes';
        }

        // Void registered = customer-impacting → 4-eyes
        if ( $action === 'void' && in_array( $current_state, array( 'registered', 'claimed' ), true ) ) {
            return '4_eyes';
        }

        // Pre-activation operations → single-admin (1 admin ≠ self)
        if ( in_array( $action, array( 'swap', 'void' ), true )
             && in_array( $current_state, array( 'shipped', 'allocated_to_order' ), true ) ) {
            return 'single_admin';
        }

        // Bulk relink registered → single-admin
        if ( $action === 'relink' && $current_state === 'registered' && $bulk_count > 1 ) {
            return 'single_admin';
        }

        // Default: auto (relink in_pool, void in_pool/reserved, single-plate ops)
        return 'auto';
    }
}

if ( ! function_exists( 'dinoco_sn_get_approval_sla_seconds' ) ) {
    /**
     * SLA window for approval tier (per v2.13 §2.7 + §K.6).
     */
    function dinoco_sn_get_approval_sla_seconds( $tier, $urgency = 'normal' ) {
        $urgency = in_array( $urgency, array( 'urgent', 'normal', 'low' ), true ) ? $urgency : 'normal';

        if ( $tier === '4_eyes' ) {
            // Urgent (swap registered) = 1 hour, Normal = 24h, Low = 72h
            $map = array( 'urgent' => 3600, 'normal' => 86400, 'low' => 259200 );
            return $map[ $urgency ];
        }

        if ( $tier === 'single_admin' ) {
            // Single-admin always 24h
            return 86400;
        }

        return 0; // 'auto' = no SLA
    }
}

if ( ! function_exists( 'dinoco_sn_register_capabilities' ) ) {
    /**
     * Add custom capabilities to administrator role. Idempotent —
     * safe to run on every init (WP role->add_cap is no-op if exists).
     *
     * Naming convention: dinoco_sn_* (matches snippet namespace per
     * v2.4 SHOULD-FIX #7 fullstack-developer review).
     */
    function dinoco_sn_register_capabilities() {
        $admin = get_role( 'administrator' );
        if ( ! $admin ) return;
        $caps = array(
            'dinoco_sn_warehouse',
            'dinoco_sn_approver',
            'dinoco_sn_view_pii',
        );
        foreach ( $caps as $cap ) {
            if ( ! $admin->has_cap( $cap ) ) {
                $admin->add_cap( $cap );
            }
        }
    }
}

if ( ! has_action( 'init', 'dinoco_sn_register_capabilities' ) ) {
    add_action( 'init', 'dinoco_sn_register_capabilities', 10 );
}

