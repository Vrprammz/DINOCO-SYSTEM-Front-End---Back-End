 *   Q7 — Reuse Slip2Go + B2B_BANK_* (no new partnership)
 *   Q8 — per-SKU manual pricing (admin gates extension price per SKU/year)
 *
 * Master kill switch: dinoco_sn_marketplace_enabled (default OFF)
 * Plan: docs/sn-system/22-phase5-w15-w18-prep.md §W15.3 + §W15.4
 *
 * State machine (sn_warranty_extensions.payment_status):
 *   pending_payment ──upload-slip─┬─→ paid (auto-verify ±2%)
 *                                 └─→ pending_admin_review
 *   pending_admin_review ──admin─┬─→ paid (manual approve)
 *                                └─→ rejected
 *   paid ──W17 refund flow──────────→ refunded (Q20 manual, Phase 5 W17)
 *
 * Idempotency: every POST wrapped via dinoco_sn_with_idempotency() + Round 30+
 * actor_user_id pattern. Concurrent slip-upload + apply uses GET_LOCK + FOR
 * UPDATE per Phase 1 W2 atomic-mutation pattern.
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_marketplace_is_enabled' ) ) {
    /**
     * Marketplace master kill switch. Default OFF — boss flips ON after
     * pricing config + Slip2Go ready (per W15 plan W15.5 admin tab).
     */
    function dinoco_sn_marketplace_is_enabled() {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return false;
        }
        return (bool) get_option( 'dinoco_sn_marketplace_enabled', false );
    }
}

if ( ! function_exists( 'dinoco_sn_marketplace_compute_quote' ) ) {
    /**
     * Pure-logic price computation. VAT 7% (Thai standard).
     *
     * @param float $base_price (THB ex-VAT, from sn_ext_price_{N}y)
     * @param int   $years 1|2|3
     * @return array { base_price, years, vat, total, vat_rate }
     */
    function dinoco_sn_marketplace_compute_quote( $base_price, $years ) {
        $base = round( (float) $base_price, 2 );
        $years = max( 1, min( 3, (int) $years ) );
        $vat_rate = 0.07;
        $vat = round( $base * $vat_rate, 2 );
        $total = round( $base + $vat, 2 );
        return array(
            'years'      => $years,
            'base_price' => $base,
            'vat'        => $vat,
            'vat_rate'   => $vat_rate,
            'total'      => $total,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_marketplace_compute_new_warranty_end' ) ) {
    /**
     * Pure-logic warranty math: current + N years using DateTime::modify.
     *
     * @param string $current_warranty_end MySQL DATE/DATETIME or ISO 8601
     * @param int    $years 1|2|3
     * @return string|null new warranty_until 'Y-m-d' or null on parse fail
     */
    function dinoco_sn_marketplace_compute_new_warranty_end( $current_warranty_end, $years ) {
        if ( empty( $current_warranty_end ) ) return null;
        $years = max( 1, min( 3, (int) $years ) );
        try {
            $dt = new \DateTime( (string) $current_warranty_end );
            $dt->modify( '+' . $years . ' years' );
            return $dt->format( 'Y-m-d' );
        } catch ( \Throwable $e ) {
            return null;
        }
    }
}

if ( ! function_exists( 'dinoco_sn_marketplace_warranty_status' ) ) {
    /**
     * Eligibility classifier for marketplace.
     * grace_period = within 30 days post-expiry (still purchasable).
     * Returns 'active' | 'grace_period' | 'expired_no_grace'.
     */
    function dinoco_sn_marketplace_warranty_status( $warranty_until ) {
        if ( empty( $warranty_until ) ) return 'expired_no_grace';
        try {
            $end = new \DateTime( (string) $warranty_until );
            $now = new \DateTime( 'now' );
            $diff = (int) $now->diff( $end )->format( '%r%a' ); // signed days
            if ( $diff >= 0 ) return 'active';
            if ( $diff >= -30 ) return 'grace_period';
            return 'expired_no_grace';
        } catch ( \Throwable $e ) {
            return 'expired_no_grace';
        }
    }
}

if ( ! function_exists( 'dinoco_sn_marketplace_validate_pricing' ) ) {
    /**
     * Defensive validation of admin-supplied per-SKU pricing.
     * Q8: per-SKU manual pricing — admin can omit any tier (null = not offered).
     *
     * Rules:
     *   - All values null = no pricing (treat as "wipe all tiers")
     *   - Each non-null value: ≥0 + ≤1,000,000 (sanity ceiling)
     *   - If 1y + 2y both set → 1y < 2y (cheaper to buy 1y than 2y)
     *   - If 2y + 3y both set → 2y < 3y
     *   - If 1y + 3y both set → 1y < 3y
     *
     * @return true|WP_Error
     */
    function dinoco_sn_marketplace_validate_pricing( $price_1y, $price_2y, $price_3y ) {
        $values = array( '1y' => $price_1y, '2y' => $price_2y, '3y' => $price_3y );
        foreach ( $values as $tier => $p ) {
            if ( $p === null || $p === '' ) continue;
            if ( ! is_numeric( $p ) ) {
                return new WP_Error( 'invalid_price',
                    sprintf( 'price_%s must be numeric', $tier ),
                    array( 'status' => 400 ) );
            }
            $n = (float) $p;
            if ( $n < 0 || $n > 1000000 ) {
                return new WP_Error( 'invalid_price',
                    sprintf( 'price_%s out of range [0, 1000000]', $tier ),
                    array( 'status' => 400 ) );
            }
        }
        $p1 = ( $price_1y === null || $price_1y === '' ) ? null : (float) $price_1y;
        $p2 = ( $price_2y === null || $price_2y === '' ) ? null : (float) $price_2y;
        $p3 = ( $price_3y === null || $price_3y === '' ) ? null : (float) $price_3y;

        if ( $p1 !== null && $p2 !== null && $p1 >= $p2 ) {
            return new WP_Error( 'illogical_pricing',
                'price_1y must be < price_2y (longer term should cost more total)',
                array( 'status' => 400 ) );
        }
        if ( $p2 !== null && $p3 !== null && $p2 >= $p3 ) {
            return new WP_Error( 'illogical_pricing',
                'price_2y must be < price_3y',
                array( 'status' => 400 ) );
        }
        if ( $p1 !== null && $p3 !== null && $p1 >= $p3 ) {
            return new WP_Error( 'illogical_pricing',
                'price_1y must be < price_3y',
                array( 'status' => 400 ) );
        }
        return true;
    }
}

if ( ! function_exists( 'dinoco_sn_marketplace_resolve_warranty_end' ) ) {
    /**
     * Best-effort: prefer warranty_registration CPT 'warranty_until' ACF field
     * (Phase 4 W14 schema). Fallback: compute from sn_pool.registered_at +
     * default warranty years (Phase 1 stub helper).
     */
    function dinoco_sn_marketplace_resolve_warranty_end( $sn_row ) {
        $warranty_id = is_array( $sn_row ) ? ( $sn_row['registered_warranty_id'] ?? 0 ) : ( $sn_row->registered_warranty_id ?? 0 );
        $warranty_id = (int) $warranty_id;
        if ( $warranty_id > 0 ) {
            // Try ACF first, then post_meta directly (defensive)
            $end = '';
            if ( function_exists( 'get_field' ) ) {
                $end = (string) get_field( 'warranty_until', $warranty_id );
            }
            if ( $end === '' ) {
                $end = (string) get_post_meta( $warranty_id, 'warranty_until', true );
            }
            if ( $end !== '' ) return $end;
        }
        // Fallback: helper from Manager (registered_at + default years)
        if ( function_exists( 'dinoco_sn_warranty_end_for_pool_row' ) ) {
            $dt = dinoco_sn_warranty_end_for_pool_row( $sn_row );
            if ( $dt instanceof \DateTime ) return $dt->format( 'Y-m-d' );
        }
        return null;
    }
}

