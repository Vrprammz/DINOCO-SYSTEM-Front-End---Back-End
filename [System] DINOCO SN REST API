if ( ! function_exists( 'dinoco_sn_rest_pool_stats' ) ) {
    /**
     * GET /pool-stats — heatmap counters per linked_sku × status.
     *
     * Response: {
     *   stats: [{ linked_sku, in_pool, registered, claimed, voided, ... }],
     *   totals: { reserved, in_pool, registered, ... },
     *   updated_at: <ISO timestamp>
     * }
     *
     * Cached 60s via wp_options to avoid hammering 1M+ row sn_pool.
     */
    function dinoco_sn_rest_pool_stats( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return rest_ensure_response( array(
                'stats' => array(),
                'totals' => new \stdClass(),
                'updated_at' => current_time( 'c' ),
                'note' => 'pool table not yet installed',
            ) );
        }

        // 60s cache via transient
        $cached = get_transient( 'dinoco_sn_pool_stats_v1' );
        if ( $cached !== false ) {
            return rest_ensure_response( $cached );
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'pool' );

        // V.0.6 audit fix (P1-3): SUM(status='x') is MySQL boolean shorthand —
        // not portable to ANSI SQL strict modes (PostgreSQL / MySQL strict).
        // SUM(CASE WHEN status='x' THEN 1 ELSE 0 END) is portable + identical
        // semantics on all engines.
        //
        // 200-SKU LIMIT note: per-row breakdown shows top 200 by total only.
        // sum(stats[].total) MAY NOT equal totals.total if more SKUs exist —
        // this is intentional to cap payload size. Admin UI should display
        // both values + label "showing top 200 SKUs" if stats[] count = 200.
        $rows = $wpdb->get_results(
            "SELECT linked_sku,
                    SUM(CASE WHEN status = 'reserved'           THEN 1 ELSE 0 END) AS reserved,
                    SUM(CASE WHEN status = 'in_pool'            THEN 1 ELSE 0 END) AS in_pool,
                    SUM(CASE WHEN status = 'allocated_to_order' THEN 1 ELSE 0 END) AS allocated,
                    SUM(CASE WHEN status = 'shipped'            THEN 1 ELSE 0 END) AS shipped,
                    SUM(CASE WHEN status = 'registered'         THEN 1 ELSE 0 END) AS registered,
                    SUM(CASE WHEN status = 'claimed'            THEN 1 ELSE 0 END) AS claimed,
                    SUM(CASE WHEN status = 'replaced'           THEN 1 ELSE 0 END) AS replaced,
                    SUM(CASE WHEN status = 'transferred'        THEN 1 ELSE 0 END) AS transferred,
                    SUM(CASE WHEN status = 'voided'             THEN 1 ELSE 0 END) AS voided,
                    SUM(CASE WHEN status = 'recalled'           THEN 1 ELSE 0 END) AS recalled,
                    COUNT(*)                                                       AS total
             FROM {$tbl}
             WHERE linked_sku IS NOT NULL AND linked_sku != ''
             GROUP BY linked_sku
             ORDER BY total DESC
             LIMIT 200",
            ARRAY_A
        );

        // Totals across ALL rows (not limited)
        $totals = $wpdb->get_row(
            "SELECT
                SUM(CASE WHEN status = 'reserved'           THEN 1 ELSE 0 END) AS reserved,
                SUM(CASE WHEN status = 'in_pool'            THEN 1 ELSE 0 END) AS in_pool,
                SUM(CASE WHEN status = 'allocated_to_order' THEN 1 ELSE 0 END) AS allocated,
                SUM(CASE WHEN status = 'shipped'            THEN 1 ELSE 0 END) AS shipped,
                SUM(CASE WHEN status = 'registered'         THEN 1 ELSE 0 END) AS registered,
                SUM(CASE WHEN status = 'claimed'            THEN 1 ELSE 0 END) AS claimed,
                SUM(CASE WHEN status = 'replaced'           THEN 1 ELSE 0 END) AS replaced,
                SUM(CASE WHEN status = 'transferred'        THEN 1 ELSE 0 END) AS transferred,
                SUM(CASE WHEN status = 'voided'             THEN 1 ELSE 0 END) AS voided,
                SUM(CASE WHEN status = 'recalled'           THEN 1 ELSE 0 END) AS recalled,
                COUNT(*)                                                       AS total
             FROM {$tbl}",
            ARRAY_A
        );

        $resp = array(
            'stats'         => array_map( function( $r ) {
                foreach ( $r as $k => $v ) { $r[ $k ] = $k === 'linked_sku' ? $v : (int) $v; }
                return $r;
            }, $rows ?: array() ),
            'totals'        => $totals ? array_map( 'intval', $totals ) : new \stdClass(),
            'stats_capped'  => count( $rows ?: array() ) >= 200,  // hint UI to show "top 200" badge
            'updated_at'    => current_time( 'c' ),
            'cached'        => false,
        );

        set_transient( 'dinoco_sn_pool_stats_v1', $resp, 60 );
        return rest_ensure_response( $resp );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_search' ) ) {
    /**
     * GET /search?q=&status=&batch_id=&limit=&offset=
     *
     * Universal admin search across sn_pool. Supports:
     *   - exact S/N match (q="DNCSS0001234")
     *   - prefix match (q="DNCSS*")
     *   - status filter (q + status combined)
     *   - batch filter (batch_id)
     *
     * Returns rows with linked_sku, status, registered_user_id (masked
     * if !view_pii capability), batch_code, registered_at.
     */
    function dinoco_sn_rest_search( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return rest_ensure_response( array( 'rows' => array(), 'total' => 0 ) );
        }

        global $wpdb;
        $pool    = dinoco_sn_table( 'pool' );
        $batches = dinoco_sn_table( 'batches' );

        $q       = trim( (string) $req->get_param( 'q' ) );
        $status  = (string) $req->get_param( 'status' );
        $batchId = (int) $req->get_param( 'batch_id' );
        $limit   = max( 1, min( 200, (int) $req->get_param( 'limit' ) ) );
        $offset  = max( 0, (int) $req->get_param( 'offset' ) );

        $where  = array();
        $params = array();

        if ( $q !== '' ) {
            // Wildcard support — DNCSS* / *1234 / partial
            if ( strpos( $q, '*' ) !== false ) {
                $like = str_replace( '*', '%', strtoupper( $q ) );
                $where[] = 'p.sn LIKE %s';
                $params[] = $like;
            } else {
                $where[] = '( p.sn = %s OR p.sn LIKE %s )';
                $params[] = strtoupper( $q );
                $params[] = '%' . $wpdb->esc_like( strtoupper( $q ) ) . '%';
            }
        }
        if ( $status !== '' ) {
            $where[] = 'p.status = %s';
            $params[] = $status;
        }
        if ( $batchId > 0 ) {
            $where[] = 'p.batch_id = %d';
            $params[] = $batchId;
        }

        $where_sql = $where ? ( 'WHERE ' . implode( ' AND ', $where ) ) : '';
        $count_sql = "SELECT COUNT(*) FROM {$pool} p {$where_sql}";
        $list_sql  = "SELECT p.sn, p.batch_id, p.linked_sku, p.status, p.registered_user_id,
                             p.registered_warranty_id, p.registered_at, p.received_at,
                             b.batch_code
                      FROM {$pool} p
                      LEFT JOIN {$batches} b ON b.id = p.batch_id
                      {$where_sql}
                      ORDER BY p.received_at DESC, p.sn ASC
                      LIMIT %d OFFSET %d";

        $count_params = $params;
        $list_params  = array_merge( $params, array( $limit, $offset ) );

        $total = (int) ( $params
            ? $wpdb->get_var( $wpdb->prepare( $count_sql, $count_params ) )
            : $wpdb->get_var( $count_sql ) );

        $rows = $wpdb->get_results( $wpdb->prepare( $list_sql, $list_params ), ARRAY_A );

        // Mask user_id unless view_pii cap
        $can_pii = function_exists( 'dinoco_sn_user_can_view_pii' ) && dinoco_sn_user_can_view_pii();
        $rows = array_map( function( $r ) use ( $can_pii ) {
            if ( ! $can_pii && ! empty( $r['registered_user_id'] ) ) {
                $r['registered_user_id_masked'] = 'user_' . substr( md5( (string) $r['registered_user_id'] ), 0, 6 );
                $r['registered_user_id'] = (int) $r['registered_user_id'];
            }
            return $r;
        }, $rows ?: array() );

        return rest_ensure_response( array(
            'rows'   => $rows,
            'total'  => $total,
            'limit'  => $limit,
            'offset' => $offset,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_sn_detail' ) ) {
    /**
     * GET /sn/{sn} — full detail card for Tab 4 investigation view.
     *
     * Returns: pool row + meta row + batch row + audit timeline (last 50).
     * Includes computed top_set_sku via hierarchy resolver.
     */
    function dinoco_sn_rest_sn_detail( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        if ( $sn === '' ) {
            return new WP_Error( 'invalid_sn', __( 'S/N is required.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'sn_pool not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        global $wpdb;
        $pool    = dinoco_sn_table( 'pool' );
        $batches = dinoco_sn_table( 'batches' );
        $audit   = dinoco_sn_table( 'audit' );

        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT p.*, b.batch_code, b.prefix, b.factory_name
             FROM {$pool} p
             LEFT JOIN {$batches} b ON b.id = p.batch_id
             WHERE p.sn = %s
             LIMIT 1",
            $sn
        ), ARRAY_A );

        if ( ! $row ) {
            return new WP_Error( 'sn_not_found',
                sprintf( __( 'S/N %s not found in pool.', 'dinoco-sn' ), $sn ),
                array( 'status' => 404 ) );
        }

        // Audit timeline (last 50 events)
        $timeline = array();
        if ( dinoco_sn_table_exists( 'audit' ) ) {
            $timeline = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, event_type, status_from, status_to, actor_user_id,
                        approver_user_id, reason, reason_category, context_json,
                        ip_address, is_sensitive, created_at
                 FROM {$audit}
                 WHERE sn = %s
                 ORDER BY created_at DESC, id DESC
                 LIMIT 50",
                $sn
            ), ARRAY_A );

            // Decode context_json + resolve actor display names
            $timeline = array_map( function( $t ) {
                $t['context'] = ! empty( $t['context_json'] ) ? json_decode( $t['context_json'], true ) : null;
                unset( $t['context_json'] );
                if ( ! empty( $t['actor_user_id'] ) ) {
                    $u = get_user_by( 'id', (int) $t['actor_user_id'] );
                    $t['actor_display'] = $u ? $u->display_name : ( 'user#' . $t['actor_user_id'] );
                }
                if ( ! empty( $t['approver_user_id'] ) ) {
                    $u = get_user_by( 'id', (int) $t['approver_user_id'] );
                    $t['approver_display'] = $u ? $u->display_name : ( 'user#' . $t['approver_user_id'] );
                }
                return $t;
            }, $timeline ?: array() );
        }

        // Compute top_set_sku via hierarchy resolver (best-effort)
        $top_set_sku = $row['top_set_sku'] ?? null;
        if ( ! $top_set_sku && ! empty( $row['linked_sku'] ) && function_exists( 'dinoco_get_ancestor_skus' ) ) {
            $ancestors = (array) dinoco_get_ancestor_skus( $row['linked_sku'] );
            $top_set_sku = end( $ancestors ) ?: $row['linked_sku'];
        }

        // Customer info if registered (PII-gated)
        $customer = null;
        if ( ! empty( $row['registered_user_id'] ) ) {
            $u = get_user_by( 'id', (int) $row['registered_user_id'] );
            if ( $u ) {
                $can_pii = function_exists( 'dinoco_sn_user_can_view_pii' ) && dinoco_sn_user_can_view_pii();
                $customer = array(
                    'user_id'      => (int) $u->ID,
                    'display_name' => $u->display_name,
                    'email'        => $can_pii ? $u->user_email : preg_replace( '/(.).*(@.*)/', '$1***$2', (string) $u->user_email ),
                );
            }
        }

        return rest_ensure_response( array(
            'sn'           => $row,
            'top_set_sku'  => $top_set_sku,
            'customer'     => $customer,
            'timeline'     => $timeline,
            'fetched_at'   => current_time( 'c' ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_audit_search' ) ) {
    /**
     * GET /audit?sn=&event_type=&actor_id=&days=&limit=&offset=
     *
     * Tab 5 paginated audit log search. Default 30-day window.
     * Anomaly detection (M13) deferred to Phase 3+.
     */
    function dinoco_sn_rest_audit_search( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) {
            return rest_ensure_response( array( 'rows' => array(), 'total' => 0 ) );
        }
        global $wpdb;
        $tbl = dinoco_sn_table( 'audit' );

        $sn       = trim( (string) $req->get_param( 'sn' ) );
        $eventTyp = (string) $req->get_param( 'event_type' );
        $actorId  = (int) $req->get_param( 'actor_id' );
        $days     = max( 1, min( 365, (int) $req->get_param( 'days' ) ) );
        $limit    = max( 1, min( 500, (int) $req->get_param( 'limit' ) ) );
        $offset   = max( 0, (int) $req->get_param( 'offset' ) );

        $where  = array( 'created_at >= %s' );
        $params = array( gmdate( 'Y-m-d H:i:s', time() - $days * 86400 ) );

        if ( $sn !== '' ) {
            $where[] = 'sn = %s';
            $params[] = strtoupper( $sn );
        }
        if ( $eventTyp !== '' ) {
            $where[] = 'event_type = %s';
            $params[] = $eventTyp;
        }
        if ( $actorId > 0 ) {
            $where[] = 'actor_user_id = %d';
            $params[] = $actorId;
        }

        $where_sql = 'WHERE ' . implode( ' AND ', $where );
        $total = (int) $wpdb->get_var( $wpdb->prepare( "SELECT COUNT(*) FROM {$tbl} {$where_sql}", $params ) );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, sn, event_type, status_from, status_to, actor_user_id,
                    approver_user_id, reason, reason_category, ip_address,
                    is_sensitive, created_at
             FROM {$tbl}
             {$where_sql}
             ORDER BY created_at DESC, id DESC
             LIMIT %d OFFSET %d",
            array_merge( $params, array( $limit, $offset ) )
        ), ARRAY_A );

        // Resolve actor display names (cached per request)
        static $user_cache = array();
        $rows = array_map( function( $r ) use ( &$user_cache ) {
            foreach ( array( 'actor_user_id', 'approver_user_id' ) as $field ) {
                if ( ! empty( $r[ $field ] ) ) {
                    $uid = (int) $r[ $field ];
                    if ( ! isset( $user_cache[ $uid ] ) ) {
                        $u = get_user_by( 'id', $uid );
                        $user_cache[ $uid ] = $u ? $u->display_name : ( 'user#' . $uid );
                    }
                    $key = str_replace( '_user_id', '_display', $field );
                    $r[ $key ] = $user_cache[ $uid ];
                }
            }
            return $r;
        }, $rows ?: array() );

        return rest_ensure_response( array(
            'rows'   => $rows,
            'total'  => $total,
            'limit'  => $limit,
            'offset' => $offset,
            'days'   => $days,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_audit_export' ) ) {
    /**
     * GET /audit/export — Phase 2 W5 / V.0.13 CSV download for Tab 5.
     *
     * Same filters as /audit search. Streams up to 5,000 rows as CSV
     * (UTF-8 BOM for Excel + RFC 4180 quoting). Rate-limited via
     * b2b_rate_limit() if helper available — fail-open to prevent
     * accidental admin lockout if helper missing.
     *
     * Response is CSV (Content-Type: text/csv) — NOT JSON. WordPress
     * REST framework supports this via $response->get_data() returning
     * raw string + manual headers.
     */
    function dinoco_sn_rest_audit_export( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'audit' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'Audit table not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        // Rate limit (5/hr/user) — reuse B2B helper if available
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $uid   = (int) get_current_user_id();
            $limit = b2b_rate_limit( "sn_audit_export_{$uid}", 5, HOUR_IN_SECONDS );
            if ( is_wp_error( $limit ) ) {
                return new WP_Error( 'rate_limited',
                    __( 'Export limit reached (5/hr). Please retry later.', 'dinoco-sn' ),
                    array( 'status' => 429, 'retry_after' => 3600 ) );
            }
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'audit' );

        $sn       = trim( (string) $req->get_param( 'sn' ) );
        $eventTyp = (string) $req->get_param( 'event_type' );
        $actorId  = (int) $req->get_param( 'actor_id' );
        $days     = max( 1, min( 365, (int) $req->get_param( 'days' ) ) );
        $limit    = max( 1, min( 5000, (int) $req->get_param( 'limit' ) ) );

        $where  = array( 'created_at >= %s' );
        $params = array( gmdate( 'Y-m-d H:i:s', time() - $days * 86400 ) );

        if ( $sn !== '' ) {
            $where[] = 'sn = %s';
            $params[] = strtoupper( $sn );
        }
        if ( $eventTyp !== '' ) {
            $where[] = 'event_type = %s';
            $params[] = $eventTyp;
        }
        if ( $actorId > 0 ) {
            $where[] = 'actor_user_id = %d';
            $params[] = $actorId;
        }

        $where_sql = 'WHERE ' . implode( ' AND ', $where );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, sn, event_type, status_from, status_to, actor_user_id,
                    approver_user_id, reason, reason_category, ip_address,
                    is_sensitive, context_json, created_at
             FROM {$tbl}
             {$where_sql}
             ORDER BY created_at DESC, id DESC
             LIMIT %d",
            array_merge( $params, array( $limit ) )
        ), ARRAY_A );

        // Resolve actor display names with single batch query (N+1 defense)
        $user_ids = array();
        foreach ( $rows ?: array() as $r ) {
            if ( ! empty( $r['actor_user_id'] ) ) $user_ids[] = (int) $r['actor_user_id'];
            if ( ! empty( $r['approver_user_id'] ) ) $user_ids[] = (int) $r['approver_user_id'];
        }
        $user_ids = array_unique( $user_ids );
        $users = array();
        if ( ! empty( $user_ids ) ) {
            $u_objs = get_users( array( 'include' => $user_ids, 'fields' => array( 'ID', 'display_name', 'user_login' ) ) );
            foreach ( $u_objs as $u ) {
                $users[ (int) $u->ID ] = $u->display_name . ' (' . $u->user_login . ')';
            }
        }

        // Stream CSV — UTF-8 BOM + RFC 4180 quoting via fputcsv
        $fh = fopen( 'php://temp', 'w+' );
        // BOM for Excel UTF-8 detection
        fwrite( $fh, "\xEF\xBB\xBF" );

        // Header row
        fputcsv( $fh, array(
            'id', 'created_at', 'sn', 'event_type',
            'status_from', 'status_to',
            'actor_user_id', 'actor_display',
            'approver_user_id', 'approver_display',
            'reason_category', 'reason',
            'is_sensitive', 'ip_address', 'context_json',
        ) );

        foreach ( $rows ?: array() as $r ) {
            fputcsv( $fh, array(
                (int) $r['id'],
                (string) $r['created_at'],
                (string) $r['sn'],
                (string) $r['event_type'],
                (string) $r['status_from'],
                (string) $r['status_to'],
                (int) $r['actor_user_id'],
                $users[ (int) $r['actor_user_id'] ] ?? '',
                (int) $r['approver_user_id'],
                $users[ (int) $r['approver_user_id'] ] ?? '',
                (string) $r['reason_category'],
                (string) $r['reason'],
                (int) $r['is_sensitive'],
                (string) $r['ip_address'],
                (string) $r['context_json'],
            ) );
        }

        rewind( $fh );
        $csv = stream_get_contents( $fh );
        fclose( $fh );

        // Build filename — sn_audit_YYYY-MM-DD_HHMMSS.csv
        $filename = 'sn_audit_' . gmdate( 'Y-m-d_His' ) . '.csv';

        $resp = new WP_REST_Response( $csv, 200 );
        $resp->header( 'Content-Type', 'text/csv; charset=utf-8' );
        $resp->header( 'Content-Disposition', 'attachment; filename="' . $filename . '"' );
        $resp->header( 'X-Content-Type-Options', 'nosniff' );
        $resp->header( 'X-Audit-Row-Count', (string) count( $rows ?: array() ) );

        return $resp;
    }
}

