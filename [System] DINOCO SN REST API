if ( ! function_exists( 'dinoco_sn_handler_marketplace_upload_slip' ) ) {
    function dinoco_sn_handler_marketplace_upload_slip( $req ) {
        global $wpdb;
        $extension_id  = (int) $req->get_param( 'id' );
        $slip_image_id = (int) $req->get_param( 'slip_image_id' );
        $user_id       = get_current_user_id();

        if ( $extension_id <= 0 || $slip_image_id <= 0 ) {
            return new WP_Error( 'invalid_input', __( 'id + slip_image_id required', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        // Verify slip media is owned by user (or admin)
        $att = get_post( $slip_image_id );
        if ( ! $att || $att->post_type !== 'attachment' ) {
            return new WP_Error( 'slip_not_found', __( 'Slip image not found', 'dinoco-sn' ), array( 'status' => 404 ) );
        }
        if ( (int) $att->post_author !== $user_id && ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'slip_not_yours', __( 'Slip image not owned by you', 'dinoco-sn' ), array( 'status' => 403 ) );
        }

        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'extensions' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'extensions table missing', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        $tbl = dinoco_sn_table( 'extensions' );

        $lock_name = "dinoco_sn_extend_slip_{$extension_id}";
        $lock_acquired = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_name, 5 ) );
        if ( $lock_acquired !== '1' ) {
            return new WP_Error( 'db_lock_timeout', __( 'Cannot acquire slip lock — try again', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        $wpdb->query( 'START TRANSACTION' );
        try {
            $ext = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl} WHERE id = %d FOR UPDATE", $extension_id
            ) );
            if ( ! $ext ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return new WP_Error( 'extension_not_found', __( 'Extension not found', 'dinoco-sn' ), array( 'status' => 404 ) );
            }
            // Owner check
            if ( (int) $ext->user_id !== $user_id && ! current_user_can( 'manage_options' ) ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return new WP_Error( 'not_yours', __( 'Extension not yours', 'dinoco-sn' ), array( 'status' => 403 ) );
            }
            // Idempotent: if not pending_payment, return current state without re-processing
            if ( $ext->payment_status !== 'pending_payment' ) {
                $wpdb->query( 'ROLLBACK' );
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return rest_ensure_response( array(
                    'success'           => true,
                    'idempotent'        => true,
                    'extension_id'      => $extension_id,
                    'status'            => $ext->payment_status,
                    'status_reason'     => 'already_processed',
                    'new_warranty_end'  => $ext->payment_status === 'paid' ? $ext->warranty_until_new : null,
                ) );
            }

            // Slip2Go verify (Q7 reuse) — defensive
            $slip_url = wp_get_attachment_url( $slip_image_id );
            $expected_amount = (float) $ext->price_paid;
            $verify_ok = false;
            $verify_reason = 'verify_helper_unavailable';
            if ( function_exists( 'b2b_verify_slip_image' ) && $slip_url ) {
                try {
                    $verify_result = b2b_verify_slip_image( $slip_url, $expected_amount );
                    if ( is_array( $verify_result ) ) {
                        $verify_ok = ! empty( $verify_result['verified'] );
                        $verify_reason = (string) ( $verify_result['reason'] ?? ( $verify_ok ? 'auto_verified' : 'amount_mismatch' ) );
                    } elseif ( $verify_result === true ) {
                        $verify_ok = true;
                        $verify_reason = 'auto_verified';
                    } else {
                        $verify_ok = false;
                        $verify_reason = 'slip2go_failed';
                    }
                } catch ( \Throwable $e ) {
                    $verify_ok = false;
                    $verify_reason = 'slip2go_exception';
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'marketplace_slip_verify', 'extension_id' => $extension_id ) );
                    }
                }
            }

            $now = current_time( 'mysql' );
            if ( $verify_ok ) {
                // Auto-approve → flip paid
                $wpdb->update( $tbl, array(
                    'payment_status'     => 'paid',
                    'paid_at'            => $now,
                    'receipt_invoice_id' => $slip_image_id,
                ), array( 'id' => $extension_id ),
                   array( '%s', '%s', '%d' ),
                   array( '%d' ) );
                $wpdb->query( 'COMMIT' );

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log( $ext->sn, 'extension_paid', 'pending_payment', 'paid', array(
                        'extension_id' => $extension_id,
                        'verify_reason' => $verify_reason,
                    ), $user_id, null, '', 'auto_verified', false );
                }

                // Apply warranty extension atomically (W15.4)
                $apply_result = function_exists( 'dinoco_sn_apply_warranty_extension' )
                    ? dinoco_sn_apply_warranty_extension( $extension_id )
                    : array( 'success' => false, 'error' => 'apply_helper_missing' );

                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return rest_ensure_response( array(
                    'success'          => true,
                    'extension_id'     => $extension_id,
                    'status'           => 'paid',
                    'status_reason'    => $verify_reason,
                    'new_warranty_end' => isset( $apply_result['new_warranty_end'] ) ? $apply_result['new_warranty_end'] : $ext->warranty_until_new,
                    'apply_result'     => $apply_result,
                ) );
            } else {
                // Pending admin review
                $wpdb->update( $tbl, array(
                    'payment_status'     => 'pending_admin_review',
                    'receipt_invoice_id' => $slip_image_id,
                ), array( 'id' => $extension_id ),
                   array( '%s', '%d' ),
                   array( '%d' ) );
                $wpdb->query( 'COMMIT' );

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log( $ext->sn, 'extension_pending_admin_review', 'pending_payment', 'pending_admin_review', array(
                        'extension_id'  => $extension_id,
                        'verify_reason' => $verify_reason,
                    ), $user_id, null, '', 'slip_review', false );
                }

                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return rest_ensure_response( array(
                    'success'        => true,
                    'extension_id'   => $extension_id,
                    'status'         => 'pending_admin_review',
                    'status_reason'  => $verify_reason,
                ) );
            }
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'marketplace_upload_slip', 'extension_id' => $extension_id ) );
            }
            return new WP_Error( 'upload_slip_failed', $e->getMessage(), array( 'status' => 500 ) );
        }
    }
}

