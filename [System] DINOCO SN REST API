/* ═══════════════════════════════════════════════════════════════════════════
 * 9. PHASE 3 W10 — F#9 CUSTOMER LTV DASHBOARD HANDLERS
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * Reads from wp_dinoco_sn_customer_ltv_snapshot (populated by daily cron).
 * Admin-only. PII (phone/email) auto-masked unless dinoco_sn_view_pii cap.
 */

if ( ! function_exists( 'dinoco_sn_rest_ltv_list' ) ) {
    /**
     * GET /ltv/list?tier=&limit=&offset= — top customers by lifetime spend.
     */
    function dinoco_sn_rest_ltv_list( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'ltv_snapshot' ) ) {
            return rest_ensure_response( array( 'rows' => array(), 'total' => 0,
                'note' => 'ltv_snapshot table not installed (run cron once)' ) );
        }

        global $wpdb;
        $tbl   = dinoco_sn_table( 'ltv_snapshot' );
        $tier  = sanitize_key( (string) $req->get_param( 'tier' ) );
        $limit = max( 1, min( 200, (int) $req->get_param( 'limit' ) ) );
        $offset = max( 0, (int) $req->get_param( 'offset' ) );

        $allowed_tiers = array( 'bronze', 'silver', 'gold', 'platinum', 'diamond' );
        $where  = '';
        $params = array();
        if ( $tier !== '' && in_array( $tier, $allowed_tiers, true ) ) {
            $where = 'WHERE loyalty_tier = %s';
            $params[] = $tier;
        }

        $count_sql = "SELECT COUNT(*) FROM {$tbl} {$where}";
        $list_sql  = "SELECT user_id, plates_count, registered_count, active_warranties_count,
                             total_lifetime_spent, first_purchase_date, last_purchase_date,
                             claim_count, loyalty_tier, computed_at
                      FROM {$tbl}
                      {$where}
                      ORDER BY total_lifetime_spent DESC, user_id ASC
                      LIMIT %d OFFSET %d";

        $total = (int) ( $params
            ? $wpdb->get_var( $wpdb->prepare( $count_sql, $params ) )
            : $wpdb->get_var( $count_sql ) );

        $list_params = array_merge( $params, array( $limit, $offset ) );
        $rows = $wpdb->get_results( $wpdb->prepare( $list_sql, $list_params ), ARRAY_A );

        // Resolve display names + PII gate
        $can_pii = function_exists( 'dinoco_sn_user_can_view_pii' ) && dinoco_sn_user_can_view_pii();
        $rows = array_map( function( $r ) use ( $can_pii ) {
            $uid = (int) $r['user_id'];
            $u = $uid ? get_user_by( 'id', $uid ) : null;
            $r['user_id']           = $uid;
            $r['display_name']      = $u ? $u->display_name : ( 'user#' . $uid );
            $r['email']             = ( $u && $can_pii )
                ? $u->user_email
                : ( $u ? preg_replace( '/(.).*(@.*)/', '$1***$2', (string) $u->user_email ) : null );
            $r['plates_count']            = (int) $r['plates_count'];
            $r['registered_count']        = (int) $r['registered_count'];
            $r['active_warranties_count'] = (int) $r['active_warranties_count'];
            $r['claim_count']             = (int) $r['claim_count'];
            $r['total_lifetime_spent']    = (float) $r['total_lifetime_spent'];
            return $r;
        }, $rows ?: array() );

        // Tier distribution summary (single-pass aggregation)
        $tier_dist = $wpdb->get_results(
            "SELECT loyalty_tier, COUNT(*) AS n FROM {$tbl} GROUP BY loyalty_tier",
            ARRAY_A
        );
        $tier_summary = array();
        foreach ( $allowed_tiers as $t ) { $tier_summary[ $t ] = 0; }
        foreach ( $tier_dist ?: array() as $td ) {
            $tier_summary[ $td['loyalty_tier'] ] = (int) $td['n'];
        }

        return rest_ensure_response( array(
            'rows'         => $rows,
            'total'        => $total,
            'limit'        => $limit,
            'offset'       => $offset,
            'tier_summary' => $tier_summary,
            'pii_visible'  => $can_pii,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_ltv_detail' ) ) {
    /**
     * GET /ltv/{user_id} — full detail with plate list + summary.
     */
    function dinoco_sn_rest_ltv_detail( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }
        $user_id = (int) $req->get_param( 'user_id' );
        if ( $user_id <= 0 ) {
            return new WP_Error( 'invalid_user', __( 'Invalid user_id.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        global $wpdb;
        $u = get_user_by( 'id', $user_id );
        if ( ! $u ) {
            return new WP_Error( 'user_not_found', __( 'User not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
        }

        $can_pii = function_exists( 'dinoco_sn_user_can_view_pii' ) && dinoco_sn_user_can_view_pii();

        // LTV snapshot (may be null if cron hasn't run for this user)
        $snapshot = null;
        if ( dinoco_sn_table_exists( 'ltv_snapshot' ) ) {
            $tbl = dinoco_sn_table( 'ltv_snapshot' );
            $snapshot = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl} WHERE user_id = %d", $user_id
            ), ARRAY_A );
            if ( $snapshot ) {
                foreach ( array( 'plates_count', 'registered_count',
                    'active_warranties_count', 'claim_count' ) as $k ) {
                    $snapshot[ $k ] = (int) $snapshot[ $k ];
                }
                $snapshot['total_lifetime_spent'] = (float) $snapshot['total_lifetime_spent'];
            }
        }

        // Plates owned (top 50 most recent)
        $plates = array();
        if ( dinoco_sn_table_exists( 'pool' ) ) {
            $pool = dinoco_sn_table( 'pool' );
            $plates = $wpdb->get_results( $wpdb->prepare(
                "SELECT sn, status, linked_sku, registered_at
                 FROM {$pool}
                 WHERE registered_user_id = %d
                 ORDER BY registered_at DESC
                 LIMIT 50",
                $user_id
            ), ARRAY_A );
        }

        // Phase 3 W10 — F#9 LTV detail expansion (v2.10 spec):
        // Add claims + reviews + cross-sell suggestion. All best-effort:
        // sources may not be installed → graceful empty array.

        // Claims — read claim_ticket CPT directly (Service Center / Claim
        // System integration). Filter by post_author = $user_id since
        // [System] DINOCO Claim System line 173 sets post_author on submit.
        $claims = array();
        $claim_post_type_exists = post_type_exists( 'claim_ticket' );
        if ( $claim_post_type_exists ) {
            $q = new WP_Query( array(
                'post_type'      => 'claim_ticket',
                'post_status'    => 'any',
                'author'         => $user_id,
                'posts_per_page' => 20,
                'orderby'        => 'date',
                'order'          => 'DESC',
                'fields'         => 'ids',
                'no_found_rows'  => true,
            ) );
            if ( ! is_wp_error( $q ) && ! empty( $q->posts ) ) {
                // Prime meta cache (Round 15 ITEM A pattern — N+1 defense)
                update_meta_cache( 'post', $q->posts );
                foreach ( $q->posts as $cid ) {
                    $sn   = (string) get_post_meta( $cid, 'warranty_serial', true );
                    if ( $sn === '' ) {
                        $sn = (string) get_post_meta( $cid, 'serial_code', true );
                    }
                    $claims[] = array(
                        'claim_id'      => (int) $cid,
                        'ticket_status' => (string) get_post_meta( $cid, 'ticket_status', true ),
                        'sn'            => strtoupper( $sn ),
                        'created_at'    => get_post_field( 'post_date', $cid ),
                        'product_name'  => (string) get_post_meta( $cid, 'product_name', true ),
                    );
                }
            }
            wp_reset_postdata();
        }

        // Reviews — best-effort read of completed review_requests for this user
        $reviews = array();
        if ( dinoco_sn_table_exists( 'review_requests' ) ) {
            $rr_tbl = dinoco_sn_table( 'review_requests' );
            $reviews = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, sn, rating, status, scheduled_at, sent_at, reviewed_at
                 FROM {$rr_tbl}
                 WHERE user_id = %d
                 ORDER BY COALESCE(reviewed_at, sent_at, scheduled_at) DESC
                 LIMIT 20",
                $user_id
            ), ARRAY_A );
            $reviews = array_map( function( $r ) {
                return array(
                    'review_request_id' => (int) $r['id'],
                    'sn'                => strtoupper( (string) $r['sn'] ),
                    'rating'            => $r['rating'] !== null ? (int) $r['rating'] : null,
                    'status'            => (string) $r['status'],
                    'scheduled_at'      => $r['scheduled_at'],
                    'sent_at'           => $r['sent_at'],
                    'reviewed_at'       => $r['reviewed_at'],
                );
            }, $reviews ?: array() );
        }

        // Cross-sell suggestion — derive from current plate ownership.
        // Strategy: top-set frequency among other Diamond/Platinum customers
        // (collaborative filter). For Phase 3 stub we use simpler approach:
        // surface SKUs the customer hasn't bought yet that share compatible
        // motorcycle models with current plates. Defers ML to Phase 4 W14.
        $cross_sell = array();
        if ( ! empty( $plates ) && function_exists( 'DINOCO_Catalog::get_by_skus' ) ) {
            // Best-effort — only run if catalog helper available
            $owned_skus = array();
            foreach ( $plates as $p ) {
                if ( ! empty( $p['linked_sku'] ) ) {
                    $owned_skus[ strtoupper( $p['linked_sku'] ) ] = true;
                }
            }
            $cross_sell = array(
                'owned_distinct' => count( $owned_skus ),
                'note'           => 'Phase 4 W14 ML-driven recommendation (collaborative filter on tier peers). Currently shows count only.',
            );
        }

        return rest_ensure_response( array(
            'user' => array(
                'user_id'      => (int) $u->ID,
                'display_name' => $u->display_name,
                'email'        => $can_pii
                    ? $u->user_email
                    : preg_replace( '/(.).*(@.*)/', '$1***$2', (string) $u->user_email ),
                'registered_at' => $u->user_registered,
            ),
            'snapshot'    => $snapshot,
            'plates'      => $plates ?: array(),
            'claims'      => $claims,
            'reviews'     => $reviews,
            'cross_sell'  => $cross_sell,
            'pii_visible' => $can_pii,
            'fetched_at'  => current_time( 'c' ),
        ) );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 10. PHASE 3 W11 — F#14 STOLEN PLATE REGISTRY HANDLERS
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * Two-sided system:
 *   - Customer-side: owner reports stolen via member dashboard (Phase 3 W11
 *     deferred — current scope = REST endpoint only, member UI later)
 *   - Admin-side: review queue + verify/recover/close decisions
 *   - Public verify: police/insurance/dealer check before second-hand purchase
 *
 * Cross-system effect:
 *   On stolen report → also create "recall" event with category=stolen
 *   so existing /recall workflow handles plate state. Anti-fraud (Phase 3
 *   W10 F#12) reads sn_pool.stolen_at + sn_stolen_log to block activation.
 *
 * PII protection:
 *   - /stolen/list (admin): includes police info, status, dates
 *   - /stolen/verify (public): returns ONLY {is_stolen: bool, reported_at}
 *     — no police_report_no / no station / no description
 */

if ( ! function_exists( 'dinoco_sn_rest_stolen_report' ) ) {
    function dinoco_sn_rest_stolen_report( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'stolen-report',
            array( 'sn', 'police_report_no', 'police_station', 'incident_date' ),
            function( $req ) {
                global $wpdb;
                $sn       = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
                $police_no = trim( (string) $req->get_param( 'police_report_no' ) );
                $station  = trim( (string) $req->get_param( 'police_station' ) );
                $incident = trim( (string) $req->get_param( 'incident_date' ) );
                $desc     = trim( (string) $req->get_param( 'description' ) );
                $reporter = (int) get_current_user_id();

                if ( $sn === '' ) {
                    return new WP_Error( 'invalid_input', __( 'sn required.', 'dinoco-sn' ), array( 'status' => 400 ) );
                }
                if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
                    return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
                }
                if ( ! dinoco_sn_table_exists( 'pool' ) || ! dinoco_sn_table_exists( 'stolen_log' ) ) {
                    return new WP_Error( 'schema_not_ready',
                        __( 'sn_stolen_log not installed.', 'dinoco-sn' ),
                        array( 'status' => 503 ) );
                }

                $pool       = dinoco_sn_table( 'pool' );
                $stolen_tbl = dinoco_sn_table( 'stolen_log' );
                $is_admin   = current_user_can( 'manage_options' );

                $wpdb->query( 'START TRANSACTION' );
                try {
                    $row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT sn, status, registered_user_id FROM {$pool} WHERE sn = %s FOR UPDATE",
                        $sn
                    ), ARRAY_A );

                    if ( ! $row ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sn_not_found',
                            __( 'S/N not in pool.', 'dinoco-sn' ),
                            array( 'status' => 404 ) );
                    }

                    // Permission: customer can only report own plate; admin any
                    $owner_id = (int) ( $row['registered_user_id'] ?? 0 );
                    if ( ! $is_admin && $owner_id !== $reporter ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'rest_forbidden',
                            __( 'You can only report your own plate as stolen.', 'dinoco-sn' ),
                            array( 'status' => 403 ) );
                    }

                    if ( in_array( $row['status'], array( 'voided', 'recalled' ), true ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'already_terminal',
                            sprintf( __( 'S/N already %s.', 'dinoco-sn' ), $row['status'] ),
                            array( 'status' => 409 ) );
                    }

                    if ( ! in_array( $row['status'], array( 'registered', 'claimed', 'shipped', 'allocated_to_order' ), true ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'invalid_state',
                            sprintf( __( 'Cannot report stolen for status %s.', 'dinoco-sn' ), $row['status'] ),
                            array( 'status' => 422 ) );
                    }

                    $now = current_time( 'mysql' );

                    // Insert stolen log row
                    $ok = $wpdb->insert( $stolen_tbl, array(
                        'sn'               => $sn,
                        'user_id'          => $owner_id ?: null,
                        'reported_by'      => $reporter,
                        'police_report_no' => $police_no ?: null,
                        'police_station'   => $station ?: null,
                        'incident_date'    => $incident ?: null,
                        'description'      => $desc ?: null,
                        'status'           => 'reported',
                        'created_at'       => $now,
                    ) );
                    if ( ! $ok ) {
                        throw new \RuntimeException( 'stolen_log insert failed' );
                    }
                    $stolen_id = (int) $wpdb->insert_id;

                    // Flip plate to recalled + record stolen_at
                    $upd = $wpdb->update( $pool, array(
                        'status'              => 'recalled',
                        'prev_status'         => $row['status'],
                        'stolen_at'           => $now,
                        'stolen_police_report' => $police_no ?: null,
                        'recalled_at'         => $now,
                    ), array( 'sn' => $sn, 'status' => $row['status'] ) );

                    if ( $upd === false || $upd === 0 ) {
                        throw new \RuntimeException( 'pool update failed (concurrent modification)' );
                    }

                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log( $sn, 'plate_recalled', $row['status'], 'recalled',
                            array(
                                'category'         => 'stolen',
                                'stolen_log_id'    => $stolen_id,
                                'reporter_user_id' => $reporter,
                                'police_report_no' => $police_no,
                            ),
                            $reporter, null,
                            $desc ?: 'reported stolen by ' . ( $is_admin ? 'admin' : 'owner' ),
                            'stolen_report', true );
                    }

                    $wpdb->query( 'COMMIT' );

                    return rest_ensure_response( array(
                        'success'         => true,
                        'stolen_log_id'   => $stolen_id,
                        'sn'              => $sn,
                        'status_to'       => 'recalled',
                        'is_admin_report' => $is_admin,
                    ) );
                } catch ( \Throwable $e ) {
                    $wpdb->query( 'ROLLBACK' );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'sn_stolen_report', 'sn' => $sn ) );
                    }
                    return new WP_Error( 'stolen_report_failed', $e->getMessage(), array( 'status' => 500 ) );
                }
            }
        );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_stolen_list' ) ) {
    function dinoco_sn_rest_stolen_list( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'stolen_log' ) ) {
            return rest_ensure_response( array( 'rows' => array(), 'total' => 0 ) );
        }
        global $wpdb;
        $tbl = dinoco_sn_table( 'stolen_log' );

        $status = sanitize_key( (string) $req->get_param( 'status' ) );
        $limit  = max( 1, min( 200, (int) $req->get_param( 'limit' ) ) );
        $offset = max( 0, (int) $req->get_param( 'offset' ) );

        $allowed_statuses = array( 'reported', 'verified', 'recovered', 'closed' );
        $where = '';
        $params = array();
        if ( $status !== '' && in_array( $status, $allowed_statuses, true ) ) {
            $where = 'WHERE status = %s';
            $params[] = $status;
        }

        $count_sql = "SELECT COUNT(*) FROM {$tbl} {$where}";
        $list_sql  = "SELECT id, sn, user_id, reported_by, police_report_no, police_station,
                             incident_date, status, created_at,
                             SUBSTRING(description, 1, 200) AS description_excerpt
                      FROM {$tbl}
                      {$where}
                      ORDER BY created_at DESC, id DESC
                      LIMIT %d OFFSET %d";

        $total = (int) ( $params
            ? $wpdb->get_var( $wpdb->prepare( $count_sql, $params ) )
            : $wpdb->get_var( $count_sql ) );

        $list_params = array_merge( $params, array( $limit, $offset ) );
        $rows = $wpdb->get_results( $wpdb->prepare( $list_sql, $list_params ), ARRAY_A );

        // Resolve display names
        static $user_cache = array();
        $rows = array_map( function( $r ) use ( &$user_cache ) {
            foreach ( array( 'user_id', 'reported_by' ) as $field ) {
                if ( ! empty( $r[ $field ] ) ) {
                    $uid = (int) $r[ $field ];
                    if ( ! isset( $user_cache[ $uid ] ) ) {
                        $u = get_user_by( 'id', $uid );
                        $user_cache[ $uid ] = $u ? $u->display_name : ( 'user#' . $uid );
                    }
                    $key = str_replace( '_id', '_display', $field );
                    $r[ $key ] = $user_cache[ $uid ];
                }
            }
            return $r;
        }, $rows ?: array() );

        // Status distribution summary
        $status_dist = $wpdb->get_results(
            "SELECT status, COUNT(*) AS n FROM {$tbl} GROUP BY status",
            ARRAY_A
        );
        $status_summary = array();
        foreach ( $allowed_statuses as $s ) { $status_summary[ $s ] = 0; }
        foreach ( $status_dist ?: array() as $sd ) {
            $status_summary[ $sd['status'] ] = (int) $sd['n'];
        }

        return rest_ensure_response( array(
            'rows'           => $rows,
            'total'          => $total,
            'limit'          => $limit,
            'offset'         => $offset,
            'status_summary' => $status_summary,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_stolen_decision' ) ) {
    /**
     * POST /stolen/{id}/decision — admin verify/recover/close.
     *
     * Decisions:
     *   verified   — admin confirmed report legit (insurance can claim)
     *   recovered  — plate found, customer confirmed return → unlock plate
     *   closed     — case closed without recovery (insurance paid out, etc.)
     *
     * On 'recovered': revert sn_pool from recalled → registered (if owner
     *   still wants warranty, plate continues serving same warranty).
     */
    function dinoco_sn_rest_stolen_decision( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'stolen-decision',
            array( 'id', 'decision' ),
            function( $req ) {
                global $wpdb;
                $id       = (int) $req->get_param( 'id' );
                $decision = sanitize_key( (string) $req->get_param( 'decision' ) );
                $notes    = trim( (string) $req->get_param( 'notes' ) );

                $allowed = array( 'verified', 'recovered', 'closed' );
                if ( ! in_array( $decision, $allowed, true ) ) {
                    return new WP_Error( 'invalid_decision',
                        sprintf( __( 'decision must be one of: %s', 'dinoco-sn' ), implode( ', ', $allowed ) ),
                        array( 'status' => 400 ) );
                }
                if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
                    return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
                }
                if ( ! dinoco_sn_table_exists( 'stolen_log' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                    return new WP_Error( 'schema_not_ready', '', array( 'status' => 503 ) );
                }

                $stolen_tbl = dinoco_sn_table( 'stolen_log' );
                $pool       = dinoco_sn_table( 'pool' );

                $wpdb->query( 'START TRANSACTION' );
                try {
                    $row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT id, sn, status FROM {$stolen_tbl} WHERE id = %d FOR UPDATE",
                        $id
                    ), ARRAY_A );
                    if ( ! $row ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'not_found', __( 'Stolen log not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
                    }
                    if ( $row['status'] === $decision ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'already_in_state',
                            sprintf( __( 'Already %s.', 'dinoco-sn' ), $decision ),
                            array( 'status' => 409 ) );
                    }
                    if ( $row['status'] === 'closed' ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'closed_terminal',
                            __( 'Closed cases cannot be reopened via decision.', 'dinoco-sn' ),
                            array( 'status' => 422 ) );
                    }

                    $upd = $wpdb->update( $stolen_tbl,
                        array( 'status' => $decision ),
                        array( 'id' => $id, 'status' => $row['status'] )
                    );
                    if ( $upd === false || $upd === 0 ) {
                        throw new \RuntimeException( 'stolen_log update failed (concurrent modification)' );
                    }

                    // On 'recovered' — unlock plate back to registered
                    if ( $decision === 'recovered' ) {
                        $pool_row = $wpdb->get_row( $wpdb->prepare(
                            "SELECT prev_status FROM {$pool} WHERE sn = %s FOR UPDATE",
                            $row['sn']
                        ), ARRAY_A );
                        if ( $pool_row && in_array( $pool_row['prev_status'], array( 'registered', 'claimed' ), true ) ) {
                            $wpdb->update( $pool, array(
                                'status'      => $pool_row['prev_status'],
                                'stolen_at'   => null,
                                'recalled_at' => null,
                            ), array( 'sn' => $row['sn'] ) );
                        }
                    }

                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log( $row['sn'], 'plate_recalled',  // reuse event_type
                            $row['status'], $decision,
                            array(
                                'stolen_log_id' => $id,
                                'decision'      => $decision,
                            ),
                            null, null, $notes ?: '', 'stolen_' . $decision, true );
                    }

                    $wpdb->query( 'COMMIT' );
                    return rest_ensure_response( array(
                        'success'  => true,
                        'id'       => $id,
                        'sn'       => $row['sn'],
                        'decision' => $decision,
                    ) );
                } catch ( \Throwable $e ) {
                    $wpdb->query( 'ROLLBACK' );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'sn_stolen_decision', 'id' => $id ) );
                    }
                    return new WP_Error( 'decision_failed', $e->getMessage(), array( 'status' => 500 ) );
                }
            }
        );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_stolen_verify' ) ) {
    /**
     * GET /stolen/verify/{sn} — PUBLIC rate-limited check.
     *
     * For police / insurance / dealer to verify plate before second-hand
     * resale. Returns boolean only — no PII, no police info, no description.
     *
     * Anti-abuse: rate-limited 30/min/IP via dinoco_sn_perm_public.
     */
    function dinoco_sn_rest_stolen_verify( $req ) {
        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        if ( $sn === '' ) {
            return new WP_Error( 'invalid_sn', '', array( 'status' => 400 ) );
        }
        if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }
        if ( ! dinoco_sn_table_exists( 'pool' ) ) {
            return rest_ensure_response( array( 'sn' => $sn, 'is_stolen' => false, 'note' => 'system not active' ) );
        }

        // 5-minute cache (less frequent updates than /lookup)
        $cache_key = 'dinoco_sn_stolen_v_' . md5( $sn );
        $cached = get_transient( $cache_key );
        if ( $cached !== false ) {
            return rest_ensure_response( $cached );
        }

        global $wpdb;
        $pool = dinoco_sn_table( 'pool' );
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT status, stolen_at FROM {$pool} WHERE sn = %s",
            $sn
        ), ARRAY_A );

        // Boolean-only response — no PII oracle leak
        $resp = array(
            'sn'        => $sn,
            'is_stolen' => false,
            'reported_at' => null,
        );

        if ( $row && $row['status'] === 'recalled' && ! empty( $row['stolen_at'] ) ) {
            $resp['is_stolen'] = true;
            // Date-only (YYYY-MM-DD) — no time precision to avoid timing oracle
            $resp['reported_at'] = date( 'Y-m-d', strtotime( $row['stolen_at'] ) );
        }

        set_transient( $cache_key, $resp, 5 * MINUTE_IN_SECONDS );
        return rest_ensure_response( $resp );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 11. PHASE 3 W11 — F#13 GEOGRAPHIC HEATMAP HANDLERS
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * Reads from wp_dinoco_sn_geo_activations table (populated by activate flow
 * + weekly gray-market scan cron).
 *
 * Phase 3 W11 stub:
 *   - /geo/heatmap aggregates by province + date range + optional SKU
 *   - /geo/gray-market returns provinces flagged is_gray_market_suspect=1
 *
 * Phase 4 W12+ adds:
 *   - IP geolocation library integration (currently relies on activate
 *     flow inserting rows manually — Phase 3 W11 = read-only viewer)
 *   - Leaflet/Mapbox UI in admin Tab 8 (deferred)
 *   - Weekly cron auto-detect gray market suspects
 */

if ( ! function_exists( 'dinoco_sn_rest_geo_heatmap' ) ) {
    function dinoco_sn_rest_geo_heatmap( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'geo_activations' ) ) {
            return rest_ensure_response( array(
                'rows' => array(),
                'total' => 0,
                'note' => 'geo_activations table not installed (Phase 4 wires activate hook)',
            ) );
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'geo_activations' );

        $from      = trim( (string) $req->get_param( 'from' ) );
        $to        = trim( (string) $req->get_param( 'to' ) );
        $sku       = strtoupper( trim( (string) $req->get_param( 'sku' ) ) );
        $batch     = trim( (string) $req->get_param( 'batch' ) );
        $gray_only = (bool) $req->get_param( 'gray_only' );

        $where  = array();
        $params = array();
        if ( $from !== '' && preg_match( '/^\d{4}-\d{2}-\d{2}$/', $from ) ) {
            $where[] = 'g.created_at >= %s';
            $params[] = $from . ' 00:00:00';
        }
        if ( $to !== '' && preg_match( '/^\d{4}-\d{2}-\d{2}$/', $to ) ) {
            $where[] = 'g.created_at <= %s';
            $params[] = $to . ' 23:59:59';
        }
        if ( $gray_only ) {
            $where[] = 'g.is_gray_market_suspect = 1';
        }

        $sku_join = '';
        if ( ( $sku !== '' || $batch !== '' ) && function_exists( 'dinoco_sn_table' ) ) {
            $pool = dinoco_sn_table( 'pool' );
            $sku_join = "INNER JOIN {$pool} p ON p.sn = g.sn";
            if ( $sku !== '' ) {
                $sku_join .= " AND p.linked_sku = %s";
                $params[] = $sku;
            }
            if ( $batch !== '' ) {
                $where[] = 'p.batch_id = %s';
                $params[] = $batch;
            }
        }

        $where_sql = $where ? ( 'WHERE ' . implode( ' AND ', $where ) ) : '';

        $sql = "SELECT g.province,
                       COUNT(*) AS activations,
                       SUM(g.is_gray_market_suspect) AS gray_market_count,
                       AVG(g.lat) AS avg_lat,
                       AVG(g.lng) AS avg_lng
                FROM {$tbl} g
                {$sku_join}
                {$where_sql}
                GROUP BY g.province
                ORDER BY activations DESC
                LIMIT 100";

        $rows = $params
            ? $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A )
            : $wpdb->get_results( $sql, ARRAY_A );

        $rows = array_map( function( $r ) {
            return array(
                'province'         => $r['province'],
                'activations'      => (int) $r['activations'],
                'gray_market_count' => (int) $r['gray_market_count'],
                'avg_lat'          => $r['avg_lat'] !== null ? (float) $r['avg_lat'] : null,
                'avg_lng'          => $r['avg_lng'] !== null ? (float) $r['avg_lng'] : null,
            );
        }, $rows ?: array() );

        // Total count for sanity (unfiltered)
        $total_count = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$tbl}" );

        return rest_ensure_response( array(
            'rows'           => $rows,
            'province_count' => count( $rows ),
            'total_records'  => $total_count,
            'filter'         => array(
                'from'      => $from ?: null,
                'to'        => $to ?: null,
                'sku'       => $sku ?: null,
                'batch'     => $batch ?: null,
                'gray_only' => $gray_only,
            ),
            'fetched_at'     => current_time( 'c' ),
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_geo_province_detail' ) ) {
    /**
     * Phase 3 W11.1 — F#13 drill-down per province.
     *
     * Returns activation_count + top_skus[] + line_regions[] + sample_plates[]
     * + gray_market_flag for sidebar rendering.
     *
     * Permission: manage_options (admin-only — handled by `dinoco_sn_perm_admin`).
     * PII: sample_plates returns SN + created_at only (no owner_user_id, no IP).
     */
    function dinoco_sn_rest_geo_province_detail( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' )
            || ! dinoco_sn_table_exists( 'geo_activations' )
            || ! dinoco_sn_table_exists( 'pool' ) ) {
            return rest_ensure_response( array(
                'success' => false,
                'note'    => 'geo_activations table not installed',
            ) );
        }
        global $wpdb;
        $tbl_geo  = dinoco_sn_table( 'geo_activations' );
        $tbl_pool = dinoco_sn_table( 'pool' );

        $province = trim( (string) $req->get_param( 'province' ) );
        $days     = max( 1, min( 365, (int) $req->get_param( 'days' ) ) );

        if ( $province === '' ) {
            return new WP_Error( 'invalid_province', 'Province required', array( 'status' => 400 ) );
        }

        // Activation count in window
        $count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$tbl_geo}
             WHERE province = %s
               AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)",
            $province, $days
        ) );

        // Gray market flag
        $gray_count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$tbl_geo}
             WHERE province = %s
               AND is_gray_market_suspect = 1
               AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)",
            $province, $days
        ) );

        // Top 5 SKUs joined via pool.linked_sku
        $top_skus = $wpdb->get_results( $wpdb->prepare(
            "SELECT p.linked_sku AS sku, COUNT(*) AS count
             FROM {$tbl_geo} g
             INNER JOIN {$tbl_pool} p ON p.sn = g.sn
             WHERE g.province = %s
               AND g.created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
               AND p.linked_sku IS NOT NULL
             GROUP BY p.linked_sku
             ORDER BY count DESC
             LIMIT 5",
            $province, $days
        ), ARRAY_A );

        $top_skus = array_map( function( $r ) {
            return array( 'sku' => (string) $r['sku'], 'count' => (int) $r['count'] );
        }, $top_skus ?: array() );

        // LINE region distribution (best-effort — column may not exist in older schema)
        $line_regions = array();
        $col_exists = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM INFORMATION_SCHEMA.COLUMNS
             WHERE TABLE_SCHEMA = DATABASE()
               AND TABLE_NAME = %s
               AND COLUMN_NAME = 'line_region'",
            $tbl_geo
        ) );
        if ( $col_exists > 0 ) {
            $line_regions = $wpdb->get_results( $wpdb->prepare(
                "SELECT line_region AS region, COUNT(*) AS count
                 FROM {$tbl_geo}
                 WHERE province = %s
                   AND line_region IS NOT NULL
                   AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
                 GROUP BY line_region
                 ORDER BY count DESC
                 LIMIT 5",
                $province, $days
            ), ARRAY_A );
            $line_regions = array_map( function( $r ) {
                return array( 'region' => (string) $r['region'], 'count' => (int) $r['count'] );
            }, $line_regions ?: array() );
        }

        // Sample plates (10 most recent — SN + timestamp only, no PII)
