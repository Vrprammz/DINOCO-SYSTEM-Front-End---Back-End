if ( ! function_exists( 'dinoco_sn_format_csv_row' ) ) {
    /**
     * RFC 4180 CSV row formatter — escape commas/quotes/newlines.
     *
     * Pure-logic helper (no I/O) so it can be unit tested without DB.
     * Mirrors fputcsv() escaping behaviour but lets us assert exact output
     * in PHPUnit and reuse for non-fputcsv contexts (e.g. inline preview).
     *
     * @param array $cells Cell values (will be cast to string)
     * @return string Joined CSV row WITHOUT trailing newline
     */
    function dinoco_sn_format_csv_row( $cells ) {
        if ( ! is_array( $cells ) ) return '';
        $out = array();
        foreach ( $cells as $c ) {
            if ( $c === null ) {
                $out[] = '';
                continue;
            }
            // Cast scalars + bool to string (true→"1", false→"")
            if ( is_bool( $c ) ) {
                $c = $c ? '1' : '';
            } else {
                $c = (string) $c;
            }
            // RFC 4180: quote if contains comma, quote, CR, or LF
            if ( strpbrk( $c, ",\"\n\r" ) !== false ) {
                $out[] = '"' . str_replace( '"', '""', $c ) . '"';
            } else {
                $out[] = $c;
            }
        }
        return implode( ',', $out );
    }
}

if ( ! function_exists( 'dinoco_sn_mask_phone_for_csv' ) ) {
    /**
     * Mask Thai phone for CSV export (preserves last 4 digits).
     * Always-mask helper — caller decides whether to invoke based on PII cap.
     * Reuses dinoco_sn_mask_phone if available; else inline fallback.
     *
     * @param string|null $phone Raw phone string
     * @return string Masked phone (or empty if input invalid)
     */
    function dinoco_sn_mask_phone_for_csv( $phone ) {
        $phone = trim( (string) $phone );
        if ( $phone === '' ) return '';
        if ( function_exists( 'dinoco_sn_mask_phone' ) ) {
            return dinoco_sn_mask_phone( $phone );
        }
        // Inline fallback — keep last 4 digits
        $digits = preg_replace( '/\D+/', '', $phone );
        if ( strlen( $digits ) < 4 ) return str_repeat( 'x', strlen( $digits ) );
        return str_repeat( 'x', max( 0, strlen( $digits ) - 4 ) ) . substr( $digits, -4 );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_ltv_export' ) ) {
    /**
     * GET /ltv/export — Phase 3 W10.3 / V.0.21 CSV streaming download.
     *
     * Filters:
     *   - tier (string, optional)     — filter by loyalty_tier
     *   - min_spent (number, optional) — filter total_lifetime_spent >= X
     *   - limit (int, default 5000)    — clamp 1..5000
     *
     * PII protection:
     *   - phone column always masked unless caller has dinoco_sn_view_pii
     *   - email always masked unless caller has dinoco_sn_view_pii
     *   - response header X-PII-Visible: 0|1 informs frontend
     *
     * Rate limit: 5/hr/user via b2b_rate_limit if helper available
     * (fail-open if helper missing — defensive).
     *
     * Audit log: writes 'ltv_export' event (sensitive=true) with row_count
     * + filter context.
     */
    function dinoco_sn_rest_ltv_export( $req ) {
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'ltv_snapshot' ) ) {
            return new WP_Error( 'schema_not_ready',
                __( 'LTV snapshot table not installed (cron may not have run yet).', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        // Rate limit (5/hr/user) — reuse B2B helper if available
        $uid = (int) get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $limit = b2b_rate_limit( "sn_ltv_export_{$uid}", 5, HOUR_IN_SECONDS );
            if ( is_wp_error( $limit ) ) {
                return new WP_Error( 'rate_limited',
                    __( 'Export limit reached (5/hr). Please retry later.', 'dinoco-sn' ),
                    array( 'status' => 429, 'retry_after' => 3600 ) );
            }
        }

        global $wpdb;
        $tbl = dinoco_sn_table( 'ltv_snapshot' );

        $tier      = sanitize_key( (string) $req->get_param( 'tier' ) );
        $min_spent = max( 0, (float) $req->get_param( 'min_spent' ) );
        $limit     = max( 1, min( 5000, (int) $req->get_param( 'limit' ) ) );

        $allowed_tiers = array( 'bronze', 'silver', 'gold', 'platinum', 'diamond' );

        $where  = array();
        $params = array();
        if ( $tier !== '' && in_array( $tier, $allowed_tiers, true ) ) {
            $where[]  = 'loyalty_tier = %s';
            $params[] = $tier;
        }
        if ( $min_spent > 0 ) {
            $where[]  = 'total_lifetime_spent >= %f';
            $params[] = $min_spent;
        }
        $where_sql = $where ? ( 'WHERE ' . implode( ' AND ', $where ) ) : '';

        $sql = "SELECT user_id, plates_count, registered_count, active_warranties_count,
                       total_lifetime_spent, first_purchase_date, last_purchase_date,
                       claim_count, loyalty_tier, computed_at
                FROM {$tbl}
                {$where_sql}
                ORDER BY total_lifetime_spent DESC, user_id ASC
                LIMIT %d";
        $params[] = $limit;

        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );

        // Resolve user info (display name + email + phone) — N+1 defense
        $can_pii  = function_exists( 'dinoco_sn_user_can_view_pii' ) && dinoco_sn_user_can_view_pii();
        $user_ids = array();
        foreach ( $rows ?: array() as $r ) {
            $user_ids[] = (int) $r['user_id'];
        }
        $user_ids = array_values( array_filter( array_unique( $user_ids ) ) );
        $users = array();
        if ( ! empty( $user_ids ) ) {
            $u_objs = get_users( array(
                'include' => $user_ids,
                'fields'  => array( 'ID', 'display_name', 'user_email', 'user_registered' ),
            ) );
            foreach ( $u_objs as $u ) {
                $uid_int = (int) $u->ID;
                $phone   = (string) get_user_meta( $uid_int, 'billing_phone', true );
                if ( $phone === '' ) {
                    $phone = (string) get_user_meta( $uid_int, 'phone', true );
                }
                $users[ $uid_int ] = array(
                    'display_name'    => (string) $u->display_name,
                    'user_email'      => (string) $u->user_email,
                    'phone'           => $phone,
                    'user_registered' => (string) $u->user_registered,
                );
            }
        }

        // Stream CSV — UTF-8 BOM + RFC 4180 quoting via fputcsv
        $fh = fopen( 'php://temp', 'w+' );
        fwrite( $fh, "\xEF\xBB\xBF" );

        // Header row — Thai-friendly labels for Excel TH/EN dual-locale
        fputcsv( $fh, array(
            'User ID',
            'Display Name',
            'Email',
            'Phone' . ( $can_pii ? '' : ' (masked)' ),
            'Tier',
            'Plates',
            'Active',
            'Claims',
            'Total Spent (THB)',
            'First Purchase',
            'Last Purchase',
            'Member Years',
            'Computed At',
        ) );

        $now_ts = function_exists( 'current_time' ) ? current_time( 'timestamp' ) : time();

        foreach ( $rows ?: array() as $r ) {
            $uid_int = (int) $r['user_id'];
            $u       = $users[ $uid_int ] ?? null;
            $email   = $u ? (string) $u['user_email'] : '';
            $phone   = $u ? (string) $u['phone']      : '';

            // PII gate — mask email + phone unless caller cap
            if ( ! $can_pii ) {
                if ( $email !== '' ) {
                    $email = preg_replace( '/(.).*(@.*)/', '$1***$2', $email );
                }
                $phone = dinoco_sn_mask_phone_for_csv( $phone );
            }

            // Member years calculation — purely informational
            $member_years = '';
            if ( $u && ! empty( $u['user_registered'] ) ) {
                $reg_ts = strtotime( $u['user_registered'] );
                if ( $reg_ts > 0 && $now_ts > $reg_ts ) {
                    $member_years = number_format( ( $now_ts - $reg_ts ) / ( 86400 * 365.25 ), 1 );
                }
            }

            fputcsv( $fh, array(
                $uid_int,
                $u ? $u['display_name'] : ( 'user#' . $uid_int ),
                $email,
                $phone,
                (string) $r['loyalty_tier'],
                (int) $r['plates_count'],
                (int) $r['active_warranties_count'],
                (int) $r['claim_count'],
                number_format( (float) $r['total_lifetime_spent'], 2, '.', '' ),
                (string) $r['first_purchase_date'],
                (string) $r['last_purchase_date'],
                $member_years,
                (string) $r['computed_at'],
            ) );
        }

        rewind( $fh );
        $csv = stream_get_contents( $fh );
        fclose( $fh );

        $row_count = count( $rows ?: array() );

        // Audit log — sensitive event (PII export tracked even if masked)
        if ( function_exists( 'dinoco_sn_audit_log' ) ) {
            dinoco_sn_audit_log( null, 'ltv_export', null, null,
                array(
                    'row_count'   => $row_count,
                    'tier_filter' => $tier ?: null,
                    'min_spent'   => $min_spent ?: null,
                    'limit'       => $limit,
                    'pii_visible' => $can_pii ? 1 : 0,
                ),
                $uid, null,
                'LTV CSV export', 'export', true );
        }

        $filename = 'sn_ltv_' . ( $tier ?: 'all' ) . '_' . gmdate( 'Y-m-d_His' ) . '.csv';

        $resp = new WP_REST_Response( $csv, 200 );
        $resp->header( 'Content-Type', 'text/csv; charset=utf-8' );
        $resp->header( 'Content-Disposition', 'attachment; filename="' . $filename . '"' );
        $resp->header( 'X-Content-Type-Options', 'nosniff' );
        $resp->header( 'X-Ltv-Row-Count', (string) $row_count );
        $resp->header( 'X-PII-Visible', $can_pii ? '1' : '0' );

        return $resp;
    }
}

