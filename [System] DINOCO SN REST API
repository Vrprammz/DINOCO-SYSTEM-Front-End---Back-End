if ( ! function_exists( 'dinoco_sn_rest_void' ) ) {
    /**
     * POST /void — admin void single S/N.
     *
     * Tier matrix:
     *   - status ∈ {reserved, in_pool}        → auto (single-admin OK)
     *   - status ∈ {allocated, shipped}        → single-admin (Phase 3 enforces)
     *   - status ∈ {registered, claimed, ...}  → 4-eyes (Phase 3 enforces)
     *
     * Phase 2 W5 stub: enforces auto-tier only. registered/claimed
     * returns 422 with hint to use future approval queue.
     */
    function dinoco_sn_rest_void( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'void', array( 'sn', 'reason' ), function( $req ) {
            global $wpdb;
            $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
            $reason = trim( (string) $req->get_param( 'reason' ) );

            // Phase 1 W4.2 — Observability hook (sensitive op)
            if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                dinoco_sn_obs_capture( 'void_attempt', array(
                    'sn' => $sn, 'reason_len' => mb_strlen( $reason ),
                ) );
            }
            if ( $sn === '' || mb_strlen( $reason ) < 10 ) {
                return new WP_Error( 'invalid_input',
                    __( 'S/N + reason (≥10 chars) required.', 'dinoco-sn' ),
                    array( 'status' => 400 ) );
            }
            if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                return new WP_Error( 'schema_not_ready', __( 'sn_pool not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
            }

            $pool = dinoco_sn_table( 'pool' );
            $auto_tier = array( 'reserved', 'in_pool' );

            $wpdb->query( 'START TRANSACTION' );
            try {
                // Lock row + check current status
                $row = $wpdb->get_row( $wpdb->prepare(
                    "SELECT sn, status, batch_id FROM {$pool} WHERE sn = %s FOR UPDATE", $sn
                ), ARRAY_A );

                if ( ! $row ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'sn_not_found', __( 'S/N not in pool.', 'dinoco-sn' ), array( 'status' => 404 ) );
                }
                if ( $row['status'] === 'voided' ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'already_voided', __( 'S/N already voided.', 'dinoco-sn' ), array( 'status' => 409 ) );
                }
                if ( ! in_array( $row['status'], $auto_tier, true ) ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'requires_approval',
                        sprintf( __( 'Status %s requires 4-eyes approval (Phase 3+).', 'dinoco-sn' ), $row['status'] ),
                        array( 'status' => 422, 'current_status' => $row['status'] ) );
                }

                // Atomic flip → voided
                $upd = $wpdb->update( $pool,
                    array(
                        'status'     => 'voided',
                        'prev_status' => $row['status'],
                        'voided_at'  => current_time( 'mysql' ),
                    ),
                    array( 'sn' => $sn, 'status' => $row['status'] ) // optimistic: status unchanged
                );

                if ( $upd === false || $upd === 0 ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'concurrent_modification',
                        __( 'Status changed during void. Retry.', 'dinoco-sn' ),
                        array( 'status' => 409 ) );
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log( $sn, 'plate_voided', $row['status'], 'voided', array(
                        'batch_id' => (int) $row['batch_id'],
                        'tier'     => 'auto',
                    ), null, null, $reason, 'admin_void', false );
                }

                $wpdb->query( 'COMMIT' );

                return rest_ensure_response( array(
                    'success'      => true,
                    'sn'           => $sn,
                    'status_from'  => $row['status'],
                    'status_to'    => 'voided',
                    'tier'         => 'auto',
                ) );
            } catch ( \Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( $e, array( 'context' => 'sn_void', 'sn' => $sn ) );
                }
                return new WP_Error( 'void_failed', $e->getMessage(), array( 'status' => 500 ) );
            }
        } );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_swap' ) ) {
    /**
     * POST /swap — swap sn_old → sn_new within same SKU.
     *
     * Phase 2 W5 enforcement:
     *   - sn_old.status ∈ {in_pool, allocated_to_order, shipped} → auto
     *   - sn_old.status ∈ {registered, claimed} → 422 (Phase 3 4-eyes)
     *   - sn_new.status MUST = in_pool
     *   - sn_new.linked_sku === sn_old.linked_sku (same SKU swap only)
     *
     * Atomic: GET_LOCK + START TRANSACTION + dual UPDATE + audit.
     */
    function dinoco_sn_rest_swap( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'swap', array( 'sn_old', 'sn_new', 'reason' ), function( $req ) {
            global $wpdb;
            $sn_old = strtoupper( trim( (string) $req->get_param( 'sn_old' ) ) );
            $sn_new = strtoupper( trim( (string) $req->get_param( 'sn_new' ) ) );
            $reason = trim( (string) $req->get_param( 'reason' ) );

            // Phase 1 W4.2 — Observability hook (4-eyes sensitive op)
            if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                dinoco_sn_obs_capture( 'swap_attempt', array(
                    'sn_old' => $sn_old, 'sn_new' => $sn_new, 'reason_len' => mb_strlen( $reason ),
                ) );
            }

            if ( $sn_old === '' || $sn_new === '' || $sn_old === $sn_new ) {
                return new WP_Error( 'invalid_input',
                    __( 'sn_old + sn_new must differ.', 'dinoco-sn' ),
                    array( 'status' => 400 ) );
            }
            if ( mb_strlen( $reason ) < 10 ) {
                return new WP_Error( 'invalid_input',
                    __( 'reason must be ≥10 chars.', 'dinoco-sn' ),
                    array( 'status' => 400 ) );
            }
            if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                return new WP_Error( 'schema_not_ready', __( 'sn_pool not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
            }

            $pool = dinoco_sn_table( 'pool' );
            $lock_name = 'dnc_sn_swap_' . substr( md5( $sn_old . '|' . $sn_new ), 0, 16 );

            // GET_LOCK to serialize concurrent swap of same pair
            $got = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
            if ( $got !== 1 ) {
                return new WP_Error( 'lock_timeout', __( 'Concurrent swap in progress.', 'dinoco-sn' ), array( 'status' => 503 ) );
            }

            // V.0.6 audit fix (P1-2): wrap entire post-GET_LOCK block in
            // try/finally so RELEASE_LOCK fires on every code path —
            // including unhandled throws between START TRANSACTION + the
            // inner try{}. Early-returns no longer need manual RELEASE_LOCK.
            try {
                $wpdb->query( 'START TRANSACTION' );
                try {
                    $row_old = $wpdb->get_row( $wpdb->prepare(
                        "SELECT sn, status, linked_sku, registered_user_id, registered_warranty_id, batch_id
                         FROM {$pool} WHERE sn = %s FOR UPDATE", $sn_old
                    ), ARRAY_A );
                    $row_new = $wpdb->get_row( $wpdb->prepare(
                        "SELECT sn, status, linked_sku, batch_id
                         FROM {$pool} WHERE sn = %s FOR UPDATE", $sn_new
                    ), ARRAY_A );

                    if ( ! $row_old || ! $row_new ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sn_not_found', __( 'One or both S/N not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
                    }

                    $auto_tier_old = array( 'in_pool', 'allocated_to_order', 'shipped' );
                    if ( ! in_array( $row_old['status'], $auto_tier_old, true ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'requires_approval',
                            sprintf( __( 'sn_old status %s requires 4-eyes approval (Phase 3+).', 'dinoco-sn' ), $row_old['status'] ),
                            array( 'status' => 422, 'current_status' => $row_old['status'] ) );
                    }

                    if ( $row_new['status'] !== 'in_pool' ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sn_new_not_available',
                            __( 'sn_new must be in_pool.', 'dinoco-sn' ),
                            array( 'status' => 422 ) );
                    }

                    if ( $row_new['linked_sku'] !== $row_old['linked_sku'] ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sku_mismatch',
                            sprintf( __( 'SKU mismatch: %s vs %s.', 'dinoco-sn' ), $row_old['linked_sku'], $row_new['linked_sku'] ),
                            array( 'status' => 422 ) );
                    }

                $now = current_time( 'mysql' );

                // V.0.6 audit fix (P1-1): NULL out sn_old's registered_user_id +
                // registered_warranty_id in same UPDATE flipping to voided.
                // Prevents dual-binding window where both sn_old + sn_new
                // appear bound to same warranty if audit log fails post-COMMIT.
                $upd_old = $wpdb->update( $pool, array(
                    'status'                 => 'voided',
                    'prev_status'            => $row_old['status'],
                    'replaced_by_sn'         => $sn_new,
                    'voided_at'              => $now,
                    'registered_user_id'     => null,
                    'registered_warranty_id' => null,
                ), array( 'sn' => $sn_old, 'status' => $row_old['status'] ) );
                if ( $upd_old === false || $upd_old === 0 ) {
                    throw new \RuntimeException( 'sn_old update failed (concurrent modification)' );
                }

                // sn_new → take old's state (registered → registered, etc)
                $upd_new = $wpdb->update( $pool, array(
                    'status'                 => $row_old['status'],
                    'prev_status'            => 'in_pool',
                    'replaces_sn'            => $sn_old,
                    'registered_user_id'     => $row_old['registered_user_id'],
                    'registered_warranty_id' => $row_old['registered_warranty_id'],
                ), array( 'sn' => $sn_new, 'status' => 'in_pool' ) );
                if ( $upd_new === false || $upd_new === 0 ) {
                    throw new \RuntimeException( 'sn_new update failed (concurrent modification)' );
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log( $sn_old, 'plate_swapped', $row_old['status'], 'voided',
                        array( 'pair' => array( 'old' => $sn_old, 'new' => $sn_new ), 'side' => 'old' ),
                        null, null, $reason, 'admin_swap', false );
                    dinoco_sn_audit_log( $sn_new, 'plate_swapped', 'in_pool', $row_old['status'],
                        array( 'pair' => array( 'old' => $sn_old, 'new' => $sn_new ), 'side' => 'new' ),
                        null, null, $reason, 'admin_swap', false );
                }

                    $wpdb->query( 'COMMIT' );
                    return rest_ensure_response( array(
                        'success'      => true,
                        'sn_old'       => array( 'sn' => $sn_old, 'status' => 'voided' ),
                        'sn_new'       => array( 'sn' => $sn_new, 'status' => $row_old['status'] ),
                        'tier'         => 'auto',
                    ) );
                } catch ( \Throwable $e ) {
                    $wpdb->query( 'ROLLBACK' );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'sn_swap', 'sn_old' => $sn_old, 'sn_new' => $sn_new ) );
                    }
                    return new WP_Error( 'swap_failed', $e->getMessage(), array( 'status' => 500 ) );
                }
            } finally {
                // P1-2: ensures lock release on every path including
                // unhandled throws + early returns
                $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        } );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 8. PHASE 3 W8.2 — RECALL / REISSUE / RECONCILE
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * V.0.5 (2026-05-04) Phase 3 W8: defect recall + reissue + drift viewer.
 *
 * Recall categories (App K M4/M14):
 *   defect    — manufacturing defect (admin-initiated mass recall)
 *   safety    — safety hazard recall
 *   stolen    — customer-reported stolen (M14)
 *   fraud     — fraud detection flagged (Phase 3 F#12 integration)
 *   misship   — wrong S/N shipped (alternative to swap when no replacement)
 *
 * Reissue (M2): plate fell off → issue new plate from in_pool (same SKU)
 * to customer's address. Old plate stays "registered" until customer
 * confirms loss (admin process). Phase 3 stub does NOT auto-ship Flash —
 * admin handles physical delivery separately.
 */

if ( ! function_exists( 'dinoco_sn_rest_recall' ) ) {
    /**
     * POST /recall — admin recall plate from customer (defect / safety / stolen).
     *
     * Tier matrix:
     *   - in_pool / reserved      → 422 (use /void, recall implies customer side)
     *   - registered / claimed    → auto-tier in Phase 3 W8 (4-eyes Phase 4 W11)
     *   - already voided/recalled → 409 conflict
     *
     * Side effects:
     *   - sn_pool.status = 'recalled' + recalled_at
     *   - audit row event=plate_recalled is_sensitive=1 (5y retention)
     *   - Phase 4 W11: integrate stolen registry (F#14) for cross-validation
     */
    function dinoco_sn_rest_recall( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'recall', array( 'sn', 'reason', 'category' ), function( $req ) {
            global $wpdb;
            $sn       = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
            $reason   = trim( (string) $req->get_param( 'reason' ) );
            $category = sanitize_key( (string) ( $req->get_param( 'category' ) ?: 'defect' ) );

            $allowed_categories = array( 'defect', 'safety', 'stolen', 'fraud', 'misship' );
            if ( ! in_array( $category, $allowed_categories, true ) ) {
                return new WP_Error( 'invalid_category',
                    sprintf( __( 'category must be one of: %s', 'dinoco-sn' ), implode( ', ', $allowed_categories ) ),
                    array( 'status' => 400 ) );
            }
            if ( $sn === '' || mb_strlen( $reason ) < 10 ) {
                return new WP_Error( 'invalid_input',
                    __( 'sn + reason (≥10 chars) required.', 'dinoco-sn' ),
                    array( 'status' => 400 ) );
            }
            if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                return new WP_Error( 'schema_not_ready', __( 'sn_pool not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
            }

            $pool = dinoco_sn_table( 'pool' );
            $wpdb->query( 'START TRANSACTION' );
            try {
                $row = $wpdb->get_row( $wpdb->prepare(
                    "SELECT sn, status, batch_id, registered_user_id FROM {$pool}
                     WHERE sn = %s FOR UPDATE", $sn
                ), ARRAY_A );

                if ( ! $row ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'sn_not_found', __( 'S/N not in pool.', 'dinoco-sn' ), array( 'status' => 404 ) );
                }

                if ( in_array( $row['status'], array( 'voided', 'recalled' ), true ) ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'already_terminal',
                        sprintf( __( 'S/N already %s.', 'dinoco-sn' ), $row['status'] ),
                        array( 'status' => 409 ) );
                }

                // Recall implies customer side — block in_pool/reserved (use /void)
                if ( in_array( $row['status'], array( 'reserved', 'in_pool' ), true ) ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'use_void_instead',
                        __( 'In-pool plates should use /void, not /recall.', 'dinoco-sn' ),
                        array( 'status' => 422, 'current_status' => $row['status'] ) );
                }

                $upd = $wpdb->update( $pool, array(
                    'status'      => 'recalled',
                    'prev_status' => $row['status'],
                    'recalled_at' => current_time( 'mysql' ),
                ), array( 'sn' => $sn, 'status' => $row['status'] ) );

                if ( $upd === false || $upd === 0 ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'concurrent_modification',
                        __( 'Status changed during recall. Retry.', 'dinoco-sn' ),
                        array( 'status' => 409 ) );
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log( $sn, 'plate_recalled', $row['status'], 'recalled', array(
                        'category'             => $category,
                        'batch_id'             => (int) $row['batch_id'],
                        'registered_user_id'   => $row['registered_user_id'] ? (int) $row['registered_user_id'] : null,
                    ), null, null, $reason, 'recall_' . $category, true ); // is_sensitive=1
                }

                $wpdb->query( 'COMMIT' );

                return rest_ensure_response( array(
                    'success'      => true,
                    'sn'           => $sn,
                    'status_from'  => $row['status'],
                    'status_to'    => 'recalled',
                    'category'     => $category,
                    'is_sensitive' => true,
                ) );
            } catch ( \Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( $e, array( 'context' => 'sn_recall', 'sn' => $sn ) );
                }
                return new WP_Error( 'recall_failed', $e->getMessage(), array( 'status' => 500 ) );
            }
        } );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_reissue' ) ) {
    /**
     * POST /reissue — M2 scenario: customer's plate fell off / lost.
     *
     * Issues a fresh in_pool plate (same SKU) to customer's warranty.
     * Does NOT void old plate (admin keeps registration intact until
     * customer confirms loss — anti-abuse). Old plate flagged via
     * audit context.replaces_chain entry.
     *
     * Constraints:
     *   - sn_old must be registered/claimed
     *   - sn_new must be in_pool
     *   - sn_new.linked_sku === sn_old.linked_sku (same SKU, same warranty)
     *
     * Phase 3 W8 stub: no Flash shipping integration (admin manual).
     */
    function dinoco_sn_rest_reissue( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'reissue', array( 'sn_old', 'sn_new', 'reason' ), function( $req ) {
            global $wpdb;
            $sn_old = strtoupper( trim( (string) $req->get_param( 'sn_old' ) ) );
            $sn_new = strtoupper( trim( (string) $req->get_param( 'sn_new' ) ) );
            $reason = trim( (string) $req->get_param( 'reason' ) );

            if ( $sn_old === '' || $sn_new === '' || $sn_old === $sn_new ) {
                return new WP_Error( 'invalid_input', __( 'sn_old + sn_new must differ.', 'dinoco-sn' ), array( 'status' => 400 ) );
            }
            if ( mb_strlen( $reason ) < 10 ) {
                return new WP_Error( 'invalid_input', __( 'reason ≥10 chars required.', 'dinoco-sn' ), array( 'status' => 400 ) );
            }
            if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                return new WP_Error( 'schema_not_ready', __( 'sn_pool not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
            }

            $pool = dinoco_sn_table( 'pool' );
            $lock_name = 'dnc_sn_reissue_' . substr( md5( $sn_old . '|' . $sn_new ), 0, 16 );

            $got = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
            if ( $got !== 1 ) {
                return new WP_Error( 'lock_timeout', __( 'Concurrent reissue in progress.', 'dinoco-sn' ), array( 'status' => 503 ) );
            }

            // V.0.6 audit fix (P1-2): try/finally ensures RELEASE_LOCK on
            // every code path including unhandled throws + early returns.
            try {
                $wpdb->query( 'START TRANSACTION' );
                try {
                    $row_old = $wpdb->get_row( $wpdb->prepare(
                        "SELECT sn, status, linked_sku, registered_user_id, registered_warranty_id
                         FROM {$pool} WHERE sn = %s FOR UPDATE", $sn_old
                    ), ARRAY_A );
                    $row_new = $wpdb->get_row( $wpdb->prepare(
                        "SELECT sn, status, linked_sku FROM {$pool}
                         WHERE sn = %s FOR UPDATE", $sn_new
                    ), ARRAY_A );

                    if ( ! $row_old || ! $row_new ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sn_not_found', __( 'One or both S/N not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
                    }

                    if ( ! in_array( $row_old['status'], array( 'registered', 'claimed' ), true ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sn_old_not_active',
                            __( 'sn_old must be registered or claimed.', 'dinoco-sn' ),
                            array( 'status' => 422, 'current_status' => $row_old['status'] ) );
                    }
                    if ( $row_new['status'] !== 'in_pool' ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sn_new_not_available',
                            __( 'sn_new must be in_pool.', 'dinoco-sn' ),
                            array( 'status' => 422 ) );
                    }
                    if ( $row_new['linked_sku'] !== $row_old['linked_sku'] ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'sku_mismatch',
                            sprintf( __( 'SKU mismatch: %s vs %s.', 'dinoco-sn' ), $row_old['linked_sku'], $row_new['linked_sku'] ),
                            array( 'status' => 422 ) );
                    }

                    // Issue sn_new with same warranty linkage as sn_old
                    $wpdb->update( $pool, array(
                        'status'                 => $row_old['status'],
                        'prev_status'            => 'in_pool',
                        'replaces_sn'            => $sn_old,
                        'registered_user_id'     => $row_old['registered_user_id'],
                        'registered_warranty_id' => $row_old['registered_warranty_id'],
                    ), array( 'sn' => $sn_new, 'status' => 'in_pool' ) );

                    // Mark sn_old as having reissue pending (don't void — customer keeps proof)
                    $wpdb->update( $pool, array(
                        'replaced_by_sn' => $sn_new,
                    ), array( 'sn' => $sn_old ) );

                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log( $sn_old, 'plate_reissue_pending', $row_old['status'], $row_old['status'],
                            array( 'pair' => array( 'old' => $sn_old, 'new' => $sn_new ), 'side' => 'old' ),
                            null, null, $reason, 'admin_reissue', true );
                        dinoco_sn_audit_log( $sn_new, 'plate_reissue_pending', 'in_pool', $row_old['status'],
                            array( 'pair' => array( 'old' => $sn_old, 'new' => $sn_new ), 'side' => 'new' ),
                            null, null, $reason, 'admin_reissue', true );
                    }

                    $wpdb->query( 'COMMIT' );
                    return rest_ensure_response( array(
                        'success' => true,
                        'sn_old'  => array( 'sn' => $sn_old, 'status' => $row_old['status'], 'replaced_by' => $sn_new ),
                        'sn_new'  => array( 'sn' => $sn_new, 'status' => $row_old['status'] ),
                        'note'    => 'admin must arrange physical shipment of new plate to customer',
                    ) );
                } catch ( \Throwable $e ) {
                    $wpdb->query( 'ROLLBACK' );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'sn_reissue', 'sn_old' => $sn_old, 'sn_new' => $sn_new ) );
                    }
                    return new WP_Error( 'reissue_failed', $e->getMessage(), array( 'status' => 500 ) );
                }
            } finally {
                // P1-2: guaranteed lock release on every path
                $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        } );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_reconcile_report' ) ) {
    /**
