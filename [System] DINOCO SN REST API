if ( ! function_exists( 'dinoco_sn_rest_fraud_decision' ) ) {
    function dinoco_sn_rest_fraud_decision( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'fraud-decision',
            array( 'id', 'decision' ),
            function( $req ) {
                global $wpdb;
                $id       = (int) $req->get_param( 'id' );
                $decision = sanitize_key( (string) $req->get_param( 'decision' ) );
                $notes    = trim( (string) $req->get_param( 'notes' ) );

                $allowed = array( 'legit', 'fraud', 'suspicious' );
                if ( ! in_array( $decision, $allowed, true ) ) {
                    return new WP_Error( 'invalid_decision',
                        sprintf( __( 'decision must be one of: %s', 'dinoco-sn' ), implode( ', ', $allowed ) ),
                        array( 'status' => 400 ) );
                }
                if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'fraud_scores' ) ) {
                    return new WP_Error( 'schema_not_ready', '', array( 'status' => 503 ) );
                }

                $tbl = dinoco_sn_table( 'fraud_scores' );
                $reviewer_id = (int) get_current_user_id();

                $wpdb->query( 'START TRANSACTION' );
                try {
                    $row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT id, sn, event_type, score, outcome, ip_address
                         FROM {$tbl}
                         WHERE id = %d FOR UPDATE",
                        $id
                    ), ARRAY_A );

                    if ( ! $row ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'not_found', __( 'Fraud score not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
                    }
                    if ( $row['outcome'] !== null && $row['outcome'] !== 'pending' ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'already_decided',
                            sprintf( __( 'Already decided: %s.', 'dinoco-sn' ), $row['outcome'] ),
                            array( 'status' => 409 ) );
                    }

                    $upd = $wpdb->update( $tbl, array(
                        'outcome'     => $decision,
                        'reviewed_by' => $reviewer_id,
                        'reviewed_at' => current_time( 'mysql' ),
                    ), array( 'id' => $id ) );

                    if ( $upd === false || $upd === 0 ) {
                        throw new \RuntimeException( 'fraud_scores update failed' );
                    }

                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log( $row['sn'], 'plate_recalled',
                            $row['outcome'] ?: 'pending', $decision,
                            array(
                                'fraud_score_id' => $id,
                                'event_type'     => $row['event_type'],
                                'score'          => (int) $row['score'],
                                'decision'       => $decision,
                                'ip'             => $row['ip_address'],
                            ),
                            $reviewer_id, null, $notes ?: '', 'fraud_' . $decision, true );
                    }

                    $wpdb->query( 'COMMIT' );

                    return rest_ensure_response( array(
                        'success'      => true,
                        'id'           => $id,
                        'sn'           => $row['sn'],
                        'decision'     => $decision,
                        'reviewer_id'  => $reviewer_id,
                    ) );
                } catch ( \Throwable $e ) {
                    $wpdb->query( 'ROLLBACK' );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'sn_fraud_decision', 'id' => $id ) );
                    }
                    return new WP_Error( 'decision_failed', $e->getMessage(), array( 'status' => 500 ) );
                }
            }
        );
    }
}

