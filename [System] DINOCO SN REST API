if ( ! function_exists( 'dinoco_sn_handler_receive_single' ) ) {
    function dinoco_sn_handler_receive_single( $req ) {
        global $wpdb;
        $tbl_pool = dinoco_sn_table( 'pool' );
        $tbl_batches = dinoco_sn_table( 'batches' );

        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        $sku = strtoupper( trim( (string) $req->get_param( 'linked_sku' ) ) );
        $batch_id = (int) $req->get_param( 'batch_id' );

        if ( $sn === '' || $sku === '' || $batch_id <= 0 ) {
            return new WP_Error( 'invalid_input', __( 'Missing required fields.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        // Phase 1 W4.2 — Observability hook
        if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
            dinoco_sn_obs_capture( 'receive_attempt', array(
                'sn' => $sn, 'sku' => $sku, 'batch_id' => $batch_id,
            ) );
        }

        try {
            $wpdb->query( "START TRANSACTION" );

            // SELECT FOR UPDATE on plate
            $plate = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl_pool} WHERE sn = %s AND batch_id = %d FOR UPDATE",
                $sn, $batch_id
            ) );

            if ( ! $plate ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'sn_not_in_batch',
                    sprintf( __( 'S/N %s not found in batch %d.', 'dinoco-sn' ), $sn, $batch_id ),
                    array( 'status' => 404 )
                );
            }

            if ( $plate->status === 'in_pool' ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'already_received',
                    sprintf( __( 'S/N %s already received (linked to %s).', 'dinoco-sn' ), $sn, $plate->linked_sku ),
                    array( 'status' => 409, 'linked_sku' => $plate->linked_sku )
                );
            }

            if ( $plate->status === 'voided' ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'voided_plate',
                    __( 'Plate is voided — discard immediately.', 'dinoco-sn' ),
                    array( 'status' => 410 )
                );
            }

            if ( $plate->status !== 'reserved' ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'invalid_status',
                    sprintf( __( 'Cannot receive plate in status %s.', 'dinoco-sn' ), $plate->status ),
                    array( 'status' => 422 )
                );
            }

            // Update plate status
            $now = current_time( 'mysql' );
            $wpdb->update( $tbl_pool, array(
                'status'      => 'in_pool',
                'linked_sku'  => $sku,
                'prev_status' => $plate->status,
            ), array( 'sn' => $sn ), array( '%s', '%s', '%s' ), array( '%s' ) );

            // Update batch counter
            $wpdb->query( $wpdb->prepare(
                "UPDATE {$tbl_batches} SET qty_received = qty_received + 1,
                 status = CASE WHEN qty_received + 1 >= qty_total THEN 'received_full' ELSE 'received_partial' END
                 WHERE id = %d",
                $batch_id
            ) );

            $wpdb->query( "COMMIT" );

            // Audit
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $sn, 'plate_received', $plate->status, 'in_pool', array(
                    'batch_id'   => $batch_id,
                    'linked_sku' => $sku,
                    'session_id' => sanitize_text_field( (string) $req->get_param( 'session_id' ) ),
                ) );
            }

            // Get updated batch counts
            $batch = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM {$tbl_batches} WHERE id = %d", $batch_id ) );

            return rest_ensure_response( array(
                'sn'           => $sn,
                'status_from'  => $plate->status,
                'status_to'    => 'in_pool',
                'linked_sku'   => $sku,
                'batch'        => array(
                    'id'           => $batch_id,
                    'qty_received' => (int) $batch->qty_received,
                    'qty_total'    => (int) $batch->qty_total,
                    'progress_pct' => round( ( $batch->qty_received / max( 1, $batch->qty_total ) ) * 100, 2 ),
                ),
            ) );

        } catch ( \Throwable $e ) {
            $wpdb->query( "ROLLBACK" );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_receive_single', 'sn' => $sn ) );
            }
            return new WP_Error( 'receive_failed', $e->getMessage(), array( 'status' => 500 ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_rest_receive_bulk' ) ) {
    /**
     * POST /dinoco-sn/v1/receive/bulk — Range/Paste mode (D4 contract)
     *
     * Per-row atomic + skip conflicts default. Response shape:
     *   { success_count, skip_count, results: [{sn, status, code, ...}] }
     *
     * Idempotency body hash: sort sns ascending + concat batch_id|sku|sns_sorted_csv
     * (Round 27 bulk-array deterministic pattern)
     */
    function dinoco_sn_rest_receive_bulk( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system is disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        // Custom idempotency wrapper for bulk (sort sns for deterministic hash)
        if ( function_exists( 'dinoco_idempotency_extract_key' ) && function_exists( 'dinoco_idempotency_check' ) ) {
            $key = dinoco_idempotency_extract_key( $req );
            if ( $key !== '' ) {
                $sns = (array) $req->get_param( 'sns' );
                $sns_normalized = array_unique( array_map( function( $s ) { return strtoupper( trim( (string) $s ) ); }, $sns ) );
                sort( $sns_normalized );

                $body_hash = dinoco_idempotency_hash( array(
                    'batch_id'   => (int) $req->get_param( 'batch_id' ),
                    'linked_sku' => strtoupper( trim( (string) $req->get_param( 'linked_sku' ) ) ),
                    'sns'        => $sns_normalized,
                    'mode'       => $req->get_param( 'mode' ),
                    '_actor'     => get_current_user_id(),
                ) );

                $namespace = DINOCO_SN_REST_NAMESPACE . '::receive-bulk';
                $cached = dinoco_idempotency_check( $key, $namespace, $body_hash );
                if ( is_wp_error( $cached ) ) return $cached;
                if ( is_array( $cached ) ) return rest_ensure_response( $cached );
            }
        }

        $result = dinoco_sn_handler_receive_bulk( $req );

        // Store idempotency result
        if ( ! is_wp_error( $result ) && isset( $key ) && $key !== '' ) {
            $resp_data = is_a( $result, 'WP_REST_Response' ) ? $result->get_data() : $result;
            dinoco_idempotency_store( $key, $namespace, $body_hash, $resp_data, 200 );
        }

        return $result;
    }
}

if ( ! function_exists( 'dinoco_sn_handler_receive_bulk' ) ) {
    function dinoco_sn_handler_receive_bulk( $req ) {
        global $wpdb;

        $batch_id = (int) $req->get_param( 'batch_id' );
        $sku = strtoupper( trim( (string) $req->get_param( 'linked_sku' ) ) );
        $sns_input = (array) $req->get_param( 'sns' );
        $mode = sanitize_text_field( (string) $req->get_param( 'mode' ) ) ?: 'range';
        $session_id = sanitize_text_field( (string) $req->get_param( 'session_id' ) );

        // Normalize + dedup
        $sns = array_unique( array_map( function( $s ) {
            return strtoupper( trim( (string) $s ) );
        }, $sns_input ) );
        $sns = array_filter( $sns, function( $s ) { return $s !== ''; } );

        if ( $batch_id <= 0 || $sku === '' || empty( $sns ) ) {
            return new WP_Error( 'invalid_input', __( 'Missing required fields.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        // Cap chunk size 100 per request (D4 spec)
        if ( count( $sns ) > 100 ) {
            return new WP_Error( 'chunk_too_large',
                sprintf( __( 'Bulk chunk capped at 100 plates per request, got %d. Frontend should split.', 'dinoco-sn' ), count( $sns ) ),
                array( 'status' => 400 )
            );
        }

        $tbl_pool = dinoco_sn_table( 'pool' );
        $tbl_batches = dinoco_sn_table( 'batches' );

        $results = array();
        $success_count = 0;
        $skip_count = 0;

        // Per-row atomic (no master transaction — skip-conflict semantic)
        foreach ( $sns as $sn ) {
            try {
                $wpdb->query( "START TRANSACTION" );

                $plate = $wpdb->get_row( $wpdb->prepare(
                    "SELECT * FROM {$tbl_pool} WHERE sn = %s FOR UPDATE", $sn
                ) );

                if ( ! $plate ) {
                    $wpdb->query( "ROLLBACK" );
                    $results[] = array( 'sn' => $sn, 'status' => 'skip', 'code' => 'sn_not_found' );
                    $skip_count++;
                    continue;
                }

                if ( (int) $plate->batch_id !== $batch_id ) {
                    $wpdb->query( "ROLLBACK" );
                    $results[] = array( 'sn' => $sn, 'status' => 'skip', 'code' => 'not_in_batch' );
                    $skip_count++;
                    continue;
                }

                if ( $plate->status === 'in_pool' ) {
                    $wpdb->query( "ROLLBACK" );
                    $results[] = array( 'sn' => $sn, 'status' => 'skip', 'code' => 'already_received',
                                        'linked_sku' => $plate->linked_sku );
                    $skip_count++;
                    continue;
                }

                if ( $plate->status === 'voided' ) {
                    $wpdb->query( "ROLLBACK" );
                    $results[] = array( 'sn' => $sn, 'status' => 'skip', 'code' => 'voided' );
                    $skip_count++;
                    continue;
                }

                if ( $plate->status !== 'reserved' ) {
                    $wpdb->query( "ROLLBACK" );
                    $results[] = array( 'sn' => $sn, 'status' => 'skip', 'code' => 'invalid_status',
                                        'current_status' => $plate->status );
                    $skip_count++;
                    continue;
                }

                $wpdb->update( $tbl_pool, array(
                    'status'      => 'in_pool',
                    'linked_sku'  => $sku,
                    'prev_status' => $plate->status,
                ), array( 'sn' => $sn ), array( '%s', '%s', '%s' ), array( '%s' ) );

                $wpdb->query( "COMMIT" );

                $results[] = array( 'sn' => $sn, 'status' => 'ok', 'code' => 'received' );
                $success_count++;

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log( $sn, 'plate_received', $plate->status, 'in_pool', array(
                        'batch_id'   => $batch_id,
                        'linked_sku' => $sku,
                        'mode'       => $mode,
                        'session_id' => $session_id,
                    ) );
                }

            } catch ( \Throwable $e ) {
                $wpdb->query( "ROLLBACK" );
                if ( function_exists( 'dinoco_obs_capture' ) ) {
                    dinoco_obs_capture( $e, array( 'context' => 'sn_receive_bulk', 'sn' => $sn ) );
                }
                $results[] = array( 'sn' => $sn, 'status' => 'error', 'code' => 'db_error',
                                    'error' => $e->getMessage() );
                $skip_count++;
            }
        }

        // Update batch counter once at the end
        if ( $success_count > 0 ) {
            $wpdb->query( $wpdb->prepare(
                "UPDATE {$tbl_batches} SET qty_received = qty_received + %d,
                 status = CASE WHEN qty_received + %d >= qty_total THEN 'received_full' ELSE 'received_partial' END
                 WHERE id = %d",
                $success_count, $success_count, $batch_id
            ) );
        }

        $batch = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM {$tbl_batches} WHERE id = %d", $batch_id ) );

        return rest_ensure_response( array(
            'success_count' => $success_count,
            'skip_count'    => $skip_count,
            'total'         => count( $sns ),
            'results'       => $results,
            'batch'         => $batch ? array(
                'id'           => $batch_id,
                'qty_received' => (int) $batch->qty_received,
                'qty_total'    => (int) $batch->qty_total,
                'progress_pct' => round( ( $batch->qty_received / max( 1, $batch->qty_total ) ) * 100, 2 ),
                'status'       => $batch->status,
            ) : null,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_lookup' ) ) {
    /**
     * GET /dinoco-sn/v1/lookup/{sn} — public lookup
     *
     * Returns top SET name + warranty status (no PII).
     * Phase 2+ adds HMAC URL signing for anti-enumeration.
     */
    function dinoco_sn_rest_lookup( $req ) {
        global $wpdb;
        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        if ( $sn === '' ) {
            return new WP_Error( 'invalid_sn', __( 'Invalid S/N format.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        if ( ! function_exists( 'dinoco_sn_get_plate_data' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }

        // Cache 60s (v2.4 fix from 5min)
        $cache_key = 'dinoco_sn_lookup_' . md5( $sn );
        $cached = get_transient( $cache_key );
        if ( $cached !== false ) {
            return rest_ensure_response( $cached );
        }

        $plate = dinoco_sn_get_plate_data( $sn );
        if ( ! $plate ) {
            return new WP_Error( 'sn_not_found', __( 'S/N not found.', 'dinoco-sn' ), array( 'status' => 404 ) );
        }

        // Phase 3 W9 audit fix (P0-2 + P0-5):
        // Public lookup must NOT expose:
        //   - linked_sku / top_set_sku (SKU enumeration oracle)
        //   - is_owned_by_caller (per-user field that poisons shared cache)
        //   - activate_url (info leak: which S/Ns are pre-shipped)
        // Authenticated admin uses /sn/{sn} for full payload.
        // Public response = minimal status oracle for QR scan validation only.
        $public_status_map = array(
            'reserved'           => 'pending',
            'in_pool'            => 'pending',
            'allocated_to_order' => 'pending',
            'shipped'            => 'pending',
            'registered'         => 'registered',
            'claimed'            => 'registered',  // collapse to "registered" — claim detail is private
            'replaced'           => 'registered',
            'transferred'        => 'registered',
            'voided'             => 'invalid',
            'recalled'           => 'invalid',
        );
        $public_status = $public_status_map[ $plate->status ] ?? 'pending';

        if ( $public_status === 'invalid' ) {
            return new WP_Error( 'voided_plate',
                __( 'Plate is no longer valid — please contact support.', 'dinoco-sn' ),
                array( 'status' => 410 ) );
        }

        $resp = array(
            'sn'             => $sn,
            'public_status'  => $public_status,        // pending | registered (only)
            'is_registered'  => ( $public_status === 'registered' ),
            'activate_hint'  => ( $public_status === 'pending' )
                ? __( 'หากเป็นลูกค้า กรุณาเปิด LINE LIFF + scan QR ที่ตัวสินค้าเพื่อลงทะเบียน', 'dinoco-sn' )
                : null,
        );

        // Cache safe to share — no per-user / no PII fields above this point
        set_transient( $cache_key, $resp, 60 );
        return rest_ensure_response( $resp );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_required_plates' ) ) {
    /**
     * POST /dinoco-sn/v1/required-plates
     *
     * Compute hierarchy plate requirement for SKU + qty.
     * Used by Manual Invoice + B2B order detail panel (Phase 2 W6+).
     */
    function dinoco_sn_rest_required_plates( $req ) {
        if ( ! function_exists( 'dinoco_sn_required_plates_for_sku' ) ) {
            return new WP_Error( 'helper_missing', __( 'S/N Manager not synced.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        $sku = strtoupper( trim( (string) $req->get_param( 'sku' ) ) );
        $qty = max( 1, (int) $req->get_param( 'qty' ) );

        if ( $sku === '' ) {
            return new WP_Error( 'invalid_sku', '', array( 'status' => 400 ) );
        }

        $required = dinoco_sn_required_plates_for_sku( $sku, $qty );
        $total_plates = array_sum( array_column( $required, 'qty' ) );

        return rest_ensure_response( array(
            'sku'          => $sku,
            'qty'          => $qty,
            'attach_level' => function_exists( 'dinoco_sn_get_attach_level_for_sku' )
                                ? dinoco_sn_get_attach_level_for_sku( $sku ) : 'none',
            'required'     => $required,
            'total_plates' => (int) $total_plates,
        ) );
    }
