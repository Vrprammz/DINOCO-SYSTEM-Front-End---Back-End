if ( ! function_exists( 'dinoco_sn_rest_forecast_run' ) ) {
    /**
     * POST /dinoco-sn/v1/forecast/run
     * Manual trigger of `dinoco_sn_run_demand_forecast()` cron worker.
     * Rate limit: 1/hr/user via b2b_rate_limit (defensive — fail-open).
     * Idempotency: actor-scoped marker only (no semantic params).
     */
    function dinoco_sn_rest_forecast_run( $req ) {
        // Rate limit 1/hr/user
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $uid = get_current_user_id();
            $rl = b2b_rate_limit( "sn_forecast_run_{$uid}", 1, HOUR_IN_SECONDS );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error(
                    'rate_limited',
                    'รันได้ 1 ครั้ง/ชั่วโมง — โปรดรอแล้วลองใหม่',
                    array( 'status' => 429, 'retry_after' => 3600 )
                );
            }
        }

        return dinoco_sn_with_idempotency(
            $req,
            'sn-forecast-run',
            array(),
            function( $req ) {
                if ( ! function_exists( 'dinoco_sn_run_demand_forecast' ) ) {
                    return new WP_Error(
                        'forecast_unavailable',
                        'forecast worker not loaded',
                        array( 'status' => 503 )
                    );
                }
                $start = microtime( true );
                try {
                    dinoco_sn_run_demand_forecast();
                } catch ( \Throwable $e ) {
                    return new WP_Error(
                        'forecast_failed',
                        $e->getMessage(),
                        array( 'status' => 500 )
                    );
                }
                $elapsed_ms = (int) round( ( microtime( true ) - $start ) * 1000 );
                $last_run = get_option( 'dinoco_sn_demand_forecast_last_run', array() );
                return rest_ensure_response( array(
                    'success'    => true,
                    'elapsed_ms' => $elapsed_ms,
                    'last_run'   => is_array( $last_run ) ? $last_run : array(),
                ) );
            }
        );
    }
}

