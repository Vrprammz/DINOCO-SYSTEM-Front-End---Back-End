if ( ! function_exists( 'dinoco_sn_validate_recovery_state' ) ) {
    /**
     * Pure-logic guard for recovery state machine.
     *
     * Allowed transitions: reported → recovered, verified → recovered.
     * Blocked: recovered → recovered (idempotent error 409),
     *          closed → recovered (terminal).
     *
     * @param string $current_status stolen_log.status
     * @return array { allowed: bool, error_code?: string, http_status?: int }
     */
    function dinoco_sn_validate_recovery_state( $current_status ) {
        $current_status = strtolower( trim( (string) $current_status ) );
        if ( in_array( $current_status, array( 'reported', 'verified' ), true ) ) {
            return array( 'allowed' => true );
        }
        if ( $current_status === 'recovered' ) {
            return array(
                'allowed'     => false,
                'error_code'  => 'already_recovered',
                'http_status' => 409,
            );
        }
        if ( $current_status === 'closed' ) {
            return array(
                'allowed'     => false,
                'error_code'  => 'closed_terminal',
                'http_status' => 422,
            );
        }
        return array(
            'allowed'     => false,
            'error_code'  => 'invalid_state',
            'http_status' => 422,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_stolen_recover' ) ) {
    /**
     * POST /stolen/{id}/recover — Phase 3 W11.2 dedicated recovery handler.
     *
     * Body:
     *   - recovery_date (string, required) — YYYY-MM-DD
     *   - notes (string, optional)         — admin annotation
     *   - evidence_attachment_ids (array, optional) — WP attachment IDs
     *
     * Atomic flow:
     *   GET_LOCK → START TRANSACTION → SELECT FOR UPDATE stolen_log →
     *   validate state → UPDATE stolen_log (recovered + recovered_at) →
     *   SELECT FOR UPDATE pool → revert status → INSERT audit row →
     *   COMMIT → RELEASE_LOCK → push LINE Flex (best-effort)
     *
     * Idempotency: keyed by id + recovery_date (different date = 409 conflict)
     */
    function dinoco_sn_rest_stolen_recover( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        return dinoco_sn_with_idempotency( $req, 'stolen-recover',
            array( 'id', 'recovery_date', 'notes' ),
            function( $req ) {
                global $wpdb;

                $id            = (int) $req->get_param( 'id' );
                $recovery_date = trim( (string) $req->get_param( 'recovery_date' ) );
                $notes         = trim( (string) $req->get_param( 'notes' ) );
                $evidence_ids  = (array) $req->get_param( 'evidence_attachment_ids' );

                if ( $id <= 0 ) {
                    return new WP_Error( 'invalid_id', __( 'Invalid stolen log id.', 'dinoco-sn' ), array( 'status' => 400 ) );
                }
                // Validate recovery_date YYYY-MM-DD
                if ( $recovery_date === '' || ! preg_match( '/^\d{4}-\d{2}-\d{2}$/', $recovery_date ) ) {
                    return new WP_Error( 'invalid_date',
                        __( 'recovery_date must be YYYY-MM-DD format.', 'dinoco-sn' ),
                        array( 'status' => 400 ) );
                }

                if ( ! function_exists( 'dinoco_sn_table_exists' ) ) {
                    return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
                }
                if ( ! dinoco_sn_table_exists( 'stolen_log' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
                    return new WP_Error( 'schema_not_ready',
                        __( 'Required tables not installed.', 'dinoco-sn' ),
                        array( 'status' => 503 ) );
                }

                $stolen_tbl = dinoco_sn_table( 'stolen_log' );
                $pool       = dinoco_sn_table( 'pool' );
                $actor      = (int) get_current_user_id();
                $lock_name  = 'dinoco_sn_stolen_recover_' . $id;

                // GET_LOCK — prevent two-admin race on same case
                $got_lock = (int) $wpdb->get_var( $wpdb->prepare(
                    'SELECT GET_LOCK(%s, 5)', $lock_name
                ) );
                if ( $got_lock !== 1 ) {
                    return new WP_Error( 'lock_failed',
                        __( 'Another admin is processing this case. Try again.', 'dinoco-sn' ),
                        array( 'status' => 409 ) );
                }

                $wpdb->query( 'START TRANSACTION' );
                try {
                    $row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT id, sn, user_id, status FROM {$stolen_tbl} WHERE id = %d FOR UPDATE",
                        $id
                    ), ARRAY_A );
                    if ( ! $row ) {
                        $wpdb->query( 'ROLLBACK' );
                        $wpdb->get_var( $wpdb->prepare( 'SELECT RELEASE_LOCK(%s)', $lock_name ) );
                        return new WP_Error( 'not_found',
                            __( 'Stolen log not found.', 'dinoco-sn' ),
                            array( 'status' => 404 ) );
                    }

                    $check = dinoco_sn_validate_recovery_state( $row['status'] );
                    if ( ! $check['allowed'] ) {
                        $wpdb->query( 'ROLLBACK' );
                        $wpdb->get_var( $wpdb->prepare( 'SELECT RELEASE_LOCK(%s)', $lock_name ) );
                        return new WP_Error( $check['error_code'],
                            sprintf( __( 'Cannot recover from state: %s', 'dinoco-sn' ), $row['status'] ),
                            array( 'status' => $check['http_status'] ) );
                    }

                    $now = current_time( 'mysql' );
                    $sn  = strtoupper( trim( (string) $row['sn'] ) );

                    // Update stolen_log → status='recovered' + recovered_at
                    // Defensive: only update if status is still in expected state
                    $upd_data = array( 'status' => 'recovered' );
                    // recovered_at column may exist depending on schema version
                    $cols = $wpdb->get_col( "SHOW COLUMNS FROM {$stolen_tbl}" );
                    if ( is_array( $cols ) && in_array( 'recovered_at', $cols, true ) ) {
                        $upd_data['recovered_at'] = $now;
                    }
                    $upd = $wpdb->update( $stolen_tbl,
                        $upd_data,
                        array( 'id' => $id, 'status' => $row['status'] )
                    );
                    if ( $upd === false || $upd === 0 ) {
                        throw new \RuntimeException( 'stolen_log update failed (concurrent modification)' );
                    }

                    // Revert pool status: recalled → prev_status (or 'registered' fallback)
                    $pool_row = $wpdb->get_row( $wpdb->prepare(
                        "SELECT status, prev_status, registered_user_id, linked_sku
                         FROM {$pool} WHERE sn = %s FOR UPDATE",
                        $sn
                    ), ARRAY_A );

                    $product_name = '';
                    $owner_uid    = 0;
                    if ( $pool_row ) {
                        $owner_uid = (int) ( $pool_row['registered_user_id'] ?? 0 );

                        // Determine target status — fallback to 'registered' if prev_status missing/invalid
                        $target_status = 'registered';
                        $valid_revert  = array( 'registered', 'claimed', 'shipped', 'allocated_to_order' );
                        if ( ! empty( $pool_row['prev_status'] ) && in_array( $pool_row['prev_status'], $valid_revert, true ) ) {
                            $target_status = $pool_row['prev_status'];
                        }

                        // Only revert if currently 'recalled' (defensive — don't revert non-stolen recall)
                        if ( $pool_row['status'] === 'recalled' ) {
                            $wpdb->update( $pool, array(
                                'status'      => $target_status,
                                'stolen_at'   => null,
                                'recalled_at' => null,
                            ), array( 'sn' => $sn, 'status' => 'recalled' ) );
                        }

                        // Resolve product name for Flex card
                        $linked_sku = (string) ( $pool_row['linked_sku'] ?? '' );
                        if ( $linked_sku !== '' && function_exists( 'b2b_get_product_data' ) ) {
                            $prod = b2b_get_product_data( $linked_sku );
                            if ( is_array( $prod ) && ! empty( $prod['title'] ) ) {
                                $product_name = (string) $prod['title'];
                            } elseif ( is_array( $prod ) && ! empty( $prod['name'] ) ) {
                                $product_name = (string) $prod['name'];
                            }
                        }
                    }

                    // Audit log — sensitive (5y retention)
                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log( $sn, 'plate_recovered',
                            $row['status'], 'recovered',
                            array(
                                'stolen_log_id' => $id,
                                'recovery_date' => $recovery_date,
                                'evidence_ids'  => $evidence_ids,
                                'owner_user_id' => $owner_uid,
                            ),
                            $actor, null,
                            $notes ?: 'plate recovered', 'stolen_recovered', true );
                    }

                    $wpdb->query( 'COMMIT' );
                    $wpdb->get_var( $wpdb->prepare( 'SELECT RELEASE_LOCK(%s)', $lock_name ) );

                    // Push LINE Flex to owner — best-effort (failure does NOT roll back DB)
                    $line_pushed = false;
                    if ( $owner_uid > 0 ) {
                        $line_uid = (string) get_user_meta( $owner_uid, 'dinoco_line_uid', true );
                        if ( $line_uid !== '' ) {
                            $flex = dinoco_sn_build_recovery_flex( $sn, $product_name, $now );
                            if ( function_exists( 'b2b_line_push_raw' ) ) {
                                try {
                                    $r = b2b_line_push_raw( $line_uid, array( $flex ) );
                                    $line_pushed = is_array( $r ) && (int) ( $r['code'] ?? 0 ) === 200;
                                } catch ( \Throwable $te ) {
                                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                                        dinoco_obs_capture( $te, array( 'context' => 'sn_stolen_recover_push', 'sn' => $sn ) );
                                    }
                                }
                            }
                        }
                    }

                    return rest_ensure_response( array(
                        'success'       => true,
                        'id'            => $id,
                        'sn'            => $sn,
                        'status_to'     => 'recovered',
                        'recovery_date' => $recovery_date,
                        'pool_reverted' => ( $pool_row && $pool_row['status'] === 'recalled' ),
                        'line_pushed'   => $line_pushed,
                    ) );
                } catch ( \Throwable $e ) {
                    $wpdb->query( 'ROLLBACK' );
                    $wpdb->get_var( $wpdb->prepare( 'SELECT RELEASE_LOCK(%s)', $lock_name ) );
                    if ( function_exists( 'dinoco_obs_capture' ) ) {
                        dinoco_obs_capture( $e, array( 'context' => 'sn_stolen_recover', 'id' => $id ) );
                    }
                    return new WP_Error( 'recover_failed', $e->getMessage(), array( 'status' => 500 ) );
                }
            }
        );
    }
}

if ( ! function_exists( 'dinoco_sn_photo_ocr_decide' ) ) {
    /**
     * Pure-logic decision matrix for photo OCR validation.
     * Mirrors chatbot-rules.md §15.8 Photo OCR Validation Chain.
     *
     * @param array|null $plate    sn_pool row (null if S/N not found)
     * @param string     $line_uid LINE UID of caller (or empty if not provided)
     * @return array {
     *   decision_code: string  — proceed / not_yet_active / block_voided /
     *                            block_recalled / block_stolen /
     *                            block_other_owner / not_found
     *   status:        string  — sn_pool.status echoed (or 'unknown')
     *   message_thai:  string  — chatbot-safe Thai message (no PII oracle leak)
     *   action_hint:   string  — suggested chatbot next step
     *   escalate:      bool    — true → Telegram บอส (M14 stolen / fake)
     * }
     */
    function dinoco_sn_photo_ocr_decide( $plate, $line_uid = '' ) {
        // S/N not in system — possible counterfeit (REG-084)
        if ( ! $plate || empty( $plate['sn'] ) ) {
            return array(
                'decision_code' => 'not_found',
                'status'        => 'unknown',
                'message_thai'  => 'S/N นี้ไม่ตรงกับฐานข้อมูล DINOCO',
                'action_hint'   => 'log_and_escalate',
                'escalate'      => true,
            );
        }

        $status = (string) ( $plate['status'] ?? 'unknown' );

        // Voided / recalled / stolen — block + escalate, NEVER reveal reason
        if ( in_array( $status, array( 'voided' ), true ) ) {
            return array(
                'decision_code' => 'block_voided',
                'status'        => $status,
                'message_thai'  => 'เพลทนี้ถูกยกเลิกในระบบ — กรุณาติดต่อทีมงาน DINOCO',
                'action_hint'   => 'show_support_contact',
                'escalate'      => true,
            );
        }
        if ( in_array( $status, array( 'recalled' ), true ) ) {
            return array(
                'decision_code' => 'block_recalled',
                'status'        => $status,
                'message_thai'  => 'เพลทนี้อยู่ในรอบ recall — กรุณาติดต่อร้านที่ซื้อเพื่อตรวจสอบ',
                'action_hint'   => 'show_support_contact',
                'escalate'      => true,
            );
        }
        // Stolen reported (sn_pool.status='registered' + sn_pool_meta.stolen_at IS NOT NULL)
        // is checked here only when caller passes plate with 'is_stolen' flag set.
        if ( ! empty( $plate['is_stolen'] ) ) {
            // REG-082: NEVER use the word "ถูกแจ้งหาย" in customer-facing reply
            return array(
                'decision_code' => 'block_stolen',
                'status'        => $status,
                'message_thai'  => 'เพลทนี้มีรายงานในระบบ — โปรดติดต่อ DINOCO Support 02-XXX-XXXX',
                'action_hint'   => 'show_support_contact',
                'escalate'      => true,
            );
        }

        // Pre-activate states — customer hasn't registered yet
        if ( in_array( $status, array( 'reserved', 'in_pool', 'reserved_for_legacy', 'shipped_legacy' ), true ) ) {
            return array(
                'decision_code' => 'not_yet_active',
                'status'        => $status,
                'message_thai'  => 'ยังไม่ activate — กรุณาลงทะเบียนสินค้าก่อนเปิดเคลม',
                'action_hint'   => 'show_activation_link',
                'escalate'      => false,
            );
        }

        // Registered — owner check
        if ( in_array( $status, array( 'registered', 'claimed' ), true ) ) {
            // Owner check is best-effort — if line_uid not provided or no
            // user_id stored on plate, skip cross-check + assume valid.
            $plate_owner_user_id = (int) ( $plate['registered_user_id'] ?? 0 );
            $line_uid = trim( (string) $line_uid );

            if ( $plate_owner_user_id > 0 && $line_uid !== '' ) {
                // Resolve LINE UID → WP user_id (caller's user)
                $caller_uid = 0;
                if ( function_exists( 'get_users' ) ) {
                    $matched = get_users( array(
                        'meta_key'   => 'dinoco_line_uid',
                        'meta_value' => $line_uid,
                        'fields'     => array( 'ID' ),
                        'number'     => 1,
                    ) );
                    if ( ! empty( $matched ) ) {
                        $caller_uid = (int) $matched[0]->ID;
                    }
                }

                if ( $caller_uid > 0 && $caller_uid !== $plate_owner_user_id ) {
                    // Different LINE UID claims this plate — possible stolen/transferred
                    return array(
                        'decision_code' => 'block_other_owner',
                        'status'        => $status,
                        'message_thai'  => 'เพลทนี้ลงทะเบียนกับเจ้าของอื่น — กรุณาติดต่อเรา ทีมงานจะตรวจสอบ',
                        'action_hint'   => 'open_investigation_ticket',
                        'escalate'      => true,
                    );
                }
            }

            return array(
                'decision_code' => 'proceed',
                'status'        => $status,
                'message_thai'  => 'ตรวจสอบ S/N เรียบร้อย — เริ่มเปิดเคลมได้',
                'action_hint'   => 'continue_claim_flow',
                'escalate'      => false,
            );
        }

        // Replaced / transferred / cancelled_batch — non-actionable
        return array(
            'decision_code' => 'not_yet_active',
            'status'        => $status,
            'message_thai'  => 'สถานะเพลทไม่พร้อมรับเคลม — กรุณาติดต่อทีมงาน',
            'action_hint'   => 'show_support_contact',
            'escalate'      => false,
        );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_photo_ocr_validate' ) ) {
    /**
     * POST /photo-ocr/validate — Phase 3 W8.6 / V.0.15 (Gap C)
     *
     * Photo OCR validation chain endpoint. Caller (OpenClaw claim-flow.js)
     * extracts S/N from customer photo, normalizes via §15.1 regex, POSTs
     * here. Server performs sn_pool lookup + decision matrix per §15.8.
     *
     * Response is PII-safe: returns decision_code + status + message_thai +
     * action_hint + escalate flag. NEVER returns owner identity even if
     * mismatch detected (caller gets generic 'block_other_owner' code only).
     */
    function dinoco_sn_rest_photo_ocr_validate( $req ) {
        $sn = (string) $req->get_param( 'sn' );
        $line_uid = (string) $req->get_param( 'line_uid' );

        // Format pre-check (chatbot-rules.md §15.1)
        if ( ! preg_match( '/^[A-Z0-9]{4,40}$/', $sn ) ) {
            return rest_ensure_response( array(
                'decision_code' => 'not_found',
                'status'        => 'unknown',
                'message_thai'  => 'รูปแบบ S/N ไม่ถูกต้อง — ตัวอย่าง: DNCSS0001234',
                'action_hint'   => 'request_retype',
                'escalate'      => false,
            ) );
        }

        $plate_data = null;
        if ( function_exists( 'dinoco_sn_get_plate_data' ) ) {
            $row = dinoco_sn_get_plate_data( $sn );
            if ( $row ) {
                // Convert object → array for decision helper
                $plate_data = (array) $row;

                // Optional: enrich with stolen flag from pool_meta if available
                if ( function_exists( 'dinoco_sn_get_plate_meta' ) ) {
                    $meta = dinoco_sn_get_plate_meta( $sn );
                    if ( $meta && ! empty( $meta->stolen_at ) ) {
                        $plate_data['is_stolen'] = true;
                    }
                }
            }
        }

        $decision = dinoco_sn_photo_ocr_decide( $plate_data, $line_uid );

        // Audit hook for forensics — fire even on failures
        if ( function_exists( 'do_action' ) ) {
            do_action( 'dinoco_sn_photo_ocr_validated', $sn, $decision, $line_uid );
        }

        return rest_ensure_response( $decision );
    }
}

