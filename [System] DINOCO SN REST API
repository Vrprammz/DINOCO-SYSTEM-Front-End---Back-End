if ( ! function_exists( 'dinoco_sn_rest_marketplace_quote' ) ) {
    function dinoco_sn_rest_marketplace_quote( $req ) {
        if ( ! dinoco_sn_marketplace_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'Marketplace disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return new WP_Error( 'schema_not_ready', __( 'sn_pool not installed.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }
        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        $requested_years = (int) $req->get_param( 'years' );
        if ( $sn === '' ) {
            return new WP_Error( 'invalid_input', __( 'sn required', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        $user_id = get_current_user_id();

        $row = function_exists( 'dinoco_sn_get_plate_data' ) ? dinoco_sn_get_plate_data( $sn ) : null;
        if ( ! $row ) {
            return new WP_Error( 'sn_not_found', __( 'S/N not found', 'dinoco-sn' ), array( 'status' => 404 ) );
        }
        if ( $row->status !== 'registered' ) {
            return new WP_Error( 'not_eligible',
                __( 'Plate must be registered to extend warranty', 'dinoco-sn' ),
                array( 'status' => 403, 'reason' => 'wrong_state', 'current_status' => $row->status ) );
        }
        // Ownership check
        if ( (int) $row->registered_user_id !== (int) $user_id ) {
            return new WP_Error( 'not_owner',
                __( 'You are not the registered owner of this plate', 'dinoco-sn' ),
                array( 'status' => 403, 'reason' => 'ownership_mismatch' ) );
        }

        $current_end = dinoco_sn_marketplace_resolve_warranty_end( $row );
        $warranty_status = dinoco_sn_marketplace_warranty_status( $current_end );
        if ( $warranty_status === 'expired_no_grace' ) {
            return new WP_Error( 'expired',
                __( 'Warranty expired beyond grace period (30 days)', 'dinoco-sn' ),
                array( 'status' => 403, 'reason' => 'expired_no_grace' ) );
        }

        $linked_sku = strtoupper( (string) ( $row->linked_sku ?? '' ) );
        $available = function_exists( 'dinoco_sn_extension_available' ) ? dinoco_sn_extension_available( $linked_sku ) : array();

        $product_name = '';
        if ( $linked_sku !== '' && class_exists( 'DINOCO_Catalog' ) ) {
            $prod = DINOCO_Catalog::get_by_sku( $linked_sku );
            if ( $prod && isset( $prod->title ) ) $product_name = (string) $prod->title;
        }

        $options = array();
        $new_ends = array();
        foreach ( array( 1, 2, 3 ) as $y ) {
            $base = $available[ $y ] ?? null;
            $offered = ( $base !== null );
            $quote = $offered ? dinoco_sn_marketplace_compute_quote( $base, $y ) : array(
                'years' => $y, 'base_price' => 0, 'vat' => 0, 'total' => 0, 'vat_rate' => 0.07,
            );
            $quote['available'] = $offered;
            // Savings hint vs 1y * N
            if ( $offered && isset( $available[1] ) && $y > 1 && $available[1] > 0 ) {
                $linear = $available[1] * $y;
                if ( $linear > $base ) {
                    $quote['savings_pct'] = (int) round( ( ( $linear - $base ) / $linear ) * 100 );
                }
            }
            $options[] = $quote;
            $new_end = dinoco_sn_marketplace_compute_new_warranty_end( $current_end, $y );
            if ( $new_end ) $new_ends[ (string) $y ] = $new_end;
        }

        return rest_ensure_response( array(
            'found'                          => true,
            'sn'                             => $sn,
            'product_name'                   => $product_name,
            'linked_sku'                     => $linked_sku,
            'current_warranty_end'           => $current_end,
            'warranty_status'                => $warranty_status,
            'options'                        => $options,
            'new_warranty_end_if_purchased'  => $new_ends,
            'ownership_verified'             => true,
            'requested_years'                => $requested_years,
        ) );
    }
}

