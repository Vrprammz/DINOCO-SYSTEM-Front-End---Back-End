                array('type'=>'text','text'=>'ออเดอร์ถูกยกเลิกโดยแอดมิน','size'=>'sm','color'=>'#374151','wrap'=>true),
            );
            if ($rev && $total > 0) {
                $body_items[] = array('type'=>'text','text'=>'คืนเครดิต ฿' . number_format($total, 0) . ' แล้ว','size'=>'sm','color'=>'#16a34a','margin'=>'sm','wrap'=>true);
            }
            $body_items[] = array('type'=>'text','text'=>'หากมีข้อสงสัยกรุณาติดต่อ DINOCO','size'=>'xs','color'=>'#64748b','margin'=>'sm','wrap'=>true);
            $flex_del = array('type'=>'flex','altText'=>'❌ ' . $del_label . ' #'.$tid,
                'contents'=>array('type'=>'bubble','size'=>'kilo',
                    'header'=>b2b_flex_header('❌ ' . $del_label, 'ออเดอร์ #'.$tid, '#dc2626'),
                    'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'14px','contents'=>$body_items)));
            if (function_exists('b2b_push_guaranteed')) {
                b2b_push_guaranteed($gid, array($flex_del), $tid, 'order_deleted');
            } elseif (function_exists('b2b_line_push_raw')) {
                b2b_line_push_raw($gid, array($flex_del));
            }
        } elseif (function_exists('b2b_line_push')) {
            b2b_line_push($gid, "❌ ออเดอร์ #{$tid} ถูกยกเลิกโดยแอดมิน" . ($rev ? "\nคืนเครดิต ฿" . number_format($total, 0) . " แล้ว" : ""));
        }
    }
    if(function_exists('b2b_log'))b2b_log('[Trash] #'.$tid.($rev?' reversed ฿'.number_format($total,0):''));
    return new WP_REST_Response(array('success'=>true,'message'=>'🗑️ ย้ายไปถังขยะ #'.$tid.' สำเร็จ'.($rev?' (คืนหนี้ ฿'.number_format($total,0).')':'')));
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══════════════════════════════════════
// V.9: C1 — Recalculate Total + Audit Log
// ═══════════════════════════════════════
function b2b_rest_recalculate_total( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    if(!$tid || get_post_type($tid)!=='b2b_order') return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ถูกต้อง'),400);

    $items_text = get_field('order_items', $tid) ?: '';
    $old_total  = floatval(get_field('total_amount', $tid));

    // Parse items: "ชื่อ (SKU) x3 = ฿1,500" format
    $new_total = 0;
    if (preg_match_all('/=\s*฿?([\d,]+)/u', $items_text, $matches)) {
        foreach ($matches[1] as $val) {
            $new_total += floatval(str_replace(',', '', $val));
        }
    }
    $new_total = round($new_total, 2);
    if ($new_total <= 0 && $old_total > 0) {
        return new WP_REST_Response(array('success'=>false,'message'=>'ไม่พบรายการราคาในออเดอร์'),400);
    }

    update_field('total_amount', $new_total, $tid);
    b2b_add_audit_log($tid, 'recalculate', '฿'.number_format($old_total,0).' → ฿'.number_format($new_total,0));

    return new WP_REST_Response(array(
        'success'   => true,
        'old_total' => $old_total,
        'new_total' => $new_total,
        'message'   => '🔄 คำนวณใหม่: ฿'.number_format($new_total,0),
    ));
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

/**
 * V.9: C1 — Audit Log Helper
 * บันทึก log เป็น post meta (serialized array)
 */
if (!function_exists('b2b_add_audit_log')) {
function b2b_add_audit_log( $post_id, $action, $detail = '' ) {
    $logs = get_post_meta($post_id, '_b2b_audit_log', true);
    if (!is_array($logs)) $logs = array();
    $user = wp_get_current_user();
    $logs[] = array(
        'time'   => current_time('Y-m-d H:i:s'),
        'user'   => $user->ID ? $user->display_name : 'system',
        'action' => sanitize_text_field($action),
        'detail' => sanitize_text_field($detail),
    );
    // Keep last 50 entries
    if (count($logs) > 50) $logs = array_slice($logs, -50);
    update_post_meta($post_id, '_b2b_audit_log', $logs);
}
} // end function_exists b2b_add_audit_log

