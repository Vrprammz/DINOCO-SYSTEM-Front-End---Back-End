<script>
(function(){
  var R='<?=esc_js($rest)?>',N='<?=esc_js($nonce)?>',cur=null;
  // V.32.4 UX-C2: dinocoModal confirm/alert helper with native fallback
  // opts optional: { title, danger, confirmText, cancelText, type }
  async function _b2bCfm(msg, opts) {
    opts = opts || {};
    try {
      return await window.dinocoModal.confirm({
        title: opts.title || 'ยืนยัน',
        message: msg,
        confirmText: opts.confirmText || 'ตกลง',
        cancelText: opts.cancelText || 'ยกเลิก',
        danger: !!opts.danger
      });
    } catch (e) { return confirm(msg); }
  }
  async function _b2bAlert(msg, type, title) {
    try { await window.dinocoModal.alert({ title: title || (type === 'error' ? 'เกิดข้อผิดพลาด' : 'แจ้งเตือน'), message: msg, type: type || 'info' }); }
    catch (e) { alert(msg); }
  }
  // V.10.0 A1: Search + Status filter combined
  var activeFilter='all';
  function filterRows(){
    var q=document.getElementById('dashSearch').value.toLowerCase();
    document.querySelectorAll('.dr').forEach(function(r){
      var matchFilter=(activeFilter==='all'||r.dataset.s===activeFilter);
      var matchSearch=!q||('#'+r.dataset.id).indexOf(q)>=0||(r.dataset.shop||'').toLowerCase().indexOf(q)>=0||(r.dataset.items||'').toLowerCase().indexOf(q)>=0||(r.dataset.claimed||'').toLowerCase().indexOf(q)>=0;
      r.style.display=(matchFilter&&matchSearch)?'':'none';
    });
  }
  document.getElementById('dashSearch').addEventListener('input',filterRows);
  document.querySelectorAll('.fb').forEach(function(b){b.addEventListener('click',function(){document.querySelectorAll('.fb').forEach(function(x){x.classList.remove('active')});this.classList.add('active');activeFilter=this.dataset.f;filterRows()})});
  // V.10.0 A3: Items expand/collapse
  document.querySelectorAll('.ip').forEach(function(el){el.addEventListener('click',function(e){e.stopPropagation();this.classList.toggle('collapsed');});});
  // V.31.1: Manual refresh button
  document.getElementById('btnManualRefresh').addEventListener('click',function(){
    var btn=this; btn.disabled=true; btn.textContent='🔄 กำลังโหลด...';
    if(window.switchTab){window.switchTab('b2b_dnc');}else{location.reload();}
    setTimeout(function(){btn.disabled=false;btn.textContent='🔄 Refresh';},2000);
    refreshSec=30;
  });
  // V.31.1: Auto-refresh — respects Admin Dashboard DINOCO_AUTO_REFRESH toggle
  var refreshSec=30,refreshTimer=setInterval(function(){
    if(window.DINOCO_AUTO_REFRESH===false){document.getElementById('refreshCountdown').textContent='⏸';return;}
    refreshSec--;document.getElementById('refreshCountdown').textContent=refreshSec;
    if(refreshSec<=0){
      refreshSec=30; // reset counter instead of clearInterval (keeps auto-refresh looping)
      if(window.switchTab){window.switchTab('b2b_dnc');}else{location.reload();}
    }
  },1000);
  // V.10.0 A6: CSV Export
  document.getElementById('btnExportCSV').addEventListener('click',function(){
    var rows=[['#ID','วันที่','ร้านค้า','สถานะ','รายการ','ยอดรวม','แอดมิน']];
    document.querySelectorAll('.dr').forEach(function(r){if(r.style.display==='none')return;
      rows.push([r.dataset.id,r.children[2]?r.children[2].textContent:'',r.dataset.shop||'',r.dataset.s,'"'+(r.dataset.items||'').replace(/"/g,'""')+'"',r.dataset.total,r.dataset.claimed||'']);});
    var csv='\uFEFF'+rows.map(function(r){return r.join(',')}).join('\n');
    var blob=new Blob([csv],{type:'text/csv;charset=utf-8'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='dinoco-orders-'+new Date().toISOString().slice(0,10)+'.csv';a.click();toast('📥 Export CSV สำเร็จ','ok');
  });
