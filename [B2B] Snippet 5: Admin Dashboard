function b2b_rest_update_status( WP_REST_Request $r ) {
    try {
    $tid=intval($r->get_param('ticket_id'));$st=sanitize_text_field($r->get_param('status'));
    if(!$tid||get_post_type($tid)!=='b2b_order') return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ถูกต้อง'),400);
    if(function_exists('b2b_allowed_statuses')&&!in_array($st,b2b_allowed_statuses(),true)) return new WP_REST_Response(array('success'=>false,'message'=>'สถานะไม่ถูกต้อง'),400);
    $old_st = get_field('order_status',$tid) ?: 'unknown';
    // Status transition validation — prevent illegal transitions (relaxed for admin flexibility)
    $valid_transitions = array(
        'draft'=>array('checking_stock','awaiting_confirm','cancelled'),
        'pending'=>array('checking_stock','awaiting_confirm','cancelled'),
        'checking_stock'=>array('backorder','awaiting_confirm','awaiting_payment','ready_to_ship','cancelled'),
        'backorder'=>array('checking_stock','awaiting_confirm','awaiting_payment','cancelled'),
        'awaiting_confirm'=>array('awaiting_payment','checking_stock','ready_to_ship','cancelled'),
        'awaiting_payment'=>array('paid','ready_to_ship','cancelled'),
        'paid'=>array('ready_to_ship','shipped','cancelled'),
        'ready_to_ship'=>array('shipped','cancelled'),
        'shipped'=>array('completed','claim_opened','cancelled'),
        'completed'=>array('claim_opened','cancelled'),
        'claim_opened'=>array('claim_resolved','shipped'),
        'claim_resolved'=>array('completed'),
        'cancel_requested'=>array('cancelled','pending','checking_stock'),
        'change_requested'=>array('pending','checking_stock','cancelled'),
    );
    if (isset($valid_transitions[$old_st]) && !in_array($st, $valid_transitions[$old_st], true))
        return new WP_REST_Response(array('success'=>false,'message'=>'ไม่สามารถเปลี่ยนจาก '.$old_st.' เป็น '.$st.' ได้'),400);
    // V.31.3: completed→cancelled เฉพาะ walk-in เท่านั้น
    if ($old_st === 'completed' && $st === 'cancelled') {
        $is_walkin = function_exists('b2b_is_walkin_order') && b2b_is_walkin_order($tid);
        if (!$is_walkin) {
            return new WP_REST_Response(array('success'=>false,'message'=>'ยกเลิกได้เฉพาะ Walk-in order ที่ completed แล้วเท่านั้น'),400);
        }
    }
    b2b_set_order_status($tid,$st);
    // V.14.0: Reverse debt when cancelling a billed order
    // FIX C4: Use atomic debt operations for cancel
    if ($st === 'cancelled' && $old_st !== 'cancelled') {
        $was_billed = get_field('is_billed', $tid);
        if ($was_billed) {
            $total = floatval(get_field('total_amount', $tid));
            $gid = get_field('source_group_id', $tid);
            $dist_id_cancel = 0;
            if ($gid && function_exists('b2b_get_dist_by_group')) {
                $dist = b2b_get_dist_by_group($gid);
                if ($dist) $dist_id_cancel = $dist->ID;
            }
            // Also check _dist_post_id for manual invoices
            if (!$dist_id_cancel) $dist_id_cancel = intval(get_post_meta($tid, '_dist_post_id', true));
            if ($total > 0 && $dist_id_cancel) {
                update_field('is_billed', false, $tid);
                if (function_exists('b2b_recalculate_debt')) {
                    b2b_recalculate_debt($dist_id_cancel);
                } elseif (function_exists('b2b_debt_subtract')) {
                    b2b_debt_subtract($dist_id_cancel, $total, 'dashboard_cancel', $tid);
                }
                b2b_add_audit_log($tid, 'debt_reversed', 'Cancel reversed ฿'.number_format($total,0));
            }
        }
    }
    // V.31.4: Notify customer group when ANY order is cancelled from S5
    // V.31.8: Dedup guard — ป้องกัน Flex ยกเลิกซ้ำ (delete-ticket ส่งเองอีกรอบ)
    if ($st === 'cancelled' && $old_st !== 'cancelled' && !get_post_meta($tid, '_cancel_flex_sent', true)) {
        update_post_meta($tid, '_cancel_flex_sent', 1);
        $notify_gid = get_field('source_group_id', $tid);
        if ($notify_gid) {
            $cancel_total = floatval(get_field('total_amount', $tid));
            $was_billed_notify = !empty($was_billed);
            $is_walkin_cancel = function_exists('b2b_is_walkin_order') && b2b_is_walkin_order($tid);
            $cancel_label = $is_walkin_cancel ? 'ยกเลิก Walk-in' : 'ยกเลิกออเดอร์';
            if (function_exists('b2b_flex_header')) {
                $body_items = array(
                    array('type'=>'text','text'=>'ออเดอร์ถูกยกเลิกโดยแอดมิน','size'=>'sm','color'=>'#374151','wrap'=>true),
                );
                if ($was_billed_notify && $cancel_total > 0) {
                    $body_items[] = array('type'=>'text','text'=>'คืนเครดิต ฿' . number_format($cancel_total, 0) . ' แล้ว','size'=>'sm','color'=>'#16a34a','margin'=>'sm','wrap'=>true);
                }
                $body_items[] = array('type'=>'text','text'=>'หากมีข้อสงสัยกรุณาติดต่อ DINOCO','size'=>'xs','color'=>'#64748b','margin'=>'sm','wrap'=>true);
                $flex_msg = array('type'=>'flex','altText'=>'❌ ' . $cancel_label . ' #'.$tid,
                    'contents'=>array('type'=>'bubble','size'=>'kilo',
                        'header'=>b2b_flex_header('❌ ' . $cancel_label, 'ออเดอร์ #'.$tid, '#dc2626'),
                        'body'=>array('type'=>'box','layout'=>'vertical','paddingAll'=>'14px','contents'=>$body_items)));
                if (function_exists('b2b_push_guaranteed')) {
                    b2b_push_guaranteed($notify_gid, array($flex_msg), $tid, 'order_cancelled');
                } elseif (function_exists('b2b_line_push_raw')) {
                    b2b_line_push_raw($notify_gid, array($flex_msg));
                }
            } elseif (function_exists('b2b_line_push')) {
                $text_msg = "❌ ออเดอร์ #{$tid} ถูกยกเลิกโดยแอดมิน";
                if ($was_billed_notify && $cancel_total > 0) {
                    $text_msg .= "\nคืนเครดิต ฿" . number_format($cancel_total, 0) . " แล้ว";
                }
                b2b_line_push($notify_gid, $text_msg);
            }
        }
    }
    // V.11.0: Auto-set due_date when changing to awaiting_payment (if not already set)
    // FIX H-6: Auto-set is_billed + add debt when status changed to awaiting_payment
    if ($st === 'awaiting_payment') {
        $was_billed_check = get_field('is_billed', $tid);
        if (!$was_billed_check) {
            update_field('is_billed', true, $tid);
            $total_for_bill = floatval(get_field('total_amount', $tid));
            $gid_bill = get_field('source_group_id', $tid);
            $dist_id_bill = 0;
            if ($gid_bill && function_exists('b2b_get_dist_by_group')) {
                $dist_b = b2b_get_dist_by_group($gid_bill);
                if ($dist_b) $dist_id_bill = $dist_b->ID;
            }
            if (!$dist_id_bill) $dist_id_bill = intval(get_post_meta($tid, '_dist_post_id', true));
            if ($total_for_bill > 0 && $dist_id_bill) {
                if (function_exists('b2b_debt_add')) { b2b_debt_add($dist_id_bill, $total_for_bill, 'dashboard_bill', $tid); }
                elseif (function_exists('b2b_recalculate_debt')) { b2b_recalculate_debt($dist_id_bill); }
            }
            b2b_add_audit_log($tid, 'auto_billed', 'Auto is_billed=true via dashboard status change');
        }
        $existing_dd = get_field('due_date', $tid);
        if (empty($existing_dd)) {
            $due = b2b_date('Y-m-d', strtotime('+7 days', strtotime(b2b_date('Y-m-d'))));
            update_field('due_date', $due, $tid);
            b2b_add_audit_log($tid, 'due_date_set', 'Auto due_date: '.$due);
        }
    }
    // V.9: C1 audit log
    b2b_add_audit_log($tid, 'status_change', $old_st.' → '.$st);
    return new WP_REST_Response(array('success'=>true,'message'=>'สถานะ → '.$st));
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

function b2b_rest_delete_ticket( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    $post = get_post($tid);
    if(!$post || $post->post_type !== 'b2b_order')
        return new WP_REST_Response(array('success'=>false,'message'=>'ไม่พบ Ticket #'.$tid.' (อาจลบแล้ว)'),400);
    // FIX C5: set is_billed=false before trash + use recalculate_debt
    $billed=get_field('is_billed',$tid);$total=floatval(get_field('total_amount',$tid));$gid=get_field('source_group_id',$tid);$rev=false;
    $dist_id_del = 0;
    if ($gid && function_exists('b2b_get_dist_by_group')) {
        $dist = b2b_get_dist_by_group($gid);
        if ($dist) $dist_id_del = $dist->ID;
    }
    if (!$dist_id_del) $dist_id_del = intval(get_post_meta($tid, '_dist_post_id', true));
    if ($billed && $total > 0 && $dist_id_del) {
        update_field('is_billed', false, $tid);
        if (function_exists('b2b_recalculate_debt')) { b2b_recalculate_debt($dist_id_del); }
        elseif (function_exists('b2b_debt_subtract')) { b2b_debt_subtract($dist_id_del, $total, 'delete_ticket', $tid); }
        $rev = true;
    }
    // V.32.0: Cancel Flash orders ถ้ามี (ก่อนลบ)
    $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
    $flash_cancelled = 0;
    if (!empty($pno_statuses) && is_array($pno_statuses) && function_exists('b2b_flash_cancel_order')) {
        foreach ($pno_statuses as $pno => $pno_info) {
            $pno_status = is_array($pno_info) ? ($pno_info['status'] ?? '') : $pno_info;
            // Cancel เฉพาะ PNO ที่ยังไม่ได้เรียกคูเรีย (ไม่ใช่ shipped/delivered/completed)
            $skip = in_array($pno_status, ['shipped', 'delivered', 'completed', 'cancelled']);
            if (!$skip) {
                $cancel_result = b2b_flash_cancel_order($pno);
                if (function_exists('b2b_log')) b2b_log("[Trash] Cancel Flash PNO: {$pno} result=" . ($cancel_result ? 'OK' : 'FAIL'));
                $flash_cancelled++;
            }
        }
    }

    // V.32.0: คืนสต็อก ถ้าเคยตัดไป (Inventory system)
    // V.31.7: guard _stock_returned — hook ใน Snippet 2 (priority 5) อาจคืนไปแล้ว
    if (get_post_meta($tid, '_stock_deducted', true) && !get_post_meta($tid, '_stock_returned', true) && function_exists('dinoco_stock_add')) {
        $order_text = get_field('order_items', $tid) ?: '';
        if (preg_match_all('/\(([A-Za-z0-9_\-]+)\)\s*x(\d+)/i', $order_text, $matches, PREG_SET_ORDER)) {
            // V.6.0 [C-1 FIX]: คืนสต็อกเฉพาะ leaf nodes
            $relations = get_option('dinoco_sku_relations', []);
            foreach ($matches as $m) {
                $sku = strtoupper(trim($m[1]));
                $qty = intval($m[2]);
                if ($qty <= 0) continue;
                if (function_exists('dinoco_get_leaf_skus')) {
                    $leaf_skus = dinoco_get_leaf_skus($sku, $relations);
                    foreach ($leaf_skus as $leaf) {
                        dinoco_stock_add($leaf, $qty, 'b2b_cancel_return', 'b2b_order', $tid);
                    }
                } elseif (isset($relations[$sku]) && !empty($relations[$sku])) {
                    foreach ($relations[$sku] as $child) {
                        dinoco_stock_add($child, $qty, 'b2b_cancel_return', 'b2b_order', $tid);
                    }
                } else {
                    dinoco_stock_add($sku, $qty, 'b2b_cancel_return', 'b2b_order', $tid);
                }
            }
        }
        delete_post_meta($tid, '_stock_deducted');
    }

    // V.31.9: Clear SLA alerts ก่อน trash — ป้องกัน SLA nag หลัง cancel
    if (function_exists('b2b_clear_sla_nag')) {
        b2b_clear_sla_nag($tid);
    }
    wp_trash_post($tid);
    // V.31.8: ส่ง Flex ยกเลิกไปกลุ่มลูกค้าเมื่อลบ order (dedup guard)
    if ($gid && !get_post_meta($tid, '_cancel_flex_sent', true)) {
        update_post_meta($tid, '_cancel_flex_sent', 1);
        $is_walkin_del = function_exists('b2b_is_walkin_order') && b2b_is_walkin_order($tid);
