// ═══════════════════════════════════════
// Switch Flash → Manual shipping (cancel Flash + reprint + tracking prompt)
// ═══════════════════════════════════════
function b2b_rest_flash_switch_manual( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    if (!$tid || get_post_type($tid) !== 'b2b_order')
        return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ถูกต้อง'), 400);

    $packing = get_post_meta($tid, '_flash_packing_status', true);
    if (!in_array($packing, array('notify_error','flash_created','print_queued','print_done','flash_create_error'), true))
        return new WP_REST_Response(array('success'=>false,'message'=>'สถานะไม่สามารถเปลี่ยนเป็นส่งเองได้ (สถานะ: '.$packing.')'), 400);

    // Step 1: Cancel Flash parcels (if tracking exists)
    $pnos = get_post_meta($tid, '_flash_tracking_numbers', true);
    $cancel_errors = array();
    if (!empty($pnos) && function_exists('b2b_flash_cancel_order')) {
        foreach ((array)$pnos as $pno) {
            $result = b2b_flash_cancel_order($pno);
            if (!$result['ok']) {
                $code = isset($result['code']) ? $result['code'] : 0;
                if ($code == 1015) { $cancel_errors[] = $pno.': คูเรียร์รับไปแล้ว'; }
                else { $cancel_errors[] = $pno.': '.($result['error']??'Unknown'); }
            }
        }
    }
    if (!empty($cancel_errors))
        return new WP_REST_Response(array('success'=>false,'message'=>'ยกเลิก Flash ไม่ได้: '.implode('; ', $cancel_errors)), 400);

    // Step 2: Cancel courier pickup if exists
    $pickup_id = get_post_meta($tid, '_flash_pickup_id', true);
    if ($pickup_id && function_exists('b2b_flash_cancel_notify')) {
        b2b_flash_cancel_notify($pickup_id);
        delete_post_meta($tid, '_flash_pickup_id');
    }

    // Step 3: Clear Flash data
    // V.36: Update per-PNO statuses
    $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
    if (is_array($pno_statuses)) {
        foreach ($pno_statuses as $_p => &$_info) {
            if (is_array($_info)) $_info['status'] = 'cancelled';
        }
        unset($_info);
        update_post_meta($tid, '_flash_pno_statuses', $pno_statuses);
    }
    delete_post_meta($tid, '_flash_tracking_numbers');
    update_field('tracking_number', '', $tid);
    update_post_meta($tid, '_flash_packing_status', 'cancelled');
    update_post_meta($tid, '_flash_status', 'cancelled');
    update_post_meta($tid, '_flash_notify_error', '');

    // Step 4: Switch to manual
    update_post_meta($tid, '_ship_method', 'manual');
    update_field('shipping_provider', '', $tid);

    // Step 5: Enqueue print job (manual label + invoice + picking list)
    if (function_exists('b2b_enqueue_print_job')) b2b_enqueue_print_job($tid);

    // Step 6: Audit log
    if (function_exists('b2b_add_audit_log'))
        b2b_add_audit_log($tid, 'switch_to_manual', 'เปลี่ยนจาก Flash เป็นส่งเอง — พิมพ์ใบแปะหน้าธรรมดา');

    // Step 7: LINE notify admin group
    $dist_name = get_field('dist_name', $tid) ?: '';
    if (function_exists('b2b_build_flex_flash_admin') && function_exists('b2b_push_raw_to_admin')) {
        $admin_flex = b2b_build_flex_flash_admin($tid, 'switch_manual', array(
            'reason' => 'เปลี่ยนจาก Flash → ส่งเอง (Kerry/J&T/อื่นๆ)',
        ));
        b2b_push_raw_to_admin(array($admin_flex));
    }
    // Step 8: Push tracking prompt — remind admin to enter tracking later
    if (function_exists('b2b_build_flex_tracking_prompt') && function_exists('b2b_push_raw_to_admin')) {
        $tracking_flex = b2b_build_flex_tracking_prompt($tid, $dist_name);
        b2b_push_raw_to_admin(array($tracking_flex));
    }

    b2b_log('[AdminDash] Switch to manual #'.$tid);
    return new WP_REST_Response(array(
        'success' => true,
        'message' => 'เปลี่ยน #'.$tid.' เป็นส่งเองแล้ว — กำลังพิมพ์ใบแปะหน้าธรรมดา',
    ));
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

