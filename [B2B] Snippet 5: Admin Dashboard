function b2b_render_admin_dashboard(){
    if(!current_user_can('manage_options')) return '<div style="padding:40px;text-align:center;color:#ef4444;">⛔ ไม่มีสิทธิ์</div>';
    try {
    $nonce=wp_create_nonce('wp_rest');$rest=preg_replace('/^https?:\/\/[^\/]+/','',rest_url('b2b/v1/'));

    // V.10.0 A4: Pagination
    $page = max(1, intval($_GET['dash_page'] ?? 1));
    $per_page = 50;
    $orders=get_posts(array('post_type'=>'b2b_order','posts_per_page'=>$per_page,'paged'=>$page,'post_status'=>'publish','orderby'=>'date','order'=>'DESC'));
    if ( !empty($orders) ) {
        if(function_exists('update_post_meta_cache')) update_post_meta_cache(wp_list_pluck($orders, 'ID'));
    }
    $total_orders = wp_count_posts('b2b_order')->publish;
    $total_pages = max(1, ceil($total_orders / $per_page));

    $sl=function_exists('b2b_get_status_labels')?b2b_get_status_labels():array('draft'=>'📝 Draft','checking_stock'=>'🔍 เช็คสต็อก','awaiting_confirm'=>'📋 รอยืนยันบิล','awaiting_payment'=>'💳 รอชำระเงิน','paid'=>'✅ จ่ายแล้ว','ready_to_ship'=>'📦 รอแพ็ค/จัดส่ง','shipped'=>'🚚 จัดส่งแล้ว','completed'=>'✅ เสร็จสิ้น','backorder'=>'🔴 Backorder','cancel_requested'=>'🟡 ขอยกเลิก','cancelled'=>'🗑️ ยกเลิกแล้ว','change_requested'=>'🔧 ขอแก้ไข','claim_opened'=>'📢 เคลม','claim_resolved'=>'✅ เคลมเสร็จ');
    $scc=array('draft'=>'#94a3b8','checking_stock'=>'#f59e0b','awaiting_confirm'=>'#8b5cf6','awaiting_payment'=>'#ea580c','paid'=>'#16a34a','ready_to_ship'=>'#0ea5e9','shipped'=>'#10b981','completed'=>'#059669','backorder'=>'#dc2626','cancel_requested'=>'#ef4444','cancelled'=>'#6b7280','change_requested'=>'#7c3aed','claim_opened'=>'#db2777','claim_resolved'=>'#16a34a');

    // V.31.6: Stats — SQL aggregation (แทน get_posts -1 + loop get_field ที่ช้ามาก)
    global $wpdb;
    $stats = array('total'=>0,'checking_stock'=>0,'awaiting_confirm'=>0,'awaiting_payment'=>0,'ready_to_ship'=>0,'shipped'=>0);
    $sc_raw = $wpdb->get_results("
        SELECT pm.meta_value AS s, COUNT(*) AS c
        FROM {$wpdb->posts} p
        INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = 'order_status'
        WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
        GROUP BY pm.meta_value
    ", ARRAY_A);
    foreach ($sc_raw as $r) {
        $stats['total'] += intval($r['c']);
        if (isset($stats[$r['s']])) $stats[$r['s']] = intval($r['c']);
    }

    // V.31.6: Flash stats — SQL aggregation (แทน get_posts -1 + loop)
    $fstats=array('f_waiting'=>0,'f_active'=>0,'f_delivered'=>0,'f_problem'=>0);
    try {
        $flash_raw = $wpdb->get_results("
            SELECT pm.meta_value AS fps, COUNT(*) AS c
            FROM {$wpdb->posts} p
            INNER JOIN {$wpdb->postmeta} pm ON p.ID = pm.post_id AND pm.meta_key = '_flash_packing_status'
            WHERE p.post_type = 'b2b_order' AND p.post_status = 'publish'
              AND pm.meta_value != ''
            GROUP BY pm.meta_value
        ", ARRAY_A);
        foreach ($flash_raw as $r) {
            $fps = $r['fps'];
            $c   = intval($r['c']);
            if (in_array($fps, array('flash_created','print_queued','print_done'), true)) $fstats['f_waiting'] += $c;
            elseif (in_array($fps, array('ready_to_ship','courier_called','picked_up','in_transit','delivering'), true)) $fstats['f_active'] += $c;
            elseif ($fps === 'delivered') $fstats['f_delivered'] += $c;
            elseif (in_array($fps, array('detained','returned','flash_create_error','notify_error'), true)) $fstats['f_problem'] += $c;
        }
    } catch (\Throwable $e) {
        error_log('[S5] Flash stats error: ' . $e->getMessage());
    }

    $od=array();
    foreach($orders as $o){
        $s=get_field('order_status',$o->ID)?:'draft';
        $cnote = get_field('customer_note',$o->ID) ?: '';
        $sublabel = get_field('sub_label',$o->ID) ?: '';
        $parent_tid = get_field('parent_ticket_id',$o->ID) ?: '';
        $audit = get_post_meta($o->ID, '_b2b_audit_log', true);
        $audit_json = (is_array($audit) && !empty($audit)) ? wp_json_encode($audit) : '[]';
        // V.10.0 A2: shop_name from distributor
        $gid = get_field('source_group_id',$o->ID)?:'';
        $shop_name = '';
        if ($gid && function_exists('b2b_get_dist_by_group')) {
            $dist = b2b_get_dist_by_group($gid);
            $shop_name = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '';
        }
        $print_st = get_field('print_status',$o->ID) ?: 'none';
        $print_err = get_field('print_error',$o->ID) ?: '';
        $print_ts  = get_field('print_timestamp',$o->ID) ?: '';
        $print_det = get_field('print_details',$o->ID) ?: '';
        $ship_method = get_post_meta($o->ID, '_ship_method', true) ?: '';
        $flash_ps = get_post_meta($o->ID, '_flash_packing_status', true) ?: 'none';
        $flash_err = get_post_meta($o->ID, '_flash_create_error', true) ?: '';
        $od[]=array('id'=>$o->ID,'date'=>b2b_date('d/m/Y H:i',get_post_time('U',true,$o->ID)),'status'=>$s,'total'=>floatval(get_field('total_amount',$o->ID)),'items'=>get_field('order_items',$o->ID)?:'','note'=>get_field('admin_note',$o->ID)?:'','group_id'=>$gid,'claimed_by'=>get_field('claimed_by_admin',$o->ID)?:get_field('stock_checked_by',$o->ID)?:'','tracking'=>get_field('tracking_number',$o->ID)?:'','is_billed'=>(bool)get_field('is_billed',$o->ID),'customer_note'=>$cnote,'sub_label'=>$sublabel,'parent_tid'=>$parent_tid,'audit'=>$audit_json,'shop_name'=>$shop_name,'print_status'=>$print_st,'print_error'=>$print_err,'print_timestamp'=>$print_ts,'print_details'=>$print_det,'ship_method'=>$ship_method,'flash_ps'=>$flash_ps,'flash_err'=>$flash_err);
    }
    ob_start();
?>
