add_action( 'rest_api_init', function () {
    $ap = function( WP_REST_Request $req ) {
        return wp_verify_nonce( $req->get_header('X-WP-Nonce'), 'wp_rest' ) && current_user_can('manage_options');
    };
    register_rest_route('b2b/v1','/confirm-order',    array('methods'=>'POST','callback'=>'b2b_rest_confirm_order','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/flash-create',     array('methods'=>'POST','callback'=>'b2b_rest_flash_create','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/daily-summary',    array('methods'=>'POST','callback'=>'b2b_rest_trigger_summary','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/update-status',    array('methods'=>'POST','callback'=>'b2b_rest_update_status','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/delete-ticket',    array('methods'=>'POST','callback'=>'b2b_rest_delete_ticket','permission_callback'=>$ap));
    // V.9: C1 — Recalculate endpoint
    register_rest_route('b2b/v1','/recalculate-total', array('methods'=>'POST','callback'=>'b2b_rest_recalculate_total','permission_callback'=>$ap));
    // V.22: Flash Phase 3-5 endpoints
    register_rest_route('b2b/v1','/flash-label',         array('methods'=>'POST','callback'=>'b2b_rest_flash_label','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/flash-ready-to-ship',  array('methods'=>'POST','callback'=>'b2b_rest_flash_ready_to_ship','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/flash-cancel',         array('methods'=>'POST','callback'=>'b2b_rest_flash_cancel','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/flash-cancel-notify',  array('methods'=>'POST','callback'=>'b2b_rest_flash_cancel_notify','permission_callback'=>$ap));
    register_rest_route('b2b/v1','/flash-switch-manual',  array('methods'=>'POST','callback'=>'b2b_rest_flash_switch_manual','permission_callback'=>$ap));
    // Flash tracking force update (admin only — ใช้ poll Flash API + update สถานะ)
    register_rest_route('b2b/v1','/debug-flash/(?P<ticket_id>\d+)', array('methods'=>'GET','permission_callback'=>$ap,
        'callback'=>function( WP_REST_Request $req ) {
            $tid = intval($req->get_param('ticket_id'));
            $post = get_post($tid);
            if (!$post) return rest_ensure_response(array('error'=>'not found'));

            $pno = get_field('tracking_number',$tid) ?: '';
            $result = array(
                'ticket_id'   => $tid,
                'order_status'=> get_field('order_status',$tid),
                'flash_packing'=> get_post_meta($tid,'_flash_packing_status',true),
                'tracking'    => $pno,
            );

            // ดึง Flash Routes API + UPDATE สถานะจริง
            if ($pno && function_exists('b2b_flash_get_routes')) {
                $routes = b2b_flash_get_routes($pno);
                if (!is_wp_error($routes) && isset($routes['data']['state'])) {
                    $flash_state = intval($routes['data']['state']);
                    $state_map = array(1=>'picked_up',2=>'in_transit',3=>'delivering',4=>'detained',5=>'delivered',6=>'problem',7=>'returned',8=>'cancelled');
                    $new_packing = isset($state_map[$flash_state]) ? $state_map[$flash_state] : 'unknown_'.$flash_state;

                    // Update meta
                    update_post_meta($tid, '_flash_packing_status', $new_packing);
                    update_post_meta($tid, '_flash_status', $new_packing);

                    // Update PNO statuses
                    $pno_data = get_post_meta($tid, '_flash_pno_statuses', true) ?: array();
                    if (isset($pno_data[$pno])) {
                        $pno_data[$pno]['status'] = $new_packing;
                    }
                    update_post_meta($tid, '_flash_pno_statuses', $pno_data);

                    // V.32.3 H9 FIX: route Flash auto-update through canonical FSM helper
                    //   b2b_set_order_status() routes through B2B_Order_FSM::transition() →
                    //   fires do_action('b2b_order_status_changed') + logs history + validates transition.
                    //   Idempotency: FSM rejects same-status or terminal transitions → second webhook is a no-op.
                    //   Re-fetch $order_status after each call so chained transitions (packed→shipped→completed)
                    //   on a single delivered webhook see fresh DB state, not stale local variable.
                    $order_status = get_field('order_status', $tid);
                    if ( $flash_state >= 1 && $order_status === 'packed' ) {
                        if ( function_exists('b2b_set_order_status') ) {
                            b2b_set_order_status( $tid, 'shipped' );
                        } else {
                            // Defensive fallback — still fire hook so downstream listeners don't miss the edge
                            update_field('order_status', 'shipped', $tid);
                            do_action('b2b_order_status_changed', $tid, 'packed', 'shipped', 'system');
                        }
                        $order_status = get_field('order_status', $tid);
                        $result['order_status_updated'] = 'packed → ' . $order_status;
                    }
                    if ( $flash_state === 5 && in_array( $order_status, array('packed','shipped'), true ) ) {
                        $prev = $order_status;
                        if ( function_exists('b2b_set_order_status') ) {
                            b2b_set_order_status( $tid, 'completed' );
                        } else {
                            update_field('order_status', 'completed', $tid);
                            do_action('b2b_order_status_changed', $tid, $prev, 'completed', 'system');
                        }
                        $after = get_field('order_status', $tid);
                        $chain = isset($result['order_status_updated']) ? $result['order_status_updated'] . ' + ' : '';
                        $result['order_status_updated'] = $chain . $prev . ' → ' . $after;
                    }

                    $result['flash_state'] = $flash_state;
                    $result['flash_state_text'] = $routes['data']['stateText'] ?? '';
                    $result['updated_packing'] = $new_packing;
                    $result['routes_count'] = count($routes['data']['routes'] ?? array());
                }
                $result['flash_api'] = 'OK';
            } else {
                $result['flash_api'] = 'function not available or API error';
            }

            // Re-read after update
            $result['after'] = array(
                'order_status' => get_field('order_status',$tid),
                'flash_packing'=> get_post_meta($tid,'_flash_packing_status',true),
            );

            // Cron diagnostics
            $result['cron_diag'] = array(
                'DISABLE_WP_CRON' => defined('DISABLE_WP_CRON') ? DISABLE_WP_CRON : 'not defined',
                'flash_cron_next' => wp_next_scheduled('b2b_flash_tracking_cron'),
                'fn_tracking'     => function_exists('b2b_run_flash_tracking_fallback'),
                'fn_get_routes'   => function_exists('b2b_flash_get_routes'),
                'all_crons'       => array_keys(wp_get_schedules()),
            );

            // Force re-schedule flash cron (ใช้ interval ที่มีอยู่จริง)
            if (!wp_next_scheduled('b2b_flash_tracking_cron')) {
                wp_clear_scheduled_hook('b2b_flash_tracking_cron');
                $avail = wp_get_schedules();
                $intv = isset($avail['every_2hr_b2b']) ? 'every_2hr_b2b' : (isset($avail['everytwohours']) ? 'everytwohours' : 'twicedaily');
                $scheduled = wp_schedule_event(time() + 120, $intv, 'b2b_flash_tracking_cron');
                $result['cron_diag']['force_schedule'] = ($scheduled === true || $scheduled === null) ? 'OK ('.$intv.')' : 'FAILED';
                $result['cron_diag']['flash_cron_after'] = wp_next_scheduled('b2b_flash_tracking_cron');
            }

            return rest_ensure_response($result);
        }));
});

function b2b_rest_confirm_order( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    if(!$tid || get_post_type($tid)!=='b2b_order') return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ถูกต้อง'),400);
    $total = floatval($r->get_param('total_amount'));
    $note  = sanitize_textarea_field($r->get_param('admin_note'));
    $st    = sanitize_text_field($r->get_param('status'));
    // V.31 SEC: Validate price bounds + audit log
    if($total>0) {
        if($total > 10000000) return new WP_REST_Response(array('success'=>false,'message'=>'ยอดเงินเกินขีดจำกัด'),400);
        $old_total = floatval(get_field('total_amount',$tid));
        if(abs($old_total - $total) > 0.01 && function_exists('b2b_add_audit_log')) {
            b2b_add_audit_log($tid, 'price_change', 'Admin changed total from ฿'.number_format($old_total,2).' to ฿'.number_format($total,2));
        }
        update_field('total_amount',$total,$tid);
    }
    if($note) update_field('admin_note',$note,$tid);
    if($st) b2b_set_order_status($tid,$st);
    if($st==='awaiting_confirm'&&$total>0){
        $gid=get_field('source_group_id',$tid);
        if($gid&&function_exists('b2b_build_flex_bill_confirm')){
            b2b_line_push_raw($gid,array(b2b_build_flex_bill_confirm($tid,$total,$note)));
        }
    }
    return new WP_REST_Response(array('success'=>true,'message'=>'อัปเดต #'.$tid.' สำเร็จ'));
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══════════════════════════════════════
// V.22: Flash Create — SHA256 signed, multi-box, auto on confirm
// Uses b2b_flash_create_all_boxes() from S1 Section 17
// ═══════════════════════════════════════
function b2b_rest_flash_create( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    if(!$tid||get_post_type($tid)!=='b2b_order') return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ถูกต้อง'),400);
    if(!defined('B2B_FLASH_MCH_ID')||!defined('B2B_FLASH_SECRET_KEY')||!defined('B2B_FLASH_API_URL'))
        return new WP_REST_Response(array('success'=>false,'message'=>'Flash ยังไม่ตั้งค่า (MCH_ID/SECRET_KEY/API_URL)'),400);

    // Check order status
    $cur_status = get_field('order_status', $tid);
    if (!in_array($cur_status, array('paid','pending','checking_stock','backorder','awaiting_confirm'), true))
        return new WP_REST_Response(array('success'=>false,'message'=>'สถานะ '.$cur_status.' ไม่สามารถสร้างพัสดุได้'),400);

    // Check not already created — allow retry if previous attempt had errors
    $existing = get_post_meta($tid, '_flash_tracking_numbers', true);
    $packing_status = get_post_meta($tid, '_flash_packing_status', true);
    if (!empty($existing)) {
        if ($packing_status === 'flash_create_error') {
            // Retry: cancel any partial pnos first, then recreate all
            if (function_exists('b2b_flash_cancel_order')) {
                foreach ($existing as $old_pno) {
                    b2b_flash_cancel_order($old_pno);
                    b2b_log('[Flash] Retry: cancelled partial pno=' . $old_pno . ' for #' . $tid);
                }
            }
            delete_post_meta($tid, '_flash_tracking_numbers');
            update_field('tracking_number', '', $tid);
        } else {
            return new WP_REST_Response(array('success'=>false,'message'=>'มี tracking อยู่แล้ว: '.implode(', ',$existing)),400);
        }
    }

    // Create all boxes via Phase 1 helper (S1)
    if (!function_exists('b2b_flash_create_all_boxes'))
        return new WP_REST_Response(array('success'=>false,'message'=>'ยังไม่มีฟังก์ชัน b2b_flash_create_all_boxes (ต้อง Active S1 Section 17)'),400);
    $result = b2b_flash_create_all_boxes($tid);

    if ($result['ok']) {
        // Auto-queue print job for RPi
        if (function_exists('b2b_enqueue_print_job')) {
            b2b_enqueue_print_job($tid);
            update_post_meta($tid, '_flash_packing_status', 'print_queued');
        }
        b2b_add_audit_log($tid, 'flash_created', 'สร้างพัสดุ Flash ' . $result['total_boxes'] . ' กล่อง: ' . implode(', ', $result['pnos']));
        // ส่ง Flex Card แจ้ง admin (S1 ไม่ส่งเองแล้ว เพื่อประหยัดโควต้า LINE)
        if (function_exists('b2b_build_flex_flash_admin') && function_exists('b2b_push_raw_to_admin')) {
            $flex = b2b_build_flex_flash_admin($tid, 'created', array('boxes' => $result['total_boxes'] . ' กล่อง: ' . implode(', ', $result['pnos'])));
            b2b_push_raw_to_admin(array($flex));
        }
        return new WP_REST_Response(array(
            'success'     => true,
            'tracking'    => implode(', ', $result['pnos']),
            'total_boxes' => $result['total_boxes'],
            'pnos'        => $result['pnos'],
        ));
    }

    return new WP_REST_Response(array('success'=>false,'message'=>'Flash: '.$result['error']),500);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══════════════════════════════════════
// V.22: Phase 3 — Flash Label PDF download
// ═══════════════════════════════════════
function b2b_rest_flash_label( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    $pno = sanitize_text_field($r->get_param('pno'));
    if (!$pno && $tid) {
        $pnos = get_post_meta($tid, '_flash_tracking_numbers', true);
        $pno = is_array($pnos) && !empty($pnos) ? $pnos[0] : '';
    }
    if (!$pno) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่มี tracking number'),400);
    if (!function_exists('b2b_flash_get_label_pdf'))
        return new WP_REST_Response(array('success'=>false,'message'=>'ยังไม่มีฟังก์ชัน b2b_flash_get_label_pdf'),400);
    $result = b2b_flash_get_label_pdf($pno);
    if ($result['ok'] && !empty($result['pdf'])) {
        header('Content-Type: application/pdf');
        header('Content-Disposition: inline; filename="flash-label-'.$pno.'.pdf"');
        echo $result['pdf'];
        exit;
    }
    return new WP_REST_Response(array('success'=>false,'message'=>'ดาวน์โหลด label ไม่สำเร็จ: '.($result['error']??'unknown')),500);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══════════════════════════════════════
// V.22: Phase 4 — Ready to Ship + Notify Courier
// ═══════════════════════════════════════
function b2b_rest_flash_ready_to_ship( WP_REST_Request $r ) {
    try {
    $tids = $r->get_param('ticket_ids');
    if (!is_array($tids)) $tids = array(intval($r->get_param('ticket_id')));
    $tids = array_filter(array_map('intval', $tids));
    if (empty($tids)) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่มี ticket_id'),400);

    $total_parcels = 0;
    $notified_tids = array();
    foreach ($tids as $tid) {
        if (get_post_type($tid) !== 'b2b_order') continue;
        $packing = get_post_meta($tid, '_flash_packing_status', true);
        if (!in_array($packing, array('flash_created','print_queued','print_done','notify_error'), true)) continue;

        // Update packing status
        update_post_meta($tid, '_flash_packing_status', 'ready_to_ship');
        $notified_tids[] = $tid;

        // Count parcels for this ticket
        $pnos = get_post_meta($tid, '_flash_tracking_numbers', true);
        $total_parcels += is_array($pnos) ? count($pnos) : 1;

        // LINE push to distributor
        $sgid = get_field('source_group_id', $tid);
        $tracking = get_field('tracking_number', $tid) ?: '';
        if ($sgid && function_exists('b2b_build_flex_flash_status')) {
            $flex = b2b_build_flex_flash_status($tid, 0, 'กำลังจัดส่ง — tracking: '.$tracking);
            b2b_line_push_raw($sgid, array($flex));
        } elseif ($sgid) {
            b2b_line_push($sgid, "📦 ออเดอร์ #".$tid." กำลังจัดส่ง\nTracking: ".$tracking);
        }
        b2b_add_audit_log($tid, 'flash_ready', 'ของพร้อมส่ง');
    }

    if (empty($notified_tids)) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่มี ticket ที่พร้อมส่ง'),400);

    // Call courier for pickup (one call for all parcels)
    if (!function_exists('b2b_flash_notify_courier_from_warehouse'))
        return new WP_REST_Response(array('success'=>false,'message'=>'ยังไม่มีฟังก์ชัน b2b_flash_notify_courier_from_warehouse'),400);
    $courier_result = b2b_flash_notify_courier_from_warehouse($total_parcels, 'Orders: '.implode(',', $notified_tids));
    $courier_info = array();

    if ($courier_result['ok'] && !empty($courier_result['data'])) {
        $cd = $courier_result['data'];
        $courier_info = array(
            'pickup_id'  => isset($cd['ticketPickupId']) ? $cd['ticketPickupId'] : '',
            'staff_name' => isset($cd['staffInfoName'])  ? $cd['staffInfoName']  : '',
            'staff_phone'=> isset($cd['staffInfoPhone']) ? $cd['staffInfoPhone'] : '',
            'timeout'    => isset($cd['timeoutAtText'])  ? $cd['timeoutAtText']  : '',
        );
        foreach ($notified_tids as $tid) {
            update_post_meta($tid, '_flash_packing_status', 'courier_called');
            update_post_meta($tid, '_flash_pickup_id', $courier_info['pickup_id']);
            update_post_meta($tid, '_flash_notify_error', '');
        }
        // Admin LINE notification
        $admin_flex = b2b_build_flex_flash_admin($notified_tids[0], 'courier_ok', array(
            'courier_name'  => $courier_info['staff_name'],
            'courier_phone' => $courier_info['staff_phone'],
            'timeout'       => $courier_info['timeout'],
            'boxes'         => $total_parcels.' กล่อง จาก '.count($notified_tids).' ออเดอร์',
        ));
        b2b_push_raw_to_admin(array($admin_flex));
    } else {
        // Notify courier failed — but distributor already notified (tracking exists)
        $err = isset($courier_result['error']) ? $courier_result['error'] : 'Unknown';
        foreach ($notified_tids as $tid) {
            update_post_meta($tid, '_flash_packing_status', 'notify_error');
            update_post_meta($tid, '_flash_notify_error', $err);
        }
        $admin_flex = b2b_build_flex_flash_admin($notified_tids[0], 'courier_fail', array('error' => $err));
        b2b_push_raw_to_admin(array($admin_flex));
    }

    return new WP_REST_Response(array(
        'success'      => true,
        'message'      => 'แจ้ง '.count($notified_tids).' ออเดอร์ ('.$total_parcels.' กล่อง) สำเร็จ',
        'notified'     => count($notified_tids),
        'parcels'      => $total_parcels,
        'courier'      => $courier_info,
        'courier_ok'   => $courier_result['ok'],
        'courier_error'=> !$courier_result['ok'] ? ($courier_result['error']??'') : '',
    ));
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══════════════════════════════════════
// V.22: Phase 5 — Cancel Order + Cancel Notify
// ═══════════════════════════════════════
function b2b_rest_flash_cancel( WP_REST_Request $r ) {
    try {
    $tid = intval($r->get_param('ticket_id'));
    if(!$tid||get_post_type($tid)!=='b2b_order') return new WP_REST_Response(array('success'=>false,'message'=>'Ticket ไม่ถูกต้อง'),400);

    $pnos = get_post_meta($tid, '_flash_tracking_numbers', true);
    if (empty($pnos)) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่มี tracking'),400);

    if (!function_exists('b2b_flash_cancel_order'))
        return new WP_REST_Response(array('success'=>false,'message'=>'ยังไม่มีฟังก์ชัน b2b_flash_cancel_order'),400);
    $errors = array();
    foreach ((array)$pnos as $pno) {
        $result = b2b_flash_cancel_order($pno);
        if (!$result['ok']) {
            $code = isset($result['code']) ? $result['code'] : 0;
            if ($code == 1015) { $errors[] = $pno.': คูเรียร์รับพัสดุไปแล้ว'; }
            else { $errors[] = $pno.': '.($result['error']??'Unknown'); }
        }
    }

    if (empty($errors)) {
        // V.36: Update per-PNO statuses
        $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
        if (is_array($pno_statuses)) {
            foreach ($pno_statuses as $_p => &$_info) {
                if (is_array($_info)) $_info['status'] = 'cancelled';
            }
            unset($_info);
            update_post_meta($tid, '_flash_pno_statuses', $pno_statuses);
        }
        delete_post_meta($tid, '_flash_tracking_numbers');
        update_field('tracking_number', '', $tid);
        update_post_meta($tid, '_flash_packing_status', 'cancelled');
        update_post_meta($tid, '_flash_status', 'cancelled');
        b2b_add_audit_log($tid, 'flash_cancelled', 'ยกเลิกพัสดุ Flash');
        return new WP_REST_Response(array('success'=>true,'message'=>'ยกเลิกสำเร็จ'));
    }

    return new WP_REST_Response(array('success'=>false,'message'=>implode('; ', $errors)),400);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

