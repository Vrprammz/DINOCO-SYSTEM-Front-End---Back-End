if (!function_exists('b2b_log')) {
    function b2b_log($msg) { error_log('[B2B] ' . $msg); }
}
if (!function_exists('b2b_set_order_status')) {
    function b2b_set_order_status($tid, $st) {
        update_field('order_status', $st, $tid);
    }
}
if (!function_exists('b2b_date')) {
    function b2b_date($format = 'Y-m-d H:i:s', $timestamp = null) {
        static $tz = null;
        if ($tz === null) $tz = new DateTimeZone('Asia/Bangkok');
        $dt = new DateTime('now', $tz);
        if ($timestamp !== null) $dt->setTimestamp((int)$timestamp);
        return $dt->format($format);
    }
}
if (!function_exists('b2b_line_push')) {
    function b2b_line_push($to, $text) {
        if (!defined('B2B_LINE_ACCESS_TOKEN') || !$to || !$text) return;
        $r = wp_remote_post('https://api.line.me/v2/bot/message/push', array(
            'headers' => array('Content-Type'=>'application/json','Authorization'=>'Bearer '.B2B_LINE_ACCESS_TOKEN),
            'body' => wp_json_encode(array('to'=>$to,'messages'=>array(array('type'=>'text','text'=>$text)))),
            'timeout' => 15,
        ));
        if (is_wp_error($r)) { b2b_log('[Push] WP_Error: '.$r->get_error_message()); return; }
        $code = wp_remote_retrieve_response_code($r);
        if ($code !== 200) b2b_log('[Push] HTTP '.$code.' — '.wp_remote_retrieve_body($r));
    }
}
if (!function_exists('b2b_line_push_raw')) {
    function b2b_line_push_raw($to, $messages) {
        if (!defined('B2B_LINE_ACCESS_TOKEN') || !$to) return false;
        $body = wp_json_encode(array('to'=>$to,'messages'=>$messages));
        $r = wp_remote_post('https://api.line.me/v2/bot/message/push', array(
            'headers' => array('Content-Type'=>'application/json','Authorization'=>'Bearer '.B2B_LINE_ACCESS_TOKEN),
            'body' => $body, 'timeout' => 15,
        ));
        if (is_wp_error($r)) { b2b_log('[PushRaw] WP_Error: '.$r->get_error_message()); return array('code'=>0,'body'=>''); }
        $code = wp_remote_retrieve_response_code($r); $resp = wp_remote_retrieve_body($r);
        if ($code !== 200) { b2b_log('[PushRaw] HTTP '.$code.' — '.$resp); }
        return array('code'=>$code,'body'=>$resp);
    }
}
if (!function_exists('b2b_push_to_admin')) {
