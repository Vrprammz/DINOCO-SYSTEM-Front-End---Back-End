/* ═══════════════════════════════════════════════════════════════════════════
 * 4. REST ENDPOINTS — admin only
 * ═══════════════════════════════════════════════════════════════════════════ */

add_action( 'rest_api_init', function() {
    $perm = function() { return current_user_can( 'manage_options' ); };

    register_rest_route( 'dinoco-vat/v1', '/export/summary', array(
        'methods'             => 'GET',
        'callback'            => function( $req ) {
            $y = (int) ( $req->get_param( 'year' ) ?: date( 'Y' ) );
            $m = (int) ( $req->get_param( 'month' ) ?: date( 'n' ) );
            return rest_ensure_response( dinoco_vat_export_summary( $y, $m ) );
        },
        'permission_callback' => $perm,
    ) );

    register_rest_route( 'dinoco-vat/v1', '/export/rows', array(
        'methods'             => 'GET',
        'callback'            => function( $req ) {
            $y = (int) ( $req->get_param( 'year' ) ?: date( 'Y' ) );
            $m = (int) ( $req->get_param( 'month' ) ?: date( 'n' ) );
            $limit = max( 1, min( 500, (int) ( $req->get_param( 'limit' ) ?: 50 ) ) );
            $rows = dinoco_vat_export_query( $y, $m );
            return rest_ensure_response( array(
                'year'  => $y,
                'month' => $m,
                'total' => count( $rows ),
                'rows'  => array_slice( $rows, 0, $limit ),
            ) );
        },
        'permission_callback' => $perm,
    ) );

    register_rest_route( 'dinoco-vat/v1', '/export/csv', array(
        // V.1.1 HIGH-2: accept POST (preferred — no nonce-in-URL leak) + GET
        // (back-compat for direct curl). Endpoint manage_options-gated.
        'methods'             => array( 'GET', 'POST' ),
        'callback'            => function( $req ) {
            $y = (int) ( $req->get_param( 'year' ) ?: date( 'Y' ) );
            $m = (int) ( $req->get_param( 'month' ) ?: date( 'n' ) );
            $csv = dinoco_vat_export_to_csv( $y, $m );

            // Stream as CSV download (bypass REST envelope)
            $filename = sprintf( 'dinoco-vat-%04d-%02d.csv', $y, $m );
            if ( ! headers_sent() ) {
                header( 'Content-Type: text/csv; charset=UTF-8' );
                header( 'Content-Disposition: attachment; filename="' . $filename . '"' );
            }
            header( 'Cache-Control: no-store' );
            echo $csv;
            exit;
        },
        'permission_callback' => $perm,
    ) );
} );

