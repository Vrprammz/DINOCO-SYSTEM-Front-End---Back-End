            $('dnc-vat-download-btn').addEventListener('click', function(){
                var ym = getYM();
                // V.1.1 HIGH-2 (security): POST form submit instead of GET — keeps
                // nonce out of URL (server logs / browser history / referer / proxy
                // caches). Endpoint already manage_options-gated; nonce is CSRF
                // defense-in-depth.
                var f = document.createElement('form');
                f.method = 'POST';
                f.action = API_ROOT + 'export/csv';
                f.style.display = 'none';
                ['year','month','_wpnonce'].forEach(function(k, i){
                    var v = [ym.year, ym.month, NONCE][i];
                    var inp = document.createElement('input');
                    inp.type  = 'hidden';
                    inp.name  = k;
                    inp.value = v;
                    f.appendChild(inp);
                });
                document.body.appendChild(f);
                f.submit();
                setTimeout(function(){ document.body.removeChild(f); }, 1000);
