/* ═══════════════════════════════════════════════════════════════════════════
 * 1. QUERY — paid extensions in [year, month) window
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_export_query' ) ) {
    /**
     * Return paid extensions in the specified month, enriched with
     * receipt_no + customer + SKU + price breakdown.
     *
     * @param int $year  4-digit year (e.g. 2026)
     * @param int $month 1..12
     * @return array list of assoc rows
     */
    function dinoco_vat_export_query( $year, $month ) {
        global $wpdb;
        $year = (int) $year;
        $month = (int) $month;
        if ( $year < 2024 || $year > 2099 || $month < 1 || $month > 12 ) return array();

        $tbl_ext  = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'extensions' ) : '';
        $tbl_pool = function_exists( 'dinoco_sn_table' ) ? dinoco_sn_table( 'pool' ) : '';
        if ( $tbl_ext === '' ) return array();

        $month_start = sprintf( '%04d-%02d-01 00:00:00', $year, $month );
        $next_month = $month === 12 ? array( $year + 1, 1 ) : array( $year, $month + 1 );
        $month_end = sprintf( '%04d-%02d-01 00:00:00', $next_month[0], $next_month[1] );

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, sn, user_id, extension_months, price_paid,
                    payment_method, payment_ref, paid_at, created_at
               FROM {$tbl_ext}
              WHERE payment_status = %s
                AND paid_at >= %s
                AND paid_at <  %s
              ORDER BY paid_at ASC",
            'paid', $month_start, $month_end
        ), ARRAY_A );
        if ( empty( $rows ) ) return array();

        // VAT rate (constant or option)
        $rate = (float) ( function_exists( 'dinoco_vat_get' ) ? dinoco_vat_get( 'rate', '0.07' ) : 0.07 );
        if ( $rate < 0 || $rate > 1 ) $rate = 0.07;

        // Prime user + sn_pool lookups in bulk to avoid N+1
        $uids = array();
        $sns  = array();
        foreach ( $rows as $r ) {
            $uids[ (int) $r['user_id'] ] = true;
            $sns[ strtoupper( (string) $r['sn'] ) ] = true;
        }
        unset( $uids[0] );
        if ( ! empty( $uids ) && function_exists( 'update_meta_cache' ) ) {
            update_meta_cache( 'user', array_keys( $uids ) );
        }
        // Pool batch fetch
        $pool_map = array();
        if ( $tbl_pool !== '' && ! empty( $sns ) ) {
            $placeholders = implode( ',', array_fill( 0, count( $sns ), '%s' ) );
            $sql = $wpdb->prepare(
                "SELECT sn, linked_sku FROM {$tbl_pool} WHERE sn IN ({$placeholders})",
                array_keys( $sns )
            );
            $pool_rows = $wpdb->get_results( $sql, ARRAY_A );
            foreach ( (array) $pool_rows as $pr ) {
                $pool_map[ strtoupper( (string) $pr['sn'] ) ] = (string) $pr['linked_sku'];
            }
        }

        $out = array();
        foreach ( $rows as $r ) {
            $sn = strtoupper( (string) $r['sn'] );
            $grand = (float) $r['price_paid'];
            $subtotal = $rate > 0 ? round( $grand / ( 1 + $rate ), 2 ) : $grand;
            $vat = round( $grand - $subtotal, 2 );

            // Receipt number
            $receipt_no = function_exists( 'dinoco_vat_receipt_generate_receipt_no' )
                ? dinoco_vat_receipt_generate_receipt_no( (int) $r['id'] )
                : ( 'EXT-' . str_pad( (string) $r['id'], 7, '0', STR_PAD_LEFT ) );

            // Customer
            $customer_name = '';
            $uid = (int) $r['user_id'];
            if ( $uid > 0 ) {
                $u = get_userdata( $uid );
                if ( $u ) {
                    $customer_name = trim( $u->display_name ?: ( $u->first_name . ' ' . $u->last_name ) );
                    if ( $customer_name === '' ) $customer_name = $u->user_login;
                }
            }

            // SKU + product (SET-aware via V.0.53 helper if available)
            $linked_sku = isset( $pool_map[ $sn ] ) ? $pool_map[ $sn ] : '';
            $renewable_sku = $linked_sku;
            if ( function_exists( 'dinoco_sn_get_renewable_sku' ) && $linked_sku !== '' ) {
                // synthesize minimal row shape for helper
                $renewable_sku = strtoupper( (string) dinoco_sn_get_renewable_sku( (object) array(
                    'sn'         => $sn,
                    'linked_sku' => $linked_sku,
                ) ) );
            }
            $product_name = '';
            if ( $renewable_sku !== '' && class_exists( 'DINOCO_Catalog' ) ) {
                $prod = DINOCO_Catalog::get_by_sku( $renewable_sku );
                // V.1.1 BLOCKER-1 fix: DINOCO_Catalog returns ARRAY_A with `name` column
                if ( is_array( $prod ) && ! empty( $prod['name'] ) ) $product_name = (string) $prod['name'];
            }
            $years = (int) max( 1, round( ( (int) $r['extension_months'] ) / 12 ) );
            $item_desc = sprintf( 'ต่ออายุประกัน %d ปี — %s', $years, $product_name ?: $renewable_sku );

            $out[] = array(
                'receipt_no'     => $receipt_no,
                'paid_at'        => (string) $r['paid_at'],
                'extension_id'   => (int) $r['id'],
                'sn'             => $sn,
                'customer_name'  => $customer_name,
                'customer_uid'   => $uid,
                'item_desc'      => $item_desc,
                'sku'            => $renewable_sku,
                'subtotal_excl'  => $subtotal,
                'vat_amount'     => $vat,
                'grand_total'    => $grand,
                'vat_rate'       => $rate,
                'payment_method' => (string) $r['payment_method'],
                'payment_ref'    => (string) $r['payment_ref'],
            );
        }
        return $out;
    }
}

if ( ! function_exists( 'dinoco_vat_export_summary' ) ) {
    /**
     * Aggregated totals for the month (cheap query for UI preview).
     *
     * @param int $year
     * @param int $month
     * @return array
     */
    function dinoco_vat_export_summary( $year, $month ) {
        $rows = dinoco_vat_export_query( $year, $month );
        $count = count( $rows );
        $sub_sum = 0.0;
        $vat_sum = 0.0;
        $grand_sum = 0.0;
        foreach ( $rows as $r ) {
            $sub_sum   += (float) $r['subtotal_excl'];
            $vat_sum   += (float) $r['vat_amount'];
            $grand_sum += (float) $r['grand_total'];
        }
        return array(
            'year'         => (int) $year,
            'month'        => (int) $month,
            'count'        => $count,
            'subtotal_excl_vat' => round( $sub_sum, 2 ),
            'vat_amount'   => round( $vat_sum, 2 ),
            'grand_total'  => round( $grand_sum, 2 ),
        );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. CSV RENDERER — Thai-Excel-friendly (UTF-8 BOM + RFC 4180 escape)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_vat_export_csv_escape' ) ) {
    function dinoco_vat_export_csv_escape( $v ) {
        $v = (string) $v;
        // V.1.1 CRIT-3: CSV formula injection defense per OWASP CSV Injection
        // Prevention Cheat Sheet. If cell starts with =/+/-/@/tab/CR, Excel +
        // Google Sheets + LibreOffice interpret as formula (CVE-class:
        // arbitrary URL exfil via WEBSERVICE/HYPERLINK, DDE command exec).
        // Mitigation: prefix with single quote — Excel hides it on display
        // but neutralizes formula execution.
        // Also: strip embedded CR/LF that some parsers treat as new record.
        if ( $v !== '' && strpbrk( $v[0], "=+-@\t\r" ) !== false ) {
            $v = "'" . $v;
        }
        $v = str_replace( array( "\r\n", "\r", "\n" ), ' ', $v );
        // Always quote — safest for Thai content + commas/newlines
        return '"' . str_replace( '"', '""', $v ) . '"';
    }
}

if ( ! function_exists( 'dinoco_vat_export_to_csv' ) ) {
    /**
     * Build CSV string with UTF-8 BOM. 11 columns matching accountant's
     * standard ภาษีขาย report shape.
     *
     * @param int $year
     * @param int $month
     * @return string
     */
    function dinoco_vat_export_to_csv( $year, $month ) {
        $rows = dinoco_vat_export_query( $year, $month );
        $headers = array(
            'เลขที่ใบกำกับ',
            'วันที่',
            'ชื่อลูกค้า',
            'S/N',
            'รายการ',
            'SKU',
            'มูลค่าก่อน VAT',
            'VAT 7%',
            'รวมทั้งสิ้น',
            'วิธีชำระ',
            'เลขอ้างอิง',
        );

        $out = "\xEF\xBB\xBF"; // UTF-8 BOM
        $out .= implode( ',', array_map( 'dinoco_vat_export_csv_escape', $headers ) ) . "\r\n";

        foreach ( $rows as $r ) {
            $line = array(
                $r['receipt_no'],
                $r['paid_at'],
                $r['customer_name'],
                $r['sn'],
                $r['item_desc'],
                $r['sku'],
                number_format( $r['subtotal_excl'], 2, '.', '' ),
                number_format( $r['vat_amount'], 2, '.', '' ),
                number_format( $r['grand_total'], 2, '.', '' ),
                $r['payment_method'],
                $r['payment_ref'],
            );
            $out .= implode( ',', array_map( 'dinoco_vat_export_csv_escape', $line ) ) . "\r\n";
        }

        // Footer totals row
        $sum = dinoco_vat_export_summary( $year, $month );
        $totals = array(
            '', '', '', '', '', 'รวม',
            number_format( $sum['subtotal_excl_vat'], 2, '.', '' ),
            number_format( $sum['vat_amount'], 2, '.', '' ),
            number_format( $sum['grand_total'], 2, '.', '' ),
            '', '',
        );
        $out .= implode( ',', array_map( 'dinoco_vat_export_csv_escape', $totals ) ) . "\r\n";

        return $out;
    }
}

