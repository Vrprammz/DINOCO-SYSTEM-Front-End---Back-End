    private function import_csv_kb() {
        register_shutdown_function( function() {
            $err = error_get_last();
            if ( $err && in_array( $err['type'], [ E_ERROR, E_PARSE, E_CORE_ERROR, E_COMPILE_ERROR ] ) ) {
                while ( ob_get_level() ) ob_end_clean();
                header( 'Content-Type: application/json; charset=utf-8' );
                echo json_encode( [ 'success' => false, 'message' => 'Server Error: ' . $err['message'] ] );
                exit;
            }
        } );

        ob_start();
        try {
            @set_time_limit( 300 );
            @ini_set( 'memory_limit', '512M' );

            if ( ! isset( $_FILES['csv_file'] ) || $_FILES['csv_file']['error'] !== UPLOAD_ERR_OK ) {
                throw new Exception( 'ไม่สามารถรับไฟล์ได้' );
            }

            $file_tmp = $_FILES['csv_file']['tmp_name'];
            if ( filesize( $file_tmp ) > 2 * 1024 * 1024 ) {
                throw new Exception( 'ไฟล์ใหญ่เกิน 2MB' );
            }

            $csv_data = file_get_contents( $file_tmp );
            if ( empty( $csv_data ) ) throw new Exception( 'ไฟล์ว่างเปล่า' );

            // RTF detection
            if ( strncmp( $csv_data, "{\\rtf", 5 ) === 0 ) {
                throw new Exception( 'ไฟล์เป็น RTF ไม่ใช่ CSV กรุณา Save as CSV UTF-8' );
            }

            // BOM removal
            if ( strncmp( $csv_data, "\xef\xbb\xbf", 3 ) === 0 ) {
                $csv_data = substr( $csv_data, 3 );
            }

            $csv_data = str_replace( [ "\r\n", "\r" ], "\n", $csv_data );

            // ลบ KB เก่าทั้งหมด
            $old = get_posts( [ 'post_type' => 'ai_knowledge', 'numberposts' => -1, 'post_status' => 'any' ] );
            foreach ( $old as $p ) { wp_delete_post( $p->ID, true ); }

            // Parse CSV
            $stream = fopen( 'php://memory', 'r+' );
            fwrite( $stream, $csv_data );
            rewind( $stream );

            wp_suspend_cache_addition( true );
            wp_defer_term_counting( true );

            $count     = 0;
            $is_header = true;

            while ( ( $row = fgetcsv( $stream, 0, ',', '"' ) ) !== false ) {
                if ( empty( $row ) || ( count( $row ) === 1 && empty( trim( $row[0] ) ) ) ) continue;
                if ( $count >= 500 ) break;

                $intent = trim( $row[0] );
                $facts  = isset( $row[1] ) ? trim( $row[1] ) : '';
                $action = isset( $row[2] ) ? trim( $row[2] ) : '';

                if ( $is_header ) {
                    $is_header = false;
                    if ( stripos( $intent, 'training_phrases' ) !== false || stripos( $intent, 'Intent' ) !== false ) {
                        continue;
                    }
                }

                if ( empty( $intent ) || strlen( $intent ) > 5000 ) continue;

                $facts  = str_replace( [ ' / ', ' /', '/ ' ], "\n", $facts );
                $action = str_replace( [ ' / ', ' /', '/ ' ], "\n", $action );

                $title = function_exists( 'mb_substr' ) ? mb_substr( $intent, 0, 50, 'UTF-8' ) . '...' : substr( $intent, 0, 50 ) . '...';

                $post_id = wp_insert_post( [
                    'post_title'  => wp_slash( $title ),
                    'post_type'   => 'ai_knowledge',
                    'post_status' => 'private',
                ] );

                if ( $post_id && ! is_wp_error( $post_id ) ) {
                    update_post_meta( $post_id, 'training_phrases', wp_slash( $intent ) );
                    update_post_meta( $post_id, 'core_facts', wp_slash( $facts ) );
                    update_post_meta( $post_id, 'ai_action', wp_slash( $action ) );
                    clean_post_cache( $post_id );
                    $count++;
                }
            }

            fclose( $stream );
            wp_suspend_cache_addition( false );
            wp_defer_term_counting( false );
            ob_end_clean();

            echo json_encode( [ 'success' => true, 'count' => $count ] );
            exit;

        } catch ( Exception $e ) {
            ob_end_clean();
            echo json_encode( [ 'success' => false, 'message' => $e->getMessage() ] );
            exit;
        }
    }

    private function clear_sandbox() {
        $logs = file_exists( $this->log_file ) ? json_decode( file_get_contents( $this->log_file ), true ) : [];
        $prefix = 'sandbox_admin_' . wp_get_current_user()->ID;
        $updated = false;

        foreach ( $logs as $key => $_ ) {
            if ( strpos( $key, $prefix ) === 0 ) {
                unset( $logs[ $key ] );
                $updated = true;
            }
        }

        if ( $updated ) {
            file_put_contents( $this->log_file, json_encode( $logs, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ), LOCK_EX );
        }
        echo json_encode( [ 'success' => true ] );
    }

