     */
    private function tool_get_kb_answer( $args ) {
        $question = isset( $args['question'] ) ? $args['question'] : '';
        if ( empty( $question ) ) {
            return [ 'found' => false, 'message' => 'กรุณาระบุคำถาม' ];
        }

        $entries = $this->find_relevant_kb( $question, '' );
        if ( empty( $entries ) ) {
            return [
                'found'       => false,
                'message'     => "ไม่พบข้อมูลเกี่ยวกับ '{$question}' ในคลังความรู้",
                'instruction' => 'ถ้าตอบไม่ได้จริงๆ ให้เรียก escalate_to_admin',
            ];
        }

        $results = [];
        foreach ( $entries as $kb ) {
            $results[] = [
                'topic'     => isset( $kb['q'] ) ? mb_substr( $kb['q'], 0, 100, 'UTF-8' ) : '',
                'facts'     => isset( $kb['f'] ) ? $kb['f'] : '',
                'guideline' => isset( $kb['a'] ) ? $kb['a'] : ( isset( $kb['legacy'] ) ? $kb['legacy'] : '' ),
            ];
        }

        return [
            'found'       => true,
            'count'       => count( $results ),
            'answers'     => $results,
            'instruction' => 'ใช้ข้อมูลจากผลลัพธ์นี้ตอบลูกค้า ห้ามแต่งข้อมูลเพิ่มที่ไม่มีในผลลัพธ์',
