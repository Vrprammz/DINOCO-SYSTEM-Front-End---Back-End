    /**
     * validate_turns() — ทำให้ turns เป็น alternating user/model
     * ป้องกัน consecutive same-role ที่ Gemini API ไม่ยอมรับ
     */
    private function validate_turns( $contents ) {
        if ( empty( $contents ) ) return $contents;

        $validated = [];
        $last_role = '';

        foreach ( $contents as $turn ) {
            if ( $turn['role'] === $last_role && ! empty( $validated ) ) {
                // Merge into previous turn
                $idx = count( $validated ) - 1;
                $validated[ $idx ]['parts'][0]['text'] .= "\n" . $turn['parts'][0]['text'];
                continue;
            }
            $validated[] = $turn;
            $last_role   = $turn['role'];
        }

        // Must start with user
        if ( ! empty( $validated ) && $validated[0]['role'] !== 'user' ) {
            array_shift( $validated );
        }

        return $validated;
    }

    /**
     * debug_log() — บันทึก debug log (auto-rotate ที่ 1MB)
     */
    private function debug_log( $msg ) {
        $ts   = date( 'Y-m-d H:i:s' );
        $line = "[{$ts}] {$msg}\n";

        // Auto-rotate log file ถ้าเกิน 1MB
        if ( file_exists( $this->debug_log_file ) && filesize( $this->debug_log_file ) > 1048576 ) {
            file_put_contents( $this->debug_log_file, $line, LOCK_EX );
        } else {
            file_put_contents( $this->debug_log_file, $line, FILE_APPEND | LOCK_EX );
        }
    }

    // =========================================================================
    // [SECTION 3] API REQUEST ROUTER
    // =========================================================================
    public function handle_api_requests() {
        if ( $_SERVER['REQUEST_METHOD'] !== 'POST' || ! isset( $_POST['dnc_action_v19'] ) ) {
            return;
        }

        // Clean output buffers
        while ( ob_get_level() ) { ob_end_clean(); }
        error_reporting( 0 );
        @ini_set( 'display_errors', 0 );

        if ( ! headers_sent() ) {
            header( 'Content-Type: application/json; charset=utf-8' );
            header( 'Cache-Control: no-store, no-cache, must-revalidate, max-age=0' );
        }

        if ( ! current_user_can( 'manage_options' ) ) {
            echo json_encode( [ 'success' => false, 'reply' => 'Access Denied' ] );
            exit;
        }

        $act = sanitize_text_field( $_POST['dnc_action_v19'] );

        $actions = [
            'save_config'  => 'save_config',
            'get_data'     => 'get_data',
            'test_chat'    => 'process_chat_logic',
            'get_logs'     => 'get_logs',
            'add_cpt_kb'   => 'add_cpt_kb',
            'delete_cpt_kb'=> 'delete_cpt_kb',
            'import_csv_kb'=> 'import_csv_kb',
            'update_cpt_kb'=> 'update_cpt_kb',
            'clear_sandbox'=> 'clear_sandbox',
            'update_claim' => 'update_claim_status',   // legacy compat
            'approve_claim'=> 'approve_claim_status',
            'ship_claim'   => 'ship_claim_status',
            'reject_claim' => 'reject_claim_status',
            'admin_reply'  => 'admin_reply_takeover',
        ];

        if ( isset( $actions[ $act ] ) ) {
            $method = $actions[ $act ];
            $this->$method();
        }

        exit;
    }

    // =========================================================================
    // [SECTION 4] CHAT PROCESSING (SANDBOX)
    // =========================================================================
    private function process_chat_logic() {
        $msg = isset( $_POST['message'] ) ? sanitize_text_field( $_POST['message'] ) : '';
        $sandbox_session = isset( $_POST['sandbox_session'] ) ? sanitize_text_field( $_POST['sandbox_session'] ) : 'default';

        if ( empty( trim( $msg ) ) ) {
            echo json_encode( [ 'success' => false, 'reply' => 'ข้อความว่าง' ] );
            exit;
        }

        $config  = get_option( 'dinoco_ai_config_v9', [] );
        $api_key = ! empty( $config['api_key'] ) ? $config['api_key'] : ( defined( 'DINOCO_GEMINI_KEY' ) ? DINOCO_GEMINI_KEY : '' );

        if ( empty( $api_key ) ) {
            echo json_encode( [ 'success' => false, 'reply' => '❌ กรุณาตั้งค่า Gemini API Key ที่เมนู Config หรือ wp-config.php' ] );
            exit;
        }

        // Load logs
        $logs = file_exists( $this->log_file ) ? json_decode( file_get_contents( $this->log_file ), true ) : [];
        if ( ! is_array( $logs ) ) $logs = [];

        $user = wp_get_current_user();
        $sid  = 'sandbox_admin_' . $user->ID . '_' . $sandbox_session;

        if ( ! isset( $logs[ $sid ] ) ) {
            $logs[ $sid ] = [
                'name'         => '👨‍💻 Admin Sandbox (' . $sandbox_session . ')',
                'profile_pic'  => '',
                'messages'     => [],
                'is_claim'     => false,
                'claim_status' => 'none',
                'needs_admin'  => false,
            ];
        }

        // บันทึกข้อความ user
        $logs[ $sid ]['messages'][] = [
            'role'      => 'user',
            'text'      => $msg,
            'timestamp' => time(),
        ];

        $history_raw = $logs[ $sid ]['messages'];

        // ★ ใช้ public methods ที่ webhook ก็ใช้เหมือนกัน ★
        $final_reply = $this->get_ai_response( $msg, $history_raw );

        if ( ! empty( $final_reply ) ) {
            // Parse action tags
            if ( strpos( $final_reply, '[ACTION: OPEN_CLAIM]' ) !== false ) {
                $final_reply = str_replace( '[ACTION: OPEN_CLAIM]', '', $final_reply );
                $logs[ $sid ]['claim_status'] = 'pending';
                $logs[ $sid ]['is_claim']     = true;

                // ★ v20.2: Extract basic claim_data from sandbox history
                $sb_photos = []; $sb_phone = ''; $sb_address = '';
                $phone_pat = '/0[0-9]{1,2}[\s\-]?[0-9]{3,4}[\s\-]?[0-9]{3,4}/u';
                foreach ( $logs[ $sid ]['messages'] as $sh ) {
                    if ( ( $sh['role'] ?? '' ) !== 'user' ) continue;
                    $st = $sh['text'] ?? '';
                    if ( ! empty( $sh['image'] ) ) $sb_photos[] = $sh['image'];
                    if ( empty( $sb_phone ) && preg_match( $phone_pat, $st, $spm ) ) $sb_phone = $spm[0];
                    if ( empty( $sb_address ) && mb_strlen( $st, 'UTF-8' ) > 30 && preg_match( '/\d/', $st ) ) $sb_address = $st;
                }
                $logs[ $sid ]['claim_data'] = [
                    'id'         => 'CLM-' . strtoupper( substr( md5( $sid . time() ), 0, 6 ) ),
                    'created_at' => date( 'Y-m-d H:i:s' ),
                    'customer'   => $logs[ $sid ]['name'] ?? 'Sandbox User',
                    'problem'    => '', 'photos' => $sb_photos,
                    'address'    => $sb_address, 'phone' => $sb_phone,
                    'status'     => 'pending', 'tracking' => '', 'admin_note' => '',
                ];
            }
            if ( strpos( $final_reply, '[ACTION: CALL_ADMIN]' ) !== false ) {
                $logs[ $sid ]['needs_admin'] = true;
                $final_reply = str_replace( '[ACTION: CALL_ADMIN]', '', $final_reply );
            }

            $final_reply = trim( $final_reply );

            $logs[ $sid ]['messages'][] = [
                'role'      => 'ai',
                'text'      => $final_reply,
                'timestamp' => time(),
            ];

            file_put_contents( $this->log_file, json_encode( $logs, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ), LOCK_EX );
        } else {
            $final_reply = "ขออภัยค่ะ ระบบขัดข้องชั่วคราว กรุณาลองใหม่ หรือพิมพ์ 'ขอคุยกับแอดมิน' ค่ะ 🙏";
        }

        echo json_encode( [ 'success' => ! empty( $final_reply ), 'reply' => $final_reply, 'fc_status' => $this->last_fc_status ] );
        exit;
    }

