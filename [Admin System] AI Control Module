    /**
     * ปฏิเสธเคลม (pending → rejected)
     */
    private function reject_claim_status() {
        $uid    = isset( $_POST['user_id'] ) ? sanitize_text_field( $_POST['user_id'] ) : '';
        $reason = isset( $_POST['reason'] ) ? sanitize_text_field( $_POST['reason'] ) : '';

        $logs = file_exists( $this->log_file ) ? json_decode( file_get_contents( $this->log_file ), true ) : [];
        if ( isset( $logs[ $uid ] ) ) {
