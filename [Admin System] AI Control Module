        <script>
        window.getCacheBustedUrl = function() {
            var u = window.location.href.split('#')[0];
            return u + (u.indexOf('?') !== -1 ? '&' : '?') + 'no_cache=' + Date.now();
        };
        var globalLogs = {};
        window.currentChatUid = null;
        window.currentClaimUid = null;
        var currentSandboxSession = Date.now();

        window.loadChat = function(uid) {
            window.currentChatUid = uid;
            jQuery('#dnc-users .item').removeClass('active');
            jQuery('#user-item-' + uid).addClass('active');
            var d = globalLogs[uid];
            if (!d) return;
            var html = '<div style="display:flex;flex-direction:column;width:100%;gap:10px;">';
            if (d.history && d.history.length > 0) {
                jQuery.each(d.history, function(i, h) {
                    var isU = (h.role === 'user'), isA = (h.role === 'admin');
                    var bc = isU ? 'dnc-b-user' : (isA ? 'dnc-b-admin' : 'dnc-b-ai');
                    var rl = isU ? 'ลูกค้า' : (isA ? 'แอดมิน' : 'AI');
                    var txt = h.text ? h.text.replace(/\n/g,'<br>') : '';
                    var av = isU ? (d.profile_pic || 'https://ui-avatars.com/api/?name='+encodeURIComponent(d.name)+'&background=e2e8f0&color=94a3b8') : 'https://ui-avatars.com/api/?name=AI&background=2563eb&color=fff';
                    if (isA) av = 'https://ui-avatars.com/api/?name=Ad&background=10b981&color=fff';
                    html += '<div style="display:flex;width:100%;gap:10px;margin-bottom:12px;'+(isU?'justify-content:flex-start;':'justify-content:flex-end;')+'">';
                    if (isU) html += '<img src="'+av+'" style="width:35px;height:35px;border-radius:50%;object-fit:cover;flex-shrink:0;margin-top:auto;">';
                    html += '<div class="dnc-bubble '+bc+'" style="margin-bottom:0;max-width:75%;"><strong style="font-size:0.8rem;opacity:0.8;display:block;margin-bottom:4px;">'+rl+'</strong>'+txt;
                    if (h.image) html += '<br><img src="'+h.image+'" style="max-width:100%;border-radius:8px;margin-top:10px;">';
                    html += '</div>';
                    if (!isU) html += '<img src="'+av+'" style="width:35px;height:35px;border-radius:50%;object-fit:cover;flex-shrink:0;margin-top:auto;">';
                    html += '</div>';
                });
            } else { html += '<div style="text-align:center;padding:50px;color:#aaa;">ไม่มีประวัติ</div>'; }
            html += '</div>';
            jQuery('#dnc-chat-area').html(html);
            document.getElementById('dnc-chat-area').scrollTop = 999999;
        };

        window.currentClaimFilter = 'pending';
        window.filterClaims = function(f) {
            window.currentClaimFilter = f;
            jQuery('.dnc-claim-filter').removeClass('active');
            jQuery('.dnc-claim-filter[data-f="'+f+'"]').addClass('active');
            window.renderClaimsList();
        };

        window.renderClaimsList = function() {
            var claims='', count=0, f=window.currentClaimFilter;
            jQuery.each(globalLogs, function(k,v){
                if(k.indexOf('sandbox')!==-1) return;
                var cs=v.claim_status||'none';
                if(cs==='none') return;
                if(f!=='all' && cs!==f) return;
                count++;
                var av=v.profile_pic||'https://ui-avatars.com/api/?name='+encodeURIComponent(v.name)+'&background=e2e8f0&color=94a3b8';
                var cd=v.claim_data||{};
                var badge='', borderColor='#e2e8f0';
                if(cs==='pending')  { badge='<span class="dnc-badge warn">รอตรวจ</span>'; borderColor='#fbbf24'; }
                else if(cs==='approved') { badge='<span class="dnc-badge green">รอจัดส่ง</span>'; borderColor='#34d399'; }
                else if(cs==='shipped')  { badge='<span class="dnc-badge blue">จัดส่งแล้ว</span>'; borderColor='#60a5fa'; }
                else if(cs==='rejected') { badge='<span class="dnc-badge red">ปฏิเสธ</span>'; borderColor='#f87171'; }
                var tid=cd.id||'';
                var time=cd.created_at||'';
                claims+='<div class="item" id="claim-item-'+k+'" onclick="loadClaimDetails(\''+k+'\')" style="display:flex;gap:10px;align-items:center;">';
                claims+='<img src="'+av+'" style="width:40px;height:40px;border-radius:50%;object-fit:cover;border:2px solid '+borderColor+';flex-shrink:0;">';
                claims+='<div style="flex:1;min-width:0;"><div style="display:flex;align-items:center;gap:6px;"><strong style="font-size:0.9rem;">'+v.name+'</strong>'+badge+'</div>';
                claims+='<div style="color:#94a3b8;font-size:0.8rem;">'+(tid?tid+' · ':'')+time+'</div></div></div>';
            });
            jQuery('#dnc-claim-list').html(count>0?claims:'<div style="padding:30px;text-align:center;color:#94a3b8;"><i class="fa-solid fa-inbox" style="font-size:2rem;margin-bottom:10px;display:block;opacity:0.3;"></i>ไม่มีเคลม'+(f==='pending'?'ค้าง':'')+'</div>');
        };

        window.loadClaimDetails = function(uid) {
            window.currentClaimUid = uid;
            jQuery('#dnc-claim-list .item').removeClass('active');
            jQuery('#claim-item-'+uid).addClass('active');
            var d = globalLogs[uid];
            if (!d) return;

            var cd = d.claim_data || {};
            var cs = d.claim_status || 'pending';
            var html = '';

            // === Status Bar ===
            var statusIcon, statusText, statusClass;
            if(cs==='pending')  { statusIcon='fa-clock'; statusText='รอแอดมินตรวจสอบ'; statusClass='pending'; }
            else if(cs==='approved') { statusIcon='fa-circle-check'; statusText='อนุมัติแล้ว — รอจัดส่งสินค้า'; statusClass='approved'; }
            else if(cs==='shipped')  { statusIcon='fa-truck'; statusText='จัดส่งแล้ว — '+(cd.tracking||''); statusClass='shipped'; }
            else if(cs==='rejected') { statusIcon='fa-circle-xmark'; statusText='ปฏิเสธ — '+(cd.admin_note||''); statusClass='rejected'; }
            html += '<div class="claim-status-bar '+statusClass+'"><i class="fa-solid '+statusIcon+'"></i> '+statusText+'</div>';

            // === Ticket Info ===
            html += '<div class="claim-data-card"><h4><i class="fa-solid fa-ticket"></i> ข้อมูล Ticket</h4>';
            html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:0.9rem;">';
            html += '<div><span style="color:#94a3b8;">ID:</span> <strong>'+(cd.id||'—')+'</strong></div>';
            html += '<div><span style="color:#94a3b8;">วันที่:</span> '+(cd.created_at||'—')+'</div>';
            html += '<div><span style="color:#94a3b8;">ลูกค้า:</span> <strong>'+(cd.customer||d.name||'—')+'</strong></div>';
            html += '<div><span style="color:#94a3b8;">เบอร์:</span> <strong style="color:#2563eb;">'+(cd.phone||'<span style=\"color:#ef4444;\">ไม่มี</span>')+'</strong></div>';
            html += '</div></div>';

            // === Problem ===
            if (cd.problem) {
                html += '<div class="claim-data-card"><h4><i class="fa-solid fa-bug"></i> ปัญหาที่แจ้ง</h4>';
                html += '<div style="font-size:0.9rem;color:#334155;">'+cd.problem.replace(/\n/g,'<br>')+'</div></div>';
            }

            // === Photos ===
            var photos = cd.photos || [];
            // Also scan history for extra images
            if (d.history && d.history.length) {
                jQuery.each(d.history, function(i,h){
                    if(h.image && h.image.trim()!=='' && h.role==='user'){
                        var exists=false;
                        for(var p=0;p<photos.length;p++){if(photos[p]===h.image){exists=true;break;}}
                        if(!exists) photos.push(h.image);
                    }
                });
            }
            html += '<div class="claim-data-card"><h4><i class="fa-solid fa-images"></i> รูปภาพหลักฐาน <span class="dnc-badge">'+(photos.length)+' รูป</span></h4>';
            if (photos.length > 0) {
                html += '<div class="claim-photo-grid">';
                jQuery.each(photos, function(i,img){
                    html += '<a href="'+img+'" target="_blank"><img src="'+img+'" alt="Evidence '+(i+1)+'"></a>';
                });
                html += '</div>';
