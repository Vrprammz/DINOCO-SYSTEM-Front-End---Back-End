    /**
     * ★ send_fb_message() — ส่งข้อความไป Facebook Messenger จริง
     * ใช้ใน: approve, ship, reject, admin_reply
     *
     * @param string $uid  — log key เช่น "fb_123456789"
     * @param string $text — ข้อความที่จะส่ง
     * @return bool
     */
    private function send_fb_message( $uid, $text ) {
        if ( strpos( $uid, 'fb_' ) !== 0 ) {
            return false;
        }
        $sender_id = substr( $uid, 3 );

        $page_token = defined( 'DINOCO_PAGE_TOKEN' ) ? DINOCO_PAGE_TOKEN : '';
        if ( empty( $page_token ) ) {
            $config = get_option( 'dinoco_ai_config_v9', [] );
            $page_token = isset( $config['page_token'] ) ? $config['page_token'] : '';
        }

        $debug = WP_CONTENT_DIR . '/dinoco-fb-send.log';

        if ( empty( $page_token ) ) {
            @file_put_contents( $debug, date('H:i:s') . " [FAIL] No PAGE_TOKEN! Define DINOCO_PAGE_TOKEN in wp-config.php\n", FILE_APPEND );
            return false;
        }

        $url     = 'https://graph.facebook.com/v19.0/me/messages?access_token=' . $page_token;
        $payload = json_encode( [
            'recipient' => [ 'id' => $sender_id ],
            'message'   => [ 'text' => $text ],
        ] );

        @file_put_contents( $debug, date('H:i:s') . " [SEND] uid={$uid} sender={$sender_id} len=" . strlen($text) . "\n", FILE_APPEND );

        $response = wp_remote_post( $url, [
            'headers'   => [ 'Content-Type' => 'application/json' ],
            'body'      => $payload,
            'timeout'   => 15,
            'sslverify' => false,
        ] );

        if ( is_wp_error( $response ) ) {
            @file_put_contents( $debug, date('H:i:s') . " [WP_ERROR] " . $response->get_error_message() . "\n", FILE_APPEND );
            return false;
        }

        $code = wp_remote_retrieve_response_code( $response );
        $body = wp_remote_retrieve_body( $response );

        @file_put_contents( $debug, date('H:i:s') . " [RESPONSE] HTTP {$code} — " . substr($body, 0, 200) . "\n", FILE_APPEND );

        return ( $code === 200 );
    }

    /**
     * Step 1: อนุมัติเคลม (pending → approved)
     */
    private function approve_claim_status() {
        $uid = isset( $_POST['user_id'] ) ? sanitize_text_field( $_POST['user_id'] ) : '';

        $logs = file_exists( $this->log_file ) ? json_decode( file_get_contents( $this->log_file ), true ) : [];
        if ( isset( $logs[ $uid ] ) ) {
            $logs[ $uid ]['claim_status'] = 'approved';

            if ( isset( $logs[ $uid ]['claim_data'] ) ) {
                $logs[ $uid ]['claim_data']['status']      = 'approved';
                $logs[ $uid ]['claim_data']['approved_at']  = date( 'Y-m-d H:i:s' );
                $logs[ $uid ]['claim_data']['approved_by']  = wp_get_current_user()->user_login;
            }

            $msg_text = "✅ แอดมินตรวจสอบเรียบร้อยแล้วค่ะ อนุมัติเคลมให้ลูกค้าเรียบร้อยค่ะ\nทางเรากำลังจัดเตรียมสินค้าให้ลูกค้า รอรับแจ้งเลขพัสดุอีกครั้งนะคะ 🙏";

            $logs[ $uid ]['messages'][] = [
                'role' => 'admin',
                'text' => $msg_text,
                'timestamp' => time(),
            ];
            file_put_contents( $this->log_file, json_encode( $logs, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ), LOCK_EX );

            // ★ ส่ง Facebook Messenger จริง
            $sent = $this->send_fb_message( $uid, $msg_text );

            echo json_encode( [ 'success' => true, 'message' => 'อนุมัติเคลมสำเร็จ' . ( $sent ? ' — แจ้งลูกค้าแล้ว' : ' — ⚠️ ส่ง FB ไม่ได้' ) ] );
        } else {
            echo json_encode( [ 'success' => false, 'message' => 'ไม่พบ User' ] );
        }
        exit;
    }

    /**
     * Step 2: กรอกเลขพัสดุ (approved → shipped)
     */
    private function ship_claim_status() {
        $uid      = isset( $_POST['user_id'] ) ? sanitize_text_field( $_POST['user_id'] ) : '';
        $tracking = isset( $_POST['tracking'] ) ? sanitize_text_field( $_POST['tracking'] ) : '';

        $logs = file_exists( $this->log_file ) ? json_decode( file_get_contents( $this->log_file ), true ) : [];
        if ( isset( $logs[ $uid ] ) ) {
            $logs[ $uid ]['claim_status'] = 'shipped';
            $logs[ $uid ]['needs_admin']  = false;

            if ( isset( $logs[ $uid ]['claim_data'] ) ) {
                $logs[ $uid ]['claim_data']['status']     = 'shipped';
                $logs[ $uid ]['claim_data']['tracking']    = $tracking;
                $logs[ $uid ]['claim_data']['shipped_at']  = date( 'Y-m-d H:i:s' );
                $logs[ $uid ]['claim_data']['shipped_by']  = wp_get_current_user()->user_login;
            }

            $msg_text = "🎉 จัดส่งสินค้าเคลมเรียบร้อยแล้วค่ะ!\n📦 เลขพัสดุ: {$tracking}\nรอรับสินค้าได้เลยนะคะ ขอบคุณที่ไว้วางใจ DINOCO ค่ะ 💙";

            $logs[ $uid ]['messages'][] = [
                'role' => 'admin',
                'text' => $msg_text,
                'timestamp' => time(),
            ];
            file_put_contents( $this->log_file, json_encode( $logs, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE ), LOCK_EX );

            // ★ ส่ง Facebook Messenger จริง
            $sent = $this->send_fb_message( $uid, $msg_text );

            echo json_encode( [ 'success' => true, 'message' => 'บันทึกเลขพัสดุสำเร็จ' . ( $sent ? ' — แจ้งลูกค้าแล้ว' : ' — ⚠️ ส่ง FB ไม่ได้' ) ] );
        } else {
            echo json_encode( [ 'success' => false, 'message' => 'ไม่พบ User' ] );
        }
        exit;
    }

