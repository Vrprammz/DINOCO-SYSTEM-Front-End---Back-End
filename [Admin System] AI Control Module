    /**
     * ★ build_conversation_turns() ★
     * สร้าง contents array สำหรับ Gemini API จาก history
     * รวม auto-merge consecutive same-role + validation
     *
     * PUBLIC เพราะ webhook.php ต้องเรียกใช้
     */
    public function build_conversation_turns( $history_raw ) {
        $contents  = [];
        $last_role = '';
        $recent    = array_slice( $history_raw, -self::AI_HISTORY_LIMIT );

        foreach ( $recent as $h ) {
            $role = ( $h['role'] === 'user' ) ? 'user' : 'model';
            $text = isset( $h['text'] ) ? trim( $h['text'] ) : '';

            // ถ้ามีรูปภาพ → เพิ่ม marker
            if ( ! empty( $h['image'] ) && mb_strpos( $text, 'รูปภาพ' ) === false ) {
                $text .= " [แนบรูปภาพ]";
            }

            $text = trim( $text );
            if ( empty( $text ) ) continue;

            // Auto-merge consecutive same-role turns (Gemini requirement)
            if ( $role === $last_role && ! empty( $contents ) ) {
                $idx = count( $contents ) - 1;
                $contents[ $idx ]['parts'][0]['text'] .= "\n" . $text;
            } else {
                $contents[] = [ 'role' => $role, 'parts' => [ [ 'text' => $text ] ] ];
                $last_role = $role;
            }
        }

        // Gemini ต้องเริ่มด้วย user turn
        if ( ! empty( $contents ) && $contents[0]['role'] === 'model' ) {
            array_shift( $contents );
        }

        // Final validation: alternating roles
        $contents = $this->validate_turns( $contents );

        return $contents;
    }

    /**
     * ★ call_gemini_fc() ★ — v22 Function Calling Loop
     * เรียก Gemini API พร้อม tools declaration
     * ถ้า AI เรียก function → execute → ส่งผลกลับ → วนจน AI ตอบ text
     *
     * @return string AI reply text
     */
    public function call_gemini_fc( $system_instruction, $contents, $force_tools = false ) {
        $config  = get_option( 'dinoco_ai_config_v9', [] );
        $api_key = ! empty( $config['api_key'] ) ? $config['api_key'] : ( defined( 'DINOCO_GEMINI_KEY' ) ? DINOCO_GEMINI_KEY : '' );

        if ( empty( $api_key ) ) {
            $this->debug_log( 'NO API KEY!' );
            return '';
        }

        $tools = [ [ 'functionDeclarations' => $this->get_tool_declarations() ] ];
        $model = self::AI_MODEL_PRIMARY;
        $url   = "https://generativelanguage.googleapis.com/v1beta/models/{$model}:generateContent?key={$api_key}";

        // ★ v22.1: force_tools = ANY mode → Gemini ต้องเรียก tool อย่างน้อย 1 ตัว
        $fc_mode = $force_tools ? 'ANY' : 'AUTO';
        $this->debug_log( "FC Mode: {$fc_mode} | Force: " . ( $force_tools ? 'YES' : 'NO' ) );

        // Function Calling Loop
        $tools_called = [];
        for ( $loop = 0; $loop < self::AI_FC_MAX_LOOPS; $loop++ ) {

            $payload = [
                'systemInstruction' => [ 'parts' => [ [ 'text' => $system_instruction ] ] ],
                'contents'          => $contents,
                'tools'             => $tools,
                'toolConfig'        => [ 'functionCallingConfig' => [ 'mode' => $fc_mode ] ],
                'generationConfig'  => [
                    'temperature'     => self::AI_TEMPERATURE,
                    'maxOutputTokens' => self::AI_MAX_TOKENS,
                ],
            ];

            $this->debug_log( "FC Loop {$loop} | Model: {$model} | Turns: " . count( $contents ) );

            $response = wp_remote_post( $url, [
                'body'    => json_encode( $payload, JSON_UNESCAPED_UNICODE ),
                'headers' => [ 'Content-Type' => 'application/json' ],
                'timeout' => self::AI_TIMEOUT,
            ] );

            if ( is_wp_error( $response ) ) {
                $this->debug_log( "WP_Error: " . $response->get_error_message() );
                break;
            }

            $code = wp_remote_retrieve_response_code( $response );
            $body = json_decode( wp_remote_retrieve_body( $response ), true );

            if ( $code !== 200 ) {
                $err = isset( $body['error']['message'] ) ? $body['error']['message'] : "HTTP {$code}";
                $this->debug_log( "API Error: {$err}" );

                // Fallback: ถ้า primary model ไม่รองรับ FC → ลอง model เดิมแบบไม่มี tools
                if ( $loop === 0 ) {
                    $this->debug_log( "Fallback to non-FC mode" );
                    $this->last_fc_status = "❌ Model error → Legacy mode (no FC)";
                    return $this->call_gemini_legacy( $system_instruction, $contents );
                }
                break;
            }

            // Parse response parts
            $parts = isset( $body['candidates'][0]['content']['parts'] ) ? $body['candidates'][0]['content']['parts'] : [];

            if ( empty( $parts ) ) {
                $this->debug_log( "Empty parts in response" );
                break;
            }

            // Check for function calls
            $has_fc = false;
            $model_parts = []; // AI's response parts (may include text + function calls)
            $fc_response_parts = []; // Our function results

            foreach ( $parts as $part ) {
                $model_parts[] = $part;

                if ( isset( $part['functionCall'] ) ) {
                    $has_fc    = true;
                    $func_name = $part['functionCall']['name'];
                    $func_args = isset( $part['functionCall']['args'] ) ? $part['functionCall']['args'] : [];

                    $this->debug_log( "FC Call: {$func_name}(" . json_encode( $func_args, JSON_UNESCAPED_UNICODE ) . ")" );
                    $tools_called[] = $func_name;

                    // Execute function
                    $result = $this->process_function_call( $func_name, $func_args );

                    $this->debug_log( "FC Result: " . mb_substr( json_encode( $result, JSON_UNESCAPED_UNICODE ), 0, 300 ) );

                    $fc_response_parts[] = [
                        'functionResponse' => [
                            'name'     => $func_name,
                            'response' => $result,
                        ],
                    ];
                }
            }

            if ( $has_fc ) {
                // Add AI's response (with function calls) to conversation
                $contents[] = [ 'role' => 'model', 'parts' => $model_parts ];

                // Add function results as user turn
                $contents[] = [ 'role' => 'user', 'parts' => $fc_response_parts ];

                // ★ v22.1: หลังเรียก tool แล้ว → เปลี่ยนเป็น AUTO เพื่อให้ AI ตอบ text ได้
                $fc_mode = 'AUTO';

                // Loop back to let AI respond with the function results
                continue;
            }

            // No function call → extract text response
            $text_parts = [];
            foreach ( $parts as $part ) {
                if ( isset( $part['text'] ) ) {
                    $text_parts[] = $part['text'];
                }
            }

            $reply = implode( "\n", $text_parts );

            // Clean internal markers
            $reply = preg_replace( '/\[แนบรูปภาพ[^\]]*\]/u', '', $reply );
            $reply = preg_replace( '/\[ลูกค้ารายนี้เพิ่งส่งรูปภาพ[^\]]*\]/u', '', $reply );
            $reply = trim( $reply );

            $this->debug_log( "FC Complete | Loops: {$loop} | Reply: " . mb_strlen( $reply, 'UTF-8' ) . " chars" );
            $tc = ! empty( $tools_called ) ? implode( ', ', $tools_called ) : 'none';
            $mode_label = $force_tools ? 'FORCED' : 'AUTO';
            $this->last_fc_status = ! empty( $tools_called )
                ? "✅ FC ({$mode_label}) | Tools: {$tc}"
                : "⚡ FC ({$mode_label}) | No tools";
            return $reply;
        }

        $this->debug_log( "FC Max loops reached or error — falling back" );
        $this->last_fc_status = "⚠️ FC Failed → Legacy fallback";
        return $this->call_gemini_legacy( $system_instruction, $contents );
    }

    /**
     * ★ call_gemini_legacy() ★ — v21-compatible fallback (no function calling)
     * ใช้เมื่อ model ไม่รองรับ FC หรือ FC loop ล้มเหลว
     */
    private function call_gemini_legacy( $system_instruction, $contents ) {
        $config  = get_option( 'dinoco_ai_config_v9', [] );
        $api_key = ! empty( $config['api_key'] ) ? $config['api_key'] : ( defined( 'DINOCO_GEMINI_KEY' ) ? DINOCO_GEMINI_KEY : '' );

        $models = [ self::AI_MODEL_PRIMARY, self::AI_MODEL_FALLBACK ];

        // Filter out any functionCall/functionResponse parts that FC loop may have added
        $clean_contents = [];
        foreach ( $contents as $turn ) {
            $clean_parts = [];
            foreach ( $turn['parts'] as $p ) {
                if ( isset( $p['text'] ) ) {
                    $clean_parts[] = $p;
                }
            }
            if ( ! empty( $clean_parts ) ) {
                $clean_contents[] = [ 'role' => $turn['role'], 'parts' => $clean_parts ];
            }
        }
        $clean_contents = $this->validate_turns( $clean_contents );

        foreach ( $models as $model ) {
            $url = "https://generativelanguage.googleapis.com/v1beta/models/{$model}:generateContent?key={$api_key}";

            $payload = [
                'systemInstruction' => [ 'parts' => [ [ 'text' => $system_instruction ] ] ],
                'contents'          => $clean_contents,
                'generationConfig'  => [
                    'temperature'     => self::AI_TEMPERATURE,
                    'maxOutputTokens' => self::AI_MAX_TOKENS,
                ],
            ];

            $response = wp_remote_post( $url, [
                'body'    => json_encode( $payload, JSON_UNESCAPED_UNICODE ),
                'headers' => [ 'Content-Type' => 'application/json' ],
                'timeout' => self::AI_TIMEOUT,
            ] );

            if ( is_wp_error( $response ) ) continue;

            $code = wp_remote_retrieve_response_code( $response );
            $body = json_decode( wp_remote_retrieve_body( $response ), true );

            if ( $code === 200 && isset( $body['candidates'][0]['content']['parts'][0]['text'] ) ) {
                $reply = $body['candidates'][0]['content']['parts'][0]['text'];
                $reply = preg_replace( '/\[แนบรูปภาพ[^\]]*\]/u', '', $reply );
                $reply = preg_replace( '/\[ลูกค้ารายนี้เพิ่งส่งรูปภาพ[^\]]*\]/u', '', $reply );
                $this->debug_log( "Legacy Success ({$model})" );
                return trim( $reply );
            }
        }

        $this->debug_log( "ALL MODELS FAILED (legacy)" );
        return '';
    }

    /**
     * ★ get_ai_response() — v22 ★
     * One-call method — สร้าง prompt + turns + เรียก FC loop
     */
    public function get_ai_response( $user_msg, $history_raw ) {
        $system_prompt = $this->generate_smart_prompt( $user_msg, $history_raw );
        $contents      = $this->build_conversation_turns( $history_raw );

        // Safety: ต้องมีอย่างน้อย 1 turn
        if ( empty( $contents ) ) {
            $contents = [ [ 'role' => 'user', 'parts' => [ [ 'text' => $user_msg ] ] ] ];
        }

        // ★ v22.1: Detect if we should force tool calling
        // ถ้าข้อความไม่ใช่แค่ทักทาย → บังคับ tools
        $greet_patterns = '/^(สวัสดี|หวัดดี|ดีครับ|ดีค่ะ|hi|hello|ขอบคุณ|ขอบพระคุณ|ไว้จะมา|โอเค|ok|bye|ลาก่อน|แต้งกิ้ว|thx|thank)/iu';
        $force_tools = ! preg_match( $greet_patterns, trim( $user_msg ) );

        return $this->call_gemini_fc( $system_prompt, $contents, $force_tools );
    }

