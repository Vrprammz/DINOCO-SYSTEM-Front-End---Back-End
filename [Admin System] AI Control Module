    /**
     * ★ analyze_claim_status() ★
     * วิเคราะห์ประวัติแชทเพื่อตรวจสอบว่าลูกค้าให้ข้อมูลเคลมอะไรมาแล้วบ้าง
     * inject ผลลัพธ์ลง prompt → AI จะรู้ว่าต้องถามอะไรเพิ่ม
     *
     * v20.1: NEW — แก้ปัญหา AI ถามข้อมูลซ้ำที่ลูกค้าให้ไปแล้ว
     */
    private function analyze_claim_status( $history_raw ) {
        $has_photo   = false;
        $has_address = false;
        $has_phone   = false;
        $is_claim    = false;
        $photo_count = 0;
        $address_text = '';
        $phone_text   = '';

        // คำที่บ่งบอกว่าเป็นเรื่องเคลม
        $claim_keywords = [ 'เคลม', 'หลุด', 'ลอก', 'แตก', 'หัก', 'พัง', 'ชำรุด', 'เสียหาย',
                            'สติ๊กเกอร์', 'โลโก้', 'กาว', 'น็อต', 'มุม', 'ร้าว', 'บุบ', 'งอ',
                            'ประกัน', 'ซ่อม', 'เปลี่ยน', 'เบิก', 'ปัญหา', 'มีปัญหา', 'สนิม',
                            'น้ำเข้า', 'รั่ว', 'กุญแจหาย' ];

        // Address patterns
        $address_keywords = [ 'จังหวัด', 'อำเภอ', 'ตำบล', 'แขวง', 'เขต', 'ซอย', 'ถนน',
                              'หมู่', 'บ้านเลขที่', 'ไปรษณีย์', 'รหัสไปรษณีย์',
                              'กรุงเทพ', 'นนทบุรี', 'ปทุมธานี', 'สมุทรปราการ',
                              'บริษัท', 'จำกัด', 'คอร์ปอเรชั่น' ];

        // Phone patterns
        $phone_pattern = '/0[0-9]{1,2}[\s\-]?[0-9]{3,4}[\s\-]?[0-9]{3,4}/u';

        foreach ( $history_raw as $h ) {
            $text = isset( $h['text'] ) ? $h['text'] : '';
            $role = isset( $h['role'] ) ? $h['role'] : '';
            $text_lower = mb_strtolower( $text, 'UTF-8' );

            // ตรวจจับว่าเป็นเรื่องเคลมหรือไม่
            if ( $role === 'user' || $role === 'ai' || $role === 'model' ) {
                foreach ( $claim_keywords as $kw ) {
                    if ( mb_strpos( $text_lower, $kw ) !== false ) {
                        $is_claim = true;
                        break;
                    }
                }
            }

            // ตรวจข้อมูลจากฝั่ง user เท่านั้น
            if ( $role !== 'user' ) continue;

            // 1) รูปภาพ — เช็คทุกวิธี
            if ( ! empty( $h['image'] ) ) {
                $has_photo = true;
                $photo_count++;
            }
            // ★ v20.1.1: เช็คทุก marker ที่เป็นไปได้
            if ( mb_strpos( $text, '[แนบรูปภาพ' ) !== false ) {
                $has_photo = true;
                // ดึงจำนวนรูปจาก marker "[แนบรูปภาพ 3 รูป]"
                if ( preg_match( '/\[แนบรูปภาพ\s*(\d+)\s*รูป\]/', $text, $pm ) ) {
                    $photo_count += intval( $pm[1] );
                } else {
                    $photo_count++;
                }
            }
            if ( mb_strpos( $text, '[ลูกค้ารายนี้เพิ่งส่งรูปภาพ' ) !== false ) {
                $has_photo = true;
                $photo_count++;
            }

            // 2) ที่อยู่ — ตรวจจากคำที่บ่งบอกที่อยู่ หรือข้อความยาว > 30 ตัวอักษรที่มีตัวเลข
            foreach ( $address_keywords as $akw ) {
                if ( mb_strpos( $text_lower, $akw ) !== false ) {
                    $has_address = true;
                    $address_text = mb_substr( $text, 0, 80, 'UTF-8' );
                    break;
                }
            }
            // ตรวจจับรหัสไปรษณีย์ 5 หลัก
            if ( ! $has_address && preg_match( '/\d{5}/', $text ) && mb_strlen( $text, 'UTF-8' ) > 20 ) {
                $has_address = true;
                $address_text = mb_substr( $text, 0, 80, 'UTF-8' );
            }
            // ★ ตรวจจับที่อยู่แบบยาว (>40 ตัวอักษร + มีเลข) แม้ไม่มี keyword
            if ( ! $has_address && mb_strlen( $text, 'UTF-8' ) > 40 && preg_match( '/\d/', $text ) && preg_match( '/[\/\-]/', $text ) ) {
                $has_address = true;
                $address_text = mb_substr( $text, 0, 80, 'UTF-8' );
            }

            // 3) เบอร์โทร
            if ( preg_match( $phone_pattern, $text, $m ) ) {
                $has_phone = true;
                $phone_text = $m[0];
            }
        }

        // ไม่ใช่เรื่องเคลม → ไม่ต้อง inject
        if ( ! $is_claim ) {
            return '';
        }

        // สร้าง status report สำหรับ inject ลง prompt
        $collected = [];
        $missing   = [];

        if ( $has_photo )   { $collected[] = "✅ รูปภาพ (ได้รับแล้ว {$photo_count} รูป)"; }
        else                { $missing[]   = "❌ รูปภาพ/วีดีโอ (ยังไม่ได้)"; }

        if ( $has_address ) { $collected[] = "✅ ที่อยู่ (ได้รับแล้ว: '{$address_text}...')"; }
        else                { $missing[]   = "❌ ชื่อ-ที่อยู่จัดส่ง (ยังไม่ได้)"; }

        if ( $has_phone )   { $collected[] = "✅ เบอร์โทร (ได้รับแล้ว: {$phone_text})"; }
        else                { $missing[]   = "❌ เบอร์โทรศัพท์ (ยังไม่ได้)"; }

        $report = "# 🔎 สถานะข้อมูลเคลม (ระบบตรวจจับอัตโนมัติ)\n";
        $report .= "ข้อมูลที่ได้รับแล้ว:\n" . implode( "\n", $collected ) . "\n";

        if ( ! empty( $missing ) ) {
            $report .= "\nข้อมูลที่ยังขาด:\n" . implode( "\n", $missing ) . "\n";
            $report .= "\n⚡ คำสั่งสำคัญ:\n";
            $report .= "- ห้ามถามข้อมูลที่ ✅ ได้รับแล้ว ซ้ำเด็ดขาด!\n";
            $report .= "- ขอบคุณลูกค้าสำหรับข้อมูลที่เพิ่งส่งมา\n";
            $report .= "- ถามเฉพาะข้อมูลที่ ❌ ยังขาด เท่านั้น ด้วยประโยคธรรมชาติ\n";
            $report .= "- ห้ามพิมพ์ฟอร์ม (ชื่อ: / ที่อยู่: / เบอร์:) ถ้ามีบางข้อมูลแล้ว\n";

            if ( $has_address && ! $has_phone ) {
                $report .= "- ตัวอย่าง: 'ขอบคุณสำหรับที่อยู่ค่ะ รบกวนขอเบอร์โทรศัพท์เพิ่มเติมด้วยนะคะ'\n";
            }
            if ( $has_photo && ! $has_address && ! $has_phone ) {
                $report .= "- ตัวอย่าง: 'ได้รับรูปภาพเรียบร้อยค่ะ รบกวนขอชื่อ-ที่อยู่จัดส่งด้วยนะคะ'\n";
            }
            if ( $has_photo && $has_address && ! $has_phone ) {
                $report .= "- ตัวอย่าง: 'เหลือแค่เบอร์โทรศัพท์ค่ะ รบกวนพิมพ์มาให้แอดมินด้วยนะคะ'\n";
            }
        } else {
            $report .= "\n🎉 ข้อมูลครบทั้ง 3 รายการแล้ว!\n";
            $report .= "คำสั่ง: พิมพ์ [ACTION: OPEN_CLAIM] ต่อท้ายข้อความเสมอ! ห้ามลืมเด็ดขาด!\n";
            $report .= "สรุปข้อมูลให้ลูกค้าตรวจสอบ แล้ว **ต้อง** ปิดท้ายด้วย [ACTION: OPEN_CLAIM]\n";
        }

        return $report;
    }

