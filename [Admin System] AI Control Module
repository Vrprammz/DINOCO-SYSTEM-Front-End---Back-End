            'flow_name'            => function_exists( 'get_field' ) ? get_field( 'flow_name', 'option' ) : '',
            'step_1_ask'           => function_exists( 'get_field' ) ? get_field( 'step_1_ask', 'option' ) : '',
            'step_2_ask'           => function_exists( 'get_field' ) ? get_field( 'step_2_ask', 'option' ) : '',
            'success_message'      => function_exists( 'get_field' ) ? get_field( 'success_message', 'option' ) : '',
        ];

        // Compiled prompt (for display)
        $data['core_prompt'] = $this->get_core_persona_data();

        // Knowledge Base
        if ( ! isset( $data['knowledge'] ) ) $data['knowledge'] = [];
        $data['acf_knowledge'] = [];
        $posts = get_posts( [ 'post_type' => 'ai_knowledge', 'posts_per_page' => -1, 'post_status' => [ 'publish', 'private' ] ] );
        foreach ( $posts as $p ) {
            $q = get_post_meta( $p->ID, 'training_phrases', true );
            if ( ! empty( $q ) ) {
                $data['acf_knowledge'][] = [
                    'id'     => $p->ID,
                    'q'      => $q,
                    'f'      => get_post_meta( $p->ID, 'core_facts', true ),
                    'a'      => get_post_meta( $p->ID, 'ai_action', true ),
                    'legacy' => get_post_meta( $p->ID, 'exact_response', true ),
                ];
            }
        }

        // Catalog
        $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', []);
        $data['catalog'] = is_array( $catalog ) ? $catalog : [];

        echo json_encode( [ 'success' => true, 'data' => $data ] );
        exit;
    }

    private function get_logs() {
        $logs = file_exists( $this->log_file ) ? json_decode( file_get_contents( $this->log_file ), true ) : [];
        if ( ! is_array( $logs ) ) $logs = [];

        $formatted = [];
        foreach ( $logs as $uid => $d ) {
            $hist = isset( $d['messages'] ) ? $d['messages'] : ( isset( $d['history'] ) ? $d['history'] : [] );
            $last_msg = 'ไม่มีข้อความ';
            $last_time = '';
            if ( ! empty( $hist ) ) {
                $li = end( $hist );
                if ( isset( $li['text'] ) && ! empty( $li['text'] ) ) {
                    $last_msg = mb_substr( $li['text'], 0, 30, 'UTF-8' ) . '...';
                } elseif ( ! empty( $li['image'] ) ) {
                    $last_msg = '📷 ส่งรูปภาพ';
                }
                if ( isset( $li['timestamp'] ) ) {
                    $last_time = date( 'H:i', $li['timestamp'] );
                }
            }

            $name = isset( $d['name'] ) ? $d['name'] : 'User ' . $uid;
            if ( strpos( $uid, 'sandbox_admin_' ) === 0 ) {
                $name = '👨‍💻 Admin Sandbox (' . wp_get_current_user()->user_login . ')';
            }

            $formatted[ $uid ] = [
                'name'         => $name,
                'profile_pic'  => isset( $d['profile_pic'] ) ? $d['profile_pic'] : '',
                'last_msg'     => $last_msg,
                'last_time'    => $last_time,
                'time'         => 'ล่าสุด',
                'claim_status' => isset( $d['claim_status'] ) ? $d['claim_status'] : 'none',
                'claim_data'   => isset( $d['claim_data'] ) ? $d['claim_data'] : null,
                'needs_admin'  => isset( $d['needs_admin'] ) ? $d['needs_admin'] : false,
                'is_claim'     => isset( $d['is_claim'] ) ? $d['is_claim'] : false,
                'history'      => $hist,
            ];
        }

        if ( empty( $formatted ) ) {
            $formatted['u1'] = [
                'name' => 'ระบบรอรับข้อความ...', 'profile_pic' => '', 'last_msg' => 'ยังไม่มีแชท',
                'last_time' => '', 'time' => '-', 'claim_status' => 'none', 'claim_data' => null,
                'needs_admin' => false, 'is_claim' => false, 'history' => [],
            ];
        }

        echo json_encode( [ 'success' => true, 'data' => $formatted ] );
        exit;
    }

