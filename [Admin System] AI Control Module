    /**
     * ★ v22: TOOL — get_product()
     * ค้นหาสินค้าจาก inventory ให้ตรงที่สุด 1 ชิ้น
     * return: ชื่อเต็ม + ราคา + รูป + ประกัน
     */
    private function tool_get_product( $args ) {
        $model    = isset( $args['model'] ) ? $args['model'] : '';
        $category = isset( $args['category'] ) ? $args['category'] : '';
        $variant  = isset( $args['variant'] ) ? $args['variant'] : '';

        $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', []);
        if ( empty( $catalog ) || ! is_array( $catalog ) ) {
            return [ 'found' => false, 'message' => 'ไม่มีข้อมูลสินค้าในระบบ' ];
        }

        $search = mb_strtolower( $model . ' ' . $category . ' ' . $variant, 'UTF-8' );

        // Model mapping
        $model_aliases = [
            'nx500' => [ 'nx500', 'nx 500' ], 'cb500x' => [ 'cb500x', 'cb500', 'cb 500' ],
            'adv350' => [ 'adv350', 'adv 350', 'adv' ], 'forza350' => [ 'forza350', 'forza 350', 'forza' ],
            'xl750' => [ 'xl750', 'transalp' ], 'xadv750' => [ 'xadv', 'x-adv' ],
        ];
        $model_key = '';
        foreach ( $model_aliases as $mk => $aliases ) {
            foreach ( $aliases as $a ) {
                if ( mb_strpos( $search, $a ) !== false ) { $model_key = $mk; break 2; }
            }
        }

        // Category mapping
        $cat_map = [
            'กันล้ม' => [ 'กันล้ม', 'crash', 'crashbar' ],
            'กล่องข้าง' => [ 'กล่องข้าง', 'side box', 'sidebox', 'side case' ],
            'กล่องหลัง' => [ 'กล่องหลัง', 'กล่องท้าย', 'top box', 'topbox', 'top case' ],
            'แร็ค' => [ 'แร็ค', 'rack', 'ตะแกรง' ],
            'กระเป๋า' => [ 'กระเป๋า', 'bag', 'dry bag' ],
        ];
        $cat_key = '';
        foreach ( $cat_map as $ck => $kws ) {
            foreach ( $kws as $kw ) {
                if ( mb_strpos( $search, $kw ) !== false ) { $cat_key = $ck; break 2; }
            }
        }

        // Score items
        $best_score = 0;
        $best_item  = null;
        $all_matches = [];

        foreach ( $catalog as $sku => $item ) {
            $name_lower = mb_strtolower( isset( $item['name'] ) ? $item['name'] : '', 'UTF-8' );
            $score = 0;

            // Model match
            if ( $model_key ) {
                $model_kws = isset( $model_aliases[ $model_key ] ) ? $model_aliases[ $model_key ] : [];
                foreach ( $model_kws as $mk ) {
                    if ( mb_strpos( $name_lower, $mk ) !== false ) { $score += 100; break; }
                }
            }

            // Category match
            if ( $cat_key ) {
                $cat_kws = isset( $cat_map[ $cat_key ] ) ? $cat_map[ $cat_key ] : [];
                foreach ( $cat_kws as $ck ) {
                    if ( mb_strpos( $name_lower, $ck ) !== false ) { $score += 50; break; }
                }
            }

            // Variant match
            if ( $variant ) {
                $variant_lower = mb_strtolower( $variant, 'UTF-8' );
                $variant_terms = preg_split( '/[\s,]+/u', $variant_lower );
                foreach ( $variant_terms as $vt ) {
                    if ( mb_strlen( $vt, 'UTF-8' ) >= 2 && mb_strpos( $name_lower, $vt ) !== false ) {
                        $score += 30;
                    }
                }
            }

            if ( $score >= 100 ) {
                $all_matches[] = [
                    'name'     => isset( $item['name'] ) ? $item['name'] : $sku,
                    'price'    => isset( $item['price'] ) ? $item['price'] : '-',
                    'image'    => isset( $item['img'] ) ? $item['img'] : '',
                    'warranty' => isset( $item['years'] ) ? $item['years'] . ' ปี' : '-',
                    'sku'      => $sku,
                    'score'    => $score,
                ];
            }
        }

        if ( empty( $all_matches ) ) {
            return [ 'found' => false, 'message' => "ไม่พบสินค้า {$model} {$category} {$variant} ในคลังสินค้า" ];
        }

        // Sort by score
        usort( $all_matches, function( $a, $b ) { return $b['score'] <=> $a['score']; } );

        // ถ้ามี variant → return 1 ชิ้น (best match)
        // ถ้าไม่มี variant → return top 3 ให้เลือก
        if ( ! empty( $variant ) ) {
            $best = $all_matches[0];
            return [
                'found'    => true,
                'count'    => 1,
                'product'  => [
                    'name'     => $best['name'],
                    'price'    => $best['price'],
                    'image'    => $best['image'],
                    'warranty' => $best['warranty'],
                ],
                'instruction' => 'ตอบชื่อสินค้าเต็ม + ราคา + ส่งรูปด้วย [IMG:url] ที่ให้มา ห้ามใช้รูปอื่น',
            ];
        } else {
            $top3 = array_slice( $all_matches, 0, 3 );
            $products = [];
            foreach ( $top3 as $m ) {
                $products[] = [
                    'name'     => $m['name'],
                    'price'    => $m['price'],
                    'image'    => $m['image'],
                    'warranty' => $m['warranty'],
                ];
            }
            return [
                'found'       => true,
                'count'       => count( $products ),
                'products'    => $products,
                'instruction' => 'แสดงตัวเลือกให้ลูกค้า ถ้าลูกค้าเลือกแล้ว ต้องส่งรูปด้วย [IMG:url] ของสินค้าที่เลือก',
            ];
        }
    }

