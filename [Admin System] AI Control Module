    /**
     * ดึง persona/rules จาก ACF Options หรือ fallback จาก wp_options
     * v20: ลบ sections 6/7/8 ที่ขัดกัน → ย้ายเป็น rules ใน generate_smart_prompt()
     */
    private function get_core_persona_data() {
        $prompt = "";

        if ( function_exists( 'get_field' ) ) {
            // ดึงข้อมูลจาก ACF fields
            $fields = [
                'ai_persona'           => '[1. บทบาทและหน้าที่]',
                'ai_tone_of_voice'     => '[2. น้ำเสียงการตอบ]',
                'negative_prompts'     => '[3. ข้อห้ามเด็ดขาด]',
                'human_handoff_script' => '[4. สคริปต์โอนแอดมิน]',
            ];

            foreach ( $fields as $key => $label ) {
                $val = get_field( $key, 'option' );
                if ( ! empty( $val ) ) {
                    $prompt .= "{$label}\n{$val}\n\n";
                }
            }

            // SOP Flow (ถ้ามี)
            $flow_name = get_field( 'flow_name', 'option' );
            if ( ! empty( $flow_name ) ) {
                $prompt .= "[5. SOP: {$flow_name}]\n";
                $s1 = get_field( 'step_1_ask', 'option' );
                $s2 = get_field( 'step_2_ask', 'option' );
                $sm = get_field( 'success_message', 'option' );
                if ( ! empty( $s1 ) ) $prompt .= "ขั้นตอน 1: {$s1}\n";
                if ( ! empty( $s2 ) ) $prompt .= "ขั้นตอน 2: {$s2}\n";
                if ( ! empty( $sm ) ) $prompt .= "เมื่อสำเร็จ: {$sm}\n";
                $prompt .= "\n";
            }
        }

        // Fallback: ถ้า ACF ว่าง → ดึงจาก wp_options
        if ( empty( trim( $prompt ) ) ) {
            $config = get_option( 'dinoco_ai_config_v9', [] );
            if ( ! empty( $config['core_prompt'] ) ) {
                $prompt = $config['core_prompt'];
            } else {
                $prompt = "คุณคือ AI Admin ของ DINOCO THAILAND\n";
                $prompt .= "หน้าที่: ให้ข้อมูลสินค้า (กล่องอลูมิเนียม, แคชบาร์, แร็ค) และบริการหลังการขาย\n";
                $prompt .= "ตอบกระชับ สุภาพ เป็นภาษาไทย ลงท้ายด้วย 'ค่ะ'\n";
            }
        }

        return $prompt;
    }

    /**
     * ดึง Knowledge Base ทั้งหมดจาก CPT 'ai_knowledge' + wp_options
     */
    private function get_knowledge_base() {
        $kb = [];

        // ดึงจาก CPT
        $posts = get_posts( [
            'post_type'      => 'ai_knowledge',
            'posts_per_page' => -1,
            'post_status'    => [ 'publish', 'private' ],
        ] );

        foreach ( $posts as $post ) {
            $intent = get_post_meta( $post->ID, 'training_phrases', true );
            if ( ! empty( $intent ) ) {
                $kb[] = [
                    'q'      => $intent,
                    'f'      => get_post_meta( $post->ID, 'core_facts', true ),
                    'a'      => get_post_meta( $post->ID, 'ai_action', true ),
                    'legacy' => get_post_meta( $post->ID, 'exact_response', true ),
                ];
            }
        }

        // ดึงจาก wp_options (Manual KB)
        $config = get_option( 'dinoco_ai_config_v9', [] );
        if ( ! empty( $config['knowledge'] ) && is_array( $config['knowledge'] ) ) {
            $kb = array_merge( $kb, $config['knowledge'] );
        }

        return $kb;
    }

