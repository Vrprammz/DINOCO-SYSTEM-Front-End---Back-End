            if ( mb_strpos( $raw_search, $ts ) !== false ) {
                $extra_parts .= ' ' . $ts;
                // ดึงส่วนที่เหลือหลัง keyword ออกมาด้วย
                $parts = explode( $ts, $raw_search );
                foreach ( $parts as $part ) {
                    $part = trim( $part );
                    if ( mb_strlen( $part, 'UTF-8' ) >= 2 ) {
                        $extra_parts .= ' ' . $part;
                    }
                }
            }
