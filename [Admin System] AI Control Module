    private function update_cpt_kb() {
        $post_id = isset( $_POST['post_id'] ) ? intval( $_POST['post_id'] ) : 0;
        $q = isset( $_POST['q'] ) ? sanitize_textarea_field( wp_unslash( $_POST['q'] ) ) : '';
        $f = isset( $_POST['f'] ) ? sanitize_textarea_field( wp_unslash( $_POST['f'] ) ) : '';
        $a = isset( $_POST['a'] ) ? sanitize_textarea_field( wp_unslash( $_POST['a'] ) ) : '';

        if ( $post_id > 0 && ! empty( $q ) ) {
            $title = function_exists( 'mb_substr' ) ? mb_substr( $q, 0, 50, 'UTF-8' ) . '...' : substr( $q, 0, 50 ) . '...';
            wp_update_post( [ 'ID' => $post_id, 'post_title' => wp_slash( $title ) ] );

            update_post_meta( $post_id, 'training_phrases', wp_slash( $q ) );
            update_post_meta( $post_id, 'core_facts', wp_slash( $f ) );
