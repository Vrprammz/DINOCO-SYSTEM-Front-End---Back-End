    /**
     * ★ INVENTORY MATCHING — ดึงสินค้าจาก wp_options: dinoco_product_catalog
     * ข้อมูลนี้คือ "แคตาล็อกสินค้า" (ชื่อ, ราคา, รูป) ที่ AI จะเสนอให้ลูกค้าดู
     * จากนั้นแนะนำไปซื้อกับตัวแทนจำหน่าย
     *
     * v19: method มีอยู่แต่ไม่เคยถูกเรียกใช้! AI จึงไม่รู้ราคาหรือรูปสินค้าเลย
     * v20: เรียกใช้ใน generate_smart_prompt() — AI เห็นสินค้าตรงรุ่นทุกครั้ง
     */
    private function get_relevant_inventory( $user_context ) {
        $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', []);
        if ( empty( $catalog ) || ! is_array( $catalog ) ) {
            return "";
        }

        $ctx = mb_strtolower( $user_context, 'UTF-8' );

        // === ตรวจจับรุ่นรถจากบริบท ===
        $model_map = [
            'nx500'    => [ 'nx500', 'nx 500', 'เอ็นเอ็ก' ],
            'cb500x'   => [ 'cb500x', 'cb500', 'cb 500', 'ซีบี' ],
            'adv350'   => [ 'adv350', 'adv 350' ],
            'forza350' => [ 'forza350', 'forza 350', 'forza', 'ฟอร์ซ่า' ],
            'forza750' => [ 'forza750', 'forza 750' ],
            'xl750'    => [ 'xl750', 'transalp', 'ทรานซัลป์' ],
            'xadv750'  => [ 'xadv', 'x-adv', 'xadv750' ],
            'nmax'     => [ 'nmax', 'เอ็นแม็ก' ],
            'xmax'     => [ 'xmax', 'เอ็กแม็ก' ],
            'pcx'      => [ 'pcx' ],
            'ct125'    => [ 'ct125', 'ct 125' ],
        ];

        $detected_models = [];
        foreach ( $model_map as $mk => $aliases ) {
            foreach ( $aliases as $alias ) {
                if ( mb_strpos( $ctx, $alias ) !== false ) {
                    $detected_models[ $mk ] = true;
                    break;
                }
            }
        }

        // Fix: "adv" alone → adv350 (ไม่ใช่ xadv)
        if ( ! isset( $detected_models['adv350'] ) && preg_match( '/\badv\b/iu', $ctx ) && ! isset( $detected_models['xadv750'] ) ) {
            $detected_models['adv350'] = true;
        }

        // Fix: "forza" alone → forza350 (ไม่ใช่ 750 ถ้าไม่ได้ระบุ)
        if ( isset( $detected_models['forza350'] ) && isset( $detected_models['forza750'] ) ) {
            // ถ้ามี 750 explicit ให้ลบ forza350 ออก
            unset( $detected_models['forza350'] );
        }

        // === ตรวจจับประเภทสินค้า ===
        $type_keywords = [
            'side_box' => [ 'กล่องข้าง', 'ปี๊บข้าง', 'sidebox', 'side box', 'side case' ],
            'top_box'  => [ 'กล่องหลัง', 'กล่องท้าย', 'ปี๊บหลัง', 'ปี๊บท้าย', 'topbox', 'top box', 'top case' ],
            'rack'     => [ 'แร็ค', 'ตะแกรง', 'rack' ],
            'guard'    => [ 'กันล้ม', 'แคชบาร์', 'crash bar', 'crashbar', 'แครชบาร์' ],
            'bag'      => [ 'กระเป๋า', 'bag', 'dry bag' ],
            'acc'      => [ 'เบาะ', 'อินเนอร์', 'ซับใน', 'ถาด', 'plate', 'อะไหล่' ],
            'general'  => [ 'กล่อง', 'ปี๊บ', 'box', 'เท่าไหร่', 'ราคา', 'สนใจ' ],
        ];

        $detected_types = [];
        foreach ( $type_keywords as $tk => $kws ) {
            foreach ( $kws as $kw ) {
                if ( mb_strpos( $ctx, $kw ) !== false ) {
                    $detected_types[ $tk ] = true;
                    break;
                }
            }
        }

        $has_model = ! empty( $detected_models );
        $has_type  = ! empty( $detected_types );

        // ถ้าไม่มีทั้งรุ่นรถและประเภทสินค้า → ไม่ต้อง inject
        if ( ! $has_model && ! $has_type ) {
            return "";
        }

        // ถ้ามีประเภทสินค้าแต่ไม่มีรุ่นรถ → บอก AI ให้ถามรุ่นรถก่อน
        if ( ! $has_model && $has_type ) {
            return "[📦 คลังสินค้า] ⚠️ ลูกค้าถามหาสินค้าแต่ยังไม่ระบุรุ่นรถ\n"
                 . "คำสั่ง: ห้ามเสนอสินค้าใดๆ ห้ามเดารุ่น ให้ถามรุ่นรถก่อน เช่น 'ลูกค้าใช้รถรุ่นไหนคะ?'";
        }

        // ถ้ามีรุ่นรถแต่ไม่มีประเภท → บอก AI ให้ถามประเภท
        if ( $has_model && ! $has_type ) {
            return "[📦 คลังสินค้า] ⚠️ ลูกค้าระบุรุ่นรถแล้ว แต่ยังไม่ระบุประเภทสินค้า\n"
                 . "คำสั่ง: ห้ามร่ายรายการทั้งหมด ให้ถามว่า 'สนใจเป็นกล่องท้าย กล่องข้าง แร็ค หรือกันล้มดีคะ?'";
        }

        // === ทั้งรุ่นรถ + ประเภทมีครบ → ค้นหาจาก catalog ===
        $hits = [];

        foreach ( $catalog as $sku => $item ) {
            if ( ! is_array( $item ) || empty( $item['name'] ) ) continue;
            $name_lower = mb_strtolower( $item['name'], 'UTF-8' );
            $score = 0;
            $model_matched = false;

            // 1) เช็ครุ่นรถตรง
            foreach ( $detected_models as $mk => $_ ) {
                $aliases = isset( $model_map[ $mk ] ) ? $model_map[ $mk ] : [];
                foreach ( $aliases as $alias ) {
                    if ( mb_strpos( $name_lower, $alias ) !== false ) {
                        $score += 100;
                        $model_matched = true;
                        break 2;
                    }
                }
            }

            // 2) เช็คว่าเป็นสินค้า Universal (ไม่มีชื่อรุ่นรถในชื่อ + ไม่ใช่ rack/guard)
            if ( ! $model_matched ) {
                $is_universal = true;

                // ถ้ามีชื่อรุ่นรถในชื่อสินค้า → ไม่ใช่ Universal
                foreach ( $model_map as $aliases ) {
                    foreach ( $aliases as $alias ) {
                        if ( mb_strpos( $name_lower, $alias ) !== false ) {
                            $is_universal = false;
                            break 2;
                        }
                    }
                }

                // Rack และ Guard เป็นตรงรุ่นเสมอ
                if ( preg_match( '/(rack|guard|crash|กันล้ม|แร็ค|แคชบาร์)/i', $name_lower ) ) {
                    $is_universal = false;
                }

                if ( $is_universal ) {
                    $score += 60;
                    $model_matched = true;
                }
            }

            // ถ้ามีรุ่นรถ detected แต่สินค้านี้ไม่ match → ข้ามไป
            if ( $has_model && ! $model_matched ) {
                continue;
            }

            // 3) เช็คประเภทสินค้า
            foreach ( $detected_types as $tk => $_ ) {
                $type_kws = isset( $type_keywords[ $tk ] ) ? $type_keywords[ $tk ] : [];
                foreach ( $type_kws as $tkw ) {
                    if ( mb_strpos( $name_lower, $tkw ) !== false ) {
                        $score += 50;
                        break;
                    }
                }
            }

            // Threshold — ถ้าระบุทั้งรุ่นรถ+ประเภท ต้อง match ทั้งสองอย่าง
            if ( $has_model && $has_type ) {
                // ต้องได้ทั้ง model (100) + type (50) = 150+
                if ( $score >= 150 ) {
                    $item['sku']   = $sku;
                    $item['score'] = $score;
                    $hits[]        = $item;
                }
            } else {
                // ระบุอย่างเดียว — threshold เดิม
                if ( $score >= 50 ) {
                    $item['sku']   = $sku;
                    $item['score'] = $score;
                    $hits[]        = $item;
                }
            }
        }

        if ( empty( $hits ) ) {
            // Fallback: ถ้า strict match ไม่เจอ → ลอง model-only (score >= 100)
            foreach ( $catalog as $sku => $item ) {
                if ( ! is_array( $item ) || empty( $item['name'] ) ) continue;
                $name_lower = mb_strtolower( $item['name'], 'UTF-8' );
                $fb_score = 0;
                $fb_model = false;
                foreach ( $detected_models as $mk => $_ ) {
                    $aliases = isset( $model_map[ $mk ] ) ? $model_map[ $mk ] : [];
                    foreach ( $aliases as $alias ) {
                        if ( mb_strpos( $name_lower, $alias ) !== false ) {
                            $fb_score += 100;
                            $fb_model = true;
                            break 2;
                        }
                    }
                }
                if ( $fb_model ) {
                    $item['sku']   = $sku;
                    $item['score'] = $fb_score;
                    $hits[]        = $item;
                }
            }
        }

        if ( empty( $hits ) ) {
            return "[📦 คลังสินค้า] ❌ ไม่พบสินค้าตรงรุ่นในฐานข้อมูล\n"
                 . "คำสั่ง: แจ้งลูกค้าว่า 'ขออภัยค่ะ ทางเรายังไม่มีสินค้าประเภทนี้ตรงรุ่นค่ะ'";
        }

        // Sort by score → take top 6
        usort( $hits, function( $a, $b ) { return $b['score'] <=> $a['score']; } );
        $hits = array_slice( $hits, 0, 6 );

        // ★ v21: Detect category per item and group output
        $category_map = [
            'กันล้ม'   => '🛡️ กันล้ม',
            'crash'    => '🛡️ กันล้ม',
            'กล่องข้าง' => '📦 กล่องข้าง',
            'side'     => '📦 กล่องข้าง',
            'กล่องหลัง' => '📦 กล่องหลัง',
            'กล่องท้าย' => '📦 กล่องหลัง',
            'top box'  => '📦 กล่องหลัง',
            'top case' => '📦 กล่องหลัง',
            'แร็ค'     => '🔩 แร็ค',
            'rack'     => '🔩 แร็ค',
            'กระเป๋า'  => '🎒 กระเป๋า',
            'bag'      => '🎒 กระเป๋า',
            'dry'      => '🎒 กระเป๋า',
            'handguard' => '🖐️ การ์ดแฮนด์',
            'การ์ด'    => '🖐️ การ์ดแฮนด์',
        ];

        // Assign category to each hit
        foreach ( $hits as &$h ) {
            $name_lower = mb_strtolower( isset( $h['name'] ) ? $h['name'] : '', 'UTF-8' );
            $h['category'] = '📋 อื่นๆ';
            foreach ( $category_map as $kw => $cat ) {
                if ( mb_strpos( $name_lower, $kw ) !== false ) {
                    $h['category'] = $cat;
                    break;
                }
            }
        }
        unset( $h );

        // Group by category
        $groups = [];
        foreach ( $hits as $h ) {
            $groups[ $h['category'] ][] = $h;
        }

        // Format output grouped by category
        $out = "[📦 คลังสินค้า] ✅ พบสินค้าตรงรุ่น:\n";
        foreach ( $groups as $cat => $items ) {
            $out .= "\n--- {$cat} ---\n";
            foreach ( $items as $h ) {
                $name    = isset( $h['name'] ) ? $h['name'] : '?';
