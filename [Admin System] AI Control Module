            $intent_clean = preg_replace( '/["\'""\(\)]/u', ' ', $intent );
            $intent_clean = preg_replace( '/\s+/', ' ', trim( $intent_clean ) );

            // รวมทุก column เป็น searchable text
            $kb_text = $intent_clean . ' ' . $facts . ' ' . $action;

            // 1) Keyword matching จาก intent (primary — คะแนนสูง)
            $keywords = array_filter(
                preg_split( '/[\s,]+/u', $intent_clean ),
                function( $w ) { return mb_strlen( $w, 'UTF-8' ) >= 2; }
            );

            foreach ( $keywords as $kw ) {
                $kw = trim( $kw );
                if ( empty( $kw ) ) continue;
                if ( mb_strpos( $clean_search, $kw ) !== false ) {
                    $matched++;
                    $score += ( mb_strlen( $kw, 'UTF-8' ) >= 4 ) ? 15 : 8;
                }
            }

            // 2) ★ Compound word matching — ค้นหาทั้ง "สติ๊กเกอร์ลอก" เป็นวลีเดียว
            $user_words = preg_split( '/\s+/u', $raw_search );
            foreach ( $user_words as $uw ) {
                if ( mb_strlen( $uw, 'UTF-8' ) >= 6 ) {
                    // คำยาว → ลองตัดย่อยแล้วเทียบกับ intent
                    foreach ( $keywords as $kw ) {
                        $kw = trim( $kw );
                        if ( mb_strlen( $kw, 'UTF-8' ) >= 3 && mb_strpos( $uw, $kw ) !== false ) {
                            if ( mb_strpos( $clean_search, $kw ) === false ) {
                                // keyword อยู่ใน compound word แต่ไม่ match จากขั้นตอน 1
                                $matched++;
                                $score += 12;
                            }
                        }
                    }
                }
            }

            // 2b) ★ Reverse substring matching — เช็คว่า search words อยู่ใน KB keywords ไหม
            // เช่น KB keyword = "สติ๊กเกอร์หลุด" → search มี "สติ๊กเกอร์" + "หลุด" แยกกัน
            $search_words = array_filter(
                preg_split( '/\s+/u', $clean_search ),
                function( $w ) { return mb_strlen( $w, 'UTF-8' ) >= 3; }
            );
            foreach ( $keywords as $kw ) {
                $kw = trim( $kw );
                if ( mb_strlen( $kw, 'UTF-8' ) < 6 ) continue; // เฉพาะ compound keyword ยาว
                $sub_hits = 0;
                foreach ( $search_words as $sw ) {
                    $sw = trim( $sw );
                    if ( mb_strlen( $sw, 'UTF-8' ) >= 3 && mb_strpos( $kw, $sw ) !== false ) {
                        $sub_hits++;
                    }
                }
                if ( $sub_hits >= 2 ) {
                    // search words หลายตัวอยู่ใน KB keyword เดียว → compound match
                    $matched += $sub_hits;
                    $score += 20;
                }
            }

            // 3) Phrase matching — เช็ควลียาว
            $phrases = preg_split( '/\s{2,}|\n/', $intent );
            foreach ( $phrases as $phrase ) {
                $phrase = trim( $phrase );
                if ( mb_strlen( $phrase, 'UTF-8' ) >= 4 && mb_strpos( $clean_search, $phrase ) !== false ) {
                    $score += 30;
                }
            }

            // 4) ★ Facts/Action column matching (secondary — คะแนนต่ำกว่า)
            if ( $score < 15 && $matched < 1 ) {
                $fact_keywords = array_filter(
                    preg_split( '/[\s,]+/u', $facts . ' ' . $action ),
                    function( $w ) { return mb_strlen( $w, 'UTF-8' ) >= 4; }
                );

                $fact_matched = 0;
                foreach ( $fact_keywords as $fk ) {
                    $fk = trim( $fk );
                    if ( ! empty( $fk ) && mb_strpos( $clean_search, $fk ) !== false ) {
                        $fact_matched++;
                        $score += 5; // คะแนนต่ำกว่า intent
                    }
                }
                $matched += $fact_matched;
            }

            // Threshold
            if ( $score >= 12 && $matched >= 1 ) {
                $scored[] = [ 'score' => $score, 'entry' => $entry ];
            }
        }

        // Sort by score descending
        usort( $scored, function( $a, $b ) { return $b['score'] <=> $a['score']; } );

        // Return top N entries
        $results = [];
        foreach ( $scored as $i => $s ) {
            if ( $i >= self::AI_KB_MAX_ENTRIES ) break;
            $results[] = $s['entry'];
        }

        return $results;
    }

