if ( ! function_exists( 'b2f_generate_rcv_number' ) ) {
    function b2f_generate_rcv_number() {
        global $wpdb;
        $today     = wp_date( 'ymd' );
        $lock_name = 'b2f_rcv_num_' . $today;

        $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );

        $last_seq = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT MAX( CAST( SUBSTRING_INDEX(pm.meta_value, '-', -1) AS UNSIGNED ) )
             FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'rcv_number'
             WHERE p.post_type = 'b2f_receiving'
             AND pm.meta_value LIKE %s",
            'RCV-' . $today . '-%'
        ) );

        $rcv_number = sprintf( 'RCV-%s-%03d', $today, $last_seq + 1 );

        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );

        return $rcv_number;
    }
}

