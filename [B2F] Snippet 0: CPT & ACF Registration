// ════════════════════════════════════════════
// 3. HELPER: GROUP ID VALIDATION
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_validate_group_id' ) ) {
    /**
     * ตรวจว่า group_id ไม่ซ้ำกับ distributor หรือ maker อื่น
     * @param string $group_id   LINE Group ID
     * @param int    $exclude_id Post ID ที่ต้อง exclude (ตอนแก้ไข)
     * @return true|WP_Error
     */
    function b2f_validate_group_id( $group_id, $exclude_id = 0 ) {
        if ( empty( $group_id ) ) return true; // ยังไม่กรอก OK

        // ตรวจซ้ำกับ distributor
        $dist = new WP_Query( array(
            'post_type'      => 'distributor',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'meta_query'     => array( array(
                'key'   => 'line_group_id',
                'value' => $group_id,
            ) ),
        ) );
        if ( $dist->found_posts > 0 ) {
            return new WP_Error( 'group_id_conflict', 'Group ID นี้ใช้กับตัวแทนอยู่แล้ว ห้ามซ้ำ' );
        }

        // ตรวจซ้ำกับ maker อื่น
        $maker = new WP_Query( array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => 1,
            'fields'         => 'ids',
            'post__not_in'   => $exclude_id ? array( $exclude_id ) : array(),
            'meta_query'     => array( array(
                'key'   => 'maker_line_group_id',
                'value' => $group_id,
            ) ),
        ) );
        if ( $maker->found_posts > 0 ) {
            return new WP_Error( 'group_id_conflict', 'Group ID นี้ใช้กับโรงงานอื่นอยู่แล้ว ห้ามซ้ำ' );
        }

        return true;
    }
}

// ════════════════════════════════════════════
// 4. HELPER: GET MAKER BY GROUP ID (cached)
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_get_maker_by_group' ) ) {
    /**
     * หา Maker จาก LINE group_id (cached 1 ชม.)
     * @param string $group_id
     * @return array|false  { id, name, group_id } หรือ false
     */
    function b2f_get_maker_by_group( $group_id ) {
        if ( empty( $group_id ) ) return false;

        $cache_key = 'b2f_maker_gid_' . md5( $group_id );
        $cached = get_transient( $cache_key );
        // ถ้า cache เป็น array (มี maker) → return, ถ้า cache เป็น string 'none' → return false
        if ( is_array( $cached ) ) return $cached;
        if ( $cached === 'none' ) return false;

        $q = new WP_Query( array(
            'post_type'      => 'b2f_maker',
            'posts_per_page' => 1,
            'post_status'    => 'publish',
            'meta_query'     => array(
                array( 'key' => 'maker_line_group_id', 'value' => $group_id ),
                array( 'key' => 'maker_status', 'value' => 'active' ),
            ),
        ) );

        if ( ! $q->have_posts() ) {
            // Cache 'none' แค่ 5 นาที (ไม่ใช่ 1 ชม.) — เผื่อ admin เพิ่ม group_id ใหม่
            set_transient( $cache_key, 'none', 300 );
            return false;
        }

        $post = $q->posts[0];
        $result = array(
            'id'       => $post->ID,
            'name'     => get_field( 'maker_name', $post->ID ) ?: $post->post_title,
            'group_id' => $group_id,
        );
        set_transient( $cache_key, $result, 3600 );
        return $result;
    }
}

// ════════════════════════════════════════════
// 5. HELPER: PO NUMBER GENERATOR (query-based)
// ════════════════════════════════════════════

if ( ! function_exists( 'b2f_generate_po_number' ) ) {
    /**
     * สร้างเลข PO แบบ PO-DNC-YYMMDD-NNN (query-based, ไม่ใช้ transient)
     * @return string
     */
    function b2f_generate_po_number() {
        global $wpdb;
        $today     = wp_date( 'ymd' );
        $lock_name = 'b2f_po_num_' . $today;

        // CRIT-09 fix: ใช้ MySQL lock + MAX แทน COUNT เพื่อป้องกัน race condition
        $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );

        $last_seq = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT MAX( CAST( SUBSTRING_INDEX(pm.meta_value, '-', -1) AS UNSIGNED ) )
             FROM {$wpdb->posts} p
             JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID AND pm.meta_key = 'po_number'
             WHERE p.post_type = 'b2f_order'
             AND pm.meta_value LIKE %s",
            'PO-DNC-' . $today . '-%'
        ) );

        $po_number = sprintf( 'PO-DNC-%s-%03d', $today, $last_seq + 1 );

        $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );

        return $po_number;
    }
}

