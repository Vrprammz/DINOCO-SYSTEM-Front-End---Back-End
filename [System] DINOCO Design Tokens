if ( ! function_exists( 'dinoco_status_badge_flex' ) ) {
    /**
     * Render status badge as LINE Flex box JSON array — for use inside Flex
     * Bubble bodies.
     *
     * @param string $status  raw or canonical status
     * @param string $hint    optional subsystem hint
     * @return array  Flex box JSON-compatible array
     */
    function dinoco_status_badge_flex( $status, $hint = '' ) {
        $key = dinoco_status_resolve_key( $status, $hint );
        $registry = dinoco_status_registry();
        $color = '#6b7280'; $bg = '#f3f4f6'; $label = (string) $status; $icon = '';
        if ( isset( $registry[ $key ] ) ) {
            $entry = $registry[ $key ];
            $color = $entry['color'];
            $bg    = $entry['bg'];
            $label = $entry['label_th'];
            $icon  = isset( $entry['icon'] ) ? $entry['icon'] : '';
        }
        $text = $icon !== '' ? ( $icon . ' ' . $label ) : $label;
        return array(
            'type'             => 'box',
