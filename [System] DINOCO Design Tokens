if ( ! function_exists( 'dinoco_design_tokens_should_load' ) ) {
    /**
     * Frontend gate — skip wp-admin (no design tokens needed there).
     *
     * @return bool true when token CSS should emit on this request.
     */
    function dinoco_design_tokens_should_load() {
        if ( is_admin() ) return false;
        if ( defined( 'DOING_AJAX' ) && DOING_AJAX ) return false;
        if ( defined( 'DOING_CRON' ) && DOING_CRON ) return false;
        if ( defined( 'REST_REQUEST' ) && REST_REQUEST ) return false;
        return true;
    }
}

add_action( 'wp_head', function () {
    if ( function_exists( 'dinoco_design_tokens_should_load' )
         && dinoco_design_tokens_should_load() ) {
        dinoco_design_tokens_render_css();
    }
}, 1 );

