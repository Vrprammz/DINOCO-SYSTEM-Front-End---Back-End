if ( ! function_exists( 'dinoco_status_resolve_key' ) ) {
    /**
     * Map free-form status string to canonical registry key.
     * Tolerates legacy strings (e.g. 'paid' → 'b2b.paid' for backwards
     * compatibility with b2b_get_status_labels()).
     *
     * @param string $status   raw status value
     * @param string $hint     optional subsystem hint: 'b2b'|'b2f'|'claim'|'sn'|'charge'
     * @return string  canonical key (e.g. 'b2b.paid') or original $status if no match
     */
    function dinoco_status_resolve_key( $status, $hint = '' ) {
        $status = (string) $status;
        $registry = dinoco_status_registry();
        // Already canonical (contains dot)
        if ( strpos( $status, '.' ) !== false && isset( $registry[ $status ] ) ) {
            return $status;
        }
        // Try hint prefix
        if ( $hint && isset( $registry[ $hint . '.' . $status ] ) ) {
            return $hint . '.' . $status;
        }
        // Try all subsystem prefixes
        foreach ( array( 'b2b', 'b2f', 'claim', 'sn', 'charge' ) as $pfx ) {
            if ( isset( $registry[ $pfx . '.' . $status ] ) ) {
                return $pfx . '.' . $status;
            }
        }
        return $status; // unresolved — caller falls back
    }
}

if ( ! function_exists( 'dinoco_status_label' ) ) {
    /**
     * Get human label for a status.
     *
     * @param string $status  raw or canonical status key
     * @param string $lang    'th' | 'en' (default 'th' per DINOCO conventions)
     * @param string $hint    optional subsystem prefix hint
     * @return string  label text (empty if status unknown)
     */
    function dinoco_status_label( $status, $lang = 'th', $hint = '' ) {
        $key = dinoco_status_resolve_key( $status, $hint );
        $registry = dinoco_status_registry();
        if ( ! isset( $registry[ $key ] ) ) return (string) $status;
        $entry = $registry[ $key ];
        return $lang === 'en'
            ? ( isset( $entry['label_en'] ) ? $entry['label_en'] : '' )
            : ( isset( $entry['label_th'] ) ? $entry['label_th'] : '' );
    }
}

if ( ! function_exists( 'dinoco_status_color' ) ) {
    /**
     * Get status color hex.
     *
     * @param string $status  raw or canonical status key
     * @param string $shade   'primary' (color) | 'bg' (tinted background) | 'severity'
     * @param string $hint    optional subsystem hint
     * @return string  hex color (e.g. '#16a34a') or severity keyword
     */
    function dinoco_status_color( $status, $shade = 'primary', $hint = '' ) {
        $key = dinoco_status_resolve_key( $status, $hint );
        $registry = dinoco_status_registry();
        if ( ! isset( $registry[ $key ] ) ) return '#6b7280';
        $entry = $registry[ $key ];
        switch ( $shade ) {
            case 'bg':       return isset( $entry['bg'] ) ? $entry['bg'] : '#f3f4f6';
            case 'severity': return isset( $entry['severity'] ) ? $entry['severity'] : 'info';
            case 'primary':
            default:         return isset( $entry['color'] ) ? $entry['color'] : '#6b7280';
        }
    }
}

if ( ! function_exists( 'dinoco_status_badge_html' ) ) {
    /**
     * Render status badge as HTML span — for admin tables, customer dashboards.
