     * @param string $status  raw or canonical status
     * @param string $context 'admin' | 'customer' (currently same output, hook for future)
     * @param string $hint    optional subsystem hint
     * @return string  safe HTML
     */
    function dinoco_status_badge_html( $status, $context = 'admin', $hint = '' ) {
        $key = dinoco_status_resolve_key( $status, $hint );
        $registry = dinoco_status_registry();
        if ( ! isset( $registry[ $key ] ) ) {
            // Unknown status — render generic gray badge
            return sprintf(
