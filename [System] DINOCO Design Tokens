/* ═══════════════════════════════════════════════════════════════════════════
 * V.1.2 H5 — Inline JS helper window.dinocoFormatDate(ts, context)
 *    Mirror of `dinoco_format_date()` PHP helper (shipped in B2B Snippet 1
 *    V.34.33 Sprint 2B). Canonical date format per D3 (B2B Snippet 11:659).
 *
 *    customer/flex context → 'd/m/Y' (Gregorian, day-first)
 *    admin context         → 'd/m/Y H:i'
 *    iso context           → 'Y-m-d H:i:s'
 *
 *    Used by Phase 1.3 Flex builders + customer LIFF pages so display
 *    matches server-rendered values byte-identically.
 * ═══════════════════════════════════════════════════════════════════════════ */
if ( ! function_exists( 'dinoco_design_tokens_render_js' ) ) {
    function dinoco_design_tokens_render_js() {
        if ( is_admin() ) return;
        ?>
        <script id="dinoco-design-tokens-js">
        (function() {
            'use strict';
            if (window.dinocoFormatDate) return; // idempotent (loaded multiple times safe)
            function pad(n) { n = String(n); return n.length < 2 ? '0' + n : n; }
            window.dinocoFormatDate = function(ts, context) {
                context = context || 'customer';
                var d;
                if (ts instanceof Date) {
                    d = ts;
                } else if (typeof ts === 'number') {
                    // Unix ms or seconds — heuristic: seconds if < 10^11
                    d = new Date(ts < 1e11 ? ts * 1000 : ts);
                } else if (typeof ts === 'string' && ts) {
                    // Try ISO / MySQL DATETIME — let Date constructor handle
                    d = new Date(ts.replace(' ', 'T'));
                } else {
                    return '';
                }
                if (isNaN(d.getTime())) return '';
                var dd = pad(d.getDate());
                var mm = pad(d.getMonth() + 1);
                var yyyy = d.getFullYear();
                var hh = pad(d.getHours());
                var mi = pad(d.getMinutes());
                var ss = pad(d.getSeconds());
                switch (context) {
                    case 'admin': return dd + '/' + mm + '/' + yyyy + ' ' + hh + ':' + mi;
                    case 'iso':   return yyyy + '-' + mm + '-' + dd + ' ' + hh + ':' + mi + ':' + ss;
                    case 'flex':
                    case 'customer':
                    default:      return dd + '/' + mm + '/' + yyyy;
                }
            };
        })();
        </script>
        <?php
    }
}

