if ( ! function_exists( 'dinoco_design_token_map' ) ) {
    /**
     * Returns the full token registry as a flat associative array.
     * Tokens are namespaced by domain: brand / semantic / sn-status / tier.
     *
     * @return array<string,string> token_key => hex_value
     */
    function dinoco_design_token_map() {
        static $cached = null;
        if ( $cached !== null ) return $cached;

        $cached = array(
            // Brand primary palette
            'brand-navy'             => '#1A3A5C',
            'brand-orange'           => '#FF6B00',
            'brand-cream'            => '#FFF8E7',
            'brand-orange-hover'     => '#E55D00',
            'brand-navy-hover'       => '#13283F',

            // Semantic palette (WCAG AA on #ffffff bg)
            'success'                => '#10b981',
            'warning'                => '#f59e0b',
            'danger'                 => '#dc2626',
            'info'                   => '#3b82f6',

            // S/N pool status (12 states — match Phase 1 W2 schema)
            'sn-status-reserved'           => '#94a3b8',
            'sn-status-in-pool'            => '#3b82f6',
            'sn-status-allocated'          => '#f59e0b',
            'sn-status-shipped'            => '#8b5cf6',
            'sn-status-registered'         => '#10b981',
            'sn-status-claimed'            => '#ec4899',
            'sn-status-replaced'           => '#06b6d4',
            'sn-status-transferred'        => '#0ea5e9',
            'sn-status-voided'             => '#6b7280',
            'sn-status-recalled'           => '#b45309',
            'sn-status-stolen'             => '#dc2626',
            'sn-status-cancelled-batch'    => '#9ca3af',

            // Tier badges (loyalty — match B2B distributor rank_system)
            'tier-bronze'            => '#b45309',
            'tier-silver'            => '#94a3b8',
            'tier-gold'              => '#ca8a04',
            'tier-platinum'          => '#4338ca',
            'tier-diamond-from'      => '#6d28d9',
            'tier-diamond-to'        => '#9333ea',

            // Surface / text (light theme defaults)
            'text-primary'           => '#111827',
            'text-secondary'         => '#4b5563',
            'text-muted'             => '#9ca3af',
            'surface-bg'             => '#f5f5f5',
            'surface-card'           => '#ffffff',
            'border-default'         => '#e0e0e0',
        );
        return $cached;
    }
}

if ( ! function_exists( 'dinoco_brand_color' ) ) {
    /**
     * PHP helper — fetch a token's hex value by key.
     * Use for inline styles, GD label render, Flex Bubble color attributes.
     *
     * @param string $token  e.g. 'brand-orange', 'sn-status-registered'
     * @param string $fallback  returned when token missing (default '#000000')
     * @return string Hex code (e.g. '#FF6B00')
     */
    function dinoco_brand_color( $token, $fallback = '#000000' ) {
        $map = dinoco_design_token_map();
        $key = (string) $token;
        return isset( $map[ $key ] ) ? $map[ $key ] : (string) $fallback;
    }
}

if ( ! function_exists( 'dinoco_brand_logo_url' ) ) {
    /**
     * Returns canonical brand logo URL — overridable via wp_option.
     * Used by Flex Bubble headers (HIGH-4 closure) + admin Audit shortcode.
     *
     * @param string $variant  'default' | 'white' | 'square' (future)
     * @return string Absolute URL to logo image
     */
    function dinoco_brand_logo_url( $variant = 'default' ) {
        $variant = is_string( $variant ) ? $variant : 'default';
        $opt_key = 'dinoco_brand_logo_url' . ( $variant === 'default' ? '' : '_' . $variant );
        $cached  = get_option( $opt_key, '' );
        if ( $cached && filter_var( $cached, FILTER_VALIDATE_URL ) ) {
            return $cached;
        }
        // Hard fallback — canonical existing asset (matches Manual Invoice + Dashboard usage)
        return 'https://dinoco.in.th/wp-content/uploads/dinoco-logo.png';
    }
}

