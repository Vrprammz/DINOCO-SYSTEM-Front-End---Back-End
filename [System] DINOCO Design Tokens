            'spacing'          => 'sm',
            'backgroundColor'  => $bg,
            'cornerRadius'     => 'xl',
            'paddingAll'       => '6px',
            'paddingStart'     => '12px',
            'paddingEnd'       => '12px',
            'contents'         => array(
                array(
                    'type'   => 'text',
                    'text'   => $text,
