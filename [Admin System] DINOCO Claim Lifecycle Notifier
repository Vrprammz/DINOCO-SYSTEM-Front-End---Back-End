if ( ! function_exists( 'dinoco_claim_notif_status_to_slug' ) ) {
    /**
     * Canonical long-form status label → URL-safe slug.
     *
     * Pure-logic transformation matching spec §5.1 status table.
     * Used to construct Flex builder function name + dedup transient key.
     *
     * @param string $status Long-form status (e.g. "Under Maintenance")
     * @return string Slug (e.g. "under_maintenance"). Empty for unknown.
     *
     * @example dinoco_claim_notif_status_to_slug('Under Maintenance')
     *          === 'under_maintenance'
     */
    function dinoco_claim_notif_status_to_slug( $status ) {
        $s = trim( (string) $status );
        if ( $s === '' ) return '';
        // Lowercase + replace spaces/hyphens with underscore + strip non-alnum_
        $slug = strtolower( $s );
        $slug = preg_replace( '/[\s\-]+/', '_', $slug );
        $slug = preg_replace( '/[^a-z0-9_]/', '', $slug );
        $slug = preg_replace( '/_+/', '_', $slug );
        return trim( $slug, '_' );
    }
}

if ( ! function_exists( 'dinoco_claim_notif_should_send' ) ) {
    /**
     * Decide whether a given (from, to) transition warrants a customer push.
     *
     * Pure-logic decision table per spec §5.1:
     *   - Status #3 "In Transit to Company" → NO push (customer keyed tracking)
     *   - All other 10 statuses → YES push
     *   - Empty `to` → NO push (defensive)
     *   - Same from === to → NO push (HR4 — terminal silent skip)
     *
     * @param string $from_status Previous status
     * @param string $to_status   New status
     * @return array{should:bool, reason:string}
     */
    function dinoco_claim_notif_should_send( $from_status, $to_status ) {
        $to = trim( (string) $to_status );
        if ( $to === '' ) {
            return array( 'should' => false, 'reason' => 'empty_to' );
        }
        if ( trim( (string) $from_status ) === $to ) {
            return array( 'should' => false, 'reason' => 'no_change' );
        }
        if ( dinoco_claim_notif_status_to_slug( $to ) === 'in_transit_to_company' ) {
            return array( 'should' => false, 'reason' => 'skip_by_design' );
        }
        return array( 'should' => true, 'reason' => 'ok' );
    }
}

if ( ! function_exists( 'dinoco_claim_notif_dedup_key' ) ) {
    /**
     * Per-(claim, status) dedup transient key. 60s window per spec §2.1.
     *
     * @param int    $claim_id
     * @param string $to_status
     * @return string transient key (≤172 chars per WP option_name limit)
     */
    function dinoco_claim_notif_dedup_key( $claim_id, $to_status ) {
        $slug = dinoco_claim_notif_status_to_slug( $to_status );
        return 'dnc_claim_notif_dedup_' . (int) $claim_id . '_' . $slug;
    }
}


