if ( ! function_exists( 'dinoco_claim_charge_register_crons' ) ) {
    /**
     * Schedule both crons on init. Idempotent — wp_next_scheduled guard.
     */
    function dinoco_claim_charge_register_crons() {
        if ( ! wp_next_scheduled( 'dinoco_claim_charge_expire_cron' ) ) {
            // V.0.6 Sprint 14 C1 fix — moved 02:25 → 02:30 ICT. Was colliding
            // with QW-7 Service Reminder cron (Manager line ~12451) which also
            // fires 02:25 ICT (5 min after LTV). CLAUDE.md cron stagger schedule:
            //   02:00 LTV / 02:05 expiry reminder / 02:10 anniversary / 02:15
            //   service_reminder / 02:20 forecast / 02:30 [THIS — claim_charge]
            //   03:30 GDPR / 03:35 SN orphan / 03:45 claim_charges_cleanup /
            //   03:55 SN audit pepper
            $first_run = strtotime( 'tomorrow 02:30:00' );
            if ( $first_run !== false ) {
                wp_schedule_event( $first_run, 'daily', 'dinoco_claim_charge_expire_cron' );
            }
        }
        if ( ! wp_next_scheduled( 'dinoco_claim_charge_pending_review_sweep_cron' ) ) {
            // V.0.6 Sprint 14 M5 fix — anchor to deterministic :15 minute-of-hour
            // (was `time() + 600` which drifts on every redeploy when
            // wp_next_scheduled returns false). Aligns Health Monitor
            // expectations + survives flag flip-flop cycles.
            $next_quarter = strtotime( 'next hour' );
            if ( $next_quarter !== false ) $next_quarter += 15 * 60;
            else $next_quarter = time() + 900;
            wp_schedule_event( $next_quarter, 'hourly', 'dinoco_claim_charge_pending_review_sweep_cron' );
        }
    }
}


