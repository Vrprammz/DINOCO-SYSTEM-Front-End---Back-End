if ( ! function_exists( 'dinoco_sn_handler_update_batch_status' ) ) {
    function dinoco_sn_handler_update_batch_status( $req ) {
        global $wpdb;
        if ( ! function_exists( 'dinoco_sn_table' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }

        $id = (int) $req->get_param( 'id' );
        $new_status = sanitize_text_field( $req->get_param( 'status' ) );
        $valid = array( 'draft', 'sent_to_factory', 'received_partial', 'received_full', 'closed', 'cancelled' );
        if ( ! in_array( $new_status, $valid, true ) ) {
            return new WP_Error( 'invalid_status', __( 'Invalid batch status.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }

        $tbl = dinoco_sn_table( 'batches' );
        $row = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM {$tbl} WHERE id = %d", $id ) );
        if ( ! $row ) {
            return new WP_Error( 'batch_not_found', '', array( 'status' => 404 ) );
        }

        $now = current_time( 'mysql' );
        $update = array( 'status' => $new_status );
        $update_format = array( '%s' );

        if ( $new_status === 'sent_to_factory' && empty( $row->sent_at ) ) {
            $update['sent_at'] = $now;
            $update_format[] = '%s';
        }
        if ( in_array( $new_status, array( 'closed', 'cancelled' ), true ) && empty( $row->closed_at ) ) {
            $update['closed_at'] = $now;
            $update_format[] = '%s';
        }

        $wpdb->update( $tbl, $update, array( 'id' => $id ), $update_format, array( '%d' ) );

        if ( function_exists( 'dinoco_sn_audit_log' ) ) {
            dinoco_sn_audit_log( null, 'batch_status_change', $row->status, $new_status, array(
                'batch_id'   => $id,
                'batch_code' => $row->batch_code,
            ) );
        }

        return rest_ensure_response( array(
            'success'    => true,
            'id'         => $id,
            'status'     => $new_status,
            'updated_at' => $now,
        ) );
    }
}

