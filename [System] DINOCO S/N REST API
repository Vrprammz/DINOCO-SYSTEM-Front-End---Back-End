/* ═══════════════════════════════════════════════════════════════════════════
 * 6. BATCH CRUD HANDLERS
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_rest_create_batch' ) ) {
    /**
     * POST /dinoco-sn/v1/batches
     *
     * Create new batch + reserve N S/N rows in sn_pool atomically.
     * Idempotent via X-Idempotency-Key header.
     */
    function dinoco_sn_rest_create_batch( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', __( 'S/N system is disabled.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        return dinoco_sn_with_idempotency(
            $req,
            'batch-create',
            array( 'batch_code', 'prefix', 'qty_total', 'format_pattern', 'allocation_strategy' ),
            function( $req ) {
                return dinoco_sn_handler_create_batch( $req );
            }
        );
    }
}

if ( ! function_exists( 'dinoco_sn_handler_create_batch' ) ) {
    /**
     * Inner handler — atomic batch + bulk INSERT chunked 5000/iter.
     *
     * SAFETY:
     *   - GET_LOCK on prefix (prevent prefix collision)
     *   - START TRANSACTION wrap
     *   - Validates qty range + prefix uniqueness
     *   - Chunked INSERT prevents OOM at 100k+ qty
     */
    function dinoco_sn_handler_create_batch( $req ) {
        global $wpdb;

        if ( ! function_exists( 'dinoco_sn_table' ) ) {
            return new WP_Error( 'helper_missing', __( 'S/N Manager not synced.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        $tbl_batches = dinoco_sn_table( 'batches' );
        $tbl_pool    = dinoco_sn_table( 'pool' );

        $batch_code  = sanitize_text_field( $req->get_param( 'batch_code' ) );
        $prefix      = strtoupper( preg_replace( '/[^A-Z0-9]/i', '', (string) $req->get_param( 'prefix' ) ) );
        $qty_total   = (int) $req->get_param( 'qty_total' );
        $format      = sanitize_text_field( $req->get_param( 'format_pattern' ) ?: '{PREFIX}{SEQ:7}' );
        $strategy    = sanitize_text_field( $req->get_param( 'allocation_strategy' ) ?: 'open_pool' );
        $factory     = sanitize_text_field( (string) $req->get_param( 'factory_name' ) );
        $po_ref      = sanitize_text_field( (string) $req->get_param( 'factory_po_ref' ) );
        $notes       = sanitize_textarea_field( (string) $req->get_param( 'notes' ) );
        $created_by  = get_current_user_id();
        $now         = current_time( 'mysql' );

        // Acquire prefix lock (5s timeout)
        $lock_name = "dnc_sn_batch_prefix_{$prefix}";
        $lock_acquired = $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_name, 5 ) );
        if ( $lock_acquired !== '1' ) {
            return new WP_Error( 'db_lock_timeout', __( 'Cannot acquire prefix lock — try again.', 'dinoco-sn' ), array( 'status' => 503 ) );
        }

        try {
            // Check batch_code uniqueness
            $exists = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$tbl_batches} WHERE batch_code = %s", $batch_code
            ) );
            if ( $exists > 0 ) {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
                return new WP_Error( 'batch_code_duplicate',
                    sprintf( __( 'Batch code %s already exists.', 'dinoco-sn' ), $batch_code ),
                    array( 'status' => 409 )
                );
            }

            // Determine next start_seq for this prefix (continue from last or start at 1)
            $last_seq = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT MAX(qty_total) FROM {$tbl_batches} WHERE prefix = %s", $prefix
            ) );
            $start_seq = $last_seq + 1; // Conservative — could clash if old batches existed
            // Safer: scan sn_pool for max numeric suffix matching prefix
            $sn_max = $wpdb->get_var( $wpdb->prepare(
                "SELECT sn FROM {$tbl_pool} WHERE sn LIKE %s ORDER BY sn DESC LIMIT 1",
                $wpdb->esc_like( $prefix ) . '%'
            ) );
            if ( $sn_max ) {
                $sn_suffix = preg_replace( '/^' . preg_quote( $prefix, '/' ) . '/', '', $sn_max );
                $start_seq = ( (int) $sn_suffix ) + 1;
            } else {
                $start_seq = 1;
            }

            // Begin transaction
            $wpdb->query( "START TRANSACTION" );

            // INSERT batch
            $insert_ok = $wpdb->insert( $tbl_batches, array(
                'batch_code'          => $batch_code,
                'prefix'              => $prefix,
                'format_pattern'      => $format,
                'qty_total'           => $qty_total,
                'qty_received'        => 0,
                'qty_voided'          => 0,
                'allocation_strategy' => $strategy,
                'factory_name'        => $factory ?: null,
                'factory_po_ref'      => $po_ref ?: null,
                'status'              => 'draft',
                'notes'               => $notes ?: null,
                'created_by'          => $created_by,
                'created_at'          => $now,
            ), array( '%s','%s','%s','%d','%d','%d','%s','%s','%s','%s','%s','%d','%s' ) );

            if ( ! $insert_ok ) {
                throw new \Exception( 'Failed to insert batch: ' . $wpdb->last_error );
            }

            $batch_id = (int) $wpdb->insert_id;

            // Generate S/N values + chunked INSERT (5000/chunk)
            $chunk_size = 5000;
            $seq_pad = 7; // Default for {PREFIX}{SEQ:7}
            // Parse format pattern (simple {SEQ:N} extraction)
            if ( preg_match( '/\{SEQ:(\d+)\}/', $format, $m ) ) {
                $seq_pad = (int) $m[1];
            }

            $first_sn = $prefix . str_pad( (string) $start_seq, $seq_pad, '0', STR_PAD_LEFT );
            $last_sn  = $prefix . str_pad( (string) ( $start_seq + $qty_total - 1 ), $seq_pad, '0', STR_PAD_LEFT );

            $rows_inserted = 0;
            for ( $i = 0; $i < $qty_total; $i += $chunk_size ) {
                $values = array();
                $placeholders = array();
                $end = min( $i + $chunk_size, $qty_total );

                for ( $j = $i; $j < $end; $j++ ) {
                    $sn = $prefix . str_pad( (string) ( $start_seq + $j ), $seq_pad, '0', STR_PAD_LEFT );
                    $values[] = $sn;
                    $values[] = $batch_id;
                    $values[] = $now;
                    $placeholders[] = "(%s, %d, 'reserved', %s)";
                }

                if ( empty( $placeholders ) ) continue;

                $sql = "INSERT INTO {$tbl_pool} (sn, batch_id, status, created_at) VALUES " . implode( ',', $placeholders );
                $prepared = $wpdb->prepare( $sql, $values );
                $chunk_ok = $wpdb->query( $prepared );

                if ( $chunk_ok === false ) {
                    throw new \Exception( "Chunk insert failed at offset {$i}: " . $wpdb->last_error );
                }

                $rows_inserted += (int) $chunk_ok;
            }

            $wpdb->query( "COMMIT" );

            // Audit log
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( null, 'batch_created', null, null, array(
                    'batch_id'   => $batch_id,
                    'batch_code' => $batch_code,
                    'qty_total'  => $qty_total,
                    'first_sn'   => $first_sn,
                    'last_sn'    => $last_sn,
                ) );
            }

            return rest_ensure_response( array(
                'success'      => true,
                'id'           => $batch_id,
                'batch_code'   => $batch_code,
                'qty_total'    => $qty_total,
                'qty_inserted' => $rows_inserted,
                'first_sn'     => $first_sn,
                'last_sn'      => $last_sn,
                'status'       => 'draft',
                'csv_url'      => rest_url( DINOCO_SN_REST_NAMESPACE . "/batches/{$batch_id}/csv" ),
                'qr_pdf_url'   => rest_url( DINOCO_SN_REST_NAMESPACE . "/batches/{$batch_id}/qr-pdf" ),
                'created_at'   => $now,
            ) );

        } catch ( \Throwable $e ) {
            $wpdb->query( "ROLLBACK" );
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_create_batch', 'batch_code' => $batch_code ) );
            }
            return new WP_Error( 'batch_create_failed', $e->getMessage(), array( 'status' => 500 ) );
        } finally {
            // RELEASE_LOCK is idempotent — safe to call again
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_rest_list_batches' ) ) {
    function dinoco_sn_rest_list_batches( $req ) {
        global $wpdb;

        if ( ! function_exists( 'dinoco_sn_table' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }

        $tbl = dinoco_sn_table( 'batches' );
        $where = array( '1=1' );
        $params = array();

        $status = $req->get_param( 'status' );
        if ( $status ) { $where[] = "status = %s"; $params[] = $status; }

        $prefix = $req->get_param( 'prefix' );
        if ( $prefix ) { $where[] = "prefix = %s"; $params[] = strtoupper( $prefix ); }

        $orderby = in_array( $req->get_param( 'orderby' ), array( 'created_at', 'qty_total', 'qty_received' ), true )
            ? $req->get_param( 'orderby' ) : 'created_at';
        $order = in_array( strtoupper( $req->get_param( 'order' ) ), array( 'ASC', 'DESC' ), true )
            ? strtoupper( $req->get_param( 'order' ) ) : 'DESC';

        $limit  = max( 1, min( 200, (int) $req->get_param( 'limit' ) ) );
        $offset = max( 0, (int) $req->get_param( 'offset' ) );

        $sql_count = "SELECT COUNT(*) FROM {$tbl} WHERE " . implode( ' AND ', $where );
        $sql_data  = "SELECT * FROM {$tbl} WHERE " . implode( ' AND ', $where ) .
                     " ORDER BY {$orderby} {$order} LIMIT %d OFFSET %d";

        if ( ! empty( $params ) ) {
            $total = (int) $wpdb->get_var( $wpdb->prepare( $sql_count, $params ) );
            $rows  = $wpdb->get_results( $wpdb->prepare( $sql_data, array_merge( $params, array( $limit, $offset ) ) ) );
        } else {
            $total = (int) $wpdb->get_var( $sql_count );
            $rows  = $wpdb->get_results( $wpdb->prepare( $sql_data, $limit, $offset ) );
        }

        return rest_ensure_response( array(
            'data' => $rows,
            'meta' => array(
                'total'  => $total,
                'limit'  => $limit,
                'offset' => $offset,
            ),
        ) );
    }
}

