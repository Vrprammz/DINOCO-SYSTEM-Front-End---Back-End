if ( ! function_exists( 'dinoco_sn_perm_public' ) ) {
    /**
     * Public lookup endpoint (S/N → top SET name only). Rate-limited.
     * Phase 2+ adds HMAC URL signing (v2.7 BLOCKER B3 promote).
     */
    function dinoco_sn_perm_public( $request ) {
        // Rate limit — reuse b2b_rate_limit if available
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $ip = $_SERVER['REMOTE_ADDR'] ?? 'unknown';
            $rl = b2b_rate_limit( $ip, 'sn_lookup', 30, 60 ); // 30/min/IP
            if ( is_wp_error( $rl ) ) return $rl;
        }
        return true;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 4. IDEMPOTENCY WRAPPER (delegates to Idempotency Helper V.1.0+)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_with_idempotency' ) ) {
    /**
     * Standard wrapper for POST endpoints. Pattern from Round 19+ DINOCO
     * (e.g., place-order, manual-flash-create).
     *
     * Body hash includes actor_user_id (Round 30+ pattern, fullstack
     * SHOULD-FIX #1 from v2.12 review).
     *
     * Usage:
     *   register_rest_route( DINOCO_SN_REST_NAMESPACE, '/batches', array(
     *     'methods'  => 'POST',
     *     'callback' => 'dinoco_sn_rest_create_batch',
     *     'permission_callback' => 'dinoco_sn_perm_admin',
     *   ) );
     *
     *   function dinoco_sn_rest_create_batch( $req ) {
     *       return dinoco_sn_with_idempotency( $req, 'sn-batch-create',
     *           array( 'batch_code', 'prefix', 'qty_total', 'format_pattern' ),
     *           function( $req ) { return dinoco_sn_handler_create_batch( $req ); }
     *       );
     *   }
     */
    function dinoco_sn_with_idempotency( $req, $namespace_suffix, $body_keys, $handler ) {
        if ( ! function_exists( 'dinoco_idempotency_extract_key' )
          || ! function_exists( 'dinoco_idempotency_check' )
          || ! function_exists( 'dinoco_idempotency_store' )
          || ! function_exists( 'dinoco_idempotency_hash' ) ) {
            // Idempotency Helper not synced — fall through (defensive)
            return call_user_func( $handler, $req );
        }

        $key = dinoco_idempotency_extract_key( $req );
        $namespace = DINOCO_SN_REST_NAMESPACE . '::' . $namespace_suffix;

        // Build body hash from declared keys + actor_user_id
        $body = array();
        foreach ( $body_keys as $k ) {
            $body[ $k ] = $req->get_param( $k );
        }
        $body['_actor_user_id'] = get_current_user_id();
        $body_hash = dinoco_idempotency_hash( $body );

        if ( $key !== '' ) {
            $cached = dinoco_idempotency_check( $key, $namespace, $body_hash );
            if ( is_wp_error( $cached ) ) return $cached; // 409 hash mismatch
            if ( is_array( $cached ) ) return rest_ensure_response( $cached );
        }

        $result = call_user_func( $handler, $req );

        if ( $key !== '' && ! is_wp_error( $result ) ) {
            $resp_data = is_a( $result, 'WP_REST_Response' ) ? $result->get_data() : $result;
            $resp_code = is_a( $result, 'WP_REST_Response' ) ? $result->get_status() : 200;
            dinoco_idempotency_store( $key, $namespace, $body_hash, $resp_data, $resp_code );
        }

        return $result;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 5. ROUTE REGISTRATION (Phase 1 W2 — Batch CRUD only)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_rest_register_routes' ) ) {
    function dinoco_sn_rest_register_routes() {

        // POST /batches — create batch
        register_rest_route( DINOCO_SN_REST_NAMESPACE, '/batches', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_create_batch',
            'permission_callback' => 'dinoco_sn_perm_admin',
            'args'                => array(
                'batch_code' => array(
                    'required'          => true,
                    'type'              => 'string',
                    'sanitize_callback' => 'sanitize_text_field',
                    'validate_callback' => function( $val ) {
                        return is_string( $val ) && strlen( $val ) >= 3 && strlen( $val ) <= 64;
                    },
                ),
                'prefix' => array(
                    'required'          => true,
                    'type'              => 'string',
                    'sanitize_callback' => function( $val ) {
                        return strtoupper( preg_replace( '/[^A-Z0-9]/i', '', (string) $val ) );
                    },
                    'validate_callback' => function( $val ) {
                        return is_string( $val ) && preg_match( '/^[A-Z0-9]{3,6}$/', strtoupper( $val ) );
                    },
                ),
                'qty_total' => array(
                    'required'          => true,
                    'type'              => 'integer',
                    'validate_callback' => function( $val ) {
                        $n = (int) $val;
                        return $n >= 1 && $n <= 1000000;
                    },
                ),
                'format_pattern' => array(
                    'type'              => 'string',
                    'default'           => '{PREFIX}{SEQ:7}',
                    'sanitize_callback' => 'sanitize_text_field',
                ),
                'allocation_strategy' => array(
                    'type'              => 'string',
                    'default'           => 'open_pool',
                    'enum'              => array( 'open_pool', 'pre_assigned' ),
                ),
                'factory_name'   => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'factory_po_ref' => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'notes'          => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_textarea_field' ),
            ),
        ) );

        // GET /batches — list (paginated)
        register_rest_route( DINOCO_SN_REST_NAMESPACE, '/batches', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_list_batches',
            'permission_callback' => 'dinoco_sn_perm_admin',
            'args'                => array(
                'status'   => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'prefix'   => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'orderby'  => array( 'type' => 'string', 'default' => 'created_at',
                                     'enum' => array( 'created_at', 'qty_total', 'qty_received' ) ),
                'order'    => array( 'type' => 'string', 'default' => 'DESC',
                                     'enum' => array( 'ASC', 'DESC' ) ),
                'limit'    => array( 'type' => 'integer', 'default' => 50, 'sanitize_callback' => 'absint' ),
                'offset'   => array( 'type' => 'integer', 'default' => 0, 'sanitize_callback' => 'absint' ),
            ),
        ) );

        // GET /batches/{id} — detail
        register_rest_route( DINOCO_SN_REST_NAMESPACE, '/batches/(?P<id>\d+)', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_get_batch',
            'permission_callback' => 'dinoco_sn_perm_admin',
            'args'                => array(
                'id' => array( 'required' => true, 'type' => 'integer', 'sanitize_callback' => 'absint' ),
            ),
        ) );

        // PATCH /batches/{id}/status — flip status
        register_rest_route( DINOCO_SN_REST_NAMESPACE, '/batches/(?P<id>\d+)/status', array(
            'methods'             => 'POST', // PATCH not universally supported, use POST
            'callback'            => 'dinoco_sn_rest_update_batch_status',
            'permission_callback' => 'dinoco_sn_perm_admin',
            'args'                => array(
                'id' => array( 'required' => true, 'type' => 'integer', 'sanitize_callback' => 'absint' ),
                'status' => array(
                    'required' => true,
                    'type'     => 'string',
                    'enum'     => array( 'draft', 'sent_to_factory', 'received_partial', 'received_full', 'closed', 'cancelled' ),
                ),
            ),
        ) );

        // GET /version — health check (helps debugging)
        register_rest_route( DINOCO_SN_REST_NAMESPACE, '/version', array(
            'methods'             => 'GET',
            'callback'            => function() {
                return rest_ensure_response( array(
                    'api_version'    => DINOCO_SN_API_VERSION,
                    'schema_version' => function_exists( 'dinoco_sn_schema_version' ) ? dinoco_sn_schema_version() : 'unknown',
                    'enabled'        => function_exists( 'dinoco_sn_is_enabled' ) ? dinoco_sn_is_enabled() : false,
                    'phase'          => '1 W2',
                ) );
            },
            'permission_callback' => '__return_true',
        ) );
    }
}

if ( ! has_action( 'rest_api_init', 'dinoco_sn_rest_register_routes' ) ) {
    add_action( 'rest_api_init', 'dinoco_sn_rest_register_routes' );
