if ( ! function_exists( 'dinoco_sn_user_can_admin' ) ) {
    function dinoco_sn_user_can_admin() {
        return current_user_can( 'manage_options' );
    }
}

if ( ! function_exists( 'dinoco_sn_user_can_warehouse' ) ) {
    function dinoco_sn_user_can_warehouse() {
        return current_user_can( 'dinoco_sn_warehouse' )
            || current_user_can( 'manage_options' );
    }
}

if ( ! function_exists( 'dinoco_sn_user_can_approver' ) ) {
    function dinoco_sn_user_can_approver() {
        return current_user_can( 'dinoco_sn_approver' )
            || current_user_can( 'manage_options' );
    }
}

if ( ! function_exists( 'dinoco_sn_user_can_view_pii' ) ) {
    /**
     * Permission to see unmasked customer phone/address. Phase 1+ — only
     * super admin (boss). Service Center sees masked by default.
     */
    function dinoco_sn_user_can_view_pii() {
