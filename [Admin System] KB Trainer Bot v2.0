        <script>
        var T=(function(){
            var N='<?php echo $nonce;?>',A='<?php echo admin_url("admin-ajax.php");?>';
            var h=[],all=[],cn=0,cu=0,busy=0;
            var $c,$i;
            document.addEventListener('DOMContentLoaded',function(){
                $c=document.getElementById('kc');$i=document.getElementById('ki');
                $i.addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();}});
                load();
            });

            function send(){
                if(busy)return;var m=$i.value.trim();if(!m)return;
                msg('user',m);h.push({role:'user',text:m});$i.value='';
                var dot=document.createElement('div');dot.className='ktyp';dot.innerHTML='<i></i><i></i><i></i>';
                $c.appendChild(dot);$c.scrollTop=$c.scrollHeight;
                busy=1;
                var fd=new FormData();fd.append('action','kbt_chat');fd.append('nonce',N);
                fd.append('message',m);fd.append('history',JSON.stringify(h));
                fetch(A,{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(r){
                    dot.remove();busy=0;
                    if(r.success&&r.data){
                        var rp=r.data.reply||'',kb=r.data.kb_entries||[];
                        var cl=rp.replace(/```kb[\s\S]*?```/g,'').trim();
                        if(cl)msg('bot',cl);
                        h.push({role:'model',text:rp});
                        kb.forEach(function(k){card(k);});
                    }else{msg('bot','❌ '+(r.data&&r.data.reply?r.data.reply:'Error'));}
                    $i.focus();
                }).catch(function(e){dot.remove();busy=0;msg('bot','❌ '+e.message);});
            }

            function msg(role,text){
                var d=document.createElement('div');d.className='km '+role;
                d.innerHTML=text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                    .replace(/```(\w*)\n([\s\S]*?)```/g,'<pre>$2</pre>')
                    .replace(/`([^`]+)`/g,'<code>$1</code>')
                    .replace(/\*\*(.+?)\*\*/g,'<b>$1</b>')
                    .replace(/\n/g,'<br>');
                $c.appendChild(d);$c.scrollTop=$c.scrollHeight;
            }

            function card(kb){
                var box=document.getElementById('kp');
                var u='k'+Date.now()+Math.random().toString(36).substr(2,4);
                var isU=kb.action==='update'&&kb.post_id;
                var c=document.createElement('div');
                c.className='kkc '+(isU?'upd':'new');c.id=u;
                c.innerHTML=
                    '<div style="font-weight:700;color:'+(isU?'#1d4ed8':'#92400e')+';margin-bottom:8px">'
                    +(isU?'✏️ แก้ไข KB #'+kb.post_id:'🆕 KB Entry ใหม่')+' — แก้ได้ก่อนบันทึก</div>'
                    +'<div class="kfl"><label>training_phrases</label><div class="kv" contenteditable="true" id="'+u+'-q">'+esc(kb.intent||'')+'</div></div>'
                    +'<div class="kfl"><label>core_facts</label><div class="kv" contenteditable="true" id="'+u+'-f">'+esc(kb.facts||'')+'</div></div>'
                    +'<div class="kfl"><label>ai_action</label><div class="kv" contenteditable="true" id="'+u+'-a">'+esc(kb.guideline||'')+'</div></div>'
                    +'<div class="kacts">'
                    +'<button class="kb1 g s" onclick="T.ok(\''+u+'\','+(isU?kb.post_id:0)+')">✅ บันทึกลง CPT</button>'
                    +'<button class="kb1 r s" onclick="document.getElementById(\''+u+'\').remove()">❌ ยกเลิก</button></div>';
                box.prepend(c);c.scrollIntoView({behavior:'smooth'});
            }

            function ok(uid,pid){
                var q=document.getElementById(uid+'-q').innerText.trim();
                var f=document.getElementById(uid+'-f').innerText.trim();
                var a=document.getElementById(uid+'-a').innerText.trim();
                if(!q){alert('Intent ห้ามว่าง');return;}
                var fd=new FormData();fd.append('nonce',N);
                fd.append('intent',q);fd.append('facts',f);fd.append('guideline',a);
                if(pid>0){fd.append('action','kbt_update');fd.append('post_id',pid);}
                else{fd.append('action','kbt_save');}
                var c=document.getElementById(uid);c.style.opacity='.5';
                fetch(A,{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(r){
                    if(r.success){
                        c.querySelector('.kacts').innerHTML='<div class="kok">'+r.data.message+'</div>';
                        c.style.opacity='1';c.className='kkc done';
                        if(pid>0){cu++;document.getElementById('st-u').textContent=cu;}
                        else{cn++;document.getElementById('st-n').textContent=cn;}
                        load();
                    }else{c.style.opacity='1';alert('❌ '+(r.data&&r.data.message?r.data.message:'Error'));}
                });
            }

            function clear(){
                h=[];$c.innerHTML='<div class="km bot">เริ่มใหม่! 🔄 พี่อยากเทรนเรื่องอะไรครับ?<br>หรือพิมพ์ <b>"เช็ค gap"</b> ให้ผมวิเคราะห์ KB ให้ครับ</div>';
                document.getElementById('kp').innerHTML='';
            }

            function load(){
                var fd=new FormData();fd.append('action','kbt_list');fd.append('nonce',N);
                fetch(A,{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(r){
                    if(r.success){all=r.data.entries||[];document.getElementById('st-t').textContent=all.length;render(all);}
                });
            }

            function filter(){
                var q=document.getElementById('kq').value.toLowerCase();
                if(!q){render(all);return;}
                render(all.filter(function(e){
                    return(e.q||'').toLowerCase().indexOf(q)!==-1||(e.f||'').toLowerCase().indexOf(q)!==-1||(e.a||'').toLowerCase().indexOf(q)!==-1;
                }));
            }

            function render(arr){
                var el=document.getElementById('kl');
                if(!arr.length){el.innerHTML='<div style="text-align:center;color:#94a3b8;padding:20px">ไม่พบ</div>';return;}
                var s='';
                arr.forEach(function(e){
                    s+='<div class="kent" onclick="T.ask('+e.id+')">'
                      +'<span class="kid">#'+e.id+'</span>'
                      +'<span>'+esc((e.q||'').substring(0,100))+'</span>'
                      +(e.f?'<br><small style="color:#64748b">'+esc((e.f||'').substring(0,80))+'...</small>':'')
                      +'</div>';
                });
                el.innerHTML=s;
            }

            function ask(pid){$i.value='แก้ KB #'+pid;$i.focus();}
            function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

            return{send:send,clear:clear,load:load,filter:filter,ok:ok,ask:ask};
        })();
        </script>
        <?php
    }
}
new Dinoco_KB_Trainer();
