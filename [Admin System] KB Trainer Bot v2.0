/**
 * File: [Admin System] KB Trainer Bot v2.0
 * DINOCO KB Trainer Bot
 * Version: V.30.1
 * DB_ID: 62
 * ใช้กับ: Code Snippets plugin → Execute Everywhere
 *
 * ฟีเจอร์:
 * - บอทเห็น KB เดิมทั้งถัง (training_phrases / core_facts / ai_action)
 * - สร้าง entry ใหม่ หรือแก้ไข entry เดิมได้ (ระบุ post_id)
 * - ปรับภาษาอัตโนมัติ — พิมพ์ห้วนๆ บอทเขียนเป็นภาษาแอดมินให้
 * - ใช้ Gemini API Key เดียวกับ AI Command Center
 */

if ( ! defined( 'ABSPATH' ) ) return;

class Dinoco_KB_Trainer {

    public function __construct() {
        add_action( 'admin_menu', [ $this, 'add_menu' ] );
        add_action( 'wp_ajax_kbt_chat',   [ $this, 'ajax_chat' ] );
        add_action( 'wp_ajax_kbt_save',   [ $this, 'ajax_save' ] );
        add_action( 'wp_ajax_kbt_update', [ $this, 'ajax_update' ] );
        add_action( 'wp_ajax_kbt_list',   [ $this, 'ajax_list' ] );
    }

    public function add_menu() {
        add_menu_page( 'KB Trainer', 'KB Trainer', 'manage_options',
            'dinoco-kb-trainer', [ $this, 'render_page' ],
            'dashicons-welcome-learn-more', 31 );
    }

    private function api_key() {
        $c = get_option( 'dinoco_ai_config_v9', [] );
        if ( ! empty( $c['api_key'] ) ) return $c['api_key'];
        return defined( 'DINOCO_GEMINI_KEY' ) ? DINOCO_GEMINI_KEY : '';
    }

    // =================================================================
    // ★ ดึง KB ทั้งถัง — ครบทุก field
    // =================================================================
    private function get_all_kb() {
        $posts = get_posts([
            'post_type'      => 'ai_knowledge',
            'posts_per_page' => -1,
            'post_status'    => [ 'publish', 'private' ],
            'orderby'        => 'ID',
            'order'          => 'ASC',
        ]);
        $out = [];
        foreach ( $posts as $p ) {
            $q = get_post_meta( $p->ID, 'training_phrases', true );
            if ( empty( $q ) ) continue;
            $out[] = [
                'id' => $p->ID,
                'q'  => $q,
                'f'  => (string) get_post_meta( $p->ID, 'core_facts', true ),
                'a'  => (string) get_post_meta( $p->ID, 'ai_action', true ),
            ];
        }
        return $out;
    }

    /** KB dump แบบเต็มทุก field สำหรับ prompt */
    private function kb_dump() {
        $all = $this->get_all_kb();
        if ( empty( $all ) ) return "(ยังไม่มี KB)";
        $lines = [];
        foreach ( $all as $i => $e ) {
            $n = $i + 1;
            $b  = "=== E{$n} [POST_ID:{$e['id']}] ===\n";
            $b .= "training_phrases: {$e['q']}\n";
            $b .= "core_facts: {$e['f']}\n";
            $b .= "ai_action: {$e['a']}\n";
            $lines[] = $b;
        }
        return implode( "\n", $lines );
    }

    // =================================================================
    // ★ SYSTEM PROMPT
    // =================================================================
    private function sys_prompt() {
        $cnt  = count( $this->get_all_kb() );
        $dump = $this->kb_dump();

        return <<<PROMPT
# บทบาท
คุณคือ "KB Trainer Bot" — ผู้ช่วยสร้างและแก้ไขคลังความรู้ AI Chatbot ของ DINOCO Thailand (อุปกรณ์แต่งรถมอเตอร์ไซค์)

# ★ คุณเห็น KB เดิมทั้งหมด {$cnt} entries ด้านล่าง (ครบทุก field: training_phrases, core_facts, ai_action)
ใช้ข้อมูลนี้เพื่อ:
- ตรวจจับข้อมูลที่ผิด/ขาดหาย/ล้าสมัย → เสนอ update
- ถ้าเรื่องซ้ำกับ entry เดิม → ต้อง update (ห้ามสร้างซ้ำเด็ดขาด)
- เทียบข้อมูลที่แอดมินบอกกับ KB เดิม → ถ้าขัดกัน ชี้ให้เห็น
- แนะนำหมวดที่ยังขาด

# วิธีทำงาน
1. สัมภาษณ์แอดมิน — ถามทีละเรื่อง ลงรายละเอียด
2. ได้ข้อมูลพอ → เช็ค KB เดิมก่อน:
   - มี entry ซ้ำ/เกี่ยวข้อง → เสนอ **update** (ระบุ POST_ID เสมอ)
   - ไม่มีเลย → เสนอ **create** ใหม่
3. แสดง KB card ในรูปแบบ JSON ให้แอดมินตรวจก่อนบันทึก

# ★★ กฎปรับภาษา — สำคัญมาก ★★
แอดมินอาจพิมพ์ห้วนๆ เช่น "ไม่มีพลัส ขายแต่อลูฯ"
คุณต้อง **ปรับเป็นภาษาทางการแอดมิน** ที่ AI Chatbot ใช้ได้:
- training_phrases: ครอบคลุมหลายรูปแบบคำถาม (ภาษาพูด+ทางการ+คำย่อ+ภาษาอังกฤษ) คั่นช่องว่าง
- core_facts: ประโยคสมบูรณ์ ข้อเท็จจริงชัดเจน ใส่ราคา/ตัวเลขครบ คั่นด้วย " / "
- ai_action: วิธีตอบลูกค้าชัดเจน สุภาพ ระบุข้อห้าม/ข้อยกเว้น

ตัวอย่าง:
  แอดมินพิมพ์: "กล่องข้าง nx มีแค่อลู 2 แบบ ไม่มีพลาสติก STD 15900 PRO 18500"
  บอทปรับเป็น:
  → training_phrases: กล่องข้าง NX500 มีกี่แบบ กล่องข้างพลาสติก มีอลูมิเนียมไหม side box NX กล่องข้าง CB500X วัสดุกล่อง
  → core_facts: กล่องข้าง NX500 มีเฉพาะอลูมิเนียมเท่านั้น ไม่มีพลาสติก / มี 2 แบบ: STD (15,900 บาท) และ PRO (18,500 บาท) / ขายเป็น Full Set เท่านั้น / CB500X ใช้ชุดเดียวกับ NX500
  → ai_action: ถ้าลูกค้าถามกล่องพลาสติก → ตอบชัดว่าไม่มีค่ะ มีเฉพาะอลูมิเนียม / เสนอ STD กับ PRO ให้เลือก / ถ้าเลือกแล้ว ส่งรูปทันที

# กฎสัมภาษณ์
1. พูดไทย เรียก "พี่" สุภาพ กระชับ
2. ถามทีละเรื่อง ไม่รวมหลายเรื่อง
3. ได้ข้อมูลพอ → สร้าง KB ทันที
4. **ก่อน create → เช็ค KB เดิมเสมอ** ถ้าซ้ำ → update + ระบุ POST_ID
5. ข้อมูลขัดกับ KB เดิม → ชี้ให้เห็น
6. "เช็ค gap" → วิเคราะห์ KB แล้วแนะนำหมวดที่ขาด

# รูปแบบ JSON — สร้างใหม่
```kb
{
  "action": "create",
  "intent": "training_phrases ที่ปรับภาษาแล้ว",
  "facts": "core_facts ที่ปรับภาษาแล้ว",
  "guideline": "ai_action ที่ปรับภาษาแล้ว"
}
```

# รูปแบบ JSON — แก้ไข entry เดิม
```kb
{
  "action": "update",
  "post_id": 123,
  "intent": "training_phrases ใหม่ (รวมของเดิม+เพิ่มเติม)",
  "facts": "core_facts ใหม่ (แก้ไข/เพิ่มเติม)",
  "guideline": "ai_action ใหม่ (แก้ไข/เพิ่มเติม)"
}
```

# ★★★ KB เดิมทั้งหมด ({$cnt} entries) ★★★
{$dump}
PROMPT;
    }

    // =================================================================
    // AJAX: CHAT
    // =================================================================
    public function ajax_chat() {
        check_ajax_referer( 'kbt_nonce', 'nonce' );
        $msg = isset($_POST['message']) ? sanitize_textarea_field(wp_unslash($_POST['message'])) : '';
        $hist = isset($_POST['history']) ? json_decode(wp_unslash($_POST['history']), true) : [];
        if ( empty($msg) ) wp_send_json_error(['reply'=>'กรุณาพิมพ์ข้อความ']);

        $key = $this->api_key();
        if ( empty($key) ) wp_send_json_error(['reply'=>'ไม่พบ Gemini API Key']);

        $contents = [];
        if ( is_array($hist) ) {
            foreach ( $hist as $h ) {
                $r = ($h['role']==='user') ? 'user' : 'model';
                $t = isset($h['text']) ? trim($h['text']) : '';
                if ($t) $contents[] = ['role'=>$r,'parts'=>[['text'=>$t]]];
            }
        }
        $contents[] = ['role'=>'user','parts'=>[['text'=>$msg]]];
        $contents = $this->fix_turns($contents);

        $reply = $this->gemini($key, $this->sys_prompt(), $contents);
        if ( empty($reply) ) wp_send_json_error(['reply'=>'Gemini ไม่ตอบ — ลองใหม่']);

        $blocks = [];
        if ( preg_match_all('/```kb\s*\n(.*?)\n```/s', $reply, $m) ) {
            foreach ($m[1] as $js) {
                $d = json_decode($js, true);
                if (is_array($d) && !empty($d['intent'])) $blocks[] = $d;
            }
        }

        wp_send_json_success(['reply'=>$reply, 'kb_entries'=>$blocks]);
    }

    // AJAX: SAVE NEW
    public function ajax_save() {
        check_ajax_referer('kbt_nonce','nonce');
        $q = isset($_POST['intent']) ? sanitize_textarea_field(wp_unslash($_POST['intent'])) : '';
        $f = isset($_POST['facts']) ? sanitize_textarea_field(wp_unslash($_POST['facts'])) : '';
        $a = isset($_POST['guideline']) ? sanitize_textarea_field(wp_unslash($_POST['guideline'])) : '';
        if (empty($q)) wp_send_json_error(['message'=>'Intent ห้ามว่าง']);

        $pid = wp_insert_post([
            'post_title'  => wp_slash(mb_substr($q,0,60,'UTF-8').'...'),
            'post_type'   => 'ai_knowledge',
            'post_status' => 'private',
        ]);
        if (!$pid || is_wp_error($pid)) wp_send_json_error(['message'=>'สร้าง Post ไม่ได้']);

        $this->save_meta($pid, $q, $f, $a);
        wp_send_json_success(['post_id'=>$pid, 'message'=>"✅ สร้าง KB #{$pid} เรียบร้อย"]);
    }

    // AJAX: UPDATE EXISTING
    public function ajax_update() {
        check_ajax_referer('kbt_nonce','nonce');
        $pid = isset($_POST['post_id']) ? intval($_POST['post_id']) : 0;
        $q = isset($_POST['intent']) ? sanitize_textarea_field(wp_unslash($_POST['intent'])) : '';
        $f = isset($_POST['facts']) ? sanitize_textarea_field(wp_unslash($_POST['facts'])) : '';
        $a = isset($_POST['guideline']) ? sanitize_textarea_field(wp_unslash($_POST['guideline'])) : '';

        if ($pid<=0||empty($q)) wp_send_json_error(['message'=>'post_id/Intent ไม่ถูกต้อง']);
        $post = get_post($pid);
        if (!$post||$post->post_type!=='ai_knowledge') wp_send_json_error(['message'=>"ไม่พบ KB #{$pid}"]);

        wp_update_post(['ID'=>$pid,'post_title'=>wp_slash(mb_substr($q,0,60,'UTF-8').'...')]);
        $this->save_meta($pid, $q, $f, $a);
        wp_send_json_success(['post_id'=>$pid, 'message'=>"✅ อัปเดต KB #{$pid} เรียบร้อย"]);
    }

    // AJAX: LIST ALL
    public function ajax_list() {
        check_ajax_referer('kbt_nonce','nonce');
        $all = $this->get_all_kb();
        wp_send_json_success(['count'=>count($all),'entries'=>$all]);
    }

    // Save meta helper
    private function save_meta($pid,$q,$f,$a) {
        update_post_meta($pid,'training_phrases',wp_slash($q));
        update_post_meta($pid,'core_facts',wp_slash($f));
        update_post_meta($pid,'ai_action',wp_slash($a));
        if (function_exists('update_field')) {
            update_field('training_phrases',wp_slash($q),$pid);
            update_field('core_facts',wp_slash($f),$pid);
            update_field('ai_action',wp_slash($a),$pid);
        }
    }

    // Gemini API
    private function gemini($key,$sys,$contents) {
        $r = wp_remote_post(
            "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={$key}",
            [
                'body'    => json_encode([
                    'systemInstruction'=>['parts'=>[['text'=>$sys]]],
                    'contents'=>$contents,
                    'generationConfig'=>['temperature'=>0.5,'maxOutputTokens'=>4000],
                ], JSON_UNESCAPED_UNICODE),
                'headers' => ['Content-Type'=>'application/json'],
                'timeout' => 30,
            ]
        );
        if (is_wp_error($r)) return '';
        $b = json_decode(wp_remote_retrieve_body($r),true);
        return isset($b['candidates'][0]['content']['parts'][0]['text'])
             ? $b['candidates'][0]['content']['parts'][0]['text'] : '';
    }

    private function fix_turns($c) {
        if(empty($c))return$c;$v=[];$lr='';
        foreach($c as$t){if($t['role']===$lr&&!empty($v)){$i=count($v)-1;$v[$i]['parts'][0]['text'].="\n".$t['parts'][0]['text'];continue;}$v[]=$t;$lr=$t['role'];}
        if(!empty($v)&&$v[0]['role']!=='user')array_shift($v);
        return$v;
    }

