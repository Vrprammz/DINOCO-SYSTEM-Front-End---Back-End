// CLEANUP
// ════════════════════════════════════════════
add_action('b2b_daily_summary_cron', 'b2b_cleanup_old_invoices');
function b2b_cleanup_old_invoices() {
    $d = wp_upload_dir(); $p = $d['basedir'].'/b2b-invoices';
    if (!is_dir($p)) return; $c = 0;
    foreach (glob($p.'/inv-*.png') as $f) {
        if (filemtime($f) < time() - (30 * 86400)) { @unlink($f); $c++; }
    }
    if ($c > 0) b2b_log('[InvImg] Cleaned '.$c.' old files');
}
