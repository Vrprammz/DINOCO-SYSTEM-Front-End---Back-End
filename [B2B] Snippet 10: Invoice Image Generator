        imagettftext($img, 10, 0, $rankX, $y+20, $blueAcc, $font, '('.$rlabel.')');
    }
    imagettftext($img, 12, 0, $rx, $y+20, $gray, $fontB, 'วันที่:');
    imagettftext($img, 13, 0, $rx+130, $y+20, $dark, $font, $data['date']);

    $y += 30;
    if (!empty($data['dist_addr'])) {
        imagettftext($img, 12, 0, $mx+10, $y+20, $gray, $fontB, 'ที่อยู่:');
        $addrLines = b2b_inv_wrap($data['dist_addr'], 380, 11, $font);
        $ay = $y + 20;
        foreach (array_slice($addrLines, 0, 2) as $al) {
            imagettftext($img, 11, 0, $mx+160, $ay, $dark, $font, $al);
            $ay += 18;
        }
    }
    imagettftext($img, 12, 0, $rx, $y+20, $gray, $fontB, 'เลขที่:');
    imagettftext($img, 14, 0, $rx+130, $y+20, $dark, $fontB, $data['inv_no']);

    $y += 30;
    imagettftext($img, 12, 0, $rx, $y+20, $gray, $fontB, 'ผู้สร้างรายการ:');
    $creator = defined('B2B_CREATOR_NAME') ? B2B_CREATOR_NAME : 'DINOCO System';
    imagettftext($img, 13, 0, $rx+130, $y+20, $dark, $font, $creator);

    $y += 34;
    imageline($img, $mx, $y+4, $rgt, $y+4, $vlgray);
    return $y + 14;
}

