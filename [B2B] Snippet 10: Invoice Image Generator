function b2b_inv_font_dir() {
    $d = wp_upload_dir(); $p = $d['basedir'].'/b2b-fonts';
    if (!file_exists($p)) wp_mkdir_p($p); return $p;
}

function b2b_inv_get_font( $bold = false ) {
    $dir = b2b_inv_font_dir();
    $name = $bold ? 'Sarabun-Bold.ttf' : 'Sarabun-Regular.ttf';
    $file = $dir.'/'.$name;
    if (file_exists($file) && filesize($file) > 50000) return $file;
    $urls = $bold ? array(
        'https://fonts.gstatic.com/s/sarabun/v15/DtVjJx26TKEr37c9YOZqik4s.ttf',
        'https://github.com/google/fonts/raw/main/ofl/sarabun/Sarabun-Bold.ttf',
    ) : array(
        'https://fonts.gstatic.com/s/sarabun/v15/DtVjJx26TKEr37c9YL5rik4s.ttf',
        'https://github.com/google/fonts/raw/main/ofl/sarabun/Sarabun-Regular.ttf',
    );
    foreach ($urls as $url) {
        $resp = wp_remote_get($url, array('timeout'=>30,'headers'=>array('User-Agent'=>'Mozilla/5.0')));
        if (!is_wp_error($resp) && wp_remote_retrieve_response_code($resp)===200) {
            $body = wp_remote_retrieve_body($resp);
            if (strlen($body) > 50000 && strpos($body,'<html')===false) {
                if (file_put_contents($file,$body) === false) { b2b_log('[Font] Write failed: '.$file); continue; }
                b2b_log('[Font] Downloaded '.$name.' ('.round(strlen($body)/1024).'KB)');
                return $file;
            }
        }
    }
    $sys = '/usr/share/fonts/truetype/dejavu/DejaVuSans'.($bold?'-Bold':'').'.ttf';
    if (file_exists($sys)) return $sys;
    b2b_log('[Font] ALL sources failed! Upload manually to: '.$dir.'/'.$name);
    return false;
}

// ════════════════════════════════════════════
// LOGO: Download & cache logo image for GD
// ════════════════════════════════════════════
function b2b_inv_get_logo_gd() {
    $url = defined('B2B_LOGO_URL') ? B2B_LOGO_URL : (function_exists('b2b_get_logo_url') ? b2b_get_logo_url() : '');
    if (empty($url)) return false;
    $dir = wp_upload_dir();
    $cache = $dir['basedir'].'/b2b-fonts/logo_cache.png';
    if (file_exists($cache) && filemtime($cache) > time()-86400 && filesize($cache)>1000) {
        $src = @imagecreatefrompng($cache);
        if ($src) { imagealphablending($src, true); imagesavealpha($src, true); return $src; }
    }
    $resp = wp_remote_get($url, array('timeout'=>15));
    if (is_wp_error($resp)) return false;
    $body = wp_remote_retrieve_body($resp);
    if (strlen($body) < 500) return false;
    $src = @imagecreatefromstring($body);
    if (!$src) return false;
    imagealphablending($src, true); imagesavealpha($src, true);
    imagepng($src, $cache, 6);
    return $src;
}

// ════════════════════════════════════════════
// PARSE ORDER ITEMS → with SKU extraction
// V.9: Rank-tier price in discount column (F12)
// ════════════════════════════════════════════
function b2b_inv_parse_items( $raw, $total_amount = 0, $dist_rank = 'standard' ) {
    $items = array();
    if (empty($raw)) return $items;

    $clean = preg_replace('/^.*?ขอยืนยัน[^:]*:\s*/u', '', $raw);
    $clean = preg_replace('/[━─═]+.*$/us', '', $clean);
    $clean = preg_replace('/💰.*$/us', '', $clean);
    $clean = preg_replace('/🏷️.*$/us', '', $clean);

    $lines = preg_split('/[\r\n]+/', trim($clean));
    foreach ($lines as $line) {
        $line = trim($line);
        if (empty($line) || mb_strlen($line) < 3) continue;
        if (preg_match('/^[@🔔📦💰✅❌⏳💲]/', $line)) continue;

        $sku = '';
        if (preg_match('/\(([A-Z0-9]{5,})\)/u', $line, $skuM)) {
            $sku = $skuM[1];
        }

        if (preg_match('/(.+?)\s*x(\d+)\s*=\s*[฿B]?([\d,\.]+)/u', $line, $m)) {
            $qty = intval($m[2]);
            $lineTotal = floatval(str_replace(',','',$m[3]));
            $unitPrice = $qty > 0 ? $lineTotal / $qty : $lineTotal;
            $items[] = array(
                'sku'        => $sku,
                'name'       => trim(preg_replace('/\([A-Z0-9]{5,}\)/u', '', $m[1])),
                'qty'        => $qty,
                'unit_price' => $unitPrice,
                'discount'   => '',
                'total'      => $lineTotal,
            );
        } elseif (!preg_match('/^(?:ยอดประมาณ|ราคาตัวแทนจำหน่าย|มูลค่ารวมสุทธิ)/u', $line)) {
            $items[] = array('sku'=>$sku,'name'=>$line,'qty'=>1,'unit_price'=>0,'discount'=>'','total'=>0);
        }
    }

    if (empty($items) && !empty($raw)) {
        $items[] = array('sku'=>'','name'=>mb_substr($raw,0,100),'qty'=>1,'unit_price'=>$total_amount,'discount'=>'','total'=>$total_amount);
    }

    // V.36: Resolve SET children from dinoco_sku_relations
    $sku_relations = get_option('dinoco_sku_relations', array());
    $catalog = function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog', array());
    foreach ($items as &$it) {
        if (!empty($it['sku'])) {
            $sku_upper = strtoupper(trim($it['sku']));
            if (isset($sku_relations[$sku_upper]) && is_array($sku_relations[$sku_upper])) {
                $children = array();
                foreach ($sku_relations[$sku_upper] as $child_sku) {
                    $child_name = isset($catalog[$child_sku]['name']) ? $catalog[$child_sku]['name'] : $child_sku;
                    $children[] = array('sku' => $child_sku, 'name' => $child_name);
                }
                $it['children'] = $children;
            }
        }
    }
    unset($it);

    // V.30.5: Fill discount + retail using b2b_compute_dealer_price (tier % discount)
    foreach ($items as &$it) {
        if (!empty($it['sku'])) {
            $sku_upper = strtoupper(trim($it['sku']));
            $pd = function_exists('b2b_get_product_data') ? b2b_get_product_data($sku_upper) : null;
            if ($pd) {
                $catalog_price = floatval($pd['base_price'] ?? $pd['price_standard'] ?? 0);
                if ($catalog_price <= 0 && isset($catalog[$sku_upper]['price'])) {
                    $catalog_price = floatval(str_replace(',', '', $catalog[$sku_upper]['price']));
                }
                if ($catalog_price > 0) $it['retail'] = $catalog_price;
                // V.30.5: Use shared helper for dealer price
                if ($catalog_price > 0 && function_exists('b2b_compute_dealer_price')) {
                    $dealer = b2b_compute_dealer_price($catalog_price, $dist_rank, $pd);
                    if ($dealer < $catalog_price) {
                        $disc_pct = round((1 - $dealer / $catalog_price) * 100, 1);
                        $it['discount'] = number_format($disc_pct, 1) . '%';
                    }
                } else {
                    $disc = floatval($pd['b2b_discount_percent']);
                    if ($disc > 0) $it['discount'] = number_format($disc, 2) . '%';
                }
            } elseif (function_exists('b2b_find_product_by_sku')) {
                // Fallback ACF
                $pid = b2b_find_product_by_sku($it['sku']);
                if ($pid) {
                    $catalog_price = floatval(get_field('price_standard', $pid));
                    if ($catalog_price <= 0 && isset($catalog[$sku_upper]['price'])) {
                        $catalog_price = floatval(str_replace(',', '', $catalog[$sku_upper]['price']));
                    }
                    if ($catalog_price > 0) $it['retail'] = $catalog_price;
                    $disc = floatval(get_field('b2b_discount_percent', $pid));
                    if ($disc > 0) $it['discount'] = number_format($disc, 2) . '%';
                }
            }
        }
        // Final fallback: catalog price without product post
        if (empty($it['retail']) && !empty($it['sku'])) {
            $sku_upper = strtoupper(trim($it['sku']));
            if (isset($catalog[$sku_upper]['price'])) {
                $cp = floatval(str_replace(',', '', $catalog[$sku_upper]['price']));
                if ($cp > 0) $it['retail'] = $cp;
            }
        }
    }
    unset($it);

    return $items;
}

// ════════════════════════════════════════════
// THAI BAHT TEXT
// ════════════════════════════════════════════
function b2b_baht_text( $amount ) {
    $amount = round($amount, 2);
    if ($amount == 0) return 'ศูนย์บาทถ้วน';
    $t1 = array('','หนึ่ง','สอง','สาม','สี่','ห้า','หก','เจ็ด','แปด','เก้า');
    $t2 = array('','สิบ','ร้อย','พัน','หมื่น','แสน','ล้าน');
    $baht = intval($amount); $sat = round(($amount-$baht)*100); $r = '';
    if ($baht > 0) {
        $s = strval($baht); $len = strlen($s);
        for ($i=0;$i<$len;$i++) {
            $d=intval($s[$i]); $p=$len-$i-1;
            if ($d==0) continue;
            if ($p==1 && $d==1) { $r.='สิบ'; continue; }
            if ($p==1 && $d==2) { $r.='ยี่สิบ'; continue; }
            if ($p==0 && $d==1 && $len>1) { $r.='เอ็ด'; continue; }
            $r .= $t1[$d].$t2[$p%6];
            if ($p>=6 && $p%6==0) $r.='ล้าน';
        }
        $r .= 'บาท';
    }
    if ($sat > 0) {
        $s2=str_pad(strval($sat),2,'0',STR_PAD_LEFT); $d1=intval($s2[0]); $d2=intval($s2[1]);
        if ($d1==1) $r.='สิบ'; elseif ($d1==2) $r.='ยี่สิบ'; elseif ($d1>0) $r.=$t1[$d1].'สิบ';
        if ($d2==1 && $d1>0) $r.='เอ็ด'; elseif ($d2>0) $r.=$t1[$d2];
        $r .= 'สตางค์';
    } else { $r .= 'ถ้วน'; }
    return $r;
}

// ════════════════════════════════════════════
// GD HELPERS
// ════════════════════════════════════════════
function b2b_inv_tr( $img, $sz, $font, $txt, $rx, $y, $col ) {
    $bb = imagettfbbox($sz, 0, $font, $txt);
    imagettftext($img, $sz, 0, $rx-($bb[2]-$bb[0]), $y, $col, $font, $txt);
}
function b2b_inv_wrap( $text, $maxW, $sz, $font ) {
    $words = preg_split('/([\s]+)/u', $text, -1, PREG_SPLIT_DELIM_CAPTURE);
    $lines = array(); $cur = '';
    foreach ($words as $w) {
        $test = $cur.$w;
        $bb = imagettfbbox($sz, 0, $font, $test);
        if (($bb[2]-$bb[0]) > $maxW && !empty(trim($cur))) { $lines[]=trim($cur); $cur=$w; } else { $cur=$test; }
    }
    if (!empty(trim($cur))) $lines[]=trim($cur);
    return $lines;
}

