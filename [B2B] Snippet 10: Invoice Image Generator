add_action('rest_api_init', function(){
    register_rest_route('b2b/v1','/invoice-image', array(
        'methods'=>'GET','callback'=>'b2b_rest_serve_invoice_image',
        'permission_callback'=>function( WP_REST_Request $req ) {
            // Allow with session token OR signed HMAC URL
            if ( function_exists('b2b_verify_session_token') && b2b_verify_session_token($req) ) return true;
            $sig = sanitize_text_field($req->get_param('_sig'));
            $ts  = intval($req->get_param('_ts'));
            if ( !empty($sig) && $ts > 0 && function_exists('b2b_generate_sig') ) {
                // Reject signatures older than 4 hours
                if ( abs(time() - $ts) > 14400 ) return false;
                $params = array('ticket_id'=>intval($req->get_param('ticket_id')),'_ts'=>$ts,'_sig'=>$sig);
                unset($params['_sig']); ksort($params);
                $expected = b2b_generate_sig('invoice-image/', $params);
                return !empty($expected) && hash_equals($expected, $sig);
            }
            return current_user_can('manage_options');
        },
    ));
});
/**
 * V.10.0: BUG-INV Fix — ลูกค้าไม่เห็น raw JSON อีกแล้ว
 * - ?format=json → return JSON (สำหรับ API call)
 * - default → redirect 302 ไปรูปจริง (1 หน้า) หรือ render HTML gallery (หลายหน้า)
 * - Cache: ใช้ไฟล์เดิมถ้ายังไม่เกิน 1 ชม.
 */
function b2b_rest_serve_invoice_image( WP_REST_Request $r ) {
    $tid = intval($r->get_param('ticket_id'));
    if (!$tid) return new WP_REST_Response(array('error'=>'Missing ticket_id'),400);
    $format = sanitize_text_field($r->get_param('format'));

    // V.10.0: Cache — ดูว่ามีไฟล์เก่าที่ยังไม่เกิน 1 ชม. อยู่ไหม
    $urls = b2b_get_cached_invoice_pages($tid);
    if (empty($urls)) {
        $urls = b2b_generate_invoice_pages($tid);
    }
    if (!$urls) return new WP_REST_Response(array('error'=>'Failed'),500);

    // ?format=json → return JSON (สำหรับ programmatic use)
    if ($format === 'json') {
        return new WP_REST_Response(array('success'=>true,'pages'=>$urls));
    }

    // Default: redirect/render HTML
    if (count($urls) === 1) {
        // 1 หน้า → redirect 302 ไปรูปจริง
        header('Location: ' . $urls[0], true, 302);
        exit;
    } else {
        // หลายหน้า → render HTML gallery
        header('Content-Type: text/html; charset=UTF-8');
        echo '<!DOCTYPE html><html lang="th"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">';
        echo '<title>Invoice #'.$tid.'</title>';
        echo '<style>body{margin:0;padding:16px;background:#f1f5f9;font-family:-apple-system,sans-serif;text-align:center}img{max-width:100%;margin:8px auto;display:block;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1)}h3{color:#1e293b;margin:16px 0 8px}p{color:#64748b;font-size:13px;margin:4px 0}</style>';
        echo '</head><body><h3>Invoice #'.$tid.'</h3>';
        foreach ($urls as $i => $url) {
            echo '<p>หน้า '.($i+1).'/'.count($urls).'</p>';
            echo '<img src="'.esc_url($url).'" alt="Invoice page '.($i+1).'">';
        }
        echo '<p style="margin-top:24px;font-size:11px;color:#94a3b8;">DINOCO B2B Invoice System</p>';
        echo '</body></html>';
        exit;
    }
}

/**
 * V.10.0: Cache — ดึงไฟล์ invoice ที่ gen ไว้แล้ว (ไม่เกิน 1 ชม.)
 */
function b2b_get_cached_invoice_pages( $ticket_id ) {
    $upload = wp_upload_dir();
    $dir = $upload['basedir'].'/b2b-invoices';
    $url_base = $upload['baseurl'].'/b2b-invoices';
    $pattern = $dir.'/inv-'.$ticket_id.'-*.png';
    $files = glob($pattern);
    if (empty($files)) return array();

    // Check if newest file is less than 1 hour old
    $newest = 0;
    foreach ($files as $f) {
        $mtime = filemtime($f);
        if ($mtime > $newest) $newest = $mtime;
    }
    if ((time() - $newest) > 3600) return array(); // expired

    sort($files);
    $urls = array();
    foreach ($files as $f) {
        $urls[] = $url_base . '/' . basename($f);
    }
    return $urls;
}

