// ════════════════════════════════════════════
// V.10.0: B2 — รองรับ Receipt (doc_type = 'receipt' สำหรับ paid/completed)
function b2b_inv_draw_header( $img, $font, $fontB, $colors, $pageNum, $totalPages, $inv_no, $doc_type = 'invoice' ) {
    $W = B2B_INV_W; $mx = B2B_INV_MX; $rgt = $W-$mx;
    extract($colors);
    $hH = 90;
    imagefilledrectangle($img, 0, 0, $W, $hH, $dark);
    $logo = b2b_inv_get_logo_gd();
    if ($logo) {
        $lw = imagesx($logo); $lh = imagesy($logo);
        $targetH = 55; $targetW = $lh > 0 ? intval($lw * ($targetH / $lh)) : $lw;
        $logoX = $mx + 10; $logoY = intval(($hH - $targetH) / 2);
        imagealphablending($img, true);
        imagecopyresampled($img, $logo, $logoX, $logoY, 0, 0, $targetW, $targetH, $lw, $lh);
        imagedestroy($logo);
    } else {
        $co = defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO THAILAND';
        imagettftext($img, 26, 0, $mx+10, intval($hH/2)+10, $white, $fontB, $co);
    }
    // V.10.0: B2 — แสดง "ใบเสร็จรับเงิน" ถ้าจ่ายแล้ว
    $doc_title = ($doc_type === 'receipt') ? 'ใบเสร็จรับเงิน' : 'ใบแจ้งหนี้/วางบิล';
    b2b_inv_tr($img, 26, $fontB, $doc_title, $rgt-10, 55, $white);
    if ($totalPages > 1) {
        $pg = 'หน้า '.$pageNum.'/'.$totalPages;
        b2b_inv_tr($img, 10, $font, $pg, $rgt-10, 80, $lgray2);
    }
    imagefilledrectangle($img, 0, $hH, $W, $hH+5, $green);
    return $hH + 5;
}

