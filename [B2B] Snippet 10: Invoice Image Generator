    extract($colors);
    imagettftext($img, 13, 0, $mx, $y, $dark, $fontB, 'รายการสินค้า');
    $y += 18;
    $thH = 36;
    imagefilledrectangle($img, $mx, $y, $rgt, $y+$thH, $dark);
    imagettftext($img, 10, 0, $mx+10, $y+24, $white, $fontB, '#');
    imagettftext($img, 10, 0, $mx+40, $y+24, $white, $fontB, 'รหัสสินค้า');
    imagettftext($img, 10, 0, $mx+180, $y+24, $white, $fontB, 'ชื่อสินค้า');
    b2b_inv_tr($img, 10, $fontB, 'จำนวน', $mx+670, $y+24, $white);
    b2b_inv_tr($img, 10, $fontB, 'ราคาจำหน่าย', $mx+820, $y+24, $white);
    b2b_inv_tr($img, 10, $fontB, 'ส่วนลดตัวแทน(%)', $mx+960, $y+24, $white);
    b2b_inv_tr($img, 10, $fontB, 'ราคาตัวแทนรวมส่วนลด(฿)', $rgt-8, $y+24, $white);
    return $y + $thH;
}

// ════════════════════════════════════════════
// DRAW: Single table row
// ════════════════════════════════════════════
function b2b_inv_draw_row( $img, $y, $idx, $item, $font, $fontB, $colors, $maxNameW ) {
    $W = B2B_INV_W; $mx = B2B_INV_MX; $rgt = $W-$mx;
    extract($colors);
    $nameLines = b2b_inv_wrap($item['name'], $maxNameW, 11, $font);
    $skuLines  = !empty($item['sku']) ? b2b_inv_wrap($item['sku'], 120, 9, $font) : array();
    $textH = max(count($nameLines), count($skuLines)) * 18;
    $rowH  = max(44, $textH + 16);
    $bgc = ($idx % 2 === 0) ? $white : imagecolorallocate($img, 248, 248, 248);
    imagefilledrectangle($img, $mx, $y, $rgt, $y+$rowH, $bgc);
    imageline($img, $mx, $y+$rowH, $rgt, $y+$rowH, $vlgray);
    $cols = array($mx+35, $mx+165, $mx+560, $mx+680, $mx+830, $mx+970);
    foreach ($cols as $cx) { imageline($img, $cx, $y, $cx, $y+$rowH, $vlgray); }
    imagettftext($img, 10, 0, $mx+12, $y+24, $dark, $font, strval($idx));
    $sy = $y + 22;
    foreach ($skuLines as $sl) { imagettftext($img, 9, 0, $mx+42, $sy, $gray, $font, $sl); $sy += 16; }
    $ny = $y + 22;
    foreach ($nameLines as $nl) { imagettftext($img, 11, 0, $mx+172, $ny, $dark, $font, $nl); $ny += 18; }
    b2b_inv_tr($img, 11, $font, strval($item['qty']), $mx+670, $y+24, $dark);
    $up = !empty($item['retail']) ? number_format($item['retail'], 2) : ($item['unit_price'] > 0 ? number_format($item['unit_price'], 2) : '-');
    b2b_inv_tr($img, 11, $font, $up, $mx+820, $y+24, $dark);
    $disc = !empty($item['discount']) ? $item['discount'] : '-';
    b2b_inv_tr($img, 11, $font, $disc, $mx+960, $y+24, $gray);
    $tot = $item['total'] > 0 ? number_format($item['total'], 2) : '-';
    b2b_inv_tr($img, 11, $fontB, $tot, $rgt-8, $y+24, $dark);
    return $rowH;
}

// ════════════════════════════════════════════
// DRAW: Totals + Due + Notes
// V.9: customer_note displayed (N5)
// ════════════════════════════════════════════
function b2b_inv_draw_footer_section( $img, $y, $font, $fontB, $colors, $data ) {
    $W = B2B_INV_W; $mx = B2B_INV_MX; $rgt = $W-$mx;
    extract($colors);

    $y += 6;

    // 1. ราคาจำหน่าย
    if (!empty($data['total_retail']) && $data['total_retail'] > 0) {
        imagettftext($img, 12, 0, $mx+560+10, $y+16, $gray, $font, 'ราคาจำหน่าย');
        b2b_inv_tr($img, 12, $font, number_format($data['total_retail'],2), $rgt-8, $y+16, $dark);
        $y += 24;
    }

    // 2. ส่วนลดตัวแทน (฿ only)
    if (!empty($data['total_discount']) && $data['total_discount'] > 0) {
        imagettftext($img, 12, 0, $mx+560+10, $y+16, $green, $font, 'ส่วนลดตัวแทน');
        b2b_inv_tr($img, 12, $font, '-'.number_format($data['total_discount'],2), $rgt-8, $y+16, $green);
        $y += 24;
    }

    // 3. ราคาตัวแทนรวมส่วนลด
    imagettftext($img, 12, 0, $mx+560+10, $y+16, $gray, $font, 'ราคาตัวแทนรวมส่วนลด');
    b2b_inv_tr($img, 12, $fontB, number_format($data['subtotal'],2), $rgt-8, $y+16, $dark);
    $y += 24;

    $y += 4;
    imageline($img, $mx+560, $y, $rgt, $y, $vlgray);
    $y += 10;

    // 5. มูลค่ารวมสุทธิ (bold grand total)
    imagettftext($img, 15, 0, $mx+560+10, $y+22, $dark, $fontB, 'มูลค่ารวมสุทธิ');
    b2b_inv_tr($img, 22, $fontB, number_format($data['total'],2).' บาท', $rgt-8, $y+24, $green);
    $y += 36;
    $btxt = '('.b2b_baht_text($data['total']).')';
    b2b_inv_tr($img, 10, $font, $btxt, $rgt-8, $y+8, $gray);

    $y += 36;

    imagefilledrectangle($img, $mx, $y, $rgt, $y+44, $pinkBg);
    imagefilledrectangle($img, $mx, $y, $mx+5, $y+44, $red);
    imagettftext($img, 13, 0, $mx+22, $y+30, $red, $fontB, 'กำหนดชำระ:  '.$data['due_str'].'  ('.$data['term'].' วัน)');
    $y += 60;

    // Admin note
    if (!empty($data['note'])) {
        imagettftext($img, 11, 0, $mx, $y, $gray, $font, 'หมายเหตุ Admin: '.mb_substr($data['note'],0,80));
        $y += 20;
    }

    // V.9: Customer note (N5)
    if (!empty($data['customer_note'])) {
        imagettftext($img, 11, 0, $mx, $y, $blueAcc, $font, 'หมายเหตุลูกค้า: '.mb_substr($data['customer_note'],0,80));
        $y += 20;
    }

    return $y;
}

// ════════════════════════════════════════════
// DRAW: Signatures (4 ช่อง)
// ════════════════════════════════════════════
function b2b_inv_draw_signatures( $img, $font, $fontB, $colors ) {
    $W = B2B_INV_W; $mx = B2B_INV_MX; $rgt = $W-$mx; $cw = $rgt-$mx;
    extract($colors);
    $sy = B2B_INV_H - 190;
    imageline($img, $mx, $sy-15, $rgt, $sy-15, $vlgray);
    $sigW = intval(($cw - 60) / 4);
    $sigs = array('ผู้รับสินค้า','ผู้ส่งสินค้า','ผู้รับเงิน','ผู้อนุมัติ');
    for ($i = 0; $i < 4; $i++) {
        $sx = $mx + 15 + $i * ($sigW + 20);
        imagettftext($img, 11, 0, $sx+15, $sy, $dark, $fontB, $sigs[$i]);
        if ($i === 3) {
            imagettftext($img, 14, 0, $sx+10, $sy+38, $blueAcc, $fontB, 'DINOCO SYSTEM');
            imagettftext($img, 9, 0, $sx+10, $sy+55, $lgray, $font, '(Digital Signature)');
        }
        for ($dx = 0; $dx < $sigW-20; $dx += 6) {
            imagesetpixel($img, $sx+10+$dx, $sy+65, $lgray);
            imagesetpixel($img, $sx+11+$dx, $sy+65, $lgray);
        }
        imagettftext($img, 10, 0, $sx+15, $sy+85, $lgray, $font, 'วันที่');
        if ($i === 3) {
            imagettftext($img, 10, 0, $sx+55, $sy+85, $dark, $font, b2b_date('d/m/Y'));
        } else {
            for ($dx = 0; $dx < $sigW-70; $dx += 6) {
                imagesetpixel($img, $sx+55+$dx, $sy+85, $lgray);
                imagesetpixel($img, $sx+56+$dx, $sy+85, $lgray);
            }
        }
    }
    $fy = B2B_INV_H - 45;
    imageline($img, $mx, $fy, $rgt, $fy, $vlgray);
    $co = defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO THAILAND';
    imagettftext($img, 9, 0, $mx, $fy+22, $lgray, $font, $co.'  •  Auto-generated  •  '.b2b_date('d/m/Y H:i'));
    b2b_inv_tr($img, 9, $font, 'dinoco.in.th', $rgt, $fy+22, $lgray);
}

// ════════════════════════════════════════════
// COLOR PALETTE
