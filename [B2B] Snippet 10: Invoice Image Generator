    imagettftext($img, 14, 0, $mx+160, $y+20, $dark, $fontB, $data['dist_name']);
    // V.9: Rank label next to name
    if (!empty($data['dist_rank']) && $data['dist_rank'] !== 'standard') {
        $rl = array('silver'=>'🥈 Silver','gold'=>'🥇 Gold','platinum'=>'💎 Platinum','diamond'=>'💠 Diamond');
        $bb = imagettfbbox(14, 0, $fontB, $data['dist_name']);
        $rankX = $mx + 160 + ($bb[2] - $bb[0]) + 12;
