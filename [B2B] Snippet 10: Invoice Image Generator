function b2b_inv_colors( $img ) {
    return array(
        'white'=>imagecolorallocate($img,255,255,255),'black'=>imagecolorallocate($img,0,0,0),
        'dark'=>imagecolorallocate($img,34,34,34),'gray'=>imagecolorallocate($img,100,100,100),
        'lgray'=>imagecolorallocate($img,170,170,170),'lgray2'=>imagecolorallocate($img,180,180,180),
        'vlgray'=>imagecolorallocate($img,225,225,225),'green'=>imagecolorallocate($img,22,163,106),
        'red'=>imagecolorallocate($img,200,30,30),'blueAcc'=>imagecolorallocate($img,0,128,128),
        'pinkBg'=>imagecolorallocate($img,255,240,240),'bankBg'=>imagecolorallocate($img,245,245,245),
    );
}

// ════════════════════════════════════════════
// MAIN: Generate Invoice Pages
// V.9: dist_addr + dist_rank + customer_note
// ════════════════════════════════════════════
function b2b_generate_invoice_pages( $ticket_id ) {
    if (!function_exists('imagecreatetruecolor') || !function_exists('imagettftext')) {
        b2b_log('[InvImg] GD/FreeType not available'); return false;
    }
    $font = b2b_inv_get_font(false); $fontB = b2b_inv_get_font(true);
    if (!$font) return false;
    if (!$fontB) $fontB = $font;

    $upload = wp_upload_dir();
    $dir = $upload['basedir'].'/b2b-invoices';
    if (!file_exists($dir)) wp_mkdir_p($dir);
    // V.10.0: ไม่ลบไฟล์เก่าทันที — ให้ cache ยังใช้ได้ (cleanup cron จะลบหลัง 30 วัน)
    // ลบเฉพาะเมื่อ re-generate เท่านั้น
    $old_files = glob($dir.'/inv-'.$ticket_id.'-*.png');
    if (!empty($old_files)) array_map('unlink', $old_files);

    // ── Ticket Data ──
    $total     = floatval(get_field('total_amount',$ticket_id));
    $items_raw = get_field('order_items',$ticket_id) ?: '';
    $note      = get_field('admin_note',$ticket_id) ?: '';
    $gid       = get_field('source_group_id',$ticket_id) ?: '';
    $due_date  = get_field('due_date',$ticket_id) ?: '';
    $dist      = $gid ? b2b_get_dist_by_group($gid) : null;
    $dist_name = $dist ? (get_field('shop_name',$dist->ID) ?: get_the_title($dist->ID)) : 'Customer';

    // V.9: Distributor address from ACF fields (C2)
    $dist_addr = '';
    if ($dist) {
        $parts = array_filter(array(
            get_field('dist_address', $dist->ID),
            get_field('dist_district', $dist->ID),
            get_field('dist_province', $dist->ID),
            get_field('dist_postcode', $dist->ID),
        ));
        $dist_addr = implode(' ', $parts);
    }

    // V.9: Distributor rank for pricing (F12)
    $dist_rank = $dist ? (get_field('rank_system', $dist->ID) ?: 'standard') : 'standard';

    // คำนวณจำนวนวันจริงจากวันที่บิล → วันครบกำหนด
    // Safe date parse — รองรับทั้ง d/m/Y และ Y-m-d
    $due_ts_calc = false;
    if (!empty($due_date)) {
        $dto = DateTime::createFromFormat('d/m/Y', $due_date) ?: DateTime::createFromFormat('Y-m-d', $due_date);
        $due_ts_calc = $dto ? $dto->getTimestamp() : strtotime($due_date);
    }
    $inv_ts_calc = strtotime(get_post_meta($ticket_id, '_inv_date', true) ?: get_the_date('Y-m-d', $ticket_id));
    if ($due_ts_calc && $due_ts_calc > 86400 && $inv_ts_calc && $inv_ts_calc > 86400) {
        $term = intval(round(($due_ts_calc - $inv_ts_calc) / 86400));
    } else {
        $term = $dist ? (intval(get_field('credit_term_days',$dist->ID)) ?: 30) : 30;
    }
    $bank      = function_exists('b2b_get_bank_info') ? b2b_get_bank_info( $ticket_id ) : array('name'=>'-','account'=>'-','holder'=>'-');
    $items     = b2b_inv_parse_items($items_raw, $total, $dist_rank);
    $due_str   = !empty($due_date) ? (function_exists('b2b_parse_date') ? b2b_parse_date($due_date) : $due_date) : '-';
    $inv_no    = 'INV-'.$ticket_id;

    // V.9: Customer note (N5)
    $customer_note = get_field('customer_note', $ticket_id) ?: '';

    // V.10.0: B2 — Receipt detection (หลังจ่าย = receipt)
    $ticket_status = get_field('order_status', $ticket_id) ?: 'draft';
    $doc_type = in_array($ticket_status, array('paid','completed','claim_resolved'), true) ? 'receipt' : 'invoice';

    $maxNameW = 380;

    $pageH = B2B_INV_H;
    $footerReserve = 250 + 200 + 60;
    $p1_available  = $pageH - 135 - 120 - 56 - $footerReserve;
    $pN_available  = $pageH - 135 - 56 - $footerReserve;

    $rowHeights = array();
    foreach ($items as $it) {
        $nl = b2b_inv_wrap($it['name'], $maxNameW, 11, $font);
        $sl = !empty($it['sku']) ? b2b_inv_wrap($it['sku'], 120, 9, $font) : array();
        $textH = max(count($nl), count($sl)) * 18;
        $rowHeights[] = max(44, $textH + 16);
    }

    $pages = array(); $curItems = array(); $curH = 0; $pageIdx = 0;
    foreach ($items as $i => $item) {
        $rh = $rowHeights[$i];
        $avail = ($pageIdx === 0) ? $p1_available : $pN_available;
        if ($curH + $rh > $avail && !empty($curItems)) {
            $pages[] = $curItems; $curItems = array(); $curH = 0; $pageIdx++;
        }
        $curItems[] = array('item'=>$item, 'height'=>$rh, 'orig_idx'=>$i);
        $curH += $rh;
    }
    if (!empty($curItems)) $pages[] = $curItems;
    if (empty($pages)) $pages[] = array();

    $totalPages = count($pages);
    $totalQty = array_sum(array_column($items, 'qty'));
    $subtotal = array_sum(array_column($items, 'total'));
    if ($subtotal <= 0) $subtotal = $total;

    // V.30.4: Compute retail/discount for footer — custom table first
    $ft_total_retail = 0;
    foreach ($items as $it) {
        if (!empty($it['retail'])) {
            $ft_total_retail += $it['retail'] * $it['qty'];
        } elseif (!empty($it['sku'])) {
            $pd = function_exists('b2b_get_product_data') ? b2b_get_product_data($it['sku']) : null;
            if ($pd && $pd['price_standard'] > 0) {
                $ft_total_retail += $pd['price_standard'] * $it['qty'];
            } elseif (function_exists('b2b_find_product_by_sku')) {
                $pid = b2b_find_product_by_sku($it['sku']);
                if ($pid) {
                    $rp = floatval(get_field('price_standard', $pid));
                    if ($rp > 0) $ft_total_retail += $rp * $it['qty'];
                }
            }
        }
    }
    $ft_total_discount = $ft_total_retail > 0 ? $ft_total_retail - $total : 0;
    if ($ft_total_discount < 0) $ft_total_discount = 0;

    $footerData = array(
        'total_qty'=>$totalQty, 'subtotal'=>$subtotal, 'total'=>$total,
        'total_retail'=>$ft_total_retail, 'total_discount'=>$ft_total_discount,
        'due_str'=>$due_str, 'term'=>$term, 'note'=>$note,
        'customer_note'=>$customer_note, // V.9
    );
    $_inv_date_raw = get_post_meta($ticket_id, '_inv_date', true) ?: get_the_date('Y-m-d', $ticket_id);
    $_inv_date_ts = strtotime($_inv_date_raw);
    $_inv_date_fmt = ($_inv_date_ts && $_inv_date_ts > 86400) ? b2b_date('d/m/Y', $_inv_date_ts) : b2b_date('d/m/Y');
    $custData = array(
        'dist_name'=>$dist_name, 'dist_addr'=>$dist_addr,
        'date'=>$_inv_date_fmt, 'inv_no'=>$inv_no,
        'dist_rank'=>$dist_rank, // V.9
    );

    $urls = array();
    foreach ($pages as $pi => $pageItems) {
        $W = B2B_INV_W; $H = B2B_INV_H;
        $img = imagecreatetruecolor($W, $H);
        imagealphablending($img, true);
        $colors = b2b_inv_colors($img);
        imagefill($img, 0, 0, $colors['white']);

        $y = b2b_inv_draw_header($img, $font, $fontB, $colors, $pi+1, $totalPages, $inv_no, $doc_type);

        if ($pi === 0) {
            $y = b2b_inv_draw_customer($img, $y, $font, $fontB, $colors, $custData);
        } else {
            $y += 20;
            imagettftext($img, 11, 0, B2B_INV_MX, $y, $colors['gray'], $font, $inv_no.' — ต่อจากหน้า '.($pi));
            $y += 20;
        }

        $y = b2b_inv_draw_table_header($img, $y, $font, $fontB, $colors);
        $tblTop = $y;

        foreach ($pageItems as $ri) {
            $rh = b2b_inv_draw_row($img, $y, $ri['orig_idx']+1, $ri['item'], $font, $fontB, $colors, $maxNameW);
            $y += $rh;
            // V.36: Draw SET children rows
            if (!empty($ri['item']['children']) && is_array($ri['item']['children'])) {
                $childBg = imagecolorallocate($img, 240, 249, 255);
                $childColor = imagecolorallocate($img, 3, 105, 161);
                $mx = B2B_INV_MX; $rgt = $W - $mx;
                foreach ($ri['item']['children'] as $child) {
                    $chH = 28;
                    imagefilledrectangle($img, $mx, $y, $rgt, $y + $chH, $childBg);
                    imageline($img, $mx, $y + $chH, $rgt, $y + $chH, $colors['vlgray']);
                    $cname = is_array($child) ? ($child['name'] ?? $child['sku'] ?? '') : $child;
                    $csku = is_array($child) ? ($child['sku'] ?? '') : $child;
                    imagettftext($img, 8, 0, $mx + 42, $y + 18, $childColor, $font, $csku);
                    imagettftext($img, 9, 0, $mx + 172, $y + 18, $childColor, $font, '↳ ' . $cname);
                    $y += $chH;
                }
            }
        }

        imageline($img, B2B_INV_MX, $tblTop, B2B_INV_MX, $y, $colors['vlgray']);
        imageline($img, $W-B2B_INV_MX, $tblTop, $W-B2B_INV_MX, $y, $colors['vlgray']);

        if ($pi === $totalPages - 1) {
            b2b_inv_draw_footer_section($img, $y, $font, $fontB, $colors, $footerData);
            b2b_inv_draw_signatures($img, $font, $fontB, $colors);
        } else {
            imagettftext($img, 11, 0, B2B_INV_MX, $y+30, $colors['gray'], $font, '--- ต่อหน้าถัดไป ---');
            $fy = $H - 45;
            imageline($img, B2B_INV_MX, $fy, $W-B2B_INV_MX, $fy, $colors['vlgray']);
            $co = defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO THAILAND';
            imagettftext($img, 9, 0, B2B_INV_MX, $fy+22, $colors['lgray'], $font, $co.' • หน้า '.($pi+1).'/'.$totalPages);
        }

        $fname = 'inv-'.$ticket_id.'-'.($pi+1).'-'.time().'.png';
        $fpath = $dir.'/'.$fname;
        imagepng($img, $fpath, 6);
        imagedestroy($img);
        $urls[] = $upload['baseurl'].'/b2b-invoices/'.$fname;
        b2b_log('[InvImg] Page '.($pi+1).': '.$fname.' ('.round(filesize($fpath)/1024).'KB)');
    }

    return $urls;
}

// Backward compat
function b2b_generate_invoice_image( $ticket_id ) {
    $urls = b2b_generate_invoice_pages($ticket_id);
    return $urls ? $urls[0] : false;
}

// ════════════════════════════════════════════
// PUSH: Send invoice pages via LINE
// ════════════════════════════════════════════
function b2b_send_invoice_image( $group_id, $ticket_id ) {
    if (!$group_id || !$ticket_id) return false;
    $urls = b2b_generate_invoice_pages($ticket_id);
    if (!$urls) return false;
    $msgs = array();
    foreach ($urls as $url) {
        $url = str_replace('http://','https://',$url);
        $msgs[] = array('type'=>'image','originalContentUrl'=>$url,'previewImageUrl'=>$url);
    }
    $results = array();
    foreach (array_chunk($msgs, 5) as $batch) {
        $results[] = b2b_line_push_raw($group_id, $batch);
    }
    b2b_log('[InvImg] Pushed '.count($urls).' pages to '.$group_id);
    return $results;
}

// ════════════════════════════════════════════════════
// V.22.0: COMBINED INVOICE — multiple tickets in one
// ════════════════════════════════════════════════════
function b2b_generate_combined_invoice_pages( $ticket_ids ) {
    if (!function_exists('imagecreatetruecolor') || !function_exists('imagettftext')) {
        b2b_log('[InvImg] GD/FreeType not available'); return false;
    }
    $font = b2b_inv_get_font(false); $fontB = b2b_inv_get_font(true);
    if (!$font) return false;
    if (!$fontB) $fontB = $font;

    $upload = wp_upload_dir();
    $dir = $upload['basedir'].'/b2b-invoices';
    if (!file_exists($dir)) wp_mkdir_p($dir);

    // Delete old combined files for this set
    $ids_slug = implode('-', $ticket_ids);
    $old_files = glob($dir.'/inv-combined-'.$ids_slug.'-*.png');
    if (!empty($old_files)) array_map('unlink', $old_files);

    // ── Gather data from all tickets ──
    $first_tid = $ticket_ids[0];
    $gid = get_field('source_group_id', $first_tid) ?: '';
    $dist = $gid ? b2b_get_dist_by_group($gid) : null;
    $dist_name = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : 'Customer';
    $dist_addr = '';
    if ($dist) {
        $parts = array_filter(array(
            get_field('dist_address', $dist->ID),
            get_field('dist_district', $dist->ID),
            get_field('dist_province', $dist->ID),
            get_field('dist_postcode', $dist->ID),
        ));
        $dist_addr = implode(' ', $parts);
    }
    $dist_rank = $dist ? (get_field('rank_system', $dist->ID) ?: 'standard') : 'standard';
    $term_fallback = $dist ? (intval(get_field('credit_term_days', $dist->ID)) ?: 30) : 30;

    // ── Merge items from all tickets, with section dividers ──
    $all_items = array();
    $combined_total = 0;
    $earliest_due = '';
    foreach ($ticket_ids as $tid) {
        $tid = intval($tid);
        $items_raw = get_field('order_items', $tid) ?: '';
        $ticket_total = floatval(get_field('total_amount', $tid));
        $due_date = get_field('due_date', $tid) ?: '';
        $combined_total += $ticket_total;

        if (!empty($due_date)) {
            $dd = DateTime::createFromFormat('d/m/Y', $due_date) ?: DateTime::createFromFormat('Y-m-d', $due_date);
            $ed = !empty($earliest_due) ? (DateTime::createFromFormat('d/m/Y', $earliest_due) ?: DateTime::createFromFormat('Y-m-d', $earliest_due)) : null;
            if (empty($earliest_due) || ($dd && $ed && $dd->getTimestamp() < $ed->getTimestamp())) {
                $earliest_due = $due_date;
            }
        }

        $ticket_items = b2b_inv_parse_items($items_raw, $ticket_total, $dist_rank);

        // Add section divider
        $all_items[] = array(
            'sku' => '', 'name' => '── Ticket #'.$tid.' ──',
            'qty' => 0, 'unit_price' => 0, 'discount' => '', 'total' => 0,
            '_divider' => true, '_ticket_id' => $tid, '_ticket_total' => $ticket_total,
        );

        foreach ($ticket_items as $item) {
            $all_items[] = $item;
        }
    }

    $inv_no = 'INV-COMBINED-' . implode('+', $ticket_ids);
    $due_str = !empty($earliest_due) ? (function_exists('b2b_parse_date') ? b2b_parse_date($earliest_due) : $earliest_due) : '-';
    // คำนวณจำนวนวันจริงจากวันที่บิล → วันครบกำหนด
    $_dc = !empty($earliest_due) ? (DateTime::createFromFormat('d/m/Y', $earliest_due) ?: DateTime::createFromFormat('Y-m-d', $earliest_due)) : null;
    $due_ts_c = $_dc ? $_dc->getTimestamp() : false;
    $inv_ts_c = strtotime(get_post_meta($first_tid, '_inv_date', true) ?: get_the_date('Y-m-d', $first_tid));
    if ($due_ts_c && $due_ts_c > 86400 && $inv_ts_c && $inv_ts_c > 86400) {
        $term = intval(round(($due_ts_c - $inv_ts_c) / 86400));
    } else {
        $term = $term_fallback;
    }

    $maxNameW = 380;
    $pageH = B2B_INV_H;
    $footerReserve = 250 + 200 + 60;
    $p1_available  = $pageH - 135 - 120 - 56 - $footerReserve;
    $pN_available  = $pageH - 135 - 56 - $footerReserve;

    $rowHeights = array();
    foreach ($all_items as $it) {
        if (!empty($it['_divider'])) {
            $rowHeights[] = 36; // Section divider row height
        } else {
            $nl = b2b_inv_wrap($it['name'], $maxNameW, 11, $font);
            $sl = !empty($it['sku']) ? b2b_inv_wrap($it['sku'], 120, 9, $font) : array();
            $textH = max(count($nl), count($sl)) * 18;
            $rowHeights[] = max(44, $textH + 16);
        }
    }

    // Paginate
    $pages = array(); $curItems = array(); $curH = 0; $pageIdx = 0;
    foreach ($all_items as $i => $item) {
        $rh = $rowHeights[$i];
        $avail = ($pageIdx === 0) ? $p1_available : $pN_available;
        if ($curH + $rh > $avail && !empty($curItems)) {
            $pages[] = $curItems; $curItems = array(); $curH = 0; $pageIdx++;
        }
        $curItems[] = array('item'=>$item, 'height'=>$rh, 'orig_idx'=>$i);
        $curH += $rh;
    }
    if (!empty($curItems)) $pages[] = $curItems;
    if (empty($pages)) $pages[] = array();

    $totalPages = count($pages);
    $totalQty = 0; $subtotal = 0;
    foreach ($all_items as $it) {
        if (empty($it['_divider'])) {
            $totalQty += intval($it['qty']);
            $subtotal += floatval($it['total']);
        }
    }
    if ($subtotal <= 0) $subtotal = $combined_total;

    $ft_total_retail = 0;
    $ft_total_discount = 0;
    foreach ($all_items as $ai) {
        if (empty($ai['_divider'])) {
            $ft_total_retail += floatval($ai['retail'] ?? $ai['unit_price'] ?? 0) * intval($ai['qty'] ?? 1);
        }
    }
    $ft_total_discount = $ft_total_retail - $combined_total;
    if ($ft_total_discount < 0) $ft_total_discount = 0;

    $footerData = array(
        'total_qty'=>$totalQty, 'subtotal'=>$subtotal, 'total'=>$combined_total,
        'total_retail'=>$ft_total_retail, 'total_discount'=>$ft_total_discount,
        'due_str'=>$due_str, 'term'=>$term, 'note'=>'รวมจ่าย '.count($ticket_ids).' บิล: #'.implode(', #', $ticket_ids),
        'customer_note'=>'',
    );
    $_inv_date_raw = get_post_meta($first_tid, '_inv_date', true) ?: get_the_date('Y-m-d', $first_tid);
    $_inv_date_ts = strtotime($_inv_date_raw);
    $_inv_date_fmt = ($_inv_date_ts && $_inv_date_ts > 86400) ? b2b_date('d/m/Y', $_inv_date_ts) : b2b_date('d/m/Y');
    $custData = array(
        'dist_name'=>$dist_name, 'dist_addr'=>$dist_addr,
        'date'=>$_inv_date_fmt, 'inv_no'=>$inv_no,
        'dist_rank'=>$dist_rank,
    );

    $urls = array();
    $idx_counter = 0;
    foreach ($pages as $pi => $pageItems) {
        $W = B2B_INV_W; $H = B2B_INV_H;
        $img = imagecreatetruecolor($W, $H);
        imagealphablending($img, true);
        $colors = b2b_inv_colors($img);
        imagefill($img, 0, 0, $colors['white']);

        $y = b2b_inv_draw_header($img, $font, $fontB, $colors, $pi+1, $totalPages, $inv_no, 'invoice');

        if ($pi === 0) {
            $y = b2b_inv_draw_customer($img, $y, $font, $fontB, $colors, $custData);
        } else {
            $y += 20;
            imagettftext($img, 11, 0, B2B_INV_MX, $y, $colors['gray'], $font, $inv_no.' — ต่อจากหน้า '.($pi));
            $y += 20;
        }

        $y = b2b_inv_draw_table_header($img, $y, $font, $fontB, $colors);
        $tblTop = $y;

        foreach ($pageItems as $ri) {
            $item = $ri['item'];
            if (!empty($item['_divider'])) {
                // Draw section divider row
                $mx = B2B_INV_MX;
                $rgt = $W - $mx;
                imagefilledrectangle($img, $mx, $y, $rgt, $y + 32, $colors['vlgray']);
                $label = $item['name'];
                if ($item['_ticket_total'] > 0) {
                    $label .= '  ฿'.number_format($item['_ticket_total'], 2);
                }
                imagettftext($img, 10, 0, $mx + 12, $y + 22, $colors['gray'], $fontB, $label);
                $y += 36;
            } else {
                $idx_counter++;
                $rh = b2b_inv_draw_row($img, $y, $idx_counter, $item, $font, $fontB, $colors, $maxNameW);
                $y += $rh;
            }
        }

        imageline($img, B2B_INV_MX, $tblTop, B2B_INV_MX, $y, $colors['vlgray']);
        imageline($img, $W-B2B_INV_MX, $tblTop, $W-B2B_INV_MX, $y, $colors['vlgray']);

        if ($pi === $totalPages - 1) {
            b2b_inv_draw_footer_section($img, $y, $font, $fontB, $colors, $footerData);
            b2b_inv_draw_signatures($img, $font, $fontB, $colors);
        } else {
            imagettftext($img, 11, 0, B2B_INV_MX, $y+30, $colors['gray'], $font, '--- ต่อหน้าถัดไป ---');
            $fy = $H - 45;
            imageline($img, B2B_INV_MX, $fy, $W-B2B_INV_MX, $fy, $colors['vlgray']);
            $co = defined('B2B_COMPANY_NAME') ? B2B_COMPANY_NAME : 'DINOCO THAILAND';
            imagettftext($img, 9, 0, B2B_INV_MX, $fy+22, $colors['lgray'], $font, $co.' • หน้า '.($pi+1).'/'.$totalPages);
        }

        $fname = 'inv-combined-'.$ids_slug.'-'.($pi+1).'-'.time().'.png';
        $fpath = $dir.'/'.$fname;
        imagepng($img, $fpath, 6);
        imagedestroy($img);
        $urls[] = $upload['baseurl'].'/b2b-invoices/'.$fname;
        b2b_log('[InvImg] Combined page '.($pi+1).': '.$fname);
    }

    return $urls;
}

