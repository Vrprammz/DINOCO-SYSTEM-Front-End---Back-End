if ( ! function_exists( 'dinoco_github_sync_status' ) ) {
    function dinoco_github_sync_status() {
        global $wpdb;
        $table = $wpdb->prefix . 'snippets';

        $rows = $wpdb->get_results(
            "SELECT id, name, active, modified, revision, SUBSTRING(code, 1, 800) AS code_head FROM {$table} WHERE active = 1 AND (name LIKE '[Admin System]%' OR name LIKE '[System]%' OR name LIKE '[AdminSystem-System]%' OR name LIKE '[B2B]%') ORDER BY name"
        );

        $snippets = array();
        foreach ( $rows as $r ) {
            $php_ver = '';
            if ( ! empty( $r->code_head ) && preg_match( '/Version:\s*(V?\.?[\d]+[\d.]*(?:\s*\(.*?\))?)/', $r->code_head, $vm ) ) {
                $php_ver = trim( $vm[1] );
            }
            $snippets[] = array(
                'id'       => $r->id,
                'name'     => dinoco_normalize_snippet_name( $r->name ),
                'raw_name' => $r->name,
                'version'  => $php_ver,
                'modified' => $r->modified,
                'revision' => $r->revision,
            );
        }

        return new WP_REST_Response( array(
            'last_sync' => get_option( 'dinoco_last_sync_result', null ),
            'snippets'  => $snippets,
        ), 200 );
    }
}

