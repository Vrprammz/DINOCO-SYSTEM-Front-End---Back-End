<script>
function sdDoSync(){
    var btn=document.getElementById('sd-sync-btn'),msg=document.getElementById('sd-msg');
    btn.disabled=true;btn.innerHTML='<span class="sd-spin"></span> Syncing...';
    msg.className='sd-msg';msg.style.display='none';
    fetch('<?php echo esc_js( $rest ); ?>github-sync-manual',{
        method:'POST',
        headers:{'X-WP-Nonce':'<?php echo esc_js( $nonce ); ?>','Content-Type':'application/json'},
        credentials:'same-origin'
    })
    .then(function(r){return r.json().then(function(d){return{ok:r.ok,data:d}})})
    .then(function(res){
        btn.disabled=false;btn.textContent='Sync Now';
        if(res.ok&&res.data.ok){
            msg.className='sd-msg ok';msg.textContent='Sync complete! Updated: '+(res.data.updated||[]).length+' snippet(s)'+(res.data.errors&&res.data.errors.length?' | Errors: '+res.data.errors.length:'');
        }else{
            msg.className='sd-msg err';msg.textContent='Sync failed: '+(res.data.error||res.data.message||'Unknown error');
        }
        msg.style.display='block';
        setTimeout(function(){location.reload()},2000);
    })
    .catch(function(e){
        btn.disabled=false;btn.textContent='Sync Now';
        msg.className='sd-msg err';msg.textContent='Network error: '+e.message;msg.style.display='block';
    });
}
</script>
