        // Show commit message if available
        $commit_msg = ! empty( $last['commit_message'] ) ? $last['commit_message'] : '';
        if ( $commit_msg ) {
            $lines[] = "\nCommit Message:";
            $lines[] = '  ' . esc_html( mb_substr( $commit_msg, 0, 200 ) );
        }
        if ( $synced ) {
            $lines[] = "\nFiles Synced (" . count( $synced ) . '):';
            foreach ( $synced as $i => $f ) $lines[] = '  ' . ( $i + 1 ) . '. ' . esc_html( $f );
        }
        if ( $updated ) {
            $lines[] = "\nUpdated (" . count( $updated ) . '):';
            foreach ( $updated as $i => $u ) {
                // Extract version from DB for this snippet
                $u_name = preg_replace( '/\s*\(db:.*\)/', '', $u );
                $u_ver = '';
                foreach ( $rows as $_r ) {
                    if ( dinoco_normalize_snippet_name( $_r->name ) === $u_name && ! empty( $_r->code_head ) ) {
                        if ( preg_match( '/Version:\s*(V?\.?[\d]+[\d.]*(?:\s*[—\-]+\s*[^\n]{0,60})?)/u', $_r->code_head, $_vm ) ) {
                            $u_ver = ' → ' . trim( $_vm[1] );
                        }
                        break;
                    }
                }
                $lines[] = '  ' . ( $i + 1 ) . '. ' . esc_html( $u_name ) . esc_html( $u_ver );
            }
        }
        if ( $errors ) {
            $lines[] = "\nErrors (" . count( $errors ) . '):';
            foreach ( $errors as $i => $e ) $lines[] = '  ' . ( $i + 1 ) . '. ' . esc_html( $e );
        }
        echo implode( "\n", $lines );
