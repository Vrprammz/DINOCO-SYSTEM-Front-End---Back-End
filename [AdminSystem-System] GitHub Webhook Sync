/**
 * ╔══════════════════════════════════════════════════════════════╗
 * ║  [AdminSystem-System] GitHub Webhook Sync                    ║
 * ║  Version: V.34.1 — Always-on live polling + realtime sync       ║
 * ║  DB_ID: 265                                                  ║
 * ╠══════════════════════════════════════════════════════════════╣
 * ║  Push to GitHub -> Webhook -> WordPress REST API             ║
 * ║  -> อัพเดท code ใน wp_snippets table อัตโนมัติ                ║
 * ╠══════════════════════════════════════════════════════════════╣
 * ║  Required constants in wp-config.php:                        ║
 * ║    DINOCO_GITHUB_WEBHOOK_SECRET  — HMAC shared secret        ║
 * ║    DINOCO_GITHUB_TOKEN           — GitHub PAT                ║
 * ║    DINOCO_GITHUB_REPO            — owner/repo                ║
 * ╚══════════════════════════════════════════════════════════════╝
 */

// ════════════════════════════════════════════════════════════════
// 1. HELPERS
// ════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_normalize_snippet_name' ) ) {
    /** Normalize DB snippet name -> comparable string */
    function dinoco_normalize_snippet_name( $name ) {
        $name = html_entity_decode( $name, ENT_QUOTES | ENT_HTML5, 'UTF-8' );
        $name = preg_replace( '/[\x{200b}\x{200c}\x{200d}\x{feff}]/u', '', $name );
        $name = str_replace( array( "\u{2014}", "\u{2013}", "\u{2212}" ), '-', $name );
        $name = preg_replace( '/\s+/', ' ', $name );
        $name = preg_replace( '/\s*:\s*/', ': ', $name );
        return trim( $name );
    }
}

if ( ! function_exists( 'dinoco_sync_log' ) ) {
    function dinoco_sync_log( $message ) {
        if ( defined( 'WP_DEBUG' ) && WP_DEBUG ) {
            error_log( '[DINOCO-Sync] ' . $message );
        }
    }
}

if ( ! function_exists( 'dinoco_extract_db_id' ) ) {
    /** Parse DB_ID: NNN จาก code header (1000 chars แรก) */
    function dinoco_extract_db_id( $code ) {
        $head = substr( $code, 0, 1000 );
        if ( preg_match( '/\*?\s*DB_ID:\s*(\d+)/i', $head, $m ) ) {
            return intval( $m[1] );
        }
        return 0;
    }
}

if ( ! function_exists( 'dinoco_sync_acquire_lock' ) ) {
    /** ลอง acquire lock — return true ถ้าได้, false ถ้า lock อยู่ */
    function dinoco_sync_acquire_lock( $trigger ) {
        $lock = get_transient( 'dinoco_sync_running' );
        if ( $lock ) {
            // Auto-clear ถ้าค้างเกิน 2 นาที
            $job = get_option( 'dinoco_sync_job', array() );
            $started = ! empty( $job['started_at'] ) ? strtotime( $job['started_at'] ) : 0;
            if ( $started && ( time() - $started ) > 120 ) {
                dinoco_sync_log( 'Auto-clearing stale lock (age=' . ( time() - $started ) . 's)' );
                delete_transient( 'dinoco_sync_running' );
            } else {
                return false;
            }
        }
        set_transient( 'dinoco_sync_running', $trigger, 120 );
        return true;
    }
}

if ( ! function_exists( 'dinoco_sync_release_lock' ) ) {
    function dinoco_sync_release_lock() {
        delete_transient( 'dinoco_sync_running' );
    }
}

// ════════════════════════════════════════════════════════════════
// 2. SNIPPET UPDATE — hash compare + write + verify
// ════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_sync_update_snippet' ) ) {
    function dinoco_sync_update_snippet( $row, $code, $file_name ) {
        global $wpdb;
        $table    = $wpdb->prefix . 'snippets';
        $new_hash = md5( $code );

        // Hash compare — skip ถ้าเหมือนกัน
        $cur_hash = $wpdb->get_var( $wpdb->prepare(
            "SELECT md5(code) FROM {$table} WHERE id = %d", $row->id
        ) );
        if ( $cur_hash === $new_hash ) {
            return array( 'ok' => true, 'status' => 'already_current', 'hash' => substr( $new_hash, 0, 8 ) );
        }

        // Write
        $new_rev = intval( $row->revision ) + 1;
        $result  = $wpdb->update(
            $table,
            array( 'code' => $code, 'modified' => current_time( 'mysql' ), 'revision' => $new_rev ),
            array( 'id' => $row->id ),
            array( '%s', '%s', '%d' ),
            array( '%d' )
        );
        if ( $result === false ) {
            $err = $wpdb->last_error;
            dinoco_sync_log( 'DB UPDATE FAILED: ' . $file_name . ' id=' . $row->id . ': ' . $err );
            return array( 'ok' => false, 'status' => 'failed', 'error' => 'db_error: ' . $err );
        }

        // Cache bust
        wp_cache_delete( 'alloptions', 'options' );
        delete_transient( 'code_snippets' );
        delete_transient( 'code_snippets_active' );
        delete_transient( 'all_snippets' );
        wp_cache_delete( $row->id, 'code_snippets' );
        wp_cache_delete( 'all_snippets', 'code_snippets' );

        // OPcache invalidation
        if ( function_exists( 'opcache_invalidate' ) ) {
            $f = WP_CONTENT_DIR . '/db/snippets/' . $row->id . '.php';
            if ( file_exists( $f ) ) { @opcache_invalidate( $f, true ); }
        }

        // Post-verify
        $verify = $wpdb->get_var( $wpdb->prepare(
            "SELECT md5(code) FROM {$table} WHERE id = %d", $row->id
        ) );
        if ( $verify !== $new_hash ) {
            dinoco_sync_log( 'VERIFY MISMATCH: ' . $file_name . ' expected=' . substr( $new_hash, 0, 8 ) . ' got=' . substr( $verify ?: 'null', 0, 8 ) );
            return array( 'ok' => false, 'status' => 'verify_failed', 'error' => 'hash_mismatch', 'hash' => substr( $verify ?: '', 0, 8 ) );
        }

        dinoco_sync_log( 'OK: ' . $file_name . ' id=' . $row->id . ' rev=' . $new_rev . ' hash=' . substr( $new_hash, 0, 8 ) );
        return array( 'ok' => true, 'status' => 'synced', 'hash' => substr( $new_hash, 0, 8 ), 'rev' => $new_rev );
    }
}

// ════════════════════════════════════════════════════════════════
// 3. FETCH CODE FROM GITHUB — Contents API primary, raw fallback
// ════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_fetch_github_file' ) ) {
    /**
     * ดึง file content จาก GitHub
     * @return string|WP_Error
     */
    function dinoco_fetch_github_file( $repo, $file_path, $ref, $token ) {
        // Primary: Contents API
        $url = sprintf(
            'https://api.github.com/repos/%s/contents/%s?ref=%s',
            $repo, rawurlencode( $file_path ), rawurlencode( $ref )
        );
        $resp = wp_remote_get( $url, array(
            'headers' => array(
                'Accept'        => 'application/vnd.github.v3.raw',
                'Authorization' => 'Bearer ' . $token,
                'User-Agent'    => 'DINOCO-Sync/34.0',
                'If-None-Match' => '',
            ),
            'timeout' => 30,
        ) );

        if ( ! is_wp_error( $resp ) && wp_remote_retrieve_response_code( $resp ) === 200 ) {
            return wp_remote_retrieve_body( $resp );
        }

        // Fallback: raw.githubusercontent.com
        $raw_url = sprintf(
            'https://raw.githubusercontent.com/%s/%s/%s',
            $repo, rawurlencode( $ref ), rawurlencode( $file_path )
        );
        $resp2 = wp_remote_get( $raw_url, array(
            'headers' => array(
                'Authorization' => 'token ' . $token,
                'User-Agent'    => 'DINOCO-Sync/34.0',
            ),
            'timeout' => 30,
        ) );

        if ( ! is_wp_error( $resp2 ) && wp_remote_retrieve_response_code( $resp2 ) === 200 ) {
            return wp_remote_retrieve_body( $resp2 );
        }

        $err = is_wp_error( $resp2 ) ? $resp2->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $resp2 );
        return new WP_Error( 'fetch_failed', $err );
    }
}

// ════════════════════════════════════════════════════════════════
// 4. CORE SYNC ENGINE — single-pass, ทำทุก snippet รวดเดียว
// ════════════════════════════════════════════════════════════════

if ( ! function_exists( 'dinoco_do_full_sync' ) ) {
    function dinoco_do_full_sync( $repo, $commit_sha, $trigger, $commit_message = '' ) {
        @set_time_limit( 300 );
        ignore_user_abort( true );

        if ( ! dinoco_sync_acquire_lock( $trigger ) ) {
            dinoco_sync_log( 'Sync skipped: lock active (trigger=' . $trigger . ')' );
            return;
        }

        $token = defined( 'DINOCO_GITHUB_TOKEN' ) ? DINOCO_GITHUB_TOKEN : '';
        if ( empty( $token ) ) {
            dinoco_sync_release_lock();
            dinoco_sync_log( 'Sync aborted: DINOCO_GITHUB_TOKEN not set' );
            return;
        }

        $start_time = current_time( 'mysql' );

        try {
            global $wpdb;
            $table = $wpdb->prefix . 'snippets';

            // Load active snippets from DB
            // V.34.3: filter เฉพาะ prefix ระบบ DINOCO (ไม่รวม [Speed], [Security] ที่ไม่มีใน GitHub)
            $db_rows = $wpdb->get_results(
                "SELECT id, name, active, revision FROM {$table}
                 WHERE active = 1
                 AND (name LIKE '[System]%' OR name LIKE '[Admin System]%' OR name LIKE '[AdminSystem-System]%'
                      OR name LIKE '[B2B]%' OR name LIKE '[B2F]%' OR name LIKE '[GitHub]%')
                 ORDER BY id ASC"
            );

            $db_by_name = array();
            $db_by_id   = array();
            foreach ( $db_rows as $r ) {
                $norm = dinoco_normalize_snippet_name( $r->name );
                if ( ! isset( $db_by_name[ $norm ] ) ) { $db_by_name[ $norm ] = $r; }
                $db_by_id[ intval( $r->id ) ] = $r;
            }

            // Fetch repo file list จาก Git Tree API (ใช้ commit SHA)
            $tree_url  = sprintf( 'https://api.github.com/repos/%s/git/trees/%s', $repo, rawurlencode( $commit_sha ) );
            $tree_resp = wp_remote_get( $tree_url, array(
                'headers' => array(
                    'Authorization' => 'Bearer ' . $token,
                    'User-Agent'    => 'DINOCO-Sync/34.0',
                    'If-None-Match' => '',
                ),
                'timeout' => 15,
            ) );

            $repo_files = array(); // normalized -> raw path
            if ( ! is_wp_error( $tree_resp ) && wp_remote_retrieve_response_code( $tree_resp ) === 200 ) {
                $tree = json_decode( wp_remote_retrieve_body( $tree_resp ), true );
                foreach ( ( $tree['tree'] ?? array() ) as $item ) {
                    if ( $item['type'] === 'blob' && preg_match( '/^\[/', $item['path'] ) ) {
                        $repo_files[ dinoco_normalize_snippet_name( $item['path'] ) ] = $item['path'];
                    }
                }
            }

            // Build sync list: ทุก snippet ใน DB
            $total      = count( $db_rows );
            $updated    = array();
            $skipped    = array();
            $errors     = array();
            $details    = array();

            // Save initial job state (สำหรับ progress polling)
            update_option( 'dinoco_sync_job', array(
                'status'         => 'syncing',
                'total'          => $total,
                'offset'         => 0,
                'started_at'     => $start_time,
                'trigger'        => $trigger,
                'commit_sha'     => $commit_sha,
                'commit_message' => $commit_message,
                'current_file'   => '',
            ), false );

            $idx = 0;
            foreach ( $db_by_name as $norm_name => $row ) {
                $idx++;
                $actual_file = isset( $repo_files[ $norm_name ] ) ? $repo_files[ $norm_name ] : $norm_name;

                // Update progress
                update_option( 'dinoco_sync_job', array(
                    'status'         => 'syncing',
                    'total'          => $total,
                    'offset'         => $idx,
                    'started_at'     => $start_time,
                    'trigger'        => $trigger,
                    'commit_sha'     => $commit_sha,
                    'commit_message' => $commit_message,
                    'current_file'   => $norm_name,
                ), false );

                // Fetch code
                $code = dinoco_fetch_github_file( $repo, $actual_file, $commit_sha, $token );
                if ( is_wp_error( $code ) ) {
                    $err_msg = $code->get_error_message();
                    $errors[]              = $norm_name . ': ' . $err_msg;
                    $details[ $norm_name ] = array( 'status' => 'failed', 'error' => 'fetch: ' . $err_msg );
                    continue;
                }

                // DB_ID matching (primary) with name fallback
                $code_db_id  = dinoco_extract_db_id( $code );
                $target_row  = $row; // default: matched by name
                if ( $code_db_id > 0 && isset( $db_by_id[ $code_db_id ] ) ) {
                    $target_row = $db_by_id[ $code_db_id ];
                    if ( $code_db_id !== intval( $row->id ) ) {
                        dinoco_sync_log( 'DB_ID override: file=' . $norm_name . ' code_db_id=' . $code_db_id . ' (was id=' . $row->id . ')' );
                    }
                }

                // Update snippet
                $result = dinoco_sync_update_snippet( $target_row, $code, $norm_name );
                $detail = array(
                    'status' => $result['status'],
                    'hash'   => $result['hash'] ?? '',
                    'rev'    => $result['rev'] ?? $target_row->revision,
                    'db_id'  => intval( $target_row->id ),
                );
                if ( ! $result['ok'] ) {
                    $detail['error'] = $result['error'] ?? $result['status'];
                    $errors[] = $norm_name . ': ' . ( $result['error'] ?? $result['status'] );
                } elseif ( $result['status'] === 'already_current' ) {
                    $skipped[] = $norm_name;
                } else {
                    $updated[] = $norm_name;
                }
                $details[ $norm_name ] = $detail;
            }

            // Global cache flush
            wp_cache_flush();
            if ( function_exists( 'opcache_reset' ) ) { @opcache_reset(); }
            if ( function_exists( 'wpfc_clear_all_cache' ) ) { wpfc_clear_all_cache( true ); }

            $completed_at = current_time( 'mysql' );
            $dur = strtotime( $completed_at ) - strtotime( $start_time );

            // Save final result
            $final = array(
                'time'            => $completed_at,
                'trigger'         => $trigger,
                'commit_sha'      => $commit_sha,
                'commit_message'  => mb_substr( $commit_message, 0, 200 ),
                'status'          => 'completed',
                'total'           => $total,
                'updated'         => $updated,
                'skipped'         => $skipped,
                'errors'          => $errors,
                'snippet_details' => $details,
                'started_at'      => $start_time,
                'completed_at'    => $completed_at,
                'duration'        => $dur,
            );
            update_option( 'dinoco_last_sync_result', $final, false );
            update_option( 'dinoco_sync_job', array_merge( $final, array( 'offset' => $total ) ), false );
            update_option( 'dinoco_last_processed_commit', $commit_sha, false );

            dinoco_sync_log( 'DONE (' . $trigger . '): ' . count( $updated ) . ' synced, ' . count( $skipped ) . ' same, ' . count( $errors ) . ' errors in ' . $dur . 's' );

        } catch ( \Throwable $e ) {
            dinoco_sync_log( 'FATAL: ' . $e->getMessage() );
            update_option( 'dinoco_last_sync_result', array(
                'time'    => current_time( 'mysql' ),
                'trigger' => $trigger,
                'status'  => 'fatal_error',
                'errors'  => array( $e->getMessage() ),
            ), false );
        }

        dinoco_sync_release_lock();
    }
}

// ════════════════════════════════════════════════════════════════
// 5. REST: POST /wp-json/dinoco/v1/github-sync (Webhook)
// ════════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {
    register_rest_route( 'dinoco/v1', '/github-sync', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_webhook_handler',
        'permission_callback' => '__return_true',
    ) );
} );

if ( ! function_exists( 'dinoco_webhook_handler' ) ) {
    function dinoco_webhook_handler( WP_REST_Request $req ) {
        // HMAC-SHA256 signature verification
        $secret = defined( 'DINOCO_GITHUB_WEBHOOK_SECRET' ) ? DINOCO_GITHUB_WEBHOOK_SECRET : '';
        if ( empty( $secret ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'webhook_secret_not_configured' ), 500 );
        }

        $sig     = $req->get_header( 'X-Hub-Signature-256' );
        $payload = $req->get_body();
        if ( empty( $sig ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'missing_signature' ), 403 );
        }
        $expected = 'sha256=' . hash_hmac( 'sha256', $payload, $secret );
        if ( ! hash_equals( $expected, $sig ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'invalid_signature' ), 403 );
        }

        // Parse push event
        $data = json_decode( $payload, true );
        if ( empty( $data['commits'] ) || empty( $data['repository'] ) ) {
            return new WP_REST_Response( array( 'ok' => true, 'message' => 'ping_received' ), 200 );
        }

        // Only main branch
        $ref = $data['ref'] ?? '';
        if ( $ref !== 'refs/heads/main' ) {
            return new WP_REST_Response( array( 'ok' => true, 'message' => 'ignored_non_main', 'ref' => $ref ), 200 );
        }

        // Schedule sync in shutdown hook (respond 200 first)
        $GLOBALS['_dinoco_pending_webhook'] = array(
            'repo'       => $data['repository']['full_name'],
            'commit_sha' => $data['after'] ?? '',
            'message'    => $data['head_commit']['message'] ?? '',
        );
        add_action( 'shutdown', 'dinoco_webhook_shutdown', 0 );

        return new WP_REST_Response( array(
            'ok'      => true,
            'message' => 'sync_scheduled',
            'sha'     => substr( $data['after'] ?? '', 0, 7 ),
        ), 200 );
    }
}

if ( ! function_exists( 'dinoco_webhook_shutdown' ) ) {
    function dinoco_webhook_shutdown() {
        if ( empty( $GLOBALS['_dinoco_pending_webhook'] ) ) return;
        $p = $GLOBALS['_dinoco_pending_webhook'];
        unset( $GLOBALS['_dinoco_pending_webhook'] );

        if ( function_exists( 'fastcgi_finish_request' ) ) {
            fastcgi_finish_request();
        }

        dinoco_do_full_sync( $p['repo'], $p['commit_sha'], 'webhook', $p['message'] );
    }
}

// ════════════════════════════════════════════════════════════════
// 6. REST: POST /wp-json/dinoco/v1/github-sync-manual
// ════════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {
    register_rest_route( 'dinoco/v1', '/github-sync-manual', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_manual_sync_handler',
        'permission_callback' => function () { return current_user_can( 'manage_options' ); },
    ) );
} );

if ( ! function_exists( 'dinoco_manual_sync_handler' ) ) {
    function dinoco_manual_sync_handler( WP_REST_Request $req ) {
        $token = defined( 'DINOCO_GITHUB_TOKEN' ) ? DINOCO_GITHUB_TOKEN : '';
        $repo  = defined( 'DINOCO_GITHUB_REPO' )  ? DINOCO_GITHUB_REPO  : '';
        if ( empty( $token ) || empty( $repo ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'missing DINOCO_GITHUB_TOKEN or DINOCO_GITHUB_REPO' ), 500 );
        }

        $branch = sanitize_text_field( $req->get_param( 'branch' ) ?: 'main' );

        // Resolve commit SHA จาก Git Ref API
        $commit_sha = '';
        $ref_url = sprintf( 'https://api.github.com/repos/%s/git/ref/heads/%s', $repo, rawurlencode( $branch ) );
        $ref_resp = wp_remote_get( $ref_url, array(
            'headers' => array(
                'Authorization' => 'Bearer ' . $token,
                'User-Agent'    => 'DINOCO-Sync/34.0',
                'Accept'        => 'application/vnd.github.v3+json',
                'If-None-Match' => '',
            ),
            'timeout' => 15,
        ) );
        if ( ! is_wp_error( $ref_resp ) && wp_remote_retrieve_response_code( $ref_resp ) === 200 ) {
            $ref_data = json_decode( wp_remote_retrieve_body( $ref_resp ), true );
            $commit_sha = $ref_data['object']['sha'] ?? '';
        }
        if ( empty( $commit_sha ) ) {
            $commit_sha = $branch; // fallback
        }

        // ตรวจว่า webhook sync ไปแล้วหรือยัง
        $last_processed     = get_option( 'dinoco_last_processed_commit', '' );
        $webhook_already    = ( $commit_sha && $last_processed === $commit_sha );

        // Force clear stale lock
        delete_transient( 'dinoco_sync_running' );

        // Run sync (blocking — manual sync รอจบ)
        dinoco_do_full_sync( $repo, $commit_sha, 'manual', '' );

        $result = get_option( 'dinoco_last_sync_result', array() );
        $result['webhook_already_synced'] = $webhook_already;
        update_option( 'dinoco_last_sync_result', $result, false );

        return new WP_REST_Response( array(
            'ok'                    => true,
            'updated'               => $result['updated'] ?? array(),
            'skipped'               => $result['skipped'] ?? array(),
            'errors'                => $result['errors'] ?? array(),
            'total'                 => $result['total'] ?? 0,
            'commit_sha'            => $commit_sha,
            'webhook_already_synced' => $webhook_already,
        ), 200 );
    }
}

// ════════════════════════════════════════════════════════════════
// 7. REST: GET /wp-json/dinoco/v1/sync-status (Progress polling)
// ════════════════════════════════════════════════════════════════

add_action( 'rest_api_init', function () {
    register_rest_route( 'dinoco/v1', '/sync-status', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_sync_status_handler',
        'permission_callback' => function () { return current_user_can( 'manage_options' ); },
    ) );
} );

if ( ! function_exists( 'dinoco_sync_status_handler' ) ) {
    function dinoco_sync_status_handler() {
        $lock = get_transient( 'dinoco_sync_running' );
        $job  = get_option( 'dinoco_sync_job', array() );
        $last = get_option( 'dinoco_last_sync_result', array() );

        $is_syncing = ! empty( $lock ) && ( ! empty( $job['status'] ) && $job['status'] === 'syncing' );

        return new WP_REST_Response( array(
            'is_syncing'   => $is_syncing,
            'progress'     => ( $job['offset'] ?? 0 ) . '/' . ( $job['total'] ?? 0 ),
            'current_file' => $job['current_file'] ?? '',
            'job_status'   => $job['status'] ?? '',
            'last_sync'    => $last,
        ), 200 );
    }
}

// ════════════════════════════════════════════════════════════════
// 8. DASHBOARD SHORTCODE [dinoco_sync_dashboard]
// ════════════════════════════════════════════════════════════════

add_shortcode( 'dinoco_sync_dashboard', 'dinoco_render_sync_dashboard' );

if ( ! function_exists( 'dinoco_render_sync_dashboard' ) ) {
function dinoco_render_sync_dashboard() {
    if ( ! current_user_can( 'manage_options' ) ) {
        return '<div style="padding:60px;text-align:center;color:#ef4444;font-size:18px">ไม่มีสิทธิ์เข้าถึง</div>';
    }

    // Auto-clear stale lock (> 2 min) เมื่อเปิด dashboard
    $lock = get_transient( 'dinoco_sync_running' );
    if ( $lock ) {
        $job = get_option( 'dinoco_sync_job', array() );
        $started = ! empty( $job['started_at'] ) ? strtotime( $job['started_at'] ) : 0;
        if ( $started && ( time() - $started ) > 120 ) {
            delete_transient( 'dinoco_sync_running' );
            $lock = false;
        }
    }

    // Data
    $last  = get_option( 'dinoco_last_sync_result', array() );
    $nonce = wp_create_nonce( 'wp_rest' );
    $rest  = esc_url( rest_url( 'dinoco/v1/' ) );
    $wh_url = esc_url( rest_url( 'dinoco/v1/github-sync' ) );

    $has_secret = defined( 'DINOCO_GITHUB_WEBHOOK_SECRET' ) && DINOCO_GITHUB_WEBHOOK_SECRET !== '';
    $has_token  = defined( 'DINOCO_GITHUB_TOKEN' ) && DINOCO_GITHUB_TOKEN !== '';
    $has_repo   = defined( 'DINOCO_GITHUB_REPO' ) && DINOCO_GITHUB_REPO !== '';
    $repo_val   = $has_repo ? DINOCO_GITHUB_REPO : '';
    $token_mask = $has_token ? substr( DINOCO_GITHUB_TOKEN, 0, 4 ) . '****' : '';

    // Parse last sync
    $trigger    = $last['trigger'] ?? '--';
    $commit_sha = $last['commit_sha'] ?? '';
    $commit_msg = $last['commit_message'] ?? '';
    $updated    = $last['updated'] ?? array();
    $skipped    = $last['skipped'] ?? array();
    $errors_arr = $last['errors'] ?? array();
    $details    = $last['snippet_details'] ?? array();
    $started_at = $last['started_at'] ?? '';
    $completed  = $last['completed_at'] ?? '';
    $duration   = isset( $last['duration'] ) ? $last['duration'] . 's' : '--';
    $webhook_already = ! empty( $last['webhook_already_synced'] );

    // Relative time
    $ago = '--';
    if ( ! empty( $last['time'] ) ) {
        $diff = time() - strtotime( get_gmt_from_date( $last['time'] ) );
        if ( $diff < 60 )        $ago = $diff . ' วินาทีที่แล้ว';
        elseif ( $diff < 3600 )  $ago = floor( $diff / 60 ) . ' นาทีที่แล้ว';
        elseif ( $diff < 86400 ) $ago = floor( $diff / 3600 ) . ' ชั่วโมงที่แล้ว';
        else                     $ago = floor( $diff / 86400 ) . ' วันที่แล้ว';
    }

    // DB snippets
    global $wpdb;
    $table = $wpdb->prefix . 'snippets';
    // V.34.3: ดึงเฉพาะ prefix ที่เป็นระบบ DINOCO (ไม่รวม [Speed], [Security] ที่ไม่มีใน GitHub)
    $rows  = $wpdb->get_results(
        "SELECT id, name, active, modified, revision, md5(code) AS code_hash, SUBSTRING(code, 1, 500) AS code_head
         FROM {$table} WHERE active = 1
         AND (name LIKE '[System]%' OR name LIKE '[Admin System]%' OR name LIKE '[AdminSystem-System]%'
              OR name LIKE '[B2B]%' OR name LIKE '[B2F]%' OR name LIKE '[GitHub]%')
         ORDER BY id ASC"
    );

    // Stats
    $cnt_total  = count( $rows );
    $cnt_synced = count( $updated );
    $cnt_same   = count( $skipped );
    $cnt_error  = count( $errors_arr );

    // Per-snippet status map
    $s_map = array(); // norm_name -> { status, error, hash, rev }
    foreach ( $details as $name => $d ) {
        $s_map[ $name ] = $d;
    }

    // Tab counts
    $tc = array( 'all' => $cnt_total, 'synced' => 0, 'same' => 0, 'error' => 0 );
    foreach ( $rows as $r ) {
        $n  = dinoco_normalize_snippet_name( $r->name );
        $st = $s_map[ $n ]['status'] ?? 'pending';
        if ( $st === 'synced' ) $tc['synced']++;
        elseif ( $st === 'already_current' ) $tc['same']++;
        elseif ( in_array( $st, array( 'failed', 'verify_failed', 'not_found' ), true ) ) $tc['error']++;
    }

    ob_start();
?>
