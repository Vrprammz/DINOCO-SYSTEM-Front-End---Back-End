<script>
(function(){
    // Filter tabs
    window.sdFilter = function(el) {
        var tabs = document.querySelectorAll('#dinoco-sync-dash .sd-tab');
        for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
        el.classList.add('active');
        var filter = el.getAttribute('data-filter');
        var trs = document.querySelectorAll('#sd-tbody tr');
        for (var j = 0; j < trs.length; j++) {
            if (filter === 'all') {
                trs[j].style.display = '';
            } else {
                trs[j].style.display = trs[j].getAttribute('data-filter') === filter ? '' : 'none';
            }
        }
    };

    // V.33.1: Live sync progress polling
    var _pollTimer = null;
    function sdStartPolling() {
        if (_pollTimer) return;
        var prog = document.getElementById('sd-live-progress');
        var stat = document.getElementById('sd-static-sync');
        if (prog) prog.style.display = '';
        if (stat) stat.style.display = 'none';
        _pollTimer = setInterval(function() {
            fetch('<?php echo esc_js( $rest ); ?>sync-status', {
                headers: { 'X-WP-Nonce': '<?php echo esc_js( $nonce ); ?>' },
                credentials: 'same-origin'
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                var bar = document.getElementById('sd-prog-bar');
                var txt = document.getElementById('sd-prog-text');
                var det = document.getElementById('sd-prog-detail');
                if (d.is_syncing) {
                    var parts = (d.progress || '0/38').split('/');
                    var done = parseInt(parts[0]) || 0;
                    var total = parseInt(parts[1]) || 38;
                    var pct = Math.round((done / total) * 100);
                    if (bar) bar.style.width = pct + '%';
                    if (txt) txt.textContent = 'กำลัง Sync... ' + done + '/' + total + ' (' + pct + '%)';
                    if (det) det.textContent = d.job_status === 'syncing' ? 'กำลังดึงโค้ดจาก GitHub และอัพเดท...' : '';
                } else {
                    // Sync finished — reload page to show results
                    clearInterval(_pollTimer);
                    _pollTimer = null;
                    if (bar) bar.style.width = '100%';
                    if (txt) txt.textContent = 'Sync เสร็จแล้ว! กำลังรีเฟรช...';
                    if (det) det.textContent = '';
                    setTimeout(function() { location.reload(); }, 1500);
                }
            })
            .catch(function() {}); // silent fail on poll
        }, 2000);
    }
    // Auto-start polling if page loaded during sync
    <?php if ( $lock ) : ?>
    sdStartPolling();
    <?php endif; ?>

    // Sync button
    window.sdDoSync = function() {
        var btn = document.getElementById('sd-sync-btn');
        var msg = document.getElementById('sd-msg');
        btn.disabled = true;
        btn.innerHTML = '<span class="sd-spin"></span> กำลัง Sync...';
        msg.className = 'sd-msg';
        msg.style.display = 'none';
        fetch('<?php echo esc_js( $rest ); ?>github-sync-manual', {
            method: 'POST',
            headers: { 'X-WP-Nonce': '<?php echo esc_js( $nonce ); ?>', 'Content-Type': 'application/json' },
            credentials: 'same-origin'
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(res) {
            btn.disabled = false;
            btn.textContent = 'Sync Now';
            if (res.ok && res.data.ok) {
                var u = res.data.updated || [];
                var s = res.data.skipped || [];
                var e = res.data.errors || [];
                var t = res.data.total || 0;
                var sha = res.data.commit_sha ? res.data.commit_sha.substring(0, 7) : '';
                var webhookDone = res.data.webhook_already_synced;
                var detail = 'Sync สำเร็จ!' + (sha ? ' (commit: ' + sha + ')' : '') + '\n' + u.length + ' synced, ' + s.length + ' ไม่เปลี่ยน, ' + e.length + ' ผิดพลาด (จาก ' + t + ' snippets)';
                if (u.length === 0 && s.length > 0 && webhookDone) {
                    detail += '\n\nWebhook sync ทำงานแล้วก่อน Manual Sync -- โค้ดตรงกับ GitHub อยู่แล้ว';
                } else if (u.length === 0 && s.length > 0) {
                    detail += '\n\nโค้ดบน WordPress ตรงกับ GitHub ทุกไฟล์ ไม่มีความเปลี่ยนแปลง';
                }
                if (u.length > 0) detail += '\n\nSynced:\n' + u.map(function(n, i) { return '  ' + (i + 1) + '. ' + n; }).join('\n');
                if (e.length > 0) detail += '\n\nErrors (' + e.length + '):\n' + e.map(function(n, i) { return '  ' + (i + 1) + '. ' + n; }).join('\n');
                msg.className = e.length > 0 ? 'sd-msg err' : 'sd-msg ok';
                msg.style.whiteSpace = 'pre-wrap';
                msg.textContent = detail;
            } else {
                msg.className = 'sd-msg err';
                msg.textContent = 'Sync ล้มเหลว: ' + (res.data.error || res.data.message || 'Unknown error');
            }
            msg.style.display = 'block';
            setTimeout(function() { location.reload(); }, 3000);
        })
        .catch(function(e) {
            btn.disabled = false;
            btn.textContent = 'Sync Now';
            msg.className = 'sd-msg err';
            msg.textContent = 'Network error: ' + e.message;
            msg.style.display = 'block';
        });
    };
})();
</script>
