// ══════════════════════════════════════════════════════════════
// HELPER: Normalize DB snippet name → GitHub filename
// ══════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_normalize_snippet_name' ) ) {
    function dinoco_normalize_snippet_name( $name ) {
        $name = html_entity_decode( $name, ENT_QUOTES | ENT_HTML5, 'UTF-8' );
        $name = preg_replace( '/[\x{200b}\x{200c}\x{200d}\x{feff}]/u', '', $name );
        $name = str_replace( array( "\u{2014}", "\u{2013}", "\u{2212}" ), '-', $name );
        $name = preg_replace( '/\s+/', ' ', $name );
        $name = preg_replace( '/\s*:\s*/', ': ', $name );
        return trim( $name );
    }
}

// ══════════════════════════════════════════════════════════════
// HELPER: Log for debugging
// ══════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_sync_log' ) ) {
    function dinoco_sync_log( $message ) {
        if ( defined( 'WP_DEBUG' ) && WP_DEBUG ) {
            error_log( '[DINOCO-Sync] ' . $message );
        }
    }
}

// ══════════════════════════════════════════════════════════════
// HELPER: Extract DB_ID from code header (V.32.0)
// ══════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_extract_db_id' ) ) {
    function dinoco_extract_db_id( $code ) {
        // Look for DB_ID in first 1000 chars of code
        $head = substr( $code, 0, 1000 );
        if ( preg_match( '/\*?\s*DB_ID:\s*(\d+)/i', $head, $m ) ) {
            return intval( $m[1] );
        }
        return 0;
    }
}

// ══════════════════════════════════════════════════════════════
// HELPER: Update snippet code with cache-bust + verify
// ══════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_sync_update_snippet' ) ) {
    function dinoco_sync_update_snippet( $row, $code, $file_name ) {
        global $wpdb;
        $table = $wpdb->prefix . 'snippets';
        $new_hash = md5( $code );

        // 0. Hash comparison — skip update if code is identical
        $current_hash = $wpdb->get_var( $wpdb->prepare(
            "SELECT md5(code) FROM {$table} WHERE id = %d",
            $row->id
        ) );
        if ( $current_hash === $new_hash ) {
            dinoco_sync_log( 'SKIP (identical): ' . $file_name . ' (id=' . $row->id . ', hash=' . substr( $new_hash, 0, 8 ) . ')' );
            return array(
                'ok'      => true,
                'status'  => 'already_current',
                'message' => 'already_current',
                'hash'    => substr( $new_hash, 0, 8 ),
            );
        }

        // 1. Execute update
        $new_revision = intval( $row->revision ) + 1;
        $result = $wpdb->update(
            $table,
            array(
                'code'     => $code,
                'modified' => current_time( 'mysql' ),
                'revision' => $new_revision,
            ),
            array( 'id' => $row->id ),
            array( '%s', '%s', '%d' ),
            array( '%d' )
        );

        // 2. Check return value
        if ( $result === false ) {
            $err = $wpdb->last_error;
            dinoco_sync_log( 'DB UPDATE FAILED: ' . $file_name . ' (id=' . $row->id . '): ' . $err );
            return array( 'ok' => false, 'status' => 'failed', 'message' => 'db_update_failed: ' . $err );
        }

        // 3. Flush WordPress object cache
        wp_cache_delete( 'alloptions', 'options' );

        // 4. Clear Code Snippets plugin caches
        delete_transient( 'code_snippets' );
        delete_transient( 'code_snippets_active' );
        delete_transient( 'all_snippets' );
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%code_snippets%' AND option_name LIKE '%_transient%'" );
        wp_cache_delete( $row->id, 'code_snippets' );
        wp_cache_delete( 'all_snippets', 'code_snippets' );

        // 5. Clear WP Fastest Cache if available
        if ( function_exists( 'wpfc_clear_all_cache' ) ) {
            wpfc_clear_all_cache( true );
        }

        // 6. OPcache invalidation
        if ( function_exists( 'opcache_invalidate' ) ) {
            $snippet_file = WP_CONTENT_DIR . '/db/snippets/' . $row->id . '.php';
            if ( file_exists( $snippet_file ) ) {
                @opcache_invalidate( $snippet_file, true );
            }
        }

        // 7. Post-sync verification — read back from DB and compare hash
        $verify_hash = $wpdb->get_var( $wpdb->prepare(
            "SELECT md5(code) FROM {$table} WHERE id = %d",
            $row->id
        ) );

        if ( $verify_hash !== $new_hash ) {
            dinoco_sync_log( 'VERIFY MISMATCH: ' . $file_name . ' expected=' . substr( $new_hash, 0, 8 ) . ' actual=' . substr( $verify_hash ?: 'null', 0, 8 ) );
            return array(
                'ok'      => false,
                'status'  => 'verify_failed',
                'message' => 'verify_hash_mismatch (expected=' . substr( $new_hash, 0, 8 ) . ' actual=' . substr( $verify_hash ?: 'null', 0, 8 ) . ')',
                'hash'    => substr( $verify_hash ?: '', 0, 8 ),
            );
        }

        dinoco_sync_log( 'OK: ' . $file_name . ' (id=' . $row->id . ', rev=' . $new_revision . ', hash=' . substr( $new_hash, 0, 8 ) . ', len=' . strlen( $code ) . ')' );
        return array(
            'ok'      => true,
            'status'  => 'synced',
            'message' => 'updated_and_verified',
            'hash'    => substr( $new_hash, 0, 8 ),
            'rev'     => $new_revision,
        );
    }
}

// ══════════════════════════════════════════════════════════════
// REST API ENDPOINT: /wp-json/dinoco/v1/github-sync
// ══════════════════════════════════════════════════════════════
add_action( 'rest_api_init', function () {
    register_rest_route( 'dinoco/v1', '/github-sync', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_github_sync_handler',
        'permission_callback' => '__return_true',
    ) );
} );

if ( ! function_exists( 'dinoco_github_sync_handler' ) ) {
    function dinoco_github_sync_handler( WP_REST_Request $req ) {
        // 1. Verify GitHub HMAC-SHA256 Signature
        $secret = defined( 'DINOCO_GITHUB_WEBHOOK_SECRET' ) ? DINOCO_GITHUB_WEBHOOK_SECRET : '';
        if ( empty( $secret ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'webhook_secret_not_configured' ), 500 );
        }

        $signature = $req->get_header( 'X-Hub-Signature-256' );
        $payload   = $req->get_body();

        if ( empty( $signature ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'missing_signature' ), 403 );
        }

        $expected = 'sha256=' . hash_hmac( 'sha256', $payload, $secret );
        if ( ! hash_equals( $expected, $signature ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'invalid_signature' ), 403 );
        }

        // 2. Parse push event
        $data = json_decode( $payload, true );
        if ( empty( $data['commits'] ) || empty( $data['repository'] ) ) {
            return new WP_REST_Response( array( 'ok' => true, 'message' => 'ping_received' ), 200 );
        }

        // Only sync from main branch
        $ref = isset( $data['ref'] ) ? $data['ref'] : '';
        if ( $ref !== 'refs/heads/main' ) {
            return new WP_REST_Response( array(
                'ok'      => true,
                'message' => 'ignored_non_main_branch',
                'ref'     => $ref,
            ), 200 );
        }

        // 3. Respond 200 immediately, run sync via shutdown hook
        $GLOBALS['_dinoco_pending_sync'] = $data;
        add_action( 'shutdown', 'dinoco_sync_on_shutdown', 0 );

        // Backup: WP-Cron (delay 30s)
        // Cancel ALL previous sync cron jobs to prevent stale pushes from overwriting newer code
        $prev_jobs = get_option( 'dinoco_sync_pending_jobs', array() );
        foreach ( $prev_jobs as $old_job_id ) {
            wp_clear_scheduled_hook( 'dinoco_github_sync_process', array( $old_job_id ) );
            delete_transient( $old_job_id );
        }

        $job_id = 'dinoco_sync_' . substr( md5( $payload ), 0, 12 );
        set_transient( $job_id, $data, 600 );
        update_option( 'dinoco_sync_pending_jobs', array( $job_id ), false );

        // Pass job_id to shutdown hook so it can cancel cron backup after starting
        $GLOBALS['_dinoco_pending_sync_job_id'] = $job_id;

        // Store the latest commit SHA so cron/sync can verify freshness
        $latest_sha = ! empty( $data['after'] ) ? $data['after'] : '';
        if ( $latest_sha ) {
            update_option( 'dinoco_sync_latest_sha', $latest_sha, false );
        }

        wp_schedule_single_event( time() + 30, 'dinoco_github_sync_process', array( $job_id ) );
        spawn_cron();

        return new WP_REST_Response( array(
            'ok'      => true,
            'message' => 'sync_started',
            'job_id'  => $job_id,
            'ref'     => $ref,
        ), 200 );
    }
}

// ══════════════════════════════════════════════════════════════
// SHUTDOWN HOOK — runs after REST response is sent
// ══════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_sync_on_shutdown' ) ) {
    function dinoco_sync_on_shutdown() {
        if ( empty( $GLOBALS['_dinoco_pending_sync'] ) ) return;
        $data = $GLOBALS['_dinoco_pending_sync'];
        unset( $GLOBALS['_dinoco_pending_sync'] );

        if ( function_exists( 'fastcgi_finish_request' ) ) {
            fastcgi_finish_request();
        }

        @set_time_limit( 300 );
        ignore_user_abort( true );

        // Cancel the cron backup — shutdown hook is handling this push
        if ( ! empty( $GLOBALS['_dinoco_pending_sync_job_id'] ) ) {
            $job_id = $GLOBALS['_dinoco_pending_sync_job_id'];
            wp_clear_scheduled_hook( 'dinoco_github_sync_process', array( $job_id ) );
            delete_transient( $job_id );
            update_option( 'dinoco_sync_pending_jobs', array(), false );
            dinoco_sync_log( 'Shutdown hook started — cancelled cron backup job: ' . $job_id );
            unset( $GLOBALS['_dinoco_pending_sync_job_id'] );
        }

        // Record this push commit+time so cron backup can verify freshness
        $commit_sha = ! empty( $data['after'] ) ? $data['after'] : '';
        if ( $commit_sha ) {
            update_option( 'dinoco_last_processed_commit', $commit_sha, false );
            update_option( 'dinoco_last_processed_time', time(), false );
        }

        dinoco_do_full_sync( $data, 'shutdown' );
    }
}

// ══════════════════════════════════════════════════════════════
// WP-CRON BACKUP
// ══════════════════════════════════════════════════════════════
add_action( 'dinoco_github_sync_process', 'dinoco_github_sync_process_job' );
if ( ! function_exists( 'dinoco_github_sync_process_job' ) ) {
    function dinoco_github_sync_process_job( $job_id ) {
        @set_time_limit( 300 );
        $data = get_transient( $job_id );
        if ( ! $data ) {
            dinoco_sync_log( 'Cron job skipped: transient ' . $job_id . ' missing (shutdown hook likely cancelled it)' );
            return;
        }
        delete_transient( $job_id );

        // Check if this job's commit is still the latest — skip if a newer push has arrived
        $job_sha    = ! empty( $data['after'] ) ? $data['after'] : '';
        $latest_sha = get_option( 'dinoco_sync_latest_sha', '' );
        if ( $job_sha && $latest_sha && $job_sha !== $latest_sha ) {
            dinoco_sync_log( 'Cron job skipped: commit ' . substr( $job_sha, 0, 7 ) . ' superseded by ' . substr( $latest_sha, 0, 7 ) );
            return;
        }

        // Check if the shutdown hook already processed this exact commit
        $already_processed = get_option( 'dinoco_last_processed_commit', '' );
        if ( $job_sha && $already_processed === $job_sha ) {
            dinoco_sync_log( 'Cron job skipped: commit ' . substr( $job_sha, 0, 7 ) . ' already processed by shutdown hook' );
            return;
        }

        // Clean up pending jobs list
        update_option( 'dinoco_sync_pending_jobs', array(), false );

        dinoco_do_full_sync( $data, 'cron' );
    }
}

// ══════════════════════════════════════════════════════════════
// SHARED SYNC LOGIC
// Match: [Admin System] * and [System] * prefixed files
// ══════════════════════════════════════════════════════════════
if ( ! function_exists( 'dinoco_do_full_sync' ) ) {
    function dinoco_do_full_sync( $data, $trigger = 'unknown' ) {
        // Freshness check — skip if a newer commit has already been registered
        $sync_sha   = ! empty( $data['after'] ) ? $data['after'] : '';
        $latest_sha = get_option( 'dinoco_sync_latest_sha', '' );
        if ( $sync_sha && $latest_sha && $sync_sha !== $latest_sha ) {
            dinoco_sync_log( 'Sync skipped (' . $trigger . '): commit ' . substr( $sync_sha, 0, 7 ) . ' superseded by ' . substr( $latest_sha, 0, 7 ) );
            return;
        }

        // Execution lock — if already syncing, queue this push for re-sync after current job finishes
        $lock = get_transient( 'dinoco_sync_running' );
        if ( $lock ) {
            // Save newer commit data so it can be picked up after current sync completes
            update_option( 'dinoco_sync_queued', $data, false );
            dinoco_sync_log( 'Sync locked by ' . $lock . ' — queued push (after=' . ( $data['after'] ?? 'n/a' ) . ') for re-sync' );
            update_option( 'dinoco_last_sync_result', array(
                'time'    => current_time( 'mysql' ),
                'trigger' => $trigger,
                'message' => 'queued_for_resync (locked by: ' . $lock . ', queued commit: ' . substr( $data['after'] ?? '', 0, 7 ) . ')',
            ) );
            return;
        }
        set_transient( 'dinoco_sync_running', $trigger, 300 );

        try {
            // Collect modified files from commits
            $modified_files = array();
            if ( ! empty( $data['commits'] ) ) {
                foreach ( $data['commits'] as $commit ) {
                    if ( ! empty( $commit['modified'] ) ) {
                        $modified_files = array_merge( $modified_files, $commit['modified'] );
                    }
                    if ( ! empty( $commit['added'] ) ) {
                        $modified_files = array_merge( $modified_files, $commit['added'] );
                    }
                }
            }
            if ( ! empty( $data['head_commit'] ) ) {
                if ( ! empty( $data['head_commit']['modified'] ) ) {
                    $modified_files = array_merge( $modified_files, $data['head_commit']['modified'] );
                }
                if ( ! empty( $data['head_commit']['added'] ) ) {
                    $modified_files = array_merge( $modified_files, $data['head_commit']['added'] );
                }
            }

            // V.22.0: Detect merge commits — force full sync
            $head_msg = ! empty( $data['head_commit']['message'] ) ? $data['head_commit']['message'] : '';
            $is_merge = preg_match( '/^Merge (pull request|branch)\b/', $head_msg );
            if ( $is_merge ) {
                dinoco_sync_log( 'Merge commit detected: ' . substr( $head_msg, 0, 80 ) . ' — force full sync' );
            }

            // Check if any DINOCO snippet files changed
            $has_snippet = (bool) $is_merge;
            foreach ( $modified_files as $f ) {
                if ( strpos( $f, '[Admin System]' ) === 0 || strpos( $f, '[System]' ) === 0 || strpos( $f, '[AdminSystem-System]' ) === 0 || strpos( $f, '[B2B]' ) === 0 ) {
                    $has_snippet = true;
                    break;
                }
            }

            // Compare API fallback
            if ( ! $has_snippet && ! empty( $data['before'] ) && ! empty( $data['after'] ) ) {
                $token = defined( 'DINOCO_GITHUB_TOKEN' ) ? DINOCO_GITHUB_TOKEN : '';
                if ( ! empty( $token ) ) {
                    $compare_url = sprintf(
                        'https://api.github.com/repos/%s/compare/%s...%s',
                        $data['repository']['full_name'], $data['before'], $data['after']
                    );
                    $cmp_resp = wp_remote_get( $compare_url, array(
                        'headers' => array(
                            'Accept'        => 'application/vnd.github.v3+json',
                            'Authorization' => 'Bearer ' . $token,
                            'User-Agent'    => 'DINOCO-System-Sync/1.0',
                        ),
                        'timeout' => 15,
                    ) );
                    if ( ! is_wp_error( $cmp_resp ) && wp_remote_retrieve_response_code( $cmp_resp ) === 200 ) {
                        $cmp_data = json_decode( wp_remote_retrieve_body( $cmp_resp ), true );
                        if ( ! empty( $cmp_data['files'] ) ) {
                            foreach ( $cmp_data['files'] as $cf ) {
                                if ( ! empty( $cf['filename'] ) && ( strpos( $cf['filename'], '[Admin System]' ) === 0 || strpos( $cf['filename'], '[System]' ) === 0 || strpos( $cf['filename'], '[AdminSystem-System]' ) === 0 || strpos( $cf['filename'], '[B2B]' ) === 0 ) ) {
                                    $has_snippet = true;
                                    break;
                                }
                            }
                        }
                    } else {
                        // V.22.0: Compare API failed — fallback to full sync instead of silently skipping
                        $cmp_err = is_wp_error( $cmp_resp ) ? $cmp_resp->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $cmp_resp );
                        dinoco_sync_log( 'Compare API failed: ' . $cmp_err . ' — fallback to full sync' );
                        $has_snippet = true;
                    }
                }
            }

            if ( ! $has_snippet ) {
                delete_transient( 'dinoco_sync_running' );
                update_option( 'dinoco_last_sync_result', array(
                    'time'    => current_time( 'mysql' ),
                    'trigger' => $trigger,
                    'message' => 'no_snippet_files_changed',
                    'files'   => array_values( array_unique( $modified_files ) ),
                ) );
                return;
            }

            // Sync snippets using commit SHA (bypass CDN cache)
            $repo       = $data['repository']['full_name'];
            $branch     = str_replace( 'refs/heads/', '', $data['ref'] );
            $commit_sha = ! empty( $data['after'] ) ? $data['after'] : $branch;
            $token      = defined( 'DINOCO_GITHUB_TOKEN' ) ? DINOCO_GITHUB_TOKEN : '';

            if ( empty( $token ) ) {
                delete_transient( 'dinoco_sync_running' );
                update_option( 'dinoco_last_sync_result', array(
                    'time'    => current_time( 'mysql' ),
                    'trigger' => $trigger,
                    'error'   => 'github_token_not_configured',
                ) );
                return;
            }

            global $wpdb;
            $table   = $wpdb->prefix . 'snippets';
            $updated = array();
            $errors  = array();

            // Load active DB rows matching [Admin System] or [System] or [AdminSystem-System] prefix
            $all_db_rows = $wpdb->get_results(
                "SELECT id, name, active, revision FROM {$table} WHERE active = 1 AND (name LIKE '[Admin System]%' OR name LIKE '[System]%' OR name LIKE '[AdminSystem-System]%' OR name LIKE '[B2B]%') ORDER BY id ASC"
            );

            $db_by_name = array();
            foreach ( $all_db_rows as $dbr ) {
                $normalized = dinoco_normalize_snippet_name( $dbr->name );
                if ( ! isset( $db_by_name[ $normalized ] ) ) {
                    $db_by_name[ $normalized ] = $dbr;
                }
            }

            // Build file list from commits + DB
            // FIX: create normalized→raw mapping so we can find repo files by normalized name
            $snippet_files = array();
            $norm_to_raw = array(); // normalized name → raw repo filename
            foreach ( $modified_files as $f ) {
                if ( strpos( $f, '[Admin System]' ) === 0 || strpos( $f, '[System]' ) === 0 || strpos( $f, '[AdminSystem-System]' ) === 0 || strpos( $f, '[B2B]' ) === 0 ) {
                    $snippet_files[ $f ] = $f;
                    $norm_to_raw[ dinoco_normalize_snippet_name( $f ) ] = $f;
                }
            }

            // Full sync: add DB snippets not in commits (use raw repo name if available)
            foreach ( $db_by_name as $name => $dbr ) {
                if ( ! isset( $snippet_files[ $name ] ) ) {
                    $raw_name = isset( $norm_to_raw[ $name ] ) ? $norm_to_raw[ $name ] : $name;
                    $snippet_files[ $raw_name ] = $raw_name;
                }
            }

            // V.23.0: Chunked sync — save queue to option, process via chained cron
            // Each chunk syncs 5 snippets then schedules the next chunk
            // Prevents 504 timeout on large repos (30+ snippets)
            $all_files = array_values( $snippet_files );
            $chunk_size = 5;
            $total_files = count( $all_files );

            // Save sync job state (token read from constant in chunk processor — not stored)
            $job_state = array(
                'files'      => $all_files,
                'chunk_size' => $chunk_size,
                'offset'     => 0,
                'total'      => $total_files,
                'repo'       => $repo,
                'commit_sha' => $commit_sha,
                'branch'     => $branch,
                'trigger'    => $trigger,
                'updated'    => array(),
                'skipped'    => array(),
                'errors'     => array(),
                'snippet_details' => array(),
                'db_names'   => array_keys( $db_by_name ),
                'started_at'     => current_time( 'mysql' ),
                'status'         => 'syncing',
                'commit_message' => ! empty( $data['head_commit']['message'] ) ? mb_substr( $data['head_commit']['message'], 0, 200 ) : '',
            );
            update_option( 'dinoco_sync_job', $job_state, false );
            update_option( 'dinoco_last_sync_result', array(
                'time'    => current_time( 'mysql' ),
                'trigger' => $trigger,
                'mode'    => 'chunked_sync_v23',
                'status'  => 'syncing',
                'progress' => '0/' . $total_files,
                'commit_sha' => $commit_sha,
            ) );

            // V.33.1: Process ALL chunks in shutdown hook (cron may not fire reliably)
            // set_time_limit(300) at top of shutdown hook gives enough headroom
            $max_loops = 20; // safety limit (20 chunks × 5 files = 100 files max)
            for ( $i = 0; $i < $max_loops; $i++ ) {
                dinoco_sync_process_chunk();
                $job_check = get_option( 'dinoco_sync_job' );
                if ( empty( $job_check ) || $job_check['status'] !== 'syncing' ) break;
            }

        } catch ( \Throwable $e ) {
            dinoco_sync_log( 'SYNC FATAL: ' . $e->getMessage() );
            delete_transient( 'dinoco_sync_running' );
        }
    }
}

// ── CHUNK PROCESSOR (V.23.0) ──
// Processes $chunk_size snippets, then schedules next chunk via WP-Cron
if ( ! function_exists( 'dinoco_sync_process_chunk' ) ) {
    function dinoco_sync_process_chunk() {
        $job = get_option( 'dinoco_sync_job' );
        if ( empty( $job ) || $job['status'] !== 'syncing' ) return;

        // V.30.1: Stale job detection — abort if a newer push has arrived
        $job_commit  = isset( $job['commit_sha'] ) ? $job['commit_sha'] : '';
        $latest_sha  = get_option( 'dinoco_sync_latest_sha', '' );
        if ( $job_commit && $latest_sha && $job_commit !== $latest_sha ) {
            dinoco_sync_log( 'STALE JOB ABORTED: job commit ' . substr( $job_commit, 0, 7 ) . ' superseded by ' . substr( $latest_sha, 0, 7 ) . ' — restarting sync' );

            // Mark current job as aborted
            $job['status'] = 'aborted_stale';
            update_option( 'dinoco_sync_job', $job, false );
            update_option( 'dinoco_last_sync_result', array(
                'time'       => current_time( 'mysql' ),
                'trigger'    => $job['trigger'],
                'mode'       => 'chunked_sync_v23',
                'status'     => 'aborted_stale',
                'message'    => 'Aborted stale commit ' . substr( $job_commit, 0, 7 ) . ', restarting with ' . substr( $latest_sha, 0, 7 ),
                'commit_sha' => $job_commit,
            ) );

            // Release lock and process queued push (which has the latest commit)
            delete_transient( 'dinoco_sync_running' );
            $queued = get_option( 'dinoco_sync_queued', null );
            if ( $queued && ! empty( $queued['after'] ) ) {
                delete_option( 'dinoco_sync_queued' );
                dinoco_sync_log( 'Restarting with queued push: commit=' . substr( $queued['after'], 0, 7 ) );
                dinoco_do_full_sync( $queued, 'stale_restart' );
            }
            return;
        }

        // Extend lock TTL for this chunk (ป้องกัน lock หมดอายุระหว่าง sync)
        set_transient( 'dinoco_sync_running', $job['trigger'] ?? 'chunk', 300 );

        global $wpdb;
        $table = $wpdb->prefix . 'snippets';

        $files      = $job['files'];
        $offset     = intval( $job['offset'] );
        $chunk_size = intval( $job['chunk_size'] );
        $total      = intval( $job['total'] );
        $repo       = $job['repo'];
        $commit_sha = $job['commit_sha'];
        $token      = defined( 'DINOCO_GITHUB_TOKEN' ) ? DINOCO_GITHUB_TOKEN : '';
        $updated    = $job['updated'];
        $skipped    = isset( $job['skipped'] ) ? $job['skipped'] : array();
        $errors     = $job['errors'];
        $snippet_details = isset( $job['snippet_details'] ) ? $job['snippet_details'] : array();

        if ( empty( $token ) ) {
            $job['status'] = 'completed';
            $job['errors'][] = 'DINOCO_GITHUB_TOKEN not configured';
            update_option( 'dinoco_sync_job', $job, false );
            delete_transient( 'dinoco_sync_running' );
            return;
        }

        // Load DB snippet map
        $all_db_rows = $wpdb->get_results(
            "SELECT id, name, active, revision FROM {$table} WHERE active = 1 AND (name LIKE '[Admin System]%' OR name LIKE '[System]%' OR name LIKE '[AdminSystem-System]%' OR name LIKE '[B2B]%') ORDER BY id ASC"
        );
        $db_by_name = array();
        $db_by_id   = array();
        foreach ( $all_db_rows as $dbr ) {
            $normalized = dinoco_normalize_snippet_name( $dbr->name );
            if ( ! isset( $db_by_name[ $normalized ] ) ) {
                $db_by_name[ $normalized ] = $dbr;
            }
            $db_by_id[ intval( $dbr->id ) ] = $dbr;
        }

        // Process this chunk
        $chunk = array_slice( $files, $offset, $chunk_size );
        foreach ( $chunk as $file_name ) {
            // Fetch from GitHub
            $raw_url = sprintf( 'https://raw.githubusercontent.com/%s/%s/%s', $repo, rawurlencode( $commit_sha ), rawurlencode( $file_name ) );
            $raw_resp = wp_remote_get( $raw_url, array(
                'headers' => array( 'Authorization' => 'token ' . $token, 'User-Agent' => 'DINOCO-System-Sync/1.0' ),
                'timeout' => 15,
            ) );

            if ( is_wp_error( $raw_resp ) || wp_remote_retrieve_response_code( $raw_resp ) !== 200 ) {
                // Fallback: Contents API
                $content_url = sprintf( 'https://api.github.com/repos/%s/contents/%s?ref=%s', $repo, rawurlencode( $file_name ), rawurlencode( $commit_sha ) );
                $raw_resp = wp_remote_get( $content_url, array(
                    'headers' => array( 'Accept' => 'application/vnd.github.v3.raw', 'Authorization' => 'Bearer ' . $token, 'User-Agent' => 'DINOCO-System-Sync/1.0' ),
                    'timeout' => 15,
                ) );
            }

            if ( is_wp_error( $raw_resp ) || wp_remote_retrieve_response_code( $raw_resp ) !== 200 ) {
                $err_msg = is_wp_error( $raw_resp ) ? $raw_resp->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $raw_resp );
                $errors[] = $file_name . ': ' . $err_msg;
                $snippet_details[ $file_name ] = array( 'status' => 'failed', 'error' => 'fetch_failed: ' . $err_msg );
                continue;
            }

            $code = wp_remote_retrieve_body( $raw_resp );

            // V.23: Relaxed content verification
            $code_head = substr( $code, 0, 800 );
            $content_ok = false;
            if ( preg_match( '/Snippet\s*(\d+)/', $file_name, $sn_match ) ) {
                $content_ok = ( strpos( $code_head, 'Snippet ' . $sn_match[1] ) !== false
                             || strpos( $code_head, 'Snippet' . $sn_match[1] ) !== false );
            }
            if ( ! $content_ok ) {
                $name_parts = explode( ']', explode( '[', $file_name, 2 )[1] ?? '', 2 );
                $prefix_tag = isset( $name_parts[0] ) ? '[' . $name_parts[0] . ']' : '';
                $name_after_prefix = trim( substr( $file_name, strlen( $prefix_tag ) ) );
                if ( ! empty( $name_after_prefix ) && strpos( $code_head, $name_after_prefix ) !== false ) {
                    $content_ok = true;
                }
                if ( ! $content_ok && ! empty( $name_after_prefix ) ) {
                    $words = preg_split( '/[\s:—\-_&+]+/', $name_after_prefix );
                    foreach ( $words as $w ) {
                        if ( mb_strlen( $w ) > 4 && strpos( $code_head, $w ) !== false ) {
                            $content_ok = true;
                            break;
                        }
                    }
                }
            }
            if ( ! $content_ok && strpos( $file_name, '[B2B]' ) !== 0 ) {
                $content_ok = true;
            }
            if ( ! $content_ok ) {
                dinoco_sync_log( 'CONTENT VERIFY FAIL: ' . $file_name . ' — keyword not found in header (len=' . strlen($code) . '), skipping' );
                $errors[] = $file_name . ': content_mismatch_prevented_swap';
                $snippet_details[ $file_name ] = array( 'status' => 'failed', 'error' => 'content_mismatch_prevented_swap' );
                continue;
            }

            // V.32.0: DB_ID matching (primary) with name fallback
            $db_id = dinoco_extract_db_id( $code );
            $row = null;
            if ( $db_id > 0 && isset( $db_by_id[ $db_id ] ) ) {
                $row = $db_by_id[ $db_id ];
                dinoco_sync_log( 'MATCH BY DB_ID: ' . $file_name . ' → id=' . $db_id . ' (db:' . $row->name . ')' );
            } else {
                // Fallback: normalize file_name before matching against normalized DB names
                $normalized_file = dinoco_normalize_snippet_name( $file_name );
                $row = isset( $db_by_name[ $normalized_file ] ) ? $db_by_name[ $normalized_file ] : null;
                if ( $row ) {
                    dinoco_sync_log( 'MATCH BY NAME: ' . $file_name . ' → id=' . $row->id . ' (db_id_in_code=' . $db_id . ')' );
                }
            }
            if ( $row ) {
                $sync_result = dinoco_sync_update_snippet( $row, $code, $file_name );
                $detail = array(
                    'status' => isset( $sync_result['status'] ) ? $sync_result['status'] : ( $sync_result['ok'] ? 'synced' : 'failed' ),
                    'hash'   => isset( $sync_result['hash'] ) ? $sync_result['hash'] : '',
                    'rev'    => isset( $sync_result['rev'] ) ? $sync_result['rev'] : $row->revision,
                );
                if ( ! $sync_result['ok'] ) {
                    $detail['error'] = $sync_result['message'];
                    $errors[] = $file_name . ': ' . $sync_result['message'];
                } elseif ( isset( $sync_result['status'] ) && $sync_result['status'] === 'already_current' ) {
                    $skipped[] = $file_name;
                } else {
                    $updated[] = $file_name . ' (db:' . $row->name . ')';
                }
                $snippet_details[ $file_name ] = $detail;
            } else {
                $errors[] = $file_name . ': snippet_not_found_in_db';
                $snippet_details[ $file_name ] = array( 'status' => 'not_found', 'error' => 'snippet_not_found_in_db' );
            }
        }

        // Update job state
        $new_offset = $offset + $chunk_size;
        $is_done    = $new_offset >= $total;

        $job['offset']          = $new_offset;
        $job['updated']         = $updated;
        $job['skipped']         = $skipped;
        $job['errors']          = $errors;
        $job['snippet_details'] = $snippet_details;
        $job['status']          = $is_done ? 'completed' : 'syncing';
        if ( $is_done ) {
            $job['completed_at'] = current_time( 'mysql' );
        }
        update_option( 'dinoco_sync_job', $job, false );

        // Update progress in last_sync_result (for dashboard polling)
        $progress = min( $new_offset, $total ) . '/' . $total;
        update_option( 'dinoco_last_sync_result', array(
            'time'            => current_time( 'mysql' ),
            'trigger'         => $job['trigger'],
            'branch'          => $job['branch'],
            'commit_sha'      => $job['commit_sha'],
            'commit_message'  => isset( $job['commit_message'] ) ? $job['commit_message'] : '',
            'mode'            => 'chunked_sync_v32',
            'status'          => $is_done ? 'completed' : 'syncing',
            'progress'        => $progress,
            'files_synced'    => $files,
            'db_names'        => $job['db_names'],
            'updated'         => $updated,
            'skipped'         => $skipped,
            'errors'          => $errors,
            'snippet_details' => $snippet_details,
            'started_at'      => isset( $job['started_at'] ) ? $job['started_at'] : '',
            'completed_at'    => $is_done ? current_time( 'mysql' ) : '',
        ) );

        dinoco_sync_log( 'Chunk done: ' . $progress . ' (' . count( $chunk ) . ' files, ' . count( $updated ) . ' updated, ' . count( $errors ) . ' errors)' );

        if ( $is_done ) {
            // Final: flush caches once
            wp_cache_flush();
            if ( function_exists( 'opcache_reset' ) ) @opcache_reset();
            if ( function_exists( 'wpfc_clear_all_cache' ) ) wpfc_clear_all_cache( true );
            $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%snippet%' AND option_name LIKE '%transient%'" );
            $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%code_snippets%'" );
            dinoco_sync_log( 'Sync COMPLETED: ' . count( $updated ) . ' updated, ' . count( $errors ) . ' errors' );

            // Record this commit as fully processed (prevents cron backup from re-running)
            if ( ! empty( $job['commit_sha'] ) ) {
                update_option( 'dinoco_last_processed_commit', $job['commit_sha'], false );
                update_option( 'dinoco_last_processed_time', time(), false );
            }

            // Release lock before checking queue
            delete_transient( 'dinoco_sync_running' );

            // Check if a newer push was queued while this sync was running
            $queued = get_option( 'dinoco_sync_queued', null );
            if ( $queued && ! empty( $queued['after'] ) ) {
                delete_option( 'dinoco_sync_queued' );
                dinoco_sync_log( 'Processing queued push: commit=' . substr( $queued['after'], 0, 7 ) );
                dinoco_do_full_sync( $queued, 'queued_resync' );
            }
        } else {
            // Schedule next chunk in 2 seconds
            wp_schedule_single_event( time() + 2, 'dinoco_sync_chunk_event' );
            spawn_cron();
        }
    }
}
add_action( 'dinoco_sync_chunk_event', 'dinoco_sync_process_chunk' );

// ══════════════════════════════════════════════════════════════
// MANUAL SYNC: POST /wp-json/dinoco/v1/github-sync-manual
// ══════════════════════════════════════════════════════════════
add_action( 'rest_api_init', function () {
    register_rest_route( 'dinoco/v1', '/github-sync-manual', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_github_sync_manual',
        'permission_callback' => function () {
            return current_user_can( 'manage_options' );
        },
    ) );
} );

if ( ! function_exists( 'dinoco_github_sync_manual' ) ) {
    function dinoco_github_sync_manual( WP_REST_Request $req ) {
        @set_time_limit( 300 );
        ignore_user_abort( true );

        $token = defined( 'DINOCO_GITHUB_TOKEN' ) ? DINOCO_GITHUB_TOKEN : '';
        $repo  = defined( 'DINOCO_GITHUB_REPO' )  ? DINOCO_GITHUB_REPO  : '';

        if ( empty( $token ) || empty( $repo ) ) {
            return new WP_REST_Response( array( 'ok' => false, 'error' => 'missing_config: DINOCO_GITHUB_TOKEN or DINOCO_GITHUB_REPO' ), 500 );
        }

        // Clear any stale lock/queue to ensure clean sync
        delete_transient( 'dinoco_sync_running' );
        delete_option( 'dinoco_sync_queued' );

        $branch = $req->get_param( 'branch' ) ?: 'main';

        // V.33.0: Resolve latest commit SHA for the branch FIRST
        // Using commit SHA instead of branch name bypasses GitHub CDN caching
        $commit_sha = '';
        $ref_url = sprintf( 'https://api.github.com/repos/%s/git/ref/heads/%s', $repo, rawurlencode( $branch ) );
        $ref_resp = wp_remote_get( $ref_url, array(
            'headers' => array(
                'Authorization' => 'Bearer ' . $token,
                'User-Agent'    => 'DINOCO-System-Sync/1.0',
                'Accept'        => 'application/vnd.github.v3+json',
                'If-None-Match' => '',  // Force bypass any HTTP cache
            ),
            'timeout' => 15,
        ) );
        if ( ! is_wp_error( $ref_resp ) && wp_remote_retrieve_response_code( $ref_resp ) === 200 ) {
            $ref_data = json_decode( wp_remote_retrieve_body( $ref_resp ), true );
            if ( ! empty( $ref_data['object']['sha'] ) ) {
                $commit_sha = $ref_data['object']['sha'];
                dinoco_sync_log( 'Manual sync: resolved branch ' . $branch . ' → SHA ' . substr( $commit_sha, 0, 7 ) );
            }
        }
        if ( empty( $commit_sha ) ) {
            // Fallback: use branch name (may be CDN-cached)
            $commit_sha = $branch;
            dinoco_sync_log( 'Manual sync: could not resolve SHA, using branch name: ' . $branch );
        }

        // Track whether webhook already synced this commit
        $last_processed = get_option( 'dinoco_last_processed_commit', '' );
        $webhook_already_synced = ( $commit_sha && $last_processed === $commit_sha );

        global $wpdb;
        $table   = $wpdb->prefix . 'snippets';
        $updated = array();
        $errors  = array();

        // Load active DB rows
        $all_db_rows = $wpdb->get_results(
            "SELECT id, name, active, revision FROM {$table} WHERE active = 1 AND (name LIKE '[Admin System]%' OR name LIKE '[System]%' OR name LIKE '[AdminSystem-System]%' OR name LIKE '[B2B]%') ORDER BY id ASC"
        );

        $db_by_name = array();
        $db_by_id   = array();
        foreach ( $all_db_rows as $dbr ) {
            $normalized = dinoco_normalize_snippet_name( $dbr->name );
            if ( ! isset( $db_by_name[ $normalized ] ) ) {
                $db_by_name[ $normalized ] = $dbr;
            }
            $db_by_id[ intval( $dbr->id ) ] = $dbr;
        }

        $skipped = array();
        $snippet_details = array();

        // V.33.0: build repo file list from GitHub tree using COMMIT SHA (not branch name)
        $tree_url = sprintf( 'https://api.github.com/repos/%s/git/trees/%s', $repo, rawurlencode( $commit_sha ) );
        $tree_resp = wp_remote_get( $tree_url, array(
            'headers' => array(
                'Authorization' => 'Bearer ' . $token,
                'User-Agent'    => 'DINOCO-System-Sync/1.0',
                'If-None-Match' => '',
            ),
            'timeout' => 15,
        ) );
        $repo_files = array(); // normalized → raw filename
        if ( ! is_wp_error( $tree_resp ) && wp_remote_retrieve_response_code( $tree_resp ) === 200 ) {
            $tree_data = json_decode( wp_remote_retrieve_body( $tree_resp ), true );
            foreach ( ( $tree_data['tree'] ?? array() ) as $item ) {
                if ( $item['type'] === 'blob' && preg_match( '/^\[/', $item['path'] ) ) {
                    $repo_files[ dinoco_normalize_snippet_name( $item['path'] ) ] = $item['path'];
                }
            }
        }

        foreach ( $db_by_name as $file_name => $row ) {
            // Resolve actual repo filename (may differ from normalized DB name)
            $actual_file = isset( $repo_files[ $file_name ] ) ? $repo_files[ $file_name ] : $file_name;

            // V.33.0: Use commit SHA for Contents API (bypass CDN cache completely)
            $content_url = sprintf(
                'https://api.github.com/repos/%s/contents/%s?ref=%s',
                $repo,
                rawurlencode( $actual_file ),
                rawurlencode( $commit_sha )
            );
            $raw_response = wp_remote_get( $content_url, array(
                'headers' => array(
                    'Accept'        => 'application/vnd.github.v3.raw',
                    'Authorization' => 'Bearer ' . $token,
                    'User-Agent'    => 'DINOCO-System-Sync/1.0',
                    'If-None-Match' => '',  // Force bypass HTTP cache
                ),
                'timeout' => 30,
            ) );

            // Fallback: raw.githubusercontent.com using commit SHA (not branch)
            if ( is_wp_error( $raw_response ) || wp_remote_retrieve_response_code( $raw_response ) !== 200 ) {
                $raw_url = sprintf(
                    'https://raw.githubusercontent.com/%s/%s/%s',
                    $repo,
                    rawurlencode( $commit_sha ),
                    rawurlencode( $actual_file )
                );
                $raw_response = wp_remote_get( $raw_url, array(
                    'headers' => array(
                        'Authorization' => 'token ' . $token,
                        'User-Agent'    => 'DINOCO-System-Sync/1.0',
                    ),
                    'timeout' => 30,
                ) );
            }

            if ( is_wp_error( $raw_response ) || wp_remote_retrieve_response_code( $raw_response ) !== 200 ) {
                $err_msg = is_wp_error( $raw_response ) ? $raw_response->get_error_message() : 'HTTP ' . wp_remote_retrieve_response_code( $raw_response );
                $errors[] = $file_name . ': ' . $err_msg;
                $snippet_details[ $file_name ] = array( 'status' => 'failed', 'error' => 'fetch_failed: ' . $err_msg );
                continue;
            }

            $code = wp_remote_retrieve_body( $raw_response );

            // V.32.0: DB_ID matching — override row if code declares a different DB_ID
            $code_db_id = dinoco_extract_db_id( $code );
            if ( $code_db_id > 0 && $code_db_id !== intval( $row->id ) && isset( $db_by_id[ $code_db_id ] ) ) {
                dinoco_sync_log( 'MANUAL DB_ID OVERRIDE: file=' . $file_name . ' code_db_id=' . $code_db_id . ' (was id=' . $row->id . ')' );
                $row = $db_by_id[ $code_db_id ];
            }

            // V.30.2: Safety — verify fetched code belongs to this snippet
            $code_head = substr( $code, 0, 800 );
            $content_ok = false;
            if ( preg_match( '/Snippet\s*(\d+)/', $file_name, $sn_match ) ) {
                $content_ok = ( strpos( $code_head, 'Snippet ' . $sn_match[1] ) !== false
                             || strpos( $code_head, 'Snippet' . $sn_match[1] ) !== false );
            }
            if ( ! $content_ok ) {
                $name_parts = explode( ']', explode( '[', $file_name, 2 )[1] ?? '', 2 );
                $prefix_tag = isset( $name_parts[0] ) ? '[' . $name_parts[0] . ']' : '';
                $name_after_prefix = trim( substr( $file_name, strlen( $prefix_tag ) ) );
                if ( ! empty( $name_after_prefix ) ) {
                    $words = preg_split( '/[\s:—\-_&+]+/', $name_after_prefix );
                    foreach ( $words as $w ) {
                        if ( mb_strlen( $w ) > 4 && strpos( $code_head, $w ) !== false ) {
                            $content_ok = true;
                            break;
                        }
                    }
                }
            }
            if ( ! $content_ok && strpos( $file_name, '[B2B]' ) !== 0 ) {
                $content_ok = true;
            }
            if ( ! $content_ok ) {
                dinoco_sync_log( 'CONTENT MISMATCH (manual): file=' . $file_name . ' — SKIPPED' );
                $errors[] = $file_name . ': content_mismatch_prevented_swap';
                $snippet_details[ $file_name ] = array( 'status' => 'failed', 'error' => 'content_mismatch_prevented_swap' );
                continue;
            }

            $sync_result = dinoco_sync_update_snippet( $row, $code, $file_name );
            $detail = array(
                'status' => isset( $sync_result['status'] ) ? $sync_result['status'] : ( $sync_result['ok'] ? 'synced' : 'failed' ),
                'hash'   => isset( $sync_result['hash'] ) ? $sync_result['hash'] : '',
                'rev'    => isset( $sync_result['rev'] ) ? $sync_result['rev'] : $row->revision,
            );
            if ( ! $sync_result['ok'] ) {
                $detail['error'] = $sync_result['message'];
                $errors[] = $file_name . ': ' . $sync_result['message'];
            } elseif ( isset( $sync_result['status'] ) && $sync_result['status'] === 'already_current' ) {
                $skipped[] = $file_name;
            } else {
                $updated[] = $file_name;
            }
            $snippet_details[ $file_name ] = $detail;
        }

        // Global cache flush
        wp_cache_flush();
        if ( function_exists( 'opcache_reset' ) ) {
            @opcache_reset();
        }
        if ( function_exists( 'wpfc_clear_all_cache' ) ) {
            wpfc_clear_all_cache( true );
        }
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%snippet%' AND option_name LIKE '%transient%'" );
        $wpdb->query( "DELETE FROM {$wpdb->options} WHERE option_name LIKE '%code_snippets%'" );

        // Save result to dashboard
        update_option( 'dinoco_last_sync_result', array(
            'time'            => current_time( 'mysql' ),
            'trigger'         => 'manual',
            'branch'          => $branch,
            'commit_sha'      => $commit_sha,
            'mode'            => 'manual_sync_v33',
            'status'          => 'completed',
            'files_synced'    => array_keys( $db_by_name ),
            'updated'         => $updated,
            'skipped'         => $skipped,
            'errors'          => $errors,
            'snippet_details' => $snippet_details,
            'webhook_already_synced' => $webhook_already_synced,
        ) );

        return new WP_REST_Response( array(
            'ok'      => true,
            'updated' => $updated,
            'skipped' => $skipped,
            'errors'  => $errors,
            'branch'  => $branch,
            'commit_sha' => $commit_sha,
            'total'   => count( $db_by_name ),
            'webhook_already_synced' => $webhook_already_synced,
        ), 200 );
    }
}

