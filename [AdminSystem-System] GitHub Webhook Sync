<script>
(function(){
    var REST = '<?php echo esc_js( $rest ); ?>';
    var NONCE = '<?php echo esc_js( $nonce ); ?>';
    var _poll = null;

    // Filter tabs
    window.sdF = function(el) {
        var tabs = document.querySelectorAll('#sd-wrap .sd-tab');
        for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
        el.classList.add('active');
        var f = el.getAttribute('data-f');
        var trs = document.querySelectorAll('#sd-tbody tr');
        for (var j = 0; j < trs.length; j++) {
            trs[j].style.display = (f === 'all' || trs[j].getAttribute('data-f') === f) ? '' : 'none';
        }
    };

    // V.34.1: Always-on polling — detects webhook sync in real-time
    var _wasSyncing = <?php echo $lock ? 'true' : 'false'; ?>;
    var _lastSha = '<?php echo esc_js( substr( $commit_sha, 0, 7 ) ); ?>';

    function doPoll() {
        fetch(REST + 'sync-status', {
            headers: { 'X-WP-Nonce': NONCE },
            credentials: 'same-origin'
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            var prog = document.getElementById('sd-prog');
            var fill = document.getElementById('sd-prog-fill');
            var txt  = document.getElementById('sd-prog-txt');
            var sub  = document.getElementById('sd-prog-sub');

            if (d.is_syncing) {
                // Sync กำลังทำงาน — แสดง progress bar
                _wasSyncing = true;
                if (prog) prog.style.display = '';
                var parts = (d.progress || '0/1').split('/');
                var done = parseInt(parts[0]) || 0;
                var tot  = parseInt(parts[1]) || 1;
                var pct  = Math.round((done / tot) * 100);
                if (fill) fill.style.width = pct + '%';
                if (txt) txt.textContent = 'กำลัง Sync... ' + done + '/' + tot + ' (' + pct + '%)';
                if (sub) sub.textContent = d.current_file ? 'อัพเดท ' + d.current_file + '...' : 'กำลังดึงโค้ดจาก GitHub...';
            } else if (_wasSyncing) {
                // เพิ่งเสร็จ — แสดงเสร็จแล้ว refresh
                _wasSyncing = false;
                if (prog) prog.style.display = '';
                if (fill) fill.style.width = '100%';
                if (txt) txt.textContent = '✅ Sync เสร็จแล้ว! กำลังรีเฟรช...';
                if (sub) sub.textContent = '';
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                // Idle — ซ่อน progress bar, ตรวจว่ามี commit ใหม่ไหม
                if (prog) prog.style.display = 'none';
                var newSha = d.last_sync && d.last_sync.commit_sha ? d.last_sync.commit_sha.substring(0,7) : '';
                if (newSha && newSha !== _lastSha) {
                    // Webhook sync เสร็จไป โดย user ไม่ได้เห็น — refresh เพื่อแสดงผลใหม่
                    _lastSha = newSha;
                    location.reload();
                }
            }
        })
        .catch(function() {});
    }

    // Poll ทุก 3 วินาทีตลอดเวลา (lightweight GET)
    setInterval(doPoll, 3000);
    // เริ่ม poll ครั้งแรกทันที
    doPoll();

    // Sync Now button — polling จะจับ progress อัตโนมัติ
    window.sdSync = function() {
        var btn = document.getElementById('sd-sync-btn');
        var msg = document.getElementById('sd-msg');
        var prog = document.getElementById('sd-prog');
        var txt  = document.getElementById('sd-prog-txt');
        var fill = document.getElementById('sd-prog-fill');
        btn.disabled = true;
        btn.innerHTML = '<span class="sd-spin"></span> กำลัง Sync...';
        msg.className = 'sd-msg'; msg.style.display = 'none';

        // แสดง progress bar ทันที (polling จะอัพเดทจริงทีหลัง)
        if (prog) prog.style.display = '';
        if (fill) fill.style.width = '5%';
        if (txt) txt.textContent = 'กำลังเริ่ม Sync...';
        _wasSyncing = true;

        fetch(REST + 'github-sync-manual', {
            method: 'POST',
            headers: { 'X-WP-Nonce': NONCE, 'Content-Type': 'application/json' },
            credentials: 'same-origin'
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(res) {
            btn.disabled = false; btn.textContent = 'Sync Now';
            if (res.ok && res.data.ok) {
                var u = res.data.updated || [];
                var s = res.data.skipped || [];
                var e = res.data.errors || [];
                var t = res.data.total || 0;
                var sha = res.data.commit_sha ? res.data.commit_sha.substring(0,7) : '';
                var detail = u.length + ' synced, ' + s.length + ' same, ' + e.length + ' errors';
                if (u.length === 0 && s.length > 0 && res.data.webhook_already_synced) {
                    detail = 'โค้ดตรงกับ GitHub อยู่แล้ว (webhook sync ทำงานแล้ว)';
                }
                if (fill) fill.style.width = '100%';
                if (txt) txt.textContent = '✅ ' + detail;
                msg.className = e.length > 0 ? 'sd-msg err' : 'sd-msg ok';
                if (e.length > 0) { msg.textContent = 'Errors:\n' + e.join('\n'); msg.style.display = 'block'; }
            } else {
                msg.className = 'sd-msg err';
                msg.textContent = 'Sync ล้มเหลว: ' + (res.data.error || 'Unknown error');
                msg.style.display = 'block';
            }
            setTimeout(function() { location.reload(); }, 2000);
        })
        .catch(function(e) {
            btn.disabled = false; btn.textContent = 'Sync Now';
            msg.className = 'sd-msg err';
            msg.textContent = 'Network error: ' + e.message;
            msg.style.display = 'block';
        });
    };
})();
</script>
