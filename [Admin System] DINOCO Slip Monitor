            $row['dist_name'] = isset( $name_map[ $row['group_id'] ] ) ? $name_map[ $row['group_id'] ] : '';
        }
        unset( $row );

        return rest_ensure_response( array( 'success' => true, 'rows' => $rows ) );
    }
}

// ────────────────────────────────────────────────────────────────
// POST /clear-locks — force-unlock specific group or all
// Body: { group_id: '', reason: '' }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_clear_locks' ) ) {
    function dinoco_slip_monitor_rest_clear_locks( WP_REST_Request $req ) {
        // Rate limit 5/min per user (reuse b2b_rate_limit if available)
        $uid = get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_clear_locks_u' . $uid, 5, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 5/min)', array( 'status' => 429 ) );
            }
        }

        if ( ! function_exists( 'b2b_slip_clear_locks' ) ) {
            return new WP_Error( 'missing_helper', 'ต้อง Snippet 1 V.34.8+ ก่อน', array( 'status' => 501 ) );
        }

        $group_id = sanitize_text_field( (string) $req->get_param( 'group_id' ) );
        $reason   = sanitize_text_field( (string) $req->get_param( 'reason' ) ?: 'admin_manual' );

        // V.1.14 Round 49: Idempotency-Key wrap. Admin "Clear Locks" double-click on
        // slow b2b_slip_clear_locks() (scans wp_options → DELETE LIKE pattern + audit
        // INSERT) → 2× DELETE storm + 2× audit row "slip_locks_cleared" + 2× admin
        // dashboard refresh. Body hash = single {group_id, reason} — same retry =
        // cached 200; different reason mid-retry → 409 forces admin to type correct
        // reason (audit trail integrity).
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $req ) : '';
        $idem_namespace = 'dinoco-slip/v1::clear-locks';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'group_id' => $group_id,
                'reason'   => $reason,
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) {
                $err_data    = $cached->get_error_data();
                $status_code = ( is_array( $err_data ) && isset( $err_data['status'] ) ) ? (int) $err_data['status'] : 409;
                return new WP_Error(
                    'idempotency_conflict',
                    'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                    array( 'status' => $status_code )
                );
            }
            if ( is_array( $cached ) ) {
                $resp = $cached;
                unset( $resp['_idem_code'] );
                return rest_ensure_response( $resp );
            }
        }

        $result = b2b_slip_clear_locks( $group_id, 'admin:' . $uid . ':' . $reason );
        $resp   = array( 'success' => true, 'data' => $result );

        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store(
                $idem_key,
                $idem_namespace,
                $idem_body,
                array_merge( $resp, array( '_idem_code' => 200 ) ),
                200
            );
        }

        return rest_ensure_response( $resp );
    }
}

// ────────────────────────────────────────────────────────────────
// GET /missed-sweep — Forensic audit: สลิปที่ process แล้วไม่เจอ order match ในช่วง 30d
// ใช้ตรวจย้อนหลังว่ามีสลิปหายก่อนหน้านี้ที่บอสไม่รู้มั้ย
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_missed_sweep' ) ) {
    function dinoco_slip_monitor_rest_missed_sweep( WP_REST_Request $req ) {
        // V.1.1 M-6: rate-limit 10/min/user. Forensic sweep scans up to 500 rows across
        // 90 days — admin could spam it during debug panic and lock the table. Same
        // pattern as /clear-locks.
        $uid = get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_missed_sweep_u' . $uid, 10, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 10/min)', array( 'status' => 429 ) );
            }
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $table_exists ) {
            return rest_ensure_response( array( 'success' => true, 'rows' => array(), 'table_missing' => true ) );
        }

        $days = max( 1, min( 90, (int) $req->get_param( 'days' ) ?: 30 ) );

        // สลิปที่:
        //   • result_status = 'slip2go_error' หรือ 'line_api_error' หรือ 'unregistered_group'
        //     (= สลิปที่ระบบไม่ประมวลผลสำเร็จ)
        //   • result_status = 'amount_no_pending' (= match ผิดร้าน admin ต้อง manual)
        //   • result_status = 'no_distributor' (= Slip2Go OK แต่ไม่มี dist CPT)
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, group_id, message_id, user_id, dist_id, slip_code, amount, trans_ref,
                    sender_name, result_status, error_code, error_msg, http_code, created_at
             FROM {$table}
             WHERE created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
               AND result_status IN ('slip2go_error','line_api_error','unregistered_group','amount_no_pending','no_distributor','data_missing','unknown_slip_code')
             ORDER BY created_at DESC
             LIMIT 500",
            $days
        ), ARRAY_A );

        // V.1.1 M-4: batch enrich (single JOIN query, was N+1 across up to 500 rows)
        $gids = array();
        foreach ( $rows as $r ) { if ( ! empty( $r['group_id'] ) ) $gids[] = $r['group_id']; }
        $name_map = dinoco_slip_monitor_get_dist_names_batch( $gids );
        foreach ( $rows as &$row ) {
            $row['dist_name'] = isset( $name_map[ $row['group_id'] ] ) ? $name_map[ $row['group_id'] ] : '';
        }
        unset( $row );

        // Breakdown
        $breakdown = array();
        foreach ( $rows as $r ) {
            $s = $r['result_status'];
            if ( ! isset( $breakdown[ $s ] ) ) $breakdown[ $s ] = 0;
            $breakdown[ $s ]++;
        }

        return rest_ensure_response( array(
            'success' => true,
            'days' => $days,
            'count' => count( $rows ),
            'breakdown' => $breakdown,
            'rows' => $rows,
        ) );
    }
}

