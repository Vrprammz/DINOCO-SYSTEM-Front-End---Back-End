            const result = document.getElementById('dncSlipCnResult');
            const confirmBtn = document.getElementById('dncSlipCnConfirmBtn');

            const amount = parseFloat(amountEl.value);
            const reason = (reasonEl.value || '').trim();
            const notify = !!notifyEl.checked;

            if (!Number.isFinite(amount) || amount <= 0) {
                result.innerHTML = '<div style="color:#dc2626; font-size:12px;">❌ กรุณาระบุยอดที่ถูกต้อง</div>';
                amountEl.focus();
                return;
            }
            if (amount > Number(cnState.eligible.amount)) {
                result.innerHTML = '<div style="color:#dc2626; font-size:12px;">❌ ยอด credit note (฿' + amount.toFixed(2) + ') มากกว่ายอดสลิป (฿' + Number(cnState.eligible.amount).toFixed(2) + ')</div>';
                amountEl.focus();
                return;
            }
            if (reason.length < 10) {
                result.innerHTML = '<div style="color:#dc2626; font-size:12px;">❌ ต้องระบุเหตุผลไม่น้อยกว่า 10 ตัวอักษร</div>';
                reasonEl.focus();
                return;
            }

            const ok = await cnSafeConfirm({
                title: '💰 ยืนยันออก Credit Note',
                message: 'ร้าน: ' + cnState.eligible.dist_name + '\n'
                       + 'ยอด: ฿' + amount.toFixed(2) + '\n'
                       + 'หนี้ปัจจุบัน: ฿' + Number(cnState.eligible.current_debt).toFixed(2) + '\n'
                       + 'หนี้ใหม่ (ประมาณ): ฿' + Math.max(0, Number(cnState.eligible.current_debt) - amount).toFixed(2) + '\n\n'
                       + 'การกระทำนี้ตัดเครดิตจากร้านโดยตรง — กดยืนยันเพื่อดำเนินการ',
                confirmText: 'ยืนยันออก Credit Note',
                cancelText: 'ยกเลิก',
                danger: true,
            });
            if (!ok) return;

            cnState.inFlight = true;
            confirmBtn.disabled = true;
            confirmBtn.textContent = 'กำลังประมวลผล...';
            result.innerHTML = '<div style="color:#64748b; font-size:12px;">กำลังประมวลผล...</div>';

            try {
                const r = await apiPost('/issue-credit-note', {
                    log_id: cnState.logId,
                    amount: amount,
                    reason: reason,
                    notify_dist: notify,
                });
                if (r.success) {
                    result.innerHTML = '<div style="background:#dcfce7; color:#166534; padding:10px; border-radius:6px; font-size:12px;">✅ ' + esc(r.message || 'OK') + '</div>';
                    setTimeout(function() {
                        dncSlipCreditNoteClose();
                        dncSlipMonitorRefresh();
                    }, 900);
                } else {
                    result.innerHTML = '<div style="background:#fee2e2; color:#991b1b; padding:10px; border-radius:6px; font-size:12px;">❌ ' + esc(r.message || r.code || 'unknown error') + '</div>';
                    confirmBtn.disabled = false;
                    confirmBtn.textContent = '💰 ยืนยันออก Credit Note';
                }
            } catch (e) {
                result.innerHTML = '<div style="background:#fee2e2; color:#991b1b; padding:10px; border-radius:6px; font-size:12px;">❌ Error: ' + esc(e.message || 'unknown') + '</div>';
                confirmBtn.disabled = false;
                confirmBtn.textContent = '💰 ยืนยันออก Credit Note';
            } finally {
                cnState.inFlight = false;
            }
        };

        // Event delegation — credit note button on Recent rows
        document.addEventListener('click', function(e) {
            const btn = e.target && e.target.closest ? e.target.closest('.dnc-slip-cn-btn') : null;
            if (!btn) return;
            const logId = btn.dataset && btn.dataset.logId ? parseInt(btn.dataset.logId, 10) : 0;
            if (!logId) return;
            window.dncSlipCreditNoteOpen(logId);
        });

        // Backdrop click closes modal
        const _cnModalEl = document.getElementById('dncSlipCreditNoteModal');
        if (_cnModalEl) {
            _cnModalEl.addEventListener('click', function(e) {
                if (e.target === _cnModalEl) dncSlipCreditNoteClose();
            });
        }
        // ESC closes modal
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const m = document.getElementById('dncSlipCreditNoteModal');
                if (m && m.style.display !== 'none') dncSlipCreditNoteClose();
            }
        });

        // Auto-load on page ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                dncSlipMonitorRefresh();
                loadDistributors();
                dncSlipNeedsReview(30); // V.1.9
            });
        } else {
            dncSlipMonitorRefresh();
            loadDistributors();
            dncSlipNeedsReview(30); // V.1.9
        }
    })();
    </script>
    <?php
    return ob_get_clean();
}
