                       result_status, error_code, error_msg, http_code, processing_time_ms, retry_count, created_at
                       {$ai_cols_select}{$cn_cols_select}
                FROM {$table}
                WHERE " . implode( ' AND ', $where ) . "
                ORDER BY id DESC
                LIMIT %d";
        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );

        // V.1.1 M-4: batch enrich (single JOIN query, previously N+1 get_posts)
        $gids = array();
