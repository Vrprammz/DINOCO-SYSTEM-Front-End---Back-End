// ────────────────────────────────────────────────────────────────
// POST /manual-process — emergency bypass (Slip2Go quota deadlock rescue)
// Body: { dist_id, amount, trans_ref?, sender_name?, reason, image_base64?, image_mime? }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_manual_process' ) ) {
    function dinoco_slip_monitor_rest_manual_process( WP_REST_Request $req ) {
        $uid = get_current_user_id();
        // Rate limit 5/min (destructive + touches debt)
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_manual_process_u' . $uid, 5, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 5/min)', array( 'status' => 429 ) );
            }
        }

        $dist_id     = (int) $req->get_param( 'dist_id' );
        $amount      = floatval( $req->get_param( 'amount' ) );
        $trans_ref   = sanitize_text_field( (string) $req->get_param( 'trans_ref' ) );
        $sender_name = sanitize_text_field( (string) $req->get_param( 'sender_name' ) );
        $reason      = sanitize_text_field( (string) $req->get_param( 'reason' ) );
        $image_b64   = (string) $req->get_param( 'image_base64' ); // optional — only if admin uploaded
        $image_mime  = sanitize_text_field( (string) $req->get_param( 'image_mime' ) );

        // Validation
        if ( $dist_id <= 0 || get_post_type( $dist_id ) !== 'distributor' ) {
            return new WP_Error( 'bad_dist', 'ไม่พบร้านที่เลือก', array( 'status' => 400 ) );
        }
        if ( $amount <= 0 || $amount > 10000000 ) {
            return new WP_Error( 'bad_amount', 'ยอดไม่ถูกต้อง (1 ถึง 10,000,000)', array( 'status' => 400 ) );
        }
        if ( $reason === '' || mb_strlen( $reason ) < 10 ) {
            return new WP_Error( 'bad_reason', 'ต้องระบุเหตุผลไม่น้อยกว่า 10 ตัวอักษร (audit trail)', array( 'status' => 400 ) );
        }
        if ( mb_strlen( $reason ) > 500 ) $reason = mb_substr( $reason, 0, 500 );

        $dist_name = get_the_title( $dist_id );
        $group_id  = function_exists( 'get_field' ) ? (string) get_field( 'line_group_id', $dist_id ) : '';

        // V.1.14 Round 49: Idempotency-Key wrap (CRITICAL retry-prone — debt subtract).
        // Admin "บันทึก Manual" double-click on slow b2b_debt_subtract + LINE push +
        // audit log → 2× debt subtract (FOR UPDATE prevents physical race BUT 2nd retry
        // AFTER 1st commit re-subtracts — V.1.4/V.1.6 GET_LOCK prevents within window
        // but cached idempotency replay extends protection across full TTL). Body hash
        // = single {dist_id, amount, trans_ref, sender_name} core — image_b64 EXCLUDED
        // (binary blob too large for idempotency_keys row; image_hash + trans_ref +
        // GET_LOCK provide layered defense already). reason EXCLUDED — admin may
        // correct text without triggering 409 (audit annotation only). Different
        // amount/dist_id/trans_ref mid-retry → 409 catches admin business decision
        // change (wrong dist clicked / amount typo / fresh trans_ref pasted).
        $idem_key       = function_exists( 'dinoco_idempotency_extract_key' ) ? dinoco_idempotency_extract_key( $req ) : '';
        $idem_namespace = 'dinoco-slip/v1::manual-process';
        $idem_body      = null;
        if ( $idem_key !== '' && function_exists( 'dinoco_idempotency_check' ) ) {
            $idem_body = array(
                'dist_id'     => $dist_id,
                'amount'      => round( $amount, 2 ),
                'trans_ref'   => $trans_ref,
                'sender_name' => $sender_name,
            );
            $cached = dinoco_idempotency_check( $idem_key, $idem_namespace, $idem_body );
            if ( is_wp_error( $cached ) ) {
                $err_data    = $cached->get_error_data();
                $status_code = ( is_array( $err_data ) && isset( $err_data['status'] ) ) ? (int) $err_data['status'] : 409;
                return new WP_Error(
                    'idempotency_conflict',
                    'Idempotency-Key ซ้ำกับ request เก่าที่มีข้อมูลต่างกัน',
                    array( 'status' => $status_code )
                );
            }
            if ( is_array( $cached ) ) {
                $resp = $cached;
                unset( $resp['_idem_code'] );
                return rest_ensure_response( $resp );
            }
        }

        // Duplicate guard — hash the uploaded image (if any) + trans_ref check
        $image_hash = '';
        $image_binary = '';
        if ( $image_b64 !== '' ) {
            // Strip data URI prefix if present
            if ( preg_match( '#^data:([^;]+);base64,(.*)$#', $image_b64, $m ) ) {
                if ( $image_mime === '' ) $image_mime = sanitize_text_field( $m[1] );
                $image_b64 = $m[2];
            }
            $image_binary = base64_decode( $image_b64, true );
            if ( $image_binary === false ) {
                return new WP_Error( 'bad_image', 'ไม่สามารถ decode รูปได้', array( 'status' => 400 ) );
            }
            // 10MB cap
            if ( strlen( $image_binary ) > 10 * 1024 * 1024 ) {
                return new WP_Error( 'image_too_large', 'รูปใหญ่เกิน 10MB', array( 'status' => 400 ) );
            }
            if ( function_exists( 'b2b_slip_compute_image_hash' ) ) {
                $image_hash = b2b_slip_compute_image_hash( $image_binary );
            }
            // Check duplicate by hash
            if ( $image_hash && function_exists( 'b2b_slip_find_prior_payment' ) ) {
                $prior = b2b_slip_find_prior_payment( $image_hash );
                if ( $prior ) {
                    return new WP_Error( 'image_already_paid',
                        'รูปสลิปนี้เคยตัดหนี้แล้ว (log id=' . (int) $prior['id']
                        . ' เมื่อ ' . ( $prior['created_at'] ?? '-' ) . ')',
                        array( 'status' => 409 ) );
                }
            }
        }
        // trans_ref duplicate check (bank-cleared dedup)
        if ( $trans_ref !== '' && function_exists( 'b2b_slip_is_trans_ref_seen' ) ) {
            if ( b2b_slip_is_trans_ref_seen( $trans_ref ) ) {
                return new WP_Error( 'transref_seen',
                    'TransRef นี้เคยถูกใช้แล้ว (dedup guard)',
                    array( 'status' => 409 ) );
            }
        }

        // Save image to disk for audit (optional — only if uploaded)
        $image_stored_url = '';
        if ( $image_binary !== '' ) {
            $uploads = wp_upload_dir();
            $ym = gmdate( 'Y-m' );
            $subdir = trailingslashit( $uploads['basedir'] ) . 'slip-manual/' . $ym;
            if ( ! is_dir( $subdir ) ) wp_mkdir_p( $subdir );
            $ext = 'jpg';
            if ( strpos( $image_mime, 'png' ) !== false )  $ext = 'png';
            if ( strpos( $image_mime, 'webp' ) !== false ) $ext = 'webp';
            $filename = ( $image_hash ? substr( $image_hash, 0, 40 ) : 'manual_' . time() ) . '.' . $ext;
            $full_path = trailingslashit( $subdir ) . $filename;
            // file_put_contents with LOCK_EX + silent failure (not fatal for debt mutation)
            @file_put_contents( $full_path, $image_binary, LOCK_EX );
            if ( file_exists( $full_path ) ) {
                $image_stored_url = trailingslashit( $uploads['baseurl'] ) . 'slip-manual/' . $ym . '/' . $filename;
            }
        }

        // ═════════════ ATOMIC DEBT SUBTRACT ═════════════
        if ( ! function_exists( 'b2b_debt_subtract' ) ) {
            return new WP_Error( 'no_debt_fn', 'b2b_debt_subtract ไม่พร้อม (Snippet 13)', array( 'status' => 501 ) );
        }

        // V.1.4 BUG-B FIX: MySQL GET_LOCK — guarantees ONE manual_process per dist+amount+trans_ref
        // at a time. Prevents double-click race where 2 REST calls arrive within 200ms before the
        // first b2b_slip_log_insert commits trans_ref → b2b_slip_is_trans_ref_seen() dedup miss →
        // double debt subtract + double Flex. Lock scoped to (dist_id, amount, trans_ref hash) so
        // different operations in parallel are not blocked.
        global $wpdb;
        $lock_key = 'dnc_mp_' . $dist_id . '_' . md5( (string) $amount . '|' . $trans_ref );
        // Lock names >64 chars are truncated by MySQL 5.7+ (not rejected). Our naming
        // (`dnc_mp_<dist_id>_<md5_hash>`) = 7 + ~10 + 1 + 32 = ~50 chars, well under limit.
        $lock_acquired = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 3)", $lock_key ) );
        if ( $lock_acquired !== 1 ) {
            return new WP_Error( 'concurrent_process',
                'มีคนกำลังทำ manual process อันเดียวกันอยู่ — กรุณารอสักครู่แล้วรีเฟรชดู',
                array( 'status' => 409 ) );
        }

        // V.1.6 H3 FIX: $log_id declared outside try-block so post-release LINE notify can reference it
        $log_id = 0;

        try {
            // Re-check dedup INSIDE the lock — first call wrote trans_ref, second call sees it
            if ( $trans_ref !== '' && function_exists( 'b2b_slip_is_trans_ref_seen' ) ) {
                if ( b2b_slip_is_trans_ref_seen( $trans_ref ) ) {
                    $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                    return new WP_Error( 'transref_seen_inlock',
                        'TransRef นี้เพิ่งถูก process ไปแล้ว (dedup in-lock)',
                        array( 'status' => 409 ) );
                }
            }

            $old_debt = function_exists( 'get_field' ) ? floatval( get_field( 'current_debt', $dist_id ) ) : 0;
            $reason_tag = 'manual_admin_slip:u=' . $uid . ':' . mb_substr( $reason, 0, 80 );
            $new_debt = b2b_debt_subtract( $dist_id, $amount, $reason_tag );
            if ( $new_debt === false ) {
                $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                return new WP_Error( 'debt_subtract_fail', 'ตัดหนี้ไม่สำเร็จ (debt_subtract คืน false)', array( 'status' => 500 ) );
            }

            // Reconstruct old_debt for overpayment calc (same pattern as auto slip flow)
            $overpaid_amount = ( $amount > $old_debt && $old_debt > 0 ) ? round( $amount - $old_debt, 2 ) : 0;
            $actual_paid = min( $amount, $old_debt > 0 ? $old_debt : $amount );
            if ( function_exists( 'get_field' ) ) {
                $mtd = floatval( get_field( 'monthly_sales_mtd', $dist_id ) );
                update_field( 'monthly_sales_mtd', round( $mtd + $actual_paid, 2 ), $dist_id );
                if ( $new_debt <= 0 ) update_field( 'credit_hold', false, $dist_id );
            }

            // Stamp trans_ref on matching orders + auto-mark paid (reuse existing flow)
            // V.1.4 BUG-A FIX: auto_mark_paid marks orders → changes order_status → affects
            // b2b_recalculate_debt result. MUST run BEFORE recalculate to get accurate $new_debt.
            // Previous order (recalc → auto_mark) returned stale debt = amount (since order was
            // still awaiting_payment at recalc time) → Flex showed "หนี้คงเหลือ = ฿amount" even
            // when actual debt was ฿0. Mirror b2b_handle_slip_image at Snippet 2 line 3051→3062.
            $paid_tickets = array();
            if ( function_exists( 'b2b_auto_mark_paid_after_slip' ) && $group_id !== '' ) {
                $match = b2b_auto_mark_paid_after_slip( $dist_id, $amount, $group_id );
                $paid_tickets = isset( $match['paid_tickets'] ) ? $match['paid_tickets'] : array();
                if ( $trans_ref !== '' ) {
                    foreach ( $paid_tickets as $pt ) {
                        update_post_meta( $pt['id'], '_slip_trans_ref', $trans_ref );
                    }
                }
            }

            // Recalc from source of truth AFTER auto_mark_paid — otherwise still reads awaiting_payment orders
            $new_debt = function_exists( 'b2b_recalculate_debt' ) ? b2b_recalculate_debt( $dist_id )
                        : ( function_exists( 'get_field' ) ? floatval( get_field( 'current_debt', $dist_id ) ) : $new_debt );

            // V.1.6 H3 FIX (Wave 2 audit): log_insert MUST happen INSIDE the lock window so that
            // a concurrent call's dedup check (b2b_slip_is_trans_ref_seen via slip_log table)
            // sees this row. Previous order: lock release → log_insert → next call dedup miss.
            // Now: log_insert → release. Log row commits its own transaction (atomic INSERT)
            // before RELEASE_LOCK so dedup query in any concurrent caller sees committed trans_ref.
            if ( function_exists( 'b2b_slip_log_insert' ) ) {
                $log_id = (int) b2b_slip_log_insert( array(
                    'group_id'      => $group_id,
                    'message_id'    => 'MANUAL_' . $uid . '_' . time(),
                    'user_id'       => (string) $uid,
                    'dist_id'       => $dist_id,
                    'slip_code'     => 'ADMIN',
                    'amount'        => $amount,
                    'trans_ref'     => $trans_ref,
                    'sender_name'   => $sender_name,
                    'result_status' => 'manual_admin_paid',
                    'error_code'    => 'ADMIN_MANUAL',
                    'error_msg'     => mb_substr( 'reason=' . $reason . ( $image_stored_url ? ' img=' . $image_stored_url : '' ), 0, 490 ),
                    'http_code'     => null,
                    'processing_time_ms' => null,
                    'retry_count'   => 0,
                    'image_hash'    => $image_hash ?: null,
                    'image_mime'    => $image_mime ?: null,
                    'slip2go_response' => null, // bypass → no API call
                ) );
            }
        } catch ( \Throwable $e ) {
            $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[Slip ManualProcess] FATAL dist=' . $dist_id . ' err=' . $e->getMessage() );
            }
            return new WP_Error( 'fatal', 'เกิด error ระหว่างประมวลผล: ' . mb_substr( $e->getMessage(), 0, 200 ),
                array( 'status' => 500 ) );
        }

        // V.1.6 H3 FIX: log_insert moved INSIDE try-block above (committed before RELEASE_LOCK).
        // Release lock AFTER log_insert so dedup query sees the trans_ref. LINE side-effects below
        // are still post-release (idempotent network calls — blocking retry window not justified).
        $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );

        // Notify LINE group (customer) + admin
        if ( function_exists( 'b2b_line_push' ) && $group_id !== '' ) {
            $notify = "✅ แอดมินตรวจสลิปและตัดหนี้ให้แล้ว\n"
                    . "ร้าน: " . $dist_name . "\n"
                    . "ยอด: ฿" . number_format( $amount, 2 );
            if ( $trans_ref !== '' ) $notify .= "\nRef: " . $trans_ref;
            $notify .= "\nหนี้คงเหลือ: ฿" . number_format( $new_debt, 2 );
            if ( $new_debt <= 0 ) $notify .= "\n\n🎉 ชำระครบแล้วครับ!";
            b2b_line_push( $group_id, $notify );
        }
        if ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin(
                "🛠️ Admin Manual Process (slip bypass)\n"
                . "Admin: user#" . $uid . "\n"
                . "ร้าน: " . $dist_name . "\n"
                . "ยอด: ฿" . number_format( $amount, 2 ) . "\n"
                . "Ref: " . ( $trans_ref !== '' ? $trans_ref : '-' ) . "\n"
                . "ผู้โอน: " . ( $sender_name !== '' ? $sender_name : '-' ) . "\n"
                . "หนี้เหลือ: ฿" . number_format( $new_debt, 2 ) . "\n"
                . "Log id: #" . $log_id . "\n"
                . "Reason: " . mb_substr( $reason, 0, 200 )
                . ( $overpaid_amount > 0 ? "\n⚠️ โอนเกิน ฿" . number_format( $overpaid_amount, 2 ) : '' )
            );
        }
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( '[Slip ManualProcess] admin=' . $uid . ' dist=' . $dist_id
                . ' amount=' . $amount . ' new_debt=' . $new_debt . ' log_id=' . $log_id );
        }

        // V.1.7 Phase 1.5: unified forensic chain (best-effort INDEX overlay).
        // Ties manual override → b2b_debt_subtract (already audited) → b2b_auto_mark_paid
        // (slip_apply audit) via shared request_id. related_log_id links to slip_log row.
        if ( function_exists( 'dinoco_audit_log' ) ) {
            dinoco_audit_log( array(
                'event_type'    => 'manual_admin_paid',
                'actor_type'    => 'admin',
                'actor_id'      => (string) $uid,
                'target_type'   => 'distributor',
                'target_id'     => (string) $dist_id,
                'amount'        => (float) $amount,
                'delta_before'  => (string) round( $old_debt, 2 ),
                'delta_after'   => (string) round( $new_debt, 2 ),
                'related_log_id' => $log_id ? (int) $log_id : null,
                'context'       => array(
                    'reason'        => $reason,
                    'trans_ref'     => $trans_ref,
                    'sender_name'   => $sender_name,
                    'image_hash'    => $image_hash ?: null,
                    'overpaid'      => $overpaid_amount > 0 ? $overpaid_amount : null,
                    'paid_tickets'  => array_map( function ( $t ) { return (int) $t['id']; }, $paid_tickets ),
                ),
            ) );
        }

        $resp = array(
            'success'        => true,
            'log_id'         => $log_id,
            'dist_id'        => $dist_id,
            'dist_name'      => $dist_name,
            'old_debt'       => round( $old_debt, 2 ),
            'new_debt'       => round( $new_debt, 2 ),
            'amount'         => $amount,
            'overpaid'       => $overpaid_amount,
            'paid_tickets'   => array_map( function ( $t ) { return (int) $t['id']; }, $paid_tickets ),
            'image_hash'     => $image_hash,
            'image_stored_url' => $image_stored_url,
            'message'        => 'ตัดหนี้ ฿' . number_format( $amount, 2 ) . ' สำเร็จ — หนี้เหลือ ฿' . number_format( $new_debt, 2 ),
        );

        // V.1.14 Round 49: store cached replay payload for double-click protection.
        if ( $idem_key !== '' && $idem_body !== null && function_exists( 'dinoco_idempotency_store' ) ) {
            dinoco_idempotency_store(
                $idem_key,
                $idem_namespace,
                $idem_body,
                array_merge( $resp, array( '_idem_code' => 200 ) ),
                200
            );
        }

        return rest_ensure_response( $resp );
    }
}

// ────────────────────────────────────────────────────────────────
// GET /replay-candidates — rows with slip2go_response cached + not yet success
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_replay_candidates' ) ) {
    function dinoco_slip_monitor_rest_replay_candidates( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $table_exists ) {
            return rest_ensure_response( array( 'success' => true, 'rows' => array(), 'table_missing' => true ) );
        }
        // Check column existence (pre-V.8.6 tables miss it)
        $col_exists = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(1) FROM INFORMATION_SCHEMA.COLUMNS
             WHERE table_schema = DATABASE() AND table_name = %s AND column_name = 'slip2go_response'",
            $table
        ) );
        if ( ! $col_exists ) {
            return rest_ensure_response( array(
                'success' => true, 'rows' => array(),
                'schema_missing' => true,
                'note' => 'wp_dinoco_slip_log.slip2go_response ยังไม่มี — ต้องรัน Snippet 15 V.8.6 migration ก่อน',
            ) );
        }
        $days = max( 1, min( 30, (int) $req->get_param( 'days' ) ?: 7 ) );

        // Replay-able: has cached response + status in "our failure" set
        // Exclude rows already replayed-from (prevent chain-replay confusion)
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, group_id, dist_id, amount, trans_ref, sender_name, result_status,
                    error_code, error_msg, image_hash, created_at
             FROM {$table}
             WHERE created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
               AND slip2go_response IS NOT NULL
               AND result_status IN (
                   'line_api_error','data_missing','unregistered_group',
                   'fatal_exception','unknown_slip_code','no_distributor'
               )
             ORDER BY id DESC
             LIMIT 200",
            $days
        ), ARRAY_A );

        $gids = array();
        foreach ( $rows as $r ) { if ( ! empty( $r['group_id'] ) ) $gids[] = $r['group_id']; }
        $name_map = dinoco_slip_monitor_get_dist_names_batch( $gids );
        foreach ( $rows as &$row ) {
            $row['dist_name'] = isset( $name_map[ $row['group_id'] ] ) ? $name_map[ $row['group_id'] ] : '';
        }
        unset( $row );

        return rest_ensure_response( array(
            'success' => true, 'days' => $days, 'count' => count( $rows ), 'rows' => $rows,
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// POST /replay-slip — rerun cascade from cached slip2go_response
// Body: { log_id }
// Note: Re-invokes b2b_handle_slip_image() — the cascade there will detect the
//       image_hash + cached response and route to path (b) automatically.
//       BUT b2b_handle_slip_image fetches from LINE Content API by message_id
//       which is stale (LINE Content expires in 24h). We bypass by directly
//       dispatching the cached response through the processing branches.
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_replay_slip' ) ) {
    function dinoco_slip_monitor_rest_replay_slip( WP_REST_Request $req ) {
        $uid = get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_replay_u' . $uid, 5, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 5/min)', array( 'status' => 429 ) );
            }
        }
        $log_id = (int) $req->get_param( 'log_id' );
        if ( $log_id <= 0 ) {
            return new WP_Error( 'bad_log_id', 'log_id ไม่ถูกต้อง', array( 'status' => 400 ) );
        }
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, group_id, message_id, user_id, image_hash, slip2go_response, result_status
             FROM {$table} WHERE id = %d",
            $log_id
        ), ARRAY_A );
        if ( ! $row ) {
            return new WP_Error( 'not_found', 'ไม่พบ log row', array( 'status' => 404 ) );
        }
        if ( empty( $row['slip2go_response'] ) ) {
            return new WP_Error( 'no_cache', 'row นี้ไม่มี cached response', array( 'status' => 422 ) );
        }

        // Safety — don't replay success states (already applied)
        if ( in_array( $row['result_status'], array( 'paid', 'paid_overpayment', 'manual_admin_paid', 'duplicate' ), true ) ) {
            return new WP_Error( 'already_resolved',
                'Row นี้ถูก resolve แล้ว (' . $row['result_status'] . ') — ห้าม replay',
                array( 'status' => 409 ) );
        }

        // Strategy: re-invoke b2b_handle_slip_image with the original message_id.
        // Inside the cascade, path (b) will fire if image_hash matches + cached response found.
        // Downside: LINE Content might be expired → falls back to path (d) fresh call (same bug as before).
        // Better: directly process the cached response by synthesizing a minimal in-process call.
        // For V.1.3 we implement the simpler "re-invoke" — admin has Manual Process Tool as fallback.

        if ( ! function_exists( 'b2b_handle_slip_image' ) ) {
            return new WP_Error( 'no_handler', 'b2b_handle_slip_image ไม่พร้อม', array( 'status' => 501 ) );
        }

        // Fire handler — will attempt LINE Content download (often 24h expired); if expired,
        // it returns line_api_error but admin knows to use Manual Process Tool instead.
        try {
            b2b_handle_slip_image( (string) $row['message_id'], (string) $row['group_id'], (string) $row['user_id'], '', false );
        } catch ( \Throwable $e ) {
            return new WP_Error( 'replay_exception', $e->getMessage(), array( 'status' => 500 ) );
        }

        return rest_ensure_response( array(
            'success' => true,
            'log_id'  => $log_id,
            'message' => 'Replay triggered — ดู Recent 50 Attempts ว่า process สำเร็จหรือไม่. ถ้า LINE Content หมดอายุ (>24h) ให้ใช้ Manual Process Tool แทน',
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// V.1.9: GET /needs-review?days=30 — list pool entries
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_needs_review' ) ) {
    function dinoco_slip_monitor_rest_needs_review( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $exists ) {
            return rest_ensure_response( array( 'success' => true, 'rows' => array(), 'count' => 0, 'table_missing' => true ) );
        }
        // Schema check — image_path column may not exist on legacy installs
        $col_exists = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(1) FROM INFORMATION_SCHEMA.COLUMNS
             WHERE table_schema = DATABASE() AND table_name = %s AND column_name = 'image_path'",
            $table
        ) );
        if ( ! $col_exists ) {
            return rest_ensure_response( array(
                'success'        => true,
                'rows'           => array(),
                'count'          => 0,
                'schema_missing' => true,
                'note'           => 'Snippet 15 V.8.11+ ต้อง sync ก่อน — schema ยังไม่มี image_path/review_decision columns',
            ) );
        }

        $days = max( 1, min( 90, (int) $req->get_param( 'days' ) ?: 30 ) );

        // Pending (not yet reviewed) entries with image_path or status in needs_review/unknown_slip_code
        // Bounded LIMIT 50 — pool UI is decisional, not analytical (use /recent for full audit).
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, group_id, message_id, user_id, dist_id, slip_code, amount, trans_ref, sender_name,
                    result_status, error_code, error_msg, image_hash, image_mime, image_path,
                    review_decision, reviewed_at, reviewed_by, created_at
             FROM {$table}
             WHERE result_status IN ('needs_review','unknown_slip_code')
               AND review_decision IS NULL
               AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
             ORDER BY id DESC
             LIMIT 50",
            $days
        ), ARRAY_A );

        // Enrich with dist_name (batch JOIN — not N+1)
        $gids = array();
        foreach ( $rows as $r ) { if ( ! empty( $r['group_id'] ) ) $gids[] = $r['group_id']; }
        $name_map = function_exists( 'dinoco_slip_monitor_get_dist_names_batch' )
            ? dinoco_slip_monitor_get_dist_names_batch( $gids )
            : array();
        foreach ( $rows as &$row ) {
            $row['dist_name'] = isset( $name_map[ $row['group_id'] ] ) ? $name_map[ $row['group_id'] ] : '';
            // Image proxy URL (admin-only via REST permission_callback)
            if ( ! empty( $row['image_path'] ) ) {
                $row['image_url'] = rest_url( 'dinoco-slip/v1/pool-image' ) . '?id=' . (int) $row['id'];
            } else {
                $row['image_url'] = '';
            }
        }
        unset( $row );

        // Total count for stat card
        $count_30d = (int) $wpdb->get_var(
            "SELECT COUNT(*) FROM {$table}
             WHERE result_status IN ('needs_review','unknown_slip_code')
               AND review_decision IS NULL
               AND created_at >= DATE_SUB(NOW(), INTERVAL 30 DAY)"
        );

        return rest_ensure_response( array(
            'success' => true,
            'rows'    => $rows,
            'count'   => count( $rows ),
            'total_30d' => $count_30d,
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// V.1.9: POST /review-decision
// Body: { log_id, decision: 'is_slip'|'not_slip', delete_image?: bool }
// Note: 'is_slip' decision = informational only (admin still uses Manual Process tool
//        separately to actually subtract debt). This endpoint is the audit-trail step.
//        For not_slip: image is deleted from disk to free PII.
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_review_decision' ) ) {
    function dinoco_slip_monitor_rest_review_decision( WP_REST_Request $req ) {
        $uid = get_current_user_id();
        // Rate limit 10/min/user (review actions are bursty during admin pool sweep)
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_review_u' . $uid, 10, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 10/min)', array( 'status' => 429 ) );
            }
        }

        $log_id   = (int) $req->get_param( 'log_id' );
        $decision = sanitize_text_field( (string) $req->get_param( 'decision' ) );
        $delete_image = (bool) $req->get_param( 'delete_image' );

        if ( $log_id <= 0 ) {
            return new WP_Error( 'bad_log_id', 'log_id ไม่ถูกต้อง', array( 'status' => 400 ) );
        }
        $allowed_decisions = array( 'is_slip', 'not_slip', 'manual_process' );
        if ( ! in_array( $decision, $allowed_decisions, true ) ) {
            return new WP_Error( 'bad_decision',
                'decision ต้องเป็น is_slip|not_slip|manual_process',
                array( 'status' => 400 ) );
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, image_path, review_decision FROM {$table} WHERE id = %d",
            $log_id
        ), ARRAY_A );
        if ( ! $row ) {
            return new WP_Error( 'not_found', 'ไม่พบ log row', array( 'status' => 404 ) );
        }
        if ( ! empty( $row['review_decision'] ) ) {
            return new WP_Error( 'already_reviewed',
                'รายการนี้ถูก review แล้วเมื่อ — ไม่สามารถเปลี่ยน decision ได้ (audit lock)',
                array( 'status' => 409 ) );
        }

        // For 'not_slip' decision → delete image from disk (PII hygiene, no further use)
        $image_deleted = false;
        if ( $decision === 'not_slip' || $delete_image ) {
            if ( ! empty( $row['image_path'] ) ) {
                $uploads = wp_upload_dir();
                if ( ! empty( $uploads['basedir'] ) ) {
                    $rel = (string) $row['image_path'];
                    // Defensive: reject path traversal
                    if ( strpos( $rel, '..' ) === false && strpos( $rel, ':' ) === false ) {
                        $abs = trailingslashit( $uploads['basedir'] ) . ltrim( $rel, '/' );
                        if ( file_exists( $abs ) ) {
                            $image_deleted = (bool) @unlink( $abs );
                        }
                    }
                }
            }
        }

        // Update DB row — atomic UPDATE
        $upd_data = array(
            'review_decision' => $decision,
            'reviewed_at'     => current_time( 'mysql' ),
            'reviewed_by'     => $uid,
        );
        $upd_fmt = array( '%s', '%s', '%d' );
        // Null out image_path if file deleted
        if ( $image_deleted ) {
            $upd_data['image_path'] = null;
            $upd_fmt[] = '%s';
        }
        $ok = $wpdb->update( $table, $upd_data, array( 'id' => $log_id ), $upd_fmt, array( '%d' ) );
        if ( $ok === false ) {
            return new WP_Error( 'db_error',
                'อัพเดท DB ไม่สำเร็จ: ' . $wpdb->last_error,
                array( 'status' => 500 ) );
        }

        // Forensic log via b2b_log + audit_log overlay (Phase 1.5)
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( '[SlipReview] decision=' . $decision . ' log_id=' . $log_id
                . ' admin_uid=' . $uid . ' image_deleted=' . ( $image_deleted ? '1' : '0' ) );
        }
        if ( function_exists( 'dinoco_audit_log' ) ) {
            dinoco_audit_log( array(
                'event_type'     => 'slip_review_decision',
                'actor_type'     => 'admin',
                'actor_id'       => (string) $uid,
                'target_type'    => 'slip_log',
                'target_id'      => (string) $log_id,
                'context_json'   => wp_json_encode( array(
                    'decision' => $decision,
                    'image_deleted' => $image_deleted,
                ) ),
                'success'        => 1,
            ) );
        }

        return rest_ensure_response( array(
            'success'       => true,
            'log_id'        => $log_id,
            'decision'      => $decision,
            'image_deleted' => $image_deleted,
            'message'       => $decision === 'is_slip'
                ? 'บันทึกแล้ว — ใช้ Manual Process Tool เพื่อตัดหนี้จริง'
                : ( $decision === 'manual_process'
                    ? 'บันทึกแล้ว — ลิงก์กับ manual_process แล้ว'
                    : 'บันทึกแล้ว — รูปถูกลบแล้ว (ไม่ใช่สลิป)' ),
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// V.1.9: GET /pool-image?id={log_id} — image proxy (admin-only)
// Streams pool image from wp-content/uploads/slip-pool/ (which is
// .htaccess-blocked from public web access) with admin-only cap check.
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_pool_image' ) ) {
    function dinoco_slip_monitor_rest_pool_image( WP_REST_Request $req ) {
        $log_id = (int) $req->get_param( 'id' );
        if ( $log_id <= 0 ) {
            return new WP_Error( 'bad_id', 'id ต้องเป็นเลข log_id', array( 'status' => 400 ) );
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT image_path, image_mime FROM {$table} WHERE id = %d",
            $log_id
        ), ARRAY_A );
        if ( ! $row || empty( $row['image_path'] ) ) {
            return new WP_Error( 'no_image', 'ไม่พบรูปสำหรับ log นี้', array( 'status' => 404 ) );
        }

        $uploads = wp_upload_dir();
        if ( empty( $uploads['basedir'] ) ) {
            return new WP_Error( 'uploads_unset', 'wp_upload_dir basedir ไม่ตั้ง', array( 'status' => 500 ) );
        }

        $rel = (string) $row['image_path'];
        // Defensive: reject path traversal + absolute paths
        if ( strpos( $rel, '..' ) !== false || strpos( $rel, ':' ) !== false ) {
            return new WP_Error( 'bad_path', 'path น่าสงสัย', array( 'status' => 400 ) );
        }
        $abs = trailingslashit( $uploads['basedir'] ) . ltrim( $rel, '/' );

        // Ensure file is inside uploads/ (defense-in-depth — realpath check)
        $real_uploads = realpath( $uploads['basedir'] );
        $real_target  = realpath( $abs );
        if ( ! $real_target || ! $real_uploads || strpos( $real_target, $real_uploads ) !== 0 ) {
            return new WP_Error( 'bad_path', 'file path นอก uploads/', array( 'status' => 403 ) );
        }
        if ( ! file_exists( $abs ) ) {
            return new WP_Error( 'file_missing', 'file ไม่อยู่บน disk แล้ว (อาจถูก cleanup cron ลบ)', array( 'status' => 410 ) );
        }

        $mime = $row['image_mime'] ?: 'image/jpeg';
        // Whitelist mime types
        if ( ! in_array( $mime, array( 'image/jpeg', 'image/png', 'image/webp' ), true ) ) {
            $mime = 'image/jpeg';
        }

        // Stream file with caching headers (admin-only — short cache OK)
        nocache_headers();
        header( 'Content-Type: ' . $mime );
        header( 'Content-Length: ' . filesize( $abs ) );
        header( 'X-Content-Type-Options: nosniff' );
        header( 'Content-Disposition: inline; filename="slip-pool-' . $log_id . '"' );
        readfile( $abs );
        exit;
    }
}

// ────────────────────────────────────────────────────────────────
// V.1.10: GET /ai-stats?days=1 — AI classifier metrics + savings estimate
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_ai_stats' ) ) {
    function dinoco_slip_monitor_rest_ai_stats( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $days = max( 1, min( 90, (int) $req->get_param( 'days' ) ?: 1 ) );

        // V.1.11: Phase 4c — Config Layer with raw fallback
        $enabled = function_exists( 'dinoco_config' )
            ? (bool) dinoco_config( 'slip.ai_classifier_enabled', true )
            : (bool) get_option( 'b2b_slip_ai_classifier_enabled', 1 );
        $api_key_set = defined( 'B2B_ANTHROPIC_API_KEY' ) && B2B_ANTHROPIC_API_KEY !== '';

        // Probe AI columns exist (silent on legacy installs)
        $ai_cols_exist = (bool) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(1) FROM INFORMATION_SCHEMA.COLUMNS
             WHERE table_schema = DATABASE() AND table_name = %s AND column_name = 'ai_classifier_decision'",
            $table
        ) );

        $count_not_slip_ai = 0;
        $total_ai_runs    = 0;
        $cache_hits       = 0;
        $cache_misses     = 0;

        if ( $ai_cols_exist ) {
            // count_not_slip_ai = how many slips were AI-blocked (Slip2Go quota saved)
            $count_not_slip_ai = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$table}
                 WHERE result_status = 'not_slip_ai'
                   AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)",
                $days
            ) );

            // total_ai_runs = how many slip_log rows have ai_classifier_at populated
            $total_ai_runs = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$table}
                 WHERE ai_classifier_at IS NOT NULL
                   AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)",
                $days
            ) );

            // cache_hits — rows whose ai_classifier_reason starts with 'cached:' (Snippet 1 marker)
            $cache_hits = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$table}
                 WHERE ai_classifier_reason LIKE 'cached:%%'
                   AND created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)",
                $days
            ) );
            $cache_misses = max( 0, $total_ai_runs - $cache_hits );
        }

        // Savings estimate: each AI-blocked slip saved a Slip2Go call (~5 baht avg)
        $estimated_savings_baht = $count_not_slip_ai * 5;
        $cached_hit_rate = $total_ai_runs > 0 ? round( 100 * $cache_hits / $total_ai_runs, 1 ) : 0;

        return rest_ensure_response( array(
            'success'                => true,
            'ai_enabled'             => $enabled,
            'api_key_set'            => $api_key_set,
            'ai_cols_exist'          => $ai_cols_exist,
            'days'                   => $days,
            'count_not_slip_ai'      => $count_not_slip_ai,
            'total_ai_runs'          => $total_ai_runs,
            'cache_hits'             => $cache_hits,
            'cache_misses'           => $cache_misses,
            'cached_hit_rate'        => $cached_hit_rate,
            'estimated_savings_baht' => $estimated_savings_baht,
        ) );
    }
}

