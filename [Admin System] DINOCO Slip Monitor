// ────────────────────────────────────────────────────────────────
// GET /monitor — Dashboard summary (stats + active locks + queues)
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_get' ) ) {
    function dinoco_slip_monitor_rest_get( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';

        // Stats 24h
        $stats_24h = array(
            'total' => 0, 'paid' => 0, 'duplicate' => 0,
            'receiver_mismatch' => 0, 'amount_mismatch' => 0, 'amount_no_pending' => 0,
            'slip2go_error' => 0, 'line_api_error' => 0,
            'queued' => 0, 'not_slip' => 0, 'unregistered_group' => 0,
            'other' => 0,
        );
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( $table_exists ) {
            $results = $wpdb->get_results(
                "SELECT result_status, COUNT(*) AS cnt FROM {$table}
                 WHERE created_at >= DATE_SUB(NOW(), INTERVAL 24 HOUR)
                 GROUP BY result_status"
            );
            foreach ( $results as $r ) {
                $status = $r->result_status;
                $cnt = (int) $r->cnt;
                $stats_24h['total'] += $cnt;
                if ( array_key_exists( $status, $stats_24h ) ) {
                    $stats_24h[ $status ] += $cnt;
                } else {
                    $stats_24h['other'] += $cnt;
                }
            }
        }

        // Active locks + queues
        $locks = array();
        $lock_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT option_name, option_value FROM {$wpdb->options} WHERE option_name LIKE %s",
            $wpdb->esc_like( '_transient_timeout_b2b_slip_lock_' ) . '%'
        ) );
        $now = time();
        foreach ( $lock_rows as $r ) {
            $gid = substr( $r->option_name, strlen( '_transient_timeout_b2b_slip_lock_' ) );
            if ( $gid === '' ) continue;
            $expires_at = (int) $r->option_value;
            $dist_name = dinoco_slip_monitor_get_dist_name( $gid );
            $locks[] = array(
                'group_id'     => $gid,
                'dist_name'    => $dist_name,
                'expires_at'   => $expires_at,
                'remaining_s'  => max( 0, $expires_at - $now ),
                'is_stuck'     => ( $expires_at > 0 && ( $now - $expires_at ) > 120 ),
            );
        }

        $queues = array();
        $queue_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT option_name, option_value FROM {$wpdb->options} WHERE option_name LIKE %s",
            $wpdb->esc_like( 'b2b_slip_queue_' ) . '%'
        ) );
        foreach ( $queue_rows as $r ) {
            $gid = substr( $r->option_name, strlen( 'b2b_slip_queue_' ) );
            if ( $gid === '' ) continue;
            $queue = maybe_unserialize( $r->option_value );
            if ( ! is_array( $queue ) || empty( $queue ) ) continue;
            $oldest = PHP_INT_MAX;
            foreach ( $queue as $q ) {
                $t = (int) ( $q['time'] ?? 0 );
                if ( $t > 0 && $t < $oldest ) $oldest = $t;
            }
            $queues[] = array(
                'group_id'       => $gid,
                'dist_name'      => dinoco_slip_monitor_get_dist_name( $gid ),
                'size'           => count( $queue ),
                'oldest_age_min' => $oldest < PHP_INT_MAX ? (int) round( ( $now - $oldest ) / 60 ) : 0,
            );
        }

        // Slip2Go health
        $s2g_health = array(
            'err_count_10min' => (int) get_transient( 'b2b_slip2go_err_count' ),
            'admin_alerted'   => (bool) get_transient( 'b2b_slip2go_alerted' ),
        );

        // Success rate
        $success_rate = 0;
        if ( $stats_24h['total'] > 0 ) {
            $success_rate = round( 100 * ( $stats_24h['paid'] + $stats_24h['duplicate'] ) / $stats_24h['total'], 1 );
        }

        return rest_ensure_response( array(
            'success'       => true,
            'table_exists'  => $table_exists,
            'stats_24h'     => $stats_24h,
            'success_rate'  => $success_rate,
            'active_locks'  => $locks,
            'active_queues' => $queues,
            'slip2go'       => $s2g_health,
            'now'           => $now,
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// GET /recent?limit=50&status=&group_id=
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_recent' ) ) {
    function dinoco_slip_monitor_rest_recent( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $table_exists ) {
            return rest_ensure_response( array( 'success' => true, 'rows' => array(), 'table_missing' => true ) );
        }

        $limit = max( 1, min( 200, (int) $req->get_param( 'limit' ) ?: 50 ) );
        $status = sanitize_text_field( (string) $req->get_param( 'status' ) );
        $group_id = sanitize_text_field( (string) $req->get_param( 'group_id' ) );

        $where = array( '1=1' );
        $params = array();
        if ( $status !== '' ) {
            $where[] = 'result_status = %s';
            $params[] = $status;
        }
        if ( $group_id !== '' ) {
            $where[] = 'group_id = %s';
            $params[] = $group_id;
        }
        $params[] = $limit;

        $sql = "SELECT id, group_id, message_id, user_id, dist_id, slip_code, amount, trans_ref, sender_name,
                       result_status, error_code, error_msg, http_code, processing_time_ms, retry_count, created_at
                FROM {$table}
                WHERE " . implode( ' AND ', $where ) . "
                ORDER BY id DESC
                LIMIT %d";
        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $params ), ARRAY_A );

        // V.1.1 M-4: batch enrich (single JOIN query, previously N+1 get_posts)
        $gids = array();
        foreach ( $rows as $r ) { if ( ! empty( $r['group_id'] ) ) $gids[] = $r['group_id']; }
        $name_map = dinoco_slip_monitor_get_dist_names_batch( $gids );
        foreach ( $rows as &$row ) {
            $row['dist_name'] = isset( $name_map[ $row['group_id'] ] ) ? $name_map[ $row['group_id'] ] : '';
        }
        unset( $row );

        return rest_ensure_response( array( 'success' => true, 'rows' => $rows ) );
    }
}

// ────────────────────────────────────────────────────────────────
// POST /clear-locks — force-unlock specific group or all
// Body: { group_id: '', reason: '' }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_clear_locks' ) ) {
    function dinoco_slip_monitor_rest_clear_locks( WP_REST_Request $req ) {
        // Rate limit 5/min per user (reuse b2b_rate_limit if available)
        $uid = get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_clear_locks_u' . $uid, 5, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 5/min)', array( 'status' => 429 ) );
            }
        }

        if ( ! function_exists( 'b2b_slip_clear_locks' ) ) {
            return new WP_Error( 'missing_helper', 'ต้อง Snippet 1 V.34.8+ ก่อน', array( 'status' => 501 ) );
        }

        $group_id = sanitize_text_field( (string) $req->get_param( 'group_id' ) );
        $reason   = sanitize_text_field( (string) $req->get_param( 'reason' ) ?: 'admin_manual' );

        $result = b2b_slip_clear_locks( $group_id, 'admin:' . $uid . ':' . $reason );
        return rest_ensure_response( array( 'success' => true, 'data' => $result ) );
    }
}

// ────────────────────────────────────────────────────────────────
// GET /missed-sweep — Forensic audit: สลิปที่ process แล้วไม่เจอ order match ในช่วง 30d
// ใช้ตรวจย้อนหลังว่ามีสลิปหายก่อนหน้านี้ที่บอสไม่รู้มั้ย
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_missed_sweep' ) ) {
    function dinoco_slip_monitor_rest_missed_sweep( WP_REST_Request $req ) {
        // V.1.1 M-6: rate-limit 10/min/user. Forensic sweep scans up to 500 rows across
        // 90 days — admin could spam it during debug panic and lock the table. Same
        // pattern as /clear-locks.
        $uid = get_current_user_id();
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_missed_sweep_u' . $uid, 10, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 10/min)', array( 'status' => 429 ) );
            }
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $table_exists ) {
            return rest_ensure_response( array( 'success' => true, 'rows' => array(), 'table_missing' => true ) );
        }

        $days = max( 1, min( 90, (int) $req->get_param( 'days' ) ?: 30 ) );

        // สลิปที่:
        //   • result_status = 'slip2go_error' หรือ 'line_api_error' หรือ 'unregistered_group'
        //     (= สลิปที่ระบบไม่ประมวลผลสำเร็จ)
        //   • result_status = 'amount_no_pending' (= match ผิดร้าน admin ต้อง manual)
        //   • result_status = 'no_distributor' (= Slip2Go OK แต่ไม่มี dist CPT)
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT id, group_id, message_id, user_id, dist_id, slip_code, amount, trans_ref,
                    sender_name, result_status, error_code, error_msg, http_code, created_at
             FROM {$table}
             WHERE created_at >= DATE_SUB(NOW(), INTERVAL %d DAY)
               AND result_status IN ('slip2go_error','line_api_error','unregistered_group','amount_no_pending','no_distributor','data_missing','unknown_slip_code')
             ORDER BY created_at DESC
             LIMIT 500",
            $days
        ), ARRAY_A );

        // V.1.1 M-4: batch enrich (single JOIN query, was N+1 across up to 500 rows)
        $gids = array();
        foreach ( $rows as $r ) { if ( ! empty( $r['group_id'] ) ) $gids[] = $r['group_id']; }
        $name_map = dinoco_slip_monitor_get_dist_names_batch( $gids );
        foreach ( $rows as &$row ) {
            $row['dist_name'] = isset( $name_map[ $row['group_id'] ] ) ? $name_map[ $row['group_id'] ] : '';
        }
        unset( $row );

        // Breakdown
        $breakdown = array();
        foreach ( $rows as $r ) {
            $s = $r['result_status'];
            if ( ! isset( $breakdown[ $s ] ) ) $breakdown[ $s ] = 0;
            $breakdown[ $s ]++;
        }

        return rest_ensure_response( array(
            'success' => true,
            'days' => $days,
            'count' => count( $rows ),
            'breakdown' => $breakdown,
            'rows' => $rows,
        ) );
    }
}

// ────────────────────────────────────────────────────────────────
// Helper: get distributor name (cached per-request)
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_get_dist_name' ) ) {
    function dinoco_slip_monitor_get_dist_name( $group_id ) {
        static $cache = array();
        if ( ! $group_id ) return '';
        if ( isset( $cache[ $group_id ] ) ) return $cache[ $group_id ];
        // V.1.1 M-4: single-row fallback uses batch helper so the same static cache
        // is populated — subsequent calls in the same request hit the cache.
        $map = dinoco_slip_monitor_get_dist_names_batch( array( $group_id ) );
        $name = isset( $map[ $group_id ] ) ? $map[ $group_id ] : '';
        $cache[ $group_id ] = $name;
        return $name;
    }
}

// ────────────────────────────────────────────────────────────────
// V.1.1 M-4: Batch distributor-name lookup — single JOIN query
// Replaces per-row get_posts() (was N+1 across /recent + /missed-sweep).
// 50-row /recent call: 50 meta_query get_posts → 1 JOIN. ~400ms saved per load.
// Returns [ group_id => title ] map. Unknown groups map to empty string.
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_get_dist_names_batch' ) ) {
    function dinoco_slip_monitor_get_dist_names_batch( $group_ids ) {
        static $cache = array();
        if ( empty( $group_ids ) || ! is_array( $group_ids ) ) return array();

        // Normalize + dedup + filter empty
        $group_ids = array_unique( array_filter( array_map( 'strval', $group_ids ), 'strlen' ) );
        if ( empty( $group_ids ) ) return array();

        // Return from cache where possible; query only uncached ids
        $result = array();
        $missing = array();
        foreach ( $group_ids as $gid ) {
            if ( array_key_exists( $gid, $cache ) ) {
                $result[ $gid ] = $cache[ $gid ];
            } else {
                $missing[] = $gid;
            }
        }
        if ( empty( $missing ) ) return $result;

        global $wpdb;
        if ( ! $wpdb ) {
            foreach ( $missing as $gid ) { $result[ $gid ] = ''; $cache[ $gid ] = ''; }
            return $result;
        }

        $placeholders = implode( ',', array_fill( 0, count( $missing ), '%s' ) );
        $sql = "SELECT pm.meta_value AS gid, p.post_title AS name
                FROM {$wpdb->posts} p
                INNER JOIN {$wpdb->postmeta} pm ON pm.post_id = p.ID
                WHERE p.post_type = 'distributor'
                  AND pm.meta_key = 'line_group_id'
                  AND pm.meta_value IN ({$placeholders})";
        // post_status='any' semantics preserved by omitting post_status filter — a later
        // admin could repurpose a trashed distributor post and we still want to show
        // its title in audit logs for historical accuracy.
        $rows = $wpdb->get_results( $wpdb->prepare( $sql, $missing ), ARRAY_A );

        $found = array();
        if ( is_array( $rows ) ) {
            foreach ( $rows as $row ) {
                $found[ (string) $row['gid'] ] = (string) $row['name'];
            }
        }

        // Populate cache + result for ALL requested ids (unknown → '')
        foreach ( $missing as $gid ) {
            $name = isset( $found[ $gid ] ) ? $found[ $gid ] : '';
            $cache[ $gid ] = $name;
            $result[ $gid ] = $name;
        }

        return $result;
    }
}

