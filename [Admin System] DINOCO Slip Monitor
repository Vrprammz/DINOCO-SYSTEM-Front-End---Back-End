// ────────────────────────────────────────────────────────────────
// GET /distributors — active CPTs (id, name, group_id, current_debt)
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_distributors' ) ) {
    function dinoco_slip_monitor_rest_distributors( WP_REST_Request $req ) {
        $posts = get_posts( array(
            'post_type'      => 'distributor',
            'post_status'    => 'publish',
            'posts_per_page' => 500,
            'orderby'        => 'title',
            'order'          => 'ASC',
            'fields'         => 'ids',
        ) );
        $out = array();
        foreach ( $posts as $pid ) {
            $debt = function_exists( 'get_field' ) ? floatval( get_field( 'current_debt', $pid ) ) : 0;
            $gid  = function_exists( 'get_field' ) ? (string) get_field( 'line_group_id', $pid ) : '';
            $out[] = array(
                'id'           => (int) $pid,
                'name'         => (string) get_the_title( $pid ),
                'group_id'     => $gid,
                'current_debt' => round( $debt, 2 ),
            );
        }
        return rest_ensure_response( array( 'success' => true, 'rows' => $out ) );
    }
}

