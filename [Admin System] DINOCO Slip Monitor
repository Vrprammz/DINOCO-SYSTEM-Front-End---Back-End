    <script>
    (function(){
        const NONCE = <?php echo wp_json_encode( $nonce ); ?>;
        const REST = '<?php echo esc_js( rest_url( 'dinoco-slip/v1' ) ); ?>';

        function fmtDateTH(iso) {
            if (!iso) return '-';
            const d = new Date(iso.replace(' ', 'T') + '+07:00');
            return d.getDate().toString().padStart(2, '0') + '/' + (d.getMonth() + 1).toString().padStart(2, '0') + ' ' + d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');
        }
        function esc(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
        function fmtBaht(n) { if (n == null || n === '') return '-'; return '฿' + Number(n).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}); }

        async function apiGet(path) {
            const r = await fetch(REST + path, { headers: { 'X-WP-Nonce': NONCE } });
            return r.json();
        }
        async function apiPost(path, body) {
            const r = await fetch(REST + path, {
                method: 'POST',
                headers: { 'X-WP-Nonce': NONCE, 'Content-Type': 'application/json' },
                body: JSON.stringify(body || {}),
            });
            return r.json();
        }

        window.dncSlipMonitorRefresh = async function() {
            const resp = await apiGet('/monitor');
            if (!resp.success) {
                document.getElementById('dncSlipBanner').innerHTML = '<div class="dnc-slip-banner bad">โหลดข้อมูลไม่ได้</div>';
                return;
            }
            const s = resp.stats_24h;
            document.getElementById('statTotal').textContent = s.total;
            document.getElementById('statPaid').textContent = (s.paid + s.paid_overpayment);
            document.getElementById('statDup').textContent = s.duplicate;
            document.getElementById('statErr').textContent = (s.slip2go_error + s.line_api_error + s.data_missing);
            document.getElementById('statUnreg').textContent = s.unregistered_group;
            document.getElementById('statRate').textContent = resp.success_rate + '%';

            // Banner
            let banner = '';
            if (!resp.table_exists) {
                banner = '<div class="dnc-slip-banner bad">⚠️ wp_dinoco_slip_log table ยังไม่ถูกสร้าง — ไปที่ wp-admin แล้วกด refresh เพื่อ trigger init hook (Snippet 15 V.8.4+)</div>';
            } else if (resp.slip2go.admin_alerted) {
                banner = '<div class="dnc-slip-banner bad">🚨 Slip2Go API มีปัญหา — Error ' + resp.slip2go.err_count_10min + ' ครั้งใน 10 นาทีล่าสุด (Admin ถูกแจ้งเตือนแล้ว)</div>';
            } else if (resp.active_locks.some(l => l.is_stuck)) {
                banner = '<div class="dnc-slip-banner warn">⚠️ เจอ lock ค้าง ' + resp.active_locks.filter(l => l.is_stuck).length + ' รายการ — ระบบจะ auto-clear ใน cron รอบถัดไป (หรือกด Force Clear เพื่อล้างทันที)</div>';
            } else if (s.total === 0) {
                banner = '<div class="dnc-slip-banner warn">ℹ️ ไม่มี slip activity ใน 24 ชม. ที่ผ่านมา — ถ้าลูกค้าส่งสลิปมาจริง ตรวจสอบ LINE webhook</div>';
            } else {
                banner = '<div class="dnc-slip-banner ok">✅ ระบบทำงานปกติ — success rate ' + resp.success_rate + '% (24h)</div>';
            }
            document.getElementById('dncSlipBanner').innerHTML = banner;

            // Locks + queues table
            const locks = resp.active_locks || [];
            const queues = resp.active_queues || [];
            if (locks.length === 0 && queues.length === 0) {
                document.getElementById('dncSlipLocks').innerHTML = '<p style="color:#64748b; font-size:13px;">— ไม่มี active lock หรือ queue —</p>';
            } else {
                const rows = [];
                // V.1.1 M-1: data-gid attribute + event delegation (see bind at bottom
                // of IIFE). HTML attribute context auto-decodes entities before JS
                // consumes them, so inline onclick with interpolated group_id had a
                // latent XSS vector even with esc(). Data attributes are read via
                // dataset.gid which returns the decoded-once value safely.
                locks.forEach(l => {
                    const statusBadge = l.is_stuck ? '<span class="dnc-slip-status slip2go_error">ค้าง ' + Math.abs(l.remaining_s) + 's</span>' :
                        '<span class="dnc-slip-status queued">เหลือ ' + l.remaining_s + 's</span>';
                    rows.push(`<tr>
                        <td>🔐 Lock</td>
                        <td>${esc(l.dist_name || '(ไม่ระบุร้าน)')}</td>
                        <td><span class="dnc-slip-code">${esc(l.group_id)}</span></td>
                        <td>${statusBadge}</td>
                        <td>—</td>
                        <td><button class="dnc-slip-btn dnc-slip-clear-one" data-gid="${esc(l.group_id)}">Force Clear</button></td>
                    </tr>`);
                });
                queues.forEach(q => {
                    const stale = q.oldest_age_min >= 60;
                    const statusBadge = stale ? '<span class="dnc-slip-status slip2go_error">ค้าง ' + q.oldest_age_min + 'min</span>' :
                        '<span class="dnc-slip-status queued">pending</span>';
                    rows.push(`<tr>
                        <td>📋 Queue</td>
                        <td>${esc(q.dist_name || '(ไม่ระบุร้าน)')}</td>
                        <td><span class="dnc-slip-code">${esc(q.group_id)}</span></td>
                        <td>${statusBadge}</td>
                        <td>size=${q.size}, oldest=${q.oldest_age_min}min</td>
                        <td><button class="dnc-slip-btn dnc-slip-clear-one" data-gid="${esc(q.group_id)}">Force Clear</button></td>
                    </tr>`);
                });
                document.getElementById('dncSlipLocks').innerHTML = `<table class="dnc-slip-table">
                    <thead><tr><th>Type</th><th>ร้าน</th><th>Group ID</th><th>Status</th><th>ข้อมูล</th><th>Action</th></tr></thead>
                    <tbody>${rows.join('')}</tbody>
                </table>`;
            }

            // Recent slips
            const recent = await apiGet('/recent?limit=50');
            if (!recent.success || !recent.rows || recent.rows.length === 0) {
                document.getElementById('dncSlipRecent').innerHTML = '<p style="color:#64748b; font-size:13px;">— ยังไม่มีข้อมูล slip log —</p>';
            } else {
                const trs = recent.rows.map(r => `<tr>
                    <td>${fmtDateTH(r.created_at)}</td>
                    <td>${esc(r.dist_name || '(ไม่ระบุ)')}</td>
                    <td><span class="dnc-slip-status ${esc(r.result_status)}">${esc(r.result_status)}</span></td>
                    <td>${fmtBaht(r.amount)}</td>
                    <td><span class="dnc-slip-ref">${esc(r.trans_ref || '-')}</span></td>
                    <td>${esc(r.sender_name || '-')}</td>
                    <td><span class="dnc-slip-code">HTTP ${r.http_code || '-'} / ${r.processing_time_ms || '-'}ms / retry=${r.retry_count || 0}</span></td>
                    <td><span class="dnc-slip-code">${esc(r.error_msg || '')}</span></td>
                </tr>`).join('');
                document.getElementById('dncSlipRecent').innerHTML = `<table class="dnc-slip-table">
                    <thead><tr><th>เวลา</th><th>ร้าน</th><th>Status</th><th>ยอด</th><th>Ref</th><th>ผู้โอน</th><th>Tech</th><th>Error</th></tr></thead>
                    <tbody>${trs}</tbody>
                </table>`;
            }
        };

        window.dncSlipClearOne = async function(groupId) {
            if (!confirm('ยืนยัน force-clear lock สำหรับ group นี้?\n\nGroup: ' + groupId + '\n\nSlip ถัดไปในกลุ่มนี้จะ process ตามปกติ')) return;
            const r = await apiPost('/clear-locks', { group_id: groupId, reason: 'ui_per_group' });
            if (r.success) {
                alert('ล้างเรียบร้อย: lock=' + r.data.cleared_locks + ' queue=' + r.data.cleared_queues);
                dncSlipMonitorRefresh();
            } else {
                alert('Error: ' + (r.message || 'unknown'));
            }
        };

        window.dncSlipClearAll = async function() {
            if (!confirm('⚠️ ยืนยัน force-clear ALL slip locks + queues?\n\nใช้เมื่อระบบค้าง/มี lock stuck จำนวนมาก\n\nการทำงานปกติหลังจากนี้ไม่กระทบ')) return;
            const r = await apiPost('/clear-locks', { group_id: '', reason: 'ui_clear_all' });
            if (r.success) {
                alert('ล้างเรียบร้อย: lock=' + r.data.cleared_locks + ' queue=' + r.data.cleared_queues + ' (' + (r.data.groups || []).length + ' groups)');
                dncSlipMonitorRefresh();
            } else {
                alert('Error: ' + (r.message || 'unknown'));
            }
        };

        window.dncSlipMissedSweep = async function(days) {
            document.getElementById('dncSlipMissed').innerHTML = '<p>กำลังสแกน...</p>';
            const r = await apiGet('/missed-sweep?days=' + days);
            if (!r.success || !r.rows || r.rows.length === 0) {
                document.getElementById('dncSlipMissed').innerHTML = '<p style="color:#16a34a; font-weight:600;">✅ ไม่พบ slip หาย ใน ' + days + ' วันที่ผ่านมา</p>';
                return;
            }
            const bdParts = Object.keys(r.breakdown).map(k => '<strong>' + esc(k) + '</strong>: ' + r.breakdown[k]);
            const trs = r.rows.slice(0, 100).map(row => `<tr>
                <td>${fmtDateTH(row.created_at)}</td>
                <td>${esc(row.dist_name || '(ไม่ระบุ)')}</td>
                <td><span class="dnc-slip-status ${esc(row.result_status)}">${esc(row.result_status)}</span></td>
                <td>${fmtBaht(row.amount)}</td>
                <td><span class="dnc-slip-ref">${esc(row.trans_ref || '-')}</span></td>
                <td>${esc(row.sender_name || '-')}</td>
                <td><span class="dnc-slip-code">${esc(row.error_msg || '')}</span></td>
            </tr>`).join('');
            document.getElementById('dncSlipMissed').innerHTML = `
                <div class="dnc-slip-banner warn">พบ slip ที่ไม่ประมวลผลสำเร็จ <strong>${r.count}</strong> รายการ ใน ${days} วัน<br>
                ${bdParts.join(' / ')}</div>
                <table class="dnc-slip-table">
                    <thead><tr><th>เวลา</th><th>ร้าน</th><th>Status</th><th>ยอด</th><th>Ref</th><th>ผู้โอน</th><th>Error</th></tr></thead>
                    <tbody>${trs}</tbody>
                </table>`;
        };

        // V.1.1 M-1: event delegation for dynamically-rendered Force Clear buttons.
        // Single listener at container level — no per-render bind + no inline onclick
        // interpolation. Guards against HTML-attribute-context XSS with malicious
        // group_id (admin-gated, defense-in-depth per code review).
        document.addEventListener('click', function(e) {
            const btn = e.target && e.target.closest ? e.target.closest('.dnc-slip-clear-one') : null;
            if (!btn) return;
            const gid = btn.dataset && btn.dataset.gid ? btn.dataset.gid : '';
            if (!gid) return;
            // Guard against accidental double-click during async API call
            if (btn.disabled) return;
            btn.disabled = true;
            window.dncSlipClearOne(gid).finally(function() {
                // Re-enable only if the button is still in DOM (refresh may have replaced it)
                if (document.body.contains(btn)) btn.disabled = false;
            });
        });

        // ═══════════════════════════════════════════════════════
        // V.1.3: Manual Process Tool + Replay Candidates
        // ═══════════════════════════════════════════════════════
        let _mpDistMap = null; // cache dist rows by id

        async function loadDistributors() {
            try {
                const r = await apiGet('/distributors');
                const sel = document.getElementById('mpDistId');
                if (!r.success || !Array.isArray(r.rows)) {
                    sel.innerHTML = '<option value="">-- โหลดไม่สำเร็จ --</option>';
                    return;
                }
                _mpDistMap = {};
                sel.innerHTML = '<option value="">-- เลือกร้าน --</option>' + r.rows.map(d => {
                    _mpDistMap[d.id] = d;
                    const debtLabel = d.current_debt > 0 ? (' [หนี้ ' + fmtBaht(d.current_debt) + ']') : ' [ไม่มีหนี้]';
                    return '<option value="' + d.id + '">' + esc(d.name) + debtLabel + '</option>';
                }).join('');
            } catch (err) {
                document.getElementById('mpDistId').innerHTML = '<option value="">-- error --</option>';
            }
        }

        function fileToBase64(file) {
            return new Promise(function(resolve, reject) {
                const reader = new FileReader();
                reader.onload = function() { resolve({ b64: reader.result, mime: file.type }); };
                reader.onerror = reject;
                reader.readAsDataURL(file);
            });
        }

        window.dncSlipMPReset = function() {
            ['mpAmount','mpTransRef','mpSender','mpReason'].forEach(id => {
                const el = document.getElementById(id); if (el) el.value = '';
            });
            document.getElementById('mpDistId').value = '';
            const fi = document.getElementById('mpImageFile');
            if (fi) fi.value = '';
            document.getElementById('mpStatus').textContent = '';
            document.getElementById('mpResult').innerHTML = '';
        };

        window.dncSlipManualProcess = async function() {
            const distId = parseInt(document.getElementById('mpDistId').value || '0', 10);
            const amount = parseFloat(document.getElementById('mpAmount').value || '0');
            const transRef = document.getElementById('mpTransRef').value.trim();
            const sender = document.getElementById('mpSender').value.trim();
            const reason = document.getElementById('mpReason').value.trim();
            const fileInput = document.getElementById('mpImageFile');

            if (!distId) { alert('กรุณาเลือกร้าน'); return; }
            if (!(amount > 0)) { alert('กรุณาระบุยอด (> 0)'); return; }
            if (reason.length < 10) { alert('กรุณาระบุเหตุผลไม่น้อยกว่า 10 ตัวอักษร'); return; }

            const distInfo = _mpDistMap && _mpDistMap[distId] ? _mpDistMap[distId] : null;
            const distName = distInfo ? distInfo.name : ('#' + distId);
            const currentDebt = distInfo ? distInfo.current_debt : 0;
            let confirmMsg = '⚠️ ยืนยันตัดหนี้ manual?\n\n'
                + 'ร้าน: ' + distName + '\n'
                + 'ยอด: ' + fmtBaht(amount) + '\n'
                + 'หนี้ปัจจุบัน: ' + fmtBaht(currentDebt) + '\n'
                + 'หนี้ใหม่: ' + fmtBaht(Math.max(0, currentDebt - amount)) + '\n\n'
                + 'การทำงานนี้จะ:\n'
                + '• ตัดหนี้ผ่าน b2b_debt_subtract (atomic)\n'
                + '• บันทึก audit row (manual_admin_paid)\n'
                + '• ส่งแจ้งร้านทาง LINE\n'
                + '• ส่งแจ้ง admin group\n\n'
                + 'กด OK เพื่อดำเนินการ';
            if (!confirm(confirmMsg)) return;

            document.getElementById('mpStatus').textContent = '⏳ กำลัง process...';

            let imageB64 = '', imageMime = '';
            if (fileInput && fileInput.files && fileInput.files[0]) {
                try {
                    const res = await fileToBase64(fileInput.files[0]);
                    imageB64 = res.b64;
                    imageMime = res.mime;
                } catch (err) {
                    document.getElementById('mpStatus').textContent = '';
                    alert('อ่านไฟล์รูปไม่สำเร็จ: ' + err.message);
                    return;
                }
            }

            try {
                const r = await apiPost('/manual-process', {
                    dist_id: distId,
                    amount: amount,
                    trans_ref: transRef,
                    sender_name: sender,
                    reason: reason,
                    image_base64: imageB64,
                    image_mime: imageMime,
                });
                document.getElementById('mpStatus').textContent = '';
                if (r.success) {
                    const msg = '<div class="dnc-slip-banner ok">'
                        + '✅ <strong>' + esc(r.message) + '</strong><br>'
                        + 'Log id: #' + r.log_id
                        + (r.overpaid > 0 ? ' / โอนเกิน ' + fmtBaht(r.overpaid) : '')
                        + (Array.isArray(r.paid_tickets) && r.paid_tickets.length > 0
                            ? ' / เคลียร์บิล: #' + r.paid_tickets.join(', #') : '')
                        + '</div>';
                    document.getElementById('mpResult').innerHTML = msg;
                    dncSlipMPReset();
                    dncSlipMonitorRefresh();
                    loadDistributors(); // refresh dist debt amounts
                } else {
                    const errMsg = r.message || (r.code + ': ' + (r.data ? JSON.stringify(r.data) : ''));
                    document.getElementById('mpResult').innerHTML = '<div class="dnc-slip-banner bad">❌ Error: ' + esc(errMsg) + '</div>';
                }
            } catch (err) {
                document.getElementById('mpStatus').textContent = '';
                document.getElementById('mpResult').innerHTML = '<div class="dnc-slip-banner bad">❌ Network: ' + esc(err.message) + '</div>';
            }
        };

        window.dncSlipReplayCandidates = async function(days) {
            document.getElementById('dncSlipReplay').innerHTML = '<p>กำลังโหลด...</p>';
            const r = await apiGet('/replay-candidates?days=' + days);
            if (!r.success) {
                document.getElementById('dncSlipReplay').innerHTML = '<div class="dnc-slip-banner bad">โหลดไม่สำเร็จ</div>';
                return;
            }
            if (r.schema_missing) {
                document.getElementById('dncSlipReplay').innerHTML = '<div class="dnc-slip-banner warn">' + esc(r.note) + '</div>';
                return;
            }
            if (!r.rows || r.rows.length === 0) {
                document.getElementById('dncSlipReplay').innerHTML = '<p style="color:#16a34a; font-weight:600;">✅ ไม่มี replay candidate ใน ' + days + ' วันที่ผ่านมา</p>';
                return;
            }
            const trs = r.rows.map(row => `<tr>
                <td>${fmtDateTH(row.created_at)}</td>
                <td>${esc(row.dist_name || '(ไม่ระบุ)')}</td>
                <td><span class="dnc-slip-status ${esc(row.result_status)}">${esc(row.result_status)}</span></td>
                <td>${fmtBaht(row.amount)}</td>
                <td><span class="dnc-slip-ref">${esc(row.trans_ref || '-')}</span></td>
                <td><span class="dnc-slip-code">${row.image_hash ? esc(String(row.image_hash).substr(0, 12)) + '...' : '-'}</span></td>
                <td><span class="dnc-slip-code">${esc(String(row.error_msg || '').substr(0, 80))}</span></td>
                <td><button class="dnc-slip-btn dnc-slip-replay-one" data-log-id="${row.id}">🔁 Replay</button></td>
            </tr>`).join('');
            document.getElementById('dncSlipReplay').innerHTML = `
                <div class="dnc-slip-banner warn">พบ <strong>${r.count}</strong> row ที่ replay ได้ (${days} วัน)</div>
                <table class="dnc-slip-table">
                    <thead><tr><th>เวลา</th><th>ร้าน</th><th>Status</th><th>ยอด</th><th>Ref</th><th>Hash</th><th>Error</th><th>Action</th></tr></thead>
                    <tbody>${trs}</tbody>
                </table>`;
        };

        window.dncSlipReplayOne = async function(logId) {
            if (!confirm('ยืนยัน replay log #' + logId + '?\n\nระบบจะพยายาม process สลิปใหม่โดยใช้ cached Slip2Go response.\n\n⚠️ ถ้า LINE Content หมดอายุ (>24h) → fallback ไปใช้ Manual Process Tool แทน')) return;
            const r = await apiPost('/replay-slip', { log_id: logId });
            if (r.success) {
                alert('✅ Replay triggered — ' + (r.message || ''));
                dncSlipMonitorRefresh();
                dncSlipReplayCandidates(7);
            } else {
                alert('❌ ' + (r.message || r.code || 'unknown error'));
            }
        };

        // Event delegation for dynamically-rendered Replay buttons
        document.addEventListener('click', function(e) {
            const btn = e.target && e.target.closest ? e.target.closest('.dnc-slip-replay-one') : null;
            if (!btn) return;
            const logId = btn.dataset && btn.dataset.logId ? parseInt(btn.dataset.logId, 10) : 0;
            if (!logId) return;
            if (btn.disabled) return;
            btn.disabled = true;
            window.dncSlipReplayOne(logId).finally(function() {
                if (document.body.contains(btn)) btn.disabled = false;
            });
        });

        // Auto-load on page ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                dncSlipMonitorRefresh();
                loadDistributors();
            });
        } else {
            dncSlipMonitorRefresh();
            loadDistributors();
        }
    })();
    </script>
    <?php
    return ob_get_clean();
}
