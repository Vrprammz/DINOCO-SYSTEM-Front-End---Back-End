        $group_id = sanitize_text_field( (string) $req->get_param( 'group_id' ) );

        $where = array( '1=1' );
        $params = array();
        if ( $status !== '' ) {
            $where[] = 'result_status = %s';
            $params[] = $status;
        }
        if ( $group_id !== '' ) {
            $where[] = 'group_id = %s';
            $params[] = $group_id;
        }
        $params[] = $limit;

        // V.1.10: Schema-aware AI columns probe (silent on legacy installs)
        static $_recent_ai_cols_exist = null;
        if ( $_recent_ai_cols_exist === null ) {
            $cols_check = $wpdb->get_col( $wpdb->prepare(
                "SELECT column_name FROM INFORMATION_SCHEMA.COLUMNS
                 WHERE table_schema = DATABASE() AND table_name = %s
                   AND column_name IN ('ai_classifier_decision','ai_classifier_confidence','ai_classifier_reason')",
                $table
            ) );
            $_recent_ai_cols_exist = is_array( $cols_check ) && count( $cols_check ) === 3;
        }
        $ai_cols_select = $_recent_ai_cols_exist
            ? ', ai_classifier_decision, ai_classifier_confidence, ai_classifier_reason'
            : '';

        // V.1.13: Schema-aware credit_note columns probe (silent on pre-V.8.15 installs)
        $cn_cols_select = function_exists( 'dinoco_slip_monitor_credit_note_cols_exist' ) && dinoco_slip_monitor_credit_note_cols_exist()
            ? ', credit_note_amount, credit_note_issued_at, credit_note_by'
            : '';

