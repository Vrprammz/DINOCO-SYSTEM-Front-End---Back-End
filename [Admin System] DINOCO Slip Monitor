                <textarea id="mpReason" rows="3" maxlength="500" style="width:100%; padding:8px; border:1px solid #d1d5db; border-radius:6px; font-size:13px; resize:vertical;" placeholder="เช่น: Slip2Go คืน 200501 duplicate — CNX ส่งสลิปช่วง routing bug V.34.7 — ตัดหนี้ manual"></textarea>
