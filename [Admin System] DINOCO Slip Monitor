if ( ! function_exists( 'dinoco_slip_monitor_rest_get' ) ) {
    function dinoco_slip_monitor_rest_get( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';

        // Stats 24h
        // V.1.5: include ALL result_status values that handler can write — missing keys
        // caused JS to compute `s.paid + s.paid_overpayment` = `0 + undefined` = NaN
        // and incorrect success_rate (manual_admin_paid + replay_* not counted as success).
        $stats_24h = array(
            'total' => 0,
            // success bucket
            'paid' => 0, 'paid_overpayment' => 0, 'manual_admin_paid' => 0,
            'replay_after_paid' => 0, 'replayed_from_pool' => 0,
            // duplicate bucket (bank cleared, blocked locally)
            'duplicate' => 0,
            // rejected bucket (bank cleared, business rule reject)
            'receiver_mismatch' => 0, 'amount_mismatch' => 0,
            'amount_no_pending' => 0, 'no_distributor' => 0,
            // error bucket (our system failure)
            'slip2go_error' => 0, 'line_api_error' => 0, 'data_missing' => 0,
            'unknown_slip_code' => 0, 'fatal_exception' => 0, 'empty_binary' => 0,
            // V.1.9: classifier bucket — pre-filter heuristic + needs_review pool
            'needs_review' => 0, 'not_slip_heuristic' => 0,
            // V.1.10: AI classifier bucket — Slip2Go quota saved
            'not_slip_ai' => 0,
            // queue / routing
            'queued' => 0, 'not_slip' => 0, 'unregistered_group' => 0,
            'other' => 0,
        );
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( $table_exists ) {
            $results = $wpdb->get_results(
                "SELECT result_status, COUNT(*) AS cnt FROM {$table}
                 WHERE created_at >= DATE_SUB(NOW(), INTERVAL 24 HOUR)
                 GROUP BY result_status"
            );
            foreach ( $results as $r ) {
                $status = $r->result_status;
                $cnt = (int) $r->cnt;
                $stats_24h['total'] += $cnt;
                if ( array_key_exists( $status, $stats_24h ) ) {
                    $stats_24h[ $status ] += $cnt;
                } else {
                    $stats_24h['other'] += $cnt;
                }
            }
        }

        // Active locks + queues
        $locks = array();
        $lock_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT option_name, option_value FROM {$wpdb->options} WHERE option_name LIKE %s",
            $wpdb->esc_like( '_transient_timeout_b2b_slip_lock_' ) . '%'
        ) );
        $now = time();
        foreach ( $lock_rows as $r ) {
            $gid = substr( $r->option_name, strlen( '_transient_timeout_b2b_slip_lock_' ) );
            if ( $gid === '' ) continue;
            $expires_at = (int) $r->option_value;
            $dist_name = dinoco_slip_monitor_get_dist_name( $gid );
            $locks[] = array(
                'group_id'     => $gid,
                'dist_name'    => $dist_name,
                'expires_at'   => $expires_at,
                'remaining_s'  => max( 0, $expires_at - $now ),
                'is_stuck'     => ( $expires_at > 0 && ( $now - $expires_at ) > 120 ),
            );
        }

        $queues = array();
        $queue_rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT option_name, option_value FROM {$wpdb->options} WHERE option_name LIKE %s",
            $wpdb->esc_like( 'b2b_slip_queue_' ) . '%'
        ) );
        foreach ( $queue_rows as $r ) {
            $gid = substr( $r->option_name, strlen( 'b2b_slip_queue_' ) );
            if ( $gid === '' ) continue;
            $queue = maybe_unserialize( $r->option_value );
            if ( ! is_array( $queue ) || empty( $queue ) ) continue;
            $oldest = PHP_INT_MAX;
            foreach ( $queue as $q ) {
                $t = (int) ( $q['time'] ?? 0 );
                if ( $t > 0 && $t < $oldest ) $oldest = $t;
            }
            $queues[] = array(
                'group_id'       => $gid,
                'dist_name'      => dinoco_slip_monitor_get_dist_name( $gid ),
                'size'           => count( $queue ),
                'oldest_age_min' => $oldest < PHP_INT_MAX ? (int) round( ( $now - $oldest ) / 60 ) : 0,
            );
        }

        // Slip2Go health
        $s2g_health = array(
            'err_count_10min' => (int) get_transient( 'b2b_slip2go_err_count' ),
            'admin_alerted'   => (bool) get_transient( 'b2b_slip2go_alerted' ),
        );

        // Success rate
        // V.1.5: include all success-class statuses + duplicate (already-paid is also fine)
        $success_rate = 0;
        if ( $stats_24h['total'] > 0 ) {
            $success_count = $stats_24h['paid']
                           + $stats_24h['paid_overpayment']
                           + $stats_24h['manual_admin_paid']
                           + $stats_24h['replay_after_paid']
                           + $stats_24h['replayed_from_pool']
                           + $stats_24h['duplicate'];
            $success_rate = round( 100 * $success_count / $stats_24h['total'], 1 );
        }

        return rest_ensure_response( array(
            'success'       => true,
            'table_exists'  => $table_exists,
            'stats_24h'     => $stats_24h,
            'success_rate'  => $success_rate,
            'active_locks'  => $locks,
            'active_queues' => $queues,
            'slip2go'       => $s2g_health,
            'now'           => $now,
        ) );
    }
}

