// ────────────────────────────────────────────────────────────────
// GET /credit-note-eligible?log_id=N
// Returns: { eligible:bool, log_id, dist_id, dist_name, group_id, amount,
//            current_debt, suggested_overpaid, already_issued:bool, issued_info?:{} }
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_credit_note_eligible' ) ) {
    function dinoco_slip_monitor_rest_credit_note_eligible( WP_REST_Request $req ) {
        if ( ! dinoco_slip_monitor_credit_note_cols_exist() ) {
            return new WP_Error(
                'schema_missing',
                'Snippet 15 V.8.15+ ต้อง sync ก่อน (credit_note_* columns ยังไม่มี)',
                array( 'status' => 501 )
            );
        }

        $log_id = (int) $req->get_param( 'log_id' );
        if ( $log_id <= 0 ) {
            return new WP_Error( 'bad_log_id', 'log_id ไม่ถูกต้อง', array( 'status' => 400 ) );
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, group_id, dist_id, amount, sender_name, trans_ref, result_status,
                    credit_note_amount, credit_note_issued_at, credit_note_reason, credit_note_by
             FROM {$table} WHERE id = %d LIMIT 1",
            $log_id
        ), ARRAY_A );

        if ( ! $row ) {
            return new WP_Error( 'not_found', 'ไม่พบ log row', array( 'status' => 404 ) );
        }

        $dist_id   = (int) $row['dist_id'];
        $dist_name = $dist_id > 0 ? get_the_title( $dist_id ) : '';
        $group_id  = $row['group_id'] ?: ( $dist_id > 0 && function_exists( 'get_field' )
                        ? (string) get_field( 'line_group_id', $dist_id ) : '' );

        $current_debt = ( $dist_id > 0 && function_exists( 'b2b_recalculate_debt' ) )
            ? floatval( b2b_recalculate_debt( $dist_id ) )
            : ( ( $dist_id > 0 && function_exists( 'get_field' ) ) ? floatval( get_field( 'current_debt', $dist_id ) ) : 0 );

        // Eligibility: status must be paid_overpayment + not already credited
        $is_overpayment   = ( $row['result_status'] === 'paid_overpayment' );
        $already_issued   = ! empty( $row['credit_note_issued_at'] );
        $eligible         = $is_overpayment && ! $already_issued;

        // Suggested overpaid amount = the slip amount minus what was outstanding before.
        // We approximate: if current_debt is 0 (fully paid), the entire over-amount is excess
        // beyond the closing debt. Admin will confirm exact amount in modal — this is just hint.
        // Spec uses overpaid recorded by handler when row was inserted; we re-derive here as a
        // best-effort cap: max suggested = slip amount itself (admin clamps further if needed).
        $suggested_overpaid = floatval( $row['amount'] );
        // Heuristic: if debt < amount AND debt >= 0, overpaid = (amount - debt_at_insert).
        // We don't have debt-at-insert snapshot, so use min(amount, amount) — admin enters exact.
        // We instead report a safer ceiling: amount - max(0, current_debt) ≈ what's still credit.
        $approx_credit_remaining = max( 0, $suggested_overpaid - max( 0, $current_debt ) );
        if ( $approx_credit_remaining > 0 && $approx_credit_remaining <= $suggested_overpaid ) {
            $suggested_overpaid = round( $approx_credit_remaining, 2 );
        }

        $resp = array(
            'success'         => true,
            'eligible'        => $eligible,
            'log_id'          => (int) $row['id'],
            'dist_id'         => $dist_id,
            'dist_name'       => $dist_name,
            'group_id'        => $group_id,
            'amount'          => floatval( $row['amount'] ),
            'sender_name'     => $row['sender_name'] ?: '',
            'trans_ref'       => $row['trans_ref'] ?: '',
            'result_status'   => $row['result_status'],
            'current_debt'    => round( $current_debt, 2 ),
            'suggested_overpaid' => round( $suggested_overpaid, 2 ),
            'already_issued'  => $already_issued,
        );

        if ( ! $is_overpayment ) {
            $resp['reason_blocked'] = 'row นี้ไม่ใช่ paid_overpayment (status=' . $row['result_status'] . ')';
        }
        if ( $already_issued ) {
            $resp['issued_info'] = array(
                'amount'    => floatval( $row['credit_note_amount'] ),
                'issued_at' => $row['credit_note_issued_at'],
                'reason'    => $row['credit_note_reason'],
                'by_user'   => (int) $row['credit_note_by'],
            );
        }

        return rest_ensure_response( $resp );
    }
}

// ────────────────────────────────────────────────────────────────
// POST /issue-credit-note
// Body: { log_id, amount, reason, notify_dist?:bool }
// Logic: validate → GET_LOCK(log_id) → b2b_debt_subtract → UPDATE slip_log →
//        audit_log → LINE notify (post-lock) → response
// ────────────────────────────────────────────────────────────────
if ( ! function_exists( 'dinoco_slip_monitor_rest_issue_credit_note' ) ) {
    function dinoco_slip_monitor_rest_issue_credit_note( WP_REST_Request $req ) {
        if ( ! dinoco_slip_monitor_credit_note_cols_exist() ) {
            return new WP_Error(
                'schema_missing',
                'Snippet 15 V.8.15+ ต้อง sync ก่อน',
                array( 'status' => 501 )
            );
        }

        $uid = get_current_user_id();
        // Rate limit 5/min/user (destructive — mutates debt)
        if ( function_exists( 'b2b_rate_limit' ) ) {
            $rl = b2b_rate_limit( 'slip_credit_note_u' . $uid, 5, 60 );
            if ( is_wp_error( $rl ) ) {
                return new WP_Error( 'rate_limit', 'เรียกบ่อยเกินไป (max 5/min)', array( 'status' => 429 ) );
            }
        }

        if ( ! function_exists( 'b2b_debt_subtract' ) ) {
            return new WP_Error( 'no_debt_fn', 'b2b_debt_subtract ไม่พร้อม (Snippet 13)', array( 'status' => 501 ) );
        }

        $body = $req->get_json_params();
        if ( ! is_array( $body ) ) $body = array();

        $log_id      = (int) ( isset( $body['log_id'] ) ? $body['log_id'] : $req->get_param( 'log_id' ) );
        $amount_raw  = isset( $body['amount'] ) ? $body['amount'] : $req->get_param( 'amount' );
        $amount      = floatval( $amount_raw );
        $reason      = sanitize_text_field( (string) ( isset( $body['reason'] ) ? $body['reason'] : $req->get_param( 'reason' ) ) );
        $notify_dist = isset( $body['notify_dist'] ) ? (bool) $body['notify_dist'] : true;

        // Validation
        if ( $log_id <= 0 ) {
            return new WP_Error( 'bad_log_id', 'log_id ไม่ถูกต้อง', array( 'status' => 400 ) );
        }
        if ( $amount <= 0 || $amount > 10000000 ) {
            return new WP_Error( 'bad_amount', 'ยอดไม่ถูกต้อง (1 ถึง 10,000,000)', array( 'status' => 400 ) );
        }
        if ( $reason === '' || mb_strlen( $reason ) < 10 ) {
            return new WP_Error( 'bad_reason', 'ต้องระบุเหตุผลไม่น้อยกว่า 10 ตัวอักษร (audit trail)', array( 'status' => 400 ) );
        }
        if ( mb_strlen( $reason ) > 500 ) $reason = mb_substr( $reason, 0, 500 );

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';

        // Pre-lock load + eligibility
        $row = $wpdb->get_row( $wpdb->prepare(
            "SELECT id, group_id, dist_id, amount, sender_name, trans_ref, result_status,
                    credit_note_issued_at
             FROM {$table} WHERE id = %d LIMIT 1",
            $log_id
        ), ARRAY_A );

        if ( ! $row ) {
            return new WP_Error( 'not_found', 'ไม่พบ log row', array( 'status' => 404 ) );
        }
        if ( $row['result_status'] !== 'paid_overpayment' ) {
            return new WP_Error( 'not_overpayment',
                'row นี้ไม่ใช่ paid_overpayment (status=' . $row['result_status'] . ')',
                array( 'status' => 422 ) );
        }
        if ( ! empty( $row['credit_note_issued_at'] ) ) {
            return new WP_Error( 'already_credited',
                'row นี้เคยออก credit note แล้วเมื่อ ' . $row['credit_note_issued_at'],
                array( 'status' => 409 ) );
        }

        $dist_id = (int) $row['dist_id'];
        if ( $dist_id <= 0 || get_post_type( $dist_id ) !== 'distributor' ) {
            return new WP_Error( 'bad_dist', 'log row ไม่มี distributor ที่ valid', array( 'status' => 422 ) );
        }
        $slip_amount = floatval( $row['amount'] );
        if ( $amount > $slip_amount ) {
            return new WP_Error( 'amount_exceeds_slip',
                'จำนวน credit note (฿' . number_format( $amount, 2 ) . ') มากกว่ายอดสลิป (฿' . number_format( $slip_amount, 2 ) . ')',
                array( 'status' => 422 ) );
        }

        $dist_name = get_the_title( $dist_id );
        $group_id  = (string) ( $row['group_id'] ?: ( function_exists( 'get_field' ) ? get_field( 'line_group_id', $dist_id ) : '' ) );

        // GET_LOCK on log_id — prevents double-issue race when admin clicks twice
        $lock_key      = 'dnc_cn_' . $log_id;
        $lock_acquired = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 3)", $lock_key ) );
        if ( $lock_acquired !== 1 ) {
            return new WP_Error( 'concurrent_issue',
                'มีคนกำลังออก credit note สำหรับ log นี้อยู่ — รอสักครู่',
                array( 'status' => 409 ) );
        }

        $audit_id = 0;
        $new_debt = 0;
        $old_debt = 0;

        try {
            // Re-check inside lock (defense in depth)
            $still_eligible = $wpdb->get_row( $wpdb->prepare(
                "SELECT credit_note_issued_at FROM {$table} WHERE id = %d LIMIT 1",
                $log_id
            ), ARRAY_A );
            if ( $still_eligible && ! empty( $still_eligible['credit_note_issued_at'] ) ) {
                $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                return new WP_Error( 'already_credited_inlock',
                    'row นี้เพิ่งถูกออก credit note ไปแล้ว',
                    array( 'status' => 409 ) );
            }

            // Atomic debt subtract
            $old_debt = function_exists( 'get_field' ) ? floatval( get_field( 'current_debt', $dist_id ) ) : 0;
            $reason_tag = 'credit_note:slip_log#' . $log_id . ':u=' . $uid . ':' . mb_substr( $reason, 0, 60 );
            $new_debt   = b2b_debt_subtract( $dist_id, $amount, $reason_tag );

            if ( $new_debt === false ) {
                $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
                return new WP_Error( 'debt_subtract_fail',
                    'ตัดหนี้ไม่สำเร็จ (debt_subtract คืน false)',
                    array( 'status' => 500 ) );
            }

            // Audit log dual-write FIRST (before slip_log UPDATE) so we can
            // store the audit_id back into slip_log for forensic chain
            if ( function_exists( 'dinoco_audit_log' ) ) {
                $audit_id = (int) dinoco_audit_log( array(
                    'event_type'    => 'credit_note_issued',
                    'actor_type'    => 'admin',
                    'actor_id'      => (string) $uid,
                    'target_type'   => 'distributor',
                    'target_id'     => (string) $dist_id,
                    'amount'        => (float) $amount,
                    'delta_before'  => (string) round( $old_debt, 2 ),
                    'delta_after'   => (string) round( $new_debt, 2 ),
                    'related_log_id' => $log_id,
                    'context'       => array(
                        'reason'      => $reason,
                        'slip_amount' => $slip_amount,
                        'trans_ref'   => $row['trans_ref'],
                        'sender_name' => $row['sender_name'],
                        'group_id'    => $group_id,
                    ),
                ) );
            }

            // UPDATE slip_log to mark issued
            $now_mysql = current_time( 'mysql' );
            $upd = $wpdb->update(
                $table,
                array(
                    'credit_note_amount'    => $amount,
                    'credit_note_issued_at' => $now_mysql,
                    'credit_note_reason'    => $reason,
                    'credit_note_by'        => $uid,
                    'credit_note_audit_id'  => $audit_id ?: null,
                ),
                array( 'id' => $log_id ),
                array( '%f', '%s', '%s', '%d', '%d' ),
                array( '%d' )
            );
            if ( $upd === false ) {
                // slip_log update failed — debt already subtracted; log loud but don't reverse
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( '[CreditNote] WARN slip_log UPDATE failed log_id=' . $log_id
                        . ' err=' . $wpdb->last_error . ' — debt subtract already committed' );
                }
            }

            // Recalc from source of truth
            $new_debt = function_exists( 'b2b_recalculate_debt' )
                ? floatval( b2b_recalculate_debt( $dist_id ) )
                : $new_debt;
        } catch ( \Throwable $e ) {
            $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( '[CreditNote] FATAL log_id=' . $log_id . ' err=' . $e->getMessage() );
            }
            return new WP_Error( 'fatal',
                'เกิด error ระหว่างประมวลผล: ' . mb_substr( $e->getMessage(), 0, 200 ),
                array( 'status' => 500 ) );
        }

        // Release lock BEFORE LINE side effects (idempotent network calls)
        $wpdb->get_var( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_key ) );

        // LINE notify customer (best-effort)
        if ( $notify_dist && function_exists( 'b2b_line_push' ) && $group_id !== '' ) {
            $msg = "💰 ออก Credit Note (คืนเครดิต)\n"
                 . "ร้าน: " . $dist_name . "\n"
                 . "ยอดที่คืน: ฿" . number_format( $amount, 2 ) . "\n"
                 . "หนี้คงเหลือ: ฿" . number_format( $new_debt, 2 ) . "\n"
                 . "เหตุผล: " . mb_substr( $reason, 0, 200 );
            if ( ! empty( $row['trans_ref'] ) ) {
                $msg .= "\nอ้างอิงสลิป Ref: " . $row['trans_ref'];
            }
            b2b_line_push( $group_id, $msg );
        }

        // Notify admin group
        if ( function_exists( 'b2b_push_to_admin' ) ) {
            b2b_push_to_admin(
                "💰 Credit Note Issued\n"
                . "Admin: user#" . $uid . "\n"
                . "ร้าน: " . $dist_name . "\n"
                . "ยอด: ฿" . number_format( $amount, 2 ) . "\n"
                . "Slip log id: #" . $log_id . "\n"
                . "หนี้เหลือ: ฿" . number_format( $new_debt, 2 ) . "\n"
                . "Reason: " . mb_substr( $reason, 0, 200 )
            );
        }

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( '[CreditNote] log_id=' . $log_id . ' admin=' . $uid
                . ' dist=' . $dist_id . ' amount=' . $amount . ' new_debt=' . $new_debt
                . ' audit_id=' . $audit_id );
        }

        return rest_ensure_response( array(
            'success'    => true,
            'log_id'     => $log_id,
            'dist_id'    => $dist_id,
            'dist_name'  => $dist_name,
            'amount'     => round( $amount, 2 ),
            'old_debt'   => round( $old_debt, 2 ),
            'new_debt'   => round( $new_debt, 2 ),
            'audit_id'   => $audit_id,
            'message'    => 'ออก Credit Note ฿' . number_format( $amount, 2 ) . ' สำเร็จ — หนี้เหลือ ฿' . number_format( $new_debt, 2 ),
        ) );
    }
}

