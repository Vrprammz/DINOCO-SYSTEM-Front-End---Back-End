if ( ! function_exists( 'dinoco_slip_monitor_rest_recent' ) ) {
    function dinoco_slip_monitor_rest_recent( WP_REST_Request $req ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_slip_log';
        $table_exists = (bool) $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $table ) );
        if ( ! $table_exists ) {
            return rest_ensure_response( array( 'success' => true, 'rows' => array(), 'table_missing' => true ) );
        }

        $limit = max( 1, min( 200, (int) $req->get_param( 'limit' ) ?: 50 ) );
