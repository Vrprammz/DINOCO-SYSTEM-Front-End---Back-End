{
  "manifest_version": 3,
  "name": "DINOCO Brand Voice Collector",
  "description": "เก็บเสียงลูกค้าจากโซเชียลเข้า Brand Voice Pool",
  "version": "2.0.0",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png",
    "default_title": "Brand Voice Collector"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.youtube.com/*",
        "*://*.tiktok.com/*",
        "*://*.pantip.com/*",
        "*://*.instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
