        $system_prompt = 'คุณคือนักวิเคราะห์ธุรกิจ DINOCO หน้าที่: วิเคราะห์เครือข่ายตัวแทนจำหน่ายและประเมินความเสี่ยงทางธุรกิจ

บริบทธุรกิจ: DINOCO ผลิต/จำหน่ายอะไหล่และตัวแต่ง Honda BigBike เป็นหลัก สินค้ามีวางจำหน่ายใน Honda BigWing ทุกสาขาทั่วประเทศ (แต่ BigWing เป็นเพียงช่องทางจัดจำหน่าย ไม่ใช่ตัวแทนของเรา)

เมื่อวิเคราะห์พื้นที่ขยาย ให้พิจารณา:
- จังหวัดที่มี Honda BigWing แต่ยังไม่มีตัวแทน DINOCO = โอกาสสูง
- จังหวัดที่มี GDP สูง + ประชากรมาก = ตลาดใหญ่
- จังหวัดท่องเที่ยว = ดีมานด์ BigBike สูง (เช่น เชียงใหม่, ภูเก็ต, กระบี่)

ข้อมูล bigwing_without_dinoco คือจังหวัดที่มี BigWing แต่ยังไม่มีตัวแทน DINOCO

ตอบเป็น JSON format เท่านั้น ห้ามเพิ่ม markdown, backtick หรือ text อื่นนอก JSON format:
{
  "overview": { "status": "ดี|ปานกลาง|ต้องปรับปรุง", "summary": "สรุป 2-3 ประโยค" },
  "expansion": [
    { "province": "จังหวัด", "reason": "เหตุผล", "priority": "สูง|กลาง|ต่ำ", "has_bigwing": true }
  ],
  "risks": [
    { "name": "ชื่อร้าน", "issue": "ปัญหา", "severity": "สูง|กลาง|ต่ำ", "action": "แนะนำ" }
  ],
  "strategy": [
    { "title": "หัวข้อ", "detail": "รายละเอียด", "impact": "สูง|กลาง|ต่ำ" }
  ]
}';

        $user_message = 'วิเคราะห์ข้อมูลเครือข่ายตัวแทนจำหน่าย DINOCO ต่อไปนี้:' . "\n\n" . json_encode($ai_data, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);

        $result = DINOCO_AI::chat(
            $system_prompt,
            [['role' => 'user', 'text' => $user_message]],
            [],
            ['temperature' => 0.4, 'max_tokens' => 4096, 'model' => 'claude-sonnet-4-20250514']
        );

        if (!empty($result['success']) && !empty($result['text'])) {
            $raw = $result['text'];

            // Try to extract JSON from response (strip markdown code blocks if present)
            $json_str = $raw;
            if (preg_match('/```(?:json)?\s*([\s\S]*?)```/', $raw, $m)) {
                $json_str = trim($m[1]);
            }
            $json_str = trim($json_str);

            $parsed = json_decode($json_str, true);
            if ($parsed && isset($parsed['overview'])) {
                // Valid JSON response
                set_transient('dinoco_ai_fin_analysis_v3', $parsed, HOUR_IN_SECONDS);
                echo json_encode(['success' => true, 'ai_json' => $parsed, 'cached' => false]);
            } else {
                // Fallback: return raw text
                set_transient('dinoco_ai_fin_analysis_v3', $raw, HOUR_IN_SECONDS);
                echo json_encode(['success' => true, 'ai_raw' => wp_kses_post($raw), 'cached' => false]);
            }
        } else {
            $err = isset($result['error']) ? $result['error'] : 'AI วิเคราะห์ไม่สำเร็จ กรุณาลองใหม่';
            echo json_encode(['success' => false, 'error' => $err]);
        }
