<script>
(function() {
    var $ = jQuery;
    var _origSetTimeout = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
    var ajaxUrl = '<?php echo esc_url(admin_url('admin-post.php')); ?>';

    // Region province data from PHP
    var regionProvinces = <?php echo $region_provinces_json; ?>;

    // =======================================
    // Utility functions
    // =======================================
    function fmtBaht(n) {
        if (n === null || n === undefined || isNaN(n)) return '-';
        return parseFloat(n).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' ฿';
    }
    function fmtNum(n) {
        if (n === null || n === undefined || isNaN(n)) return '-';
        return parseFloat(n).toLocaleString('th-TH');
    }
    function escHtml(s) {
        if (!s) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(s));
        return div.innerHTML;
    }

    // Charts refs
    var chartTrend = null, chartAging = null, chartRank = null;

    // Store last data for map/province rendering
    var lastData = null;

    // =======================================
    // finLoad() - Main data load
    // =======================================
    function finLoad() {
        $.post(ajaxUrl, {
            action: 'admin_post_nopriv',
            dinoco_finance_action: 'get_finance_summary'
        }, function(resp) {
            if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) { return; }
            if (!resp.success) return;

            var d = resp.data;
            lastData = d;

            // ---- KPIs ----
            $('#kpi-rev-today').text(fmtBaht(d.revenue_today));
            $('#kpi-rev-month').text(fmtBaht(d.revenue_month));
            $('#kpi-orders-month').text(d.orders_month + ' ออเดอร์');
            $('#kpi-rev-year').text(fmtBaht(d.revenue_year));
            $('#kpi-paid-month').text(fmtBaht(d.paid_month));
            $('#kpi-total-debt').text(fmtBaht(d.total_debt));
            $('#kpi-debt-sub').text('ตัวแทนทั้งหมด ' + d.dist_total + ' ร้าน');
            $('#kpi-overdue').text(fmtBaht(d.overdue_amount));
            $('#kpi-overdue-sub').text(d.overdue_count + ' บิลเกินกำหนด');
            $('#kpi-awaiting').text(fmtBaht(d.awaiting_amount));
            $('#kpi-hold').text(d.credit_hold_count + ' ร้าน');
            $('#kpi-hold-sub').text('จาก ' + d.dist_total + ' ร้านทั้งหมด');

            // ---- Revenue Trend Chart ----
            if (chartTrend) chartTrend.destroy();
            chartTrend = new ApexCharts(document.querySelector('#chart-revenue-trend'), {
                chart: { type: 'area', height: 280, fontFamily: 'Noto Sans Thai', toolbar: { show: false } },
                series: [{ name: 'รายได้', data: d.monthly_trend.map(function(m){ return m.amount; }) }],
                xaxis: { categories: d.monthly_trend.map(function(m){ return m.label; }) },
                yaxis: { labels: { formatter: function(v){ return fmtBaht(v); } } },
                tooltip: { y: { formatter: function(v){ return fmtBaht(v); } } },
                colors: ['#3b82f6'],
                fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05 } },
                stroke: { curve: 'smooth', width: 3 },
                dataLabels: { enabled: false },
                grid: { borderColor: '#f1f5f9' }
            });
            chartTrend.render();

            // ---- Debt Aging Chart ----
            var agingLabels = ['1-7 วัน', '8-30 วัน', '31-60 วัน', '60+ วัน'];
            var agingData = [d.overdue_aging['1_7'], d.overdue_aging['8_30'], d.overdue_aging['31_60'], d.overdue_aging['60_plus']];

            if (chartAging) chartAging.destroy();
            chartAging = new ApexCharts(document.querySelector('#chart-aging'), {
                chart: { type: 'bar', height: 280, fontFamily: 'Noto Sans Thai', toolbar: { show: false } },
                series: [{ name: 'ยอดเกินกำหนด', data: agingData }],
                xaxis: { categories: agingLabels },
                yaxis: { labels: { formatter: function(v){ return fmtBaht(v); } } },
                tooltip: { y: { formatter: function(v){ return fmtBaht(v); } } },
                colors: ['#f59e0b'],
                plotOptions: { bar: { borderRadius: 6, columnWidth: '50%' } },
                dataLabels: { enabled: false },
                grid: { borderColor: '#f1f5f9' }
            });
            chartAging.render();

            // ---- Rank Revenue Chart ----
            var rankLabels = ['Standard', 'Silver', 'Gold', 'Platinum', 'Diamond'];
            var rankColors = ['#94a3b8', '#64748b', '#f59e0b', '#8b5cf6', '#06b6d4'];
            var rankData = [d.rank_revenue.standard, d.rank_revenue.silver, d.rank_revenue.gold, d.rank_revenue.platinum, d.rank_revenue.diamond];

            if (chartRank) chartRank.destroy();
            chartRank = new ApexCharts(document.querySelector('#chart-rank-revenue'), {
                chart: { type: 'donut', height: 280, fontFamily: 'Noto Sans Thai' },
                series: rankData,
                labels: rankLabels,
                colors: rankColors,
                legend: { position: 'bottom', fontSize: '13px' },
                tooltip: { y: { formatter: function(v){ return fmtBaht(v); } } },
                plotOptions: { pie: { donut: { size: '55%', labels: { show: true, total: { show: true, label: 'รวม', formatter: function(w){ return fmtBaht(w.globals.seriesTotals.reduce(function(a,b){return a+b;},0)); } } } } } },
                dataLabels: { enabled: false }
            });
            chartRank.render();

            // ---- Pipeline ----
            var pipeHtml = '';
            var pipeMap = {
                draft: { label: 'แบบร่าง', color: '#94a3b8' },
                awaiting_confirm: { label: 'รอยืนยัน', color: '#f59e0b' },
                awaiting_payment: { label: 'รอชำระ', color: '#ef4444' },
                paid: { label: 'ชำระแล้ว', color: '#10b981' },
                packed: { label: 'แพ็คแล้ว', color: '#6366f1' },
                shipped: { label: 'จัดส่งแล้ว', color: '#06b6d4' },
                completed: { label: 'สำเร็จ', color: '#22c55e' },
                cancelled: { label: 'ยกเลิก', color: '#dc2626' }
            };
            for (var key in pipeMap) {
                var cnt = d.pipeline[key] || 0;
                pipeHtml += '<div class="fin-pipe-item" style="border-left: 3px solid ' + pipeMap[key].color + '">' +
                    '<div class="fin-pipe-count" style="color:' + pipeMap[key].color + '">' + fmtNum(cnt) + '</div>' +
                    '<div class="fin-pipe-label">' + pipeMap[key].label + '</div>' +
                '</div>';
            }
            $('#fin-pipeline').html(pipeHtml);

            // ---- Distributor Debt Table ----
            var distHtml = '';
            if (d.dist_debts && d.dist_debts.length) {
                d.dist_debts.forEach(function(dd, i) {
                    var debtClass = dd.debt > 0 ? 'amt-red' : '';
                    var pct = dd.limit > 0 ? Math.round(dd.debt / dd.limit * 100) : 0;
                    distHtml += '<tr>' +
                        '<td>' + (i + 1) + '</td>' +
                        '<td><strong>' + escHtml(dd.name) + '</strong></td>' +
                        '<td><span class="rank-badge rank-' + dd.rank + '">' + dd.rank + '</span></td>' +
                        '<td style="text-align:right" class="' + debtClass + '">' + fmtBaht(dd.debt) + '</td>' +
                        '<td style="text-align:right">' + fmtBaht(dd.limit) + (dd.limit > 0 ? ' <small style="color:#94a3b8">(' + pct + '%)</small>' : '') + '</td>' +
                        '<td>' + (dd.hold ? '<span class="hold-badge">HOLD</span>' : '<span style="color:var(--fin-green);font-size:12px;">ปกติ</span>') + '</td>' +
                    '</tr>';
                });
            } else {
                distHtml = '<tr><td colspan="6" style="text-align:center;color:#94a3b8;padding:20px;">ไม่มีข้อมูล</td></tr>';
            }
            $('#fin-dist-tbody').html(distHtml);

            // ---- Recent Payments Table ----
            var payHtml = '';
            if (d.recent_payments && d.recent_payments.length) {
                d.recent_payments.forEach(function(p) {
                    payHtml += '<tr>' +
                        '<td><strong>' + escHtml(p.inv) + '</strong></td>' +
                        '<td>' + escHtml(p.dist) + '</td>' +
                        '<td style="text-align:right" class="amt-green">' + fmtBaht(p.amount) + '</td>' +
                        '<td>' + escHtml(p.date) + '</td>' +
                    '</tr>';
                });
            } else {
                payHtml = '<tr><td colspan="4" style="text-align:center;color:#94a3b8;padding:20px;">ไม่มีข้อมูล</td></tr>';
            }
            $('#fin-payments-tbody').html(payHtml);

            // ---- [V.2.0] Distributor Revenue Table ----
            renderRevTable(d.dist_revenue);

            // ---- [V.2.0] Region Map + Province Coverage ----
            renderRegionMap(d.region_summary, d.province_map);

            // ---- Updated timestamp ----
            var now = new Date();
            $('#fin-updated').text('อัพเดทล่าสุด: ' + now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }));

            // ---- [V.2.0] Load AI after main data ----
            finLoadAI(false);

        }).fail(function() {
            $('#fin-updated').text('โหลดข้อมูลไม่สำเร็จ');
        });
    }

    // =======================================
    // [V.2.0] Feature 1: Distributor Revenue Table
    // =======================================
    var allDistRevenue = [];

    function renderRevTable(data) {
        allDistRevenue = data || [];
        filterRevTable('');
    }

    function filterRevTable(query) {
        query = (query || '').toLowerCase().trim();
        var html = '';
        var idx = 0;
        if (allDistRevenue.length) {
            allDistRevenue.forEach(function(dd) {
                // Filter by search query
                if (query && dd.name.toLowerCase().indexOf(query) === -1 &&
                    (dd.province || '').toLowerCase().indexOf(query) === -1) {
                    return;
                }
                idx++;
                var debtClass = dd.debt > 0 ? 'amt-red' : '';
                html += '<tr>' +
                    '<td>' + idx + '</td>' +
                    '<td><strong>' + escHtml(dd.name) + '</strong></td>' +
                    '<td>' + escHtml(dd.province || '-') + '</td>' +
                    '<td><span class="rank-badge rank-' + dd.rank + '">' + dd.rank + '</span></td>' +
                    '<td style="text-align:right">' + fmtBaht(dd.mtd) + '</td>' +
                    '<td style="text-align:right" class="amt-green">' + fmtBaht(dd.cumulative) + '</td>' +
                    '<td style="text-align:right" class="' + debtClass + '">' + fmtBaht(dd.debt) + '</td>' +
                    '<td>' + (dd.hold ? '<span class="hold-badge">HOLD</span>' : '<span style="color:var(--fin-green);font-size:12px;">ปกติ</span>') + '</td>' +
                '</tr>';
            });
        }
        if (!html) {
            html = '<tr><td colspan="8" style="text-align:center;color:#94a3b8;padding:20px;">ไม่พบข้อมูล</td></tr>';
        }
        $('#fin-rev-tbody').html(html);
    }

    // Search input handler
    $(document).on('input', '#fin-dist-search', function() {
        filterRevTable(this.value);
    });

    // =======================================
    // [V.2.0] Feature 2: Region Map + Province Coverage
    // =======================================
    var regionColors = {
        high:   '#10b981',
        medium: '#f59e0b',
        low:    '#ef4444',
        none:   '#cbd5e1'
    };

    function getRegionColor(covered, total) {
        if (total === 0) return regionColors.none;
        var pct = (covered / total) * 100;
        if (pct >= 50) return regionColors.high;
        if (pct >= 25) return regionColors.medium;
        if (pct > 0)   return regionColors.low;
        return regionColors.none;
    }

    function renderRegionMap(regionSummary, provinceMap) {
        if (!regionSummary) return;

        // Color SVG regions
        var svgRegions = document.querySelectorAll('.dnc-fin .fin-region');
        svgRegions.forEach(function(el) {
            var regionName = el.getAttribute('data-region');
            var rs = regionSummary[regionName];
            if (!rs) return;

            var color = getRegionColor(rs.covered, rs.total_provinces);
            var pathEl = el.querySelector('path');
            if (pathEl) pathEl.setAttribute('fill', color);

            // Update stat text
            var statEl = el.querySelector('.region-stat');
            if (statEl) statEl.textContent = rs.distributors + ' ร้าน';
        });

        // Tooltip
        var tooltip = document.getElementById('fin-region-tooltip');
        var mapContainer = document.getElementById('fin-map-container');

        svgRegions.forEach(function(el) {
            el.addEventListener('mouseenter', function(e) {
                var regionName = el.getAttribute('data-region');
                var rs = regionSummary[regionName];
                if (!rs) return;

                var pct = rs.total_provinces > 0 ? Math.round(rs.covered / rs.total_provinces * 100) : 0;
                tooltip.innerHTML =
                    '<strong>' + escHtml(regionName) + '</strong><br>' +
                    'ตัวแทน: ' + rs.distributors + ' ร้าน<br>' +
                    'รายได้: ' + fmtBaht(rs.revenue) + '<br>' +
                    'Coverage: ' + rs.covered + '/' + rs.total_provinces + ' จังหวัด (' + pct + '%)';
                tooltip.classList.add('visible');
            });

            el.addEventListener('mousemove', function(e) {
                var rect = mapContainer.getBoundingClientRect();
                tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
                tooltip.style.top = (e.clientY - rect.top - 10) + 'px';
            });

            el.addEventListener('mouseleave', function() {
                tooltip.classList.remove('visible');
            });

            // Click to filter province list
            el.addEventListener('click', function() {
                var regionName = el.getAttribute('data-region');
                // Activate the corresponding tab
                $('.dnc-fin .fin-region-tab').removeClass('active');
                $('.dnc-fin .fin-region-tab[data-filter="' + regionName + '"]').addClass('active');
                renderProvinceGrid(regionName, provinceMap);
            });
        });

        // Build region filter tabs
        var tabsHtml = '<span class="fin-region-tab active" data-filter="all">ทั้งหมด</span>';
        for (var rName in regionProvinces) {
            tabsHtml += '<span class="fin-region-tab" data-filter="' + escHtml(rName) + '">' + escHtml(rName) + '</span>';
        }
        $('#fin-region-tabs').html(tabsHtml);

        // Tab click handler
        $(document).off('click.finRegionTab').on('click.finRegionTab', '.dnc-fin .fin-region-tab', function() {
            $('.dnc-fin .fin-region-tab').removeClass('active');
            $(this).addClass('active');
            var filter = $(this).attr('data-filter');
            renderProvinceGrid(filter === 'all' ? null : filter, provinceMap);
        });

        // Initial render: all provinces
        renderProvinceGrid(null, provinceMap);
    }

    function renderProvinceGrid(filterRegion, provinceMap) {
        var html = '';
        var regions = filterRegion ? {} : regionProvinces;

        if (filterRegion) {
            regions[filterRegion] = regionProvinces[filterRegion];
        }

        for (var rName in regions) {
            var provs = regions[rName];
            if (!provs) continue;

            // Region header
            html += '<div style="grid-column:1/-1;font-weight:600;font-size:13px;color:var(--fin-heading);margin-top:8px;padding:4px 0;border-bottom:1px solid var(--fin-border);">' + escHtml(rName) + '</div>';

            provs.forEach(function(p) {
                var pm = provinceMap && provinceMap[p];
                var isCovered = pm && pm.count > 0;
                var cls = isCovered ? 'covered' : 'uncovered';
                var info = isCovered ? (pm.count + ' ร้าน') : 'ไม่มีตัวแทน';
                html += '<div class="fin-prov-item ' + cls + '">' +
                    '<span>' + escHtml(p) + '</span>' +
                    '<span>' + info + '</span>' +
                '</div>';
            });
        }

        if (!html) {
            html = '<div style="text-align:center;padding:20px;color:#94a3b8;grid-column:1/-1;">ไม่มีข้อมูล</div>';
        }

        $('#fin-prov-grid').html(html);
    }

    // =======================================
    // [V.2.0] Feature 3: AI Risk Assessment
    // =======================================
    window.finLoadAI = function(force) {
        var $body = $('#fin-ai-body');
        $body.html('<div class="fin-loading"><i class="fa-solid fa-spinner"></i>กำลังวิเคราะห์ด้วย AI...</div>');

        $.post(ajaxUrl, {
            action: 'admin_post_nopriv',
            dinoco_finance_action: 'get_ai_analysis',
            force: force ? '1' : '0'
        }, function(resp) {
            if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {
                $body.html('<div style="color:var(--fin-red);padding:20px;">ไม่สามารถวิเคราะห์ได้ (parse error)</div>');
                return;
            }

            if (resp.success && resp.html) {
                var cacheNote = resp.cached ? '<div style="font-size:11px;color:#94a3b8;margin-bottom:12px;"><i class="fa-solid fa-clock"></i> ผลจาก cache (กดปุ่ม "วิเคราะห์ใหม่" เพื่ออัพเดท)</div>' : '';
                $body.html(cacheNote + resp.html);
            } else {
                var errMsg = resp.error || 'AI วิเคราะห์ไม่สำเร็จ';
                $body.html('<div style="color:var(--fin-red);padding:20px;"><i class="fa-solid fa-triangle-exclamation"></i> ' + escHtml(errMsg) + '</div>');
            }
        }).fail(function() {
            $body.html('<div style="color:var(--fin-red);padding:20px;"><i class="fa-solid fa-triangle-exclamation"></i> เชื่อมต่อ AI ไม่สำเร็จ</div>');
        });
    };

    // =======================================
    // Refresh handler
    // =======================================
    window.finRefresh = function() {
        var $icon = $('#fin-refresh-icon');
        $icon.addClass('fa-spin');
        _origSetTimeout(function(){ $icon.removeClass('fa-spin'); }, 1500);
        finLoad();
    };

    // =======================================
    // Init: finLoad() -> finLoadAI(false)
    // =======================================
    finLoad();
})();
</script>

    <?php
    return ob_get_clean();
}
