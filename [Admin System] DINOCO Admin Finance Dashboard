                d.recent_payments.forEach(function(p) {
                    payHtml += '<tr>' +
                        '<td><strong>' + escHtml(p.inv) + '</strong></td>' +
                        '<td>' + escHtml(p.dist) + '</td>' +
                        '<td style="text-align:right" class="amt-green">' + fmtBaht(p.amount) + '</td>' +
                        '<td>' + escHtml(p.date) + '</td>' +
                    '</tr>';
