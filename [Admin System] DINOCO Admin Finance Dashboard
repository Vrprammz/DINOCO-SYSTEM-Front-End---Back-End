    }

    // =======================================
    // Distributor Revenue Table
    // =======================================
    var allDistRevenue = [];

    function renderRevTable(data) {
        allDistRevenue = data || [];
        filterRevTable('');
    }

    function filterRevTable(query) {
        query = (query || '').toLowerCase().trim();
        var html = '';
        var idx = 0;
        if (allDistRevenue.length) {
            allDistRevenue.forEach(function(dd) {
                if (query && dd.name.toLowerCase().indexOf(query) === -1 &&
                    (dd.province || '').toLowerCase().indexOf(query) === -1) {
                    return;
                }
                idx++;
                var debtClass = dd.debt > 0 ? 'amt-red' : '';
                html += '<tr>' +
                    '<td>' + idx + '</td>' +
                    '<td><strong>' + escHtml(dd.name) + '</strong></td>' +
                    '<td>' + escHtml(dd.province || '-') + '</td>' +
                    '<td><span class="rank-badge rank-' + dd.rank + '">' + dd.rank + '</span></td>' +
                    '<td style="text-align:right">' + fmtBaht(dd.mtd) + '</td>' +
                    '<td style="text-align:right" class="amt-green">' + fmtBaht(dd.cumulative) + '</td>' +
                    '<td style="text-align:right" class="' + debtClass + '">' + fmtBaht(dd.debt) + '</td>' +
                    '<td>' + (dd.hold ? '<span class="hold-badge">HOLD</span>' : '<span style="color:var(--fin-green);font-size:11px;">ปกติ</span>') + '</td>' +
                '</tr>';
            });
        }
        if (!html) {
            html = '<tr><td colspan="8" style="text-align:center;color:#94a3b8;padding:16px;">ไม่พบข้อมูล</td></tr>';
        }
        $('#fin-rev-tbody').html(html);
    }

    // Search input handler
    $(document).on('input', '#fin-dist-search', function() {
        filterRevTable(this.value);
    });

    // =======================================
    // Region Map + Province Coverage
    // =======================================
    var regionColors = {
        high:   '#10b981',
        medium: '#f59e0b',
        low:    '#ef4444',
        none:   '#cbd5e1'
    };

    function getRegionColor(covered, total) {
        if (total === 0) return regionColors.none;
        var pct = (covered / total) * 100;
        if (pct >= 50) return regionColors.high;
        if (pct >= 25) return regionColors.medium;
        if (pct > 0)   return regionColors.low;
        return regionColors.none;
    }

    function renderRegionMap(regionSummary, provinceMap) {
        if (!regionSummary) return;

        // Color SVG regions
        var svgRegions = document.querySelectorAll('.dnc-fin .fin-region');
        svgRegions.forEach(function(el) {
            var regionName = el.getAttribute('data-region');
            var rs = regionSummary[regionName];
            if (!rs) return;

            var color = getRegionColor(rs.covered, rs.total_provinces);
            var pathEl = el.querySelector('path');
            if (pathEl) pathEl.setAttribute('fill', color);

            var statEl = el.querySelector('.region-stat');
            if (statEl) statEl.textContent = rs.distributors + ' ร้าน';
        });

        // Tooltip
        var tooltip = document.getElementById('fin-region-tooltip');
        var mapContainer = document.getElementById('fin-map-container');

        svgRegions.forEach(function(el) {
            el.addEventListener('mouseenter', function(e) {
                var regionName = el.getAttribute('data-region');
                var rs = regionSummary[regionName];
                if (!rs) return;

                var pct = rs.total_provinces > 0 ? Math.round(rs.covered / rs.total_provinces * 100) : 0;
                tooltip.innerHTML =
                    '<strong>' + escHtml(regionName) + '</strong><br>' +
                    'ตัวแทน: ' + rs.distributors + ' ร้าน<br>' +
                    'รายได้: ' + fmtBaht(rs.revenue) + '<br>' +
                    'Coverage: ' + rs.covered + '/' + rs.total_provinces + ' จังหวัด (' + pct + '%)';
                tooltip.classList.add('visible');
            });

            el.addEventListener('mousemove', function(e) {
                var rect = mapContainer.getBoundingClientRect();
                tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
                tooltip.style.top = (e.clientY - rect.top - 10) + 'px';
            });

            el.addEventListener('mouseleave', function() {
                tooltip.classList.remove('visible');
            });

            // Click to filter province list
            el.addEventListener('click', function() {
                var regionName = el.getAttribute('data-region');
                $('.dnc-fin .fin-region-tab').removeClass('active');
                $('.dnc-fin .fin-region-tab[data-filter="' + regionName + '"]').addClass('active');
                renderProvinceGrid(regionName, provinceMap);
            });
        });

        // Build region filter tabs
        var tabsHtml = '<span class="fin-region-tab active" data-filter="all">ทั้งหมด</span>';
        for (var rName in regionProvinces) {
            tabsHtml += '<span class="fin-region-tab" data-filter="' + escHtml(rName) + '">' + escHtml(rName) + '</span>';
        }
        $('#fin-region-tabs').html(tabsHtml);

        // Tab click handler
        $(document).off('click.finRegionTab').on('click.finRegionTab', '.dnc-fin .fin-region-tab', function() {
            $('.dnc-fin .fin-region-tab').removeClass('active');
            $(this).addClass('active');
            var filter = $(this).attr('data-filter');
            renderProvinceGrid(filter === 'all' ? null : filter, provinceMap);
        });

        // Initial render: all provinces
        renderProvinceGrid(null, provinceMap);
    }

    function renderProvinceGrid(filterRegion, provinceMap) {
        var html = '';
        var regions = filterRegion ? {} : regionProvinces;

        if (filterRegion) {
            regions[filterRegion] = regionProvinces[filterRegion];
        }

        for (var rName in regions) {
            var provs = regions[rName];
            if (!provs) continue;

            html += '<div style="grid-column:1/-1;font-weight:600;font-size:12px;color:var(--fin-heading);margin-top:6px;padding:3px 0;border-bottom:1px solid var(--fin-border);">' + escHtml(rName) + '</div>';

            provs.forEach(function(p) {
                var pm = provinceMap && provinceMap[p];
                var isCovered = pm && pm.count > 0;
                var cls = isCovered ? 'covered' : 'uncovered';
                var info = isCovered ? (pm.count + ' ร้าน') : 'ไม่มีตัวแทน';
                html += '<div class="fin-prov-item ' + cls + '">' +
                    '<span>' + escHtml(p) + '</span>' +
                    '<span>' + info + '</span>' +
                '</div>';
            });
        }

        if (!html) {
            html = '<div style="text-align:center;padding:16px;color:#94a3b8;grid-column:1/-1;">ไม่มีข้อมูล</div>';
        }

        $('#fin-prov-grid').html(html);
    }

    // =======================================
    // AI Risk Assessment V.3.0 - JSON card rendering
    // =======================================
    function mapStatusClass(status) {
        if (!status) return 'status-medium';
        if (status.indexOf('ดี') !== -1) return 'status-good';
        if (status.indexOf('ปรับปรุง') !== -1) return 'status-bad';
        return 'status-medium';
    }
    function mapBadgeClass(status) {
        if (!status) return 'badge-medium';
        if (status.indexOf('ดี') !== -1) return 'badge-good';
        if (status.indexOf('ปรับปรุง') !== -1) return 'badge-bad';
        return 'badge-medium';
    }
    function mapPriorityClass(p) {
        if (!p) return 'p-medium';
        if (p.indexOf('สูง') !== -1) return 'p-high';
        if (p.indexOf('ต่ำ') !== -1) return 'p-low';
        return 'p-medium';
    }
    function mapSeverityClass(s) {
        if (!s) return 'sev-medium';
        if (s.indexOf('สูง') !== -1) return 'sev-high';
        if (s.indexOf('ต่ำ') !== -1) return 'sev-low';
        return 'sev-medium';
    }

    function renderAICards(data) {
        var html = '';

        // 1. Overview
        if (data.overview) {
            var ov = data.overview;
            var stClass = mapStatusClass(ov.status);
            var bdClass = mapBadgeClass(ov.status);
            html += '<div class="fin-ai-overview ' + stClass + '">' +
                '<span class="fin-ai-badge ' + bdClass + '">' + escHtml(ov.status || 'ปานกลาง') + '</span>' +
                '<div class="fin-ai-summary">' + escHtml(ov.summary || '') + '</div>' +
            '</div>';
        }

        // 2. Expansion
        if (data.expansion && data.expansion.length) {
            html += '<div class="fin-ai-section-title"><i class="fa-solid fa-map-pin" style="color:var(--fin-green);"></i> พื้นที่ควรขยาย</div>';
            html += '<div class="fin-ai-grid">';
            data.expansion.forEach(function(item) {
                var pClass = mapPriorityClass(item.priority);
                html += '<div class="fin-ai-card">' +
                    '<div class="fin-ai-card-title">' +
                        escHtml(item.province || '') +
                        ' <span class="fin-ai-priority ' + pClass + '">' + escHtml(item.priority || '') + '</span>' +
                        (item.has_bigwing ? '<span class="fin-ai-bigwing-icon">BigWing</span>' : '') +
                    '</div>' +
                    '<div class="fin-ai-card-detail">' + escHtml(item.reason || '') + '</div>' +
                '</div>';
            });
            html += '</div>';
        }

        // 3. Risks
        if (data.risks && data.risks.length) {
            html += '<div class="fin-ai-section-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--fin-red);"></i> ตัวแทนเสี่ยง</div>';
            html += '<div class="fin-tbl-wrap"><table class="fin-ai-risk-table">' +
                '<thead><tr><th>ร้าน</th><th>ปัญหา</th><th>ระดับ</th><th>คำแนะนำ</th></tr></thead><tbody>';
            data.risks.forEach(function(r) {
                var sClass = mapSeverityClass(r.severity);
                html += '<tr>' +
                    '<td><strong>' + escHtml(r.name || '') + '</strong></td>' +
                    '<td>' + escHtml(r.issue || '') + '</td>' +
                    '<td><span class="fin-ai-severity ' + sClass + '">' + escHtml(r.severity || '') + '</span></td>' +
                    '<td>' + escHtml(r.action || '') + '</td>' +
                '</tr>';
            });
            html += '</tbody></table></div>';
        }

        // 4. Strategy
        if (data.strategy && data.strategy.length) {
            html += '<div class="fin-ai-section-title"><i class="fa-solid fa-lightbulb" style="color:var(--fin-blue);"></i> คำแนะนำเชิงกลยุทธ์</div>';
            html += '<div class="fin-ai-strategy">';
            data.strategy.forEach(function(s) {
                var iClass = mapPriorityClass(s.impact);
                html += '<div class="fin-ai-strat-card">' +
                    '<div class="fin-ai-strat-title">' + escHtml(s.title || '') +
                        ' <span class="fin-ai-priority ' + iClass + '">' + escHtml(s.impact || '') + '</span>' +
                    '</div>' +
                    '<div class="fin-ai-strat-detail">' + escHtml(s.detail || '') + '</div>' +
                '</div>';
            });
            html += '</div>';
        }

        return html;
    }

    window.finLoadAI = function(force) {
        var $body = $('#fin-ai-body');
        $body.html('<div class="fin-loading"><i class="fa-solid fa-spinner"></i>กำลังวิเคราะห์ด้วย AI...</div>');

        $.post(ajaxUrl, {
            action: 'admin_post_nopriv',
            dinoco_finance_action: 'get_ai_analysis',
            force: force ? '1' : '0'
        }, function(resp) {
            if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {
                $body.html('<div style="color:var(--fin-red);padding:16px;">ไม่สามารถวิเคราะห์ได้ (parse error)</div>');
                return;
            }

            if (!resp.success) {
                var errMsg = resp.error || 'AI วิเคราะห์ไม่สำเร็จ';
                $body.html('<div style="color:var(--fin-red);padding:16px;"><i class="fa-solid fa-triangle-exclamation"></i> ' + escHtml(errMsg) + '</div>');
                return;
            }

            var cacheNote = resp.cached ? '<div style="font-size:10px;color:#94a3b8;margin-bottom:10px;"><i class="fa-solid fa-clock"></i> ผลจาก cache (กดปุ่ม "วิเคราะห์ใหม่" เพื่ออัพเดท)</div>' : '';

            // Try JSON card rendering
            if (resp.ai_json && typeof resp.ai_json === 'object' && resp.ai_json.overview) {
                $body.html(cacheNote + renderAICards(resp.ai_json));
            } else if (resp.ai_json && typeof resp.ai_json === 'string') {
                // ai_json is a raw string (fallback from cache)
                var parsed = null;
                try { parsed = JSON.parse(resp.ai_json); } catch(e) {}
                if (parsed && parsed.overview) {
                    $body.html(cacheNote + renderAICards(parsed));
                } else {
                    $body.html(cacheNote + '<div style="line-height:1.7;">' + resp.ai_json + '</div>');
                }
            } else if (resp.ai_raw) {
                // Fallback: raw HTML/text from AI
                $body.html(cacheNote + '<div style="line-height:1.7;">' + resp.ai_raw + '</div>');
            } else {
                $body.html('<div style="color:var(--fin-red);padding:16px;"><i class="fa-solid fa-triangle-exclamation"></i> ไม่มีข้อมูลจาก AI</div>');
            }
        }).fail(function() {
            $body.html('<div style="color:var(--fin-red);padding:16px;"><i class="fa-solid fa-triangle-exclamation"></i> เชื่อมต่อ AI ไม่สำเร็จ</div>');
        });
    };

    // =======================================
    // Refresh handler
    // =======================================
    window.finRefresh = function() {
        var $icon = $('#fin-refresh-icon');
        $icon.addClass('fa-spin');
        _origSetTimeout(function(){ $icon.removeClass('fa-spin'); }, 1500);
        finLoad();
    };

    // =======================================
    // Init
    // =======================================
    finLoad();
})();
</script>

