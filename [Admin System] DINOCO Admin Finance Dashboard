    // =======================================
    // Map Fullscreen V.3.11
    // =======================================
    window.toggleMapFullscreen = function() {
        var card = document.querySelector('#fin-svg-map').closest('.fin-card');
        if (!card) return;
        var icon = document.getElementById('fin-map-expand-icon');

        if (card.classList.contains('fin-map-fullscreen')) {
            card.classList.remove('fin-map-fullscreen');
            if (icon) icon.className = 'fa-solid fa-expand';
            document.body.style.overflow = '';
            var svg = card.querySelector('svg');
            if (svg) { svg.style.height = '360px'; svg.style.width = 'auto'; }
        } else {
            card.classList.add('fin-map-fullscreen');
            if (icon) icon.className = 'fa-solid fa-compress';
            document.body.style.overflow = 'hidden';
            var svg = card.querySelector('svg');
            if (svg) { svg.style.height = 'calc(100vh - 120px)'; svg.style.width = 'auto'; }
        }
    };
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            var card = document.querySelector('.fin-map-fullscreen');
            if (card) toggleMapFullscreen();
        }
    });

    // =======================================
    // AI Risk Assessment V.3.0 - JSON card rendering
    // =======================================
    function mapStatusClass(status) {
        if (!status) return 'status-medium';
        if (status.indexOf('ดี') !== -1) return 'status-good';
        if (status.indexOf('ปรับปรุง') !== -1) return 'status-bad';
        return 'status-medium';
    }
    function mapBadgeClass(status) {
        if (!status) return 'badge-medium';
        if (status.indexOf('ดี') !== -1) return 'badge-good';
        if (status.indexOf('ปรับปรุง') !== -1) return 'badge-bad';
        return 'badge-medium';
    }
    function mapPriorityClass(p) {
        if (!p) return 'p-medium';
        if (p.indexOf('สูง') !== -1) return 'p-high';
        if (p.indexOf('ต่ำ') !== -1) return 'p-low';
        return 'p-medium';
    }
    function mapSeverityClass(s) {
        if (!s) return 'sev-medium';
        if (s.indexOf('สูง') !== -1) return 'sev-high';
        if (s.indexOf('ต่ำ') !== -1) return 'sev-low';
        return 'sev-medium';
    }

    function renderAICards(data) {
        var html = '';

        // 1. Overview + Score + Key Metrics
        if (data.overview) {
            var ov = data.overview;
