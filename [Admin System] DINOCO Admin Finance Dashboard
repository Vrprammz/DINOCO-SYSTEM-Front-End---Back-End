/**
 * Fuzzy match province name: trim, ตัด "จังหวัด" prefix, case-insensitive
 */
function dinoco_normalize_province($name) {
    $name = trim($name);
    $name = preg_replace('/^จังหวัด\s*/u', '', $name);
    $name = mb_strtolower($name, 'UTF-8');
    return $name;
}

// ===================================================================
// AJAX Endpoint: dinoco_finance_action
// ===================================================================
add_action('init', function() {

    if ($_SERVER['REQUEST_METHOD'] !== 'POST' || empty($_POST['dinoco_finance_action'])) {
        return;
    }

    $action = sanitize_text_field($_POST['dinoco_finance_action']);

    // -----------------------------------------
    // (a) get_finance_summary
    // -----------------------------------------
    if ($action === 'get_finance_summary') {

        if (ob_get_length()) ob_clean();
        error_reporting(0);
        @ini_set('display_errors', 0);

        header('Content-Type: application/json; charset=utf-8');
        header('Cache-Control: no-cache, no-store, must-revalidate');

        if (!current_user_can('manage_options')) {
            echo json_encode(['success' => false, 'error' => 'ACCESS DENIED']);
            exit;
        }

        global $wpdb;
        date_default_timezone_set('Asia/Bangkok');

        $today      = date('Y-m-d');
        $month_start = date('Y-m-01');
        $year_start  = date('Y-01-01');
        $now_ts      = current_time('timestamp');

        // =======================================
        // 1. DEBT SUMMARY (จาก distributor CPT)
        // =======================================
        $distributors = get_posts([
            'post_type'      => 'distributor',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
        ]);

        $total_debt       = 0;
        $total_credit_limit = 0;
        $credit_hold_count = 0;
        $dist_debts       = [];

        // Build lookup: line_group_id -> dist_id, dist_post_id -> dist_id
        $dist_group_map = []; // source_group_id -> dist_id
        $dist_post_map  = []; // dist post ID -> dist data

        foreach ($distributors as $dist_id) {
            $debt   = floatval(get_field('current_debt', $dist_id) ?: 0);
            $limit  = floatval(get_field('credit_limit', $dist_id) ?: 0);
            $hold   = get_field('credit_hold', $dist_id);
            $name   = get_field('shop_name', $dist_id) ?: get_the_title($dist_id);
            $rank   = get_field('rank_system', $dist_id) ?: 'standard';
            $mtd    = floatval(get_field('monthly_sales_mtd', $dist_id) ?: 0);
            $province = get_field('dist_province', $dist_id) ?: '';
            $line_group = get_field('line_group_id', $dist_id) ?: '';

            $total_debt += $debt;
            $total_credit_limit += $limit;
            if ($hold) $credit_hold_count++;

            $dist_debts[] = [
                'id'       => $dist_id,
                'name'     => $name,
                'debt'     => $debt,
                'limit'    => $limit,
                'hold'     => (bool) $hold,
                'rank'     => $rank,
                'mtd'      => $mtd,
                'province' => $province,
                'line_group' => $line_group,
            ];

            if ($line_group) {
                $dist_group_map[$line_group] = $dist_id;
            }
            $dist_post_map[$dist_id] = count($dist_debts) - 1; // index
        }

        // Sort by debt descending
        usort($dist_debts, function($a, $b) {
            return $b['debt'] <=> $a['debt'];
        });

        // =======================================
        // 2. ORDER FINANCIAL DATA (จาก b2b_order CPT)
        // =======================================

        // 2a. Overdue orders (billed but unpaid, past due_date)
        $overdue_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                'relation' => 'AND',
                ['key' => 'is_billed', 'value' => '1', 'compare' => '='],
                ['key' => 'order_status', 'value' => ['paid', 'completed', 'cancelled'], 'compare' => 'NOT IN'],
                ['key' => 'due_date', 'value' => $today, 'compare' => '<', 'type' => 'DATE'],
            ],
        ]);
        $overdue_count  = $overdue_q->found_posts;
        $overdue_amount = 0;
        $overdue_aging  = ['1_7' => 0, '8_30' => 0, '31_60' => 0, '60_plus' => 0];

        foreach ($overdue_q->posts as $oid) {
            $amt  = floatval(get_field('total_amount', $oid) ?: 0);
            $paid = floatval(get_post_meta($oid, '_inv_paid_amount', true) ?: 0);
            $remaining = $amt - $paid;
            $overdue_amount += $remaining;

            $due = get_field('due_date', $oid);
            if ($due) {
                $days_overdue = max(0, floor((strtotime($today) - strtotime($due)) / 86400));
                if ($days_overdue <= 7)       $overdue_aging['1_7'] += $remaining;
                elseif ($days_overdue <= 30)  $overdue_aging['8_30'] += $remaining;
                elseif ($days_overdue <= 60)  $overdue_aging['31_60'] += $remaining;
                else                          $overdue_aging['60_plus'] += $remaining;
            }
        }

        // 2b. Awaiting payment (billed, not overdue yet)
        $awaiting_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'meta_query'     => [
                'relation' => 'AND',
                ['key' => 'is_billed', 'value' => '1', 'compare' => '='],
                ['key' => 'order_status', 'value' => 'awaiting_payment', 'compare' => '='],
                ['key' => 'due_date', 'value' => $today, 'compare' => '>=', 'type' => 'DATE'],
            ],
        ]);
        $awaiting_amount = 0;
        foreach ($awaiting_q->posts as $oid) {
            $amt  = floatval(get_field('total_amount', $oid) ?: 0);
            $paid = floatval(get_post_meta($oid, '_inv_paid_amount', true) ?: 0);
            $awaiting_amount += ($amt - $paid);
        }

        // 2c. Revenue -- completed/shipped/paid orders this month
        $revenue_month_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [['after' => $month_start, 'inclusive' => true]],
            'meta_query'     => [
                ['key' => 'order_status', 'value' => ['paid', 'shipped', 'completed', 'packed'], 'compare' => 'IN'],
            ],
        ]);
        $revenue_month = 0;
        $orders_month  = $revenue_month_q->found_posts;
        foreach ($revenue_month_q->posts as $oid) {
            $revenue_month += floatval(get_field('total_amount', $oid) ?: 0);
        }

        // 2d. Revenue -- today
        $revenue_today_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [['after' => $today . ' 00:00:00', 'before' => $today . ' 23:59:59', 'inclusive' => true]],
            'meta_query'     => [
                ['key' => 'order_status', 'value' => ['paid', 'shipped', 'completed', 'packed'], 'compare' => 'IN'],
            ],
        ]);
        $revenue_today = 0;
        foreach ($revenue_today_q->posts as $oid) {
            $revenue_today += floatval(get_field('total_amount', $oid) ?: 0);
        }

        // 2e. Revenue -- this year
        $revenue_year_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [['after' => $year_start, 'inclusive' => true]],
            'meta_query'     => [
                ['key' => 'order_status', 'value' => ['paid', 'shipped', 'completed', 'packed'], 'compare' => 'IN'],
            ],
        ]);
        $revenue_year = 0;
        foreach ($revenue_year_q->posts as $oid) {
            $revenue_year += floatval(get_field('total_amount', $oid) ?: 0);
        }

        // 2f. Paid this month (actual collected)
        $paid_month_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [['after' => $month_start, 'inclusive' => true]],
            'meta_query'     => [
                ['key' => 'order_status', 'value' => 'paid', 'compare' => '='],
            ],
        ]);
        $paid_month = 0;
        foreach ($paid_month_q->posts as $oid) {
            $paid_month += floatval(get_post_meta($oid, '_inv_paid_amount', true) ?: get_field('total_amount', $oid) ?: 0);
        }

        // =======================================
        // 3. ORDER PIPELINE
        // =======================================
        $all_statuses = ['draft','checking_stock','awaiting_confirm','awaiting_payment','paid','packed','shipped','completed','cancelled','backorder','claim_opened','claim_resolved'];
        $pipeline = [];
        foreach ($all_statuses as $st) {
            $pq = new WP_Query([
                'post_type'      => 'b2b_order',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'meta_query'     => [['key' => 'order_status', 'value' => $st, 'compare' => '=']],
            ]);
            $pipeline[$st] = $pq->found_posts;
        }

        // =======================================
        // 4. MONTHLY REVENUE TREND (6 months)
        // =======================================
        $monthly_trend = [];
        for ($i = 5; $i >= 0; $i--) {
            $m_start = date('Y-m-01', strtotime("-{$i} months"));
            $m_end   = date('Y-m-t', strtotime("-{$i} months"));
            $m_label = date('M Y', strtotime("-{$i} months"));

            $mq = new WP_Query([
                'post_type'      => 'b2b_order',
                'post_status'    => 'publish',
                'posts_per_page' => -1,
                'fields'         => 'ids',
                'date_query'     => [['after' => $m_start, 'before' => $m_end . ' 23:59:59', 'inclusive' => true]],
                'meta_query'     => [
                    ['key' => 'order_status', 'value' => ['paid', 'shipped', 'completed', 'packed'], 'compare' => 'IN'],
                ],
            ]);
            $m_total = 0;
            foreach ($mq->posts as $oid) {
                $m_total += floatval(get_field('total_amount', $oid) ?: 0);
            }
            $monthly_trend[] = ['label' => $m_label, 'amount' => round($m_total, 2)];
        }

        // =======================================
        // 5. RECENT PAYMENTS (last 10)
        // =======================================
        $recent_payments_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => 10,
            'orderby'        => 'modified',
            'order'          => 'DESC',
            'meta_query'     => [
                ['key' => 'order_status', 'value' => 'paid', 'compare' => '='],
            ],
        ]);
        $recent_payments = [];
        foreach ($recent_payments_q->posts as $p) {
            $recent_payments[] = [
                'id'     => $p->ID,
                'inv'    => get_post_meta($p->ID, '_inv_number', true) ?: '#' . $p->ID,
                'dist'   => get_field('dist_name', $p->ID) ?: '-',
                'amount' => floatval(get_post_meta($p->ID, '_inv_paid_amount', true) ?: get_field('total_amount', $p->ID) ?: 0),
                'date'   => get_the_modified_date('j M Y', $p->ID),
            ];
        }

        // =======================================
        // 6. REVENUE BY RANK
        // =======================================
        $rank_revenue = ['standard' => 0, 'silver' => 0, 'gold' => 0, 'platinum' => 0, 'diamond' => 0];
        foreach ($dist_debts as $d) {
            $r = $d['rank'] ?: 'standard';
            if (isset($rank_revenue[$r])) {
                $rank_revenue[$r] += $d['mtd'];
            }
        }

        // =======================================
        // 7. [V.2.0] DISTRIBUTOR REVENUE TABLE
        // =======================================
        // Cumulative = SUM(total_amount) from completed/paid/shipped orders this year
        // Match via source_group_id -> line_group_id OR _dist_post_id -> distributor post ID

        // Build cumulative per distributor
        $yearly_orders_q = new WP_Query([
            'post_type'      => 'b2b_order',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
            'date_query'     => [['after' => $year_start, 'inclusive' => true]],
            'meta_query'     => [
                ['key' => 'order_status', 'value' => ['paid', 'shipped', 'completed'], 'compare' => 'IN'],
            ],
        ]);

        $dist_cumulative = []; // dist_id -> cumulative amount
        foreach ($yearly_orders_q->posts as $oid) {
            $amt = floatval(get_field('total_amount', $oid) ?: 0);
            $matched_dist_id = null;

            // Try _dist_post_id first
            $dist_post_id = get_post_meta($oid, '_dist_post_id', true);
            if ($dist_post_id && isset($dist_post_map[intval($dist_post_id)])) {
                $matched_dist_id = intval($dist_post_id);
            }

            // Fallback: source_group_id -> line_group_id
            if (!$matched_dist_id) {
                $source_group = get_field('source_group_id', $oid) ?: get_post_meta($oid, 'source_group_id', true);
                if ($source_group && isset($dist_group_map[$source_group])) {
                    $matched_dist_id = $dist_group_map[$source_group];
                }
            }

            if ($matched_dist_id) {
                if (!isset($dist_cumulative[$matched_dist_id])) {
                    $dist_cumulative[$matched_dist_id] = 0;
                }
                $dist_cumulative[$matched_dist_id] += $amt;
            }
        }

        // Build dist_revenue array
        $dist_revenue = [];
        foreach ($dist_debts as $dd) {
            $dist_revenue[] = [
                'id'         => $dd['id'],
                'name'       => $dd['name'],
                'province'   => $dd['province'],
                'rank'       => $dd['rank'],
                'mtd'        => $dd['mtd'],
                'cumulative' => round(isset($dist_cumulative[$dd['id']]) ? $dist_cumulative[$dd['id']] : 0, 2),
                'debt'       => $dd['debt'],
                'credit_limit' => $dd['limit'],
                'hold'       => $dd['hold'],
            ];
        }

        // Sort dist_revenue by cumulative descending
        usort($dist_revenue, function($a, $b) {
            return $b['cumulative'] <=> $a['cumulative'];
        });

        // =======================================
        // 8. [V.2.0] PROVINCE MAP & REGION SUMMARY
        // =======================================
        $region_provinces = dinoco_get_region_provinces();

        // Build province_map: province_name -> { count, revenue, names }
        $province_map = [];
        foreach ($dist_debts as $dd) {
            $prov = dinoco_normalize_province($dd['province']);
            if (!$prov) continue;

            // Find matching canonical province
            $matched_prov = null;
            foreach ($region_provinces as $region => $provs) {
                foreach ($provs as $canonical) {
                    if (dinoco_normalize_province($canonical) === $prov) {
                        $matched_prov = $canonical;
                        break 2;
                    }
                }
            }
            if (!$matched_prov) continue;

            if (!isset($province_map[$matched_prov])) {
                $province_map[$matched_prov] = ['count' => 0, 'revenue' => 0, 'names' => []];
            }
            $province_map[$matched_prov]['count']++;
            $province_map[$matched_prov]['revenue'] += $dd['mtd'];
            $province_map[$matched_prov]['names'][] = $dd['name'];
        }

        // Build region_summary
        $region_summary = [];
        foreach ($region_provinces as $region => $provs) {
            $covered = 0;
            $dist_count = 0;
            $rev = 0;
            foreach ($provs as $p) {
                if (isset($province_map[$p])) {
                    $covered++;
                    $dist_count += $province_map[$p]['count'];
                    $rev += $province_map[$p]['revenue'];
                }
            }
            $region_summary[$region] = [
                'total_provinces' => count($provs),
                'covered'         => $covered,
                'distributors'    => $dist_count,
                'revenue'         => round($rev, 2),
            ];
        }

        // =======================================
        // RESPONSE
        // =======================================
        echo json_encode([
            'success' => true,
            'data'    => [
                // KPI Cards
                'total_debt'         => round($total_debt, 2),
                'total_credit_limit' => round($total_credit_limit, 2),
                'credit_hold_count'  => $credit_hold_count,
                'overdue_count'      => $overdue_count,
                'overdue_amount'     => round($overdue_amount, 2),
                'awaiting_amount'    => round($awaiting_amount, 2),
                'revenue_today'      => round($revenue_today, 2),
                'revenue_month'      => round($revenue_month, 2),
                'revenue_year'       => round($revenue_year, 2),
                'orders_month'       => $orders_month,
                'paid_month'         => round($paid_month, 2),

                // Charts & Tables
                'overdue_aging'     => $overdue_aging,
                'monthly_trend'     => $monthly_trend,
                'pipeline'          => $pipeline,
                'dist_debts'        => array_slice($dist_debts, 0, 15),
                'recent_payments'   => $recent_payments,
                'rank_revenue'      => $rank_revenue,
                'dist_total'        => count($distributors),

                // [V.2.0] New data
                'dist_revenue'      => $dist_revenue,
                'province_map'      => $province_map,
                'region_summary'    => $region_summary,
            ],
        ]);
        exit;
    }

    // -----------------------------------------
    // (b) [V.2.0] get_ai_analysis
    // -----------------------------------------
    if ($action === 'get_ai_analysis') {

        if (ob_get_length()) ob_clean();
        error_reporting(0);
        @ini_set('display_errors', 0);

        header('Content-Type: application/json; charset=utf-8');
        header('Cache-Control: no-cache, no-store, must-revalidate');

        if (!current_user_can('manage_options')) {
            echo json_encode(['success' => false, 'error' => 'ACCESS DENIED']);
            exit;
        }

        $force = !empty($_POST['force']) && $_POST['force'] === '1';

        // Check cache first
        if (!$force) {
            $cached = get_transient('dinoco_ai_fin_analysis');
            if ($cached) {
                echo json_encode(['success' => true, 'html' => $cached, 'cached' => true]);
                exit;
            }
        }

        // Check DINOCO_AI class
        if (!class_exists('DINOCO_AI')) {
            echo json_encode([
                'success' => false,
                'error'   => 'ไม่พบ DINOCO_AI class กรุณา activate AI Provider snippet ก่อนใช้งาน'
            ]);
            exit;
        }

        date_default_timezone_set('Asia/Bangkok');

        // Gather data for AI
        $distributors = get_posts([
            'post_type'      => 'distributor',
            'post_status'    => 'publish',
            'posts_per_page' => -1,
            'fields'         => 'ids',
        ]);

        $dist_summary = [];
        foreach ($distributors as $dist_id) {
            $dist_summary[] = [
                'name'     => get_field('shop_name', $dist_id) ?: get_the_title($dist_id),
                'province' => get_field('dist_province', $dist_id) ?: '',
                'rank'     => get_field('rank_system', $dist_id) ?: 'standard',
                'debt'     => floatval(get_field('current_debt', $dist_id) ?: 0),
                'credit_limit' => floatval(get_field('credit_limit', $dist_id) ?: 0),
                'hold'     => (bool) get_field('credit_hold', $dist_id),
                'mtd'      => floatval(get_field('monthly_sales_mtd', $dist_id) ?: 0),
            ];
        }

        // Province & region data
        $region_provinces = dinoco_get_region_provinces();
        $province_map = [];
        foreach ($dist_summary as $dd) {
            $prov = dinoco_normalize_province($dd['province']);
            if (!$prov) continue;
            $matched = null;
            foreach ($region_provinces as $region => $provs) {
                foreach ($provs as $canonical) {
                    if (dinoco_normalize_province($canonical) === $prov) {
                        $matched = $canonical;
                        break 2;
                    }
                }
            }
            if (!$matched) continue;
            if (!isset($province_map[$matched])) {
                $province_map[$matched] = ['count' => 0, 'revenue' => 0];
            }
            $province_map[$matched]['count']++;
            $province_map[$matched]['revenue'] += $dd['mtd'];
        }

        $region_summary = [];
        foreach ($region_provinces as $region => $provs) {
            $covered = 0;
            $dc = 0;
            $rv = 0;
            foreach ($provs as $p) {
                if (isset($province_map[$p])) {
                    $covered++;
                    $dc += $province_map[$p]['count'];
                    $rv += $province_map[$p]['revenue'];
                }
            }
            $region_summary[$region] = [
                'total' => count($provs),
                'covered' => $covered,
                'distributors' => $dc,
                'revenue' => $rv,
            ];
        }

        // Financial KPIs
        $total_debt = 0;
        $total_hold = 0;
        $total_mtd = 0;
        foreach ($dist_summary as $dd) {
            $total_debt += $dd['debt'];
            $total_mtd += $dd['mtd'];
            if ($dd['hold']) $total_hold++;
        }

        $ai_data = [
            'total_distributors' => count($dist_summary),
            'total_debt' => $total_debt,
            'total_mtd' => $total_mtd,
            'credit_hold_count' => $total_hold,
            'distributors' => $dist_summary,
            'province_coverage' => $province_map,
            'region_summary' => $region_summary,
            'analysis_date' => date('Y-m-d H:i'),
        ];

        $system_prompt = 'คุณคือนักวิเคราะห์ธุรกิจ DINOCO (มอเตอร์ไซค์/อะไหล่) หน้าที่: วิเคราะห์เครือข่ายตัวแทนจำหน่ายและประเมินความเสี่ยงทางธุรกิจ
ตอบเป็นภาษาไทย ใช้ HTML format (<h4>, <ul>, <li>, <strong>, <span style="color:...">) สำหรับแสดงผลใน dashboard
แบ่งการวิเคราะห์เป็น:
1. สรุปภาพรวม - สถานะเครือข่ายตัวแทนโดยรวม
2. พื้นที่ที่ควรขยาย - จังหวัดที่มีศักยภาพแต่ยังไม่มีตัวแทน (ดูจากประชากร, เศรษฐกิจ, ที่ตั้ง)
3. ตัวแทนที่มีความเสี่ยง - หนี้สูง, credit hold, ยอดขายลดลง
4. คำแนะนำเชิงกลยุทธ์ - ควรเพิ่ม/ลด/ปรับตัวแทนอย่างไร';

        $user_message = 'วิเคราะห์ข้อมูลเครือข่ายตัวแทนจำหน่าย DINOCO ต่อไปนี้:' . "\n\n" . json_encode($ai_data, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);

        $result = DINOCO_AI::chat(
            $system_prompt,
            [['role' => 'user', 'text' => $user_message]],
            [],
            ['temperature' => 0.4, 'max_tokens' => 4096, 'model' => 'claude-sonnet-4-20250514']
        );

        if (!empty($result['success']) && !empty($result['text'])) {
            $html = wp_kses_post($result['text']);
            set_transient('dinoco_ai_fin_analysis', $html, HOUR_IN_SECONDS);
            echo json_encode(['success' => true, 'html' => $html, 'cached' => false]);
        } else {
            $err = isset($result['error']) ? $result['error'] : 'AI วิเคราะห์ไม่สำเร็จ กรุณาลองใหม่';
            echo json_encode(['success' => false, 'error' => $err]);
        }
        exit;
    }

}, 20);


