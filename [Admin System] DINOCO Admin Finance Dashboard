                            (r.social_presence ? '<br><span style="font-size:9px;color:#94a3b8;">' + escHtml(r.social_presence) + '</span>' : '') +
                        '</td>' +
                        '<td><span style="font-weight:800;font-size:16px;color:' + scoreColor + ';">' + r.score + '</span></td>' +
                        '<td style="font-size:10px;color:var(--fin-green);">' + escHtml(r.strengths) + '</td>' +
                        '<td style="font-size:10px;color:var(--fin-red);">' + escHtml(r.weaknesses) + '</td>' +
                        '<td style="font-size:10px;font-style:italic;color:#64748b;">"' + escHtml(r.customer_voice || '') + '"</td>' +
                    '</tr>';
                });
                html += '</tbody></table></div>';
            }

            if (bs.dinoco_position) {
                html += '<div style="margin-top:8px;padding:8px 12px;background:var(--fin-blue-bg);border:1px solid #bfdbfe;border-radius:8px;font-size:12px;">' +
                    '<strong style="color:var(--fin-blue);">DINOCO:</strong> ' + escHtml(bs.dinoco_position) +
                '</div>';
            }

            if (bs.improvement_tips && bs.improvement_tips.length) {
                html += '<div style="margin-top:6px;font-size:11px;">';
                html += '<strong style="color:var(--fin-heading);">ควรปรับปรุง:</strong> ';
                html += bs.improvement_tips.map(function(t) { return escHtml(t); }).join(' | ');
                html += '</div>';
            }
        }

        return html;
    }

    // =======================================
    // AI Tips Distribution V.3.2
    // =======================================
    function distributeAITips(aiData) {
        if (!aiData) return;

        // Debt tip - from risks
        if (aiData.risks && aiData.risks.length > 0) {
            var riskNames = aiData.risks.map(function(r) { return r.name; }).join(', ');
            showTip('debt', 'ตัวแทนที่ต้องระวัง: ' + riskNames);
        }

        // Revenue tip - from overview
        if (aiData.overview && aiData.overview.summary) {
            showTip('revenue', aiData.overview.summary);
        }

        // Dist table tip - from strategy
        if (aiData.strategy && aiData.strategy.length > 0) {
            showTip('dist', aiData.strategy[0].title + ' — ' + aiData.strategy[0].detail);
        }

        // Map tip - from expansion
        if (aiData.expansion && aiData.expansion.length > 0) {
            var topExpansion = aiData.expansion.slice(0, 3).map(function(e) { return e.province; }).join(', ');
            showTip('map', 'จังหวัดควรขยาย: ' + topExpansion);
        }
    }

    function showTip(section, text) {
        var el = document.getElementById('fin-ai-tip-' + section);
        if (!el) return;
        el.querySelector('.fin-ai-tip-text').textContent = text;
        el.style.display = 'flex';
    }

    // โหลดเฉพาะ cache — ไม่เรียก API ใหม่ ประหยัด token
    function finLoadAICacheOnly() {
        var $body = $('#fin-ai-body');

        $.post(ajaxUrl, {
            action: 'admin_post_nopriv',
            dinoco_finance_action: 'get_ai_analysis',
            force: '0'
        }, function(resp) {
            if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) { resp = {}; }

            // มี cache → แสดงผล
            if (resp.success && resp.ai_json) {
                var cacheNote = '<div style="font-size:10px;color:#94a3b8;margin-bottom:10px;"><i class="fa-solid fa-clock"></i> ผลจาก cache — กดปุ่ม "วิเคราะห์ใหม่" เมื่อต้องการอัพเดท</div>';
                var aiData = resp.ai_json;
                if (typeof aiData === 'string') { try { aiData = JSON.parse(aiData); } catch(e) { aiData = null; } }
                if (aiData && aiData.overview) {
                    $body.html(cacheNote + renderAICards(aiData));
                    distributeAITips(aiData);
                    return;
                }
            }
            // ไม่มี cache หรือ error → แสดงปุ่มวิเคราะห์ (ไม่แสดง error)
            showAIPlaceholder($body);
        }).fail(function() {
            // AJAX fail → แสดงปุ่มวิเคราะห์เฉยๆ ไม่แสดง error
            showAIPlaceholder($('#fin-ai-body'));
        });
    }

    function showAIPlaceholder($body) {
        $body.html(
            '<div style="text-align:center;padding:30px;">' +
                '<i class="fa-solid fa-brain" style="font-size:32px;color:#c4b5fd;margin-bottom:12px;display:block;"></i>' +
                '<div style="font-size:14px;color:var(--fin-heading);font-weight:600;margin-bottom:4px;">ยังไม่มีผลวิเคราะห์</div>' +
                '<div style="font-size:12px;color:#94a3b8;margin-bottom:16px;">กดปุ่มด้านล่างเพื่อให้ AI วิเคราะห์ข้อมูลธุรกิจ<br>(ใช้เวลา ~10-30 วินาที)</div>' +
                '<button class="fin-btn-refresh" onclick="finLoadAI(true)" style="margin:0 auto;background:#8b5cf6;font-size:14px;padding:10px 24px;">' +
                    '<i class="fa-solid fa-wand-magic-sparkles"></i> วิเคราะห์ตอนนี้' +
                '</button>' +
            '</div>'
        );
    }

    window.finLoadAI = function(force) {
        var $body = $('#fin-ai-body');
        $body.html('<div class="fin-loading"><i class="fa-solid fa-spinner"></i>กำลังวิเคราะห์ด้วย AI... (รอ 10-30 วินาที)</div>');

        $.post(ajaxUrl, {
            action: 'admin_post_nopriv',
            dinoco_finance_action: 'get_ai_analysis',
            force: force ? '1' : '0'
        }, function(resp) {
            if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {
                $body.html('<div style="color:var(--fin-red);padding:16px;">ไม่สามารถวิเคราะห์ได้ (parse error)</div>');
                return;
            }

            if (!resp.success) {
                var errMsg = resp.error || 'AI วิเคราะห์ไม่สำเร็จ';
                var debugHtml = '';
                if (resp.debug) {
                    debugHtml = '<details style="margin-top:8px;font-size:11px;color:#94a3b8;"><summary>Debug info</summary><pre style="white-space:pre-wrap;margin-top:4px;">' + escHtml(JSON.stringify(resp.debug, null, 2)) + '</pre></details>';
                }
                $body.html('<div style="padding:20px;text-align:center;">' +
                    '<div style="color:var(--fin-red);font-size:14px;margin-bottom:12px;"><i class="fa-solid fa-triangle-exclamation"></i> ' + escHtml(errMsg) + '</div>' +
                    '<button class="fin-btn-refresh" onclick="finLoadAI(true)" style="margin:0 auto;background:var(--fin-red);"><i class="fa-solid fa-arrows-rotate"></i> ลองใหม่</button>' +
                    debugHtml +
                '</div>');
                return;
            }

            var cacheNote = resp.cached ? '<div style="font-size:10px;color:#94a3b8;margin-bottom:10px;"><i class="fa-solid fa-clock"></i> ผลจาก cache (กดปุ่ม "วิเคราะห์ใหม่" เพื่ออัพเดท)</div>' : '';

            // Try JSON card rendering
            if (resp.ai_json && typeof resp.ai_json === 'object' && resp.ai_json.overview) {
                $body.html(cacheNote + renderAICards(resp.ai_json));
                distributeAITips(resp.ai_json);
            } else if (resp.ai_json && typeof resp.ai_json === 'string') {
                // ai_json is a raw string (fallback from cache)
                var parsed = null;
                try { parsed = JSON.parse(resp.ai_json); } catch(e) {}
                if (parsed && parsed.overview) {
                    $body.html(cacheNote + renderAICards(parsed));
                    distributeAITips(parsed);
                } else {
                    $body.html(cacheNote + '<div style="line-height:1.7;">' + resp.ai_json + '</div>');
                }
            } else if (resp.ai_raw) {
                // Fallback: raw HTML/text from AI
                $body.html(cacheNote + '<div style="line-height:1.7;">' + resp.ai_raw + '</div>');
            } else {
                $body.html('<div style="color:var(--fin-red);padding:16px;"><i class="fa-solid fa-triangle-exclamation"></i> ไม่มีข้อมูลจาก AI</div>');
            }
        }).fail(function() {
            $body.html('<div style="color:var(--fin-red);padding:16px;"><i class="fa-solid fa-triangle-exclamation"></i> เชื่อมต่อ AI ไม่สำเร็จ</div>');
        });
    };

    // =======================================
    // Refresh handler
    // =======================================
    window.finRefresh = function() {
        var $icon = $('#fin-refresh-icon');
        $icon.addClass('fa-spin');
        _origSetTimeout(function(){ $icon.removeClass('fa-spin'); }, 1500);
        finLoad();
    };

    // =======================================
    // Init
    // =======================================
    finLoad();
})();
</script>

    <?php
    return ob_get_clean();
}
