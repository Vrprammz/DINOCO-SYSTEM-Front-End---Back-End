            var regionKey = region;
            if (region === 'ภาคอีสาน') regionKey = 'ภาคตะวันออกเฉียงเหนือ';
            var rs = regionSummary[regionKey];

            if (rs) {
                var c = colorMap[regionKey] || '#94a3b8';
                html += '<div class="fin-map-stat-card" style="border-left:3px solid ' + c + ';margin-bottom:8px;">' +
                    '<h4 style="font-size:13px;">' + region + '</h4>' +
                    '<div class="stat-num" style="color:var(--fin-green);">' + rs.distributors + ' ร้าน</div>' +
                    '<div class="stat-sub">' + rs.covered + '/' + rs.total_provinces + ' จ. | ' + fmtBaht(rs.revenue) + '</div>' +
                '</div>';
            }

            // Compact distributor + BigWing list
            var regionProvs = (typeof regionProvinces !== 'undefined' && regionProvinces[regionKey]) ? regionProvinces[regionKey] : [];
            var regionDists = (distLocations || []).filter(function(d) { return regionProvs.indexOf(d.province) !== -1; });
            var regionBW = (bigwingLocations || []).filter(function(bw) { return regionProvs.indexOf(bw.province) !== -1; });

            if (regionDists.length || regionBW.length) {
                html += '<div class="fin-map-stat-detail">';
                if (regionDists.length) {
                    html += '<div style="font-weight:600;color:var(--fin-green);margin-bottom:2px;">DINOCO</div>';
                    regionDists.forEach(function(d) {
                        html += '<div class="detail-row"><span>' + escHtml(d.name) + '</span><span style="color:#94a3b8;">' + escHtml(d.province) + '</span></div>';
                    });
                }
                if (regionBW.length) {
                    html += '<div style="font-weight:600;color:var(--fin-blue);margin-top:4px;margin-bottom:2px;">BigWing</div>';
                    regionBW.forEach(function(bw) {
                        html += '<div class="detail-row"><span>' + escHtml(bw.name) + '</span><span style="color:#94a3b8;">' + escHtml(bw.province) + '</span></div>';
                    });
                }
                html += '</div>';
            }
        }

        $stats.html(html);
    }

    // Region tab click handler V.3.6
    jQuery(document).off('click.finMapTab').on('click.finMapTab', '.fin-map-tab', function() {
        jQuery('.fin-map-tab').removeClass('active');
        jQuery(this).addClass('active');

        var region = jQuery(this).attr('data-region');
        var svg = document.querySelector('#fin-svg-map svg');
        if (!svg) return;

        var allProvs = svg.querySelectorAll('.prov');

        // Max height for SVG container
        var maxH = 360;

        if (region === 'all') {
            svg.setAttribute('viewBox', '0 0 600 1231');
            allProvs.forEach(function(el) { el.style.display = ''; });
            svg.querySelectorAll('.map-marker').forEach(function(m) { m.style.display = ''; });
            // ทั้งประเทศ: จำกัดสูง, กว้างตาม ratio
            svg.style.height = maxH + 'px';
            svg.style.width = 'auto';
        } else {
            var minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            var hasVisible = false;

            allProvs.forEach(function(el) {
                var provRegion = el.getAttribute('data-region');
                if (provRegion === region) {
                    el.style.display = '';
                    try {
                        var bbox = el.getBBox();
                        if (bbox.x < minX) minX = bbox.x;
                        if (bbox.y < minY) minY = bbox.y;
                        if (bbox.x + bbox.width > maxX) maxX = bbox.x + bbox.width;
                        if (bbox.y + bbox.height > maxY) maxY = bbox.y + bbox.height;
                        hasVisible = true;
                    } catch(e) {}
                } else {
                    el.style.display = 'none';
                }
            });

            svg.querySelectorAll('.map-marker').forEach(function(m) {
                var cx = parseFloat(m.getAttribute('cx') || m.getAttribute('x') || 0);
                var cy = parseFloat(m.getAttribute('cy') || m.getAttribute('y') || 0);
                if (cx >= minX && cx <= maxX && cy >= minY && cy <= maxY) {
                    m.style.display = '';
                } else {
                    m.style.display = 'none';
                }
            });

            if (hasVisible) {
                var pad = 15;
                minX -= pad; minY -= pad; maxX += pad; maxY += pad;
                var w = maxX - minX;
                var h = maxY - minY;
                svg.setAttribute('viewBox', minX + ' ' + minY + ' ' + w + ' ' + h);

                // ทุกภาคสูงคงที่ maxH — สม่ำเสมอทุกภาค
                svg.style.height = maxH + 'px';
                svg.style.width = 'auto';
                svg.style.maxWidth = '100%';
            }
        }

        // Also filter the province coverage grid below
        var gridRegion = region;
        if (region === 'ภาคอีสาน') gridRegion = 'ภาคตะวันออกเฉียงเหนือ';
        jQuery('.dnc-fin .fin-region-tab').removeClass('active');
        if (region === 'all') {
            jQuery('.dnc-fin .fin-region-tab[data-filter="all"]').addClass('active');
        } else {
            jQuery('.dnc-fin .fin-region-tab[data-filter="' + gridRegion + '"]').addClass('active');
        }

        // Render stats panel
        if (lastData && lastData.region_summary) {
            renderMapStats(region, lastData.region_summary, lastData.dist_locations, lastData.bigwing_locations);
        }
    });

    // Province Coverage (kept from V.3.0, decoupled from SVG)
    function initProvinceCoverage(provinceMap) {
        // Build region filter tabs
        var tabsHtml = '<span class="fin-region-tab active" data-filter="all">ทั้งหมด</span>';
        for (var rName in regionProvinces) {
            tabsHtml += '<span class="fin-region-tab" data-filter="' + escHtml(rName) + '">' + escHtml(rName) + '</span>';
        }
        $('#fin-region-tabs').html(tabsHtml);

        // Tab click handler
        $(document).off('click.finRegionTab').on('click.finRegionTab', '.dnc-fin .fin-region-tab', function() {
            $('.dnc-fin .fin-region-tab').removeClass('active');
            $(this).addClass('active');
            var filter = $(this).attr('data-filter');
            renderProvinceGrid(filter === 'all' ? null : filter, provinceMap);
        });

        // Initial render: all provinces
        renderProvinceGrid(null, provinceMap);
    }

    function renderProvinceGrid(filterRegion, provinceMap) {
        var html = '';
        var regions = filterRegion ? {} : regionProvinces;

        if (filterRegion) {
            regions[filterRegion] = regionProvinces[filterRegion];
        }

        for (var rName in regions) {
            var provs = regions[rName];
            if (!provs) continue;

            html += '<div style="grid-column:1/-1;font-weight:600;font-size:12px;color:var(--fin-heading);margin-top:6px;padding:3px 0;border-bottom:1px solid var(--fin-border);">' + escHtml(rName) + '</div>';

            provs.forEach(function(p) {
                var pm = provinceMap && provinceMap[p];
                var isCovered = pm && pm.count > 0;
                var cls = isCovered ? 'covered' : 'uncovered';
                var info = isCovered ? (pm.count + ' ร้าน') : 'ไม่มีตัวแทน';
                html += '<div class="fin-prov-item ' + cls + '">' +
                    '<span>' + escHtml(p) + '</span>' +
                    '<span>' + info + '</span>' +
                '</div>';
            });
