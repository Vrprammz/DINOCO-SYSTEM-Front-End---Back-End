    // =======================================
    // SVG Map V.3.6
    // =======================================
    function initSvgMap(svgContent, distLocations, bigwingLocations, provinceMap, provincePotential) {
        var container = document.getElementById('fin-svg-map');
        if (!container) return;
        if (!svgContent) {
            container.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8;">ไม่พบไฟล์แผนที่ SVG<br><small>กรุณาอัพโหลด thailand-provinces.svg ไปที่ wp-content/uploads/dinoco/</small></div>';
            return;
        }

        container.innerHTML = svgContent;
        var svg = container.querySelector('svg');
        if (!svg) return;

        // Set initial size — ทั้งประเทศจำกัดสูง 360px
        svg.style.height = '360px';
        svg.style.width = 'auto';
        svg.style.maxWidth = '100%';

        // Build province lookup
        var distByProv = {};
        if (distLocations) {
            distLocations.forEach(function(d) {
                var p = d.province;
                if (!p) return;
                if (!distByProv[p]) distByProv[p] = [];
                distByProv[p].push(d);
            });
        }
        var bwByProv = {};
        if (bigwingLocations) {
            bigwingLocations.forEach(function(bw) {
                var p = bw.province || '';
                if (!p) return;
                if (!bwByProv[p]) bwByProv[p] = [];
                bwByProv[p].push(bw);
            });
        }

        // Color provinces based on coverage
        var allProvs = svg.querySelectorAll('.prov');
        allProvs.forEach(function(el) {
            var provName = el.getAttribute('data-province');
            var hasDinoco = distByProv[provName] && distByProv[provName].length > 0;
            var hasBigwing = bwByProv[provName] && bwByProv[provName].length > 0;

            if (hasDinoco) {
                el.classList.add('has-dinoco');
                el.style.opacity = '1';
            } else if (hasBigwing) {
                el.classList.add('has-bigwing');
                el.style.opacity = '0.85';
            } else {
                el.classList.add('no-coverage');
            }
        });

        // Add marker dots using province path bounding box center
        function getPathCenter(pathEl) {
            try {
                var bbox = pathEl.getBBox();
                return { x: bbox.x + bbox.width / 2, y: bbox.y + bbox.height / 2 };
            } catch(e) { return null; }
        }

        allProvs.forEach(function(el) {
            var provName = el.getAttribute('data-province');
            var center = getPathCenter(el);
            if (!center) return;

            var hasDinoco = distByProv[provName] && distByProv[provName].length > 0;
            var hasBigwing = bwByProv[provName] && bwByProv[provName].length > 0;

            if (hasDinoco) {
                var circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                circle.setAttribute('cx', center.x);
                circle.setAttribute('cy', center.y);
                circle.setAttribute('r', '5');
                circle.setAttribute('fill', '#10b981');
                circle.setAttribute('stroke', '#fff');
                circle.setAttribute('stroke-width', '2');
                circle.setAttribute('class', 'map-marker');
                svg.appendChild(circle);
            }
            if (hasBigwing) {
                var offsetX = hasDinoco ? 8 : 0;
                var rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                rect.setAttribute('x', center.x - 4 + offsetX);
                rect.setAttribute('y', center.y - 4);
                rect.setAttribute('width', '8');
                rect.setAttribute('height', '8');
                rect.setAttribute('rx', '2');
                rect.setAttribute('fill', '#3b82f6');
                rect.setAttribute('stroke', '#fff');
                rect.setAttribute('stroke-width', '1.5');
                rect.setAttribute('class', 'map-marker');
                svg.appendChild(rect);
            }
        });

        // Tooltip
        var tooltip = document.getElementById('fin-map-tooltip');
        var wrapper = container.closest('.fin-svg-map-wrapper');

        allProvs.forEach(function(el) {
            el.addEventListener('mouseenter', function(e) {
                var provName = el.getAttribute('data-province');
                var regionName = el.getAttribute('data-region');
                var dists = distByProv[provName] || [];
                var bws = bwByProv[provName] || [];

                var html = '<div style="font-weight:700;font-size:14px;margin-bottom:2px;">' + escHtml(provName) + '</div>';
                html += '<div style="font-size:10px;color:#94a3b8;margin-bottom:6px;">' + escHtml(regionName) + '</div>';

                // Province potential data
                var pot = (provincePotential && provincePotential[provName]) ? provincePotential[provName] : null;

                if (dists.length) {
                    html += '<div style="color:#4ade80;font-weight:600;margin-bottom:2px;">ตัวแทน DINOCO ' + dists.length + ' ร้าน:</div>';
                    dists.forEach(function(d) {
                        var mtdInfo = d.mtd > 0 ? ' — MTD ' + fmtBaht(d.mtd) : ' — ยังไม่มียอด';
                        html += '<div style="padding-left:8px;font-size:11px;">' + escHtml(d.name) + ' <span style="color:#94a3b8;">(' + escHtml(d.rank || '') + mtdInfo + ')</span></div>';
                    });
                    // แนะนำสำหรับจังหวัดที่มีตัวแทนแล้ว
                    var totalMtd = dists.reduce(function(s, d) { return s + (d.mtd || 0); }, 0);
                    if (totalMtd === 0) {
                        html += '<div style="margin-top:4px;padding:4px 8px;background:#fef3c7;border-radius:4px;font-size:10px;color:#92400e;">⚠ ตัวแทนยังไม่มียอดเดือนนี้ — ควรติดตาม</div>';
                    } else if (pot && pot.score >= 80 && totalMtd < 10000) {
                        html += '<div style="margin-top:4px;padding:4px 8px;background:#fef3c7;border-radius:4px;font-size:10px;color:#92400e;">⚠ ศักยภาพสูง แต่ยอดน้อย — ควรเพิ่มตัวแทนหรือ push ยอด</div>';
                    }
                }
                if (bws.length) {
                    html += '<div style="color:#60a5fa;font-weight:600;margin-top:4px;">Honda BigWing:</div>';
                    bws.forEach(function(bw) {
                        html += '<div style="padding-left:8px;font-size:11px;">' + escHtml(bw.name) + '</div>';
                    });
                }

                // AI Recommendation box
                if (pot) {
                    var scoreColor = pot.score >= 80 ? '#059669' : pot.score >= 60 ? '#d97706' : '#94a3b8';
                    html += '<div style="margin-top:6px;padding:6px 8px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:4px;">';
                    html += '<div style="font-size:10px;color:#64748b;margin-bottom:2px;">ศักยภาพตลาด BigBike</div>';
                    html += '<div style="display:flex;gap:8px;align-items:center;margin-bottom:3px;">';
                    html += '<span style="font-weight:700;font-size:16px;color:' + scoreColor + ';">' + pot.score + '</span>';
                    html += '<span style="font-size:10px;color:#64748b;">คะแนน | จดทะเบียน: ' + escHtml(pot.bigbike_reg) + ' | GDP: ' + escHtml(pot.gdp) + '</span>';
                    html += '</div>';
                    html += '<div style="font-size:10px;color:#334155;">' + escHtml(pot.note) + '</div>';

                    // คำแนะนำเฉพาะ
                    if (!dists.length && !bws.length && pot.score >= 60) {
                        html += '<div style="margin-top:3px;font-size:10px;color:#dc2626;font-weight:600;">★ แนะนำเปิดตัวแทน — ศักยภาพดีแต่ยังไม่มี DINOCO & BigWing</div>';
                    } else if (!dists.length && bws.length) {
                        html += '<div style="margin-top:3px;font-size:10px;color:#2563eb;font-weight:600;">★ โอกาสสูง — มี BigWing แต่ยังไม่มีตัวแทน DINOCO</div>';
                    } else if (!dists.length && pot.score >= 70) {
                        html += '<div style="margin-top:3px;font-size:10px;color:#d97706;font-weight:600;">★ ควรพิจารณาหาตัวแทน — คะแนนศักยภาพสูง</div>';
                    }
                    html += '</div>';
                } else if (!dists.length && !bws.length) {
                    html += '<div style="color:#94a3b8;font-size:10px;margin-top:4px;">ไม่มีตัวแทน & BigWing — ศักยภาพต่ำ</div>';
                }

                tooltip.innerHTML = html;
                tooltip.style.display = 'block';
            });

            el.addEventListener('mousemove', function(e) {
                var x = e.clientX + 15;
                var y = e.clientY - 10;
                // ไม่ให้ตกขอบจอขวา
                if (x + 330 > window.innerWidth) x = e.clientX - 340;
                // ไม่ให้ตกขอบจอล่าง
                if (y + 200 > window.innerHeight) y = e.clientY - 200;
                tooltip.style.left = x + 'px';
                tooltip.style.top = y + 'px';
            });

            el.addEventListener('mouseleave', function() {
                tooltip.style.display = 'none';
            });

            // Click to filter province grid
            el.addEventListener('click', function() {
                var regionName = el.getAttribute('data-region');
                var gridRegion = regionName;
                if (regionName === 'ภาคอีสาน') gridRegion = 'ภาคตะวันออกเฉียงเหนือ';

                jQuery('.dnc-fin .fin-region-tab').removeClass('active');
                jQuery('.dnc-fin .fin-region-tab[data-filter="' + gridRegion + '"]').addClass('active');
                var grid = document.getElementById('fin-prov-grid');
                if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
        });
    }

    // =======================================
    // Map Region Stats Panel V.3.6
    // =======================================
    function renderMapStats(region, regionSummary, distLocations, bigwingLocations) {
        var $stats = jQuery('#fin-map-stats');
        if (!$stats.length) return;

        var colorMap = {
            'ภาคเหนือ': '#4ade80', 'ภาคตะวันออกเฉียงเหนือ': '#fbbf24',
            'ภาคกลาง': '#f87171', 'ภาคตะวันออก': '#60a5fa',
            'ภาคตะวันตก': '#c084fc', 'ภาคใต้': '#2dd4bf'
        };
        var shortNames = {
            'ภาคเหนือ': 'เหนือ', 'ภาคตะวันออกเฉียงเหนือ': 'อีสาน',
            'ภาคกลาง': 'กลาง', 'ภาคตะวันออก': 'ตะวันออก',
            'ภาคตะวันตก': 'ตะวันตก', 'ภาคใต้': 'ใต้'
        };
        var html = '';

        if (region === 'all') {
            // Compact 3x2 grid — mini cards
            html += '<div class="fin-map-stats-grid">';
            for (var rName in regionSummary) {
                var rs = regionSummary[rName];
                var c = colorMap[rName] || '#94a3b8';
                var sn = shortNames[rName] || rName;
                html += '<div class="fin-map-stat-card">' +
                    '<h4><span style="width:8px;height:8px;border-radius:2px;background:' + c + ';display:inline-block;"></span> ' + sn + '</h4>' +
                    '<div class="stat-num">' + rs.distributors + ' <span style="font-size:11px;font-weight:400;color:#94a3b8;">ร้าน</span></div>' +
                    '<div class="stat-sub">' + rs.covered + '/' + rs.total_provinces + ' จ. | ' + fmtBaht(rs.revenue) + '</div>' +
                '</div>';
