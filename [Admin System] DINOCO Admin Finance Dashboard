                        '<td>' + (i + 1) + '</td>' +
                        '<td><strong>' + escHtml(cw.name) + '</strong></td>' +
                        '<td>' + escHtml(cw.province || '-') + '</td>' +
                        '<td>' + escHtml(cw.last_order) + '</td>' +
                        '<td class="' + daysClass + '">' + daysText + '</td>' +
                    '</tr>';
                });
                $('#fin-churn-tbody').html(churnHtml);
            } else {
                $('#fin-churn-section').hide();
