// P2-5. CUSTOMER LINK — Link FB/IG user กับ WP member
// =========================================================================
function dinoco_mcp_customer_link( $request ) {
    $source_id = sanitize_text_field( $request->get_param( 'source_id' ) ); // FB/IG user ID
    $platform  = sanitize_text_field( $request->get_param( 'platform' ) );  // facebook / instagram
    $wp_user   = sanitize_text_field( $request->get_param( 'wp_user_id_or_phone' ) );

    if ( empty( $source_id ) || empty( $wp_user ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'source_id and wp_user_id_or_phone required' ), 400 );
    }

    // หา WP user จาก user_id หรือ phone
    $user = null;
    if ( is_numeric( $wp_user ) ) {
        $user = get_user_by( 'ID', (int) $wp_user );
    }
    if ( ! $user ) {
        // ค้นจาก phone ใน user meta
        $users = get_users( array(
            'meta_key'   => 'phone',
            'meta_value' => $wp_user,
            'number'     => 1,
        ) );
        $user = ! empty( $users ) ? $users[0] : null;
    }

    if ( ! $user ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'WP user not found' ), 404 );
    }

    // บันทึก link ใน user meta
    $meta_key = 'mcp_' . ( $platform ?: 'social' ) . '_id';
    update_user_meta( $user->ID, $meta_key, $source_id );
    update_user_meta( $user->ID, 'mcp_linked_platform', $platform );
    update_user_meta( $user->ID, 'mcp_linked_at', current_time( 'mysql' ) );

    return new WP_REST_Response( array(
        'success'    => true,
        'wp_user_id' => $user->ID,
        'platform'   => $platform,
        'source_id'  => $source_id,
    ), 200 );
}

// =========================================================================
// P2-6. DEALER SLA REPORT — Dealer SLA metrics
// =========================================================================
function dinoco_mcp_dealer_sla_report( $request ) {
    $dealer_id = sanitize_text_field( $request->get_param( 'dealer_id' ) );

    // ดึง claims ที่มี dealer_id
    $args = array(
        'post_type'      => 'claim_ticket',
        'posts_per_page' => 200,
        'post_status'    => 'publish',
        'meta_query'     => array(),
    );

    if ( ! empty( $dealer_id ) ) {
        $args['meta_query'][] = array( 'key' => 'claim_dealer_id', 'value' => $dealer_id );
    }

    $posts = get_posts( $args );

    // คำนวณ SLA metrics
    $total_claims   = count( $posts );
    $resolved       = 0;
    $avg_resolve_hr = 0;
    $resolve_times  = array();

    foreach ( $posts as $p ) {
        $status = get_post_meta( $p->ID, 'ticket_status', true );
        if ( in_array( $status, array( 'resolved', 'completed', 'closed' ), true ) ) {
            $resolved++;
            $created = strtotime( $p->post_date );
            $updated = strtotime( $p->post_modified );
            if ( $created && $updated && $updated > $created ) {
                $resolve_times[] = ( $updated - $created ) / 3600; // hours
            }
        }
    }

    if ( ! empty( $resolve_times ) ) {
        $avg_resolve_hr = round( array_sum( $resolve_times ) / count( $resolve_times ), 1 );
    }

    $report = array(
        'dealer_id'            => $dealer_id ?: 'all',
        'total_claims'         => $total_claims,
        'resolved_claims'      => $resolved,
        'resolution_rate'      => $total_claims > 0 ? round( $resolved / $total_claims * 100, 1 ) : 0,
        'avg_resolution_hours' => $avg_resolve_hr,
        'generated_at'         => current_time( 'c' ),
    );

    return new WP_REST_Response( $report, 200 );
}

// =========================================================================
// P2-7. DISTRIBUTOR GET — distributor detail by ID
// =========================================================================
function dinoco_mcp_distributor_get( $request ) {
    $id = (int) $request['id'];

    $post = get_post( $id );
    if ( ! $post || $post->post_type !== 'distributor' ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'Distributor not found' ), 404 );
    }

    $result = array(
        'found'         => true,
        'id'            => $post->ID,
        'name'          => get_post_meta( $post->ID, 'shop_name', true ) ?: $post->post_title,
        'province'      => get_post_meta( $post->ID, 'province', true ),
        'phone'         => get_post_meta( $post->ID, 'phone', true ),
        'address'       => get_post_meta( $post->ID, 'address', true ),
        'line_group_id' => get_post_meta( $post->ID, 'line_group_id', true ),
        'active'        => get_post_meta( $post->ID, 'is_active', true ) !== '0',
        'contact_name'  => get_post_meta( $post->ID, 'contact_name', true ),
        'created_at'    => get_the_date( 'c', $post ),
    );

    // ดึง debt info ถ้ามี
    $debt = get_field( 'current_debt', $post->ID );
    if ( $debt !== null ) {
        $result['current_debt'] = (float) $debt;
    }

    return new WP_REST_Response( $result, 200 );
}

// =========================================================================
// P2-8. PRODUCT COMPATIBILITY — ค้นหาสินค้าที่ใช้ได้กับรุ่นมอเตอร์ไซค์
// =========================================================================
function dinoco_mcp_product_compatibility( $request ) {
    $brand = sanitize_text_field( $request->get_param( 'brand' ) );
    $model = sanitize_text_field( $request->get_param( 'model' ) );

    if ( empty( $brand ) && empty( $model ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'brand or model required' ), 400 );
    }

    $catalog = function_exists( 'b2b_get_catalog' ) ? b2b_get_catalog() : get_option( 'dinoco_product_catalog', array() );
    if ( empty( $catalog ) || ! is_array( $catalog ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'ไม่มีข้อมูลสินค้าในระบบ' ), 200 );
    }

    $search_term = mb_strtolower( trim( $brand . ' ' . $model ), 'UTF-8' );
    $matches = array();

    foreach ( $catalog as $sku => $item ) {
        $name_lower = mb_strtolower( isset( $item['name'] ) ? $item['name'] : '', 'UTF-8' );
        $compat     = mb_strtolower( isset( $item['compatibility'] ) ? $item['compatibility'] : '', 'UTF-8' );
        $haystack   = $name_lower . ' ' . $compat;

        // ตรวจ brand + model ใน product name หรือ compatibility field
        $brand_match = empty( $brand ) || mb_strpos( $haystack, mb_strtolower( $brand, 'UTF-8' ) ) !== false;
        $model_match = empty( $model ) || mb_strpos( $haystack, mb_strtolower( $model, 'UTF-8' ) ) !== false;

        if ( $brand_match && $model_match ) {
            $in_stock = isset( $item['in_stock'] ) ? $item['in_stock'] : true;
            $on_hold  = isset( $item['on_hold'] ) ? $item['on_hold'] : false;
            $matches[] = array(
                'sku'          => $sku,
                'name'         => isset( $item['name'] ) ? $item['name'] : '',
                'price'        => isset( $item['price'] ) ? $item['price'] : 0,
                'img_url'      => isset( $item['img'] ) ? $item['img'] : '',
                'stock_status' => $on_hold ? 'hold' : ( $in_stock ? 'available' : 'out_of_stock' ),
            );
        }
    }

    if ( empty( $matches ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => "ไม่พบสินค้าสำหรับ {$brand} {$model}" ), 200 );
    }

    return new WP_REST_Response( array( 'found' => true, 'count' => count( $matches ), 'products' => $matches ), 200 );
}

// =========================================================================
// P3-1. KB UPDATED — Webhook trigger for Qdrant re-sync
// =========================================================================
function dinoco_mcp_kb_updated( $request ) {
    // Acknowledge webhook — OpenClaw สามารถ re-sync Qdrant ได้เอง
    // บันทึก last trigger time เพื่อ debug
    update_option( 'dinoco_mcp_kb_last_updated', current_time( 'mysql' ), false );

    // นับจำนวน KB entries ปัจจุบัน
    $count = wp_count_posts( 'ai_knowledge' );
    $total = isset( $count->publish ) ? $count->publish : 0;
    $total += isset( $count->private ) ? $count->private : 0;

    return new WP_REST_Response( array(
        'acknowledged' => true,
        'kb_total'     => $total,
        'triggered_at' => current_time( 'c' ),
    ), 200 );
}

// =========================================================================
// P3-2. INVENTORY CHANGED — Webhook trigger when stock changes
// =========================================================================
function dinoco_mcp_inventory_changed( $request ) {
    $sku      = sanitize_text_field( $request->get_param( 'sku' ) );
    $action   = sanitize_text_field( $request->get_param( 'action' ) ); // "in" / "out" / "hold" / "release"
    $quantity = (int) $request->get_param( 'quantity' );

    // บันทึก event log
    $log = get_option( 'dinoco_mcp_inventory_log', array() );
    $log[] = array(
        'sku'      => $sku,
        'action'   => $action,
        'quantity' => $quantity,
        'at'       => current_time( 'mysql' ),
    );
    // เก็บล่าสุด 200 entries
    $log = array_slice( $log, -200 );
    update_option( 'dinoco_mcp_inventory_log', $log, false );

    return new WP_REST_Response( array(
        'acknowledged' => true,
        'sku'          => $sku,
        'action'       => $action,
        'logged_at'    => current_time( 'c' ),
    ), 200 );
}

