if ( ! defined( 'ABSPATH' ) ) exit;

// === API Key Authentication ===
function dinoco_mcp_verify_key( $request ) {
    $key = $request->get_header( 'X-API-Key' );
    if ( empty( $key ) ) return new WP_Error( 'no_key', 'Missing X-API-Key header', array( 'status' => 401 ) );

    $stored_key = get_option( 'dinoco_mcp_api_key', '' );
    if ( empty( $stored_key ) ) {
        // Auto-generate key on first use
        $stored_key = wp_generate_password( 64, false );
        update_option( 'dinoco_mcp_api_key', $stored_key );
        error_log( '[MCP Bridge] API key auto-generated. Retrieve via: get_option("dinoco_mcp_api_key")' );
    }

    if ( ! hash_equals( $stored_key, $key ) ) {
        return new WP_Error( 'invalid_key', 'Invalid API key', array( 'status' => 403 ) );
    }
    return true;
}

// === Register REST Routes ===
add_action( 'rest_api_init', function() {

    $ns = 'dinoco-mcp/v1';

    register_rest_route( $ns, '/product-lookup', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mcp_product_lookup',
        'permission_callback' => 'dinoco_mcp_verify_key',
    ) );

    register_rest_route( $ns, '/dealer-lookup', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mcp_dealer_lookup',
        'permission_callback' => 'dinoco_mcp_verify_key',
    ) );

    register_rest_route( $ns, '/warranty-check', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mcp_warranty_check',
        'permission_callback' => 'dinoco_mcp_verify_key',
    ) );

    register_rest_route( $ns, '/kb-search', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mcp_kb_search',
        'permission_callback' => 'dinoco_mcp_verify_key',
    ) );

    register_rest_route( $ns, '/kb-export', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_mcp_kb_export',
        'permission_callback' => 'dinoco_mcp_verify_key',
    ) );

    register_rest_route( $ns, '/catalog-full', array(
        'methods'             => 'GET',
        'callback'            => 'dinoco_mcp_catalog_full',
        'permission_callback' => 'dinoco_mcp_verify_key',
    ) );

    // === LEAD PIPELINE ENDPOINTS ===
    register_rest_route( $ns, '/distributor-notify', array(
        'methods'             => 'POST',
        'callback'            => 'dinoco_mcp_distributor_notify',
        'permission_callback' => 'dinoco_mcp_verify_key',
