        }
    }

    return new WP_REST_Response( array( 'found' => false, 'message' => "ไม่พบตัวแทนในพื้นที่ '{$location}'" ), 200 );
}

// =========================================================================
// 3. WARRANTY CHECK — เช็คสถานะการรับประกัน
// =========================================================================
function dinoco_mcp_warranty_check( $request ) {
    $serial = sanitize_text_field( $request->get_param( 'serial' ) );
    $phone  = sanitize_text_field( $request->get_param( 'phone' ) );

    if ( empty( $serial ) && empty( $phone ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'กรุณาระบุ serial หรือเบอร์โทร' ), 400 );
    }

    $args = array(
        'post_type'      => 'serial_number',
        'posts_per_page' => 5,
        'post_status'    => 'publish',
    );

    // [Security] ใช้ exact match เท่านั้น ห้าม LIKE (ป้องกัน data enumeration)
    // [Security] enforce minimum length ป้องกัน search กว้างเกินไป
    if ( ! empty( $serial ) ) {
        if ( mb_strlen( $serial ) < 5 ) {
            return new WP_REST_Response( array( 'found' => false, 'message' => 'กรุณาระบุ serial อย่างน้อย 5 ตัวอักษร' ), 400 );
        }
        $args['meta_query'] = array(
            array( 'key' => 'serial_code', 'value' => $serial, 'compare' => '=' ),
        );
    } elseif ( ! empty( $phone ) ) {
        if ( mb_strlen( preg_replace( '/[^0-9]/', '', $phone ) ) < 10 ) {
            return new WP_REST_Response( array( 'found' => false, 'message' => 'กรุณาระบุเบอร์โทร 10 หลัก' ), 400 );
        }
        $args['meta_query'] = array(
            array( 'key' => 'owner_phone', 'value' => $phone, 'compare' => '=' ),
        );
    }
    $args['posts_per_page'] = 2; // จำกัด results ป้องกัน data dump

    $posts = get_posts( $args );
    if ( empty( $posts ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'ไม่พบข้อมูลการรับประกัน' ), 200 );
    }

    $results = array();
    foreach ( $posts as $p ) {
        $expiry = get_post_meta( $p->ID, 'warranty_expiry', true );
        $status = get_post_meta( $p->ID, 'w_status', true );
        $results[] = array(
            'serial'       => get_post_meta( $p->ID, 'serial_code', true ),
            'product'      => get_post_meta( $p->ID, 'owner_product', true ),
            'status'       => $status ? $status : 'unknown',
            'expiry_date'  => $expiry ? $expiry : '',
            'is_expired'   => $expiry ? ( strtotime( $expiry ) < time() ) : null,
            // [Security] ห้ามส่ง owner_name ข้ามระบบ (PII)
            'registered_at' => get_the_date( 'Y-m-d', $p ),
        );
    }

    return new WP_REST_Response( array( 'found' => true, 'count' => count( $results ), 'warranties' => $results ), 200 );
}

// =========================================================================
// 4. KB SEARCH — ค้นหา Knowledge Base
// =========================================================================
function dinoco_mcp_kb_search( $request ) {
    $query = sanitize_text_field( $request->get_param( 'query' ) );
    if ( empty( $query ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'กรุณาระบุ query' ), 400 );
    }

    $posts = get_posts( array(
        'post_type'      => 'ai_knowledge',
        'posts_per_page' => -1,
        'post_status'    => array( 'publish', 'private' ),
    ) );

    $query_lower = mb_strtolower( $query, 'UTF-8' );
    $terms = array_filter( preg_split( '/[\s,]+/u', $query_lower ), function( $w ) { return mb_strlen( $w, 'UTF-8' ) >= 2; } );

    $scored = array();
    foreach ( $posts as $p ) {
        $q = mb_strtolower( (string) get_post_meta( $p->ID, 'training_phrases', true ), 'UTF-8' );
        $f = mb_strtolower( (string) get_post_meta( $p->ID, 'core_facts', true ), 'UTF-8' );
        $a = mb_strtolower( (string) get_post_meta( $p->ID, 'ai_action', true ), 'UTF-8' );
        $all_text = $q . ' ' . $f . ' ' . $a;

        $score = 0;
        foreach ( $terms as $t ) {
            if ( mb_strpos( $all_text, $t ) !== false ) $score += ( mb_strlen( $t, 'UTF-8' ) >= 4 ) ? 15 : 8;
        }

        if ( $score > 0 ) {
            $scored[] = array(
                'id'       => $p->ID,
                'question' => get_post_meta( $p->ID, 'training_phrases', true ),
                'facts'    => get_post_meta( $p->ID, 'core_facts', true ),
                'action'   => get_post_meta( $p->ID, 'ai_action', true ),
                'score'    => $score,
            );
        }
    }

    usort( $scored, function( $a, $b ) { return $b['score'] <=> $a['score']; } );
    $top = array_slice( $scored, 0, 5 );
    foreach ( $top as &$s ) { unset( $s['score'] ); }

    if ( empty( $top ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => "ไม่พบข้อมูลเกี่ยวกับ '{$query}'" ), 200 );
    }

    return new WP_REST_Response( array( 'found' => true, 'count' => count( $top ), 'entries' => $top ), 200 );
}

// =========================================================================
// 5. KB EXPORT — Export KB ทั้งหมดสำหรับ Qdrant sync
// =========================================================================
function dinoco_mcp_kb_export( $request ) {
    $posts = get_posts( array(
        'post_type'      => 'ai_knowledge',
        'posts_per_page' => -1,
        'post_status'    => array( 'publish', 'private' ),
        'orderby'        => 'ID',
        'order'          => 'ASC',
    ) );

    $entries = array();
    foreach ( $posts as $p ) {
        $q = get_post_meta( $p->ID, 'training_phrases', true );
        if ( empty( $q ) ) continue;
        $entries[] = array(
            'id'       => $p->ID,
            'question' => $q,
            'facts'    => (string) get_post_meta( $p->ID, 'core_facts', true ),
            'action'   => (string) get_post_meta( $p->ID, 'ai_action', true ),
        );
    }

    return new WP_REST_Response( array( 'count' => count( $entries ), 'entries' => $entries ), 200 );
}

