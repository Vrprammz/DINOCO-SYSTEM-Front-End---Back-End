        'สมุทรปราการ' => 69, 'บางนา' => 69, 'ปากน้ำ' => 69,
        'เชียงใหม่' => 70, 'เชียงราย' => 70, 'ลำปาง' => 70,
        'โคราช' => 71, 'นครราชสีมา' => 71, 'อุดร' => 71, 'ขอนแก่น' => 71,
        'ภูเก็ต' => 54, 'หาดใหญ่' => 54, 'สงขลา' => 54,
        'ชลบุรี' => 53, 'ระยอง' => 53, 'พัทยา' => 53,
        // จังหวัดไม่มีตัวแทน
        'สุพรรณบุรี' => 80, 'นครปฐม' => 80, 'อยุธยา' => 80, 'กาญจนบุรี' => 80, 'หัวหิน' => 80,
        'พิษณุโลก' => 81, 'ตาก' => 81, 'น่าน' => 81,
        'บุรีรัมย์' => 82, 'สุรินทร์' => 82, 'ชัยภูมิ' => 82, 'ร้อยเอ็ด' => 82,
        'กระบี่' => 83, 'ตรัง' => 83, 'นครศรีธรรมราช' => 83, 'ยะลา' => 83,
    );

    // ค้นหา location ใน map → ดึง KB entry ตรงจาก post_id
    foreach ( $location_to_post_id as $loc_key => $post_id ) {
        if ( mb_strpos( $location_lower, $loc_key ) !== false ) {
            $q = get_post_meta( $post_id, 'training_phrases', true );
