// =========================================================================
// Lead Storage Helpers (V.2.2) — per-row wp_options แทน flat array
// แต่ละ lead เก็บแยก option: dinoco_mcp_lead_{lead_id}
// ปลอดภัยกว่า read-modify-write flat array + ไม่ degrade ตาม lead count
// =========================================================================

/**
 * Migrate flat array (dinoco_mcp_leads) → per-row wp_options
 * เรียกอัตโนมัติครั้งแรกที่มีการอ่าน/เขียน lead
 */
function dinoco_mcp_migrate_leads_if_needed() {
    // ถ้า migrate แล้วไม่ต้องทำซ้ำ
    if ( get_option( 'dinoco_mcp_leads_migrated', false ) ) return;

    $old_leads = get_option( 'dinoco_mcp_leads', array() );
    if ( ! empty( $old_leads ) && is_array( $old_leads ) ) {
        foreach ( $old_leads as $lead ) {
            if ( empty( $lead['lead_id'] ) ) continue;
            $key = 'dinoco_mcp_lead_' . sanitize_key( $lead['lead_id'] );
            // ไม่ overwrite ถ้ามีอยู่แล้ว (กรณี migrate ซ้ำ)
            if ( false === get_option( $key ) ) {
                update_option( $key, $lead, false );
            }
        }
    }

    update_option( 'dinoco_mcp_leads_migrated', true, false );
    // เก็บ old option ไว้ backup — ไม่ delete ทันที
}

/**
 * บันทึก lead เดี่ยวลง wp_options
 */
function dinoco_mcp_save_lead( $lead ) {
    $lead_id = $lead['lead_id'] ?? uniqid( 'LEAD-' );
    $lead['lead_id']    = $lead_id;
    $lead['updated_at'] = current_time( 'mysql' );
    update_option( 'dinoco_mcp_lead_' . sanitize_key( $lead_id ), $lead, false );
    return $lead_id;
}

/**
 * ดึง lead เดี่ยวจาก lead_id
 */
function dinoco_mcp_get_lead( $lead_id ) {
    dinoco_mcp_migrate_leads_if_needed();
    $lead = get_option( 'dinoco_mcp_lead_' . sanitize_key( $lead_id ), null );
    return $lead;
}

/**
 * ดึง leads ทั้งหมดจาก DB (per-row query)
 * $limit/$offset สำหรับ pagination, $filters สำหรับ PHP-side filtering
 */
function dinoco_mcp_get_all_leads( $limit = 100, $offset = 0, $filters = array() ) {
    dinoco_mcp_migrate_leads_if_needed();
    global $wpdb;

    // ดึงทั้งหมดที่ match prefix แล้ว filter ใน PHP (wp_options ไม่มี index บน value)
    $rows = $wpdb->get_results( $wpdb->prepare(
        "SELECT option_name, option_value FROM {$wpdb->options}
         WHERE option_name LIKE %s
         ORDER BY option_id DESC",
        $wpdb->esc_like( 'dinoco_mcp_lead_' ) . '%'
    ) );

    $leads = array();
    foreach ( $rows as $row ) {
        $lead = maybe_unserialize( $row->option_value );
        if ( ! is_array( $lead ) || empty( $lead['lead_id'] ) ) continue;

        // Apply filters
        if ( ! empty( $filters['status'] ) && ( $lead['status'] ?? '' ) !== $filters['status'] ) continue;
        if ( ! empty( $filters['dealer_id'] ) && ( $lead['dealer_id'] ?? '' ) !== $filters['dealer_id'] ) continue;

        $leads[] = $lead;
    }

    // Sort by created_at DESC
    usort( $leads, function( $a, $b ) {
        return strcmp( $b['created_at'] ?? '', $a['created_at'] ?? '' );
    } );

    $total = count( $leads );
    $paged = array_slice( $leads, $offset, $limit );

    return array( 'leads' => $paged, 'total' => $total );
}

// =========================================================================
// P1-1. LEAD CREATE — สร้าง lead record ใหม่
// =========================================================================
function dinoco_mcp_lead_create( $request ) {
    $customer_name     = sanitize_text_field( $request->get_param( 'customer_name' ) );
    $product_interest  = sanitize_text_field( $request->get_param( 'product_interest' ) );
    $province          = sanitize_text_field( $request->get_param( 'province' ) );
    $dealer_id         = sanitize_text_field( $request->get_param( 'dealer_id' ) );
    $phone             = sanitize_text_field( $request->get_param( 'phone' ) );
    $platform          = sanitize_text_field( $request->get_param( 'platform' ) ); // facebook / instagram / line / website
    $source_id         = sanitize_text_field( $request->get_param( 'source_id' ) ); // FB user ID / IG user ID
    $customer_platform = sanitize_text_field( $request->get_param( 'customer_platform' ) );

    if ( empty( $customer_name ) && empty( $phone ) && empty( $source_id ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'customer_name, phone, or source_id required' ), 400 );
    }

    // TODO: MCP leads ถูกเก็บใน WP (wp_options) แต่ LIFF AI leads อยู่ใน MongoDB (ผ่าน Agent proxy)
    // ยังไม่มี sync mechanism ระหว่าง 2 ระบบ — ควรรวมเป็น single source of truth ในอนาคต
    // ตัวเลือก: (1) ให้ MCP Bridge forward ไป Agent proxy (2) ให้ LIFF AI อ่านจาก WP

    dinoco_mcp_migrate_leads_if_needed();

    $lead_id = 'LEAD-' . time() . '-' . wp_rand( 1000, 9999 );

    $new_lead = array(
        'lead_id'            => $lead_id,
        'customer_name'      => $customer_name,
        'product_interest'   => $product_interest,
        'province'           => $province,
        'dealer_id'          => $dealer_id,
        'phone'              => $phone,
        'platform'           => $platform ?: 'unknown',
        'source_id'          => $source_id,
        'customer_platform'  => $customer_platform,
        'status'             => 'new', // new -> contacted -> qualified -> converted -> lost
        'notes'              => '',
        'followup_at'        => '',
        'created_at'         => current_time( 'mysql' ),
        'updated_at'         => current_time( 'mysql' ),
        'updated_by'         => 'agent',
    );

    dinoco_mcp_save_lead( $new_lead );

    return new WP_REST_Response( array(
        'success' => true,
        'lead_id' => $lead_id,
        'status'  => 'new',
    ), 200 );
}

// =========================================================================
// P1-2. LEAD UPDATE — อัพเดท lead status
// =========================================================================
function dinoco_mcp_lead_update( $request ) {
    $lead_id    = sanitize_text_field( $request->get_param( 'lead_id' ) );
    $status     = sanitize_text_field( $request->get_param( 'status' ) );
    $updated_by = sanitize_text_field( $request->get_param( 'updated_by' ) ); // agent / admin / customer
    $notes      = sanitize_textarea_field( $request->get_param( 'notes' ) );
    $followup   = sanitize_text_field( $request->get_param( 'followup_at' ) ); // datetime for next follow-up

    if ( empty( $lead_id ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'lead_id required' ), 400 );
    }

    $valid_statuses = array( 'new', 'contacted', 'qualified', 'converted', 'lost', 'follow_up' );
    if ( ! empty( $status ) && ! in_array( $status, $valid_statuses, true ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Invalid status. Valid: ' . implode( ', ', $valid_statuses ) ), 400 );
    }

    $lead = dinoco_mcp_get_lead( $lead_id );
    if ( ! $lead ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Lead not found' ), 404 );
    }

    if ( ! empty( $status ) )     $lead['status']      = $status;
    if ( ! empty( $notes ) )      $lead['notes']       = ( $lead['notes'] ?? '' ) . "\n[" . current_time( 'Y-m-d H:i' ) . '] ' . $notes;
    if ( ! empty( $updated_by ) ) $lead['updated_by']  = $updated_by;
    if ( ! empty( $followup ) )   $lead['followup_at'] = $followup;

    dinoco_mcp_save_lead( $lead );

    return new WP_REST_Response( array( 'success' => true, 'lead_id' => $lead_id, 'status' => $lead['status'] ), 200 );
}

// =========================================================================
// P1-3. LEAD LIST — รายการ leads พร้อม filter
// =========================================================================
function dinoco_mcp_lead_list( $request ) {
    $status    = sanitize_text_field( $request->get_param( 'status' ) );
    $dealer_id = sanitize_text_field( $request->get_param( 'dealer_id' ) );
    $page      = max( 1, (int) $request->get_param( 'page' ) );
    $per_page  = min( max( 1, (int) ( $request->get_param( 'per_page' ) ?: 20 ) ), 100 );

    $filters = array();
    if ( ! empty( $status ) )    $filters['status']    = $status;
    if ( ! empty( $dealer_id ) ) $filters['dealer_id'] = $dealer_id;

    $offset = ( $page - 1 ) * $per_page;
    $result = dinoco_mcp_get_all_leads( $per_page, $offset, $filters );

    return new WP_REST_Response( array(
        'count'    => count( $result['leads'] ),
        'total'    => $result['total'],
        'page'     => $page,
        'per_page' => $per_page,
        'leads'    => $result['leads'],
    ), 200 );
}

// =========================================================================
// P1-4. LEAD GET — lead detail by ID
// =========================================================================
function dinoco_mcp_lead_get( $request ) {
    $id = sanitize_text_field( $request['id'] );

    // ลองหา exact match (lead_id format: LEAD-{timestamp}-{rand})
    $lead = dinoco_mcp_get_lead( $id );
    if ( $lead ) {
        return new WP_REST_Response( array( 'found' => true, 'lead' => $lead ), 200 );
    }

    // Fallback: ลองเติม prefix
    $lead = dinoco_mcp_get_lead( 'LEAD-' . $id );
    if ( $lead ) {
        return new WP_REST_Response( array( 'found' => true, 'lead' => $lead ), 200 );
    }

    return new WP_REST_Response( array( 'found' => false, 'message' => 'Lead not found' ), 404 );
}

// =========================================================================
// P1-5. LEAD FOLLOWUP SCHEDULE — pending follow-ups for cron
// =========================================================================
function dinoco_mcp_lead_followup_schedule( $request ) {
    $result = dinoco_mcp_get_all_leads( 500, 0 );
    $now    = current_time( 'mysql' );

    $pending = array();
    foreach ( $result['leads'] as $lead ) {
        // Skip closed leads
        if ( in_array( $lead['status'] ?? '', array( 'converted', 'lost' ), true ) ) continue;
        // Has a followup_at set and it's due
        if ( ! empty( $lead['followup_at'] ) && $lead['followup_at'] <= $now ) {
            $pending[] = $lead;
        }
    }

    // Sort by followup_at ASC (most overdue first)
    usort( $pending, function( $a, $b ) {
        return strcmp( $a['followup_at'], $b['followup_at'] );
    } );

    return new WP_REST_Response( array( 'count' => count( $pending ), 'leads' => $pending ), 200 );
}

