function dinoco_mcp_warranty_registered( $request ) {
    $since = sanitize_text_field( $request->get_param( 'since' ) ); // date string e.g. "2026-03-01"
    $limit = min( max( 1, (int) ( $request->get_param( 'limit' ) ?: 20 ) ), 100 );

    $args = array(
        'post_type'      => 'serial_number',
        'posts_per_page' => $limit,
        'post_status'    => 'publish',
        'orderby'        => 'date',
        'order'          => 'DESC',
    );

    if ( ! empty( $since ) ) {
        $args['date_query'] = array(
            array( 'after' => $since, 'inclusive' => true ),
        );
    }

    $posts   = get_posts( $args );
    $results = array();
    foreach ( $posts as $p ) {
        $results[] = array(
            'id'            => $p->ID,
            'serial'        => get_post_meta( $p->ID, 'serial_code', true ),
            'product'       => get_post_meta( $p->ID, 'owner_product', true ),
            'status'        => get_post_meta( $p->ID, 'w_status', true ) ?: 'unknown',
            'expiry_date'   => get_post_meta( $p->ID, 'warranty_expiry', true ),
            'registered_at' => get_the_date( 'Y-m-d', $p ),
        );
    }

    return new WP_REST_Response( array( 'count' => count( $results ), 'warranties' => $results ), 200 );
}

