    return new WP_REST_Response( array( 'count' => count( $products ), 'products' => $products ), 200 );
}

// =========================================================================
// 7. DISTRIBUTOR NOTIFY — ส่ง LINE Flex แจ้งตัวแทนเรื่อง lead ใหม่
// =========================================================================
function dinoco_mcp_distributor_notify( $request ) {
    $dist_id       = sanitize_text_field( $request->get_param( 'distributor_id' ) );
    $customer_name = sanitize_text_field( $request->get_param( 'customer_name' ) );
    $product       = sanitize_text_field( $request->get_param( 'product_interest' ) );
    $province      = sanitize_text_field( $request->get_param( 'province' ) );
    $phone         = sanitize_text_field( $request->get_param( 'phone' ) );
    $lead_id       = sanitize_text_field( $request->get_param( 'lead_id' ) );
    $msg_type      = sanitize_text_field( $request->get_param( 'type' ) ); // "new_lead" | "follow_up"
    $custom_msg    = sanitize_text_field( $request->get_param( 'message' ) );

    if ( empty( $dist_id ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'distributor_id required' ), 400 );
    }

    // ดึง LINE group ID ของตัวแทน
    $line_group = get_post_meta( $dist_id, 'line_group_id', true );
    if ( empty( $line_group ) ) {
        // Fallback: ส่งไป admin group
        $line_group = defined( 'B2B_ADMIN_GROUP_ID' ) ? B2B_ADMIN_GROUP_ID : '';
    }

    if ( empty( $line_group ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'No LINE group for distributor' ), 200 );
    }

    $token = defined( 'B2B_LINE_ACCESS_TOKEN' ) ? B2B_LINE_ACCESS_TOKEN : '';
    if ( empty( $token ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'LINE token not configured' ), 500 );
    }

    // สร้างข้อความ
    if ( $msg_type === 'follow_up' && ! empty( $custom_msg ) ) {
        // Follow-up message (text เฉย)
        $messages = array( array( 'type' => 'text', 'text' => $custom_msg ) );
    } else {
        // New lead notification — LINE Flex Message พร้อมปุ่ม action
        $flex_body = array(
            'type' => 'bubble',
            'header' => array(
                'type' => 'box', 'layout' => 'vertical',
                'contents' => array(
                    array( 'type' => 'text', 'text' => '🔔 Lead ใหม่จาก DINOCO', 'weight' => 'bold', 'size' => 'lg', 'color' => '#FF6B00' ),
                ),
            ),
            'body' => array(
                'type' => 'box', 'layout' => 'vertical', 'spacing' => 'md',
                'contents' => array(
                    array( 'type' => 'text', 'text' => "ลูกค้า: {$customer_name}", 'size' => 'md' ),
                    array( 'type' => 'text', 'text' => "สนใจ: {$product}", 'size' => 'md', 'color' => '#1A3A5C' ),
                    array( 'type' => 'text', 'text' => "จังหวัด: {$province}", 'size' => 'sm', 'color' => '#666666' ),
                    array( 'type' => 'text', 'text' => 'กรุณาติดต่อลูกค้าภายใน 4 ชม.', 'size' => 'sm', 'color' => '#FF0000', 'weight' => 'bold' ),
                ),
            ),
            'footer' => array(
                'type' => 'box', 'layout' => 'vertical', 'spacing' => 'sm',
                'contents' => array(),
            ),
        );

        // ปุ่ม "โทรลูกค้า" (ถ้ามีเบอร์)
        if ( ! empty( $phone ) ) {
            $flex_body['footer']['contents'][] = array(
                'type' => 'button', 'action' => array( 'type' => 'uri', 'label' => '📞 โทรลูกค้า', 'uri' => "tel:{$phone}" ),
                'style' => 'primary', 'color' => '#FF6B00',
            );
        }

        // ปุ่ม "ดู Lead + รับงาน" → เปิด LIFF AI
        $liff_id = defined( 'B2B_LIFF_ID' ) ? B2B_LIFF_ID : '';
        if ( ! empty( $liff_id ) && ! empty( $lead_id ) ) {
            $liff_url = "https://liff.line.me/{$liff_id}?page=lead&id={$lead_id}";
            $flex_body['footer']['contents'][] = array(
                'type' => 'button',
                'action' => array( 'type' => 'uri', 'label' => '📋 ดู Lead + รับงาน', 'uri' => $liff_url ),
                'style' => 'primary', 'color' => '#1A3A5C',
            );
        }

        // ปุ่ม "รับแล้ว" (postback fallback — ถ้าไม่มี LIFF)
        $flex_body['footer']['contents'][] = array(
            'type' => 'button', 'action' => array( 'type' => 'postback', 'label' => '✅ รับแล้ว', 'data' => "lead_accepted:{$lead_id}" ),
            'style' => 'secondary',
        );

        $messages = array( array( 'type' => 'flex', 'altText' => "Lead ใหม่: {$customer_name} สนใจ {$product}", 'contents' => $flex_body ) );
    }

    // ส่ง LINE Push
    $response = wp_remote_post( 'https://api.line.me/v2/bot/message/push', array(
        'headers' => array(
            'Content-Type'  => 'application/json',
            'Authorization' => "Bearer {$token}",
        ),
        'body'    => wp_json_encode( array( 'to' => $line_group, 'messages' => $messages ) ),
        'timeout' => 10,
    ) );

    $code = wp_remote_retrieve_response_code( $response );
    return new WP_REST_Response( array( 'success' => $code === 200, 'http_status' => $code ), 200 );
}

