function dinoco_mcp_brand_voice_submit( $request ) {
    $content    = sanitize_textarea_field( $request->get_param( 'content' ) );
    $sentiment  = sanitize_text_field( $request->get_param( 'sentiment' ) ); // positive/neutral/negative
    $brands     = $request->get_param( 'brands' ); // array
    $categories = $request->get_param( 'categories' ); // array
    $platform   = sanitize_text_field( $request->get_param( 'platform' ) );
    $source_url = esc_url_raw( $request->get_param( 'source_url' ) );
    $intensity  = (int) $request->get_param( 'intensity' );
    $context    = sanitize_textarea_field( $request->get_param( 'post_context' ) );

    if ( empty( $content ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'content required' ), 400 );
    }

    // ใช้ bv_create_entry ถ้ามี (จาก Brand Voice Pool snippet)
    if ( function_exists( 'bv_create_entry' ) ) {
        $entry_id = bv_create_entry( array(
            'bv_content'    => $content,
            'bv_summary'    => mb_substr( $content, 0, 100 ),
            'bv_sentiment'  => $sentiment ?: 'neutral',
            'bv_intensity'  => $intensity ?: 3,
            'bv_brands'     => is_array( $brands ) ? $brands : array( 'DINOCO' ),
            'bv_categories' => is_array( $categories ) ? $categories : array(),
            'bv_platform'   => $platform ?: 'facebook_page',
            'bv_source_url' => $source_url,
            'bv_entry_method' => 'ai_import',
            'bv_admin_notes'  => $context ? "บริบทโพสต์: {$context}" : '',
        ) );

        return new WP_REST_Response( array( 'success' => (bool) $entry_id, 'id' => $entry_id ), 200 );
    }

    return new WP_REST_Response( array( 'success' => false, 'message' => 'Brand Voice Pool not active' ), 200 );
}
