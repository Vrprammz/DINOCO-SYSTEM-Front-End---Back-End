    ) );
} );

// =========================================================================
// 1. PRODUCT LOOKUP — ค้นหาสินค้าจาก catalog
// =========================================================================
function dinoco_mcp_product_lookup( $request ) {
    $query    = sanitize_text_field( $request->get_param( 'query' ) );
    $category = sanitize_text_field( $request->get_param( 'category' ) );

    if ( empty( $query ) && empty( $category ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'กรุณาระบุ query หรือ category' ), 400 );
    }

    $catalog = function_exists( 'b2b_get_catalog' ) ? b2b_get_catalog() : get_option( 'dinoco_product_catalog', array() );
    if ( empty( $catalog ) || ! is_array( $catalog ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'ไม่มีข้อมูลสินค้าในระบบ' ), 200 );
    }

    $search = mb_strtolower( $query . ' ' . $category, 'UTF-8' );

    // Model aliases
    $model_aliases = array(
        'nx500'    => array( 'nx500', 'nx 500', 'เอ็นเอ็ก' ),
        'cb500x'   => array( 'cb500x', 'cb500', 'cb 500', 'ซีบี' ),
        'adv350'   => array( 'adv350', 'adv 350', 'adv', 'เอดีวี' ),
        'forza350' => array( 'forza350', 'forza 350', 'forza', 'ฟอร์ซ่า' ),
        'forza750' => array( 'forza750', 'forza 750' ),
        'xl750'    => array( 'xl750', 'transalp', 'ทรานซัลป์' ),
        'xadv750'  => array( 'xadv', 'x-adv' ),
        'crf300l'  => array( 'crf300l', 'crf 300', 'crf300' ),
        'rebel500' => array( 'rebel', 'rebel500', 'rebel 500' ),
        'cl500'    => array( 'cl500', 'cl 500' ),
        'cb650r'   => array( 'cb650', 'cb 650' ),
        'nmax'     => array( 'nmax', 'เอ็นแม็ก' ),
        'xmax'     => array( 'xmax', 'เอ็กแม็ก' ),
        'pcx'      => array( 'pcx', 'พีซีเอ็ก' ),
    );

    $model_key = '';
    foreach ( $model_aliases as $mk => $aliases ) {
        foreach ( $aliases as $a ) {
            if ( mb_strpos( $search, mb_strtolower( $a, 'UTF-8' ) ) !== false ) { $model_key = $mk; break 2; }
        }
    }

    // Category mapping
    $cat_map = array(
        'กันล้ม'     => array( 'กันล้ม', 'crash', 'crashbar', 'แคชบาร์', 'แครชบาร์' ),
        'กล่องข้าง'  => array( 'กล่องข้าง', 'side box', 'sidebox', 'side case', 'ไซด์เคส' ),
        'กล่องหลัง'  => array( 'กล่องหลัง', 'กล่องท้าย', 'top box', 'topbox', 'top case', 'ท็อปเคส' ),
        'แร็ค'       => array( 'แร็ค', 'rack', 'ตะแกรง', 'แร็ก' ),
        'กระเป๋า'    => array( 'กระเป๋า', 'bag', 'dry bag' ),
        'ถาดรอง'     => array( 'ถาดรอง', 'เบสเพลท', 'base plate' ),
        'การ์ดแฮนด์'  => array( 'การ์ดแฮนด์', 'hand guard', 'handguard' ),
    );

    $cat_key = '';
    foreach ( $cat_map as $ck => $kws ) {
        foreach ( $kws as $kw ) {
            if ( mb_strpos( $search, mb_strtolower( $kw, 'UTF-8' ) ) !== false ) { $cat_key = $ck; break 2; }
        }
    }

    // Score items
    $matches = array();
    foreach ( $catalog as $sku => $item ) {
        $name_lower = mb_strtolower( isset( $item['name'] ) ? $item['name'] : '', 'UTF-8' );
        $score = 0;

        if ( $model_key ) {
            foreach ( $model_aliases[ $model_key ] as $mk ) {
                if ( mb_strpos( $name_lower, $mk ) !== false ) { $score += 100; break; }
            }
        }
        if ( $cat_key ) {
            foreach ( $cat_map[ $cat_key ] as $ck ) {
                if ( mb_strpos( $name_lower, mb_strtolower( $ck, 'UTF-8' ) ) !== false ) { $score += 50; break; }
            }
        }

        // General keyword match
        $terms = array_filter( preg_split( '/[\s,]+/u', $search ), function( $w ) { return mb_strlen( $w, 'UTF-8' ) >= 2; } );
        foreach ( $terms as $t ) {
            if ( mb_strpos( $name_lower, $t ) !== false ) $score += 10;
        }

        if ( $score >= 50 ) {
            $matches[] = array(
                'name'           => isset( $item['name'] ) ? $item['name'] : $sku,
                'price'          => isset( $item['price'] ) ? $item['price'] : 0,
                'sku'            => $sku,
                'img_url'        => isset( $item['img'] ) ? $item['img'] : '',
                'in_stock'       => isset( $item['in_stock'] ) ? $item['in_stock'] : true,
                'warranty_years' => isset( $item['years'] ) ? (int) $item['years'] : 0,
                'score'          => $score,
            );
        }
    }

    if ( empty( $matches ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => "ไม่พบสินค้า '{$query} {$category}'" ), 200 );
    }

    usort( $matches, function( $a, $b ) { return $b['score'] <=> $a['score']; } );
    $top = array_slice( $matches, 0, 5 );
    foreach ( $top as &$m ) { unset( $m['score'] ); }

    return new WP_REST_Response( array( 'found' => true, 'count' => count( $top ), 'products' => $top ), 200 );
}

