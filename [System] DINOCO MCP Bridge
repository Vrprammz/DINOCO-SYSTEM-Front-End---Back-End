function dinoco_mcp_on_b2b_order_created( $post_id, $post, $update ) {
    // เฉพาะ order ใหม่ (ไม่ใช่ update)
    if ( $update && get_post_meta( $post_id, '_openclaw_notified', true ) ) return;

    $distributor_id = get_post_meta( $post_id, 'distributor_id', true );
    if ( empty( $distributor_id ) ) return;

    // ส่ง webhook ไป OpenClaw (fire-and-forget)
    $openclaw_url = get_option( 'dinoco_openclaw_agent_url', '' );
    $openclaw_key = get_option( 'dinoco_openclaw_api_key', '' );
    if ( empty( $openclaw_url ) ) return;

    $order_items = get_post_meta( $post_id, 'order_items', true );
    $total       = get_post_meta( $post_id, 'total_amount', true );

    wp_remote_post( $openclaw_url . '/api/leads/b2b-order-linked', array(
        'headers' => array(
            'Content-Type'  => 'application/json',
            'Authorization' => 'Bearer ' . $openclaw_key,
        ),
        'body'    => wp_json_encode( array(
            'distributor_id' => $distributor_id,
            'order_id'       => $post_id,
            'order_items'    => $order_items,
            'total_amount'   => $total,
            'created_at'     => get_the_date( 'c', $post ),
        ) ),
        'timeout'   => 5,
        'blocking'  => false, // fire-and-forget
    ) );

    update_post_meta( $post_id, '_openclaw_notified', '1' );
}

