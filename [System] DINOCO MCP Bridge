}

// =========================================================================
// P3-4. DASHBOARD INJECT METRICS — FB/IG metrics inject เข้า DINOCO Dashboard
// =========================================================================
function dinoco_mcp_dashboard_inject_metrics( $request ) {
    $platform   = sanitize_text_field( $request->get_param( 'platform' ) ); // facebook / instagram
    $date       = sanitize_text_field( $request->get_param( 'date' ) );      // YYYY-MM-DD
    $metrics    = $request->get_param( 'metrics' ); // array of metric objects

    if ( empty( $platform ) || empty( $metrics ) || ! is_array( $metrics ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'platform and metrics[] required' ), 400 );
    }

    $date = $date ?: current_time( 'Y-m-d' );

    // Sanitize metrics
    $clean_metrics = array();
    foreach ( $metrics as $m ) {
        $clean_metrics[] = array(
            'name'  => sanitize_text_field( $m['name'] ?? '' ),
            'value' => is_numeric( $m['value'] ?? '' ) ? floatval( $m['value'] ) : sanitize_text_field( $m['value'] ?? '' ),
        );
    }

    // เก็บใน wp_options keyed by date+platform
    $key = 'dinoco_mcp_metrics_' . $platform . '_' . str_replace( '-', '', $date );
    update_option( $key, array(
        'platform'   => $platform,
        'date'       => $date,
        'metrics'    => $clean_metrics,
        'injected_at' => current_time( 'mysql' ),
    ), false );

    return new WP_REST_Response( array(
        'success'       => true,
        'platform'      => $platform,
        'date'          => $date,
        'metrics_count' => count( $clean_metrics ),
    ), 200 );
}

// =========================================================================
// P3-5. LEAD ATTRIBUTION — lead conversion measurement
// =========================================================================
function dinoco_mcp_lead_attribution( $request ) {
    $lead_id     = sanitize_text_field( $request->get_param( 'lead_id' ) );
    $event       = sanitize_text_field( $request->get_param( 'event' ) );   // "converted" / "purchased" / "registered"
    $order_id    = sanitize_text_field( $request->get_param( 'order_id' ) );
    $revenue     = floatval( $request->get_param( 'revenue' ) );
    $source      = sanitize_text_field( $request->get_param( 'source' ) );  // "facebook" / "instagram" / "line"

    if ( empty( $lead_id ) || empty( $event ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'lead_id and event required' ), 400 );
    }

    // บันทึก attribution event
    $attributions = get_option( 'dinoco_mcp_attributions', array() );
    $attributions[] = array(
        'lead_id'    => $lead_id,
        'event'      => $event,
        'order_id'   => $order_id,
        'revenue'    => $revenue,
        'source'     => $source,
        'created_at' => current_time( 'mysql' ),
    );

    // เก็บล่าสุด 500 entries
    $attributions = array_slice( $attributions, -500 );
    update_option( 'dinoco_mcp_attributions', $attributions, false );

    // อัพเดท lead status เป็น converted ถ้ายังไม่ converted
    $lead = dinoco_mcp_get_lead( $lead_id );
    if ( $lead && ( $lead['status'] ?? '' ) !== 'converted' ) {
        $lead['status']     = 'converted';
        $lead['notes']      = ( $lead['notes'] ?? '' ) . "\n[" . current_time( 'Y-m-d H:i' ) . "] Auto-converted via attribution ({$event})";
        dinoco_mcp_save_lead( $lead );
    }

    return new WP_REST_Response( array(
        'success'  => true,
        'lead_id'  => $lead_id,
        'event'    => $event,
        'recorded' => true,
    ), 200 );
}
