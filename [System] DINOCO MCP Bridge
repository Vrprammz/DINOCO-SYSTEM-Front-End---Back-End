function dinoco_mcp_kb_suggest( $request ) {
    $question  = sanitize_text_field( $request->get_param( 'question' ) );
    $source    = sanitize_text_field( $request->get_param( 'source' ) ); // "fb_chat" | "ig_chat"
    $frequency = (int) $request->get_param( 'frequency' );

    if ( empty( $question ) ) {
        return new WP_REST_Response( array( 'success' => false ), 400 );
    }

    // เก็บใน wp_options (simple queue ไม่ต้อง CPT)
    $suggestions = get_option( 'dinoco_kb_suggestions', array() );

    // เช็คว่ามี suggestion เดิมไหม → เพิ่ม frequency
    $found = false;
    foreach ( $suggestions as &$s ) {
        if ( mb_strtolower( $s['question'] ) === mb_strtolower( $question ) ) {
            $s['frequency'] = ( $s['frequency'] ?? 1 ) + 1;
            $s['last_asked'] = current_time( 'mysql' );
            $found = true;
            break;
        }
    }

    if ( ! $found ) {
        $suggestions[] = array(
            'question'   => $question,
            'source'     => $source ?: 'unknown',
            'frequency'  => max( $frequency, 1 ),
            'first_asked' => current_time( 'mysql' ),
            'last_asked'  => current_time( 'mysql' ),
        );
    }

    // เก็บสูงสุด 100 suggestions
    usort( $suggestions, function( $a, $b ) { return ( $b['frequency'] ?? 0 ) - ( $a['frequency'] ?? 0 ); } );
    $suggestions = array_slice( $suggestions, 0, 100 );

    update_option( 'dinoco_kb_suggestions', $suggestions );

    return new WP_REST_Response( array( 'success' => true, 'total_suggestions' => count( $suggestions ) ), 200 );
}

