// === Claim Manual Create ===
function dinoco_mcp_claim_manual_create( $request ) {
    $serial      = sanitize_text_field( $request->get_param( 'serial' ) );
    $product     = sanitize_text_field( $request->get_param( 'product' ) );
    $symptoms    = sanitize_text_field( $request->get_param( 'symptoms' ) );
    $customer    = sanitize_text_field( $request->get_param( 'customer_name' ) );
    $phone       = sanitize_text_field( $request->get_param( 'phone' ) );
    $address     = sanitize_textarea_field( $request->get_param( 'customer_address' ) );
    $photos      = $request->get_param( 'photos' ); // array of URLs
    $platform    = sanitize_text_field( $request->get_param( 'platform' ) );
    $source_id   = sanitize_text_field( $request->get_param( 'source_id' ) );
    $initiated   = sanitize_text_field( $request->get_param( 'initiated_by' ) ); // "customer" | "dealer"
    $dealer_id     = sanitize_text_field( $request->get_param( 'dealer_id' ) );
    $ai_analysis   = sanitize_textarea_field( $request->get_param( 'ai_analysis' ) );
    $purchase_from = sanitize_text_field( $request->get_param( 'purchase_from' ) );
    $purchase_date = sanitize_text_field( $request->get_param( 'purchase_date' ) );

    if ( empty( $symptoms ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'symptoms required' ), 400 );
    }

    // สร้าง claim ticket
    $claim_id = wp_insert_post( array(
        'post_type'   => 'claim_ticket',
        'post_title'  => 'MC-' . time() . ' ' . $customer,
        'post_status' => 'publish',
    ) );

    if ( is_wp_error( $claim_id ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Failed to create claim' ), 500 );
    }

    // บันทึก meta fields
    $meta = array(
        'ticket_sn_text'     => $serial,
        'claim_product'      => $product,
        'claim_symptoms'     => $symptoms,
        'claim_customer'     => $customer,
        'claim_phone'        => $phone,
        'claim_address'      => $address,
        'claim_photos'       => is_array( $photos ) ? wp_json_encode( $photos ) : '',
        'claim_platform'     => $platform ?: 'facebook',
        'claim_source_id'    => $source_id,
        'claim_initiated_by' => $initiated ?: 'customer',
        'claim_dealer_id'    => $dealer_id,
        'claim_ai_analysis'  => $ai_analysis,
        'claim_purchase_from' => $purchase_from,
        'claim_purchase_date' => $purchase_date,
        'ticket_status'      => 'info_collected',
        'claim_method'       => 'manual_chat',
    );

    foreach ( $meta as $key => $val ) {
        update_post_meta( $claim_id, $key, $val );
    }

    $ticket_number = 'MC-' . str_pad( $claim_id, 5, '0', STR_PAD_LEFT );
    update_post_meta( $claim_id, 'ticket_number', $ticket_number );

    return new WP_REST_Response( array(
        'success' => true,
        'claim_id' => $claim_id,
        'ticket_number' => $ticket_number,
        'status' => 'info_collected',
    ), 200 );
}

// === Claim Manual Update Status ===
function dinoco_mcp_claim_manual_update( $request ) {
    $claim_id = (int) $request->get_param( 'claim_id' );
    $status   = sanitize_text_field( $request->get_param( 'status' ) );
    $notes    = sanitize_textarea_field( $request->get_param( 'notes' ) );
    $tracking = sanitize_text_field( $request->get_param( 'tracking_number' ) );
    $case     = sanitize_text_field( $request->get_param( 'case_type' ) ); // "case_a" | "case_b" | "reject"

    if ( empty( $claim_id ) || empty( $status ) ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'claim_id and status required' ), 400 );
    }

    $post = get_post( $claim_id );
    if ( ! $post || $post->post_type !== 'claim_ticket' ) {
        return new WP_REST_Response( array( 'success' => false, 'message' => 'Claim not found' ), 404 );
    }

    // M18: route through canonical helper for allowlist + hook + history + observability.
    // Chatbot-driven status changes come from OpenClaw agent, which may use state strings
    // that haven't been registered in the filter yet. In that case the helper records the
    // attempt in dinoco_claim_observations (M20 data) then returns invalid_state — we
    // defensively fall back to raw meta write so the claim_ticket stays consistent even
    // if the vocabulary drifts, but the gap is visible in observations for canonicalization.
    if ( function_exists( 'dinoco_set_claim_status' ) ) {
        $_r = dinoco_set_claim_status( $claim_id, $status, array(
            'actor'  => 'chatbot',
            'note'   => $notes,
            'source' => 'mcp_bridge',
        ) );
        if ( is_wp_error( $_r ) && $_r->get_error_code() === 'invalid_state' ) {
            // Chatbot sent a label we don't know yet — write raw to stay consistent.
            // The observation is already recorded (helper does it BEFORE the allowlist
            // check) so M20 analysis will see the gap.
            update_post_meta( $claim_id, 'ticket_status', $status );
        }
        // terminal_state: idempotent, helper already no-op'd; nothing more to do.
    } else {
        update_post_meta( $claim_id, 'ticket_status', $status );
    }
    if ( ! empty( $notes ) )    update_post_meta( $claim_id, 'claim_admin_notes', $notes );
    if ( ! empty( $tracking ) ) update_post_meta( $claim_id, 'claim_tracking', $tracking );
    if ( ! empty( $case ) )     update_post_meta( $claim_id, 'claim_case_type', $case );

    // Webhook แจ้ง OpenClaw ว่าสถานะเปลี่ยน
    $openclaw_url = get_option( 'dinoco_openclaw_agent_url', '' );
    $openclaw_key = get_option( 'dinoco_openclaw_api_key', '' );
    if ( ! empty( $openclaw_url ) ) {
        wp_remote_post( $openclaw_url . '/api/claims/status-changed', array(
            'headers' => array(
                'Content-Type'  => 'application/json',
                'Authorization' => 'Bearer ' . $openclaw_key,
            ),
            'body'    => wp_json_encode( array(
                'claim_id'       => $claim_id,
                'ticket_number'  => get_post_meta( $claim_id, 'ticket_number', true ),
                'new_status'     => $status,
                'case_type'      => $case,
                'source_id'      => get_post_meta( $claim_id, 'claim_source_id', true ),
                'platform'       => get_post_meta( $claim_id, 'claim_platform', true ),
            ) ),
            'timeout'   => 5,
            'blocking'  => false,
        ) );
    }

    return new WP_REST_Response( array( 'success' => true, 'claim_id' => $claim_id, 'status' => $status ), 200 );
}

// === Claim Manual Status Check ===
function dinoco_mcp_claim_manual_status( $request ) {
    $claim_id = (int) $request->get_param( 'claim_id' );
    $ticket   = sanitize_text_field( $request->get_param( 'ticket_number' ) );

    if ( empty( $claim_id ) && empty( $ticket ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'claim_id or ticket_number required' ), 400 );
    }

    if ( ! empty( $ticket ) ) {
        $posts = get_posts( array(
            'post_type' => 'claim_ticket', 'posts_per_page' => 1,
            'meta_query' => array( array( 'key' => 'ticket_number', 'value' => $ticket ) ),
        ) );
        $claim_id = ! empty( $posts ) ? $posts[0]->ID : 0;
    }

    if ( empty( $claim_id ) ) {
        return new WP_REST_Response( array( 'found' => false, 'message' => 'Claim not found' ), 200 );
    }

    return new WP_REST_Response( array(
        'found'          => true,
        'claim_id'       => $claim_id,
        'ticket_number'  => get_post_meta( $claim_id, 'ticket_number', true ),
        'status'         => get_post_meta( $claim_id, 'ticket_status', true ),
        'case_type'      => get_post_meta( $claim_id, 'claim_case_type', true ),
        'symptoms'       => get_post_meta( $claim_id, 'claim_symptoms', true ),
        'admin_notes'    => get_post_meta( $claim_id, 'claim_admin_notes', true ),
        'tracking'       => get_post_meta( $claim_id, 'claim_tracking', true ),
    ), 200 );
}

