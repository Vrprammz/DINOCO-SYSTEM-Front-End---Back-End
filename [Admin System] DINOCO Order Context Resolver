if ( function_exists( 'dinoco_register_admin_module' ) ) {
    add_action( 'init', function() {
        dinoco_register_admin_module( array(
            'id'      => 'order_context_resolver',
            'label'   => 'Order Context (VAT)',
            'section' => 'utilities',
            'order'   => 90,
            'desc'    => 'Order context resolver + VAT eligibility lookup',
        ) );
    }, 20 );
}
