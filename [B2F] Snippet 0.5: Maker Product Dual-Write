// V.1.2: CLASSIFICATION INFERENCE HELPER (local to Snippet 0.5)
// ═══════════════════════════════════════════════════════════════════
//
// Infer V11 classification defaults for fresh INSERT (ON DUPLICATE excludes these).
// Prefers Snippet 1 V.7.0 helper `b2f_infer_production_mode_from_relations()` ถ้ามี,
// ไม่มีก็ inline fallback logic (Snippet 1 V.7.0 จะ consolidate ภายหลัง).
//
// Classification logic (mirror Phase 4 migration pseudocode):
//   has_children AND missing_leaves > 0 → cross_factory_assembly + as_parts
//   has_children AND has_parent         → sub_unit + auto
//   has_children AND NOT has_parent     → set_assembled + auto
//   NO children (leaf)                  → single + auto
//
// CPT save = admin-edited → confirmation_status = 'confirmed'
//   (CPT registered manually by admin, ไม่ใช่ auto-sync orphan)

if ( ! function_exists( 'b2f_dualwrite_infer_classification' ) ) {
    function b2f_dualwrite_infer_classification( $sku, $maker_id ) {
        // Prefer Snippet 1 V.7.0+ helper when available (single source of truth)
        if ( function_exists( 'b2f_infer_production_mode_from_relations' ) ) {
            $inferred = b2f_infer_production_mode_from_relations( $sku, $maker_id );
            if ( is_array( $inferred ) && isset( $inferred['production_mode'] ) ) {
                // CPT save = admin-confirmed (not auto-synced orphan)
                $inferred['confirmation_status'] = 'confirmed';
                return $inferred;
            }
        }

        // Inline fallback (Snippet 1 helper not yet synced)
        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) ) $relations = array();

        // Normalize keys to uppercase for case-insensitive lookup
        $sku_upper = strtoupper( (string) $sku );
        $rel_upper = array();
        foreach ( $relations as $parent_sku => $children ) {
            $rel_upper[ strtoupper( $parent_sku ) ] = is_array( $children ) ? array_map( 'strtoupper', $children ) : array();
        }

        $children     = isset( $rel_upper[ $sku_upper ] ) ? $rel_upper[ $sku_upper ] : array();
        $has_children = ! empty( $children );

        // has_parent: walk relations to find SKU in any parent's children array
        $has_parent = false;
        foreach ( $rel_upper as $parent_sku => $parent_children ) {
            if ( in_array( $sku_upper, $parent_children, true ) ) {
                $has_parent = true;
                break;
            }
        }

        // missing_leaves count (maker-scoped): children ที่ maker นี้ไม่ได้ register ใน junction
        $missing_count = 0;
        if ( $has_children ) {
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            // Flatten children (walk 1 level — DD-2 leaf guard handles deeper recursion elsewhere)
            $placeholders = implode( ',', array_fill( 0, count( $children ), '%s' ) );
            $args = array_merge( array( $maker_id ), $children );
            $registered = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$tbl}
                 WHERE maker_id = %d
                   AND BINARY UPPER(product_sku) IN ({$placeholders})
                   AND deleted_at IS NULL",
                $args
            ) );
            $missing_count = max( 0, count( $children ) - $registered );
        }

        // Classification matrix
        if ( $has_children && $missing_count > 0 ) {
            $production_mode    = 'cross_factory_assembly';
            $admin_display_mode = 'as_parts'; // auto-hide cross-factory SET default
        } elseif ( $has_children && $has_parent ) {
            $production_mode    = 'sub_unit';
            $admin_display_mode = 'auto';
        } elseif ( $has_children ) {
            $production_mode    = 'set_assembled';
            $admin_display_mode = 'auto';
        } else {
            $production_mode    = 'single';
            $admin_display_mode = 'auto';
        }

        return array(
            'production_mode'      => $production_mode,
            'confirmation_status'  => 'confirmed', // CPT = admin-confirmed by default
            'admin_display_mode'   => $admin_display_mode,
            'missing_leaves_count' => $missing_count,
        );
    }
}

/**
 * Soft-delete junction row เมื่อ CPT ถูกลบ
 */
if ( ! function_exists( 'b2f_dual_soft_delete_junction' ) ) {
    function b2f_dual_soft_delete_junction( $mp_id ) {
        global $wpdb;
        $mp_id = intval( $mp_id );
        if ( ! $mp_id ) return false;
        if ( ! get_option( 'b2f_schema_v10_activated' ) ) return false;

        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $uid = get_current_user_id();
        $now = current_time( 'mysql' );

        $ok = $wpdb->query( $wpdb->prepare(
            "UPDATE {$tbl}
             SET deleted_at = %s, status = 'discontinued', updated_by = %d, updated_at = %s
             WHERE legacy_cpt_id = %d AND deleted_at IS NULL",
            $now, $uid, $now, $mp_id
        ) );
        return ( $ok !== false );
    }
}

