/**
 * Read b2f_maker_product CPT (ACF) → UPSERT into wp_dinoco_product_makers
 *
 * @param int $mp_id post_id ของ b2f_maker_product
 * @return bool|WP_Error true on success, WP_Error on failure (logged, not thrown)
 */
if ( ! function_exists( 'b2f_dual_write_to_junction' ) ) {
    function b2f_dual_write_to_junction( $mp_id ) {
        global $wpdb;
        $mp_id = intval( $mp_id );
        if ( ! $mp_id ) return new WP_Error( 'invalid_id', 'Empty mp_id' );

        // V.1.2 CRIT-4: Migration lock guard
        // ถ้า Phase 4 migration กำลังทำงาน → skip dual-write ทันที + enqueue via cron
        // ป้องกัน race condition ที่ migration UPDATE overwrite fresh INSERT
        if ( get_option( 'b2f_phase4_migration_in_progress' ) ) {
            wp_schedule_single_event( time() + 10, 'b2f_replay_queued_dual_write', array( $mp_id ) );
            if ( function_exists( 'b2f_log' ) ) {
                b2f_log( '[DualWrite V.1.2] migration lock active — deferred mp_id=' . $mp_id );
            }
            return new WP_Error( 'migration_in_progress', 'Phase 4 migration active — deferred to cron' );
        }

        // Schema guard
        if ( ! get_option( 'b2f_schema_v10_activated' ) ) {
            return new WP_Error( 'schema_not_activated', 'Schema V10 not activated' );
        }

        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $obs = $wpdb->prefix . 'dinoco_maker_product_observations';

        // V.1.3 FIX: Read directly from postmeta instead of ACF `get_field()`.
        //
        // BUG: ACF maintains a per-request local cache via `acf_get_value`. When the
        // save_post hook fires from `wp_update_post()` (called BEFORE `update_field()`
        // in the save-maker-product endpoint), this function runs and caches STALE
        // values (e.g. unit_cost=666). Later, when the endpoint calls `update_field()`
        // with the new value (e.g. 3900), ACF's cache invalidation is unreliable for
        // the second dual-write call → get_field returns cached 666 again → junction
        // gets stuck at 666 even though postmeta has 3900.
        //
        // `get_post_meta()` reads WP's object cache which `update_post_meta()` (called
        // inside `update_field()`) DOES invalidate reliably. So we get fresh values.
        $sku       = (string) get_post_meta( $mp_id, 'mp_product_sku', true );
        $maker_id  = intval( get_post_meta( $mp_id, 'mp_maker_id', true ) );
        $unit_cost = floatval( get_post_meta( $mp_id, 'mp_unit_cost', true ) );
        $moq       = intval( get_post_meta( $mp_id, 'mp_moq', true ) );
        $lead_time = intval( get_post_meta( $mp_id, 'mp_lead_time_days', true ) );
        $ship_land = floatval( get_post_meta( $mp_id, 'mp_shipping_land', true ) );
        $ship_sea  = floatval( get_post_meta( $mp_id, 'mp_shipping_sea', true ) );
        $notes     = (string) get_post_meta( $mp_id, 'mp_notes', true );
        $status    = (string) ( get_post_meta( $mp_id, 'mp_status', true ) ?: 'active' );

        $sku = strtoupper( trim( (string) $sku ) );
        if ( ! $sku || ! $maker_id ) {
            return new WP_Error( 'missing_key', 'Missing sku or maker_id on mp_id=' . $mp_id );
        }

        if ( ! in_array( $status, array( 'active', 'discontinued', 'pending' ), true ) ) {
            $status = 'active';
        }
        if ( $moq < 1 ) $moq = 1;
        if ( $lead_time < 0 ) $lead_time = 7;

        // V.1.2: Infer V11 classification defaults (only used for fresh INSERT)
        // ON DUPLICATE KEY UPDATE จะ EXCLUDE fields เหล่านี้ (preserve admin choice)
        $classification = b2f_dualwrite_infer_classification( $sku, $maker_id );
        $production_mode      = $classification['production_mode'];      // default 'single'
        $confirmation_status  = $classification['confirmation_status'];  // default 'confirmed' (CPT = admin-confirmed)
        $admin_display_mode   = $classification['admin_display_mode'];   // default 'auto'
        $missing_leaves_count = $classification['missing_leaves_count']; // default 0

        $uid = get_current_user_id();
        $now = current_time( 'mysql' );

        // V.1.6 DB-C1 FIX: V11 schema CHECK constraint chk_confirmed_consistency requires
        // confirmed_by + confirmed_at be non-NULL whenever confirmation_status='confirmed'.
        // MySQL 8.0.16+ silently rejects the INSERT otherwise → junction stays stale.
        // Classification.confirmation_status defaults to 'confirmed' for CPT-initiated
        // saves (admin edited → implicit confirmation), so we must populate the audit
        // columns. For 'auto_synced' rows (unusual via dual-write path) leave NULL.
        $confirmed_by_val = null;
        $confirmed_at_val = null;
        if ( $confirmation_status === 'confirmed' ) {
            $confirmed_by_val = $uid ?: 0;
            $confirmed_at_val = current_time( 'mysql', true ); // GMT for audit precision
        }

        // UPSERT (ON DUPLICATE preserves id + created_at)
        // CRITICAL V.1.2: ON DUPLICATE KEY UPDATE **EXCLUDES** 4 V11 classification columns
        //   → admin-chosen production_mode / confirmation_status / admin_display_mode / missing_leaves_count
        //     จะถูก preserve (ไม่ overwrite จาก CPT dual-write subsequent saves)
        //   → V11 columns จะ update ผ่าน 4 new endpoints ใน /dinoco-b2f-audit/v1/ (V.3.3) เท่านั้น
        //   → missing_leaves_count ถูก recompute โดย Phase 4 migration + Snippet 15 V.7.0 hook
        //
        // V.1.6: confirmed_by / confirmed_at ON DUPLICATE uses COALESCE(existing, VALUES()) so
        // subsequent dual-writes do NOT overwrite an admin's real confirmation audit trail,
        // but DO backfill NULLs that pre-date this fix (migrating old rows into CHECK compliance).
        // %s bound with literal 'NULL' string won't work, so we build the SQL with format spec.
        $confirmed_by_sql = is_null( $confirmed_by_val ) ? 'NULL' : $wpdb->prepare( '%d', $confirmed_by_val );
        $confirmed_at_sql = is_null( $confirmed_at_val ) ? 'NULL' : $wpdb->prepare( '%s', $confirmed_at_val );

        $sql = $wpdb->prepare(
            "INSERT INTO {$tbl}
                (product_sku, maker_id, unit_cost, moq, lead_time_days,
                 shipping_land, shipping_sea, status, notes,
                 production_mode, confirmation_status, admin_display_mode, missing_leaves_count,
                 confirmed_by, confirmed_at,
                 legacy_cpt_id, created_by, updated_by, created_at, updated_at, deleted_at)
             VALUES (%s, %d, %f, %d, %d, %f, %f, %s, %s, %s, %s, %s, %d, {$confirmed_by_sql}, {$confirmed_at_sql}, %d, %d, %d, %s, %s, NULL)
             ON DUPLICATE KEY UPDATE
                unit_cost      = VALUES(unit_cost),
                moq            = VALUES(moq),
                lead_time_days = VALUES(lead_time_days),
                shipping_land  = VALUES(shipping_land),
                shipping_sea   = VALUES(shipping_sea),
                status         = VALUES(status),
                notes          = VALUES(notes),
                legacy_cpt_id  = VALUES(legacy_cpt_id),
                confirmed_by   = COALESCE(confirmed_by, VALUES(confirmed_by)),
                confirmed_at   = COALESCE(confirmed_at, VALUES(confirmed_at)),
                updated_by     = VALUES(updated_by),
                updated_at     = VALUES(updated_at),
                deleted_at     = NULL",
            $sku, $maker_id, $unit_cost, $moq, $lead_time,
            $ship_land, $ship_sea, $status, $notes,
            $production_mode, $confirmation_status, $admin_display_mode, $missing_leaves_count,
            $mp_id, $uid, $uid, $now, $now
        );
        $ok = $wpdb->query( $sql );
        if ( $ok === false ) {
            return new WP_Error( 'sql_error', 'UPSERT failed: ' . $wpdb->last_error );
        }

        // Log observation (source=cpt mirror → junction)
        $fields_snapshot = wp_json_encode( array(
            'unit_cost'      => $unit_cost,
            'moq'            => $moq,
            'lead_time_days' => $lead_time,
            'shipping_land'  => $ship_land,
            'shipping_sea'   => $ship_sea,
            'status'         => $status,
        ) );
        $wpdb->insert( $obs, array(
            'observed_at'    => $now,
            'source'         => 'cpt',
            'sku'            => $sku,
            'maker_id'       => $maker_id,
            'field_name'     => 'dual_write',
            'cpt_value'      => $fields_snapshot,
            'junction_value' => $fields_snapshot,
            'diff_detected'  => 0,
        ) );

        // V.1.2: Fire central cache invalidation hook (HIGH-4 — Snippet 1 V.7.0 listener)
        if ( function_exists( 'do_action' ) ) {
            do_action( 'b2f_junction_updated', $maker_id );
        }

        // V.1.5 MEDIUM-1: Kill-switch gate. Default ON (opt-out) — admin can disable via
        // wp_option `b2f_flag_coverage_autosync` = '0' (or via Audit dashboard flag panel)
        // if reactive propagation causes issues, without needing a code redeploy.
        //
        // V.1.4: Reactive coverage auto-sync. After writing this SKU's junction row,
        // walk UP the hierarchy — if this save now makes an ancestor's coverage complete,
        // auto-register the ancestor. Migration lock + blacklist checks handled inside
        // helper. Non-fatal: primary UPSERT already succeeded.
        $coverage_enabled = function_exists( 'b2f_is_flag_enabled' )
            ? b2f_is_flag_enabled( 'b2f_flag_coverage_autosync' )
            : ( get_option( 'b2f_flag_coverage_autosync', '1' ) !== '0' );
        if ( $coverage_enabled && function_exists( 'b2f_auto_sync_parent_coverage' ) ) {
            $auto_added = b2f_auto_sync_parent_coverage( $maker_id, $sku );
            if ( ! empty( $auto_added ) && function_exists( 'b2f_log' ) ) {
                b2f_log( '[DualWrite V.1.5] coverage auto-sync added ' . count( $auto_added ) . ' ancestor(s): ' . implode( ',', $auto_added ) );
            }
        } elseif ( ! $coverage_enabled && function_exists( 'b2f_log' ) ) {
            b2f_log( '[DualWrite V.1.5] coverage auto-sync skipped — b2f_flag_coverage_autosync=OFF (sku=' . $sku . ' maker=' . $maker_id . ')' );
        }

        return true;
    }
}

// ═══════════════════════════════════════════════════════════════════
// V.1.2: CLASSIFICATION INFERENCE HELPER (local to Snippet 0.5)
// ═══════════════════════════════════════════════════════════════════
//
// Infer V11 classification defaults for fresh INSERT (ON DUPLICATE excludes these).
// Prefers Snippet 1 V.7.0 helper `b2f_infer_production_mode_from_relations()` ถ้ามี,
// ไม่มีก็ inline fallback logic (Snippet 1 V.7.0 จะ consolidate ภายหลัง).
//
// Classification logic (mirror Phase 4 migration pseudocode):
//   has_children AND missing_leaves > 0 → cross_factory_assembly + as_parts
//   has_children AND has_parent         → sub_unit + auto
//   has_children AND NOT has_parent     → set_assembled + auto
//   NO children (leaf)                  → single + auto
//
// CPT save = admin-edited → confirmation_status = 'confirmed'
//   (CPT registered manually by admin, ไม่ใช่ auto-sync orphan)

if ( ! function_exists( 'b2f_dualwrite_infer_classification' ) ) {
    function b2f_dualwrite_infer_classification( $sku, $maker_id ) {
        // Prefer Snippet 1 V.7.0+ helper when available (single source of truth)
        if ( function_exists( 'b2f_infer_production_mode_from_relations' ) ) {
            $inferred = b2f_infer_production_mode_from_relations( $sku, $maker_id );
            if ( is_array( $inferred ) && isset( $inferred['production_mode'] ) ) {
                // CPT save = admin-confirmed (not auto-synced orphan)
                $inferred['confirmation_status'] = 'confirmed';
                return $inferred;
            }
        }

        // Inline fallback (Snippet 1 helper not yet synced)
        $relations = get_option( 'dinoco_sku_relations', array() );
        if ( ! is_array( $relations ) ) $relations = array();

        // Normalize keys to uppercase for case-insensitive lookup
        $sku_upper = strtoupper( (string) $sku );
        $rel_upper = array();
        foreach ( $relations as $parent_sku => $children ) {
            $rel_upper[ strtoupper( $parent_sku ) ] = is_array( $children ) ? array_map( 'strtoupper', $children ) : array();
        }

        $children     = isset( $rel_upper[ $sku_upper ] ) ? $rel_upper[ $sku_upper ] : array();
        $has_children = ! empty( $children );

        // has_parent: walk relations to find SKU in any parent's children array
        $has_parent = false;
        foreach ( $rel_upper as $parent_sku => $parent_children ) {
            if ( in_array( $sku_upper, $parent_children, true ) ) {
                $has_parent = true;
                break;
            }
        }

        // missing_leaves count (maker-scoped): children ที่ maker นี้ไม่ได้ register ใน junction
        $missing_count = 0;
        if ( $has_children ) {
            global $wpdb;
            $tbl = $wpdb->prefix . 'dinoco_product_makers';
            // Flatten children (walk 1 level — DD-2 leaf guard handles deeper recursion elsewhere)
            $placeholders = implode( ',', array_fill( 0, count( $children ), '%s' ) );
            $args = array_merge( array( $maker_id ), $children );
            $registered = (int) $wpdb->get_var( $wpdb->prepare(
                "SELECT COUNT(*) FROM {$tbl}
                 WHERE maker_id = %d
                   AND BINARY UPPER(product_sku) IN ({$placeholders})
                   AND deleted_at IS NULL",
                $args
            ) );
            $missing_count = max( 0, count( $children ) - $registered );
        }

        // Classification matrix
        if ( $has_children && $missing_count > 0 ) {
            $production_mode    = 'cross_factory_assembly';
            $admin_display_mode = 'as_parts'; // auto-hide cross-factory SET default
        } elseif ( $has_children && $has_parent ) {
            $production_mode    = 'sub_unit';
            $admin_display_mode = 'auto';
        } elseif ( $has_children ) {
            $production_mode    = 'set_assembled';
            $admin_display_mode = 'auto';
        } else {
            $production_mode    = 'single';
            $admin_display_mode = 'auto';
        }

        return array(
            'production_mode'      => $production_mode,
            'confirmation_status'  => 'confirmed', // CPT = admin-confirmed by default
            'admin_display_mode'   => $admin_display_mode,
            'missing_leaves_count' => $missing_count,
        );
    }
}

/**
 * Soft-delete junction row เมื่อ CPT ถูกลบ
 */
if ( ! function_exists( 'b2f_dual_soft_delete_junction' ) ) {
    function b2f_dual_soft_delete_junction( $mp_id ) {
        global $wpdb;
        $mp_id = intval( $mp_id );
        if ( ! $mp_id ) return false;
        if ( ! get_option( 'b2f_schema_v10_activated' ) ) return false;

        $tbl = $wpdb->prefix . 'dinoco_product_makers';
        $uid = get_current_user_id();
        $now = current_time( 'mysql' );

        $ok = $wpdb->query( $wpdb->prepare(
            "UPDATE {$tbl}
             SET deleted_at = %s, status = 'discontinued', updated_by = %d, updated_at = %s
             WHERE legacy_cpt_id = %d AND deleted_at IS NULL",
            $now, $uid, $now, $mp_id
        ) );
        return ( $ok !== false );
    }
}

