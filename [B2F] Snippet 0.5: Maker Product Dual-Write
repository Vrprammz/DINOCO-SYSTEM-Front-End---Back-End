// SECTION 2: WP HOOKS
// ═══════════════════════════════════════════════════════════════════

// Fire after ACF saves fields (priority 20 > ACF default 10)
add_action( 'save_post_b2f_maker_product', function( $post_id, $post, $update ) {
    // Flag gate
    if ( ! function_exists( 'b2f_is_flag_enabled' ) || ! b2f_is_flag_enabled( 'b2f_flag_shadow_write' ) ) return;

    // Skip revisions / autosaves / bulk edit
    if ( wp_is_post_revision( $post_id ) ) return;
    if ( wp_is_post_autosave( $post_id ) ) return;
    if ( defined( 'DOING_AUTOSAVE' ) && DOING_AUTOSAVE ) return;

    // Only publish/draft
    if ( ! in_array( $post->post_status, array( 'publish', 'draft' ), true ) ) return;

    $res = b2f_dual_write_to_junction( $post_id );
    if ( is_wp_error( $res ) && function_exists( 'b2f_log' ) ) {
        b2f_log( '[DualWrite] save_post error mp_id=' . $post_id . ': ' . $res->get_error_message() );
    }
}, 20, 3 );

// Soft-delete on trash/delete
add_action( 'before_delete_post', function( $post_id ) {
    if ( ! function_exists( 'b2f_is_flag_enabled' ) || ! b2f_is_flag_enabled( 'b2f_flag_shadow_write' ) ) return;

    $post = get_post( $post_id );
    if ( ! $post || $post->post_type !== 'b2f_maker_product' ) return;

    $ok = b2f_dual_soft_delete_junction( $post_id );
    if ( ! $ok && function_exists( 'b2f_log' ) ) {
        b2f_log( '[DualWrite] soft-delete failed mp_id=' . $post_id );
    }
}, 10, 1 );

// Restore on untrash (reactivate junction row)
add_action( 'untrash_post', function( $post_id ) {
    if ( ! function_exists( 'b2f_is_flag_enabled' ) || ! b2f_is_flag_enabled( 'b2f_flag_shadow_write' ) ) return;

    $post = get_post( $post_id );
    if ( ! $post || $post->post_type !== 'b2f_maker_product' ) return;

    global $wpdb;
    $tbl = $wpdb->prefix . 'dinoco_product_makers';
    $wpdb->query( $wpdb->prepare(
        "UPDATE {$tbl}
         SET deleted_at = NULL, status = 'active', updated_at = %s
         WHERE legacy_cpt_id = %d",
        current_time( 'mysql' ), $post_id
    ) );
}, 10, 1 );

// ═══════════════════════════════════════════════════════════════════
// V.1.2 CRIT-4: CRON HANDLER — REPLAY QUEUED DUAL-WRITE
// ═══════════════════════════════════════════════════════════════════
//
// Triggered by wp_schedule_single_event in b2f_dual_write_to_junction when
// migration lock flag was active. Re-runs dual-write 10 seconds later —
// loop-safe because migration flag cleared on Phase 4 finish (Audit V.3.3).
//
// If migration still active after N retries → give up + log (migration stuck).

add_action( 'b2f_replay_queued_dual_write', function( $mp_id ) {
    $mp_id = intval( $mp_id );
    if ( ! $mp_id ) return;

    // Bail if CPT was deleted between schedule + replay
    $post = get_post( $mp_id );
    if ( ! $post || $post->post_type !== 'b2f_maker_product' ) {
        if ( function_exists( 'b2f_log' ) ) {
            b2f_log( '[DualWrite V.1.2] replay cancelled — mp_id=' . $mp_id . ' deleted' );
        }
        return;
    }

    // If flag still active → re-schedule once more (max 6 retries = 1 minute total)
    if ( get_option( 'b2f_phase4_migration_in_progress' ) ) {
        $retry_count = (int) get_post_meta( $mp_id, '_b2f_replay_retry_count', true );
        if ( $retry_count >= 6 ) {
            if ( function_exists( 'b2f_log' ) ) {
                b2f_log( '[DualWrite V.1.2] replay gave up after 6 retries mp_id=' . $mp_id . ' — migration stuck?' );
            }
            delete_post_meta( $mp_id, '_b2f_replay_retry_count' );
            return;
        }
        update_post_meta( $mp_id, '_b2f_replay_retry_count', $retry_count + 1 );
        wp_schedule_single_event( time() + 10, 'b2f_replay_queued_dual_write', array( $mp_id ) );
        return;
    }

    // Lock cleared — run dual-write
    delete_post_meta( $mp_id, '_b2f_replay_retry_count' );
    $res = b2f_dual_write_to_junction( $mp_id );
    if ( is_wp_error( $res ) && function_exists( 'b2f_log' ) ) {
        b2f_log( '[DualWrite V.1.2] replay failed mp_id=' . $mp_id . ': ' . $res->get_error_message() );
    } elseif ( function_exists( 'b2f_log' ) ) {
        b2f_log( '[DualWrite V.1.2] replay success mp_id=' . $mp_id );
    }
}, 10, 1 );

