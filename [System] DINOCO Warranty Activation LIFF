if ( ! function_exists( 'dinoco_sn_render_activate_form' ) ) {
    function dinoco_sn_render_activate_form( $sn ) {
        // Lookup plate via REST
        $rest_url = rest_url( 'dinoco-sn/v1/lookup/' . urlencode( $sn ) );
        $response = wp_remote_get( $rest_url, array( 'timeout' => 5 ) );

        if ( is_wp_error( $response ) ) {
            dinoco_sn_render_activate_error( 'lookup_failed', 'ไม่สามารถดึงข้อมูล S/N ได้ ลองอีกครั้ง' );
            return;
        }

        $code = wp_remote_retrieve_response_code( $response );
        $body = json_decode( wp_remote_retrieve_body( $response ), true );

        if ( $code === 404 ) {
            dinoco_sn_render_activate_error( 'sn_not_found', 'ไม่พบ S/N นี้ในระบบ' );
            return;
        }

        if ( $code === 410 ) {
            dinoco_sn_render_activate_error( 'voided', 'เพลทถูกยกเลิก กรุณาทิ้งทันที' );
            return;
        }

        if ( ! is_array( $body ) ) {
            dinoco_sn_render_activate_error( 'system_error', 'ระบบขัดข้อง กรุณาลองใหม่' );
            return;
        }

        $status = $body['status'] ?? '';
        $linked_sku = $body['product']['linked_sku'] ?? '';
        $top_set = $body['product']['top_set_sku'] ?? $linked_sku;

        // V.0.4 — Phase 3 W8.4: explicit stolen/recalled handling.
        // Boss decision Q23 + plan v2.6 §M14 — block activate + alert บอส +
        // log incident (potential fraud signal — someone trying to register
        // a stolen/recalled plate). Customer sees neutral "ติดต่อร้าน" message
        // (no info leak to potential fraudster).
        if ( $status === 'stolen' ) {
            // Telegram alert + Obs capture (defensive)
            if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                dinoco_sn_obs_capture( 'activate_blocked_stolen', array(
                    'sn' => $sn, 'user_id' => get_current_user_id(),
                ) );
            }
            // Try to send Telegram alert (defensive — never throws from render)
            if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                try {
                    $tg_msg = sprintf(
                        '🚨 STOLEN PLATE ACTIVATE ATTEMPT %s%suser_id=%d%sIP=%s',
                        $sn, "\n",
                        get_current_user_id(), "\n",
                        sanitize_text_field( $_SERVER['REMOTE_ADDR'] ?? 'unknown' )
                    );
                    b2b_tg_send_dedup( $tg_msg, 'stolen_activate_' . $sn, 3600 );
                } catch ( \Throwable $e ) {
                    error_log( '[SN-Activate] Telegram alert failed: ' . $e->getMessage() );
                }
            }
            // Audit log (defensive)
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $sn, 'activate_blocked_stolen', $status, null,
                    array( 'attempted_user_id' => get_current_user_id() )
                );
            }
            dinoco_sn_render_activate_error( 'stolen', 'เพลทรายงานหายแล้ว — กรุณาติดต่อร้าน' );
            return;
        }

        if ( $status === 'recalled' ) {
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $sn, 'activate_blocked_recalled', $status, null,
                    array( 'attempted_user_id' => get_current_user_id() )
                );
            }
            // Customer-friendly message — don't leak recall reason details
            dinoco_sn_render_activate_error( 'recalled', 'เพลทถูกเรียกคืน — กรุณาติดต่อร้าน' );
            return;
        }

        // State D: Already registered
        if ( in_array( $status, array( 'registered', 'claimed', 'transferred' ), true ) ) {
            dinoco_sn_render_state_already_registered( $sn, $body );
            return;
        }

        // State E: Not in_pool yet (still reserved/sent_to_factory etc.)
        if ( $status !== 'in_pool' && $status !== 'shipped_legacy' ) {
            dinoco_sn_render_state_not_yet_shipped( $sn, $status );
            return;
        }

        // State A/B: Ready to activate
        ?>
        <div class="dnc-sn-card">
            <h2 style="text-align:center;">🛡 ลงทะเบียนรับประกัน</h2>

            <?php if ( $linked_sku ) : ?>
                <?php
                // Try fetch product image (defensive — function from Inventory snippet)
