        // QR scanner with lazy-loaded html5-qrcode (UMD CDN ~50KB gzip)
        // V.0.12 (2026-05-08) R3 BUG-6 HOTFIX — added SRI sha384 hash to script tag
        // (CWE-353 supply-chain attack defense). Hash computed:
        //   curl -L cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js \
        //     | openssl dgst -sha384 -binary | openssl base64 -A
        // Browser refuses to execute if CDN response bytes don't match hash.
        // Also added BUG-4 visibilitychange/pagehide listener + BUG-5 local-var
        // capture-before-null pattern.
        var _dncSnQrInstance = null;
        var _dncSnQrLibLoading = false;
        var _dncSnQrLibLoaded = false;

        function dncSnLoadQrLib(cb) {
            if (_dncSnQrLibLoaded) { cb(); return; }
            if (_dncSnQrLibLoading) {
                // Multi-tap during load — wait
                setTimeout(function() { dncSnLoadQrLib(cb); }, 100);
                return;
            }
            _dncSnQrLibLoading = true;
            var s = document.createElement('script');
            // R3 BUG-6 — set integrity + crossOrigin + referrerPolicy BEFORE src
            // (some browsers start fetch on src assignment regardless of order)
            s.integrity = 'sha384-c9d8RFSL+u3exBOJ4Yp3HUJXS4znl9f+z66d1y54ig+ea249SpqR+w1wyvXz/lk+';
            s.crossOrigin = 'anonymous';
            s.referrerPolicy = 'no-referrer';
            s.async = true;
            s.src = 'https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js';
            s.onload = function() {
