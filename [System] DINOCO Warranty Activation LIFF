if ( ! function_exists( 'dinoco_sn_render_warranty_activate' ) ) {
    function dinoco_sn_render_warranty_activate( $atts = array() ) {
        // Feature flag check
        if ( function_exists( 'dinoco_sn_is_enabled' ) && ! dinoco_sn_is_enabled() ) {
            return '<div class="dnc-sn-disabled" style="text-align:center;padding:50px;">
                <h3>ระบบยังไม่เปิดให้บริการ</h3>
                <p>กรุณาลองใหม่อีกครั้ง</p>
            </div>';
        }

        $sn = isset( $_GET['sn'] ) ? strtoupper( trim( sanitize_text_field( $_GET['sn'] ) ) ) : '';

        /* V.0.17 (2026-05-08) Phase 8 S5 — Gateway + Activation consolidate.
           Activation LIFF had its own scan-first landing (duplicate of
           [dinoco_gateway] V.31.0). Maintenance burden + customer confusion.
           Now: when NO sn param + NOT logged in → redirect to Gateway
           (single source of truth for scan-first onboarding).
           Logged-in users without SN see landing (rare case — manual nav).
           Filter `dinoco_sn_activate_no_sn_redirect` allows opt-out.
           Default flag `dinoco_sn_consolidate_with_gateway` = '1' (ON).

           NOTE: Phase 6.5 deferred this — boss approved 2026-05-08
           "ทั้งหมดฉันโอเค เลือกทางที่ดีที่สุด". Behavior controllable via
           wp_option for instant rollback without redeploy. */
        $consolidate_flag = (string) get_option( 'dinoco_sn_consolidate_with_gateway', '1' );
        if ( $consolidate_flag === '1' && $sn === '' && ! is_user_logged_in() ) {
            // Defensive: only redirect if Gateway page actually exists (page slug check)
            // Allow filter to override (e.g. for staging/testing)
            $do_redirect = apply_filters( 'dinoco_sn_activate_no_sn_redirect', true );
            if ( $do_redirect ) {
                $gateway_url = home_url( '/gateway' );
                // Fallback: if /gateway returns 404 keep landing visible (don't redirect to broken page)
                // Cheap heuristic: check if a published page with slug 'gateway' exists
                $gateway_page = get_page_by_path( 'gateway' );
                if ( $gateway_page && $gateway_page->post_status === 'publish' ) {
                    wp_safe_redirect( $gateway_url );
                    exit;
                }
            }
        }

        ob_start();
        ?>
        <div class="dnc-sn-activate-page">
            <?php
            // Render styles
            dinoco_sn_render_activate_styles();

            // No SN param → show landing
            if ( $sn === '' ) {
                dinoco_sn_render_activate_landing();
            } else {
                // Validate SN format (preliminary check before API call)
                if ( ! preg_match( '/^[A-Z0-9]{8,16}$/', $sn ) ) {
                    dinoco_sn_render_activate_error( 'invalid_sn_format', 'รูปแบบ S/N ไม่ถูกต้อง' );
                } else {
                    dinoco_sn_render_activate_form( $sn );
                }
            }
            ?>
        </div>
        <?php
        return ob_get_clean();
    }
}

