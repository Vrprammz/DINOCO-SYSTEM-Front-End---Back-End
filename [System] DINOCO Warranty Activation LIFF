if ( ! function_exists( 'dinoco_sn_rest_activate' ) ) {
    /**
     * POST /dinoco-sn/v1/activate — customer activate warranty
     *
     * Atomic: SELECT FOR UPDATE on sn_pool + flip status=registered +
     * INSERT warranty_registration CPT + INSERT audit row + LINE Flex push.
     */
    function dinoco_sn_rest_activate( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', '', array( 'status' => 503 ) );
        }
        if ( ! function_exists( 'dinoco_sn_with_idempotency' ) ) {
            // REST API snippet not synced — fall through
            return dinoco_sn_handler_activate( $req );
        }

        return dinoco_sn_with_idempotency(
            $req,
            'activate',
            array( 'sn', 'moto_brand', 'moto_model', 'purchase_date' ),
            function( $req ) { return dinoco_sn_handler_activate( $req ); }
        );
    }
}

if ( ! function_exists( 'dinoco_sn_handler_activate' ) ) {
    function dinoco_sn_handler_activate( $req ) {
        global $wpdb;

        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        $moto_brand = sanitize_text_field( $req->get_param( 'moto_brand' ) );
        $moto_model = sanitize_text_field( $req->get_param( 'moto_model' ) );
        $purchase_date = sanitize_text_field( $req->get_param( 'purchase_date' ) );
        $pdpa = (bool) $req->get_param( 'pdpa_accepted' );
        $user_id = get_current_user_id();

        // Phase 1 W4.2 — Observability hook (customer activate = high-volume sensitive op)
        if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
            dinoco_sn_obs_capture( 'activate_attempt', array(
                'sn' => $sn, 'user_id' => $user_id, 'moto_brand' => $moto_brand,
            ) );
        }

        if ( $sn === '' || $moto_brand === '' || $moto_model === '' || $purchase_date === '' ) {
            return new WP_Error( 'invalid_input', __( 'Missing required fields.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( ! $pdpa ) {
            return new WP_Error( 'pdpa_required', __( 'ต้องยอมรับ PDPA.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( $user_id <= 0 ) {
            return new WP_Error( 'not_logged_in', '', array( 'status' => 401 ) );
        }

        /* ─────────────────────────────────────────────────────────────────
         * R7 C2 (CVSS 8.1) — SN squatting attack defense.
         *
         * Pre-V.0.10: any LINE user could POST sn=DNCSS... and register an
         * arbitrary in_pool plate to themselves. Iterate all SNs → squat
         * valid plates → real owner blocked at activate-time (409 already_
         * registered). With 1M+ printed plates the enumeration cost is
         * trivial (~3hrs at 100 req/s).
         *
         * V.0.10 defense (3 layers):
         *   1. HMAC sig flag-gate. wp_option `dinoco_sn_hmac_required` = '1'
         *      enforces sig param + dinoco_sn_hmac_verify($sn, $sig). Default
         *      OFF — existing 1M plates printed without sig must be reissued
         *      first (boss flips ON only after QR PDF reissue per
         *      docs/sn-system/22-customer-support-readiness-plan.md).
         *   2. Always log unsigned attempts → boss can monitor abuse rate
         *      and decide flip-moment from real data.
         *   3. Soft rate-limit unsigned attempts at 10/IP/hr regardless of
         *      flag — defeats single-IP enumeration even before flip.
         * ───────────────────────────────────────────────────────────────── */
        $sig = (string) $req->get_param( 'sig' );
        $hmac_required = ( get_option( 'dinoco_sn_hmac_required', '0' ) === '1' );

        // Resolve client IP for rate-limit + observability
        $client_ip = '';
        if ( function_exists( 'dinoco_idempotency_resolve_ip' ) ) {
            $client_ip = (string) dinoco_idempotency_resolve_ip();
        } elseif ( isset( $_SERVER['REMOTE_ADDR'] ) ) {
            $client_ip = (string) $_SERVER['REMOTE_ADDR'];
        }

        if ( $hmac_required ) {
            // Strict mode: sig required + verified
            if ( $sig === '' ) {
                error_log( sprintf(
                    '[SN-ACTIVATE-SIG-MISSING] uid=%d sn=%s ip=%s',
                    $user_id, $sn, $client_ip
                ) );
                return new WP_Error(
                    'sig_required',
                    __( 'ลิงก์ลงทะเบียนไม่ถูกต้อง (กรุณาสแกน QR ใหม่)', 'dinoco-sn' ),
                    array( 'status' => 403 )
                );
            }
            if ( ! function_exists( 'dinoco_sn_hmac_verify' ) ) {
                // Helper missing → fail closed in strict mode
                error_log( sprintf(
                    '[SN-ACTIVATE-SIG-HELPER-MISSING] uid=%d sn=%s — dinoco_sn_hmac_verify not loaded',
                    $user_id, $sn
                ) );
                return new WP_Error(
                    'sig_verify_unavailable',
                    __( 'ระบบไม่พร้อม กรุณาลองใหม่ภายหลัง', 'dinoco-sn' ),
                    array( 'status' => 503 )
                );
            }
            if ( ! dinoco_sn_hmac_verify( $sn, $sig ) ) {
                error_log( sprintf(
                    '[SN-ACTIVATE-SIG-INVALID] uid=%d sn=%s ip=%s sig_prefix=%s',
                    $user_id, $sn, $client_ip, substr( $sig, 0, 8 )
                ) );
                return new WP_Error(
                    'invalid_sig',
                    __( 'ลิงก์ลงทะเบียนไม่ถูกต้อง', 'dinoco-sn' ),
                    array( 'status' => 403 )
                );
            }
        } else {
            // Permissive mode (flag OFF) — observability + soft rate-limit only
            if ( $sig === '' ) {
                error_log( sprintf(
                    '[SN-ACTIVATE-UNSIGNED] uid=%d sn=%s ip=%s',
                    $user_id, $sn, $client_ip
                ) );
                // Soft rate-limit: 10 unsigned attempts per IP per hour
                if ( $client_ip !== '' && function_exists( 'b2b_rate_limit' ) ) {
                    $rl = b2b_rate_limit(
                        'sn_unsigned_activate_' . md5( $client_ip ),
                        10,
                        HOUR_IN_SECONDS
                    );
                    if ( is_wp_error( $rl ) ) {
                        return $rl;
                    }
                }
            } elseif ( function_exists( 'dinoco_sn_hmac_verify' ) ) {
                // Sig present but flag OFF — verify opportunistically + log mismatch
                // (helps detect attackers probing valid sigs even before flag flip)
                if ( ! dinoco_sn_hmac_verify( $sn, $sig ) ) {
                    error_log( sprintf(
                        '[SN-ACTIVATE-SIG-PRESENT-INVALID-FLAG-OFF] uid=%d sn=%s ip=%s',
                        $user_id, $sn, $client_ip
                    ) );
                    // Don't block — flag is OFF — but signal observed
                }
            }
        }
        /* ───────────────────────────────────────────────────────────────── */


        if ( ! function_exists( 'dinoco_sn_table' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }

        $tbl_pool = dinoco_sn_table( 'pool' );

        // V.0.8 — canonical helper (matches Manual Transfer + Service Center
        // + REST API V.0.29 swap/void/recall/reissue).
        // V.0.9 R4 BLOCKER #3 — fallback literal 5 → 15 (matches new constant)
        $lock_name = function_exists( 'dinoco_sn_lock_name' )
            ? dinoco_sn_lock_name( $sn )
            : 'dnc_sn_' . md5( $sn );
        $lock_to   = defined( 'DINOCO_SN_LOCK_TIMEOUT' ) ? (int) DINOCO_SN_LOCK_TIMEOUT : 15;
        $got = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, %d)", $lock_name, $lock_to ) );
        if ( $got !== 1 ) {
            return new WP_Error( 'lock_timeout',
                __( 'มีคำสั่งกำลังประมวลผล S/N นี้อยู่ — กรุณาลองใหม่อีกครั้ง', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        try {
            $wpdb->query( "START TRANSACTION" );

            $plate = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl_pool} WHERE sn = %s FOR UPDATE", $sn
            ) );

            if ( ! $plate ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'sn_not_found', '', array( 'status' => 404 ) );
            }

            if ( in_array( $plate->status, array( 'registered', 'claimed', 'transferred' ), true ) ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'already_registered', __( 'S/N นี้ลงทะเบียนแล้ว', 'dinoco-sn' ),
                    array( 'status' => 409 ) );
            }

            if ( ! in_array( $plate->status, array( 'in_pool', 'shipped_legacy' ), true ) ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'not_ready', __( 'S/N ยังไม่พร้อมลงทะเบียน', 'dinoco-sn' ),
                    array( 'status' => 403 ) );
            }

            // V.0.6 H3 — capture lock_version for optimistic concurrency.
            // If column not present (legacy schema) → fall back to status-only WHERE.
            $current_lock_version = isset( $plate->lock_version ) ? (int) $plate->lock_version : null;

            // Create warranty_registration CPT
            $warranty_id = wp_insert_post( array(
                'post_type'   => 'warranty_registration',
                'post_status' => 'publish',
                'post_title'  => 'Warranty ' . $sn,
                'post_author' => $user_id,
            ) );

            if ( ! $warranty_id || is_wp_error( $warranty_id ) ) {
                throw new \Exception( 'Failed to create warranty_registration CPT' );
            }

            // ACF fields (defensive — use update_post_meta if ACF not loaded)
            $meta_fields = array(
                'serial_code'   => $sn,
                'sn_pool_id'    => $sn,
                'sn_batch_id'   => $plate->batch_id,
                'brand'         => $moto_brand,
                'model'         => $moto_model,
                'purchase_date' => $purchase_date,
                'owner_user_id' => $user_id,
                'w_status'      => 'warranty_on',
            );
            foreach ( $meta_fields as $k => $v ) {
                update_post_meta( $warranty_id, $k, $v );
            }

            // V.0.6 H3 — atomic UPDATE with lock_version increment (optimistic concurrency).
            // WHERE clause includes both sn AND prior lock_version (if column exists)
            // → if a concurrent writer beat us → affected_rows=0 → 409 conflict.
            $now = current_time( 'mysql' );
            $update_data = array(
                'status'                 => 'registered',
                'prev_status'            => $plate->status,
                'registered_user_id'     => $user_id,
                'registered_warranty_id' => $warranty_id,
                'registered_at'          => $now,
            );
            $update_format = array( '%s', '%s', '%d', '%d', '%s' );

            if ( $current_lock_version !== null ) {
                $update_data['lock_version'] = $current_lock_version + 1;
                $update_format[] = '%d';
                $where = array( 'sn' => $sn, 'lock_version' => $current_lock_version );
                $where_format = array( '%s', '%d' );
            } else {
                // Legacy schema fallback — guard via status to avoid double flip
                $where = array( 'sn' => $sn, 'status' => $plate->status );
                $where_format = array( '%s', '%s' );
            }

            $upd = $wpdb->update( $tbl_pool, $update_data, $where, $update_format, $where_format );
            if ( $upd === false || $upd === 0 ) {
                $wpdb->query( "ROLLBACK" );
                // Best-effort cleanup of orphan warranty CPT (will retry on next attempt)
                if ( function_exists( 'wp_delete_post' ) ) {
                    @wp_delete_post( $warranty_id, true );
                }
                return new WP_Error( 'lock_version_conflict',
                    __( 'มีการแก้ไข S/N นี้ระหว่างการลงทะเบียน — กรุณาลองใหม่', 'dinoco-sn' ),
                    array( 'status' => 409 ) );
            }

            $wpdb->query( "COMMIT" );

            // Audit log
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $sn, 'plate_registered', $plate->status, 'registered', array(
                    'warranty_id' => $warranty_id,
                    'user_id'     => $user_id,
                    'moto'        => "{$moto_brand} {$moto_model}",
                ), $user_id );
            }

            // V.0.8 F-NEW-1 — fire BOTH generic + per-user variants so Member
            // Dashboard subscriber refreshes the just-activated plate.
            if ( function_exists( 'dinoco_sn_fire_status_changed' ) ) {
                dinoco_sn_fire_status_changed( $sn, (string) $plate->status, 'registered', (int) $user_id );
            } else {
                do_action( 'dinoco_sn_pool_status_changed', $sn, $plate->status, 'registered' );
                if ( $user_id > 0 ) {
                    do_action( 'dinoco_sn_pool_status_changed_for_user', $user_id, $sn, $plate->status, 'registered' );
                }
            }
            // Belt-and-suspenders direct invalidate (in case REST API not synced)
            delete_transient( 'dinoco_sn_lookup_' . md5( $sn ) );

            // Phase 3 W11.1 — F#13 geo capture (defensive, best-effort, never throws)
            // Captures province/IP/lat/lng for heatmap + gray-market scan.
            // Wrapped in its own try/catch so geo failure NEVER blocks customer activation.
            if ( function_exists( 'dinoco_sn_record_geo_activation_for_user' ) ) {
                try {
                    dinoco_sn_record_geo_activation_for_user( $sn, $user_id );
                } catch ( \Throwable $geo_e ) {
                    if ( function_exists( 'dinoco_obs_capture_exception' ) ) {
                        dinoco_obs_capture_exception( $geo_e, array( 'context' => 'sn_activate_geo_capture', 'sn' => $sn ) );
                    }
                }
            }

            // LINE Flex push (deferred async per v2.4 performance fix)
            // wp_schedule_single_event( time() + 5, 'dinoco_sn_push_activate_flex', array( $sn, $user_id ) );

            return rest_ensure_response( array(
                'success'     => true,
                'sn'          => $sn,
                'warranty_id' => $warranty_id,
                'status'      => 'registered',
                'registered_at' => $now,
            ) );

        } catch ( \Throwable $e ) {
            $wpdb->query( "ROLLBACK" );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture_exception( $e, array( 'context' => 'sn_activate', 'sn' => $sn ) );
            }
            return new WP_Error( 'activate_failed', $e->getMessage(), array( 'status' => 500 ) );
        } finally {
            // V.0.6 C1 — always release the unified lock (idempotent on re-call)
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 3. PHASE 3 W11.1 — F#13 GEO CAPTURE ON ACTIVATE
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * dinoco_sn_record_geo_activation_for_user( $sn, $user_id )
 *   - Best-effort: NEVER throws (caller already wraps in try/catch but defensive again here)
 *   - Resolves province from REMOTE_ADDR via dinoco_sn_resolve_province_from_ip()
 *   - LINE region via id_token claim if available (Phase 4 W12 wires reliably)
 *   - Calls dinoco_sn_record_geo_activation() helper from REST API snippet
 *     (function_exists guarded — does nothing if REST API not synced yet)
 *
 * Called from dinoco_sn_handler_activate() after successful COMMIT.
 *
 * PII protection (per audit memo project_audit_2026_04_17_pending_actions):
 *   - Full IP address NEVER stored (last octet masked before logging)
 *   - lat/lng nullable (best-effort from IP geo only)
 */
if ( ! function_exists( 'dinoco_sn_record_geo_activation_for_user' ) ) {
    function dinoco_sn_record_geo_activation_for_user( $sn, $user_id ) {
        $sn = strtoupper( trim( (string) $sn ) );
        $user_id = (int) $user_id;
        if ( $sn === '' || $user_id <= 0 ) return false;

        // REST API helper guard (different snippet)
        if ( ! function_exists( 'dinoco_sn_record_geo_activation' ) ) {
            return false;
        }

        // Resolve client IP (Cloudflare/proxy aware where possible)
        $ip = dinoco_sn_get_client_ip();

        // Resolve province (defensive — function may return 'Unknown')
        $province = function_exists( 'dinoco_sn_resolve_province_from_ip' )
            ? dinoco_sn_resolve_province_from_ip( $ip )
            : 'Unknown';

        // If province resolution returned empty/Unknown, still record the row but
        // tag province='Unknown' — gray-market scan filters by has-dealer per-province.
        if ( $province === '' ) $province = 'Unknown';

        // Cross-reference dealer territory: see if user's purchase_dealer_id covers
        // this province (Phase 4 W12 — for now just pass null, leave is_in_dealer_territory=0)
        $is_in_territory = 0;
        $expected_dealer_id = null;

        // Best-effort: classify gray market based on province / has-dealer presence
        $has_dealer = false; // Phase 3 W11.1 stub — Phase 4 W12 wires dealer territory CPT lookup
        $country_code = function_exists( 'dinoco_sn_resolve_country_from_ip' )
            ? dinoco_sn_resolve_country_from_ip( $ip )
            : 'TH';
        $classification = function_exists( 'dinoco_sn_classify_gray_market' )
            ? dinoco_sn_classify_gray_market( $country_code, $has_dealer )
            : 'normal';
        $is_gray = ( $classification !== 'normal' ) ? 1 : 0;

        return dinoco_sn_record_geo_activation( $sn, $province, array(
            'source'                 => 'activate',
            'lat'                    => null, // Phase 4 W12: IP geolocation library
            'lng'                    => null,
            'is_in_dealer_territory' => $is_in_territory,
            'expected_dealer_id'     => $expected_dealer_id,
            'is_gray_market_suspect' => $is_gray,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_get_client_ip' ) ) {
    /**
     * Best-effort IP resolver (Cloudflare/proxy aware).
     * Mirrors pattern from [System] DINOCO GDPR Data Requests V.1.1
     * (`dinoco_gdpr_get_client_ip()`) for consistency.
     *
     * Returns first non-empty header value; falls back to REMOTE_ADDR.
     * Returns '' if nothing usable (CLI / cron context).
     */
    function dinoco_sn_get_client_ip() {
        $headers = array(
            'HTTP_CF_CONNECTING_IP', // Cloudflare
            'HTTP_X_FORWARDED_FOR',
            'HTTP_X_REAL_IP',
            'REMOTE_ADDR',
        );
        foreach ( $headers as $h ) {
            if ( ! empty( $_SERVER[ $h ] ) ) {
                $val = (string) $_SERVER[ $h ];
                // X-Forwarded-For can be a list — take first
                if ( strpos( $val, ',' ) !== false ) {
                    $val = trim( strtok( $val, ',' ) );
                }
                $val = trim( $val );
                if ( $val !== '' && filter_var( $val, FILTER_VALIDATE_IP ) ) {
                    return $val;
                }
            }
        }
        return '';
    }
}

if ( ! function_exists( 'dinoco_sn_mask_ip_last_octet' ) ) {
    /**
     * PII: mask last octet (IPv4) or last group (IPv6) for safe logging.
     *   192.168.1.42  → 192.168.1.x
     *   2001:db8::1   → 2001:db8::x
     */
    function dinoco_sn_mask_ip_last_octet( $ip ) {
        $ip = (string) $ip;
        if ( $ip === '' ) return '';
        if ( strpos( $ip, ':' ) !== false ) {
            // IPv6 — mask last group
            $parts = explode( ':', $ip );
            if ( count( $parts ) > 1 ) {
                $parts[ count( $parts ) - 1 ] = 'x';
                return implode( ':', $parts );
            }
            return 'x';
        }
        // IPv4
        $parts = explode( '.', $ip );
        if ( count( $parts ) === 4 ) {
            $parts[3] = 'x';
            return implode( '.', $parts );
        }
        return 'x.x.x.x';
    }
}
