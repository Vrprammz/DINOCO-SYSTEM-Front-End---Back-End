                    return;
                }
                _dncSnQrLibLoaded = true;
                _dncSnQrLibLoading = false;
                cb();
            };
            s.onerror = function() {
                _dncSnQrLibLoading = false;
                var fn = (window.dinocoModal && window.dinocoModal.alert) ? window.dinocoModal.alert : function(o){alert((o.title||'')+'\n'+(o.message||''));};
                try {
