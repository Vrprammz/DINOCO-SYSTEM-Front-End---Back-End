if ( ! function_exists( 'dinoco_sn_register_activate_endpoint' ) ) {
    function dinoco_sn_register_activate_endpoint() {
        register_rest_route( 'dinoco-sn/v1', '/activate', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_activate',
            'permission_callback' => function() {
                return is_user_logged_in();
            },
            'args' => array(
                'sn' => array( 'required' => true, 'type' => 'string' ),
                'moto_brand' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'moto_model' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'purchase_date' => array( 'required' => true, 'type' => 'string' ),
                'pdpa_accepted' => array( 'required' => true ),
            ),
        ) );
    }
}

if ( ! has_action( 'rest_api_init', 'dinoco_sn_register_activate_endpoint' ) ) {
    add_action( 'rest_api_init', 'dinoco_sn_register_activate_endpoint' );
}

if ( ! function_exists( 'dinoco_sn_rest_activate' ) ) {
    /**
     * POST /dinoco-sn/v1/activate — customer activate warranty
     *
     * Atomic: SELECT FOR UPDATE on sn_pool + flip status=registered +
     * INSERT warranty_registration CPT + INSERT audit row + LINE Flex push.
     */
    function dinoco_sn_rest_activate( $req ) {
        if ( ! function_exists( 'dinoco_sn_is_enabled' ) || ! dinoco_sn_is_enabled() ) {
            return new WP_Error( 'feature_disabled', '', array( 'status' => 503 ) );
        }
        if ( ! function_exists( 'dinoco_sn_with_idempotency' ) ) {
            // REST API snippet not synced — fall through
            return dinoco_sn_handler_activate( $req );
        }

        return dinoco_sn_with_idempotency(
            $req,
            'activate',
            array( 'sn', 'moto_brand', 'moto_model', 'purchase_date' ),
            function( $req ) { return dinoco_sn_handler_activate( $req ); }
        );
    }
}

if ( ! function_exists( 'dinoco_sn_handler_activate' ) ) {
    function dinoco_sn_handler_activate( $req ) {
        global $wpdb;

        $sn = strtoupper( trim( (string) $req->get_param( 'sn' ) ) );
        $moto_brand = sanitize_text_field( $req->get_param( 'moto_brand' ) );
        $moto_model = sanitize_text_field( $req->get_param( 'moto_model' ) );
        $purchase_date = sanitize_text_field( $req->get_param( 'purchase_date' ) );
        $pdpa = (bool) $req->get_param( 'pdpa_accepted' );
        $user_id = get_current_user_id();

        // Phase 1 W4.2 — Observability hook (customer activate = high-volume sensitive op)
        if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
            dinoco_sn_obs_capture( 'activate_attempt', array(
                'sn' => $sn, 'user_id' => $user_id, 'moto_brand' => $moto_brand,
            ) );
        }

        if ( $sn === '' || $moto_brand === '' || $moto_model === '' || $purchase_date === '' ) {
            return new WP_Error( 'invalid_input', __( 'Missing required fields.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( ! $pdpa ) {
            return new WP_Error( 'pdpa_required', __( 'ต้องยอมรับ PDPA.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( $user_id <= 0 ) {
            return new WP_Error( 'not_logged_in', '', array( 'status' => 401 ) );
        }

        if ( ! function_exists( 'dinoco_sn_table' ) ) {
            return new WP_Error( 'helper_missing', '', array( 'status' => 503 ) );
        }

        $tbl_pool = dinoco_sn_table( 'pool' );

        try {
            $wpdb->query( "START TRANSACTION" );

            $plate = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$tbl_pool} WHERE sn = %s FOR UPDATE", $sn
            ) );

            if ( ! $plate ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'sn_not_found', '', array( 'status' => 404 ) );
            }

            if ( in_array( $plate->status, array( 'registered', 'claimed', 'transferred' ), true ) ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'already_registered', __( 'S/N นี้ลงทะเบียนแล้ว', 'dinoco-sn' ),
                    array( 'status' => 409 ) );
            }

            if ( ! in_array( $plate->status, array( 'in_pool', 'shipped_legacy' ), true ) ) {
                $wpdb->query( "ROLLBACK" );
                return new WP_Error( 'not_ready', __( 'S/N ยังไม่พร้อมลงทะเบียน', 'dinoco-sn' ),
                    array( 'status' => 403 ) );
            }

            // Create warranty_registration CPT
            $warranty_id = wp_insert_post( array(
                'post_type'   => 'warranty_registration',
                'post_status' => 'publish',
                'post_title'  => 'Warranty ' . $sn,
                'post_author' => $user_id,
            ) );

            if ( ! $warranty_id || is_wp_error( $warranty_id ) ) {
                throw new \Exception( 'Failed to create warranty_registration CPT' );
            }

            // ACF fields (defensive — use update_post_meta if ACF not loaded)
            $meta_fields = array(
                'serial_code'   => $sn,
                'sn_pool_id'    => $sn,
                'sn_batch_id'   => $plate->batch_id,
                'brand'         => $moto_brand,
                'model'         => $moto_model,
                'purchase_date' => $purchase_date,
                'owner_user_id' => $user_id,
                'w_status'      => 'warranty_on',
            );
            foreach ( $meta_fields as $k => $v ) {
                update_post_meta( $warranty_id, $k, $v );
            }

            // Update sn_pool
            $now = current_time( 'mysql' );
            $wpdb->update( $tbl_pool, array(
                'status'                 => 'registered',
                'prev_status'            => $plate->status,
                'registered_user_id'     => $user_id,
                'registered_warranty_id' => $warranty_id,
                'registered_at'          => $now,
            ), array( 'sn' => $sn ),
               array( '%s', '%s', '%d', '%d', '%s' ),
               array( '%s' )
            );

            $wpdb->query( "COMMIT" );

            // Audit log
            if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                dinoco_sn_audit_log( $sn, 'plate_registered', $plate->status, 'registered', array(
                    'warranty_id' => $warranty_id,
                    'user_id'     => $user_id,
                    'moto'        => "{$moto_brand} {$moto_model}",
                ), $user_id );
            }

            // Invalidate lookup cache
            delete_transient( 'dinoco_sn_lookup_' . md5( $sn ) );

            // LINE Flex push (deferred async per v2.4 performance fix)
            // wp_schedule_single_event( time() + 5, 'dinoco_sn_push_activate_flex', array( $sn, $user_id ) );

            return rest_ensure_response( array(
                'success'     => true,
                'sn'          => $sn,
                'warranty_id' => $warranty_id,
                'status'      => 'registered',
                'registered_at' => $now,
            ) );

        } catch ( \Throwable $e ) {
            $wpdb->query( "ROLLBACK" );
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture( $e, array( 'context' => 'sn_activate', 'sn' => $sn ) );
            }
            return new WP_Error( 'activate_failed', $e->getMessage(), array( 'status' => 500 ) );
        }
    }
}
