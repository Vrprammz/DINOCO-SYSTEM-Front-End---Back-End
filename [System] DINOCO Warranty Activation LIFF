if ( ! function_exists( 'dinoco_sn_render_warranty_activate' ) ) {
    function dinoco_sn_render_warranty_activate( $atts = array() ) {
        // Feature flag check
        if ( function_exists( 'dinoco_sn_is_enabled' ) && ! dinoco_sn_is_enabled() ) {
            return '<div class="dnc-sn-disabled" style="text-align:center;padding:50px;">
                <h3>ระบบยังไม่เปิดให้บริการ</h3>
                <p>กรุณาลองใหม่อีกครั้ง</p>
            </div>';
        }

        $sn = isset( $_GET['sn'] ) ? strtoupper( trim( sanitize_text_field( $_GET['sn'] ) ) ) : '';

        ob_start();
        ?>
        <div class="dnc-sn-activate-page">
            <?php
            // Render styles
            dinoco_sn_render_activate_styles();

            // No SN param → show landing
            if ( $sn === '' ) {
                dinoco_sn_render_activate_landing();
            } else {
                // Validate SN format (preliminary check before API call)
                if ( ! preg_match( '/^[A-Z0-9]{8,16}$/', $sn ) ) {
                    dinoco_sn_render_activate_error( 'invalid_sn_format', 'รูปแบบ S/N ไม่ถูกต้อง' );
                } else {
                    dinoco_sn_render_activate_form( $sn );
                }
            }
            ?>
        </div>
        <?php
        return ob_get_clean();
    }
}

