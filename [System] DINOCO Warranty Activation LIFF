        <script>
        /* V.0.15 S7 — Buddhist year helper. Shows "พ.ศ. 2569 (8 พ.ค. 2026)"
           inline below date picker when customer selects. */
        window.dncSnUpdateBuddhistYear = function(input) {
            try {
                var helper = document.getElementById('dnc-sn-purchase-date-helper');
                if (!helper) return;
                var v = input.value;  // YYYY-MM-DD
                if (!v) {
                    helper.textContent = 'เลือกวันที่ซื้อ — ระบบจะแสดง พ.ศ. ให้ตรวจสอบ';
                    helper.style.color = '#6b7280';
                    return;
                }
                var parts = v.split('-');
                var year = parseInt(parts[0], 10);
                var month = parseInt(parts[1], 10) - 1;
                var day = parseInt(parts[2], 10);
                if (isNaN(year)) return;
                var thaiMonths = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
                var buddhist = year + 543;
                var monthName = thaiMonths[month] || '';
                helper.textContent = '✓ พ.ศ. ' + buddhist + ' — ' + day + ' ' + monthName + ' ' + buddhist;
                helper.style.color = '#047857';
                helper.style.fontWeight = '600';
            } catch (e) { /* silent */ }
        };

        /* V.0.15 S8 — Form abandonment recovery. Auto-save form data to
           localStorage on input change. Restore on next visit (same SN).
           Cleared on success (NH9 already wired this). 1-day TTL guard. */
        (function() {
            try {
                var form = document.getElementById('dnc-sn-activate-form');
                if (!form) return;
                var snParam = (new URLSearchParams(window.location.search)).get('sn') || '';
                if (!snParam) return;
                var draftKey = 'dnc_sn_activate_draft_' + snParam;
                var TTL_MS = 24 * 60 * 60 * 1000;  // 1 day

                // Restore
                try {
                    var raw = localStorage.getItem(draftKey);
                    if (raw) {
                        var parsed = JSON.parse(raw);
                        if (parsed && parsed._ts && (Date.now() - parsed._ts) < TTL_MS && parsed.data) {
                            Object.keys(parsed.data).forEach(function(k) {
                                var el = form.querySelector('[name="' + k + '"]');
                                if (!el) return;
                                if (el.type === 'checkbox') {
                                    el.checked = parsed.data[k] === '1' || parsed.data[k] === 'on';
                                } else {
                                    el.value = parsed.data[k];
                                    if (el.id === 'dnc-sn-purchase-date' && window.dncSnUpdateBuddhistYear) {
                                        window.dncSnUpdateBuddhistYear(el);
                                    }
                                }
                            });
                            // Show restore notice
                            var st = document.getElementById('dnc-sn-form-status');
                            if (st) st.textContent = 'คืนค่าจากการกรอกครั้งก่อนแล้ว';
                            // Visual hint
                            var hint = document.createElement('div');
                            hint.style.cssText = 'background:#dbeafe;border-left:3px solid #3b82f6;padding:8px 12px;border-radius:6px;margin-bottom:12px;font-size:13px;color:#1e40af;';
                            hint.textContent = '💾 คืนค่าที่กรอกไว้ — แก้ไขแล้วกด ✓ ยืนยันได้เลย';
                            form.insertBefore(hint, form.firstChild);
                            // Auto-clear after 5s
                            setTimeout(function() { hint.style.opacity = '0'; hint.style.transition = 'opacity 0.5s'; setTimeout(function() { hint.remove(); }, 500); }, 5000);
                        } else {
                            // Stale draft — clear
                            localStorage.removeItem(draftKey);
                        }
                    }
                } catch (e) { /* localStorage disabled or corrupted */ }

                // Auto-save on input change (debounced 500ms)
                var saveTimer = null;
                function saveDraft() {
                    try {
                        var data = {};
                        new FormData(form).forEach(function(v, k) { data[k] = v; });
                        localStorage.setItem(draftKey, JSON.stringify({
                            _ts: Date.now(),
                            data: data
                        }));
                    } catch (e) { /* silent */ }
                }
                form.addEventListener('input', function() {
                    clearTimeout(saveTimer);
                    saveTimer = setTimeout(saveDraft, 500);
                });
                form.addEventListener('change', function() {
                    clearTimeout(saveTimer);
                    saveTimer = setTimeout(saveDraft, 200);
                });
            } catch (e) { /* silent */ }
        })();

        document.getElementById('dnc-sn-activate-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var form = e.target;
            var btn = form.querySelector('button[type="submit"]');
            var statusEl = document.getElementById('dnc-sn-form-status');
            btn.disabled = true;
            btn.textContent = 'กำลังบันทึก...';
            // V.0.6 S3-1 — announce loading state to assistive tech
            if (statusEl) statusEl.textContent = 'กำลังบันทึกข้อมูล กรุณารอสักครู่';

            var data = {};
            new FormData(form).forEach(function(v, k) { data[k] = v; });

            fetch('<?php echo esc_js( rest_url( 'dinoco-sn/v1/activate' ) ); ?>', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-WP-Nonce': data._wpnonce,
                    'X-Idempotency-Key': crypto.randomUUID()
                },
                body: JSON.stringify(data),
                credentials: 'same-origin'
            })
            .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, body: j }; }); })
            .then(function(res) {
                if (res.ok) {
                    if (statusEl) statusEl.textContent = 'ลงทะเบียนสำเร็จ';
                    /* V.0.15 NH9 — CSS confetti animation on success (no JS lib).
                       16 confetti pieces with random color + delay. Respects
                       prefers-reduced-motion. Auto-cleanup after 2s.
                       V.0.14 NH9 — clear localStorage draft on success (S8). */
                    try {
                        var draftKey = 'dnc_sn_activate_draft_' + (new URLSearchParams(window.location.search)).get('sn');
                        localStorage.removeItem(draftKey);
                    } catch (e) {}
                    var confettiHtml = '';
                    var colors = ['#06C755', '#f59e0b', '#dc2626', '#3b82f6', '#a855f7', '#ec4899'];
                    for (var ci = 0; ci < 24; ci++) {
                        var color = colors[ci % colors.length];
                        var leftPct = Math.random() * 100;
                        var delayMs = Math.floor(Math.random() * 500);
                        var rotateDeg = Math.floor(Math.random() * 360);
                        confettiHtml += '<span class="dnc-sn-confetti" style="left:' + leftPct + '%;background:' + color + ';animation-delay:' + delayMs + 'ms;transform:rotate(' + rotateDeg + 'deg);"></span>';
                    }
                    document.querySelector('.dnc-sn-card').innerHTML =
                        '<div style="text-align:center;padding:30px;position:relative;overflow:hidden;" role="status" aria-live="polite">' +
                        '<div class="dnc-sn-confetti-container" aria-hidden="true">' + confettiHtml + '</div>' +
                        '<div style="font-size:64px;position:relative;z-index:2;" aria-hidden="true">🎉</div>' +
                        '<h2 style="position:relative;z-index:2;">ลงทะเบียนสำเร็จ!</h2>' +
                        '<p style="position:relative;z-index:2;">สินค้าของคุณได้รับประกันแล้ว</p>' +
                        '<p style="position:relative;z-index:2;">หมายเลข Warranty: WR-' + (res.body.warranty_id || '') + '</p>' +
                        '<a href="/dashboard" class="dnc-sn-btn dnc-sn-btn-primary" style="text-decoration:none;display:block;position:relative;z-index:2;" aria-label="ดู Dashboard">ดู Dashboard</a>' +
                        '</div>';
                    // Cleanup confetti after 2.5s (longest fall duration)
                    setTimeout(function() {
                        var c = document.querySelector('.dnc-sn-confetti-container');
                        if (c) c.remove();
                    }, 2500);
                } else {
                    btn.disabled = false;
                    btn.textContent = '✓ ลงทะเบียนรับประกัน';
                    var errMsg = (res.body && res.body.message) ? res.body.message : 'เกิดข้อผิดพลาด ลองใหม่อีกครั้ง';
                    if (statusEl) statusEl.textContent = 'เกิดข้อผิดพลาด: ' + errMsg;
                    alert(errMsg);
                }
            })
            .catch(function(err) {
                btn.disabled = false;
                btn.textContent = '✓ ลงทะเบียนรับประกัน';
                if (statusEl) statusEl.textContent = 'เกิดข้อผิดพลาดในการเชื่อมต่อ';
                alert('เกิดข้อผิดพลาด ลองใหม่อีกครั้ง');
            });
        });
        </script>
        <?php
    }
}

if ( ! function_exists( 'dinoco_sn_render_state_already_registered' ) ) {
    function dinoco_sn_render_state_already_registered( $sn, $data ) {
        /* V.0.14 (2026-05-08) Phase 8 S4 — Anti-Fraud Trust Signals.
           Before: customer scans plate that's registered to someone else →
           saw only "เพลทนี้ลงทะเบียนแล้ว" + ขอโอนสิทธิ์ button. No info about
           current owner + no warning that "if you just bought this NEW, this
           message means it's likely COUNTERFEIT or STOLEN".
           Now: render masked owner (first letter of first/last name) +
           registration date + red anti-fraud warning panel + dual CTA paths
           (legitimate transfer vs fraud report). */
        $is_owner_caller = ! empty( $data['warranty']['is_owned_by_caller'] );

        // Extract masked owner info if available + caller is NOT the owner
        $owner_masked = '';
        $registered_at_formatted = '';
        if ( ! $is_owner_caller ) {
            $owner_raw = isset( $data['warranty']['owner_masked'] ) ? (string) $data['warranty']['owner_masked'] : '';
            if ( $owner_raw !== '' ) {
                $owner_masked = $owner_raw;
            } elseif ( ! empty( $data['warranty']['registered_user_id'] ) ) {
                // Defensive fallback: build masked name from user object
                $u = get_userdata( (int) $data['warranty']['registered_user_id'] );
                if ( $u ) {
                    $first = trim( (string) $u->first_name );
                    $last  = trim( (string) $u->last_name );
                    if ( $first !== '' || $last !== '' ) {
                        $owner_masked = ( $first !== '' ? mb_substr( $first, 0, 1, 'UTF-8' ) . '***' : '' )
                                      . ( $first !== '' && $last !== '' ? ' ' : '' )
                                      . ( $last  !== '' ? mb_substr( $last,  0, 1, 'UTF-8' ) . '***' : '' );
                    }
                }
            }
            if ( ! empty( $data['warranty']['registered_at'] ) ) {
                $ts = strtotime( (string) $data['warranty']['registered_at'] );
                if ( $ts ) {
                    $registered_at_formatted = wp_date( 'j M Y', $ts );
                }
            }
        }
        ?>
        <div class="dnc-sn-card">
            <h2 style="text-align:center;">⚠️ ลงทะเบียนแล้ว</h2>
            <div class="dnc-sn-sn-display">S/N: <?php echo esc_html( $sn ); ?></div>
            <div class="dnc-sn-info-banner">
                <p>เพลทนี้ลงทะเบียนแล้ว</p>
                <?php if ( $is_owner_caller ) : ?>
                    <p><strong>คุณเป็นเจ้าของ — สามารถดูได้ใน Dashboard</strong></p>
                <?php else : ?>
                    <?php if ( $owner_masked !== '' || $registered_at_formatted !== '' ) : ?>
                        <div style="margin-top:10px;padding:10px 12px;background:#fff;border:1px solid #e5e7eb;border-radius:6px;font-size:13px;">
                            <?php if ( $owner_masked !== '' ) : ?>
                                <div>เจ้าของปัจจุบัน: <strong><?php echo esc_html( $owner_masked ); ?></strong></div>
                            <?php endif; ?>
                            <?php if ( $registered_at_formatted !== '' ) : ?>
                                <div style="color:#6b7280;font-size:12px;margin-top:2px;">ลงทะเบียนเมื่อ: <?php echo esc_html( $registered_at_formatted ); ?></div>
