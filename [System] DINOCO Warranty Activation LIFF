        function dncSnExtractSn(text) {
            // QR may be raw S/N or full URL (Round 3 format B)
            if (!text) return '';
            text = String(text).trim();
            // Try URL form first
            var m = text.match(/[?&]sn=([A-Za-z0-9]{8,16})/);
            if (m && m[1]) return m[1].toUpperCase();
            // Raw S/N
            text = text.toUpperCase();
            if (/^[A-Z0-9]{8,16}$/.test(text)) return text;
            return '';
        }

        function dncSnStartScan() {
