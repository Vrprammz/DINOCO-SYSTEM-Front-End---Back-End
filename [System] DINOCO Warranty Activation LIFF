if ( ! function_exists( 'dinoco_sn_render_line_fallback_script' ) ) {
    /**
     * V.0.7 F7 — LIFF in-app vs desktop browser detector.
     *
     * Renders a one-shot inline script that swaps `.dnc-sn-line-link` href
     * from `data-line-deep` (LIFF in-app preferred) to `data-line-fall`
     * (lin.ee short URL) when `liff.isInClient()` is false OR the LIFF SDK
     * is missing entirely (= plain desktop browser session).
     *
     * Idempotent — only registers once via `wp_footer` hook flag.
     */
    function dinoco_sn_render_line_fallback_script() {
        static $printed = false;
        if ( $printed ) return;
        $printed = true;
        ?>
        <script>
        (function() {
            // Run after DOM ready — links are static so DOMContentLoaded is enough.
            function applyLineFallback() {
                try {
                    var inLiff = (typeof liff !== 'undefined'
                        && typeof liff.isInClient === 'function'
                        && liff.isInClient());
                    if (inLiff) return; // LIFF in-app — keep deep link as-is
                    var links = document.querySelectorAll('.dnc-sn-line-link[data-line-fall]');
                    Array.prototype.forEach.call(links, function(a) {
                        var fall = a.getAttribute('data-line-fall');
                        if (fall) a.setAttribute('href', fall);
                    });
                } catch (e) { /* silent */ }
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', applyLineFallback);
            } else {
                applyLineFallback();
            }
        })();
        </script>
        <?php
    }
}
