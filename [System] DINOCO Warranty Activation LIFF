                        config,
                        function(decodedText) {
                            var sn = dncSnExtractSn(decodedText);
                            if (!sn) {
                                // Keep scanning — silently ignore non-SN QR codes
                                return;
                            }
                            // Success — haptic + redirect
                            if (navigator.vibrate) { try { navigator.vibrate(50); } catch(e){} }
                            dncSnStopScan();
                            window.location.href = window.location.pathname + '?sn=' + encodeURIComponent(sn);
                        },
                        function(/*errorMessage*/) {
                            // Per-frame errors are normal — don't alert
                        }
                    ).catch(function(err) {
                        var fn3 = (window.dinocoModal && window.dinocoModal.alert) ? window.dinocoModal.alert : function(o){alert((o.title||'')+'\n'+(o.message||''));};
                        fn3({ title: 'เปิดกล้องไม่สำเร็จ',
