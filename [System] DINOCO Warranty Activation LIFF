        function dncSnStopScan() {
            var btn = document.getElementById('dnc-sn-scan-btn');
            var viewport = document.getElementById('dnc-sn-scan-viewport');
            var hint = document.getElementById('dnc-sn-scan-hint');
            // V.0.12 R3 BUG-5 HOTFIX — capture local ref BEFORE nulling shared var.
            // V.0.11 bug: `_dncSnQrInstance = null` ran sync, then `.then(clear)` ran
            // async on null → TypeError unhandled rejection. Worse: if admin re-tapped
            // scan during await, stale .then would clear NEW instance.
            if (_dncSnQrInstance) {
                var inst = _dncSnQrInstance;
                _dncSnQrInstance = null;
                try {
                    inst.stop().then(function() {
                        try { inst.clear(); } catch(_) {}
                    }).catch(function() { /* ignore — instance may be stopped */ });
                } catch (e) {
                    try { inst.clear(); } catch(_) {}
                }
            }
            if (viewport) viewport.style.display = 'none';
            if (hint) hint.style.display = 'none';
            if (btn) {
                btn.style.display = '';
                btn.disabled = false;
                btn.textContent = '📷 สแกน QR';
