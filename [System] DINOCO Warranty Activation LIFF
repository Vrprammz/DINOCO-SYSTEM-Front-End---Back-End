if ( ! function_exists( 'dinoco_sn_render_activate_form' ) ) {
    function dinoco_sn_render_activate_form( $sn ) {
        // Lookup plate via REST
        $rest_url = rest_url( 'dinoco-sn/v1/lookup/' . urlencode( $sn ) );
        $response = wp_remote_get( $rest_url, array( 'timeout' => 5 ) );

        if ( is_wp_error( $response ) ) {
            dinoco_sn_render_activate_error( 'lookup_failed', 'ไม่สามารถดึงข้อมูล S/N ได้ ลองอีกครั้ง' );
            return;
        }

        $code = wp_remote_retrieve_response_code( $response );
        $body = json_decode( wp_remote_retrieve_body( $response ), true );

        if ( $code === 404 ) {
            dinoco_sn_render_activate_error( 'sn_not_found', 'ไม่พบ S/N นี้ในระบบ' );
            return;
        }

        if ( $code === 410 ) {
            dinoco_sn_render_activate_error( 'voided', 'เพลทถูกยกเลิก กรุณาทิ้งทันที' );
            return;
        }

        if ( ! is_array( $body ) ) {
            dinoco_sn_render_activate_error( 'system_error', 'ระบบขัดข้อง กรุณาลองใหม่' );
            return;
        }

        $status = $body['status'] ?? '';
        $linked_sku = $body['product']['linked_sku'] ?? '';
        $top_set = $body['product']['top_set_sku'] ?? $linked_sku;

        // State D: Already registered
        if ( in_array( $status, array( 'registered', 'claimed', 'transferred' ), true ) ) {
            dinoco_sn_render_state_already_registered( $sn, $body );
            return;
        }

        // State E: Not in_pool yet (still reserved/sent_to_factory etc.)
        if ( $status !== 'in_pool' && $status !== 'shipped_legacy' ) {
            dinoco_sn_render_state_not_yet_shipped( $sn, $status );
            return;
        }

        // State A/B: Ready to activate
        ?>
        <div class="dnc-sn-card">
            <h2 style="text-align:center;">🛡 ลงทะเบียนรับประกัน</h2>

            <?php if ( $linked_sku ) : ?>
                <?php
                // Try fetch product image (defensive — function from Inventory snippet)
                $img_url = '';
                if ( class_exists( 'DINOCO_Catalog' ) && method_exists( 'DINOCO_Catalog', 'get_by_sku' ) ) {
                    $product = DINOCO_Catalog::get_by_sku( $top_set ?: $linked_sku );
                    if ( $product && ! empty( $product->image_url ) ) {
                        $img_url = $product->image_url;
                    }
                }
                ?>
                <?php if ( $img_url ) : ?>
                    <img src="<?php echo esc_url( $img_url ); ?>"
                         class="dnc-sn-product-image" alt="">
                <?php endif; ?>
                <p class="dnc-sn-product-name">
                    <?php
                    $product_name = '';
                    if ( isset( $product ) && $product ) {
                        $product_name = $product->name ?? '';
                    }
                    echo esc_html( $product_name ?: $top_set );
                    ?>
                </p>
            <?php endif; ?>

            <div class="dnc-sn-sn-display">
                S/N: <?php echo esc_html( $sn ); ?>
            </div>
            <p style="text-align:center;">
                <span class="dnc-sn-status-badge dnc-sn-status-in-pool">🟢 พร้อมลงทะเบียน</span>
            </p>

            <?php if ( ! is_user_logged_in() ) : ?>
                <?php
                // V.0.3 — Boss 2026-05-07: First-time login flow — proper LINE OAuth
                // with WARRANTY_ACTIVATE_SN intent. Customer scans QR with phone
                // camera (URL format B) → lands here → not logged in → OAuth →
                // LINE Callback V.30.9 redirects back to /warranty/activate?sn=...
                //
                // Why not wp_login_url(): generic WP login doesn't preserve sn
                // through LINE OAuth round-trip. State-token system stores intent
                // server-side (10min transient) — survives redirect_uri rewrite.
                $line_ch_id     = defined( 'DINOCO_LINE_CHANNEL_ID' )   ? DINOCO_LINE_CHANNEL_ID   : get_option( 'dinoco_line_channel_id', '' );
                $line_redir_uri = defined( 'DINOCO_LINE_REDIRECT_URI' ) ? DINOCO_LINE_REDIRECT_URI : get_option( 'dinoco_line_redirect_uri', 'https://www.dinoco.in.th/callback-login' );

                $line_login_url = '';
                if ( ! empty( $line_ch_id ) && ! empty( $line_redir_uri ) ) {
                    $state_token = wp_generate_password( 32, false, false );
                    set_transient(
                        'dinoco_line_state_' . $state_token,
                        array(
                            'serial'  => $sn,
                            'intent'  => 'WARRANTY_ACTIVATE_SN',  // V.30.9 callback handler
                            'created' => time(),
                        ),
                        600  // 10 min — covers slow LINE OAuth on weak networks
                    );

                    $line_login_url = 'https://access.line.me/oauth2/v2.1/authorize';
                    $line_login_url .= '?response_type=code';
                    $line_login_url .= '&client_id=' . urlencode( $line_ch_id );
                    $line_login_url .= '&redirect_uri=' . urlencode( $line_redir_uri );
                    $line_login_url .= '&state=' . urlencode( $state_token );
                    $line_login_url .= '&scope=profile%20openid';
                    $line_login_url .= '&bot_prompt=aggressive';
                }
                ?>
                <div class="dnc-sn-info-banner">
                    <p style="margin:0 0 8px;font-weight:600;color:#1f2937;">📱 ลงทะเบียนด้วย LINE</p>
                    <p style="margin:0;font-size:13px;color:#4b5563;line-height:1.6;">
                        ครั้งแรกที่ใช้ระบบ ลูกค้าต้อง login ด้วย LINE
                        ก่อนลงทะเบียนรับประกัน — ระบบจะจำเข้ามาทุกครั้งหลังจากนี้
                    </p>
                </div>

                <?php if ( ! empty( $line_login_url ) ) : ?>
                    <a href="<?php echo esc_url( $line_login_url ); ?>"
                       class="dnc-sn-btn dnc-sn-btn-primary"
                       style="text-decoration:none;text-align:center;display:block;background:#06C755;color:#fff;padding:14px 20px;border-radius:12px;font-weight:600;font-size:16px;min-height:48px;">
