<script>
(function(){
var R='<?php echo esc_js($rest); ?>',N='<?php echo esc_js($nonce); ?>';
var distData=[],prodData=[],rl={standard:'⭐ Standard',silver:'🥈 Silver',gold:'🥇 Gold',platinum:'💎 Platinum',diamond:'💠 Diamond'};
document.querySelectorAll('.cp-tab').forEach(function(t){t.addEventListener('click',function(){
  document.querySelectorAll('.cp-tab').forEach(function(x){x.classList.remove('active')});
  document.querySelectorAll('.cp-panel').forEach(function(x){x.classList.remove('active')});
  this.classList.add('active');document.getElementById('panel-'+this.dataset.tab).classList.add('active');
})});
function api(m,ep,body,cb){var o={method:m,headers:{'X-WP-Nonce':N,'Content-Type':'application/json'}};if(body)o.body=JSON.stringify(body);fetch(R+ep,o).then(function(r){if(!r.ok)return r.text().then(function(t){var msg='HTTP '+r.status;try{var j=JSON.parse(t);msg=j.message||j.code||msg}catch(x){}throw new Error(msg)});return r.json()}).then(function(d){if(d&&!d.success&&d.message)toast(d.message,'e');cb(d)}).catch(function(e){toast(e.message,'e')})}
function toast(msg,t){var el=document.getElementById('cpToast');el.textContent=(t==='s'?'✓ ':'⚠ ')+msg;el.className='cp-toast '+(t||'s')+' show';setTimeout(function(){el.classList.remove('show')},3000)}
function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}
function fmt(n){return Number(n||0).toLocaleString()}
// (dirty-check removed — ใช้ inline onclick แทน)
window.closeModal=function(id){var el=document.getElementById(id);if(el){el.classList.remove('open');document.body.style.overflow=''}};
// openModal: move element to document.body before showing — fixes
// position:fixed being trapped by Dashboard's overflow:hidden + transform
// Also binds event delegation for buttons inside (inline onclick breaks after appendChild)
window.openModal=function(id){
  var el=document.getElementById(id);if(!el)return;
  if(el.parentNode!==document.body){
    // Clone เพื่อลบ event listener เก่าจาก sync ก่อนหน้าทั้งหมด
    var clone=el.cloneNode(true);
    if(el.parentNode)el.parentNode.removeChild(el);
    document.body.appendChild(clone);
    clone.addEventListener('click',function(e){if(e.target===clone)closeModal(id)});
  }
  var modal=document.getElementById(id);
  if(modal){modal.classList.add('open');document.body.style.overflow='hidden'}
}
window.showConfirm=function(title,msg,cb){
  var dlg=document.getElementById('confirmDlg');
  if(dlg&&dlg.parentNode!==document.body){
    document.body.appendChild(dlg);
    dlg.addEventListener('click',function(e){if(e.target===dlg)dlg.classList.remove('open')});
    dlg.addEventListener('click',function(e){
      var btn=e.target.closest('button');if(!btn)return;
      var t=btn.textContent||'';
      if(t.indexOf('ยกเลิก')>-1){closeConfirm();return}
      if(t.indexOf('ลบ')>-1||btn.id==='confirmOk'){if(confirmCb)confirmCb();closeConfirm()}
    });
  }
  document.getElementById('confirmTitle').textContent=title;document.getElementById('confirmMsg').textContent=msg;confirmCb=cb;dlg.classList.add('open');
};
var confirmCb=null;
window.closeConfirm=function(){document.getElementById('confirmDlg').classList.remove('open');confirmCb=null;document.body.style.overflow=''};

/* ═══ DISTRIBUTORS ═══ */
function loadDists(){api('GET','distributors',null,function(d){
  if(!d.success)return;distData=d.distributors;
  var totalDebt=0,holdCount=0;d.distributors.forEach(function(x){totalDebt+=x.current_debt;if(x.credit_hold)holdCount++});
  document.getElementById('distStats').innerHTML='<div class="stat-chip"><span class="stat-chip-label">ตัวแทน</span><span class="stat-chip-val">'+d.distributors.length+'</span></div>'
    +'<div class="stat-chip"><span class="stat-chip-label">ยอดหนี้รวม</span><span class="stat-chip-val" style="color:var(--danger)">฿'+fmt(totalDebt)+'</span></div>'
    +'<div class="stat-chip"><span class="stat-chip-label">Credit Hold</span><span class="stat-chip-val" style="color:'+(holdCount?'var(--danger)':'var(--success)')+'">'+holdCount+'</span></div>';
  renderDists(d.distributors);
})}
function renderDists(list){
  var h='';list.forEach(function(x){
    h+='<tr><td style="font-weight:600;color:var(--text-3)">#'+x.id+'</td>';
    h+='<td><div style="font-weight:600">'+esc(x.shop_name)+'</div></td>';
    h+='<td style="font-family:var(--mono);font-size:11px;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text-3)" title="'+esc(x.line_group_id)+'">'+esc(x.line_group_id||'—')+'</td>';
    h+='<td style="text-align:center"><span class="badge badge-neutral">'+(rl[x.rank_system]||x.rank_system)+'</span></td>';
    h+='<td style="text-align:right;font-weight:500">฿'+fmt(x.credit_limit)+'</td>';
    h+='<td style="text-align:right;font-weight:600;color:'+(x.current_debt>0?'var(--danger)':'var(--success)')+'">฿'+fmt(x.current_debt)+'</td>';
    h+='<td style="text-align:center">'+(x.credit_hold?'<span class="badge badge-fail"><span class="badge-dot badge-dot-fail"></span>Hold</span>':'<span class="badge badge-ok"><span class="badge-dot badge-dot-ok"></span>ปกติ</span>')+'</td>';
    // V.26: bot_enabled toggle
    h+='<td style="text-align:center"><label class="bot-toggle" title="'+(x.bot_enabled?'Bot เปิดใช้งาน':'Bot ปิดอยู่')+'"><input type="checkbox" '+(x.bot_enabled?'checked':'')+' data-act="toggleBot" data-id="'+x.id+'"><span class="bot-slider"></span></label></td>';
