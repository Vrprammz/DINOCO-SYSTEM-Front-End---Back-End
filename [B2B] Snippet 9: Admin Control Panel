window._setChildren=[];
function findProdBySku(sku){return prodData.find(function(x){return x.product_sku.toUpperCase()===sku.toUpperCase()})}
function renderSetChildren(){
  var list=document.getElementById('pf_children_list'),count=document.getElementById('pf_children_count');
  var children=window._setChildren||[];
  count.textContent=children.length?'('+children.length+' รายการ)':'';
  if(!children.length){list.innerHTML='<div class="set-empty">ยังไม่มีสินค้าลูกในชุด — ค้นหาด้านล่างเพื่อเพิ่ม</div>';return}
  var h='';children.forEach(function(sku,i){
    var p=findProdBySku(sku);var name=p?p.title:sku;var img=p?p.img:'';var price=p?p.catalog_price:0;
    h+='<div class="set-child-card" data-idx="'+i+'">';
    h+=img?'<img class="set-img" src="'+esc(img)+'" alt="">':'<div class="set-img-placeholder">📦</div>';
    h+='<div class="set-info"><div class="set-sku">'+esc(sku)+'</div><div class="set-name">'+esc(name)+'</div>';
    if(price>0)h+='<div class="set-price">฿'+fmt(price)+'</div>';
    h+='</div><button class="set-remove" data-rm="'+i+'" title="นำออกจากชุด">✕</button></div>';
  });
  list.innerHTML=h;
  list.querySelectorAll('.set-remove').forEach(function(btn){
    btn.addEventListener('click',function(e){e.preventDefault();
      var idx=parseInt(this.dataset.rm);window._setChildren.splice(idx,1);renderSetChildren()})
  });
}
function showSetDropdown(q){
  var dd=document.getElementById('pf_children_dropdown'),currentSku=(document.getElementById('pf_sku').value||'').toUpperCase();
  var selected=window._setChildren.map(function(s){return s.toUpperCase()});
  var matches=prodData.filter(function(x){
    if(x.product_sku.toUpperCase()===currentSku)return false;
    var term=q.toLowerCase();
    return x.product_sku.toLowerCase().indexOf(term)>-1||x.title.toLowerCase().indexOf(term)>-1||(x.product_category||'').toLowerCase().indexOf(term)>-1;
  }).slice(0,8);
  if(!matches.length){dd.innerHTML='<div class="set-no-result">ไม่พบสินค้า "'+esc(q)+'"</div>';dd.style.display='block';return}
  var h='';matches.forEach(function(x){
    var added=selected.indexOf(x.product_sku.toUpperCase())>-1;
    h+='<div class="set-dropdown-item'+(added?' added':'')+'" data-sku="'+esc(x.product_sku)+'">';
    h+=x.img?'<img class="sdi-img" src="'+esc(x.img)+'" alt="">':'<div class="sdi-placeholder">📦</div>';
    h+='<div class="sdi-info"><div class="sdi-sku">'+esc(x.product_sku)+'</div><div class="sdi-name">'+esc(x.title)+'</div>';
    if(x.catalog_price>0)h+='<div class="sdi-price">฿'+fmt(x.catalog_price)+'</div>';
    h+='</div>';
    if(added)h+='<div class="sdi-added">เพิ่มแล้ว ✓</div>';
    h+='</div>';
  });
  dd.innerHTML=h;dd.style.display='block';
  dd.querySelectorAll('.set-dropdown-item').forEach(function(item){
    item.addEventListener('click',function(){
      var sku=this.dataset.sku.toUpperCase();
      if(window._setChildren.map(function(s){return s.toUpperCase()}).indexOf(sku)>-1){
        window._setChildren=window._setChildren.filter(function(s){return s.toUpperCase()!==sku});
      }else{window._setChildren.push(this.dataset.sku)}
      renderSetChildren();document.getElementById('pf_children_search').value='';hideSetDropdown();
      document.getElementById('pf_children_search').focus();
    })
  });
}
function hideSetDropdown(){document.getElementById('pf_children_dropdown').style.display='none'}
(function(){
  var searchEl=document.getElementById('pf_children_search'),timer=null;
  searchEl.addEventListener('input',function(){var q=this.value.trim();clearTimeout(timer);
    if(q.length<1){hideSetDropdown();return}timer=setTimeout(function(){showSetDropdown(q)},150)});
  searchEl.addEventListener('focus',function(){var q=this.value.trim();if(q.length>=1)showSetDropdown(q)});
  searchEl.addEventListener('keydown',function(e){
    if(e.key==='Escape'){hideSetDropdown();this.blur()}
    if(e.key==='Enter'){e.preventDefault();var first=document.querySelector('#pf_children_dropdown .set-dropdown-item:not(.added)');if(first)first.click()}
  });
  document.addEventListener('click',function(e){if(!e.target.closest('#pf_children_section'))hideSetDropdown()});
})();
