function refreshCatDropdown(selected){
  var sel=document.getElementById('pf_cat');
  var cats={};prodData.forEach(function(x){var c=x.product_category||x.sub||'';if(c)cats[c]=1});
  var saved=JSON.parse(localStorage.getItem('b2b_custom_cats')||'[]');
  saved.forEach(function(c){if(c)cats[c]=1});
  var sorted=Object.keys(cats).sort();
  sel.innerHTML='<option value="">— เลือกหมวดหมู่ —</option>';
  sorted.forEach(function(c){var o=document.createElement('option');o.value=c;o.textContent=c;sel.appendChild(o)});
  if(selected){
    var found=false;for(var i=0;i<sel.options.length;i++){if(sel.options[i].value===selected){sel.selectedIndex=i;found=true;break}}
    if(!found&&selected){var o=document.createElement('option');o.value=selected;o.textContent=selected;sel.appendChild(o);sel.value=selected}
  }
}
