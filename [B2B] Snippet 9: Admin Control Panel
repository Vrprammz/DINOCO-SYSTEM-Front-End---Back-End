/**
 * Run a specific step of the Flash flow for testing
 */
function b2b_rest_flash_test_run_step( WP_REST_Request $req ) {
    try {
    $tid = intval($req->get_param('ticket_id'));
    $step = sanitize_text_field($req->get_param('step'));
    if (!$tid || get_post_type($tid) !== 'b2b_order')
        return new WP_REST_Response(array('success'=>false,'message'=>'Invalid ticket'),400);

    $log = array();

    switch ($step) {
        case 'check_address':
            // Validate distributor address completeness
            $fields = array('dist_name','dist_phone','dist_address','dist_district','dist_city','dist_province','dist_postcode');
            $missing = array(); $values = array();
            foreach ($fields as $f) {
                $v = get_field($f, $tid) ?: '';
                $values[$f] = $v;
                if (empty($v)) $missing[] = $f;
            }
            $wh = get_option('b2b_warehouse_address', array());
            $wh_missing = array();
            foreach (array('wh_name','wh_phone','wh_address','wh_district','wh_city','wh_province','wh_postcode') as $wf) {
                if (empty($wh[$wf])) $wh_missing[] = $wf;
            }
            return new WP_REST_Response(array(
                'success'=>empty($missing) && empty($wh_missing),
                'message'=>empty($missing) && empty($wh_missing) ? 'ที่อยู่ครบถ้วน' : 'ขาดข้อมูล',
                'dst'=>$values, 'dst_missing'=>$missing,
                'wh'=>$wh, 'wh_missing'=>$wh_missing,
            ),200);

        case 'flash_create':
            // Create Flash shipment via real API
            if (!function_exists('b2b_flash_create_all_boxes'))
                return new WP_REST_Response(array('success'=>false,'message'=>'S1 not loaded'),200);
            $result = b2b_flash_create_all_boxes($tid);
            if ($result['ok'] && function_exists('b2b_enqueue_print_job')) {
                // Skip actual print queue in test — just mark status
                update_post_meta($tid, '_flash_packing_status', 'print_done');
                $log[] = 'Print step skipped (RPi offline) — marked as print_done';
            }
            return new WP_REST_Response(array(
                'success'=>$result['ok'],
                'message'=>$result['ok'] ? 'สร้างพัสดุสำเร็จ' : ($result['error'] ?? 'Error'),
                'data'=>$result, 'log'=>$log,
            ),200);

        case 'download_label':
            // Legacy — kept for backward compat, just check label
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            if (empty($pnos))
                return new WP_REST_Response(array('success'=>false,'message'=>'No tracking numbers'),200);
            if (!function_exists('b2b_flash_get_label_pdf'))
                return new WP_REST_Response(array('success'=>false,'message'=>'S1 not loaded'),200);
            $result = b2b_flash_get_label_pdf($pnos[0]);
            return new WP_REST_Response(array(
                'success'=>!empty($result['ok']),
                'message'=>!empty($result['ok']) ? 'Label PDF ready ('.strlen($result['pdf']).' bytes)' : ($result['error'] ?? 'Error'),
                'pno'=>$pnos[0],
            ),200);

        case 'scan_qr':
            // Simulate QR scan: verify print is done, then auto-trigger ready_to_ship + courier call
            $packing = get_post_meta($tid, '_flash_packing_status', true);
            $print_st = get_field('print_status', $tid) ?: 'none';
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            if (empty($pnos))
                return new WP_REST_Response(array('success'=>false,'message'=>'ยังไม่มี tracking — ต้องสร้างพัสดุก่อน'),200);
            // In test mode, allow even if not print_done (RPi may not have acked)
            if (!in_array($packing, array('flash_created','print_queued','print_done','notify_error'), true)) {
                $packing_label = function_exists('b2b_flash_packing_label') ? b2b_flash_packing_label($packing) : $packing;
                return new WP_REST_Response(array('success'=>false,'message'=>'สถานะ: '.$packing_label.' — ไม่สามารถ scan ได้'),200);
            }
            // Mark ready_to_ship
            update_post_meta($tid, '_flash_packing_status', 'ready_to_ship');
            // Call courier
            if (!function_exists('b2b_flash_notify_courier_from_warehouse'))
                return new WP_REST_Response(array('success'=>true,'message'=>'QR Scan OK — แต่ไม่พบ courier function (S1 not loaded)'),200);
            $courier = b2b_flash_notify_courier_from_warehouse(count($pnos), 'QR Scan: #'.$tid);
            if (!empty($courier['ok']) && !empty($courier['data'])) {
                $cd = $courier['data'];
                update_post_meta($tid, '_flash_packing_status', 'courier_called');
                if (!empty($cd['ticketPickupId'])) update_post_meta($tid, '_flash_pickup_id', $cd['ticketPickupId']);
                return new WP_REST_Response(array('success'=>true,'message'=>'📱 QR Scan → แพ็คเสร็จ → เรียกรถสำเร็จ!','courier'=>$cd),200);
            }
            update_post_meta($tid, '_flash_packing_status', 'notify_error');
            return new WP_REST_Response(array('success'=>false,'message'=>'QR Scan OK แต่เรียกรถไม่สำเร็จ: '.($courier['error']??'Unknown'),'data'=>$courier),200);

        case 'ready_to_ship':
            // Mark ready + notify courier
            $packing = get_post_meta($tid, '_flash_packing_status', true);
            if (!in_array($packing, array('flash_created','print_queued','print_done','notify_error'), true)) {
                $packing_label = function_exists('b2b_flash_packing_label') ? b2b_flash_packing_label($packing) : $packing;
                $hint = '';
                if (in_array($packing, array('courier_called','ready_to_ship','picked_up','in_transit','delivering','delivered'), true)) {
                    $hint = ' (เรียกรถไปแล้ว ไม่ต้องเรียกซ้ำ)';
                }
                return new WP_REST_Response(array('success'=>false,'message'=>'สถานะปัจจุบัน: '.$packing_label.$hint.' — ไม่สามารถเรียกรถได้ (status: '.$packing.')'),200);
            }
            update_post_meta($tid, '_flash_packing_status', 'ready_to_ship');
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            if (!function_exists('b2b_flash_notify_courier_from_warehouse'))
                return new WP_REST_Response(array('success'=>false,'message'=>'S1 not loaded'),200);
            $courier = b2b_flash_notify_courier_from_warehouse(count($pnos), 'Test: #'.$tid);
            if (!empty($courier['ok']) && !empty($courier['data'])) {
                $cd = $courier['data'];
                update_post_meta($tid, '_flash_packing_status', 'courier_called');
                if (!empty($cd['ticketPickupId'])) update_post_meta($tid, '_flash_pickup_id', $cd['ticketPickupId']);
                return new WP_REST_Response(array('success'=>true,'message'=>'เรียกรถสำเร็จ','courier'=>$cd),200);
            }
            update_post_meta($tid, '_flash_packing_status', 'notify_error');
            return new WP_REST_Response(array('success'=>false,'message'=>'เรียกรถไม่สำเร็จ: '.($courier['error']??'Unknown'),'data'=>$courier),200);

        case 'cancel':
            // Cancel ALL Flash orders for this ticket
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            if (empty($pnos))
                return new WP_REST_Response(array('success'=>false,'message'=>'No tracking numbers to cancel'),200);
            $results = array();
            foreach ($pnos as $pno) {
                $r = function_exists('b2b_flash_cancel_order') ? b2b_flash_cancel_order($pno) : array('ok'=>false,'error'=>'S1 not loaded');
                $results[$pno] = $r;
            }
            // V.36: Update per-PNO statuses
            $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
            if (is_array($pno_statuses)) {
                foreach ($pno_statuses as $_p => &$_info) {
                    if (is_array($_info)) $_info['status'] = 'cancelled';
                }
                unset($_info);
                update_post_meta($tid, '_flash_pno_statuses', $pno_statuses);
            }
            delete_post_meta($tid, '_flash_tracking_numbers');
            update_field('tracking_number', '', $tid);
            update_post_meta($tid, '_flash_packing_status', 'none');
            update_post_meta($tid, '_flash_status', 'cancelled');
            return new WP_REST_Response(array('success'=>true,'message'=>'ยกเลิก '.count($pnos).' tracking','results'=>$results),200);

        case 'cancel_pno':
            // V.36: Cancel single PNO (partial cancel)
            $target_pno = $req->get_param('pno');
            if (empty($target_pno))
                return new WP_REST_Response(array('success'=>false,'message'=>'Missing pno parameter'),400);
            $r = function_exists('b2b_flash_cancel_order') ? b2b_flash_cancel_order($target_pno) : array('ok'=>false,'error'=>'S1 not loaded');
            if (!$r['ok'])
                return new WP_REST_Response(array('success'=>false,'message'=>'Flash cancel failed: '.($r['error']??'Unknown'),'data'=>$r),200);
            // Update per-PNO status
            $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
            if (is_array($pno_statuses) && isset($pno_statuses[$target_pno])) {
                $pno_statuses[$target_pno]['status'] = 'cancelled';
                update_post_meta($tid, '_flash_pno_statuses', $pno_statuses);
            }
            // Remove from tracking numbers array
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            $pnos = array_values(array_filter($pnos, function($p) use ($target_pno) { return $p !== $target_pno; }));
            update_post_meta($tid, '_flash_tracking_numbers', $pnos);
            update_field('tracking_number', implode(', ', $pnos), $tid);
            // Update aggregate status
            if (is_array($pno_statuses) && function_exists('b2b_flash_aggregate_status')) {
                $agg = b2b_flash_aggregate_status($pno_statuses);
                update_post_meta($tid, '_flash_status', $agg);
                update_post_meta($tid, '_flash_packing_status', $agg);
            }
            $box_info = is_array($pno_statuses) && isset($pno_statuses[$target_pno]) ? $pno_statuses[$target_pno] : array();
            $box_label = isset($box_info['box']) ? $box_info['box'] : '';
            $box_name = isset($box_info['name']) ? $box_info['name'] : '';
            return new WP_REST_Response(array('success'=>true,'message'=>'ยกเลิก PNO '.$target_pno.' ('.$box_label.' '.$box_name.')','remaining'=>count($pnos)),200);

        case 'hold_pno':
            // V.38: Hold PNO — cancel at Flash but mark as hold_pending (not cancelled)
            $target_pno = $req->get_param('target_pno') ?: $req->get_param('pno');
            if (empty($target_pno))
                return new WP_REST_Response(array('success'=>false,'message'=>'Missing target_pno'),400);
            $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
            if (!is_array($pno_statuses) || !isset($pno_statuses[$target_pno]))
                return new WP_REST_Response(array('success'=>false,'message'=>'PNO not found in ticket'),404);
            $old_info = $pno_statuses[$target_pno];
            $old_status = is_array($old_info) ? ($old_info['status'] ?? 'created') : 'created';
            if ($old_status !== 'created')
                return new WP_REST_Response(array('success'=>false,'message'=>'Hold ได้เฉพาะกล่องที่ status = created (ปัจจุบัน: '.$old_status.')'),400);
            // Cancel PNO at Flash
            $r = function_exists('b2b_flash_cancel_order') ? b2b_flash_cancel_order($target_pno) : array('ok'=>false,'error'=>'S1 not loaded');
            if (!$r['ok'])
                return new WP_REST_Response(array('success'=>false,'message'=>'Flash cancel failed: '.($r['error']??'Unknown'),'data'=>$r),200);
            // Mark as hold_pending (not cancelled — can reship later)
            $pno_statuses[$target_pno]['status'] = 'hold_pending';
            update_post_meta($tid, '_flash_pno_statuses', $pno_statuses);
            // Remove from active tracking
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            $pnos = array_values(array_filter($pnos, function($p) use ($target_pno) { return $p !== $target_pno; }));
            update_post_meta($tid, '_flash_tracking_numbers', $pnos);
            update_field('tracking_number', implode(', ', $pnos), $tid);
            $box_label = is_array($old_info) ? ($old_info['box'] ?? '') : '';
            $box_name = is_array($old_info) ? ($old_info['name'] ?? '') : '';
            b2b_add_audit_log($tid, 'hold_pno', 'Hold กล่อง '.$box_label.' ('.$box_name.') PNO '.$target_pno.' ไว้ส่งรอบถัดไป');
            if (function_exists('b2b_push_to_admin')) {
                $dist = get_field('dist_name', $tid) ?: '';
                b2b_push_to_admin('⏸ Hold กล่อง '.$box_label.' #'.$tid.' '.$dist.' — '.$box_name.' (PNO '.$target_pno.' ยกเลิกแล้ว รอสร้างใหม่)');
            }
            return new WP_REST_Response(array('success'=>true,'message'=>'⏸ Hold กล่อง '.$box_label.' '.$box_name.' สำเร็จ — รอ Reship ส่งรอบถัดไป'),200);

        case 'reship_pno':
            // V.37: Re-ship cancelled/hold PNO — create new PNO for same box + print label
            $target_pno = $req->get_param('target_pno');
            if (empty($target_pno))
                return new WP_REST_Response(array('success'=>false,'message'=>'Missing target_pno'),400);
            $pno_statuses = get_post_meta($tid, '_flash_pno_statuses', true);
            if (!is_array($pno_statuses) || !isset($pno_statuses[$target_pno]))
                return new WP_REST_Response(array('success'=>false,'message'=>'PNO not found in ticket'),404);
            $old_info = $pno_statuses[$target_pno];
            $old_status = is_array($old_info) ? ($old_info['status'] ?? 'created') : 'created';
            if (!in_array($old_status, array('cancelled','hold_pending'), true))
                return new WP_REST_Response(array('success'=>false,'message'=>'PNO status is '.$old_status.' — ไม่ใช่ cancelled/hold'),400);
            // Get box info from old PNO
            $box_label = is_array($old_info) ? ($old_info['box'] ?? '1/1') : '1/1';
            $box_parts = explode('/', $box_label);
            $box_num = intval($box_parts[0] ?? 1);
            $total_boxes_str = intval($box_parts[1] ?? 1);
            // Create new Flash order for this box
            if (!function_exists('b2b_flash_create_order'))
                return new WP_REST_Response(array('success'=>false,'message'=>'S1 not loaded'),200);
            $create_result = b2b_flash_create_order($tid, $box_num, $total_boxes_str);
            if (!$create_result['ok'])
                return new WP_REST_Response(array('success'=>false,'message'=>'Flash create failed: '.($create_result['error']??''),'data'=>$create_result),200);
            $new_pno = $create_result['pno'] ?? '';
            if (empty($new_pno))
                return new WP_REST_Response(array('success'=>false,'message'=>'No PNO returned from Flash'),200);
            // Update PNO statuses: keep old as cancelled, add new
            $pno_statuses[$new_pno] = array(
                'status' => 'created',
                'box' => $box_label,
                'sku' => is_array($old_info) ? ($old_info['sku'] ?? '') : '',
                'name' => is_array($old_info) ? ($old_info['name'] ?? '') : '',
                'children' => is_array($old_info) ? ($old_info['children'] ?? array()) : array(),
                'packed_at' => null,
            );
            update_post_meta($tid, '_flash_pno_statuses', $pno_statuses);
            // Add to tracking numbers
            $pnos = get_post_meta($tid, '_flash_tracking_numbers', true) ?: array();
            if (!in_array($new_pno, $pnos)) $pnos[] = $new_pno;
            update_post_meta($tid, '_flash_tracking_numbers', $pnos);
            update_field('tracking_number', implode(', ', $pnos), $tid);
            // Queue print for new label
            if (function_exists('b2b_enqueue_print_job')) {
                update_post_meta($tid, '_flash_packing_status', 'flash_created');
                b2b_enqueue_print_job($tid);
            }
            b2b_add_audit_log($tid, 'reship_pno', 'สร้าง PNO ใหม่ '.$new_pno.' แทน '.$target_pno.' (box '.$box_label.')');
            // Notify admin
            if (function_exists('b2b_push_to_admin')) {
                $dist = get_field('dist_name', $tid) ?: '';
                b2b_push_to_admin('📦 สร้าง PNO ใหม่ #'.$tid.' '.$dist.' — '.$new_pno.' (แทน '.$target_pno.' กล่อง '.$box_label.')');
            }
            return new WP_REST_Response(array('success'=>true,'message'=>'สร้าง PNO ใหม่สำเร็จ: '.$new_pno,'new_pno'=>$new_pno,'old_pno'=>$target_pno),200);

        default:
            return new WP_REST_Response(array('success'=>false,'message'=>'Unknown step: '.$step),400);
    }
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

