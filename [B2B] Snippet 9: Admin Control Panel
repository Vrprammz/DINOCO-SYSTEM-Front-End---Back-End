function b2b_rest_print_monitor( WP_REST_Request $req ) {
    try {
    $last_poll = intval(get_option('b2b_print_last_poll', 0));

    // Device info from heartbeat
    $device = get_option('b2b_print_device_info', array());
    $device_age = isset($device['timestamp']) ? (time() - $device['timestamp']) : -1;

    // Use heartbeat timestamp for online status (more reliable than poll timestamp)
    // Heartbeat sends every 25s, so 60s threshold allows 1 missed beat
    $hb_ts = isset($device['timestamp']) ? intval($device['timestamp']) : 0;
    $last_seen = max($last_poll, $hb_ts);
    $is_online = $last_seen > 0 && (time() - $last_seen) < 60;
    $poll_ago  = $last_seen > 0 ? (time() - $last_seen) : -1;

    // Current queue
    $queued = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>20,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'print_status','value'=>array('queued','printing'),'compare'=>'IN')),
        'orderby'=>'date','order'=>'ASC'));
    $queue_list = array();
    foreach ($queued as $o) {
        $gid = get_field('source_group_id', $o->ID) ?: '';
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '';
        $queue_list[] = array('id'=>$o->ID,'shop'=>$shop,'status'=>get_field('print_status',$o->ID),
            'boxes'=>intval(get_field('total_boxes',$o->ID)));
    }

    // Recent prints (done/error)
    $recent = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>20,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'print_status','value'=>array('done','error'),'compare'=>'IN')),
        'orderby'=>'modified','order'=>'DESC'));
    $recent_list = array();
    foreach ($recent as $o) {
        $gid = get_field('source_group_id', $o->ID) ?: '';
        $dist = $gid && function_exists('b2b_get_dist_by_group') ? b2b_get_dist_by_group($gid) : null;
        $shop = $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : '';
        $recent_list[] = array('id'=>$o->ID,'shop'=>$shop,'status'=>get_field('print_status',$o->ID),
            'error'=>get_field('print_error',$o->ID)?:'','timestamp'=>get_field('print_timestamp',$o->ID)?:'',
            'boxes'=>intval(get_field('total_boxes',$o->ID)));
    }

    // V.25: Command history + pending commands
    $cmd_history = get_option('b2b_rpi_command_history', array());
    $pending_cmds = get_option('b2b_rpi_pending_commands', array());

    return new WP_REST_Response(array('success'=>true,
        'rpi_online'=>$is_online,'poll_ago_sec'=>$poll_ago,
        'device'=>$device,'device_age_sec'=>$device_age,
        'queue'=>$queue_list,'recent'=>$recent_list,
        'cmd_history'=>array_slice($cmd_history, 0, 5),
        'pending_cmds'=>$pending_cmds), 200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

