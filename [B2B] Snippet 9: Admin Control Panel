      if(o.pickup_id)rh+='<br>Pickup ID: <code>'+esc(o.pickup_id)+'</code>';
      rh+='</div>';
    }
    document.getElementById('ftr_3').innerHTML=rh;
  }

  // Step 4: Ready to ship — show courier info if available
  if(courierDone.indexOf(fps)!==-1&&o.courier&&o.courier.staffInfoName){
    var rh='<div style="color:#16a34a">✅ เรียกรถสำเร็จ</div>';
    rh+='<div style="margin-top:4px;padding:6px 8px;background:#f0fdf4;border-radius:6px;font-size:11px">';
    rh+='🚛 <strong>'+esc(o.courier.staffInfoName)+'</strong> · 📞 '+esc(o.courier.staffInfoPhone||'');
    if(o.courier.timeoutAtText)rh+='<br>⏰ เข้ารับภายใน: '+esc(o.courier.timeoutAtText);
    if(o.pickup_id)rh+='<br>Pickup ID: <code>'+esc(o.pickup_id)+'</code>';
    rh+='</div>';
    document.getElementById('ftr_4').innerHTML=rh;
  }

  // Show weight/cost data if available from webhooks
  var simParts=[];
  if(o.weight&&o.weight.weight){
    simParts.push('⚖️ น้ำหนัก: '+o.weight.weight+'g'+(o.weight.length?' ('+o.weight.length+'×'+o.weight.width+'×'+o.weight.height+'cm)':''));
