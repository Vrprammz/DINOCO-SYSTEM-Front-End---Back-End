function b2b_rest_get_settings( WP_REST_Request $req ) {
    try {
    $editable = get_option('b2b_settings', array());
    $constants = array();
    $const_list = array('B2B_LINE_CHANNEL_SECRET','B2B_LINE_ACCESS_TOKEN','B2B_ADMIN_GROUP_ID','B2B_LIFF_ID','B2B_LIFF_URL','B2B_SLIP2GO_SECRET_KEY','B2B_FLASH_MCH_ID','B2B_FLASH_SECRET_KEY','B2B_FLASH_API_URL');
