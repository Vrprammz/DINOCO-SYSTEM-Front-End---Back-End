  if(courierDone.indexOf(fps)!==-1){
    var rh='<div style="color:#16a34a">✅ QR Scan → แพ็คเสร็จ → เรียกรถสำเร็จ</div>';
    if(o.courier&&o.courier.staffInfoName){
