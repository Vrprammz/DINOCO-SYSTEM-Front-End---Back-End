// ═══ V.10: Import CSV (A16) ═══
function b2b_rest_import_distributors( WP_REST_Request $req ) {
    try {
    $rows = $req->get_param('rows');
    if (!is_array($rows)||empty($rows)) return new WP_REST_Response(array('success'=>false,'message'=>'ไม่มีข้อมูล'),400);
    if (count($rows) > 500) return new WP_REST_Response(array('success'=>false,'message'=>'ข้อมูลเกินขีดจำกัด (สูงสุด 500 แถว)'),400);
    $imported = 0;
    foreach ($rows as $row) {
        $shop = sanitize_text_field($row['shop_name'] ?? '');
        $gid = sanitize_text_field($row['line_group_id'] ?? '');
        if (empty($shop)||empty($gid)) continue;
        $exists = get_posts(array('post_type'=>'distributor','posts_per_page'=>1,'meta_query'=>array(array('key'=>'line_group_id','value'=>$gid))));
        if (!empty($exists)) { $id = $exists[0]->ID; } else {
            $id = wp_insert_post(array('post_type'=>'distributor','post_title'=>$shop,'post_status'=>'publish'));
            if (is_wp_error($id)) continue;
        }
        update_field('shop_name',$shop,$id); update_field('line_group_id',$gid,$id);
        if (!empty($row['rank_system'])) update_field('rank_system',sanitize_text_field($row['rank_system']),$id);
        if (isset($row['credit_limit'])) update_field('credit_limit',floatval($row['credit_limit']),$id);
        if (isset($row['credit_term_days'])) update_field('credit_term_days',intval($row['credit_term_days']),$id);
        foreach (array('dist_phone','dist_province','dist_address','dist_district','dist_city','dist_postcode') as $af) {
            if (!empty($row[$af])) update_field($af,sanitize_text_field($row[$af]),$id);
        }
        $imported++;
    }
    return new WP_REST_Response(array('success'=>true,'imported'=>$imported),200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}
function b2b_rest_import_products( WP_REST_Request $req ) {
