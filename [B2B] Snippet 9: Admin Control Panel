        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}

// ═══ Products CRUD (V.7.4: rank prices) ═══
function b2b_rest_list_products( WP_REST_Request $req ) {
    try {
    $catalog=function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog',array());
    $b2b_posts=get_posts(array('post_type'=>'b2b_product','posts_per_page'=>-1,'post_status'=>'publish'));
    $bm=array();
    foreach($b2b_posts as $p){$sku=get_field('product_sku',$p->ID);if($sku){$bm[$sku]=array('post_id'=>$p->ID,'discount'=>floatval(get_field('b2b_discount_percent',$p->ID)),
        'min_order_qty'=>intval(get_field('min_order_qty',$p->ID)),'price_standard'=>floatval(get_field('price_standard',$p->ID)),
        'price_silver'=>floatval(get_field('price_silver',$p->ID)),'price_gold'=>floatval(get_field('price_gold',$p->ID)),
        'price_platinum'=>floatval(get_field('price_platinum',$p->ID)),'price_diamond'=>floatval(get_field('price_diamond',$p->ID)),
        'product_category'=>get_field('product_category',$p->ID)?:'','stock_status'=>get_field('stock_status',$p->ID)?:'in_stock',
        'oos_eta_date'=>get_field('oos_eta_date',$p->ID)?:'','oos_duration_hours'=>intval(get_field('oos_duration_hours',$p->ID)),
        'boxes_per_unit'=>max(1,intval(get_field('boxes_per_unit',$p->ID)?:1)));}}
    $sku_relations=get_option('dinoco_sku_relations',array());
    $list=array();
    foreach($catalog as $sku=>$item){$name=$item['name']??$sku;$img=$item['img']??'';$price=isset($item['price'])?b2b_parse_price($item['price']):0;$sub=$item['sub']??'';
        $b=$bm[$sku]??null;$disc=$b?$b['discount']:0;$dealer=$price>0?round($price*(1-$disc/100),2):0;
        $children=isset($sku_relations[$sku])&&is_array($sku_relations[$sku])?$sku_relations[$sku]:array();
        $list[]=array('product_sku'=>$sku,'title'=>$name,'img'=>$img,'catalog_price'=>$price,'sub'=>$sub,'discount_pct'=>$disc,'dealer_price'=>$dealer,
            'has_b2b_post'=>($b!==null),'b2b_post_id'=>$b?$b['post_id']:0,'stock_status'=>$b?$b['stock_status']:'in_stock',
            'product_category'=>$b?$b['product_category']:'','oos_eta_date'=>$b?$b['oos_eta_date']:'',
            'price_standard'=>$b?$b['price_standard']:0,'price_silver'=>$b?$b['price_silver']:0,'price_gold'=>$b?$b['price_gold']:0,
            'price_platinum'=>$b?$b['price_platinum']:0,'price_diamond'=>$b?$b['price_diamond']:0,
            'min_order_qty'=>$b?$b['min_order_qty']:1,'oos_duration_hours'=>$b?$b['oos_duration_hours']:0,
            'boxes_per_unit'=>$b?$b['boxes_per_unit']:1,'children'=>$children);}
    return new WP_REST_Response(array('success'=>true,'products'=>$list),200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}
function b2b_rest_save_product( WP_REST_Request $req ) {
    try {
    $id=intval($req->get_param('id'));$sku=strtoupper(sanitize_text_field($req->get_param('product_sku')));$title=sanitize_text_field($req->get_param('title'));
    if(empty($sku))return new WP_REST_Response(array('success'=>false,'message'=>'กรุณากรอก SKU'),400);
    if(!$id){$exists=get_posts(array('post_type'=>'b2b_product','posts_per_page'=>1,'meta_query'=>array(array('key'=>'product_sku','value'=>$sku))));
        if(!empty($exists))return new WP_REST_Response(array('success'=>false,'message'=>'SKU ซ้ำ'),400);
        $id=wp_insert_post(array('post_type'=>'b2b_product','post_title'=>$title.' ('.$sku.')','post_status'=>'publish'));if(is_wp_error($id))return new WP_REST_Response(array('success'=>false,'message'=>'สร้างไม่สำเร็จ'),500);
    }else{if(get_post_type($id)!=='b2b_product')return new WP_REST_Response(array('success'=>false,'message'=>'ID ไม่ถูกต้อง'),400);wp_update_post(array('ID'=>$id,'post_title'=>$title.' ('.$sku.')'));}
    foreach(array('product_sku','unit_of_measure','min_order_qty','b2b_discount_percent','price_standard','price_silver','price_gold','price_platinum','price_diamond','product_category','stock_status','oos_eta_date','oos_duration_hours','boxes_per_unit') as $f){
        $val=$req->get_param($f);if($val!==null){if(in_array($f,array('min_order_qty','oos_duration_hours','boxes_per_unit')))$val=max($f==='boxes_per_unit'?1:0,intval($val));elseif($f==='b2b_discount_percent')$val=max(0,min(100,floatval($val)));elseif(strpos($f,'price_')===0)$val=max(0,floatval($val));else $val=sanitize_text_field($val);update_field($f,$val,$id);}}
    if($req->get_param('stock_status')==='out_of_stock')update_field('oos_timestamp',time(),$id);
    // Save children (SET product) to dinoco_sku_relations
    $children_raw=$req->get_param('children');
    if($children_raw!==null){
        $relations=get_option('dinoco_sku_relations',array());
        if(!is_array($relations))$relations=array();
        if(is_string($children_raw))$children_arr=array_values(array_filter(array_map('trim',preg_split('/[\s,+]+/',$children_raw))));
        elseif(is_array($children_raw))$children_arr=array_values(array_filter(array_map(function($v){return strtoupper(trim(is_string($v)?$v:''));},$children_raw)));
        else $children_arr=array();
        $children_arr=array_map('strtoupper',$children_arr);
        if(!empty($children_arr))$relations[$sku]=$children_arr;
        else unset($relations[$sku]);
        update_option('dinoco_sku_relations',$relations);
        // Also update catalog sub field
        $catalog=function_exists('b2b_get_catalog') ? b2b_get_catalog() : get_option('dinoco_product_catalog',array());
        if(isset($catalog[$sku])){$catalog[$sku]['sub']=implode(' + ',$children_arr);update_option('dinoco_product_catalog',$catalog);
            // V.31: Sync to custom table
            if(class_exists('DINOCO_Catalog')){DINOCO_Catalog::upsert(array('sku'=>$sku,'subtitle'=>$catalog[$sku]['sub']));}
        }
    }
    return new WP_REST_Response(array('success'=>true,'id'=>$id,'message'=>'บันทึก "'.$title.'" สำเร็จ'),200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}
