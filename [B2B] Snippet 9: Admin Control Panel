// V.30.2: bot_enabled toggle — debounce guard ป้องกัน duplicate call
var _botToggleBusy={};
document.getElementById('distBody').addEventListener('change',function(e){
  var cb=e.target;if(!cb||cb.dataset.act!=='toggleBot')return;
  var id=parseInt(cb.dataset.id);
  if(_botToggleBusy[id]){e.preventDefault();return;}
  _botToggleBusy[id]=true;
  var val=cb.checked;
  cb.disabled=true;
  api('POST','distributor/toggle-bot',{dist_id:id,bot_enabled:val},function(r){
    cb.disabled=false;delete _botToggleBusy[id];
    if(r&&r.success){toast(r.message||('Bot '+(val?'เปิด':'ปิด')+'แล้ว'),'s');}
    else{toast((r&&r.message)||'เกิดข้อผิดพลาด','e');cb.checked=!val;}
  });
