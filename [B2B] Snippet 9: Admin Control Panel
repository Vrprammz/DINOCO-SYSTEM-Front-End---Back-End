// ═══ Distributors CRUD (V.9: +address +recommended_skus) ═══
function b2b_rest_list_distributors( WP_REST_Request $req ) {
    try {
    $posts = get_posts(array('post_type'=>'distributor','posts_per_page'=>-1,'post_status'=>'publish','orderby'=>'title','order'=>'ASC'));
    if (!empty($posts) && function_exists('update_post_meta_cache')) {
        update_post_meta_cache(wp_list_pluck($posts, 'ID'));
    }
    $list = array();
    foreach ($posts as $p) {
        $list[] = array('id'=>$p->ID,'shop_name'=>get_field('shop_name',$p->ID)?:get_the_title($p->ID),
            'line_group_id'=>get_field('line_group_id',$p->ID)?:'','rank_system'=>get_field('rank_system',$p->ID)?:'standard',
            'credit_limit'=>floatval(get_field('credit_limit',$p->ID)),'credit_term_days'=>intval(get_field('credit_term_days',$p->ID))?:30,
            'current_debt'=>function_exists('b2b_recalculate_debt') ? b2b_recalculate_debt($p->ID) : floatval(get_field('current_debt',$p->ID)),'credit_hold'=>(bool)get_field('credit_hold',$p->ID),
            'bot_enabled'=>metadata_exists('post',$p->ID,'bot_enabled') ? (bool)get_post_meta($p->ID,'bot_enabled',true) : true,
            // V.9: Address fields (C2-support for Flash API)
            'dist_phone'=>get_field('dist_phone',$p->ID)?:'',
            'dist_province'=>get_field('dist_province',$p->ID)?:'',
            'dist_address'=>get_field('dist_address',$p->ID)?:'',
            'dist_district'=>get_field('dist_district',$p->ID)?:'',
            'dist_city'=>get_field('dist_city',$p->ID)?:'',
            'dist_postcode'=>get_field('dist_postcode',$p->ID)?:'',
            // V.9: Recommended SKUs (F11)
            'recommended_skus'=>get_field('recommended_skus',$p->ID)?:'',
            'shop_logo_url'=>get_field('shop_logo_url',$p->ID)?:'',
        );
    }
    return new WP_REST_Response(array('success'=>true,'distributors'=>$list),200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}
function b2b_rest_save_distributor( WP_REST_Request $req ) {
    try {
    // get_param อาจไม่ parse JSON body ได้ทุกกรณี — ใช้ get_json_params เป็น fallback
    $body = $req->get_json_params();
    $id=intval($body['id'] ?? $req->get_param('id'));
    $shop=sanitize_text_field($body['shop_name'] ?? $req->get_param('shop_name') ?? '');
    $gid=sanitize_text_field($body['line_group_id'] ?? $req->get_param('line_group_id') ?? '');
    if(empty($shop)||empty($gid)) {
        $raw = $req->get_body();
        $debug = 'shop=' . var_export($shop,true) . ' gid=' . var_export($gid,true) . ' body_keys=' . implode(',', array_keys($body ?: [])) . ' raw_len=' . strlen($raw) . ' ct=' . $req->get_content_type()['value'];
        b2b_log('[SaveDist] Validation failed: ' . $debug);
        return new WP_REST_Response(array('success'=>false,'message'=>'กรุณากรอกชื่อร้านและ Group ID','debug'=>$debug),400);
    }
    if(!$id){$id=wp_insert_post(array('post_type'=>'distributor','post_title'=>$shop,'post_status'=>'publish'));if(is_wp_error($id))return new WP_REST_Response(array('success'=>false,'message'=>'สร้างไม่สำเร็จ'),500);}else{wp_update_post(array('ID'=>$id,'post_title'=>$shop));}
    update_field('shop_name',$shop,$id);update_field('line_group_id',$gid,$id);
    // FIX C-1: current_debt ต้องไม่ถูกเขียนตรง — ใช้ b2b_recalculate_debt แทน
    foreach(array('rank_system','credit_limit','credit_term_days','credit_hold') as $f){$val=isset($body[$f])?$body[$f]:$req->get_param($f);if($val!==null){if($f==='credit_limit')$val=max(0,min(10000000,floatval($val)));elseif($f==='credit_term_days')$val=max(1,intval($val));elseif($f==='credit_hold')$val=(bool)$val;else $val=sanitize_text_field($val);update_field($f,$val,$id);}}
    // current_debt: recalculate from source of truth if requested (admin cannot set arbitrary value)
    $debt_req = isset($body['current_debt']) ? $body['current_debt'] : $req->get_param('current_debt');
    if ($debt_req !== null && function_exists('b2b_recalculate_debt')) {
        b2b_recalculate_debt($id);
        b2b_log('[SaveDist] current_debt recalculated for dist=' . $id . ' (admin requested)');
    }
    // V.9: Address fields (C2-support)
    foreach(array('dist_phone','dist_province','dist_address','dist_district','dist_city','dist_postcode') as $af){$val=isset($body[$af])?$body[$af]:$req->get_param($af);if($val!==null)update_field($af,sanitize_text_field($val),$id);}
    // V.9: Recommended SKUs (F11)
    $rsku=isset($body['recommended_skus'])?$body['recommended_skus']:$req->get_param('recommended_skus');if($rsku!==null)update_field('recommended_skus',sanitize_text_field($rsku),$id);
    $slogo=isset($body['shop_logo_url'])?$body['shop_logo_url']:$req->get_param('shop_logo_url');if($slogo!==null)update_field('shop_logo_url',esc_url_raw($slogo),$id);
    return new WP_REST_Response(array('success'=>true,'id'=>$id,'message'=>'บันทึก "'.$shop.'" สำเร็จ'),200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}
function b2b_rest_toggle_bot( WP_REST_Request $req ) {
    try {
        $id  = intval($req->get_param('dist_id'));
        $val = (bool)$req->get_param('bot_enabled');
        if (!$id || get_post_type($id) !== 'distributor') {
            return new WP_REST_Response(array('success'=>false,'message'=>'ไม่พบตัวแทน'), 400);
        }
        // Dedup guard — ป้องกัน double call (5 วินาที)
        $dedup_key = 'b2b_toggle_bot_' . $id;
        if (get_transient($dedup_key)) {
            return new WP_REST_Response(array('success'=>true,'bot_enabled'=>$val,'message'=>'(duplicate ignored)'), 200);
        }
        set_transient($dedup_key, 1, 5);
        update_post_meta($id, 'bot_enabled', $val ? '1' : '0');
        $shop = get_field('shop_name', $id) ?: '#'.$id;
        b2b_log('[Bot Toggle] dist=' . $id . ' enabled=' . ($val ? 'YES' : 'NO'));
        return new WP_REST_Response(array('success'=>true,'bot_enabled'=>$val,'shop_name'=>$shop,'message'=>($val ? '✅ เปิดบอท' : '⛔ ปิดบอท') . ' ' . $shop . ' แล้ว'), 200);
    } catch (\Throwable $e) {
        b2b_log('[Snippet9] toggle-bot error: ' . $e->getMessage());
        return new WP_REST_Response(array('success'=>false,'message'=>'Internal error'), 500);
    }
}
function b2b_rest_delete_distributor( WP_REST_Request $req ) {
