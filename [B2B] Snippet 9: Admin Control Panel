function ftUpdateRecovery(){
  if(!ftSelected){document.getElementById('ft_recovery').style.display='none';return;}
  var fps=ftSelected.flash_packing||'none';
  var showRetry=(fps==='notify_error');
  var showSwitch=(fps==='notify_error'||fps==='flash_create_error'||fps==='print_done'||fps==='flash_created');
  var showCancelPickup=(fps==='courier_called');
  var showPanel=showRetry||showSwitch||showCancelPickup;
  document.getElementById('ft_recovery').style.display=showPanel?'':'none';
  document.getElementById('ft_retry_courier').style.display=showRetry?'':'none';
  document.getElementById('ft_switch_manual').style.display=showSwitch?'':'none';
  document.getElementById('ft_cancel_pickup').style.display=showCancelPickup?'':'none';
  document.getElementById('ftr_recovery').innerHTML='';
}

