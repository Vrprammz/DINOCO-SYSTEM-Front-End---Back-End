// ═══ System Check + Test Push (V.9: extended crons) ═══
function b2b_rest_system_check( WP_REST_Request $req ) {
    try {
    $consts=array('B2B_LINE_CHANNEL_SECRET','B2B_LINE_ACCESS_TOKEN','B2B_ADMIN_GROUP_ID','B2B_LIFF_ID','B2B_LIFF_URL','B2B_LOGO_URL','B2B_SITE_URL','B2B_SLIP2GO_SECRET_KEY','B2B_SLIP2GO_API_URL','B2B_BANK_NAME','B2B_BANK_ACCOUNT','B2B_BANK_HOLDER','B2B_BANK_CODE','B2B_PROMPTPAY_ID','B2B_COMPANY_NAME','B2B_FLASH_API_KEY','B2B_FLASH_MCH_ID','B2B_FLASH_API_URL');
    $ck=array();foreach($consts as $c)$ck[$c]=defined($c)?'ok':'missing';
    // V.9: Extended crons (8 hooks)
    $crons=array('b2b_dunning_cron_event','b2b_daily_summary_cron','b2b_rank_update_event','b2b_bo_overdue_check','b2b_auto_complete_check','b2b_oos_expiry_check','b2b_weekly_report_event');
    $cs=array();
    foreach($crons as $h){$n=wp_next_scheduled($h);$cs[$h]=$n?b2b_date('Y-m-d H:i:s',$n):'not_scheduled';}
    $dc=wp_count_posts('distributor');$pc=wp_count_posts('b2b_product');$oc=wp_count_posts('b2b_order');
    $pages=array('b2b-catalog'=>'LIFF Catalog','b2b-ticket'=>'Ticket View');$ps=array();
    foreach($pages as $s=>$l){$pg=get_page_by_path($s);$ps[$s]=array('label'=>$l,'exists'=>(bool)$pg);}
    return new WP_REST_Response(array('success'=>true,'constants'=>$ck,'crons'=>$cs,'counts'=>array('distributors'=>$dc->publish??0,'products'=>$pc->publish??0,'orders'=>$oc->publish??0),'pages'=>$ps,'webhook_url'=>rest_url('b2b/v1/webhook')),200);
    } catch ( \Throwable $e ) {
        b2b_log('[AdminDash] Error: ' . $e->getMessage());
        return new WP_REST_Response(array('success' => false, 'message' => 'Internal error'), 500);
    }
}
