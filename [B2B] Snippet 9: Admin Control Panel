function ftUpdateProgress(){
  if(!ftSelected)return;
  var o=ftSelected;
  // Determine completed steps based on current DB state (not just button clicks)
  var completedSteps=0;
  var fps=o.flash_packing||'none';
  var hasPnos=o.pnos&&o.pnos.length>0;
  // Step 1: address was validated if Flash parcel was created successfully
  if(ftStepState.check_address==='done'||(fps!=='none'&&hasPnos)){completedSteps=1;ftStepState.check_address='done';}
  // Step 2: parcel created
  if(fps!=='none'&&hasPnos){completedSteps=Math.max(completedSteps,2);ftStepState.flash_create='done';}
  // Step 3: scan QR (pack + call courier) — done if courier was called or beyond
  if(ftStepState.scan_qr==='done'||['courier_called','ready_to_ship','picked_up','in_transit','delivering','delivered'].indexOf(fps)!==-1){completedSteps=Math.max(completedSteps,3);ftStepState.scan_qr='done';}
  // Step 4: ready_to_ship / courier called
  if(['courier_called','picked_up','in_transit','delivering','delivered'].indexOf(fps)!==-1){completedSteps=Math.max(completedSteps,4);ftStepState.ready_to_ship='done';}
  // Webhook states
  var whStep=0;
  if(['picked_up','in_transit','delivering','delivered'].indexOf(fps)!==-1)whStep=5;
  if(['in_transit','delivering','delivered'].indexOf(fps)!==-1)whStep=6;
  if(fps==='delivered')whStep=7;
  var maxStep=Math.max(completedSteps,whStep);
  // Update dots
  for(var i=1;i<=7;i++){
    if(i<=maxStep)ftSetDot(i,'done');
    else ftSetDot(i,'pending');
  }
  // Step cards
  for(var j=1;j<=4;j++){
    var sn=FT_STEPS[j-1];
    ftSetStepCard(j,ftStepState[sn]||'pending');
  }
  // Progress bar fill
  var pct=maxStep>0?((maxStep-1)/6)*100:0;
  var fill=document.getElementById('ft_progress_fill');
  if(fill)fill.style.width=Math.min(pct,100)+'%';
}

