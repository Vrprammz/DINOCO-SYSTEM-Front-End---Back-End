function ftAutoRun(){
  if(!ftSelected){toast('กรุณาเลือก Order ก่อน','e');return;}
  if(ftAutoRunning){toast('กำลังทำงานอยู่...','e');return;}
  ftAutoRunning=true;
  var btn=document.getElementById('ft_autorun_btn');
  btn.disabled=true;btn.textContent='⏳ Running...';
  ftLog('🚀 === AUTO RUN ALL STEPS ===','warn');
  var steps=FT_STEPS.slice();var idx=0;
  function next(){
    if(idx>=steps.length){
      ftAutoRunning=false;btn.disabled=false;btn.textContent='🚀 Auto Run All Steps';
      ftLog('🏁 === AUTO RUN COMPLETE ===','ok');
      return;
    }
    var s=steps[idx];idx++;
    ftRun(s,function(ok){
      if(!ok){
        ftAutoRunning=false;btn.disabled=false;btn.textContent='🚀 Auto Run All Steps';
        ftLog('⛔ Auto-run stopped at '+s+' (error)','err');
        return;
      }
      setTimeout(next,800);
    });
  }
  next();
}

