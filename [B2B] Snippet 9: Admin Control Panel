function ftUpdateTimeline(){
  if(!ftSelected)return;
  var events=ftSelected.events||[];
  var wrap=document.getElementById('ft_timeline_wrap');
  var el=document.getElementById('ft_timeline');
  if(!events.length){wrap.style.display='none';return;}
  wrap.style.display='';
  var h='';
  events.slice().reverse().forEach(function(ev){
    var stateIcons={1:'🟡',2:'🔵',3:'🟠',4:'⚠️',5:'🟢',6:'🔴',7:'↩️',8:'⛔',9:'❌'};
    var icon=stateIcons[ev.state]||'⚪';
    var ts=ev.received_at?ev.received_at.replace('T',' ').substring(0,19):'';
    h+='<div style="padding:8px 0 8px 12px;border-bottom:1px solid #f1f5f9;position:relative">';
    h+='<div style="position:absolute;left:-22px;top:12px;width:10px;height:10px;border-radius:50%;background:#3b82f6;border:2px solid #fff"></div>';
    h+=icon+' <strong>'+esc(ev.message||'State '+ev.state)+'</strong>';
    if(ts)h+='<div style="font-size:10px;color:#94a3b8;margin-top:2px">'+ts+'</div>';
    h+='</div>';
  });
  el.innerHTML=h;
}

function ftRefresh(){
  api('GET','flash-test/orders',null,function(d){
    if(!d.success)return;
    ftOrders=d.orders;
    if(ftSelected){
      var updated=ftOrders.find(function(o){return o.id===ftSelected.id});
      if(updated){ftSelected=updated;ftUpdateInfo();ftUpdateProgress();ftUpdateRecovery();ftUpdateTimeline();}
    }
  });
}

function ftRun(step,cb){
  if(!ftSelected){toast('กรุณาเลือก Order ก่อน','e');return;}
  var stepNum=FT_STEP_MAP[step];
  ftLog('▶ กำลัง '+(FT_STEP_NAMES[step]||step)+' #'+ftSelected.id+'...','warn');

  // Set running state
  if(stepNum){ftStepState[step]='running';ftSetStepCard(stepNum,'running');ftSetDot(stepNum,'running');}
  var resultId=step==='cancel'?'ftr_cancel':'ftr_'+stepNum;
  if(resultId)document.getElementById(resultId).innerHTML='<div style="color:#3b82f6;display:flex;align-items:center;gap:6px"><span class="ft-spin">⏳</span> กำลังทำงาน...</div>';

  api('POST','flash-test/run-step',{ticket_id:ftSelected.id,step:step},function(d){
    var ok=d.success;
    var icon=ok?'✅':'❌';

    // Update step state
    if(stepNum){ftStepState[step]=ok?'done':'error';ftSetStepCard(stepNum,ok?'done':'error');ftSetDot(stepNum,ok?'done':'error');}

    // Render rich result
    var rh='<div style="color:'+(ok?'#16a34a':'#dc2626')+'">'+icon+' '+esc(d.message)+'</div>';

    if(step==='check_address'){
      if(d.dst&&ok){
        rh+='<div style="margin-top:6px;padding:8px;background:#f0fdf4;border-radius:6px;font-size:11px">';
        rh+='<strong>ผู้รับ:</strong> '+esc(d.dst.dist_name||'')+' · '+esc(d.dst.dist_phone||'')+'<br>';
        rh+=esc(d.dst.dist_address||'')+' '+esc(d.dst.dist_district||'')+' '+esc(d.dst.dist_province||'')+' '+esc(d.dst.dist_postcode||'');
        rh+='</div>';
      }
      if(d.dst_missing&&d.dst_missing.length>0)rh+='<div style="margin-top:4px;color:#dc2626;font-size:11px">⚠️ ผู้รับขาด: '+d.dst_missing.join(', ')+'</div>';
      if(d.wh_missing&&d.wh_missing.length>0)rh+='<div style="margin-top:4px;color:#dc2626;font-size:11px">⚠️ คลังขาด: '+d.wh_missing.join(', ')+'</div>';
      if(d.wh&&ok){
        rh+='<div style="margin-top:4px;padding:8px;background:#eff6ff;border-radius:6px;font-size:11px">';
        rh+='<strong>คลัง:</strong> '+esc(d.wh.wh_name||'')+' · '+esc(d.wh.wh_phone||'')+'<br>';
        rh+=esc(d.wh.wh_address||'')+' '+esc(d.wh.wh_district||'')+' '+esc(d.wh.wh_province||'')+' '+esc(d.wh.wh_postcode||'');
        rh+='</div>';
      }
    }

    if(step==='flash_create'&&d.data){
      if(d.data.pnos&&d.data.pnos.length>0){
        rh+='<div style="margin-top:6px;padding:8px;background:#f0fdf4;border-radius:6px;font-size:11px">';
        rh+='<strong>📦 Tracking Numbers:</strong><br>';
        d.data.pnos.forEach(function(pno,i){rh+='<code style="background:#dcfce7;padding:2px 6px;border-radius:4px;margin:2px 0;display:inline-block">'+esc(pno)+'</code> ';});
        rh+='<br><strong>กล่องทั้งหมด:</strong> '+(d.data.total_boxes||d.data.pnos.length);
        rh+='</div>';
        ftLog('📦 Tracking: '+d.data.pnos.join(', '),'ok');
      }
    }

    if(step==='scan_qr'&&ok){
      rh+='<div style="margin-top:6px;padding:8px;background:#f0fdf4;border-radius:6px;font-size:11px">';
      rh+='📱 QR Scan สำเร็จ — ปริ้นเสร็จ + แพ็คเรียบร้อย → พร้อมเรียกรถ';
      if(d.courier){rh+='<br>🚛 คูเรียร์: '+esc(d.courier.staffName||'')+'  '+esc(d.courier.staffPhone||'');}
      rh+='</div>';
    }

    if(step==='ready_to_ship'&&d.courier){
      var c=d.courier;
      rh+='<div style="margin-top:6px;padding:8px;background:#f0fdf4;border-radius:6px;font-size:11px">';
      rh+='<strong>🚛 คูเรียร์:</strong> '+esc(c.staffInfoName||'—')+' · 📞 '+esc(c.staffInfoPhone||'—')+'<br>';
      rh+='<strong>⏰ เข้ารับภายใน:</strong> '+esc(c.timeoutAtText||'—');
      if(c.ticketPickupId)rh+='<br><strong>Pickup ID:</strong> <code>'+esc(c.ticketPickupId)+'</code>';
      rh+='</div>';
      ftLog('🚛 คูเรียร์: '+(c.staffInfoName||'-')+' '+(c.staffInfoPhone||''),'ok');
      ftLog('⏰ เข้ารับ: '+(c.timeoutAtText||'-'),'ok');
    }

    if(step==='cancel'&&ok){
      // Reset all states
      ftStepState={};
      for(var i=1;i<=7;i++)ftSetDot(i,'pending');
      for(var j=1;j<=4;j++){ftSetStepCard(j,'pending');document.getElementById('ftr_'+j).innerHTML='';}
      document.getElementById('ft_progress_fill').style.width='0%';
      document.getElementById('ft_timeline_wrap').style.display='none';
    }

    if(d.log){d.log.forEach(function(l){ftLog('ℹ️ '+l,'warn')});}

    if(resultId)document.getElementById(resultId).innerHTML=rh;
    ftLog(icon+' '+step+': '+d.message,ok?'ok':'err');

    ftRefresh();
    if(cb)cb(ok);
  });
}

