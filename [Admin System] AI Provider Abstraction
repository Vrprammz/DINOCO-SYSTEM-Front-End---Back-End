/**
 * ╔══════════════════════════════════════════════════════════════╗
 * ║  [Admin System] AI Provider Abstraction Layer               ║
 * ║  Version: V.1.0                                             ║
 * ║  Description: เปลี่ยน AI model ได้ง่าย (Gemini/GPT/Claude)  ║
 * ╚══════════════════════════════════════════════════════════════╝
 *
 * ใช้แทน direct Gemini API call
 * เปลี่ยน provider แค่เปลี่ยน DINOCO_AI_PROVIDER constant
 *
 * ต้องใช้: ไม่ต้องลงปลั๊กอินเพิ่ม
 *
 * wp-config.php:
 *   define('DINOCO_AI_PROVIDER', 'gemini');  // 'gemini' | 'openai' | 'claude'
 *   define('DINOCO_GEMINI_KEY', 'xxx');
 *   define('DINOCO_OPENAI_KEY', 'xxx');      // ถ้าใช้ OpenAI
 *   define('DINOCO_CLAUDE_KEY', 'xxx');       // ถ้าใช้ Claude
 */

if ( ! defined( 'ABSPATH' ) ) exit;

if ( ! class_exists( 'DINOCO_AI' ) ) {

class DINOCO_AI {

    private static $provider = null;

    /**
     * ส่งข้อความถึง AI และรับ response
     *
     * @param string $system_prompt System instruction
     * @param array  $messages      Array of ['role'=>'user'|'model', 'text'=>'...']
     * @param array  $tools         Function calling tools (optional)
     * @param array  $options       Override options (temperature, max_tokens, etc.)
     * @return array ['success'=>bool, 'text'=>string, 'tool_calls'=>array, 'raw'=>array]
     */
    public static function chat( $system_prompt, $messages, $tools = array(), $options = array() ) {
        $provider = self::get_provider();

        $defaults = array(
            'temperature'   => 0.35,
            'max_tokens'    => 2048,
            'model'         => null,  // null = use provider default
        );
        $opts = wp_parse_args( $options, $defaults );

        switch ( $provider ) {
            case 'gemini':
                return self::call_gemini( $system_prompt, $messages, $tools, $opts );
            case 'openai':
                return self::call_openai( $system_prompt, $messages, $tools, $opts );
            case 'claude':
                return self::call_claude( $system_prompt, $messages, $tools, $opts );
            default:
                return array( 'success' => false, 'text' => 'Unknown AI provider: ' . $provider, 'tool_calls' => array() );
        }
    }

    /**
     * ตรวจว่า provider ไหนถูกตั้งค่าไว้
     */
    private static function get_provider() {
        if ( self::$provider ) return self::$provider;
        self::$provider = defined( 'DINOCO_AI_PROVIDER' ) ? strtolower( DINOCO_AI_PROVIDER ) : 'gemini';
        return self::$provider;
    }

    // ════════════════════════════════════════
    // GEMINI (Google)
    // ════════════════════════════════════════
    private static function call_gemini( $system_prompt, $messages, $tools, $opts ) {
        $api_key = defined( 'DINOCO_GEMINI_KEY' ) ? DINOCO_GEMINI_KEY : '';
        if ( empty( $api_key ) ) return array( 'success' => false, 'text' => 'DINOCO_GEMINI_KEY not defined', 'tool_calls' => array() );

        $model = $opts['model'] ?: 'gemini-2.0-flash';

        // Convert messages to Gemini format
        $contents = array();
        foreach ( $messages as $msg ) {
            $role = ( $msg['role'] === 'user' ) ? 'user' : 'model';
            $contents[] = array( 'role' => $role, 'parts' => array( array( 'text' => $msg['text'] ) ) );
        }

        $body = array(
            'system_instruction' => array( 'parts' => array( array( 'text' => $system_prompt ) ) ),
            'contents'           => $contents,
            'generationConfig'   => array(
                'temperature'    => $opts['temperature'],
                'maxOutputTokens'=> $opts['max_tokens'],
            ),
        );

        // Function calling tools
        if ( ! empty( $tools ) ) {
            $body['tools'] = array( array( 'functionDeclarations' => $tools ) );
        }

        $url = "https://generativelanguage.googleapis.com/v1beta/models/{$model}:generateContent?key={$api_key}";
        $response = wp_remote_post( $url, array(
            'headers' => array( 'Content-Type' => 'application/json' ),
            'body'    => json_encode( $body ),
            'timeout' => 30,
        ) );

        return self::parse_gemini_response( $response );
    }

    private static function parse_gemini_response( $response ) {
        if ( is_wp_error( $response ) ) return array( 'success' => false, 'text' => $response->get_error_message(), 'tool_calls' => array() );
        $status_code = wp_remote_retrieve_response_code( $response );
        if ( $status_code !== 200 ) return array( 'success' => false, 'text' => 'Gemini API error ' . $status_code . ': ' . wp_remote_retrieve_body( $response ), 'tool_calls' => array() );

        $data = json_decode( wp_remote_retrieve_body( $response ), true );
        $parts = $data['candidates'][0]['content']['parts'] ?? array();

        $text = '';
        $tool_calls = array();
        foreach ( $parts as $part ) {
            if ( isset( $part['text'] ) ) $text .= $part['text'];
            if ( isset( $part['functionCall'] ) ) {
                $tool_calls[] = array(
                    'name' => $part['functionCall']['name'],
                    'args' => $part['functionCall']['args'] ?? array(),
                );
            }
        }

        return array( 'success' => true, 'text' => $text, 'tool_calls' => $tool_calls, 'raw' => $data );
    }

    // ════════════════════════════════════════
    // OPENAI (GPT-4o / GPT-4.1)
    // ════════════════════════════════════════
    private static function call_openai( $system_prompt, $messages, $tools, $opts ) {
        $api_key = defined( 'DINOCO_OPENAI_KEY' ) ? DINOCO_OPENAI_KEY : '';
        if ( empty( $api_key ) ) return array( 'success' => false, 'text' => 'DINOCO_OPENAI_KEY not defined', 'tool_calls' => array() );

        $model = $opts['model'] ?: 'gpt-4o';

        $oai_messages = array( array( 'role' => 'system', 'content' => $system_prompt ) );
        foreach ( $messages as $msg ) {
            $role = ( $msg['role'] === 'user' ) ? 'user' : 'assistant';
            $oai_messages[] = array( 'role' => $role, 'content' => $msg['text'] );
        }

        $body = array(
            'model'       => $model,
            'messages'    => $oai_messages,
            'temperature' => $opts['temperature'],
            'max_tokens'  => $opts['max_tokens'],
        );

        if ( ! empty( $tools ) ) {
            $oai_tools = array();
            foreach ( $tools as $tool ) {
                $oai_tools[] = array(
                    'type'     => 'function',
                    'function' => array(
                        'name'        => $tool['name'],
                        'description' => $tool['description'] ?? '',
                        'parameters'  => $tool['parameters'] ?? array( 'type' => 'object', 'properties' => new stdClass ),
                    ),
                );
            }
            $body['tools'] = $oai_tools;
        }

        $response = wp_remote_post( 'https://api.openai.com/v1/chat/completions', array(
            'headers' => array( 'Content-Type' => 'application/json', 'Authorization' => 'Bearer ' . $api_key ),
            'body'    => json_encode( $body ),
            'timeout' => 30,
        ) );

        if ( is_wp_error( $response ) ) return array( 'success' => false, 'text' => $response->get_error_message(), 'tool_calls' => array() );
        $status_code = wp_remote_retrieve_response_code( $response );
        if ( $status_code !== 200 ) return array( 'success' => false, 'text' => 'OpenAI API error ' . $status_code . ': ' . wp_remote_retrieve_body( $response ), 'tool_calls' => array() );

        $data = json_decode( wp_remote_retrieve_body( $response ), true );
        $choice = $data['choices'][0]['message'] ?? array();
        $text = $choice['content'] ?? '';
        $tool_calls = array();
        if ( isset( $choice['tool_calls'] ) ) {
            foreach ( $choice['tool_calls'] as $tc ) {
                $tool_calls[] = array(
                    'id'   => $tc['id'] ?? '',
                    'name' => $tc['function']['name'],
                    'args' => json_decode( $tc['function']['arguments'] ?? '{}', true ),
                );
            }
        }

        return array( 'success' => true, 'text' => $text, 'tool_calls' => $tool_calls, 'raw' => $data );
    }

    // ════════════════════════════════════════
    // CLAUDE (Anthropic)
    // ════════════════════════════════════════
    private static function call_claude( $system_prompt, $messages, $tools, $opts ) {
        $api_key = defined( 'DINOCO_CLAUDE_KEY' ) ? DINOCO_CLAUDE_KEY : '';
        if ( empty( $api_key ) ) return array( 'success' => false, 'text' => 'DINOCO_CLAUDE_KEY not defined', 'tool_calls' => array() );

        $model = $opts['model'] ?: 'claude-sonnet-4-20250514';

        $claude_messages = array();
        foreach ( $messages as $msg ) {
            $role = ( $msg['role'] === 'user' ) ? 'user' : 'assistant';
            $claude_messages[] = array( 'role' => $role, 'content' => $msg['text'] );
        }

        $body = array(
            'model'      => $model,
            'system'     => $system_prompt,
            'messages'   => $claude_messages,
            'max_tokens' => $opts['max_tokens'],
            'temperature'=> $opts['temperature'],
        );

        if ( ! empty( $tools ) ) {
            $claude_tools = array();
            foreach ( $tools as $tool ) {
                $claude_tools[] = array(
                    'name'         => $tool['name'],
                    'description'  => $tool['description'] ?? '',
                    'input_schema' => $tool['parameters'] ?? array( 'type' => 'object', 'properties' => new stdClass ),
                );
            }
            $body['tools'] = $claude_tools;
        }

        $response = wp_remote_post( 'https://api.anthropic.com/v1/messages', array(
            'headers' => array(
                'Content-Type'      => 'application/json',
                'x-api-key'         => $api_key,
                'anthropic-version' => '2023-06-01',
            ),
            'body'    => json_encode( $body ),
            'timeout' => 30,
        ) );

        if ( is_wp_error( $response ) ) return array( 'success' => false, 'text' => $response->get_error_message(), 'tool_calls' => array() );
        $status_code = wp_remote_retrieve_response_code( $response );
        if ( $status_code !== 200 ) return array( 'success' => false, 'text' => 'Claude API error ' . $status_code . ': ' . wp_remote_retrieve_body( $response ), 'tool_calls' => array() );

        $data = json_decode( wp_remote_retrieve_body( $response ), true );
        $text = '';
        $tool_calls = array();
        foreach ( ( $data['content'] ?? array() ) as $block ) {
            if ( $block['type'] === 'text' ) $text .= $block['text'];
            if ( $block['type'] === 'tool_use' ) {
                $tool_calls[] = array( 'id' => $block['id'] ?? '', 'name' => $block['name'], 'args' => $block['input'] ?? array() );
            }
        }

        return array( 'success' => true, 'text' => $text, 'tool_calls' => $tool_calls, 'raw' => $data );
    }
}

} // end class_exists
