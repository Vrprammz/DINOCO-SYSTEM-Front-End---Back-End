        // Unknown slip code — เงียบ ไม่ตอบในห้อง (อาจไม่ใช่สลิป)
        $code = isset($slip['code']) ? $slip['code'] : 'UNKNOWN';
        b2b_log('[Slip] Unknown code=' . $code . ' group=' . $group_id);
    }

    // Release lock แล้วตรวจ queue ต่อ
    delete_transient($lock_key);

    // Process queued slips (ส่งมาตอนกำลังตรวจอันก่อนหน้า)
    $queue = get_option('b2b_slip_queue_' . $group_id, array());
    if (!empty($queue)) {
        $next = array_shift($queue);
        update_option('b2b_slip_queue_' . $group_id, $queue, false);
