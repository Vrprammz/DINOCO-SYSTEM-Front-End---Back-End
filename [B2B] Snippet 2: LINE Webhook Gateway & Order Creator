function b2b_create_draft_order( $order_text, $group_id, $user_id, $reply_token ) {
    $dist = b2b_get_dist_by_group($group_id);
    if ( $dist && get_field('credit_hold', $dist->ID) ) { b2b_line_reply($reply_token, "⛔ บัญชีถูกระงับชั่วคราว\nกรุณาชำระยอดค้างก่อนจึงจะสั่งสินค้าได้ครับ"); return; }
    $post_id = wp_insert_post(array('post_title'=>'Order-'.b2b_date('Ymd-His'),'post_type'=>'b2b_order','post_status'=>'publish','post_author'=>1));
    if ( !$post_id || is_wp_error($post_id) ) { b2b_line_reply($reply_token, "❌ เกิดข้อผิดพลาดในการสร้าง Ticket ครับ"); return; }
    $total = 0;
    if ( preg_match('/(?:ยอดประมาณ|ราคาตัวแทนจำหน่าย|มูลค่ารวมสุทธิ)[:\s]*฿?([\d,]+)/u', $order_text, $m) ) $total = b2b_parse_price($m[1]);
    b2b_set_order_status($post_id, 'draft'); update_field('source_group_id', $group_id, $post_id);
    update_field('order_items', sanitize_textarea_field($order_text), $post_id); update_field('total_amount', $total, $post_id); update_field('is_billed', false, $post_id);
    $orderer_name = b2b_get_line_profile_name($user_id);
    update_field('orderer_display_name', $orderer_name, $post_id); update_field('orderer_user_id', $user_id, $post_id);
    // V.9: N5 — save customer note
    if ( preg_match('/(?:หมายเหตุ|note|โน้ต)[:\s]*(.+?)$/imu', $order_text, $nm) ) {
        $note = trim($nm[1]);
        if ( !empty($note) ) update_field('customer_note', sanitize_textarea_field($note), $post_id);
    }
    // V.22: Copy distributor address to order for Flash shipping
    if ( $dist ) {
        $dist_title = get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID);
        update_field('dist_name', $dist_title, $post_id);
        foreach (array('dist_phone','dist_address','dist_district','dist_city','dist_province','dist_postcode') as $af) {
            $v = get_field($af, $dist->ID);
            if ( !empty($v) ) update_field($af, $v, $post_id);
        }
    }
    $clean = preg_replace('/^.*?ขอยืนยันสั่งสินค้า\s*/u', '', $order_text);
    $dist_name = $dist ? get_the_title($dist->ID) : '';
    $flex = b2b_build_flex_draft_confirm($post_id, $clean, $total, $dist_name); b2b_line_reply_raw($reply_token, array($flex));
}

