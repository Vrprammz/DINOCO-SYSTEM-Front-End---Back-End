// ════════════════════════════════════════════════════════════════
// SLIP IMAGE HANDLER (V.7.4 API + V.7.5 Flex Output)
// ════════════════════════════════════════════════════════════════
function b2b_handle_slip_image( $message_id, $group_id, $user_id, $reply_token, $manual_mode = false ) {
    if ( !defined('B2B_ADMIN_GROUP_ID') || $group_id === B2B_ADMIN_GROUP_ID ) return;
    if ( !defined('B2B_SLIP2GO_SECRET_KEY') ) return;

    // Helper: ถ้า reply_token ว่าง (queued slip) ใช้ push แทน
    $_slip_reply = function($msgs) use ($reply_token, $group_id) {
        if (!empty($reply_token)) {
            return b2b_line_reply_raw($reply_token, $msgs);
        }
        return b2b_line_push_raw($group_id, $msgs);
    };
    $_slip_reply_text = function($text) use ($reply_token, $group_id) {
        if (!empty($reply_token)) {
            return b2b_line_reply($reply_token, $text);
        }
        return b2b_line_push($group_id, $text);
    };

    // ── Queue-based slip processing — รองรับหลายสลิปพร้อมกัน ──
    $lock_key = 'b2b_slip_lock_' . $group_id;
    if ( get_transient($lock_key) ) {
        // มีสลิปกำลังตรวจอยู่ → เก็บเข้า queue แล้ว cron ตรวจต่อ
        $queue = get_option('b2b_slip_queue_' . $group_id, array());
        $queue[] = array('message_id' => $message_id, 'user_id' => $user_id, 'time' => time());
        update_option('b2b_slip_queue_' . $group_id, $queue, false);
        b2b_log('[Slip] Queued slip ' . $message_id . ' for group ' . $group_id . ' (queue size: ' . count($queue) . ')');
        return;
    }
    set_transient($lock_key, 1, 30);

    // B3: try/catch around LINE Content API
    try {
        $response = wp_remote_get('https://api-data.line.me/v2/bot/message/'.$message_id.'/content', array(
            'headers'=>array('Authorization'=>'Bearer '.B2B_LINE_ACCESS_TOKEN),'timeout'=>30,
        ));
    } catch ( Exception $e ) {
        b2b_log('[Slip LINE API Error] ' . $e->getMessage());
        $_slip_reply_text("⚠️ ระบบไม่สามารถดาวน์โหลดรูปได้ กรุณาลองใหม่ครับ");
        delete_transient($lock_key);
        return;
    }
    if ( is_wp_error($response) ) { b2b_log('[Slip LINE API] wp_error: '.$response->get_error_message()); delete_transient($lock_key); return; }
    $image_binary = wp_remote_retrieve_body($response);
    if ( empty($image_binary) ) { delete_transient($lock_key); return; }

    // V.30.0: Detect actual MIME type instead of hardcoding jpeg
    $slip_content_type = wp_remote_retrieve_header($response, 'content-type');
    $slip_mime = in_array($slip_content_type, array('image/jpeg','image/png','image/webp')) ? $slip_content_type : 'image/jpeg';
    $image_base64 = 'data:'.$slip_mime.';base64,' . base64_encode($image_binary);

    $check_condition = array('checkDuplicate' => true);
    $bank_info = function_exists('b2b_get_bank_info') ? b2b_get_bank_info() : null;
    if ( $bank_info && !empty($bank_info['account']) ) {
        $account_number = preg_replace('/[^0-9]/', '', $bank_info['account']);
        $receiver = array('accountNumber' => $account_number);
        if ( !empty($bank_info['bank_code']) ) {
            $receiver['accountType'] = '01' . str_pad($bank_info['bank_code'], 3, '0', STR_PAD_LEFT);
        }
        $check_condition['checkReceiver'] = array($receiver);
    }

    $api_url = defined('B2B_SLIP2GO_API_URL')
        ? B2B_SLIP2GO_API_URL
        : 'https://connect.slip2go.com/api/verify-slip/qr-base64/info';

    // B3: try/catch around Slip2Go API
    try {
        $slip_response = wp_remote_post($api_url, array(
            'headers' => array(
                'Authorization' => 'Bearer ' . B2B_SLIP2GO_SECRET_KEY,
                'Content-Type'  => 'application/json',
            ),
            'body' => wp_json_encode(array(
                'payload' => array(
                    'imageBase64'    => $image_base64,
                    'checkCondition' => $check_condition,
                ),
            )),
            'timeout' => 45,
        ));
    } catch ( Exception $e ) {
        b2b_log('[Slip2Go API Error] ' . $e->getMessage());
        $_slip_reply_text("⚠️ ระบบตรวจสลิปมีปัญหาชั่วคราว แอดมินจะตรวจสอบ Manual ครับ");
        b2b_push_to_admin("⚠️ Slip2Go Exception: " . $e->getMessage() . "\nGroup: " . $group_id);
        delete_transient($lock_key);
        return;
    }

    if ( is_wp_error($slip_response) ) {
        b2b_log('[Slip] wp_error: '.$slip_response->get_error_message());
        $_slip_reply_text("⚠️ ระบบตรวจสลิปมีปัญหาชั่วคราว แอดมินจะตรวจสอบ Manual ครับ");
        delete_transient($lock_key);
        return;
    }

    $http_code = wp_remote_retrieve_response_code($slip_response);
    $raw_body = wp_remote_retrieve_body($slip_response);
    $slip = json_decode($raw_body, true);
    b2b_log('[Slip] HTTP='.$http_code.' Body='.mb_substr($raw_body, 0, 500));

    if ( $http_code !== 200 || !is_array($slip) ) {
        // ไม่ตอบในห้อง — อาจไม่ใช่สลิป หรือ API มีปัญหา
        b2b_log('[Slip] API error HTTP=' . $http_code . ' group=' . $group_id);
        delete_transient($lock_key);
        return;
    }

    $slip_code = isset($slip['code']) ? $slip['code'] : '';

    if ( $slip_code === '200501' ) {
        $data = isset($slip['data']) ? $slip['data'] : array();
        $paid = floatval($data['amount'] ?? 0);
        $trans_ref = sanitize_text_field($data['transRef'] ?? '');
        $_slip_reply_text("⚠️ สลิปนี้เคยใช้แล้ว!\nTransRef: ".$trans_ref."\nยอด: ฿".number_format($paid,2)."\n\nกรุณาส่งสลิปใหม่ครับ");
        b2b_push_to_admin("🔴 สลิปซ้ำ! TransRef: ".$trans_ref."\nยอด: ฿".number_format($paid,2)."\nGroup: ".$group_id);
        delete_transient($lock_key);
        return;
    }

    if ( $slip_code === '200401' ) {
        $data = isset($slip['data']) ? $slip['data'] : array();
        $paid = floatval($data['amount'] ?? 0);
        $sender = sanitize_text_field($data['sender']['account']['name'] ?? 'ไม่ระบุ');
        $recv   = sanitize_text_field($data['receiver']['account']['name'] ?? '');
        $_slip_reply_text("⚠️ สลิปนี้โอนไปบัญชีอื่น ไม่ใช่บัญชี DINOCO\nผู้รับ: ".$recv."\nยอด: ฿".number_format($paid,2)."\n\nกรุณาตรวจสอบและส่งสลิปที่ถูกต้องครับ");
        b2b_push_to_admin("🟡 สลิปบัญชีไม่ตรง\nผู้โอน: ".$sender."\nผู้รับ: ".$recv."\nยอด: ฿".number_format($paid,2)."\nGroup: ".$group_id);
        delete_transient($lock_key);
        return;
    }

    if ( $slip_code === '200402' ) {
        $data = isset($slip['data']) ? $slip['data'] : array();
        $paid = floatval($data['amount'] ?? 0);
        $sender = sanitize_text_field($data['sender']['account']['name'] ?? 'ไม่ระบุ');
        $_slip_reply_text("⚠️ ยอดโอนไม่ตรงเงื่อนไข\nผู้โอน: ".$sender."\nยอด: ฿".number_format($paid,2)."\n\nกรุณาตรวจสอบครับ");
        b2b_push_to_admin("🟡 ยอดโอนไม่ตรง\nผู้โอน: ".$sender."\nยอด: ฿".number_format($paid,2)."\nGroup: ".$group_id);
        delete_transient($lock_key);
        return;
    }

    if ( $slip_code === '200404' ) {
        // ไม่ตอบในห้อง — รูปอาจไม่ใช่สลิป (ใบเสร็จ, รูปสินค้า, etc.)
        b2b_log('[Slip] 200404 — ไม่ใช่สลิปหรือสลิปปลอม, group=' . $group_id);
        delete_transient($lock_key);
        return;
    }

    if ( $slip_code === '200000' || $slip_code === '200200' ) {
        $data   = isset($slip['data']) && is_array($slip['data']) ? $slip['data'] : array();
        if ( empty($data) || !isset($data['amount']) ) {
            $_slip_reply_text("⚠️ ระบบตรวจสลิปมีปัญหาชั่วคราว กรุณารอแอดมินตรวจสอบครับ 🙏");
            b2b_push_to_admin("⚠️ Slip2go data missing (code=".$slip_code.")\nGroup: ".$group_id);
            delete_transient($lock_key);
            return;
        }
        $paid   = floatval($data['amount']);
        $sender = sanitize_text_field($data['sender']['account']['name'] ?? 'ไม่ระบุ');
        $recv   = sanitize_text_field($data['receiver']['account']['name'] ?? '');
        $trans_ref = sanitize_text_field($data['transRef'] ?? '');

        $cond = isset($slip['conditionResult']) ? $slip['conditionResult'] : null;
        $is_dup = ($cond && isset($cond['isDuplicate']) && $cond['isDuplicate'] === true);
        $recv_valid = ($cond && isset($cond['isReceiverValid']) && $cond['isReceiverValid'] === true);

        if ($is_dup) {
            $_slip_reply_text("⚠️ สลิปนี้เคยใช้แล้ว!\nTransRef: ".$trans_ref."\nยอด: ฿".number_format($paid,2)."\n\nกรุณาส่งสลิปใหม่ครับ");
            b2b_push_to_admin("🔴 สลิปซ้ำ! TransRef: ".$trans_ref."\nยอด: ฿".number_format($paid,2)."\nGroup: ".$group_id);
            delete_transient($lock_key);
            return;
        }
        if ($cond && isset($cond['isReceiverValid']) && !$recv_valid) {
            $_slip_reply_text("⚠️ สลิปนี้โอนไปบัญชีอื่น ไม่ใช่บัญชี DINOCO\nผู้รับ: ".$recv."\nยอด: ฿".number_format($paid,2)."\n\nกรุณาตรวจสอบและส่งสลิปที่ถูกต้องครับ");
            b2b_push_to_admin("🟡 สลิปบัญชีไม่ตรง\nผู้โอน: ".$sender."\nผู้รับ: ".$recv."\nยอด: ฿".number_format($paid,2)."\nGroup: ".$group_id);
            delete_transient($lock_key);
            return;
        }

        $dist = b2b_get_dist_by_group($group_id);
        if ($dist) {
            $old_debt = floatval(get_field('current_debt', $dist->ID));
            $new_debt = round(max(0, $old_debt - $paid), 2);
            update_field('current_debt', $new_debt, $dist->ID);
            $mtd = floatval(get_field('monthly_sales_mtd', $dist->ID));
            update_field('monthly_sales_mtd', round($mtd + $paid, 2), $dist->ID);
            if ($new_debt <= 0) update_field('credit_hold', false, $dist->ID);

            $dist_name = get_the_title($dist->ID);
            $credit_limit = floatval(get_field('credit_limit', $dist->ID));

            $match_result = b2b_auto_mark_paid_after_slip($dist->ID, $paid, $group_id);
            $paid_tickets = $match_result['paid_tickets'];

            $pending = get_posts(array('post_type'=>'b2b_order','posts_per_page'=>-1,'post_status'=>'publish',
                'meta_query'=>array(array('key'=>'source_group_id','value'=>$group_id),array('key'=>'order_status','value'=>'awaiting_payment')),'fields'=>'ids'));
            $pending_count = count($pending);
            $new_debt = floatval(get_field('current_debt', $dist->ID));

            if ( $manual_mode ) {
                // Manual Invoice mode (bot ปิด): Flex มี header + รายละเอียดบิลที่เคลียร์
                $logo = function_exists('b2b_get_logo_url') ? b2b_get_logo_url() : 'https://dinoco.in.th/wp-content/uploads/dinoco-logo.png';
