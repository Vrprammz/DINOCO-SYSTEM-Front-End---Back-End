function b2b_action_ship_packed_only( $ticket_id, $user_id, $reply_token ) {
    if ( get_post_type( $ticket_id ) !== 'b2b_order' ) return;

    // Call the ship-packed REST endpoint internally
    $config = array();
    if ( defined( 'B2B_PRINT_API_KEY' ) ) $config['api_key'] = B2B_PRINT_API_KEY;

    $pno_statuses = get_post_meta( $ticket_id, '_flash_pno_statuses', true );
    if ( ! is_array( $pno_statuses ) ) {
        b2b_line_reply( $reply_token, '❌ ไม่พบข้อมูลกล่อง #' . $ticket_id );
        return;
    }

    // Count packed vs unpacked
    $packed_count = 0;
    $hold_names   = array();
    foreach ( $pno_statuses as $pno => $info ) {
        $s  = is_array( $info ) ? ( $info['status'] ?? 'created' ) : 'created';
        if ( in_array( $s, array( 'cancelled', 'hold_pending' ), true ) ) continue;
        $pa = is_array( $info ) ? ( $info['packed_at'] ?? null ) : null;
        if ( $pa ) {
            $packed_count++;
        } else {
            $hold_names[] = is_array( $info ) ? ( $info['name'] ?? $pno ) : $pno;
            if ( is_array( $pno_statuses[ $pno ] ) ) {
                $pno_statuses[ $pno ]['status'] = 'hold_pending';
            }
        }
    }

    if ( $packed_count === 0 ) {
        b2b_line_reply( $reply_token, '❌ ไม่มีกล่องที่พร้อมส่ง #' . $ticket_id );
        return;
    }

    update_post_meta( $ticket_id, '_flash_pno_statuses', $pno_statuses );
    update_post_meta( $ticket_id, '_flash_packing_status', 'partial_shipped' );

    // Call courier for packed boxes
    $pnos = get_post_meta( $ticket_id, '_flash_tracking_numbers', true );
    $total = is_array( $pnos ) ? count( $pnos ) : 1;
    if ( function_exists( 'b2b_flash_notify_courier_from_warehouse' ) ) {
        b2b_flash_notify_courier_from_warehouse( $packed_count, 'PartialShip(postback): #' . $ticket_id );
    }

    // Notify dealer
    $customer_gid = get_field( 'source_group_id', $ticket_id );
    if ( $customer_gid && function_exists( 'b2b_build_flex_box_hold' ) && function_exists( 'b2b_push_raw_to_group' ) ) {
        $flex = b2b_build_flex_box_hold( $ticket_id, $pno_statuses, $hold_names );
        b2b_push_raw_to_group( $customer_gid, array( $flex ) );
    }

    $admin_name = b2b_get_line_profile_name( $user_id );
    b2b_add_audit_log( $ticket_id, 'partial_ship_postback', $admin_name . ' สั่งส่งเฉพาะที่พร้อม ' . $packed_count . ' กล่อง' );
    b2b_line_reply( $reply_token, '🚛 ส่ง ' . $packed_count . '/' . $total . ' กล่อง #' . $ticket_id . "\n" . implode( ', ', $hold_names ) . ' รอส่งรอบถัดไป' );
}

function b2b_action_postpone_pack( $ticket_id, $user_id, $reply_token ) {
    if ( get_post_type( $ticket_id ) !== 'b2b_order' ) return;

