        if ( $result['ok'] ) {
            update_post_meta($ticket_id, '_ship_method', 'flash');
            update_field('shipping_provider', 'Flash', $ticket_id);
            if (function_exists('b2b_enqueue_print_job')) b2b_enqueue_print_job($ticket_id);
            if (function_exists('b2b_add_audit_log')) b2b_add_audit_log($ticket_id, 'change_to_flash', '🔄 เปลี่ยนเป็น Flash (โดย '.$admin_name.')');
