function b2b_action_confirm_order( $ticket_id, $group_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'draft' ) {
        delete_transient($lock_key);
        // สถานะเปลี่ยนไปแล้ว — แจ้งสถานะปัจจุบันให้ลูกค้า
        $status_th = array('checking_stock'=>'ทีมงานกำลังเช็คสต็อก','awaiting_confirm'=>'รอยืนยันบิล','awaiting_payment'=>'รอชำระเงิน','paid'=>'ชำระแล้ว','packed'=>'แพ็คแล้ว','shipped'=>'จัดส่งแล้ว','completed'=>'เสร็จสิ้น','cancelled'=>'ยกเลิก');
        $st_text = isset($status_th[$status]) ? $status_th[$status] : $status;
        b2b_line_reply($reply_token, "✅ ส่งรายการไปแล้วครับ\nสถานะปัจจุบัน: " . $st_text);
        return;
    }

    // OOS Memory Check
    $order_text = get_field('order_items', $ticket_id) ?: '';
    $oos_items = b2b_check_order_oos($order_text);
    if ( !empty($oos_items) ) {
        $oos_msg = "🚫 สินค้าบางรายการหมดชั่วคราว:\n";
        foreach ($oos_items as $item) {
            $oos_msg .= "• " . $item['sku'] . ($item['eta'] ? " (ETA: " . $item['eta'] . ")" : " (ไม่มีกำหนด)") . "\n";
        }
        $oos_msg .= "\nท่านต้องการ Backorder (รอสินค้า) หรือยกเลิก?";

        b2b_set_order_status($ticket_id, 'backorder');
        $flex = b2b_build_flex_oos_customer($ticket_id, $oos_msg);
        b2b_line_reply_raw($reply_token, array($flex));
        return;
    }

    // เปลี่ยนสถานะ → checking_stock
    b2b_set_order_status($ticket_id, 'checking_stock');

    // แจ้งลูกค้า
    b2b_line_reply($reply_token, "✅ ส่งรายการเรียบร้อยแล้วครับ!\n⏳ ทีมงานกำลังตรวจสอบสต็อกให้ กรุณารอสักครู่");

    // Flex Alert → Admin Group
    $flex = b2b_build_flex_stock_check_alert($ticket_id, $order_text, $group_id);
    if (function_exists('b2b_push_raw_to_admin')) b2b_push_raw_to_admin(array($flex));

    // SLA 10 min
    b2b_schedule_sla_alert($ticket_id);
    delete_transient($lock_key);
}

function b2b_action_cancel_draft( $ticket_id, $reply_token ) {
    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'draft' ) { b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ดำเนินการไปแล้วครับ"); return; }
    b2b_set_order_status($ticket_id, 'cancelled');
    b2b_line_reply($reply_token, "🗑️ ยกเลิกรายการสั่งซื้อเรียบร้อยแล้วครับ\nท่านสามารถสั่งใหม่ได้ตลอดเวลา");
}

function b2b_action_stock_confirm( $ticket_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        return;
    }
    set_transient($lock_key, 1, 10);

    b2b_clear_sla_nag($ticket_id);
    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'checking_stock' ) {
        delete_transient($lock_key);
        // สถานะเปลี่ยนไปแล้ว (retry/กดซ้ำ) → ส่ง Flex ยืนยันบิลซ้ำให้ลูกค้า + แจ้งแอดมิน
        if ( $status === 'awaiting_confirm' || $status === 'awaiting_payment' ) {
            $group_id = get_field('source_group_id', $ticket_id);
            $total = floatval(get_field('total_amount', $ticket_id));
            $order_text = get_field('order_items', $ticket_id) ?: '';
            if ($group_id && function_exists('b2b_build_flex_stock_confirmed')) {
                $flex = b2b_build_flex_stock_confirmed($ticket_id, $total, $order_text);
                if (function_exists('b2b_push_guaranteed')) {
                    b2b_push_guaranteed($group_id, array($flex), $ticket_id, 'stock_confirmed');
                } else {
                    b2b_line_push_raw($group_id, array($flex));
                }
            }
            b2b_line_reply($reply_token, "✅ ยืนยันสต็อกไปแล้วครับ — ส่ง Flex ยืนยันบิลให้ลูกค้าอีกครั้ง");
        }
        return;
    }

    $admin_name = b2b_get_line_profile_name($user_id);
    b2b_set_order_status($ticket_id, 'awaiting_confirm');
    update_field('stock_checked_by', $admin_name.' ('.$user_id.')', $ticket_id);
    b2b_schedule_sla_alert($ticket_id);

    b2b_line_reply($reply_token, "✅ ยืนยันสต็อกเรียบร้อย (โดย ".$admin_name.")\nระบบแจ้งลูกค้าให้ยืนยันบิลแล้วครับ");

    // Push Flex → ลูกค้า (guaranteed — auto-retry ถ้าส่งไม่สำเร็จ)
    $group_id = get_field('source_group_id', $ticket_id);
    $total = floatval(get_field('total_amount', $ticket_id));
    $order_text = get_field('order_items', $ticket_id) ?: '';
    if ($group_id) {
        $flex = b2b_build_flex_stock_confirmed($ticket_id, $total, $order_text);
        if (function_exists('b2b_push_guaranteed')) {
            b2b_push_guaranteed($group_id, array($flex), $ticket_id, 'stock_confirmed');
        } else {
            b2b_line_push_raw($group_id, array($flex));
        }
    }
    delete_transient($lock_key);
}

function b2b_action_stock_oos( $ticket_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    b2b_clear_sla_nag($ticket_id);
    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'checking_stock' ) { delete_transient($lock_key); b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ไม่ได้อยู่ในขั้นตอนเช็คสต็อกแล้วครับ"); return; }
    $flex = b2b_build_flex_oos_eta_select($ticket_id);
    b2b_line_reply_raw($reply_token, array($flex));
    delete_transient($lock_key);
}

function b2b_action_bo_set_eta( $ticket_id, $days, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    b2b_clear_sla_nag($ticket_id);
    b2b_set_order_status($ticket_id, 'backorder');
    if ($days > 0) {
        $eta_base = strtotime(b2b_date('Y-m-d') . " +{$days} days");
        if ($eta_base === false) $eta_base = time() + ($days * 86400);
        $eta_date = b2b_date('d/m/Y', $eta_base);
        update_field('bo_eta_date', b2b_date('Y-m-d', $eta_base), $ticket_id);
        $eta_text = "~{$days} วัน ({$eta_date})";
    } else { update_field('bo_eta_date', '', $ticket_id); $eta_text = 'ไม่มีกำหนด'; }
    $order_text = get_field('order_items', $ticket_id) ?: '';
    if ( preg_match_all('/\(([A-Z0-9\-]+)\)\s*x\d+/i', $order_text, $matches) ) {
        foreach ($matches[1] as $sku) b2b_mark_product_oos($sku, $days);
    }
    $admin_name = b2b_get_line_profile_name($user_id);
    b2b_line_reply($reply_token, "🚫 บันทึก ETA: ".$eta_text." (โดย ".$admin_name.")\nระบบแจ้งลูกค้าแล้วครับ");
    $group_id = get_field('source_group_id', $ticket_id);
    if ($group_id) { $flex = b2b_build_flex_oos_customer($ticket_id, $eta_text); if (function_exists('b2b_push_guaranteed')) { b2b_push_guaranteed($group_id, array($flex), $ticket_id, 'stock_oos'); } else { b2b_line_push_raw($group_id, array($flex)); } }
    delete_transient($lock_key);
}

function b2b_action_bo_wait( $ticket_id, $reply_token ) {
    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'backorder' ) { b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ไม่ได้อยู่ใน Backorder แล้วครับ (สถานะ: ".$status.")"); return; }
    b2b_set_order_status($ticket_id, 'backorder');
    $eta = get_field('bo_eta_date', $ticket_id);
    $eta_text = !empty($eta) ? b2b_parse_date($eta) : 'ไม่มีกำหนด';
    b2b_line_reply($reply_token, "⏳ รับทราบครับ ระบบจะแจ้งเมื่อสินค้ากลับมา\nETA: ".$eta_text."\n\nขอบคุณที่รอครับ 🙏");
}

function b2b_action_confirm_bill( $ticket_id, $group_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    b2b_clear_sla_nag($ticket_id);
    $status = get_field('order_status', $ticket_id);
    if ( !in_array($status, array('awaiting_confirm')) ) {
        delete_transient($lock_key);
        b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ดำเนินการไปแล้วครับ (สถานะ: ".$status.")");
        return;
    }

    $total = floatval(get_field('total_amount', $ticket_id));
    b2b_set_order_status($ticket_id, 'awaiting_payment');

    $dist = b2b_get_dist_by_group($group_id);
    $dist_name = $dist ? get_the_title($dist->ID) : 'Unknown';
    $term = 30;
    $due_date = '';

    if ( $dist ) {
        $was_billed = get_field('is_billed', $ticket_id);
        if ( !$was_billed && $total > 0 ) {
            $term = intval(get_field('credit_term_days', $dist->ID)) ?: 30;
            $due_date = b2b_date('Y-m-d', strtotime(b2b_date('Y-m-d') . ' +'.$term.' days'));
            global $wpdb;
            $wpdb->query('START TRANSACTION');
            $debt = (float) $wpdb->get_var($wpdb->prepare(
                "SELECT meta_value FROM {$wpdb->postmeta} WHERE post_id = %d AND meta_key = 'current_debt' FOR UPDATE",
                $dist->ID
            ));
            update_field('current_debt', round($debt + $total, 2), $dist->ID);
            $wpdb->query('COMMIT');
            update_field('due_date', $due_date, $ticket_id);
            update_field('is_billed', true, $ticket_id);
        } else {
            $due_date = get_field('due_date', $ticket_id);
            $term = intval(get_field('credit_term_days', $dist->ID)) ?: 30;
        }
    }

    b2b_line_reply($reply_token, "✅ ยืนยันบิลเรียบร้อย! Ticket #".$ticket_id."\nระบบกำลังส่งใบแจ้งหนี้ให้ครับ...");

    // V.31.0: Send admin-critical messages FIRST (before heavy invoice image generation)
    // — shipping choice + admin notification must not be blocked by slow GD rendering
    $items_raw = get_field('order_items', $ticket_id) ?: '';
    if ( function_exists('b2b_build_flex_shipping_choice') ) {
        $flex = b2b_build_flex_shipping_choice($ticket_id, $dist_name, $items_raw);
        if (function_exists('b2b_push_raw_to_admin')) b2b_push_raw_to_admin(array($flex));
        b2b_log('[ConfirmBill] Sent shipping choice Flex to admin — #'.$ticket_id);
    } else {
        b2b_push_to_admin("📦 เลือกวิธีจัดส่ง #".$ticket_id." — ".$dist_name." ยอด ฿".number_format($total,0));
    }
    // Auto-fallback: if admin doesn't choose within 1 hour, auto Flash + print
    wp_schedule_single_event(time() + HOUR_IN_SECONDS, 'b2b_auto_ship_flash_event', array($ticket_id));

    // V.32: Redundant text removed — shipping choice flex above already notifies admin

    // Send invoice Flex + image to customer (can be slower — not time-critical)
    $invoice_flex = b2b_build_flex_payment_invoice($ticket_id, $total, $dist_name, $due_date, $term);
    b2b_log('[Invoice] Sending Flex to '.$group_id.' — Ticket #'.$ticket_id.' Total: '.$total);
    if (function_exists('b2b_push_guaranteed')) {
        $result = b2b_push_guaranteed($group_id, array($invoice_flex), $ticket_id, 'bill_confirm');
    } else {
        $result = b2b_line_push_raw($group_id, array($invoice_flex));
    }
    b2b_log('[Invoice] Push result: '.wp_json_encode($result));

    // Invoice image generation (GD) — heaviest operation, runs last
    if (function_exists('b2b_send_invoice_image')) b2b_send_invoice_image($group_id, $ticket_id);

    delete_transient($lock_key);
}

function b2b_action_cancel_request( $ticket_id, $group_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    if ( get_post_type($ticket_id) !== 'b2b_order' ) { delete_transient($lock_key); b2b_line_reply($reply_token, "❌ ไม่พบ Ticket #".$ticket_id); return; }
