// V.30.0: RECEIPT IMAGE → AI READER (admin group only)
// ════════════════════════════════════════════════════════════════

function b2b_handle_receipt_image( $message_id, $group_id, $user_id, $reply_token ) {
    if ( !defined('B2B_ANTHROPIC_API_KEY') ) {
        b2b_line_reply($reply_token, "⚠️ ระบบอ่านใบเสร็จยังไม่ตั้งค่า (ต้องมี B2B_ANTHROPIC_API_KEY)");
        return;
    }

    // Rate limit per group
    $lock_key = 'b2b_receipt_lock_' . $group_id;
    if ( get_transient($lock_key) ) {
        b2b_line_reply($reply_token, "⏳ ระบบกำลังอ่านใบเสร็จก่อนหน้า กรุณารอสักครู่แล้วส่งใหม่ครับ");
        return;
    }
    set_transient($lock_key, 1, 120);

    b2b_line_reply($reply_token, "🔍 กำลังอ่านใบเสร็จ... กรุณารอสักครู่");

    // Download image from LINE
    try {
        $response = wp_remote_get('https://api-data.line.me/v2/bot/message/'.$message_id.'/content', array(
            'headers'=>array('Authorization'=>'Bearer '.B2B_LINE_ACCESS_TOKEN),'timeout'=>30,
        ));
    } catch ( Exception $e ) {
        b2b_log('[Receipt LINE API Error] ' . $e->getMessage());
        b2b_push_to_admin("⚠️ ดาวน์โหลดรูปใบเสร็จล้มเหลว: " . $e->getMessage());
        delete_transient($lock_key);
        return;
    }
    if ( is_wp_error($response) ) { b2b_log('[Receipt LINE API] wp_error: '.$response->get_error_message()); delete_transient($lock_key); return; }
    $image_binary = wp_remote_retrieve_body($response);
    if ( empty($image_binary) ) { delete_transient($lock_key); return; }

    // Detect actual MIME type from response header
    $content_type = wp_remote_retrieve_header($response, 'content-type');
    $mime = in_array($content_type, array('image/jpeg','image/png','image/webp')) ? $content_type : 'image/jpeg';
    $image_b64 = base64_encode($image_binary);

    // Call Claude API to read receipt
    $prompt = 'อ่านใบเสร็จขนส่งนี้ ดึงข้อมูลทุก tracking ที่พบเป็น JSON array:'
        . "\n" . '[{"tracking":"เลข tracking","recipient_name":"ชื่อผู้รับ","ticket_id":หมายเลข ticket ถ้ามี #ตัวเลข หลังชื่อ หรือ null,"carrier":"ชื่อขนส่ง เช่น Flash, KERRY, KEX, J&T, ไปรษณีย์"}]'
        . "\n" . 'ตอบเฉพาะ JSON array เท่านั้น ไม่ต้องอธิบาย ถ้าไม่พบ tracking ตอบ []';

    $claude_body = array(
        'model' => 'claude-sonnet-4-20250514',
        'max_tokens' => 2000,
        'messages' => array(array(
            'role' => 'user',
            'content' => array(
                array('type' => 'image', 'source' => array('type' => 'base64', 'media_type' => $mime, 'data' => $image_b64)),
                array('type' => 'text', 'text' => $prompt),
            ),
        )),
    );

    try {
        $claude_response = wp_remote_post('https://api.anthropic.com/v1/messages', array(
            'headers' => array(
                'x-api-key' => B2B_ANTHROPIC_API_KEY,
                'anthropic-version' => '2023-06-01',
                'content-type' => 'application/json',
            ),
            'body' => wp_json_encode($claude_body),
            'timeout' => 60,
        ));
    } catch ( Exception $e ) {
        b2b_log('[Receipt Claude API Error] ' . $e->getMessage());
        b2b_push_to_admin("⚠️ Claude API Error: " . $e->getMessage());
        delete_transient($lock_key);
        return;
    }

    if ( is_wp_error($claude_response) ) {
        b2b_log('[Receipt Claude] wp_error: '.$claude_response->get_error_message());
        b2b_push_to_admin("⚠️ Claude API Error: ".$claude_response->get_error_message());
        delete_transient($lock_key);
        return;
    }

    $claude_http = wp_remote_retrieve_response_code($claude_response);
    $claude_raw = wp_remote_retrieve_body($claude_response);
    b2b_log('[Receipt Claude] HTTP='.$claude_http.' Body='.mb_substr($claude_raw, 0, 500));

    if ( $claude_http !== 200 ) {
        b2b_push_to_admin("⚠️ Claude API Error (HTTP ".$claude_http.")\n".mb_substr($claude_raw, 0, 300));
        delete_transient($lock_key);
        return;
    }

    $claude_data = json_decode($claude_raw, true);
    $text_content = '';
    if ( isset($claude_data['content']) && is_array($claude_data['content']) ) {
        foreach ( $claude_data['content'] as $block ) {
            if ( isset($block['type']) && $block['type'] === 'text' ) { $text_content .= $block['text']; }
        }
    }

    // Extract JSON from response (may have markdown code fences)
    $json_text = $text_content;
    if ( preg_match('/\[[\s\S]*\]/u', $text_content, $jm) ) { $json_text = $jm[0]; }
    $trackings = json_decode($json_text, true);

    if ( !is_array($trackings) || empty($trackings) ) {
        b2b_push_to_admin("📋 อ่านใบเสร็จ — ไม่พบ tracking number\n\nAI Response: ".mb_substr($text_content, 0, 300));
        delete_transient($lock_key);
        return;
    }

    // Process each tracking — matching logic
    $results = array();
    foreach ( $trackings as $t ) {
        $tracking = isset($t['tracking']) ? sanitize_text_field(trim($t['tracking'])) : '';
        $recipient = isset($t['recipient_name']) ? sanitize_text_field(trim($t['recipient_name'])) : '';
        $tid = isset($t['ticket_id']) ? intval($t['ticket_id']) : 0;
        $carrier = isset($t['carrier']) ? sanitize_text_field(trim($t['carrier'])) : 'ไม่ระบุ';

        if ( empty($tracking) ) continue;

        $result = array('tracking' => $tracking, 'recipient' => $recipient, 'carrier' => $carrier, 'status' => 'unknown');

        if ( $tid > 0 ) {
            // Direct match by ticket ID
            if ( get_post_type($tid) === 'b2b_order' ) {
                $st = get_field('order_status', $tid);
                if ( in_array($st, array('packed','paid','awaiting_payment'), true) ) {
                    b2b_set_order_status($tid, 'shipped');
                    update_field('tracking_number', $tracking, $tid);
                    update_field('shipping_provider', $carrier, $tid);
                    update_field('shipped_date', b2b_date('Y-m-d H:i:s'), $tid);
                    wp_schedule_single_event(time() + (3 * DAY_IN_SECONDS), 'b2b_delivery_check_event', array($tid));
                    $group = get_field('source_group_id', $tid);
                    if ($group) { $flex = b2b_build_flex_shipped($tid, $tracking, $carrier); if (function_exists('b2b_push_guaranteed')) { b2b_push_guaranteed($group, array($flex), $tid, 'shipped'); } else { b2b_line_push_raw($group, array($flex)); } }
                    $result['status'] = 'matched';
                    $result['ticket_id'] = $tid;
                    $result['dist_name'] = b2b_get_dist_name_by_ticket($tid);
                } else {
                    $result['status'] = 'wrong_status';
                    $result['ticket_id'] = $tid;
                    $result['error'] = 'สถานะ: '.$st;
                }
            } else {
                $result['status'] = 'not_found';
                $result['ticket_id'] = $tid;
            }
        } else {
            // Try to match by recipient name
            $matched_tickets = b2b_find_tickets_by_recipient($recipient);
            if ( count($matched_tickets) === 1 ) {
                $mt = $matched_tickets[0];
                b2b_set_order_status($mt->ID, 'shipped');
                update_field('tracking_number', $tracking, $mt->ID);
                update_field('shipping_provider', $carrier, $mt->ID);
                update_field('shipped_date', b2b_date('Y-m-d H:i:s'), $mt->ID);
                wp_schedule_single_event(time() + (3 * DAY_IN_SECONDS), 'b2b_delivery_check_event', array($mt->ID));
                $group = get_field('source_group_id', $mt->ID);
                if ($group) { $flex = b2b_build_flex_shipped($mt->ID, $tracking, $carrier); if (function_exists('b2b_push_guaranteed')) { b2b_push_guaranteed($group, array($flex), $mt->ID, 'shipped'); } else { b2b_line_push_raw($group, array($flex)); } }
                $result['status'] = 'matched';
                $result['ticket_id'] = $mt->ID;
                $result['dist_name'] = get_the_title($mt->ID);
            } elseif ( count($matched_tickets) > 1 ) {
                $result['status'] = 'multiple';
                $result['candidates'] = array_map(function($p) { return $p->ID; }, $matched_tickets);
            } else {
                $result['status'] = 'no_match';
            }
        }
        $results[] = $result;
    }

    // Send result Flex to admin
    if ( function_exists('b2b_build_flex_receipt_result') ) {
        $flex = b2b_build_flex_receipt_result($results);
        if (function_exists('b2b_push_raw_to_admin')) b2b_push_raw_to_admin(array($flex));
    } else {
        $msg = "📋 อ่านใบเสร็จ — พบ ".count($results)." tracking\n\n";
        foreach ($results as $r) {
            $icon = $r['status'] === 'matched' ? '✅' : '❓';
            $msg .= $icon . ' ' . $r['tracking'];
            if (isset($r['ticket_id'])) $msg .= ' → #'.$r['ticket_id'];
            if (isset($r['dist_name'])) $msg .= ' ('.$r['dist_name'].')';
            if ($r['status'] === 'no_match') $msg .= ' — ไม่พบ ticket (ผู้รับ: '.$r['recipient'].')';
            $msg .= "\n";
        }
        b2b_push_to_admin($msg);
    }

    delete_transient($lock_key);
}

// Helper: find packed tickets matching recipient name
function b2b_find_tickets_by_recipient( $recipient ) {
    if ( empty($recipient) ) return array();
    $orders = get_posts(array(
        'post_type' => 'b2b_order', 'posts_per_page' => 50, 'post_status' => 'publish',
        'meta_query' => array(array('key' => 'order_status', 'value' => array('packed','paid','awaiting_payment'), 'compare' => 'IN')),
    ));
    $matches = array();
    foreach ( $orders as $o ) {
        $gid = get_field('source_group_id', $o->ID);
        $dist = $gid ? b2b_get_dist_by_group($gid) : null;
        if ( !$dist ) continue;
        $shop_name = get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID);
        // Fuzzy match: recipient contains shop name or vice versa
        if ( mb_stripos($recipient, $shop_name) !== false || mb_stripos($shop_name, $recipient) !== false ) {
            $matches[] = $o;
        }
    }
    return $matches;
}

// Helper: get distributor name by ticket
function b2b_get_dist_name_by_ticket( $ticket_id ) {
    $gid = get_field('source_group_id', $ticket_id);
    $dist = $gid ? b2b_get_dist_by_group($gid) : null;
    return $dist ? (get_field('shop_name', $dist->ID) ?: get_the_title($dist->ID)) : 'Unknown';
}

// ── Auto mark paid + V.7.5: returns paid_tickets[] + Flex per ticket ──
function b2b_auto_mark_paid_after_slip( $dist_id, $paid_amount, $group_id ) {
    $orders = get_posts(array(
        'post_type'=>'b2b_order','posts_per_page'=>50,'post_status'=>'publish',
        'meta_query'=>array(
            array('key'=>'order_status','value'=>'awaiting_payment'),
            array('key'=>'source_group_id','value'=>$group_id),
            // รวมทั้ง B2B orders และ manual invoices — slip matching ใช้ทั้ง 2 ระบบ
        ),
        'orderby'=>'date','order'=>'ASC',
    ));

    if (empty($orders)) return array('paid_tickets' => array(), 'remaining' => $paid_amount, 'unmatched' => array());

    $paid = $paid_amount;
    usort($orders, function($a, $b) use ($paid) {
        $da = abs(floatval(get_field('total_amount', $a->ID)) - $paid);
        $db = abs(floatval(get_field('total_amount', $b->ID)) - $paid);
        if (abs($da - $db) < 0.01) return strtotime($a->post_date) - strtotime($b->post_date);
        return $da <=> $db;
    });

    $remaining = $paid_amount;
    $paid_tickets = array();
    $matched_ids = array();

    foreach ($orders as $o) {
        $total = floatval(get_field('total_amount', $o->ID));
        if ($total <= 0) continue;
        if ($remaining >= $total * 0.98) { // FIX #7: ลด tolerance จาก 5% เหลือ 2%
            b2b_set_order_status($o->ID, 'paid');
            update_field('paid_date', b2b_date('Y-m-d H:i:s'), $o->ID);
            // ไม่ schedule SLA / ไม่ส่ง packing alert — สลิปคือจ่ายเงิน ไม่ใช่แพ็คของ
            $remaining -= $total;
            $matched_ids[] = $o->ID;

            $items_raw = get_field('order_items', $o->ID) ?: '';
            $items_preview = trim(mb_substr(preg_replace('/^.*?ขอยืนยัน[^:]*:\s*/u', '', $items_raw), 0, 100));
            if (empty($items_preview)) $items_preview = mb_substr($items_raw, 0, 100);
            $due_date = get_field('due_date', $o->ID) ?: '';

            $paid_tickets[] = array(
                'id' => $o->ID, 'total' => $total,
                'items_preview' => $items_preview, 'due_date' => $due_date,
            );

            // admin alert อยู่ใน Flex รวมแล้ว (b2b_build_flex_payment_admin_alert) — ไม่ต้องส่ง text ซ้ำ

            if ($remaining <= 0) break;
        }
    }

    // Build unmatched orders list (orders that weren't auto-paid)
    $unmatched = array();
    foreach ($orders as $o) {
        if (in_array($o->ID, $matched_ids)) continue;
        $total = floatval(get_field('total_amount', $o->ID));
        if ($total <= 0) continue;
        $unmatched[] = array(
            'id' => $o->ID,
            'total' => $total,
            'inv_number' => get_post_meta($o->ID, '_inv_number', true) ?: '#'.$o->ID,
        );
    }

    return array('paid_tickets' => $paid_tickets, 'remaining' => round($remaining, 2), 'unmatched' => $unmatched);
}

