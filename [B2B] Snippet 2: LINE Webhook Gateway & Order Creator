// V.30.0: Auto-fallback cron — if admin doesn't choose within 1 hour
add_action('b2b_auto_ship_flash_event', 'b2b_auto_ship_flash_handler');
function b2b_auto_ship_flash_handler( $ticket_id ) {
    $status = get_field('order_status', $ticket_id);
    if ( !in_array($status, array('paid','awaiting_payment'), true) ) return; // Already chosen
    // Auto Flash
    update_post_meta($ticket_id, '_ship_method', 'flash');
    update_field('shipping_provider', 'Flash', $ticket_id);
    if ( defined('B2B_FLASH_MCH_ID') && defined('B2B_FLASH_SECRET_KEY') && defined('B2B_FLASH_API_URL') && function_exists('b2b_flash_create_all_boxes') ) {
        $result = b2b_flash_create_all_boxes($ticket_id);
        if ( $result['ok'] ) {
            b2b_set_order_status($ticket_id, 'packed');
            if (function_exists('b2b_enqueue_print_job')) {
                b2b_enqueue_print_job($ticket_id);
                update_post_meta($ticket_id, '_flash_packing_status', 'print_queued');
            }
            if (function_exists('b2b_add_audit_log')) b2b_add_audit_log($ticket_id, 'auto_flash', '⏰ Auto Flash — ไม่มีคนเลือกขนส่งใน 1 ชม.');
            // ส่ง Flex Card รวม (แทน text ประหยัดโควต้า LINE)
            if (function_exists('b2b_build_flex_flash_admin') && function_exists('b2b_push_raw_to_admin')) {
                $auto_flex = b2b_build_flex_flash_admin($ticket_id, 'created', array(
                    'boxes' => $result['total_boxes'] . ' กล่อง: ' . implode(', ', $result['pnos']),
                    'auto'  => true,
                ));
                b2b_push_raw_to_admin(array($auto_flex));
            }
            return;
        }
    }
    // Flash failed — just print as manual fallback
    b2b_set_order_status($ticket_id, 'packed');
    update_post_meta($ticket_id, '_ship_method', 'manual');
    update_field('shipping_provider', '', $ticket_id);
    if (function_exists('b2b_enqueue_print_job')) b2b_enqueue_print_job($ticket_id);
    if (function_exists('b2b_add_audit_log')) b2b_add_audit_log($ticket_id, 'auto_manual_fallback', '⏰ Auto-fallback ส่งเอง (Flash ล้มเหลว)');
    // V.32: Flex card instead of plain text
    if (function_exists('b2b_build_flex_flash_admin')) {
        $flex = b2b_build_flex_flash_admin($ticket_id, 'auto_fallback', array('message'=>'Flash ล้มเหลว → พิมพ์ label ส่งเอง'));
        if (function_exists('b2b_push_raw_to_admin')) b2b_push_raw_to_admin(array($flex));
    } else {
        b2b_push_to_admin("⏰ Auto-fallback Ticket #".$ticket_id."\nFlash ล้มเหลว → พิมพ์ label ส่งเอง\nกรุณาตรวจสอบ");
    }
}

