            b2b_log('[Slip] Processing queued slip ' . $next['message_id'] . ' for group ' . $group_id);
            b2b_handle_slip_image($next['message_id'], $group_id, $next['user_id'], '', $manual_mode);
        }
    }
    // ลบ queue ว่าง
    if (empty($queue)) delete_option('b2b_slip_queue_' . $group_id);
