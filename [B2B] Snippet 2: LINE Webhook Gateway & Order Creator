function b2b_action_bo_accept_partial( $ticket_id, $group_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'backorder' ) {
        delete_transient($lock_key);
        b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ไม่ได้อยู่ใน Backorder แล้วครับ");
        return;
    }

    $bo_json = get_field('bo_available_qty', $ticket_id);
    $bo_data = !empty($bo_json) ? json_decode($bo_json, true) : array();
    if ( empty($bo_data) || !is_array($bo_data) ) {
        b2b_line_reply($reply_token, "❌ ยังไม่มีข้อมูลจำนวนสินค้าที่มี กรุณารอ Admin กรอกข้อมูลก่อนครับ");
        return;
    }

    update_field('bo_customer_response', 'accept_partial', $ticket_id);

    $shipped_items = array();
    $remaining_items = array();
    $shipped_total = 0;
    $original_total = floatval(get_field('total_amount', $ticket_id));

    foreach ( $bo_data as $item ) {
        $ordered   = intval($item['ordered']);
        $available = intval($item['available']);
        $name      = isset($item['name']) ? $item['name'] : (isset($item['sku']) ? $item['sku'] : 'สินค้า');
        $unit_price = isset($item['unit_price']) ? floatval($item['unit_price']) : 0;

        if ( $available > 0 ) {
            $shipped_items[] = array('name'=>$name, 'qty'=>min($available, $ordered));
            $shipped_total += round($unit_price * min($available, $ordered), 2); // FIX #9: Float precision
        }
        $diff = $ordered - $available;
        if ( $diff > 0 ) {
            $remaining_items[] = array('name'=>$name, 'qty'=>$diff, 'unit_price'=>$unit_price);
        }
    }

    if ( $shipped_total <= 0 && $original_total > 0 ) $shipped_total = $original_total;

    update_field('total_amount', $shipped_total, $ticket_id);
    b2b_set_order_status($ticket_id, 'awaiting_confirm');
    b2b_schedule_sla_alert($ticket_id);

    $sub_index = function_exists('b2b_get_next_sub_index') ? b2b_get_next_sub_index($ticket_id) : 1;
    $sub_post_id = wp_insert_post(array(
        'post_title'  => 'Order-'.b2b_date('Ymd-His').'-BO-'.$sub_index,
        'post_type'   => 'b2b_order',
        'post_status' => 'publish',
        'post_author' => 1,
    ));

    if ( $sub_post_id && !is_wp_error($sub_post_id) ) {
        $remaining_text = '';
        $remaining_total = 0;
        foreach ( $remaining_items as $ri ) {
            $remaining_text .= $ri['name'] . ' x' . $ri['qty'] . "\n";
            $remaining_total += round(($ri['unit_price'] ?? 0) * $ri['qty'], 2); // FIX #9: Float precision
        }
        b2b_set_order_status($sub_post_id, 'backorder');
        update_field('source_group_id', get_field('source_group_id', $ticket_id), $sub_post_id);
        update_field('order_items', trim($remaining_text), $sub_post_id);
        update_field('total_amount', $remaining_total, $sub_post_id);
        update_field('orderer_display_name', get_field('orderer_display_name', $ticket_id), $sub_post_id);
        update_field('orderer_user_id', get_field('orderer_user_id', $ticket_id), $sub_post_id);
        update_field('parent_ticket_id', $ticket_id, $sub_post_id);
        update_field('sub_ticket_index', $sub_index, $sub_post_id);
        update_field('is_billed', false, $sub_post_id);
        $note = get_field('customer_note', $ticket_id);
        if ( $note ) update_field('customer_note', $note, $sub_post_id);
        // V.22: Copy distributor address from parent ticket
        foreach (array('dist_name','dist_phone','dist_address','dist_district','dist_city','dist_province','dist_postcode') as $af) {
            $v = get_field($af, $ticket_id);
            if ( !empty($v) ) update_field($af, $v, $sub_post_id);
        }
    }

    if ( function_exists('b2b_build_flex_bo_accepted') && $sub_post_id ) {
        $flex = b2b_build_flex_bo_accepted($ticket_id, $shipped_total, $shipped_items, $sub_post_id, $remaining_items);
        b2b_line_reply_raw($reply_token, array($flex));
    } else {
        $sub_label = function_exists('b2b_get_sub_ticket_label') ? b2b_get_sub_ticket_label($sub_post_id) : '#'.$sub_post_id;
        b2b_line_reply($reply_token, "✅ รับสินค้าบางส่วน Ticket #".$ticket_id."\nยอด ฿".number_format($shipped_total,0)."\nรายการที่เหลือ → ".$sub_label." (backorder)");
    }

    $sub_label = function_exists('b2b_get_sub_ticket_label') ? b2b_get_sub_ticket_label($sub_post_id) : '#'.$sub_post_id;
    b2b_push_to_admin("✅ ลูกค้ารับ partial #".$ticket_id." ยอด ฿".number_format($shipped_total,0)."\n⏳ สร้าง sub-ticket ".$sub_label." สำหรับของที่เหลือ (".count($remaining_items)." รายการ)");
    delete_transient($lock_key);
}

