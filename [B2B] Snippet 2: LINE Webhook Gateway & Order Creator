// V.31: SLIP-TO-INVOICE MANUAL MATCHING — POSTBACK HANDLER
// ═══════════════════════════════════════════════════════════════

function b2b_action_slip_pay( $ticket_id, $params, $group_id, $user_id, $reply_token ) {
    $slip_ref = isset($params['slip_ref']) ? sanitize_text_field($params['slip_ref']) : '';
    if ( empty($slip_ref) ) {
        b2b_line_reply($reply_token, "❌ ข้อมูลสลิปไม่ถูกต้อง กรุณาส่งสลิปใหม่ครับ");
        return;
    }

    $slip_data = get_transient('b2b_slip_' . $slip_ref);
    if ( !$slip_data ) {
        b2b_line_reply($reply_token, "⏰ หมดเวลาเลือกบิลแล้ว กรุณาส่งสลิปใหม่ครับ");
        return;
    }

    // Validate group ownership
    if ( $slip_data['group_id'] !== $group_id ) {
        b2b_line_reply($reply_token, "⛔ สลิปนี้ไม่ใช่ของกลุ่มนี้ครับ");
        return;
    }

    // Validate ticket status
    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'awaiting_payment' ) {
        b2b_line_reply($reply_token, "ℹ️ บิล #".$ticket_id." ไม่ได้อยู่ในสถานะรอชำระแล้วครับ");
        return;
    }

    // Advisory lock — prevent double-tap
    $lock_key = 'b2b_lock_slip_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        b2b_line_reply($reply_token, "⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่");
        return;
    }
    set_transient($lock_key, 1, 10);

    $ticket_total = floatval(get_field('total_amount', $ticket_id));
    $slip_remaining = floatval($slip_data['remaining']);
    $inv_no = get_post_meta($ticket_id, '_inv_number', true) ?: '#'.$ticket_id;

    // Check if slip amount covers the invoice (with 2% tolerance)
    if ( $slip_remaining < $ticket_total * 0.98 ) {
        b2b_line_reply($reply_token, "⚠️ ยอดสลิปไม่พอชำระบิลนี้เต็มจำนวน\n\nยอดสลิปคงเหลือ: ฿".number_format($slip_remaining,2)."\nยอดบิล ".$inv_no.": ฿".number_format($ticket_total,2)."\n\nกรุณาส่งสลิปเพิ่มเติมครับ");
        delete_transient($lock_key);
        return;
    }

    // Mark as paid — debt was already deducted when slip was processed, do NOT deduct again
    b2b_set_order_status($ticket_id, 'paid');
    update_field('paid_date', b2b_date('Y-m-d H:i:s'), $ticket_id);

    // Send confirmation Flex reply
    $logo = function_exists('b2b_get_logo_url') ? b2b_get_logo_url() : 'https://dinoco.in.th/wp-content/uploads/dinoco-logo.png';
    $confirm_flex = array('type'=>'bubble','size'=>'kilo',
        'header'=>array('type'=>'box','layout'=>'horizontal','backgroundColor'=>'#16a34a','paddingAll'=>'14px','contents'=>array(
            array('type'=>'image','url'=>$logo,'size'=>'xxs','aspectMode'=>'fit','flex'=>0),
            array('type'=>'box','layout'=>'vertical','flex'=>1,'margin'=>'md','contents'=>array(
                array('type'=>'text','text'=>'✅ ชำระบิลสำเร็จ','color'=>'#ffffff','size'=>'sm','weight'=>'bold'),
                array('type'=>'text','text'=>'Manual Matching','color'=>'#bbf7d0','size'=>'xxs'))))),
        'body'=>array('type'=>'box','layout'=>'vertical','contents'=>array(
            array('type'=>'box','layout'=>'horizontal','contents'=>array(
                array('type'=>'text','text'=>'บิล','size'=>'xs','color'=>'#64748b','flex'=>2),
                array('type'=>'text','text'=>$inv_no,'size'=>'sm','weight'=>'bold','flex'=>4,'align'=>'end'))),
            array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>'ยอดชำระ','size'=>'xs','color'=>'#64748b','flex'=>2),
                array('type'=>'text','text'=>'฿'.number_format($ticket_total,2),'size'=>'md','weight'=>'bold','color'=>'#16a34a','flex'=>4,'align'=>'end'))),
            array('type'=>'box','layout'=>'horizontal','margin'=>'sm','contents'=>array(
                array('type'=>'text','text'=>'Ref','size'=>'xxs','color'=>'#94a3b8','flex'=>2),
                array('type'=>'text','text'=>$slip_data['trans_ref'] ?: '-','size'=>'xxs','color'=>'#94a3b8','flex'=>4,'align'=>'end'))),
        )));
    b2b_line_reply_raw($reply_token, array(array('type'=>'flex','altText'=>'✅ ชำระบิล '.$inv_no.' สำเร็จ','contents'=>$confirm_flex)));

    // Notify admin
    $dist_name = $slip_data['dist_id'] ? get_the_title($slip_data['dist_id']) : 'ไม่ทราบ';
    b2b_push_to_admin("💳 ชำระ manual — Ticket #".$ticket_id." (".$inv_no.") ฿".number_format($ticket_total,0)."\nร้าน: ".$dist_name."\nRef: ".($slip_data['trans_ref'] ?: '-'));

    // Clean up transient after use
    delete_transient('b2b_slip_' . $slip_ref);
    delete_transient($lock_key);
}

