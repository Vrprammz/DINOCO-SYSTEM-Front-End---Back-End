function b2b_action_bo_cancel_all( $ticket_id, $group_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ( $reply_token ) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 10);

    $status = get_field('order_status', $ticket_id);
    if ( $status !== 'backorder' ) {
        delete_transient($lock_key);
        b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ไม่ได้อยู่ใน Backorder แล้วครับ");
        return;
    }
    update_field('bo_customer_response', 'cancel', $ticket_id);
    b2b_set_order_status($ticket_id, 'cancelled');

    $was_billed = get_field('is_billed', $ticket_id);
    $total = floatval(get_field('total_amount', $ticket_id));
    if ( $was_billed && $total > 0 ) {
        $dist = b2b_get_dist_by_group($group_id);
        if ( $dist ) {
            $debt = floatval(get_field('current_debt', $dist->ID));
            update_field('current_debt', max(0, $debt - $total), $dist->ID);
            update_field('is_billed', false, $ticket_id);
        }
    }

    b2b_line_reply($reply_token, "❌ ยกเลิก Ticket #".$ticket_id." เรียบร้อยครับ".($was_billed && $total > 0 ? "\n💰 คืน credit ฿".number_format($total,0)." แล้ว" : ""));

    $dist = b2b_get_dist_by_group($group_id);
    $dist_name = $dist ? get_the_title($dist->ID) : 'N/A';
    b2b_push_to_admin("❌ ลูกค้ายกเลิก BO #".$ticket_id." (".$dist_name.")".($was_billed && $total > 0 ? " — คืน credit ฿".number_format($total,0) : ""));
    delete_transient($lock_key);
}

