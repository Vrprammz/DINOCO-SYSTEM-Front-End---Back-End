function b2b_handle_sla_alert( $ticket_id ) {
    if ( get_post_type($ticket_id) !== 'b2b_order' ) return;
    $status = get_field('order_status', $ticket_id);
    $stuck_statuses = array(
        'checking_stock'   => '⏱️ รอเช็คสต็อก',
        'awaiting_confirm' => '📋 รอยืนยันราคา',
        'cancel_requested' => '⚠️ ลูกค้าขอยกเลิก',
        'change_requested' => '✏️ ลูกค้าขอแก้ไข',
        'claim_opened'     => '↩️ เคลมรอดำเนินการ',
        // 'paid' ไม่ใช่ stuck — จ่ายเงินเสร็จแล้ว ไม่ต้อง nag admin
    );
    if ( ! isset($stuck_statuses[$status]) ) return;
    $nag_count = intval(get_post_meta($ticket_id, '_sla_nag_count', true)) + 1;
    update_post_meta($ticket_id, '_sla_nag_count', $nag_count);
    $interval = 600;
    if ($nag_count >= 6)  $interval = 1800;
    if ($nag_count >= 12) $interval = 3600;
    $flex = b2b_build_flex_sla_alert($ticket_id);
    if (function_exists('b2b_push_raw_to_admin')) b2b_push_raw_to_admin(array($flex));
    if ($nag_count < 12) { // FIX #8: ลด max nags จาก 30 เป็น 12 ครั้ง
        wp_schedule_single_event(time() + $interval, 'b2b_sla_alert_event', array($ticket_id));
    }
}

