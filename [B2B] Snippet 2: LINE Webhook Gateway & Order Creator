// ════════════════════════════════════════════
// MAIN WEBHOOK HANDLER
// ════════════════════════════════════════════
function b2b_process_line_webhook( WP_REST_Request $request ) {

    if ( ! b2b_check_constants() ) return new WP_REST_Response('Config Error', 500);

    $body_raw  = $request->get_body();
    $signature = $request->get_header('x-line-signature');

    if ( empty($signature) ) return new WP_REST_Response('Bad Request', 400);
    $hash = base64_encode( hash_hmac('sha256', $body_raw, B2B_LINE_CHANNEL_SECRET, true) );
    if ( ! hash_equals($hash, $signature) ) return new WP_REST_Response('Unauthorized', 401);

    // V.18.0: Trigger WP cron check — WP pseudo-cron ต้องมี page load ถึงจะ fire
    // Webhook ถูกเรียกบ่อย → ใช้เป็น cron trigger ที่เชื่อถือได้
    if ( function_exists('spawn_cron') ) spawn_cron();

    $body = json_decode($body_raw, true);
    if ( !isset($body['events']) || !is_array($body['events']) ) return new WP_REST_Response('OK', 200);

    foreach ( $body['events'] as $event ) {
      try {
        $type        = isset($event['type']) ? $event['type'] : '';
        $source      = isset($event['source']) ? $event['source'] : array();
        $group_id    = isset($source['groupId']) ? sanitize_text_field($source['groupId']) : (isset($source['roomId']) ? sanitize_text_field($source['roomId']) : 'Private_Chat');
        $user_id     = isset($source['userId']) ? sanitize_text_field($source['userId']) : '';
        $reply_token = isset($event['replyToken']) ? $event['replyToken'] : '';

        // ── Dedup — ป้องกัน LINE webhook retry ──
        $msg_id = isset($event['message']['id']) ? $event['message']['id'] : '';
        if ( $msg_id && get_transient('b2b_dedup_' . $msg_id) ) {
            b2b_log('[Webhook] Skipped duplicate message: ' . $msg_id);
            continue;
        }
        if ( $msg_id ) set_transient('b2b_dedup_' . $msg_id, 1, 300);
        // Postback dedup — ใช้ timestamp + data hash
        if ( $type === 'postback' ) {
            $pb_ts = isset($event['timestamp']) ? $event['timestamp'] : '';
            $pb_data = isset($event['postback']['data']) ? $event['postback']['data'] : '';
            $pb_key = 'b2b_pb_' . md5($user_id . $pb_data . $pb_ts);
            if ( get_transient($pb_key) ) {
                b2b_log('[Webhook] Skipped duplicate postback: ' . $pb_data);
                continue;
            }
            set_transient($pb_key, 1, 30);
        }

        // Bot enabled check — direct DB query, bypass ALL WordPress cache
        $is_admin_group = (defined('B2B_ADMIN_GROUP_ID') && $group_id === B2B_ADMIN_GROUP_ID);
        $_bot_disabled = false;
        $_unregistered_group = false;
        if ( !$is_admin_group && $group_id !== 'Private_Chat' ) {
            global $wpdb;
            // เช็คว่า group นี้ลงทะเบียนเป็น distributor หรือยัง
            $dist_id = $wpdb->get_var($wpdb->prepare(
                "SELECT p.ID
                 FROM {$wpdb->postmeta} pm1
                 JOIN {$wpdb->posts} p ON p.ID = pm1.post_id AND p.post_type = 'distributor' AND p.post_status = 'publish'
                 WHERE pm1.meta_key = 'line_group_id' AND pm1.meta_value = %s
                 LIMIT 1",
                $group_id
            ));
            if ( !$dist_id ) {
                // กลุ่มไม่ได้ลงทะเบียน — block ทุกอย่างยกเว้น "ขอไอดี"
                $_unregistered_group = true;
            } else {
                $bot_val = get_post_meta($dist_id, 'bot_enabled', true);
                if ( $bot_val === '0' ) {
                    $_bot_disabled = true;
                }
            }
        }

        // กลุ่มไม่ได้ลงทะเบียน — อนุญาตแค่ "ขอไอดี" เท่านั้น
        if ( $_unregistered_group ) {
            if ( $type === 'message' && isset($event['message']['type']) && $event['message']['type'] === 'text' ) {
                $t = trim($event['message']['text'] ?? '');
                if ( strpos($t, 'ขอไอดีกลุ่ม') !== false || strpos($t, 'ไอดีกลุ่ม') !== false || strtolower($t) === 'groupid' ) {
                    b2b_route_bot_command($t, $group_id, $user_id, $reply_token);
                }
            }
            continue;
        }

        if ( $type === 'message' && isset($event['message']['type']) ) {
            if ( $event['message']['type'] === 'text' && isset($event['message']['text']) ) {
                // Bot disabled — still allow "ขอไอดี" / "groupid" for setup, block everything else
                if ( $_bot_disabled ) {
                    $t = trim($event['message']['text']);
                    if ( strpos($t, 'ขอไอดีกลุ่ม') === false && strpos($t, 'ไอดีกลุ่ม') === false && strtolower($t) !== 'groupid' ) {
                        b2b_log('[Bot] Disabled for group ' . $group_id . ' — ignoring text: ' . $t);
                        continue;
                    }
                }
                b2b_route_bot_command( trim($event['message']['text']), $group_id, $user_id, $reply_token );
            }
            elseif ( $event['message']['type'] === 'image' && isset($event['message']['id']) ) {
                // สลิปทำงานเสมอ — bot ปิด = simple flex, bot เปิด = B2B full flex
                // V.30.0: Admin group images → receipt reader, customer group → slip verification
                if ( $is_admin_group && function_exists('b2b_handle_receipt_image') ) {
                    b2b_handle_receipt_image( $event['message']['id'], $group_id, $user_id, $reply_token );
                } else {
                    b2b_handle_slip_image( $event['message']['id'], $group_id, $user_id, $reply_token, $_bot_disabled );
                }
            }
        }
        elseif ( $type === 'postback' ) {
            $data = isset($event['postback']['data']) ? $event['postback']['data'] : '';
            // Bot disabled — block ทุก postback ยกเว้น slip_pay (เลือกบิลจากสลิป)
            if ( $_bot_disabled && strpos($data, 'action=slip_pay') === false ) continue;
            b2b_handle_postback( $data, $group_id, $user_id, $reply_token );
        }
      } catch ( Exception $e ) {
        b2b_log('[WEBHOOK ERROR] ' . $e->getMessage() . ' in ' . $e->getFile() . ':' . $e->getLine());
      } catch ( Error $e ) {
        b2b_log('[WEBHOOK FATAL] ' . $e->getMessage() . ' in ' . $e->getFile() . ':' . $e->getLine());
      }
    }

    return new WP_REST_Response('OK', 200);
}

// ════════════════════════════════════════════
// TEXT COMMAND ROUTER (V.7.3 — Production-Ready)
// ════════════════════════════════════════════
function b2b_route_bot_command( $text, $group_id, $user_id, $reply_token ) {

    b2b_log("Router RAW: text=[{$text}] group={$group_id}");
    $is_admin = (defined('B2B_ADMIN_GROUP_ID') && $group_id === B2B_ADMIN_GROUP_ID);

    // ══════════════════════════════════
    // STEP 0: Normalize text — strip @mention ชื่อ bot ออก
    // ══════════════════════════════════
    $raw_text = $text;
    $text = preg_replace('/^@?DINOCO\s*B2B\s*System\s*/ui', '', $text);
    $text = preg_replace('/^@?dinoco\s*/ui', '', $text);
    if (preg_match('/^@[A-Za-z\s]+$/u', $text)) {
        $text = preg_replace('/^@\S+\s*/u', '', $text);
    }
    $text = trim($text);

    // V.7.3: @mention bot เฉยๆ → Flex เมนูคำสั่ง
    if (empty($text)) {
        $flex = $is_admin ? b2b_build_flex_command_menu_admin() : b2b_build_flex_command_menu_customer($group_id);
        b2b_line_reply_raw($reply_token, array($flex));
        return;
    }

    b2b_log("Router CLEAN: text=[{$text}] admin=".($is_admin?'YES':'NO'));

    // ══════════════════════════════════
    // UNIVERSAL COMMANDS (always allowed even when bot is disabled)
    // ══════════════════════════════════
    // V.14.0: Allow all users to see group ID (needed for initial setup)
    if ( strpos($text, 'ขอไอดี') !== false || strpos($text, 'ไอดีกลุ่ม') !== false || strtolower($text) === 'groupid' ) {
        $msg = "🆔 ไอดีของกลุ่มนี้คือ:\n".$group_id;
        if ($is_admin) {
            $msg .= "\n✅ (กลุ่มนี้เป็น Admin Group)";
        } else {
            $_dist_check = get_posts(array('post_type'=>'distributor','posts_per_page'=>1,'meta_query'=>array(array('key'=>'line_group_id','value'=>$group_id))));
            if (!empty($_dist_check)) {
                $msg .= "\n✅ กลุ่มนี้ผูกกับตัวแทน: " . get_field('shop_name', $_dist_check[0]->ID);
            }
        }
        b2b_line_reply($reply_token, $msg);
        return;
    }
    if ( $text === 'คำสั่ง' || $text === '@คำสั่ง' || strtolower($text) === 'help' || $text === '?' || $text === 'เมนู' ) {
        $flex = $is_admin ? b2b_build_flex_command_menu_admin() : b2b_build_flex_command_menu_customer($group_id);
        b2b_line_reply_raw($reply_token, array($flex));
        return;
    }

    // ══════════════════════════════════
    // BOT ENABLED CHECK — if bot is disabled for this group, stop responding
    // Server-push messages (Flex, Invoice) still work because they don't go through this function
    // ══════════════════════════════════
    if ( !$is_admin && $group_id !== 'Private_Chat' ) {
        $dist = get_posts(array('post_type'=>'distributor','posts_per_page'=>1,'meta_query'=>array(array('key'=>'line_group_id','value'=>$group_id))));
        if ( !empty($dist) && metadata_exists('post', $dist[0]->ID, 'bot_enabled') ) {
            if ( !get_post_meta($dist[0]->ID, 'bot_enabled', true) ) {
                b2b_log('[Bot] Disabled for group ' . $group_id . ' — ignoring: ' . $text);
                return; // Silent — don't reply anything
            }
        }
    }

    // ══════════════════════════════════
    // CUSTOMER COMMANDS
    // ══════════════════════════════════
    if ( strpos($text,'@สั่งของ')!==false || strpos($text,'สั่งของ')!==false || strpos($text,'สั้งของ')!==false
      || $text === 'สั่ง' || $text === 'order' ) {
        if ($is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่งนี้ใช้ได้เฉพาะในกลุ่มตัวแทนจำหน่ายเท่านั้นครับ"); return; }
        b2b_send_liff_catalog_flex($reply_token, $group_id);
        return;
    }
    if ( strpos($text, 'ขอยืนยันสั่งสินค้า') !== false ) {
        if ($is_admin) { return; }
        b2b_create_draft_order($text, $group_id, $user_id, $reply_token);
        return;
    }
    if ( preg_match('/@?เคลม\s*#?(\d+)/u', $text, $m) ) {
        if ($is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง 'เคลม' ใช้ได้เฉพาะในกลุ่มตัวแทนครับ"); return; }
        b2b_handle_claim_request( intval($m[1]), $group_id, $user_id, $reply_token );
        return;
    }
    if ( preg_match('/@?ยกเลิก\s*#?(\d+)/u', $text, $m) ) {
        if ($is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง 'ยกเลิก' ลูกค้าใช้ได้เฉพาะในกลุ่มตัวแทนครับ\nAdmin ใช้ postback button แทน"); return; }
        b2b_action_cancel_request( intval($m[1]), $group_id, $user_id, $reply_token );
        return;
    }
    if ( preg_match('/เช็คสถานะ\s*#?(\d+)/u', $text, $m) ) {
        if ($is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง 'เช็คสถานะ' ใช้ได้เฉพาะในกลุ่มตัวแทนครับ"); return; }
        b2b_handle_check_ticket_status(intval($m[1]), $group_id, $reply_token);
        return;
    }
    if ( !$is_admin && (strpos($text,'เช็คหนี้')!==false || strpos($text,'ยอดค้าง')!==false
      || strpos($text,'หนี้')!==false || $text==='@หนี้') ) {
        b2b_handle_customer_debt_check($group_id, $reply_token);
        return;
    }
    if ( strpos($text,'สถานะออเดอร์')!==false || strpos($text,'@สถานะ')!==false
      || strpos($text,'ประวัติ')!==false || $text==='@ประวัติ' || $text==='สถานะ' ) {
        if ($is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่งนี้ใช้ได้เฉพาะในกลุ่มตัวแทนครับ\nใช้ 'สรุปออเดอร์' แทน"); return; }
        b2b_handle_order_status_inquiry($group_id, $reply_token);
        return;
    }

    // ══════════════════════════════════
    // ADMIN COMMANDS
    // ══════════════════════════════════
    if ( preg_match('/รับงาน\s*#?(\d+)/u', $text, $m) ) {
        if (!$is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง 'รับงาน' ใช้ได้เฉพาะในกลุ่ม Admin ครับ"); return; }
        b2b_claim_order_ticket(intval($m[1]), $user_id, $reply_token);
        return;
    }
    if ( $text === 'รับงาน' ) {
        if (!$is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง 'รับงาน' ใช้ได้เฉพาะในกลุ่ม Admin ครับ"); return; }
        b2b_line_reply($reply_token, "⚠️ กรุณาระบุเลข Ticket เช่น: รับงาน 4589");
        return;
    }
    if ( preg_match('/เลขพัสดุ\s*#?(\d+)\s+(\S+)\s+(.+)$/u', $text, $m) ) {
        if (!$is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง 'เลขพัสดุ' ใช้ได้เฉพาะในกลุ่ม Admin ครับ"); return; }
        b2b_handle_tracking_input( intval($m[1]), trim($m[2]), trim($m[3]), $user_id, $reply_token );
        return;
    }
    if ( strpos($text, '@แอดมิน') !== false || strpos($text, '@admin') !== false ) {
        if (!$is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่ง Admin ใช้ได้เฉพาะในกลุ่ม Admin ครับ"); return; }
        $cmd = preg_replace('/^@แอดมิน\s*|^@admin\s*/ui', '', $text);
        b2b_handle_admin_chatops(trim($cmd), $group_id, $user_id, $reply_token);
        return;
    }
    // V.31.0: Admin cancel command: @admincancel #[ticket_id]
    if ( preg_match('/^@(?:admincancel|ยกเลิกเลย)\s*#?(\d+)/iu', $text, $m) ) {
        if (!$is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่งนี้ใช้ได้เฉพาะในกลุ่ม Admin ครับ"); return; }
        $tid = intval($m[1]);
        if ( $tid && get_post_type($tid) === 'b2b_order' ) {
            $status = get_field('order_status', $tid);
            $non_cancellable = array('cancelled', 'completed', 'claim_resolved');
            if ( in_array($status, $non_cancellable, true) ) {
                b2b_line_reply($reply_token, "❌ ออเดอร์ #{$tid} ไม่สามารถยกเลิกได้ (สถานะ: {$status})");
                return;
            }
            // Use advisory lock
            $lock_key = 'b2b_lock_' . $tid;
            if ( get_transient($lock_key) ) {
                b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่');
                return;
            }
            set_transient($lock_key, 1, 10);

            // Reverse debt if billed
            $prev_status = $status;
            if ( in_array($status, array('awaiting_payment', 'paid', 'packed', 'shipped'), true) ) {
                $total = floatval(get_field('total_amount', $tid));
                $gid = get_field('source_group_id', $tid);
                $dist = $gid ? b2b_get_dist_by_group($gid) : null;
                if ( $dist && $total > 0 ) {
                    global $wpdb;
                    $wpdb->query('START TRANSACTION');
                    $debt = (float) $wpdb->get_var($wpdb->prepare(
                        "SELECT meta_value FROM {$wpdb->postmeta} WHERE post_id = %d AND meta_key = 'current_debt' FOR UPDATE",
                        $dist->ID
                    ));
                    update_field('current_debt', max(0, round($debt - $total, 2)), $dist->ID);
                    $wpdb->query('COMMIT');
                }
            }

            update_field('cancel_prev_status', $prev_status, $tid);
            b2b_set_order_status($tid, 'cancelled');

            // Notify customer
            $group_id_notify = get_field('source_group_id', $tid);
            if ($group_id_notify) {
                b2b_line_push($group_id_notify, "❌ ออเดอร์ #{$tid} ถูกยกเลิกโดยทีมงาน");
            }

            delete_transient($lock_key);
            b2b_line_reply($reply_token, "✅ ยกเลิกออเดอร์ #{$tid} เรียบร้อย (สถานะเดิม: {$prev_status})");
            b2b_log("[AdminCancel] #{$tid} cancelled by admin (was: {$prev_status})");
            return;
        }
    }
    // V.31.0: Reprint command: @reprint #[ticket_id]
    if ( preg_match('/^@(?:reprint|พิมพ์ใหม่)\s*#?(\d+)/iu', $text, $m) ) {
        if (!$is_admin) { b2b_line_reply($reply_token, "⚠️ คำสั่งนี้ใช้ได้เฉพาะในกลุ่ม Admin ครับ"); return; }
        $tid = intval($m[1]);
        if ( $tid && get_post_type($tid) === 'b2b_order' ) {
            update_field('print_status', 'queued', $tid);
            b2b_line_reply($reply_token, "🖨️ ส่งคำสั่งพิมพ์ใหม่ออเดอร์ #{$tid} เรียบร้อย");
            b2b_log("[Reprint] #{$tid} re-queued by admin via LINE");
            return;
        }
    }
    if ( $is_admin ) {
        $admin_keywords = array(
            'เช็คของ','จัดส่ง','พร้อมส่ง','ค้างส่ง','ออเดอร์ค้าง',
            'รอยืนยัน','รอชำระ','สรุปยอด','สรุปออเดอร์','ยอดขาย','ยอดวันนี้',
            'เช็คหนี้','หนี้ค้าง','backorder','แบ็คออเดอร์','รอของ',
            'ปลดล็อก','เช็คสต็อก','สรุป','เลขพัสดุ','กรอกเลข','tracking',
        );
        foreach ($admin_keywords as $kw) {
            if ( strpos($text, $kw) !== false ) {
                b2b_handle_admin_chatops($text, $group_id, $user_id, $reply_token);
                return;
            }
        }
    }

    // NO MATCH
    if ( mb_substr($text, 0, 1) === '@' || mb_substr($raw_text, 0, 1) === '@' ) {
        b2b_line_reply($reply_token, "❓ ไม่รู้จักคำสั่ง: \"".$text."\"\nพิมพ์ \"คำสั่ง\" เพื่อดูรายการทั้งหมด");
    }
}

// ════════════════════════════════════════════════════════════════
// POSTBACK HANDLER (Phase 1-3 ทุก Action)
// ════════════════════════════════════════════════════════════════
function b2b_handle_postback( $postback_data, $group_id, $user_id, $reply_token ) {

    parse_str($postback_data, $params);
    $action    = isset($params['action'])    ? $params['action']              : '';
    $ticket_id = isset($params['ticket_id']) ? intval($params['ticket_id'])   : 0;

    b2b_log("Postback: action={$action} ticket={$ticket_id} group={$group_id}");
    if ( !$action ) return;

    if ( $ticket_id && get_post_type($ticket_id) !== 'b2b_order' ) {
        b2b_line_reply($reply_token, "❌ ไม่พบ Ticket นี้ในระบบครับ");
        return;
    }

    // Guard: ป้องกัน action บน order ที่ถูกลบ (trash) แล้ว
    if ( $ticket_id && get_post_status($ticket_id) === 'trash' ) {
        b2b_log("[Postback] Blocked action={$action} on trashed ticket #{$ticket_id}");
        b2b_line_reply($reply_token, "🗑️ ออเดอร์ #".$ticket_id." ถูกยกเลิกแล้วครับ");
        return;
    }

    // ── SEC: Admin-only actions require admin group ──
    $admin_actions = array('stock_confirm','stock_oos','stock_partial','bo_set_eta','bo_restock_admin',
        'cancel_approve','cancel_reject','pack_done','pack_flash','ship_flash','ship_manual','change_shipping',
        'change_approve','change_reject','claim_exchange','claim_refund','claim_reject','sla_snooze',
        'receipt_match','ship_packed_only','postpone_pack');
    $is_admin_group = defined('B2B_ADMIN_GROUP_ID') && $group_id === B2B_ADMIN_GROUP_ID;
    if ( in_array($action, $admin_actions) && !$is_admin_group ) {
        b2b_line_reply($reply_token, "⛔ คำสั่งนี้สำหรับ Admin เท่านั้นครับ");
        return;
    }

    // ── SEC: Customer actions require ticket ownership ──
    $customer_actions = array('confirm_order','cancel_draft','confirm_bill','cancel_request',
        'bo_wait','bo_accept_partial','bo_wait_full','bo_cancel_all','bo_continue','bo_extend',
        'delivery_ok','delivery_no','change_request','claim_open','slip_pay');
    if ( in_array($action, $customer_actions) && $ticket_id ) {
        $source_gid = get_field('source_group_id', $ticket_id);
        if ( $source_gid && $source_gid !== $group_id ) {
            b2b_line_reply($reply_token, "⛔ ออเดอร์นี้ไม่ใช่ของกลุ่มนี้ครับ");
            return;
        }
    }

    switch ( $action ) {
        case 'confirm_order':   b2b_action_confirm_order($ticket_id, $group_id, $user_id, $reply_token); break;
        case 'cancel_draft':    b2b_action_cancel_draft($ticket_id, $reply_token); break;
        case 'stock_confirm':   b2b_action_stock_confirm($ticket_id, $user_id, $reply_token); break;
        case 'stock_oos':       b2b_action_stock_oos($ticket_id, $user_id, $reply_token); break;
        case 'stock_partial':   b2b_action_stock_partial($ticket_id, $user_id, $reply_token); break;
        case 'bo_set_eta':      $days = isset($params['days']) ? max(0, min(365, intval($params['days']))) : 0; b2b_action_bo_set_eta($ticket_id, $days, $user_id, $reply_token); break;
        case 'bo_wait':         b2b_action_bo_wait($ticket_id, $reply_token); break;
        case 'bo_accept_partial': b2b_action_bo_accept_partial($ticket_id, $group_id, $user_id, $reply_token); break;
        case 'bo_wait_full':    b2b_action_bo_wait_full($ticket_id, $reply_token); break;
        case 'bo_cancel_all':   b2b_action_bo_cancel_all($ticket_id, $group_id, $user_id, $reply_token); break;
        case 'confirm_bill':    b2b_action_confirm_bill($ticket_id, $group_id, $user_id, $reply_token); break;
        case 'cancel_request':  b2b_action_cancel_request($ticket_id, $group_id, $user_id, $reply_token); break;
        case 'cancel_approve':  b2b_action_cancel_approve($ticket_id, $user_id, $reply_token); break;
        case 'cancel_reject':   b2b_action_cancel_reject($ticket_id, $user_id, $reply_token); break;
        case 'pack_done':       b2b_action_pack_done($ticket_id, $user_id, $reply_token); break;
        case 'pack_flash':      b2b_action_pack_flash($ticket_id, $user_id, $reply_token); break;
        case 'ship_flash':      b2b_action_ship_flash($ticket_id, $user_id, $reply_token); break;
        case 'ship_manual':     b2b_action_ship_manual($ticket_id, $user_id, $reply_token); break;
        case 'change_shipping': $method = isset($params['method']) ? sanitize_text_field($params['method']) : ''; b2b_action_change_shipping($ticket_id, $method, $user_id, $reply_token); break;
        case 'receipt_match':   $tracking = isset($params['tracking']) ? sanitize_text_field($params['tracking']) : ''; $carrier = isset($params['carrier']) ? sanitize_text_field($params['carrier']) : ''; b2b_action_receipt_match($ticket_id, $tracking, $carrier, $user_id, $reply_token); break;
        case 'bo_continue':     b2b_action_bo_continue($ticket_id, $reply_token); break;
        case 'bo_restock_admin': b2b_action_bo_restock_admin($ticket_id, $user_id, $reply_token); break;
        case 'bo_extend':       b2b_action_bo_extend($ticket_id, $reply_token); break;
        case 'delivery_ok':     b2b_action_delivery_ok($ticket_id, $reply_token); break;
        case 'delivery_no':     b2b_action_delivery_no($ticket_id, $reply_token); break;
        case 'change_request':  b2b_action_change_request($ticket_id, $group_id, $user_id, $reply_token); break;
        case 'change_approve':  b2b_action_change_approve($ticket_id, $user_id, $reply_token); break;
        case 'change_reject':   b2b_action_change_reject($ticket_id, $user_id, $reply_token); break;
        case 'claim_open':      $reason = isset($params['reason']) ? sanitize_text_field($params['reason']) : 'other'; b2b_action_claim_open($ticket_id, $reason, $group_id, $user_id, $reply_token); break;
        case 'claim_exchange':  b2b_action_claim_exchange($ticket_id, $user_id, $reply_token); break;
        case 'claim_refund':    b2b_action_claim_refund($ticket_id, $user_id, $reply_token); break;
        case 'claim_reject':    b2b_action_claim_reject($ticket_id, $user_id, $reply_token); break;
        case 'sla_snooze':      $mins = isset($params['mins']) ? max(1, min(1440, intval($params['mins']))) : 30; b2b_action_sla_snooze($ticket_id, $mins, $user_id, $reply_token); break;
        // V.37: Per-box pack timeout actions
        case 'ship_packed_only': b2b_action_ship_packed_only($ticket_id, $user_id, $reply_token); break;
        case 'postpone_pack':    b2b_action_postpone_pack($ticket_id, $user_id, $reply_token); break;
        // V.31: Slip-to-invoice manual matching
        case 'slip_pay':        b2b_action_slip_pay($ticket_id, $params, $group_id, $user_id, $reply_token); break;
        default: b2b_log("Unknown postback action: {$action}"); break;
    }
}

