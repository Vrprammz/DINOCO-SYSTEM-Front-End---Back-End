        b2b_line_reply_raw($reply_token, array($flex));
    } elseif ( strpos($text,'ยอดขาย')!==false || strpos($text,'สรุปยอด')!==false || strpos($text,'ยอดวันนี้')!==false ) {
        $url = b2b_liff_url('b2b-dashboard/', array('tab'=>'sales'));
        $flex = b2b_build_flex_liff_shortcut('💰 ยอดขายวันนี้', b2b_date('d/m/Y'), $url, '💰 เปิดดูยอดขาย', '#065f46');
        b2b_line_reply_raw($reply_token, array($flex));
    } elseif ( strpos($text,'สรุปออเดอร์')!==false || $text==='สรุป' ) {
        $url = b2b_liff_url('b2b-dashboard/', array('tab'=>'overview'));
