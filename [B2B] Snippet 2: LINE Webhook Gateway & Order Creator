        b2b_line_reply_raw($reply_token, array($flex));
    } elseif ( strpos($text,'เช็คหนี้')!==false || strpos($text,'หนี้ค้าง')!==false || strpos($text,'ยอดค้าง')!==false ) {
        $url = b2b_liff_url('b2b-dashboard/', array('tab'=>'debts'));
        $flex = b2b_build_flex_liff_shortcut('💳 หนี้ค้างตัวแทน', b2b_date('d/m/Y H:i'), $url, '💳 เปิดดูหนี้ค้าง', '#7c2d12');
        b2b_line_reply_raw($reply_token, array($flex));
    } elseif ( strpos($text,'backorder')!==false || strpos($text,'แบ็คออเดอร์')!==false || strpos($text,'รอของ')!==false ) {
        $url = b2b_liff_url('b2b-dashboard/', array('tab'=>'backorder'));
        $flex = b2b_build_flex_liff_shortcut('📦 Backorder', b2b_date('d/m/Y H:i'), $url, '📦 เปิดดู Backorder', '#7c2d12');
        b2b_line_reply_raw($reply_token, array($flex));
    } elseif ( strpos($text,'ปลดล็อก')!==false ) {
        $sku = '';
        if ( preg_match('/ปลดล็อก(?:สินค้า)?\s+(\S+)/u', $text, $m) ) $sku = strtoupper(trim($m[1]));
        $result = b2b_chatops_unlock_oos($sku, $reply_token);
        if ($result !== '__liff_sent__') b2b_line_reply($reply_token, $result);
        if ($sku) b2b_notify_bo_tickets_for_sku($sku);
    } elseif ( strpos($text,'เช็คสต็อก')!==false ) {
        $sku = '';
        if ( preg_match('/เช็คสต็อก\s+(\S+)/u', $text, $m) ) $sku = strtoupper(trim($m[1]));
        $result = b2b_chatops_check_stock($sku, $reply_token);
        if ($result !== '__liff_sent__') b2b_line_reply($reply_token, $result);
    } elseif ( strpos($text,'เลขพัสดุ')!==false || strpos($text,'กรอกเลข')!==false || strpos($text,'tracking')!==false ) {
        // V.13: เลขพัสดุ without full args → open LIFF
        $url = b2b_liff_url('b2b-tracking/');
        $flex = b2b_build_flex_liff_shortcut('📬 กรอกเลขพัสดุ', 'กดเพื่อกรอกเลขพัสดุ', $url, '📬 เปิดกรอกเลขพัสดุ', '#2563eb');
        b2b_line_reply_raw($reply_token, array($flex));
    } elseif ( strpos($text,'คำสั่ง')!==false || strtolower($text)==='help' ) {
        b2b_line_reply_raw($reply_token, array(b2b_build_flex_command_menu_admin()));
    } else {
        b2b_line_reply($reply_token, "❓ ไม่รู้จักคำสั่ง: \"".$text."\"\n\nพิมพ์ \"คำสั่ง\" เพื่อดูรายการทั้งหมด");
    }
}

function b2b_chatops_unlock_oos( $sku, $reply_token = '' ) {
    if (!$sku) {
        // V.13: ถ้าไม่ระบุ SKU → ส่ง LIFF shortcut แทน
        if ($reply_token && function_exists('b2b_liff_url') && function_exists('b2b_build_flex_liff_shortcut')) {
            $url = b2b_liff_url('b2b-stock/', array('filter'=>'oos'));
            $flex = b2b_build_flex_liff_shortcut('📦 จัดการสต็อก + BO', 'กดเพื่อดูสินค้าหมดสต็อกทั้งหมด', $url, '📦 เปิดจัดการสต็อก', '#16a34a');
            b2b_line_reply_raw($reply_token, array($flex));
            return '__liff_sent__';
        }
        return "❌ กรุณาระบุ SKU เช่น:\nปลดล็อกสินค้า DNCGND55L001";
    }
    $result = function_exists('b2b_unlock_product_oos') ? b2b_unlock_product_oos($sku) : false;
    if (!$result) return "❌ ไม่พบ SKU: ".$sku;
    return "🔓 ปลดล็อก SKU: ".$sku." เรียบร้อย\nสต็อก: in_stock ✅";
}

function b2b_chatops_check_stock( $sku, $reply_token = '' ) {
    if (!$sku) {
        // V.13: ถ้าไม่ระบุ SKU → ส่ง LIFF shortcut แทน
        if ($reply_token && function_exists('b2b_liff_url') && function_exists('b2b_build_flex_liff_shortcut')) {
            $url = b2b_liff_url('b2b-stock/');
            $flex = b2b_build_flex_liff_shortcut('📦 จัดการสต็อกสินค้า', 'กดเพื่อดูสต็อกทั้งหมด', $url, '📦 เปิดจัดการสต็อก', '#2563eb');
            b2b_line_reply_raw($reply_token, array($flex));
            return '__liff_sent__';
        }
        return "❌ กรุณาระบุ SKU เช่น:\nเช็คสต็อก DNCGND55L001";
    }
    $products = get_posts(array('post_type'=>'b2b_product','posts_per_page'=>5,'post_status'=>'publish',
        'meta_query'=>array(array('key'=>'product_sku','value'=>$sku,'compare'=>'LIKE'))));
    if (empty($products)) return "❌ ไม่พบสินค้า SKU: ".$sku;
    $msg = "📦 สต็อก SKU: ".$sku."\n\n";
    foreach ($products as $p) {
        $s_sku = get_field('product_sku',$p->ID); $stock = get_field('stock_status',$p->ID) ?: 'in_stock';
        $eta = get_field('oos_eta_date',$p->ID) ?: '-'; $icon = ($stock==='in_stock') ? '✅' : '❌';
        $msg .= $icon." ".$s_sku." — ".get_the_title($p->ID)."\n";
        $msg .= "   สถานะ: ".($stock==='in_stock'?'มีสินค้า':'หมดสต็อก');
        if ($stock !== 'in_stock' && $eta !== '-') $msg .= " | ETA: ".$eta;
        $msg .= "\n\n";
    }
    return $msg;
}

