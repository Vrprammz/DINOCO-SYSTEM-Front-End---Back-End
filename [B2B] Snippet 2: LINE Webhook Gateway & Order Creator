// V.25: Flash pack — auto create Flash shipment from LINE postback
function b2b_action_pack_flash( $ticket_id, $user_id, $reply_token ) {
    // Advisory lock — prevent concurrent transitions
    $lock_key = 'b2b_lock_' . $ticket_id;
    if ( get_transient($lock_key) ) {
        if ($reply_token) b2b_line_reply($reply_token, '⏳ กำลังดำเนินการอยู่ กรุณารอสักครู่');
        return;
    }
    set_transient($lock_key, 1, 60);

    b2b_clear_sla_nag($ticket_id);
    $status = get_field('order_status', $ticket_id);
    if ( !in_array($status, array('paid','awaiting_payment'), true) ) {
        delete_transient($lock_key);
        b2b_line_reply($reply_token, "ℹ️ ออเดอร์นี้ยังไม่พร้อมแพ็คครับ (สถานะ: ".$status.")");
        return;
    }
    if ( !defined('B2B_FLASH_MCH_ID') || !defined('B2B_FLASH_SECRET_KEY') || !defined('B2B_FLASH_API_URL') ) {
        delete_transient($lock_key);
        b2b_line_reply($reply_token, "❌ Flash ยังไม่ตั้งค่า (MCH_ID/SECRET_KEY/API_URL)");
        return;
    }
    // Check not already created
    $existing = get_post_meta($ticket_id, '_flash_tracking_numbers', true);
    if ( !empty($existing) ) {
        $packing = get_post_meta($ticket_id, '_flash_packing_status', true);
        if ( $packing !== 'flash_create_error' ) {
            delete_transient($lock_key);
            b2b_line_reply($reply_token, "ℹ️ สร้างพัสดุ Flash ไปแล้วครับ\nTracking: " . implode(', ', $existing));
            return;
        }
        // Retry: cancel partial
        if (function_exists('b2b_flash_cancel_order')) {
            foreach ($existing as $old_pno) { b2b_flash_cancel_order($old_pno); }
        }
        delete_post_meta($ticket_id, '_flash_tracking_numbers');
        update_field('tracking_number', '', $ticket_id);
    }
    // Create Flash shipment
    $result = function_exists('b2b_flash_create_all_boxes') ? b2b_flash_create_all_boxes($ticket_id) : array('ok'=>false,'error'=>'ไม่พบฟังก์ชัน b2b_flash_create_all_boxes');
    $admin_name = b2b_get_line_profile_name($user_id);
    if ( $result['ok'] ) {
        $pnos = $result['pnos'];
        $tracking = implode(', ', $pnos);
        // Queue print job
        if (function_exists('b2b_enqueue_print_job')) {
            b2b_enqueue_print_job($ticket_id);
            update_post_meta($ticket_id, '_flash_packing_status', 'print_queued');
        }
        if (function_exists('b2b_add_audit_log')) {
            b2b_add_audit_log($ticket_id, 'flash_created', 'สร้างพัสดุ Flash ' . count($pnos) . ' กล่อง: ' . $tracking . ' (โดย ' . $admin_name . ')');
        }
        b2b_line_reply($reply_token, "⚡ สร้างพัสดุ Flash สำเร็จ!\nTicket #".$ticket_id." (โดย ".$admin_name.")\nTracking: ".$tracking."\n\n📦 กดปุ่ม 'ของพร้อมส่ง' ใน Dashboard เพื่อเรียกรถ Flash");
    } else {
        update_post_meta($ticket_id, '_flash_packing_status', 'flash_create_error');
        update_post_meta($ticket_id, '_flash_create_error', $result['error'] ?? 'Unknown error');
        b2b_line_reply($reply_token, "❌ สร้างพัสดุ Flash ล้มเหลว\nTicket #".$ticket_id."\n\nError: ".($result['error'] ?? 'Unknown')."\n\nลองใหม่ได้ที่ Dashboard");
    }
    delete_transient($lock_key);
}

