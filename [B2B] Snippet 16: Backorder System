if ( ! function_exists( 'b2b_rest_bo_order_detail' ) ) {
    /**
     * V.1.6 H2 — Return single pending_stock_review order + snapshot
     * ใช้ใน Split Modal แทน pending-review list endpoint
     */
    function b2b_rest_bo_order_detail( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        if ( ! $order_id ) return new WP_Error( 'invalid_input', 'order_id required', array( 'status' => 400 ) );

        $status = get_field( 'order_status', $order_id );
        if ( ! $status ) return new WP_Error( 'not_found', 'Order not found', array( 'status' => 404 ) );

        $dist_id    = (int) get_field( 'distributor_id', $order_id );
        $dist_name  = $dist_id ? get_the_title( $dist_id ) : '';
        $order_text = get_field( 'order_items', $order_id ) ?: '';
        $total      = (float) get_field( 'total_amount', $order_id );
        $accepted_at = get_post_meta( $order_id, '_b2b_opaque_accept_at', true );
        $age_hours   = $accepted_at ? ( time() - strtotime( $accepted_at ) ) / 3600 : 0;
        $snapshot    = get_post_meta( $order_id, '_b2b_stock_snapshot', true );

        // H2: Also return fresh snapshot (เผื่อ stock เปลี่ยนหลัง opaque accept)
        $items   = b2b_bo_parse_order_items( $order_text );
        $fresh   = array();
        foreach ( $items as $it ) {
            $sku = strtoupper( $it['sku'] );
            $available = 0;
            if ( function_exists( 'dinoco_compute_hierarchy_stock' ) && function_exists( 'dinoco_get_reserved_qty' ) ) {
                $available = max( 0, (int) dinoco_compute_hierarchy_stock( $sku ) - (int) dinoco_get_reserved_qty( $sku ) );
            }
            $fresh[ $sku ] = array( 'available' => $available, 'requested' => (int) $it['qty'] );
        }

        return rest_ensure_response( array(
            'success'          => true,
            'id'               => $order_id,
            'ticket_no'        => get_the_title( $order_id ),
            'status'           => $status,
            'distributor_id'   => $dist_id,
            'distributor_name' => $dist_name,
            'order_items'      => $order_text,
            'total_amount'     => $total,
            'accepted_at'      => $accepted_at,
            'age_hours'        => round( $age_hours, 1 ),
            'stock_snapshot'   => is_array( $snapshot ) ? $snapshot : array(),
            'fresh_snapshot'   => $fresh,
        ) );
    }
}

if ( ! function_exists( 'b2b_rest_bo_update_eta' ) ) {
    /**
     * V.1.6 H3 — Admin extend/change ETA on BO queue item
     */
    function b2b_rest_bo_update_eta( $request ) {
        $bo_queue_id = (int) $request->get_param( 'bo_queue_id' );
        $eta_days    = max( 0, (int) $request->get_param( 'eta_days' ) );
        $notes       = sanitize_text_field( $request->get_param( 'notes' ) ?: '' );

        if ( ! $bo_queue_id ) return new WP_Error( 'invalid_input', 'bo_queue_id required', array( 'status' => 400 ) );

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $row = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM {$bo_table} WHERE id = %d", $bo_queue_id ), ARRAY_A );
        if ( ! $row ) return new WP_Error( 'not_found', 'BO row not found', array( 'status' => 404 ) );
        if ( ! in_array( $row['status'], array( 'pending', 'ready' ), true ) ) {
            return new WP_Error( 'invalid_status', 'Only pending/ready rows can update ETA', array( 'status' => 400 ) );
        }

        $new_eta = $eta_days > 0 ? date( 'Y-m-d', strtotime( "+{$eta_days} days" ) ) : null;
        $new_notes = $notes ? ( $row['notes'] ? $row['notes'] . ' | ' . $notes : $notes ) : $row['notes'];

        $wpdb->update( $bo_table, array(
            'eta'   => $new_eta,
            'notes' => $new_notes,
        ), array( 'id' => $bo_queue_id ) );

        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( "[BO] ETA updated — bo_queue_id={$bo_queue_id} eta={$new_eta} by user=" . get_current_user_id() );
        }

        return rest_ensure_response( array( 'success' => true, 'bo_queue_id' => $bo_queue_id, 'eta' => $new_eta ) );
    }
}

if ( ! function_exists( 'b2b_rest_bo_bulk_fulfill' ) ) {
    /**
     * V.1.6 H4 — Bulk fulfill multiple BO queue items
     * Body: { items: [{bo_queue_id, qty}, ...] }
     */
    function b2b_rest_bo_bulk_fulfill( $request ) {
        $items = $request->get_param( 'items' );
        if ( ! is_array( $items ) || empty( $items ) ) {
            return new WP_Error( 'invalid_input', 'items required', array( 'status' => 400 ) );
        }

        $results = array( 'success' => 0, 'failed' => 0, 'errors' => array() );

        // Group by order_id to handle FSM transition batch
        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $by_order = array();
        foreach ( $items as $it ) {
            $bo_queue_id = (int) ( $it['bo_queue_id'] ?? 0 );
            if ( ! $bo_queue_id ) continue;
            $row = $wpdb->get_row( $wpdb->prepare( "SELECT * FROM {$bo_table} WHERE id = %d", $bo_queue_id ), ARRAY_A );
            if ( ! $row ) continue;
            $by_order[ $row['order_id'] ][] = array(
                'bo_queue_id' => $bo_queue_id,
                'sku'         => $row['sku'],
                'qty'         => (int) ( $it['qty'] ?? $row['qty_bo'] ),
            );
        }

        foreach ( $by_order as $order_id => $order_items ) {
            $sub_req = new WP_REST_Request();
            $sub_req->set_param( 'order_id', $order_id );
            $sub_req->set_param( 'items', $order_items );
            $res = b2b_rest_bo_fulfill( $sub_req );

            if ( is_wp_error( $res ) ) {
                $results['failed']++;
                $results['errors'][] = "Order #{$order_id}: " . $res->get_error_message();
            } else {
                $data = $res->get_data();
                if ( ! empty( $data['success'] ) ) {
                    $results['success']++;
                } else {
                    $results['failed']++;
                }
            }
        }

        return rest_ensure_response( array(
            'success' => true,
            'results' => $results,
        ) );
    }
}

