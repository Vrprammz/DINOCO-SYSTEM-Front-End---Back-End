/**
 * Shortcode [b2b_bo_customer_order_detail order_id="123"] — embed in customer LIFF
 * แสดง split view: ส่งแล้ว + BO items + ETA
 * No stock numbers — customer-safe
 */
add_shortcode( 'b2b_bo_customer_order_detail', function( $atts ) {
    $atts = shortcode_atts( array( 'order_id' => 0 ), $atts );
    $order_id = (int) $atts['order_id'];
    if ( ! $order_id ) return '<p>Order ID required</p>';

    $status = get_field( 'order_status', $order_id );
    if ( $status !== 'partial_fulfilled' && $status !== 'pending_stock_review' ) {
        return ''; // only show for BO-relevant statuses
    }

    if ( $status === 'pending_stock_review' ) {
        return '<div class="b2b-bo-cust-view" style="padding:16px;background:#fef3c7;border:1px solid #f59e0b;border-radius:8px;margin:12px 0;">
            <div style="font-size:14px;font-weight:600;color:#78350f;">⏳ รอตรวจสอบจากแอดมิน</div>
            <div style="font-size:12px;color:#92400e;margin-top:4px;">คาดการณ์ 2-4 ชั่วโมง</div>
        </div>';
    }

    // partial_fulfilled
    $summary = b2b_compute_bo_summary( $order_id );

    ob_start();
    ?>
    <div class="b2b-bo-cust-view" style="font-family:'Sarabun',sans-serif;color:#1f2937;margin:12px 0;">
        <style>
            .b2b-bo-cust-view .cv-section { margin-bottom: 16px; background: white; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
            .b2b-bo-cust-view .cv-section .cv-header { padding: 12px 14px; font-weight: 600; font-size: 14px; color: white; display: flex; justify-content: space-between; align-items: center; }
            .b2b-bo-cust-view .cv-section.confirmed .cv-header { background: #10b981; }
            .b2b-bo-cust-view .cv-section.backorder .cv-header { background: #f59e0b; }
            .b2b-bo-cust-view .cv-item { padding: 10px 14px; border-top: 1px solid #f3f4f6; font-size: 13px; }
            .b2b-bo-cust-view .cv-item:first-child { border-top: none; }
            .b2b-bo-cust-view .cv-item .sku-name { font-weight: 600; }
            .b2b-bo-cust-view .cv-item .sub { font-size: 12px; color: #6b7280; margin-top: 2px; }
            .b2b-bo-cust-view .cv-eta { background: #fef3c7; color: #78350f; padding: 2px 8px; border-radius: 10px; font-size: 11px; display: inline-block; margin-top: 4px; }
            .b2b-bo-cust-view .cv-total { padding: 14px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 13px; }
            .b2b-bo-cust-view .cv-total .cv-row { display: flex; justify-content: space-between; margin: 4px 0; }
            .b2b-bo-cust-view .cv-total .cv-row.total { font-weight: 700; font-size: 14px; color: #1f2937; margin-top: 8px; padding-top: 8px; border-top: 1px dashed #d1d5db; }
        </style>

        <!-- Confirmed (ส่งทันที) -->
        <?php if ( $summary['fulfilled_total'] > 0 ): ?>
        <div class="cv-section confirmed">
            <div class="cv-header">
                <span>✅ จัดส่งทันที</span>
                <span><?php echo (int) $summary['fulfilled_total']; ?> ชิ้น</span>
            </div>
            <?php
            // Show fulfilled items — query from order_items that are NOT in bo_queue
            $order_text = get_field( 'order_items', $order_id ) ?: '';
            $items = b2b_bo_parse_order_items( $order_text );
            foreach ( $items as $it ):
                $bo_qty = 0;
                foreach ( $summary['items'] as $sum_it ) {
                    if ( strtoupper( $sum_it['sku'] ) === $it['sku'] && in_array( $sum_it['status'], array( 'pending', 'ready' ), true ) ) {
                        $bo_qty += (int) $sum_it['qty_bo'];
                    }
                }
                $fulfilled_qty = $it['qty'] - $bo_qty;
                if ( $fulfilled_qty <= 0 ) continue;
                $pd = b2b_get_product_data( $it['sku'] );
                $name = $pd ? $pd['name'] : $it['sku'];
            ?>
            <div class="cv-item">
                <div class="sku-name"><?php echo esc_html( $name ); ?> × <?php echo (int) $fulfilled_qty; ?></div>
                <div class="sub">SKU: <?php echo esc_html( $it['sku'] ); ?></div>
            </div>
            <?php endforeach; ?>
        </div>
        <?php endif; ?>

        <!-- BO (รอสต็อก) -->
        <?php if ( $summary['bo_total'] > 0 ): ?>
        <div class="cv-section backorder">
            <div class="cv-header">
                <span>⏳ รอสต็อก (Backorder)</span>
                <span><?php echo (int) $summary['bo_total']; ?> ชิ้น</span>
            </div>
            <?php foreach ( $summary['items'] as $bo_it ):
                if ( ! in_array( $bo_it['status'], array( 'pending', 'ready' ), true ) ) continue;
                $pd = b2b_get_product_data( $bo_it['sku'] );
                $name = $pd ? $pd['name'] : $bo_it['sku'];
            ?>
            <div class="cv-item">
                <div class="sku-name"><?php echo esc_html( $name ); ?> × <?php echo (int) $bo_it['qty_bo']; ?></div>
                <div class="sub">SKU: <?php echo esc_html( $bo_it['sku'] ); ?></div>
                <?php if ( $bo_it['eta'] ): ?>
                <span class="cv-eta">📅 คาดว่ากลับมา: <?php echo esc_html( $bo_it['eta'] ); ?></span>
                <?php endif; ?>
                <?php if ( $bo_it['status'] === 'ready' ): ?>
                <span class="cv-eta" style="background:#d1fae5;color:#065f46;">🟢 พร้อมจัดส่งแล้ว</span>
                <?php endif; ?>
            </div>
            <?php endforeach; ?>
            <div style="padding: 10px 14px; background: #fef3c7; font-size: 11px; color: #78350f; border-top: 1px solid #f3f4f6;">
                ℹ️ BO ไม่เรียกเก็บจนกว่าของจะพร้อมจัดส่ง
            </div>
        </div>
        <?php endif; ?>

        <!-- Total breakdown -->
        <div class="cv-total">
            <?php if ( $summary['fulfilled_value'] > 0 ): ?>
            <div class="cv-row"><span>ชำระแล้ว (ส่งทันที):</span><span>฿<?php echo number_format( $summary['fulfilled_value'], 2 ); ?></span></div>
            <?php endif; ?>
            <?php if ( $summary['bo_value'] > 0 ): ?>
            <div class="cv-row" style="color:#78350f;"><span>รอชำระ (BO):</span><span>฿<?php echo number_format( $summary['bo_value'], 2 ); ?></span></div>
            <?php endif; ?>
            <div class="cv-row total">
                <span>ยอดรวมออเดอร์:</span>
                <span>฿<?php echo number_format( $summary['fulfilled_value'] + $summary['bo_value'], 2 ); ?></span>
            </div>
        </div>
    </div>
    <?php
    return ob_get_clean();
} );

