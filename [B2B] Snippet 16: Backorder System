if ( ! function_exists( 'b2b_log_attempt' ) ) {
    /**
     * บันทึก order/cancel/split attempt ลง audit log
     *
     * @param int    $distributor_id
     * @param string $action          'place_order' | 'cancel' | 'split' | 'undo_split' | 'bo_fulfill'
     * @param int    $order_id        0 ถ้าไม่มี order
     * @param string $items_hash      md5(json_encode(items)) ป้องกัน duplicate
     * @param string $result          'accepted' | 'rejected' | 'rate_limit' | 'dup' | 'error'
     * @param string $rejection_code  'QTY_OVER_LIMIT' | 'RATE_LIMIT' | ... null ถ้า accepted
     * @param array  $extra           ['total_qty', 'total_value', 'group_id']
     * @return int|false              insert id หรือ false
     */
    function b2b_log_attempt( $distributor_id, $action, $order_id = 0, $items_hash = '', $result = 'accepted', $rejection_code = null, $extra = array() ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_order_attempt_log';

        $data = array(
            'distributor_id' => (int) $distributor_id,
            'group_id'       => isset( $extra['group_id'] ) ? substr( $extra['group_id'], 0, 64 ) : '',
            'action'         => substr( $action, 0, 32 ),
            'order_id'       => $order_id ? (int) $order_id : null,
            'items_hash'     => $items_hash ? substr( $items_hash, 0, 64 ) : null,
            'total_qty'      => isset( $extra['total_qty'] ) ? (int) $extra['total_qty'] : null,
            'total_value'    => isset( $extra['total_value'] ) ? (float) $extra['total_value'] : null,
            'result'         => substr( $result, 0, 16 ),
            'rejection_code' => $rejection_code ? substr( $rejection_code, 0, 32 ) : null,
            'ip'             => isset( $_SERVER['REMOTE_ADDR'] ) ? substr( sanitize_text_field( $_SERVER['REMOTE_ADDR'] ), 0, 45 ) : null,
            'user_agent'     => isset( $_SERVER['HTTP_USER_AGENT'] ) ? substr( sanitize_text_field( $_SERVER['HTTP_USER_AGENT'] ), 0, 255 ) : null,
            'created_at'     => current_time( 'mysql' ),
        );

        $inserted = $wpdb->insert( $table, $data );
        return $inserted ? $wpdb->insert_id : false;
    }
}

if ( ! function_exists( 'b2b_compute_bo_summary' ) ) {
    /**
     * คำนวณ summary ของ order ที่ split แล้ว
     *
     * @param int $order_id
     * @return array {
     *   fulfilled_total: int (qty ที่ admin confirm),
     *   fulfilled_value: float (baht),
     *   bo_total: int (qty ที่ค้าง BO),
     *   bo_value: float,
     *   bo_pending_count: int,
     *   bo_ready_count: int,
     *   bo_fulfilled_count: int,
     *   bo_cancelled_count: int,
     *   items: array (per-item breakdown from bo_queue)
     * }
     */
    function b2b_compute_bo_summary( $order_id ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_bo_queue';

        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM {$table} WHERE order_id = %d ORDER BY item_index ASC",
            $order_id
        ), ARRAY_A );

        $summary = array(
            'fulfilled_total'    => 0,
            'fulfilled_value'    => 0.0,
            'bo_total'           => 0,
            'bo_value'           => 0.0,
            'bo_pending_count'   => 0,
            'bo_ready_count'     => 0,
            'bo_fulfilled_count' => 0,
            'bo_cancelled_count' => 0,
            'items'              => array(),
        );

        if ( empty( $rows ) ) return $summary;

        foreach ( $rows as $r ) {
            $summary['items'][] = $r;
            $qty = (int) $r['qty_bo'];

            switch ( $r['status'] ) {
                case 'pending':
                    $summary['bo_pending_count']++;
                    $summary['bo_total'] += $qty;
                    break;
                case 'ready':
                    $summary['bo_ready_count']++;
                    $summary['bo_total'] += $qty;
                    break;
                case 'fulfilled':
                    $summary['bo_fulfilled_count']++;
                    $summary['fulfilled_total'] += $qty;
                    break;
                case 'cancelled':
                    $summary['bo_cancelled_count']++;
                    break;
            }
        }

        // Compute values (need price lookup per SKU)
        if ( function_exists( 'b2b_get_product_data' ) ) {
            foreach ( $summary['items'] as $item ) {
                $pd    = b2b_get_product_data( $item['sku'] );
                $price = $pd ? (float) ( $pd['base_price'] ?? 0 ) : 0;
                $qty   = (int) $item['qty_bo'];

                if ( $item['status'] === 'fulfilled' ) {
                    $summary['fulfilled_value'] += $price * $qty;
                } elseif ( in_array( $item['status'], array( 'pending', 'ready' ), true ) ) {
                    $summary['bo_value'] += $price * $qty;
                }
            }
        }

        return $summary;
    }
}

if ( ! function_exists( 'b2b_bo_get_queue_rows' ) ) {
    /**
     * Query bo_queue แบบ flexible + batch-safe
     *
     * @param array $args [
     *   'status' => 'pending' | 'ready' | 'fulfilled' | 'cancelled' | 'all',
     *   'sku'    => 'SKU_X' | null,
     *   'age_gt_hours' => int | 0,
     *   'order_id' => int | 0,
     *   'limit'  => int (default 100),
     *   'offset' => int,
     * ]
     * @return array
     */
    function b2b_bo_get_queue_rows( $args = array() ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_bo_queue';

        $defaults = array(
            'status'       => 'all',
            'sku'          => null,
            'age_gt_hours' => 0,
            'order_id'     => 0,
            'limit'        => 100,
            'offset'       => 0,
        );
        $args = wp_parse_args( $args, $defaults );

        $where = array( '1=1' );
        $params = array();

        if ( $args['status'] !== 'all' ) {
            $where[] = 'status = %s';
            $params[] = $args['status'];
        }
        if ( $args['sku'] ) {
            $where[] = 'sku = %s';
            $params[] = strtoupper( trim( $args['sku'] ) );
        }
        if ( $args['order_id'] ) {
            $where[] = 'order_id = %d';
            $params[] = (int) $args['order_id'];
        }
        if ( $args['age_gt_hours'] > 0 ) {
            $where[] = 'created_at <= DATE_SUB(NOW(), INTERVAL %d HOUR)';
            $params[] = (int) $args['age_gt_hours'];
        }

        $params[] = (int) $args['limit'];
        $params[] = (int) $args['offset'];

        $sql = "SELECT * FROM {$table}
                WHERE " . implode( ' AND ', $where ) . "
                ORDER BY created_at ASC
                LIMIT %d OFFSET %d";

        return $wpdb->get_results( $wpdb->prepare( $sql, ...$params ), ARRAY_A );
    }
}

if ( ! function_exists( 'b2b_bo_compute_age_bucket' ) ) {
    /**
     * Classify BO row age: fresh (0-3d) | warn (3-7d) | old (>7d) | ready
     */
    function b2b_bo_compute_age_bucket( $row ) {
        if ( $row['status'] === 'ready' ) return 'ready';

        $age_h = ( time() - strtotime( $row['created_at'] ) ) / 3600;
        if ( $age_h <= 72 ) return 'fresh';
        if ( $age_h <= 168 ) return 'warn';
        return 'old';
    }
}

if ( ! function_exists( 'b2b_bo_increment_daily_counters' ) ) {
    /**
     * เพิ่ม daily counters หลัง accept order (qty + value per SKU + distributor)
     * Transients expire 86400s natural — cron cleanup ไม่จำเป็น
     */
    function b2b_bo_increment_daily_counters( $distributor_id, $items, $total_value ) {
        $daily_value_key = 'b2b_daily_value_' . $distributor_id;
        $used = (float) ( get_transient( $daily_value_key ) ?: 0 );
        set_transient( $daily_value_key, $used + (float) $total_value, 86400 );

        foreach ( $items as $it ) {
            $sku = strtoupper( $it['sku'] );
            $qty_key = 'b2b_daily_qty_' . $distributor_id . '_' . $sku;
            $qty_used = (int) ( get_transient( $qty_key ) ?: 0 );
            set_transient( $qty_key, $qty_used + (int) $it['qty'], 86400 );
        }
    }
}

if ( ! function_exists( 'b2b_bo_decrement_daily_counters' ) ) {
    /**
     * ลด counters ตอน reject/cancel (revert)
     */
    function b2b_bo_decrement_daily_counters( $distributor_id, $items, $total_value ) {
        $daily_value_key = 'b2b_daily_value_' . $distributor_id;
        $used = (float) ( get_transient( $daily_value_key ) ?: 0 );
        set_transient( $daily_value_key, max( 0, $used - (float) $total_value ), 86400 );

        foreach ( $items as $it ) {
            $sku = strtoupper( $it['sku'] );
            $qty_key = 'b2b_daily_qty_' . $distributor_id . '_' . $sku;
            $qty_used = (int) ( get_transient( $qty_key ) ?: 0 );
            set_transient( $qty_key, max( 0, $qty_used - (int) $it['qty'] ), 86400 );
        }
    }
}

