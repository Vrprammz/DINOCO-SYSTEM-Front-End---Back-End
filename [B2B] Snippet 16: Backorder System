    <script>
    (function(){
        const API = <?php echo wp_json_encode( $api_base ); ?>;
        const NONCE = <?php echo wp_json_encode( $nonce ); ?>;
        let currentSplitOrderId = 0;
        let currentSplitItems = [];

        function apiCall(path, opts) {
            opts = opts || {};
            opts.headers = Object.assign({ 'X-WP-Nonce': NONCE, 'Content-Type': 'application/json' }, opts.headers || {});
            return fetch(API + path, opts).then(r => r.json());
        }

        function esc(s) { return String(s||'').replace(/[<>&"']/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c])); }
        function thb(v) { return '฿' + Number(v||0).toLocaleString('th-TH', {minimumFractionDigits:2}); }

        // Tab switching
        document.querySelectorAll('.bo-tab').forEach(t => t.addEventListener('click', () => {
            document.querySelectorAll('.bo-tab').forEach(x => x.classList.toggle('active', x === t));
            document.querySelectorAll('.bo-section').forEach(x => x.classList.toggle('active', x.dataset.section === t.dataset.tab));
        }));

        // === Pending Review ===
        // V.1.3 FIX: ใช้ custom endpoint /bo-pending-review ที่ filter server-side
        // (เดิม V.1.2 ใช้ /wp/v2/b2b_order?meta_key=X แต่ WP REST ไม่ filter meta จริง → โชว์ order ทั้งหมด)
        function loadPending() {
            const container = document.getElementById('bo-pending-list');
            container.innerHTML = '<div class="bo-loading">Loading...</div>';

            apiCall('bo-pending-review').then(res => {
                if (!res.success) {
                    container.innerHTML = '<div class="bo-empty">❌ Load error: ' + esc(res.message || 'unknown') + '</div>';
                    return;
                }
                const orders = res.data || [];
                if (orders.length === 0) {
                    container.innerHTML = '<div class="bo-empty">✨ ไม่มีออเดอร์รอ review<br><span style="font-size:11px;color:#9ca3af;">(ออเดอร์จะเข้ามาเมื่อ b2b_flag_bo_system=ON แล้วมีลูกค้าสั่งใหม่)</span></div>';
                    document.getElementById('bo-pending-count').textContent = '';
                    return;
                }
                document.getElementById('bo-pending-count').textContent = orders.length + ' รายการ';

                let html = '<table><thead><tr><th>Ticket</th><th>ร้าน</th><th>รายการ</th><th>ยอด</th><th>อายุ</th><th>Actions</th></tr></thead><tbody>';
                orders.forEach(o => {
                    const itemsShort = (o.order_items || '').length > 60 ? (o.order_items || '').slice(0, 60) + '...' : (o.order_items || '-');
                    html += `<tr>
                        <td>${esc(o.ticket_no)}</td>
                        <td>${esc(o.distributor_name || '-')}</td>
                        <td>${esc(itemsShort)}</td>
                        <td>${thb(o.total_amount)}</td>
                        <td>${Math.floor(o.age_hours || 0)}h</td>
                        <td>
                            <button class="bo-btn bo-btn-success" onclick="b2bBoConfirmFull(${o.id})">✅ เต็ม</button>
                            <button class="bo-btn bo-btn-warn" onclick="b2bBoOpenSplit(${o.id}, ${JSON.stringify(o.stock_snapshot).replace(/"/g,'&quot;')})">⚙️ Split</button>
                            <button class="bo-btn bo-btn-danger" onclick="b2bBoReject(${o.id})">❌</button>
                        </td>
                    </tr>`;
                });
                html += '</tbody></table>';
                container.innerHTML = html;
            }).catch(e => {
                container.innerHTML = '<div class="bo-empty">❌ Load error: ' + esc(e.message) + '</div>';
            });
        }

        window.b2bBoConfirmFull = function(orderId) {
            if (!confirm('ยืนยันสต็อกเต็ม (ไม่ split)?')) return;
            apiCall('bo-confirm-full', { method: 'POST', body: JSON.stringify({ order_id: orderId }) })
                .then(res => {
                    if (res.success) { alert('✅ ยืนยันแล้ว'); loadPending(); }
                    else alert('❌ ' + (res.message || 'error'));
                });
        };

        window.b2bBoReject = function(orderId) {
            const reason = prompt('เหตุผลที่ปฏิเสธ:');
            if (reason === null) return;
            apiCall('bo-reject', { method: 'POST', body: JSON.stringify({ order_id: orderId, reason: reason }) })
                .then(res => {
                    if (res.success) { alert('✅ ปฏิเสธแล้ว'); loadPending(); }
                    else alert('❌ ' + (res.message || 'error'));
                });
        };

        window.b2bBoOpenSplit = function(orderId, snapshotParam) {
            // V.1.6 H2 FIX: ใช้ /bo-order-detail endpoint (single record) แทน pending-review list
            // (faster + ไม่มี limit=50 cap หายไป)
            apiCall('bo-order-detail?order_id=' + orderId).then(order => {
                if (!order.success) { alert('❌ Load order detail failed: ' + (order.message || 'unknown')); return; }

                const title = order.ticket_no;
                const orderItems = order.order_items;
                // ใช้ fresh_snapshot (real-time compute) ถ้ามี, fallback stock_snapshot (from opaque accept time)
                const snapshot = order.fresh_snapshot || order.stock_snapshot || {};
                const items = parseOrderItems(orderItems);

                    currentSplitOrderId = orderId;
                    currentSplitItems = items;

                    document.getElementById('split-ticket').textContent = title;
                    const body = document.getElementById('bo-split-body');
                    let html = '';
                    items.forEach((it, idx) => {
                        const snap = snapshot[it.sku] || { available: 0 };
                        const available = snap.available || 0;
                        const defaultFulfill = Math.min(it.qty, available);
                        const defaultBo = it.qty - defaultFulfill;
                        html += `<div class="split-row" data-idx="${idx}">
                            <div class="sku">SKU ${esc(it.sku)} — สั่ง ${it.qty} · สต็อก ${available}</div>
                            <div class="fields">
                                <div>
                                    <label>ส่งทันที</label>
                                    <input type="number" class="split-fulfill" min="0" max="${it.qty}" value="${defaultFulfill}" />
                                </div>
                                <div>
                                    <label>BO (รอ)</label>
                                    <input type="number" class="split-bo" min="0" max="${it.qty}" value="${defaultBo}" />
                                </div>
                                <div>
                                    <label>ETA วัน (ถ้ามี BO)</label>
                                    <input type="number" class="split-eta-days" min="0" max="90" value="7" />
                                </div>
                            </div>
                            <div class="split-warning" style="display:none;"></div>
                        </div>`;
                    });
                    html += '<div class="summary-bar" id="split-summary">สรุป: ส่ง 0 · BO 0</div>';
                    body.innerHTML = html;

                    // Live update on input change
                    body.querySelectorAll('input').forEach(inp => inp.addEventListener('input', updateSplitSummary));
                    updateSplitSummary();

                    document.getElementById('bo-split-modal').classList.add('show');
                });
        };

        function parseOrderItems(text) {
            const items = [];
            const re = /\(([A-Z0-9\-]+)\)\s*x(\d+)/gi;
            let m;
            while ((m = re.exec(text)) !== null) {
                items.push({ sku: m[1].toUpperCase(), qty: parseInt(m[2], 10) });
            }
            return items;
        }

        function updateSplitSummary() {
            const rows = document.querySelectorAll('.split-row');
            let totalFulfill = 0, totalBo = 0, valid = true;
            rows.forEach((row, idx) => {
                const fulfill = parseInt(row.querySelector('.split-fulfill').value, 10) || 0;
                const bo = parseInt(row.querySelector('.split-bo').value, 10) || 0;
                const expected = currentSplitItems[idx].qty;
                const warning = row.querySelector('.split-warning');
                if (fulfill + bo !== expected) {
                    warning.style.display = 'block';
                    warning.textContent = `⚠️ ส่ง + BO ต้อง = ${expected} (ตอนนี้ = ${fulfill + bo})`;
                    valid = false;
                } else {
                    warning.style.display = 'none';
                }
                totalFulfill += fulfill;
                totalBo += bo;
            });
            const sum = document.getElementById('split-summary');
            sum.textContent = `สรุป: ส่งทันที ${totalFulfill} · BO ${totalBo}`;
            sum.style.background = valid ? '#eff6ff' : '#fef3c7';
            document.getElementById('bo-split-confirm').disabled = !valid;
        }

        window.b2bBoCloseModal = function() {
            document.getElementById('bo-split-modal').classList.remove('show');
        };

        document.getElementById('bo-split-confirm').addEventListener('click', function() {
            const rows = document.querySelectorAll('.split-row');
            const splits = [];
            rows.forEach((row, idx) => {
                splits.push({
                    sku: currentSplitItems[idx].sku,
                    qty_fulfill: parseInt(row.querySelector('.split-fulfill').value, 10) || 0,
                    qty_bo: parseInt(row.querySelector('.split-bo').value, 10) || 0,
                    eta_days: parseInt(row.querySelector('.split-eta-days').value, 10) || 7,
                });
            });
            apiCall('bo-split', { method: 'POST', body: JSON.stringify({ order_id: currentSplitOrderId, splits: splits }) })
                .then(res => {
                    if (res.success) {
                        alert(`✅ Split สำเร็จ — ส่ง ${res.fulfilled_total} · BO ${res.bo_total}\nUndo ได้ถึง ${res.undo_deadline}`);
                        b2bBoCloseModal();
                        loadPending();
                    } else {
                        alert('❌ ' + (res.message || 'error'));
                    }
                });
        });

        // === Backorders Queue ===
        function loadQueue() {
            const container = document.getElementById('bo-queue-list');
            container.innerHTML = '<div class="bo-loading">Loading...</div>';

            const params = new URLSearchParams();
            params.set('status', document.getElementById('bo-filter-status').value);
            const sku = document.getElementById('bo-filter-sku').value.trim();
            if (sku) params.set('sku', sku);
            const age = document.getElementById('bo-filter-age').value;
            if (age && age > 0) params.set('age_gt_hours', age);

            apiCall('bo-queue?' + params.toString()).then(res => {
                if (!res.success) {
                    container.innerHTML = '<div class="bo-empty">❌ Load error</div>';
                    return;
                }
                const sum = res.summary || {};
                document.getElementById('sum-pending').textContent = sum.total_pending || 0;
                document.getElementById('sum-ready').textContent = sum.total_ready || 0;
                document.getElementById('sum-oldest').textContent = sum.oldest_age_hours || 0;
                document.getElementById('sum-attention').textContent = sum.needs_attention || 0;

                const rows = res.data || [];
                if (rows.length === 0) {
                    container.innerHTML = '<div class="bo-empty">✨ ไม่มี BO ตรงกับ filter</div>';
                    return;
                }
                let html = '<table><thead><tr><th>Age</th><th>Ticket</th><th>ร้าน</th><th>SKU</th><th>BO Qty</th><th>ETA</th><th>Status</th><th>Actions</th></tr></thead><tbody>';
                rows.forEach(r => {
                    const ageBucket = r.age_bucket || 'fresh';
                    const ageH = Math.floor(r.age_hours || 0);
                    const stat = r.status || 'pending';
                    let actions = '';
                    if (stat === 'ready' || stat === 'pending') {
                        actions += `<button class="bo-btn bo-btn-success" onclick="b2bBoFulfill(${r.order_id}, ${r.id}, '${esc(r.sku)}', ${r.qty_bo})">ส่ง BO</button> `;
                        actions += `<button class="bo-btn bo-btn-danger" onclick="b2bBoCancelItem(${r.order_id}, ${r.id})">ยกเลิก</button>`;
                    }
                    html += `<tr>
                        <td><span class="bo-age ${ageBucket}">${ageH}h</span></td>
                        <td>${esc(r.ticket_no || '#' + r.order_id)}</td>
                        <td>${esc(r.distributor_name || '-')}</td>
                        <td>${esc(r.sku)}</td>
                        <td>${r.qty_bo}</td>
                        <td>${esc(r.eta || '-')}</td>
                        <td><span class="bo-stat ${stat}">${esc(stat)}</span></td>
                        <td>${actions}</td>
                    </tr>`;
                });
                html += '</tbody></table>';
                container.innerHTML = html;
            });
        }

        window.b2bBoFulfill = function(orderId, boQueueId, sku, qty) {
            if (!confirm(`Ship BO ${sku} × ${qty}?`)) return;
            apiCall('bo-fulfill', {
                method: 'POST',
                body: JSON.stringify({ order_id: orderId, items: [{ bo_queue_id: boQueueId, sku: sku, qty: qty }] })
            }).then(res => {
                if (res.success) {
                    alert(`✅ Fulfilled — ${res.total_fulfilled_qty} ชิ้น${res.all_resolved ? ' (all BO resolved)' : ''}`);
                    loadQueue();
                } else alert('❌ ' + (res.message || 'error'));
            });
        };

        window.b2bBoCancelItem = function(orderId, boQueueId) {
            const reason = prompt('เหตุผลที่ยกเลิก BO item:', 'discontinued');
            if (reason === null) return;
            apiCall('bo-cancel-item', {
                method: 'POST',
                body: JSON.stringify({ order_id: orderId, bo_queue_id: boQueueId, reason: reason })
            }).then(res => {
                if (res.success) { alert('✅ BO item ยกเลิกแล้ว'); loadQueue(); }
                else alert('❌ ' + (res.message || 'error'));
            });
        };

        document.getElementById('bo-restock-scan').addEventListener('click', function() {
            this.disabled = true;
            this.textContent = '⏳ Scanning...';
            apiCall('bo-restock-scan', { method: 'POST', body: '{}' }).then(res => {
                alert(res.success ? `✅ Marked ready: ${(res.marked_ready || []).length} รายการ` : '❌ error');
                this.disabled = false;
                this.textContent = '🔍 Restock Scan';
                loadQueue();
            });
        });

        document.getElementById('bo-refresh-pending').addEventListener('click', loadPending);
        document.getElementById('bo-refresh-queue').addEventListener('click', loadQueue);
        document.getElementById('bo-filter-status').addEventListener('change', loadQueue);
        document.getElementById('bo-filter-age').addEventListener('change', loadQueue);
        document.getElementById('bo-filter-sku').addEventListener('input', (e) => {
            clearTimeout(window._boSkuTimer);
            window._boSkuTimer = setTimeout(loadQueue, 300);
        });

        // Initial load
        loadPending();
        loadQueue();
    })();
    </script>
    <?php
    return ob_get_clean();
} );

