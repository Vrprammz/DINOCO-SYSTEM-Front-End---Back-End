/**
 * 4.3 — POST /b2b/v1/bo-reject
 * Admin rejects entire order
 */
if ( ! function_exists( 'b2b_rest_bo_reject' ) ) {
    function b2b_rest_bo_reject( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        $reason   = sanitize_text_field( $request->get_param( 'reason' ) ?: '' );

        if ( ! $order_id ) return new WP_Error( 'invalid_input', 'order_id required', array( 'status' => 400 ) );

        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'pending_stock_review' ) {
            return new WP_Error( 'invalid_status', 'Order must be in pending_stock_review', array( 'status' => 400 ) );
        }

        // Revert daily counters
        $dist_id = (int) get_field( 'distributor_id', $order_id );
        $order_items_text = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items     = b2b_bo_parse_order_items( $order_items_text );
        $total_value      = (float) get_field( 'total_amount', $order_id );

        if ( $dist_id ) {
            b2b_bo_decrement_daily_counters( $dist_id, $parsed_items, $total_value );
        }

        // FSM: pending_stock_review → cancelled
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'cancelled', 'admin', "admin reject: {$reason}" );
            if ( is_wp_error( $transition ) ) return $transition;
        }

        update_post_meta( $order_id, '_b2b_reject_reason', $reason );
        b2b_log_attempt( $dist_id, 'cancel', $order_id, '', 'rejected', 'ADMIN_REJECT' );

        // Notify customer
        if ( function_exists( 'b2b_bo_notify_customer_rejected' ) ) {
            b2b_bo_notify_customer_rejected( $order_id, $reason );
        }

        return rest_ensure_response( array( 'success' => true, 'order_id' => $order_id, 'status' => 'cancelled' ) );
    }
}

/**
 * 4.4 — POST /b2b/v1/bo-undo-split
 */
if ( ! function_exists( 'b2b_rest_bo_undo_split' ) ) {
    function b2b_rest_bo_undo_split( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        if ( ! $order_id ) return new WP_Error( 'invalid_input', 'order_id required', array( 'status' => 400 ) );

        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'partial_fulfilled' ) {
            return new WP_Error( 'invalid_status', 'Order must be in partial_fulfilled', array( 'status' => 400 ) );
        }

        $deadline = (int) get_post_meta( $order_id, '_b2b_split_undo_deadline', true );
        if ( time() > $deadline ) {
            return new WP_Error( 'undo_window_expired', 'Undo window expired (10 min)', array( 'status' => 400 ) );
        }

        // Security H5 FIX: 1 undo per order max (prevent oscillation attack)
        $undo_count = (int) get_post_meta( $order_id, '_b2b_undo_count', true );
        if ( $undo_count >= 1 ) {
            return new WP_Error( 'undo_limit_reached', 'Undo แล้ว 1 ครั้ง — ต้องติดต่อ admin เพื่อ reset', array( 'status' => 400 ) );
        }

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        // Check no BO already fulfilled
        $fulfilled = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$bo_table} WHERE order_id = %d AND status = 'fulfilled'",
            $order_id
        ) );
        if ( $fulfilled > 0 ) {
            return new WP_Error( 'bo_already_fulfilled', 'Cannot undo — some BO items already fulfilled', array( 'status' => 400 ) );
        }

        $wpdb->query( 'START TRANSACTION' );

        // Restore stock (add back fulfilled qty)
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM {$bo_table} WHERE order_id = %d",
            $order_id
        ), ARRAY_A );

        // Reverse: any item that had qty_fulfill > 0 needs stock restoration
        // For simplicity: restore by re-subtracting debt + deleting bo_queue rows
        $order_items_text = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items     = b2b_bo_parse_order_items( $order_items_text );

        // Restore stock for fulfilled portions (recompute from parsed - bo qty)
        foreach ( $parsed_items as $pi ) {
            $bo_qty_for_sku = 0;
            foreach ( $rows as $r ) {
                if ( strtoupper( $r['sku'] ) === strtoupper( $pi['sku'] ) ) {
                    $bo_qty_for_sku += (int) $r['qty_bo'];
                }
            }
            $fulfilled_qty = $pi['qty'] - $bo_qty_for_sku;
            if ( $fulfilled_qty > 0 && function_exists( 'dinoco_stock_add' ) && function_exists( 'dinoco_get_leaf_skus' ) ) {
                $leaves = dinoco_get_leaf_skus( $pi['sku'] );
                foreach ( $leaves as $leaf ) {
                    dinoco_stock_add( $leaf, $fulfilled_qty, 'b2b_undo_split', 'b2b_order', $order_id );
                }
            }
        }

        // Delete bo_queue rows
        $wpdb->delete( $bo_table, array( 'order_id' => $order_id ) );

        // Reverse debt
        $dist_id = (int) get_field( 'distributor_id', $order_id );
        if ( $dist_id && function_exists( 'b2b_debt_subtract' ) ) {
            // Reverse previous b2b_debt_add — compute from meta (or just use recalculate)
            if ( function_exists( 'b2b_recalculate_debt' ) ) {
                b2b_recalculate_debt( $dist_id );
            }
        }

        // FSM: partial_fulfilled → pending_stock_review
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'pending_stock_review', 'admin', 'admin undo split' );
            if ( is_wp_error( $transition ) ) {
                $wpdb->query( 'ROLLBACK' );
                return $transition;
            }
        }

        // Clean meta + increment undo count (Security H5 FIX)
        delete_post_meta( $order_id, '_b2b_split_at' );
        delete_post_meta( $order_id, '_b2b_split_by' );
        delete_post_meta( $order_id, '_b2b_split_undo_deadline' );
        update_post_meta( $order_id, '_b2b_undo_count', $undo_count + 1 );

        $wpdb->query( 'COMMIT' );

        b2b_log_attempt( $dist_id, 'undo_split', $order_id, '', 'accepted' );

        return rest_ensure_response( array( 'success' => true, 'order_id' => $order_id, 'status' => 'pending_stock_review' ) );
    }
}

/**
 * 4.5 — POST /b2b/v1/bo-fulfill
 * Ship BO items after restock
 */
if ( ! function_exists( 'b2b_rest_bo_fulfill' ) ) {
    function b2b_rest_bo_fulfill( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        $items    = $request->get_param( 'items' );

        if ( ! $order_id || ! is_array( $items ) || empty( $items ) ) {
            return new WP_Error( 'invalid_input', 'order_id + items required', array( 'status' => 400 ) );
        }

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $wpdb->query( 'START TRANSACTION' );

        $total_fulfilled_qty = 0;
        $total_fulfilled_value = 0;

        foreach ( $items as $item ) {
            $bo_queue_id = (int) ( $item['bo_queue_id'] ?? 0 );
            $qty         = max( 1, (int) ( $item['qty'] ?? 0 ) );
            $sku         = strtoupper( trim( $item['sku'] ?? '' ) );

            if ( ! $bo_queue_id ) continue;

            // Lock BO row
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$bo_table} WHERE id = %d AND order_id = %d FOR UPDATE",
                $bo_queue_id, $order_id
            ) );
            if ( ! $row || $row->status !== 'pending' && $row->status !== 'ready' ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'invalid_bo_row', "BO row {$bo_queue_id} ไม่สามารถ fulfill ได้", array( 'status' => 400 ) );
            }
            if ( $qty > (int) $row->qty_bo ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'qty_exceeded', "qty({$qty}) > qty_bo({$row->qty_bo})", array( 'status' => 400 ) );
            }

            // Subtract stock
            if ( function_exists( 'dinoco_stock_subtract' ) && function_exists( 'dinoco_get_leaf_skus' ) ) {
                $leaves = dinoco_get_leaf_skus( $row->sku );
                foreach ( $leaves as $leaf ) {
                    $result = dinoco_stock_subtract( $leaf, $qty, 'b2b_bo_fulfilled', 'b2b_order', $order_id );
                    if ( is_wp_error( $result ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'stock_error', "Stock subtract failed: {$leaf}", array( 'status' => 500 ) );
                    }
                }
            }

            // Update bo_queue
            $remaining = (int) $row->qty_bo - $qty;
            if ( $remaining <= 0 ) {
                $wpdb->update( $bo_table, array(
                    'status'      => 'fulfilled',
                    'resolved_at' => current_time( 'mysql' ),
                ), array( 'id' => $bo_queue_id ) );
            } else {
                $wpdb->update( $bo_table, array(
                    'qty_bo' => $remaining,
                ), array( 'id' => $bo_queue_id ) );
            }

            // Add debt for BO qty
            $dist_id = (int) get_field( 'distributor_id', $order_id );
            $pd      = function_exists( 'b2b_get_product_data' ) ? b2b_get_product_data( $row->sku ) : null;
            $price   = $pd ? (float) ( $pd['base_price'] ?? 0 ) : 0;
            if ( $dist_id && $price > 0 && function_exists( 'b2b_debt_add' ) ) {
                b2b_debt_add( $dist_id, $price * $qty, 'b2b_bo_fulfilled', $order_id );
            }

            $total_fulfilled_qty   += $qty;
            $total_fulfilled_value += $price * $qty;
        }

        // Check if all BO items resolved → transition to awaiting_confirm
        $pending_count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$bo_table} WHERE order_id = %d AND status IN ('pending', 'ready')",
            $order_id
        ) );

        if ( $pending_count === 0 ) {
            if ( function_exists( 'b2b_transition_order' ) ) {
                b2b_transition_order( $order_id, 'awaiting_confirm', 'admin', 'all BO resolved' );
            }
        }

        $wpdb->query( 'COMMIT' );

        // Log + notify
        $dist_id = (int) get_field( 'distributor_id', $order_id );
        b2b_log_attempt( $dist_id, 'bo_fulfill', $order_id, '', 'accepted', null, array(
            'total_qty' => $total_fulfilled_qty, 'total_value' => $total_fulfilled_value
        ) );

        if ( function_exists( 'b2b_bo_notify_customer_bo_ready' ) ) {
            b2b_bo_notify_customer_bo_ready( $order_id, $items );
        }

        return rest_ensure_response( array(
            'success'               => true,
            'order_id'              => $order_id,
            'total_fulfilled_qty'   => $total_fulfilled_qty,
            'total_fulfilled_value' => $total_fulfilled_value,
            'all_resolved'          => $pending_count === 0,
        ) );
    }
}

/**
 * 4.6 — POST /b2b/v1/bo-cancel-item
