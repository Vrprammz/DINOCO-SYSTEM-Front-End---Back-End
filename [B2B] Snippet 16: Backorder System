    }

    global $wpdb;
    $log_table = $wpdb->prefix . 'dinoco_order_attempt_log';

    // Filters via GET
    $f_action   = isset( $_GET['bo_filter_action'] ) ? sanitize_key( $_GET['bo_filter_action'] ) : 'all';
    $f_result   = isset( $_GET['bo_filter_result'] ) ? sanitize_key( $_GET['bo_filter_result'] ) : 'all';
    $f_dist_id  = isset( $_GET['bo_filter_dist'] ) ? absint( $_GET['bo_filter_dist'] ) : 0;
    $f_days     = isset( $_GET['bo_filter_days'] ) ? max( 1, min( 90, absint( $_GET['bo_filter_days'] ) ) ) : 7;
    $page_num   = isset( $_GET['bo_page'] ) ? max( 1, absint( $_GET['bo_page'] ) ) : 1;
    $per_page   = 50;
    $offset     = ( $page_num - 1 ) * $per_page;

    // CSV export (before render)
    if ( isset( $_GET['bo_export'] ) && $_GET['bo_export'] === '1' && check_admin_referer( 'bo_security_log_csv' ) ) {
        $where_csv = array( "created_at > DATE_SUB(NOW(), INTERVAL %d DAY)" );
        $params_csv = array( $f_days );
        if ( $f_action !== 'all' ) { $where_csv[] = 'action = %s'; $params_csv[] = $f_action; }
        if ( $f_result !== 'all' ) { $where_csv[] = 'result = %s'; $params_csv[] = $f_result; }
        if ( $f_dist_id )         { $where_csv[] = 'distributor_id = %d'; $params_csv[] = $f_dist_id; }

        $sql_csv = "SELECT * FROM {$log_table} WHERE " . implode( ' AND ', $where_csv ) . " ORDER BY created_at DESC LIMIT 5000";
        $rows_csv = $wpdb->get_results( $wpdb->prepare( $sql_csv, ...$params_csv ), ARRAY_A );

        header( 'Content-Type: text/csv; charset=utf-8' );
        header( 'Content-Disposition: attachment; filename=bo-security-log-' . date( 'Ymd-His' ) . '.csv' );
        $out = fopen( 'php://output', 'w' );
        fputs( $out, "\xEF\xBB\xBF" ); // UTF-8 BOM for Excel
        fputcsv( $out, array( 'ID', 'Time', 'Distributor', 'Group', 'Action', 'Order ID', 'Result', 'Rejection Code', 'IP', 'UA', 'Total Qty', 'Total Value' ) );
        foreach ( $rows_csv as $r ) {
            $dist_name = $r['distributor_id'] ? get_the_title( $r['distributor_id'] ) : '';
