/**
 * H5 FIX: Flash shipping secondary order on BO fulfill (spec §9.2)
 * เมื่อ BO fulfilled → เรียก Flash API สร้าง order แยกสำหรับ BO qty
 * (cleaner tracking vs append existing order)
 */
add_action( 'b2b_bo_items_fulfilled', function( $order_id, $items, $meta ) {
    // Only trigger Flash if helper exists (Snippet 5 or 3 defines this)
    if ( ! function_exists( 'b2b_flash_create_order' ) && ! function_exists( 'b2b_flash_create_secondary' ) ) {
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( "[BO-H5] Flash helper not available — order #{$order_id} BO fulfill skipped secondary Flash creation" );
        }
        return;
    }

    // Prefer dedicated secondary helper if exists
    if ( function_exists( 'b2b_flash_create_secondary' ) ) {
        try {
            $result = b2b_flash_create_secondary( $order_id, $items );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[BO-H5] Flash secondary order created — order #{$order_id} result=" . wp_json_encode( is_array( $result ) ? $result : array( 'raw' => (string) $result ) ) );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[BO-H5] Flash secondary error: " . $e->getMessage() );
            }
        }
        return;
    }

    // Fallback: use generic b2b_flash_create_order + tag as BO secondary
    if ( function_exists( 'b2b_flash_create_order' ) ) {
        try {
            $result = b2b_flash_create_order( $order_id, array(
                'is_bo_secondary' => true,
                'bo_items'        => $items,
                'skip_duplicate_check' => true, // BO = expected duplicate parent order
            ) );
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[BO-H5] Flash fallback order — #{$order_id} result=" . wp_json_encode( is_array( $result ) ? $result : array( 'raw' => (string) $result ) ) );
            }
        } catch ( \Throwable $e ) {
            if ( function_exists( 'b2b_log' ) ) {
                b2b_log( "[BO-H5] Flash fallback error: " . $e->getMessage() );
            }
        }
    }
}, 10, 3 );

/**
 * H6 FIX: Print queue secondary label on BO fulfill (spec §9.2)
 * Enqueue new print job พร้อม metadata `_print_queued_bo` flag
 */
add_action( 'b2b_bo_items_fulfilled', function( $order_id, $items, $meta ) {
    if ( ! function_exists( 'b2b_enqueue_print_job' ) ) {
        // Fallback: flag order meta สำหรับ RPi dashboard manual reprint
        update_post_meta( $order_id, '_print_queued_bo', array(
            'queued_at' => current_time( 'mysql' ),
            'items'     => $items,
            'meta'      => $meta,
        ) );
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( "[BO-H6] Print queue helper not found — meta flag only — order #{$order_id}" );
        }
        return;
    }

    try {
        $job_id = b2b_enqueue_print_job( $order_id, array(
            'source'     => 'bo_fulfill',
            'bo_items'   => $items,
            'is_secondary' => true,
        ) );
        update_post_meta( $order_id, '_print_queued_bo', array(
            'queued_at' => current_time( 'mysql' ),
            'job_id'    => $job_id,
        ) );
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( "[BO-H6] Print job queued — order #{$order_id} job_id=" . wp_json_encode( $job_id ) );
        }
    } catch ( \Throwable $e ) {
        if ( function_exists( 'b2b_log' ) ) {
            b2b_log( "[BO-H6] Print queue error: " . $e->getMessage() );
        }
    }
}, 20, 3 ); // Priority 20 — after H5 Flash (order doesn't matter much but H5 first)

/**
 * 4.6 — POST /b2b/v1/bo-cancel-item
 * Cancel discontinued BO item
 */
if ( ! function_exists( 'b2b_rest_bo_cancel_item' ) ) {
    function b2b_rest_bo_cancel_item( $request ) {
        $order_id    = (int) $request->get_param( 'order_id' );
        $bo_queue_id = (int) $request->get_param( 'bo_queue_id' );
        $reason      = sanitize_text_field( $request->get_param( 'reason' ) ?: 'discontinued' );

        if ( ! $order_id || ! $bo_queue_id ) {
            return new WP_Error( 'invalid_input', 'order_id + bo_queue_id required', array( 'status' => 400 ) );
        }

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        // V.1.8 BUG-C3 FIX: snapshot row BEFORE update for customer notify (row after update
        // will show status='cancelled' which customer-notify expects, but qty_bo field
        // is identical so pre/post snapshot is equivalent — we snapshot pre for clarity)
        $row_before = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$bo_table} WHERE id = %d AND order_id = %d",
            $bo_queue_id, $order_id
        ), ARRAY_A );

        $updated = $wpdb->update( $bo_table, array(
            'status'      => 'cancelled',
            'notes'       => 'CANCELLED: ' . $reason,
            'resolved_at' => current_time( 'mysql' ),
        ), array( 'id' => $bo_queue_id, 'order_id' => $order_id ) );

        if ( ! $updated ) {
            return new WP_Error( 'update_failed', 'Cancel update failed', array( 'status' => 500 ) );
        }

        // Check all BO resolved → transition
        $pending_count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$bo_table} WHERE order_id = %d AND status IN ('pending', 'ready')",
            $order_id
        ) );
        if ( $pending_count === 0 ) {
            // V.1.8 BUG-C3 FIX: cascade guard — กันไม่ให้ awaiting_confirm transition
            // ตัด stock ซ้ำ (hook `dinoco_inv_on_status_change` parse order_items เต็ม qty
            // รวมถึง cancelled SKUs). Stock ถูกตัด manual ใน bo-split (fulfilled portion) +
            // bo-fulfill (BO ที่ถูก fulfill) แล้ว — cancelled BO ไม่ควรตัดอีก.
            // ถ้า flag ยังไม่ได้ set (edge case: bo-split ไม่ถูกเรียก — เฉพาะ bo-cancel-item
            // บน pending_stock_review → partial_fulfilled path) → set now.
            if ( ! get_post_meta( $order_id, '_stock_deducted', true ) ) {
                update_post_meta( $order_id, '_stock_deducted', 1 );
            }

            if ( function_exists( 'b2b_transition_order' ) ) {
                b2b_transition_order( $order_id, 'awaiting_confirm', 'admin', 'all BO resolved (some cancelled)' );
            }

            // V.1.8 BUG-C3 FIX: recompute debt via b2b_recalculate_debt source-of-truth
            // เดิม total_amount ไม่ถูก recompute → ลูกค้าอาจถูกเรียกเก็บยอดเดิม.
            // Note: b2b_debt_add ถูกเรียกไปแล้วใน bo-split (confirmed_value) + bo-fulfill
            //       (per BO row). Cancelled BO rows ไม่ถูก b2b_debt_add → debt ถูกต้องอยู่แล้ว.
            //       recalculate เพื่อ reconcile กรณี edge (partial payment, manual adjustment).
            $dist_id = (int) get_field( 'distributor_id', $order_id );
            if ( $dist_id && function_exists( 'b2b_recalculate_debt' ) ) {
                b2b_recalculate_debt( $dist_id );
            }
        }

        // Notify customer
        if ( function_exists( 'b2b_bo_notify_customer_bo_cancelled' ) && $row_before ) {
            b2b_bo_notify_customer_bo_cancelled( $order_id, $row_before, $reason );
        }

        return rest_ensure_response( array( 'success' => true, 'bo_queue_id' => $bo_queue_id, 'status' => 'cancelled' ) );
    }
}

/**
 * 4.7 — GET /b2b/v1/bo-queue
 */
if ( ! function_exists( 'b2b_rest_bo_queue' ) ) {
    function b2b_rest_bo_queue( $request ) {
        $args = array(
            'status'       => $request->get_param( 'status' ) ?: 'all',
            'sku'          => $request->get_param( 'sku' ) ?: null,
            'age_gt_hours' => (int) ( $request->get_param( 'age_gt_hours' ) ?: 0 ),
            'order_id'     => (int) ( $request->get_param( 'order_id' ) ?: 0 ),
            'limit'        => min( 500, (int) ( $request->get_param( 'limit' ) ?: 100 ) ),
            'offset'       => max( 0, (int) ( $request->get_param( 'offset' ) ?: 0 ) ),
        );

        $rows = b2b_bo_get_queue_rows( $args );

        // Enrich with age_bucket + distributor_name
        $data = array();
        foreach ( $rows as $r ) {
            $r['age_bucket'] = b2b_bo_compute_age_bucket( $r );
            $r['age_hours']  = ( time() - strtotime( $r['created_at'] ) ) / 3600;
            $dist_id         = (int) get_field( 'distributor_id', $r['order_id'] );
            $r['distributor_name'] = $dist_id ? get_the_title( $dist_id ) : '';
            $r['ticket_no']        = get_the_title( $r['order_id'] );
            $data[] = $r;
        }

        // Summary
        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';
        $summary  = array(
            'total_pending'  => (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$bo_table} WHERE status='pending'" ),
            'total_ready'    => (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$bo_table} WHERE status='ready'" ),
            'oldest_age_hours' => (int) $wpdb->get_var( "SELECT COALESCE(TIMESTAMPDIFF(HOUR, MIN(created_at), NOW()), 0) FROM {$bo_table} WHERE status='pending'" ),
        );
        $summary['needs_attention'] = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$bo_table} WHERE status='pending' AND TIMESTAMPDIFF(HOUR, created_at, NOW()) > 168" );

        return rest_ensure_response( array( 'success' => true, 'data' => $data, 'summary' => $summary ) );
    }
}

