if ( ! function_exists( 'b2b_bo_flag_enabled' ) ) {
    /**
     * Master feature flag helper
     * + Option: beta distributors whitelist (array of distributor post IDs)
     */
    function b2b_bo_flag_enabled( $distributor_id = 0 ) {
        if ( ! get_option( 'b2b_flag_bo_system', false ) ) return false;

        $beta_list = get_option( 'b2b_flag_bo_beta_distributors', array() );
        if ( ! is_array( $beta_list ) || empty( $beta_list ) ) {
            // Empty beta list = flag applies globally
            return true;
        }

        // Whitelist mode
        return $distributor_id && in_array( (int) $distributor_id, array_map( 'intval', $beta_list ), true );
    }
}

