                        <?php if ( $r['user_agent'] ): ?>
                            <div title="<?php echo esc_attr( $r['user_agent'] ); ?>" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><?php echo esc_html( substr( $r['user_agent'], 0, 50 ) ); ?></div>
                        <?php endif; ?>
                    </td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>

        <?php if ( $total_pages > 1 ):
            $base_url = remove_query_arg( array( 'bo_page', 'bo_export', '_wpnonce' ) );
        ?>
        <div class="pager">
            <?php
            $range = 3;
            for ( $p = 1; $p <= $total_pages; $p++ ) {
                if ( $p == 1 || $p == $total_pages || abs( $p - $page_num ) <= $range ) {
                    if ( $p == $page_num ) {
                        echo '<span class="current">' . $p . '</span>';
                    } else {
                        echo '<a href="' . esc_url( add_query_arg( 'bo_page', $p, $base_url ) ) . '">' . $p . '</a>';
                    }
                } elseif ( abs( $p - $page_num ) == $range + 1 ) {
                    echo '<span>…</span>';
                }
            }
            ?>
        </div>
        <?php endif; ?>
        <?php endif; ?>
    </div>
    <?php
    return ob_get_clean();
} );

