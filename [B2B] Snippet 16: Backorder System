        if ( function_exists( 'b2b_line_push_text' ) ) {
            b2b_line_push_text( $group_id, $text );
        }
    }
}

if ( ! function_exists( 'b2b_bo_notify_admin_stock_review' ) ) {
    /**
     * Push stock review Flex to admin group (called after opaque accept)
     */
    function b2b_bo_notify_admin_stock_review( $order_id ) {
        $flex = b2b_build_flex_stock_review_admin( $order_id );
        if ( function_exists( 'b2b_push_raw_to_admin' ) ) {
