 * No code execution — only wp_options UPDATE
 */
add_shortcode( 'b2b_bo_flags', function() {
    if ( ! current_user_can( 'manage_options' ) ) {
        return '<p style="color:#dc2626;">⚠️ ต้องเป็น admin เท่านั้น</p>';
