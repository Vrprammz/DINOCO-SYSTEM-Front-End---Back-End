if ( ! function_exists( 'b2b_build_flex_stock_review_admin' ) ) {
    /**
     * Admin Flex — stock review with delta (admin-only visibility)
     */
    function b2b_build_flex_stock_review_admin( $order_id ) {
        $ticket_no    = get_the_title( $order_id );
        $dist_id      = (int) get_field( 'distributor_id', $order_id );
        $dist_name    = $dist_id ? get_the_title( $dist_id ) : 'ไม่ระบุ';
        $order_text   = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items = b2b_bo_parse_order_items( $order_text );
        $total_value  = (float) get_field( 'total_amount', $order_id );

        // Per-item delta
        $body_contents = array();
        $insufficient  = 0;

        // Security C1 FIX (security-pentester review): LINE group message มี insider risk
        // → ไม่แสดง exact qty ใน Flex, ใช้ bucket indicator แทน
        // → Exact qty เฉพาะใน Admin Dashboard UI (manage_options gate)
        foreach ( $parsed_items as $pi ) {
            $sku = $pi['sku'];
            $qty = $pi['qty'];

            $available = 0;
            if ( function_exists( 'dinoco_compute_hierarchy_stock' ) && function_exists( 'dinoco_get_reserved_qty' ) ) {
                $computed  = (int) dinoco_compute_hierarchy_stock( $sku );
                $reserved  = (int) dinoco_get_reserved_qty( $sku );
                $available = max( 0, $computed - $reserved );
            }

            $is_sufficient = $available >= $qty;
            if ( ! $is_sufficient ) $insufficient++;

            // Bucket indicator (no exact qty leak)
            $bucket = $is_sufficient ? '✓ พอ' : ( $available === 0 ? '⚠️ หมด' : '⚠️ ไม่พอ (ต้อง split)' );

            $body_contents[] = array(
                'type'    => 'text',
                'text'    => "SKU {$sku}",
                'weight'  => 'bold',
                'size'    => 'sm',
                'margin'  => 'md',
            );
            $body_contents[] = array(
                'type'   => 'text',
                'text'   => "สั่ง {$qty} · {$bucket}",
                'size'   => 'xs',
                'color'  => $is_sufficient ? '#10b981' : '#dc2626',
                'wrap'   => true,
            );
        }

        $body_contents[] = array( 'type' => 'separator', 'margin' => 'lg' );
        $body_contents[] = array(
            'type' => 'text',
            'text' => 'ยอดรวม: ฿' . number_format( $total_value, 2 ),
            'weight' => 'bold',
            'size' => 'sm',
            'margin' => 'md',
        );
        if ( $insufficient > 0 ) {
            $body_contents[] = array(
                'type' => 'text',
                'text' => "สต็อกไม่พอ: {$insufficient} รายการ",
                'size' => 'xs',
                'color' => '#dc2626',
            );
        }

        // Action buttons
        $footer_buttons = array();

        $footer_buttons[] = array(
            'type'   => 'button',
            'style'  => $insufficient > 0 ? 'secondary' : 'primary',
            'color'  => $insufficient > 0 ? null : '#10b981',
            'action' => array(
                'type'        => 'postback',
                'label'       => '✅ ยืนยันเต็ม',
                'data'        => "action=bo_confirm_full&order_id={$order_id}",
                'displayText' => 'ยืนยันเต็ม',
            ),
        );

        if ( $insufficient > 0 ) {
            $footer_buttons[] = array(
                'type'   => 'button',
                'style'  => 'primary',
                'color'  => '#f59e0b',
                'action' => array(
                    'type'  => 'uri',
                    'label' => '⚙️ Split BO',
                    'uri'   => function_exists( 'b2b_liff_url' )
                        ? b2b_liff_url( 'admin-bo-split', array( 'order_id' => $order_id ) )
                        : home_url( "/admin-bo-split/?order_id={$order_id}" ),
                ),
            );
        }

        $footer_buttons[] = array(
            'type'   => 'button',
            'style'  => 'secondary',
            'action' => array(
                'type'        => 'postback',
                'label'       => '❌ ปฏิเสธ',
                'data'        => "action=bo_reject&order_id={$order_id}",
                'displayText' => 'ปฏิเสธ',
            ),
        );

        return array(
            'type'    => 'flex',
            'altText' => "🔔 ตรวจสอบสต็อก #{$ticket_no}",
            'contents' => array(
                'type' => 'bubble',
                'header' => array(
                    'type' => 'box',
                    'layout' => 'vertical',
                    'backgroundColor' => '#1e3a8a',
                    'contents' => array(
                        array( 'type' => 'text', 'text' => "🔔 ตรวจสอบสต็อก #{$ticket_no}", 'color' => '#ffffff', 'weight' => 'bold', 'size' => 'md' ),
                        array( 'type' => 'text', 'text' => "ร้าน: " . esc_html( $dist_name ), 'color' => '#e0e7ff', 'size' => 'xs', 'margin' => 'xs' ),
                    ),
                ),
                'body' => array(
                    'type' => 'box',
                    'layout' => 'vertical',
                    'contents' => $body_contents,
                ),
                'footer' => array(
                    'type' => 'box',
                    'layout' => 'vertical',
                    'spacing' => 'sm',
                    'contents' => $footer_buttons,
                ),
            ),
        );
    }
}

