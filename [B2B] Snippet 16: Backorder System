if ( ! function_exists( 'b2b_bo_permission_admin' ) ) {
    /**
     * Security H1 FIX: CSRF scheme
     *   - WP admin → X-WP-Nonce header + wp_verify_nonce('wp_rest') (standard WP REST)
     *   - Admin LINE LIFF → JWT session token via b2b_verify_session_token + is_admin flag
     * GET requests skip nonce (read-only) — POST/PUT/DELETE enforce
     */
    function b2b_bo_permission_admin( $request ) {
        $method = $request->get_method();

        // WP admin path
        if ( current_user_can( 'manage_options' ) ) {
            // Enforce nonce for write methods
            if ( in_array( $method, array( 'POST', 'PUT', 'DELETE' ), true ) ) {
                $nonce = $request->get_header( 'X-WP-Nonce' );
                if ( ! $nonce || ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
                    return new WP_Error( 'rest_csrf_failed', 'Nonce required for write ops', array( 'status' => 403 ) );
                }
            }
            return true;
        }

        // Admin LINE LIFF path (session JWT)
        if ( function_exists( 'b2b_verify_session_token' ) ) {
            $session = b2b_verify_session_token( $request );
            if ( $session && ! empty( $session['is_admin'] ) ) {
                // Session token itself = CSRF defense (attacker can't forge)
                return true;
            }
        }

        return new WP_Error( 'rest_forbidden', 'Admin only', array( 'status' => 403 ) );
    }
}

/**
 * 4.1 — POST /b2b/v1/bo-split
 * Admin splits order into fulfilled + BO items
 *
 * Request: { order_id, splits: [{sku, qty_fulfill, qty_bo, eta_days, notes}] }
 */
if ( ! function_exists( 'b2b_rest_bo_split' ) ) {
    function b2b_rest_bo_split( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        $splits   = $request->get_param( 'splits' );

        if ( ! $order_id || ! is_array( $splits ) || empty( $splits ) ) {
            return new WP_Error( 'invalid_input', 'order_id + splits required', array( 'status' => 400 ) );
        }

        // Validate order status
        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'pending_stock_review' ) {
            return new WP_Error( 'invalid_status', "Order ต้องอยู่ใน pending_stock_review (current={$status})", array( 'status' => 400 ) );
        }

        // Load existing order items (from meta or order_text)
        $order_items_text = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items     = b2b_bo_parse_order_items( $order_items_text );

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $wpdb->query( 'START TRANSACTION' );

        $fulfilled_total = 0;
        $bo_total        = 0;
        $bo_queue_ids    = array();
        $dist_id         = (int) get_field( 'distributor_id', $order_id );

        foreach ( $splits as $idx => $split ) {
            $sku          = strtoupper( trim( $split['sku'] ?? '' ) );
            $qty_fulfill  = max( 0, (int) ( $split['qty_fulfill'] ?? 0 ) );
            $qty_bo       = max( 0, (int) ( $split['qty_bo'] ?? 0 ) );
            $eta_days     = max( 0, (int) ( $split['eta_days'] ?? b2b_bo_get_config( 'b2b_bo_eta_default_days' ) ) );
            $notes        = sanitize_text_field( $split['notes'] ?? '' );

            // Validate invariant: qty_fulfill + qty_bo === original_qty
            $original_qty = 0;
            foreach ( $parsed_items as $pi ) {
                if ( $pi['sku'] === $sku ) {
                    $original_qty = $pi['qty'];
                    break;
                }
            }
            if ( $qty_fulfill + $qty_bo !== $original_qty ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'invariant_violation',
                    "SKU {$sku}: qty_fulfill({$qty_fulfill}) + qty_bo({$qty_bo}) ต้อง = original({$original_qty})",
                    array( 'status' => 400 )
                );
            }

            // Subtract stock for fulfilled qty (leaf-aware)
            if ( $qty_fulfill > 0 && function_exists( 'dinoco_stock_subtract' ) && function_exists( 'dinoco_get_leaf_skus' ) ) {
                $leaves = dinoco_get_leaf_skus( $sku );
                foreach ( $leaves as $leaf ) {
                    $result = dinoco_stock_subtract( $leaf, $qty_fulfill, 'b2b_reserved', 'b2b_order', $order_id );
                    if ( is_wp_error( $result ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'stock_error',
                            "Stock subtract failed for {$leaf}: " . $result->get_error_message(),
                            array( 'status' => 500 )
                        );
                    }
                }
            }

            // Insert bo_queue row (if qty_bo > 0)
            if ( $qty_bo > 0 ) {
                $eta_date = $eta_days > 0 ? date( 'Y-m-d', strtotime( "+{$eta_days} days" ) ) : null;
                $inserted = $wpdb->insert( $bo_table, array(
                    'order_id'   => $order_id,
                    'item_index' => $idx,
                    'sku'        => $sku,
                    'qty_bo'     => $qty_bo,
                    'eta'        => $eta_date,
                    'status'     => 'pending',
                    'notes'      => $notes,
                    'created_at' => current_time( 'mysql' ),
                ) );
                if ( ! $inserted ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'db_error', 'bo_queue insert failed', array( 'status' => 500 ) );
                }
                $bo_queue_ids[] = $wpdb->insert_id;
            }

            $fulfilled_total += $qty_fulfill;
            $bo_total        += $qty_bo;
        }

        // V.1.6 M3 FIX: Debt precision — per-SKU compound (spec §5.2 step 5)
        // V.1.8 BUG-H3 FIX: dealer tier price (b2b_compute_dealer_price) — เดิมใช้ retail (base_price)
        // V.1.8 BUG-H4 FIX: fail-loud ถ้า b2b_get_product_data missing (ไม่ silent skip debt)
        // เดิม: total_value * (fulfilled / total_qty) = ratio approximation → ไม่แม่นยำ
        //       ถ้า SKU A = ฿1000 + SKU B = ฿100, fulfill A เต็ม + BO B → ratio คำนวณ debt เกินจริง
        // ใหม่: loop splits + per-SKU dealer-price × qty_fulfill → exact + tier-aware
        $confirmed_value = 0.0;
        $dealer_rank     = $dist_id ? ( get_field( 'rank_system', $dist_id ) ?: 'standard' ) : 'standard';
        if ( function_exists( 'b2b_get_product_data' ) ) {
            foreach ( $splits as $split ) {
                $sku_d = strtoupper( trim( $split['sku'] ?? '' ) );
                $qty_f = max( 0, (int) ( $split['qty_fulfill'] ?? 0 ) );
                if ( $qty_f <= 0 ) continue;
                $pd = b2b_get_product_data( $sku_d );
                if ( ! $pd ) {
                    // V.1.8 BUG-H4: fail-loud instead of silent skip — missing SKU = accounting hole
                    $wpdb->query( 'ROLLBACK' );
                    if ( function_exists( 'b2b_log' ) ) {
                        b2b_log( "[BO] CRITICAL: product_data missing for SKU {$sku_d}, order {$order_id} (bo-split)" );
                    }
                    if ( function_exists( 'b2b_send_telegram_alert' ) ) {
                        b2b_send_telegram_alert( 'bo_critical',
                            "BO SPLIT: missing product_data SKU={$sku_d} order=#{$order_id} — admin กรุณาตรวจสอบ (ROLLBACK แล้ว)" );
                    }
                    return new WP_Error( 'product_data_missing',
                        "ไม่พบข้อมูลสินค้า SKU: {$sku_d} — กรุณาติดต่อ admin",
                        array( 'status' => 500 )
                    );
                }
                $base  = (float) ( $pd['base_price'] ?? 0 );
                $price = function_exists( 'b2b_compute_dealer_price' )
                    ? (float) b2b_compute_dealer_price( $base, $dealer_rank, $pd )
                    : $base;
                $confirmed_value += $price * $qty_f;
            }
        }
        $total_value = (float) get_field( 'total_amount', $order_id );

        if ( $dist_id && $confirmed_value > 0 && function_exists( 'b2b_debt_add' ) ) {
            b2b_debt_add( $dist_id, $confirmed_value, 'b2b_bo_split_confirm', $order_id );
        }

        // V.1.8 BUG-C2 FIX: set _stock_deducted=1 BEFORE FSM transition
        // Reason: bo-split subtracted stock manual (lines 891-903); when all BO resolves later,
        //         FSM transition partial_fulfilled → awaiting_confirm fires hook
        //         `dinoco_inv_on_status_change` (Snippet 2:3682) which parses order_items and
        //         subtracts full qty AGAIN → inventory double-cut. Flag blocks the hook.
        if ( $fulfilled_total > 0 ) {
            update_post_meta( $order_id, '_stock_deducted', 1 );
        }

        // FSM transition: pending_stock_review → partial_fulfilled
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'partial_fulfilled', 'admin', 'admin split BO' );
            if ( is_wp_error( $transition ) ) {
                $wpdb->query( 'ROLLBACK' );
                return $transition;
            }
        }

        // Meta: undo window + audit
        $now_ts       = time();
        $undo_minutes = (int) b2b_bo_get_config( 'b2b_bo_split_undo_window_minutes' );
        update_post_meta( $order_id, '_b2b_split_at', $now_ts );
        update_post_meta( $order_id, '_b2b_split_by', get_current_user_id() );
        update_post_meta( $order_id, '_b2b_split_undo_deadline', $now_ts + ( $undo_minutes * 60 ) );

        $wpdb->query( 'COMMIT' );

        // Log attempt
        b2b_log_attempt( $dist_id, 'split', $order_id, '', 'accepted', null, array( 'total_qty' => $fulfilled_total + $bo_total ) );

        // Send customer notification Flex
        if ( function_exists( 'b2b_bo_notify_customer_split' ) ) {
            b2b_bo_notify_customer_split( $order_id );
        }

        return rest_ensure_response( array(
            'success'         => true,
            'order_id'        => $order_id,
            'status'          => 'partial_fulfilled',
            'fulfilled_total' => $fulfilled_total,
            'bo_total'        => $bo_total,
            'bo_queue_ids'    => $bo_queue_ids,
            'undo_deadline'   => date( 'Y-m-d H:i:s', $now_ts + ( $undo_minutes * 60 ) ),
        ) );
    }
}

/**
 * 4.2 — POST /b2b/v1/bo-confirm-full
 * Admin confirms full stock (no split)
 */
if ( ! function_exists( 'b2b_rest_bo_confirm_full' ) ) {
    function b2b_rest_bo_confirm_full( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        if ( ! $order_id ) return new WP_Error( 'invalid_input', 'order_id required', array( 'status' => 400 ) );

        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'pending_stock_review' ) {
            return new WP_Error( 'invalid_status', "Order ต้องอยู่ใน pending_stock_review", array( 'status' => 400 ) );
        }

        // FSM: pending_stock_review → awaiting_confirm (triggers existing stock subtract hook)
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'awaiting_confirm', 'admin', 'admin confirm full stock' );
            if ( is_wp_error( $transition ) ) return $transition;
        }

        $dist_id = (int) get_field( 'distributor_id', $order_id );
        b2b_log_attempt( $dist_id, 'split', $order_id, '', 'accepted', 'CONFIRM_FULL' );

        return rest_ensure_response( array( 'success' => true, 'order_id' => $order_id, 'status' => 'awaiting_confirm' ) );
    }
}

/**
 * 4.3 — POST /b2b/v1/bo-reject
 * Admin rejects entire order
 */
if ( ! function_exists( 'b2b_rest_bo_reject' ) ) {
    function b2b_rest_bo_reject( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        $reason   = sanitize_text_field( $request->get_param( 'reason' ) ?: '' );

        if ( ! $order_id ) return new WP_Error( 'invalid_input', 'order_id required', array( 'status' => 400 ) );

        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'pending_stock_review' ) {
            return new WP_Error( 'invalid_status', 'Order must be in pending_stock_review', array( 'status' => 400 ) );
        }

        // Revert daily counters
        $dist_id = (int) get_field( 'distributor_id', $order_id );
        $order_items_text = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items     = b2b_bo_parse_order_items( $order_items_text );
        $total_value      = (float) get_field( 'total_amount', $order_id );

        if ( $dist_id ) {
            b2b_bo_decrement_daily_counters( $dist_id, $parsed_items, $total_value );
        }

        // FSM: pending_stock_review → cancelled
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'cancelled', 'admin', "admin reject: {$reason}" );
            if ( is_wp_error( $transition ) ) return $transition;
        }

        update_post_meta( $order_id, '_b2b_reject_reason', $reason );
        b2b_log_attempt( $dist_id, 'cancel', $order_id, '', 'rejected', 'ADMIN_REJECT' );

        // Notify customer
        if ( function_exists( 'b2b_bo_notify_customer_rejected' ) ) {
            b2b_bo_notify_customer_rejected( $order_id, $reason );
        }

        return rest_ensure_response( array( 'success' => true, 'order_id' => $order_id, 'status' => 'cancelled' ) );
    }
}

/**
 * 4.4 — POST /b2b/v1/bo-undo-split
 */
if ( ! function_exists( 'b2b_rest_bo_undo_split' ) ) {
    function b2b_rest_bo_undo_split( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        if ( ! $order_id ) return new WP_Error( 'invalid_input', 'order_id required', array( 'status' => 400 ) );

        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'partial_fulfilled' ) {
            return new WP_Error( 'invalid_status', 'Order must be in partial_fulfilled', array( 'status' => 400 ) );
        }

        $deadline = (int) get_post_meta( $order_id, '_b2b_split_undo_deadline', true );
        if ( time() > $deadline ) {
            return new WP_Error( 'undo_window_expired', 'Undo window expired (10 min)', array( 'status' => 400 ) );
        }

        // Security H5 FIX: 1 undo per order max (prevent oscillation attack)
        $undo_count = (int) get_post_meta( $order_id, '_b2b_undo_count', true );
        if ( $undo_count >= 1 ) {
            return new WP_Error( 'undo_limit_reached', 'Undo แล้ว 1 ครั้ง — ต้องติดต่อ admin เพื่อ reset', array( 'status' => 400 ) );
        }

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        // Check no BO already fulfilled
        $fulfilled = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$bo_table} WHERE order_id = %d AND status = 'fulfilled'",
            $order_id
        ) );
        if ( $fulfilled > 0 ) {
            return new WP_Error( 'bo_already_fulfilled', 'Cannot undo — some BO items already fulfilled', array( 'status' => 400 ) );
        }

        $wpdb->query( 'START TRANSACTION' );

        // Restore stock (add back fulfilled qty)
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM {$bo_table} WHERE order_id = %d",
            $order_id
        ), ARRAY_A );

        // Reverse: any item that had qty_fulfill > 0 needs stock restoration
        // For simplicity: restore by re-subtracting debt + deleting bo_queue rows
        $order_items_text = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items     = b2b_bo_parse_order_items( $order_items_text );

        // Restore stock for fulfilled portions (recompute from parsed - bo qty)
        foreach ( $parsed_items as $pi ) {
            $bo_qty_for_sku = 0;
            foreach ( $rows as $r ) {
                if ( strtoupper( $r['sku'] ) === strtoupper( $pi['sku'] ) ) {
                    $bo_qty_for_sku += (int) $r['qty_bo'];
                }
            }
            $fulfilled_qty = $pi['qty'] - $bo_qty_for_sku;
            if ( $fulfilled_qty > 0 && function_exists( 'dinoco_stock_add' ) && function_exists( 'dinoco_get_leaf_skus' ) ) {
                $leaves = dinoco_get_leaf_skus( $pi['sku'] );
                foreach ( $leaves as $leaf ) {
                    dinoco_stock_add( $leaf, $fulfilled_qty, 'b2b_undo_split', 'b2b_order', $order_id );
                }
            }
        }

        // Delete bo_queue rows
        $wpdb->delete( $bo_table, array( 'order_id' => $order_id ) );

        // Reverse debt
        $dist_id = (int) get_field( 'distributor_id', $order_id );
        if ( $dist_id && function_exists( 'b2b_debt_subtract' ) ) {
            // Reverse previous b2b_debt_add — compute from meta (or just use recalculate)
            if ( function_exists( 'b2b_recalculate_debt' ) ) {
                b2b_recalculate_debt( $dist_id );
            }
        }

        // FSM: partial_fulfilled → pending_stock_review
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'pending_stock_review', 'admin', 'admin undo split' );
            if ( is_wp_error( $transition ) ) {
                $wpdb->query( 'ROLLBACK' );
                return $transition;
            }
        }

        // Clean meta + increment undo count (Security H5 FIX)
        delete_post_meta( $order_id, '_b2b_split_at' );
        delete_post_meta( $order_id, '_b2b_split_by' );
        delete_post_meta( $order_id, '_b2b_split_undo_deadline' );
        update_post_meta( $order_id, '_b2b_undo_count', $undo_count + 1 );

        // V.1.8 BUG-C2/C7 FIX: un-set _stock_deducted flag — bo-split's manual subtract has been
        // reversed above (dinoco_stock_add to restore fulfilled_qty). Keeping flag=1 would cause
        // re-split + fulfill path to skip hook on awaiting_confirm transition, but stock was
        // already restored — invariant says flag must match "stock currently subtracted" reality.
        delete_post_meta( $order_id, '_stock_deducted' );

        $wpdb->query( 'COMMIT' );

        b2b_log_attempt( $dist_id, 'undo_split', $order_id, '', 'accepted' );

        return rest_ensure_response( array( 'success' => true, 'order_id' => $order_id, 'status' => 'pending_stock_review' ) );
    }
}

/**
 * 4.5 — POST /b2b/v1/bo-fulfill
 * Ship BO items after restock
 */
if ( ! function_exists( 'b2b_rest_bo_fulfill' ) ) {
    function b2b_rest_bo_fulfill( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        $items    = $request->get_param( 'items' );

        if ( ! $order_id || ! is_array( $items ) || empty( $items ) ) {
            return new WP_Error( 'invalid_input', 'order_id + items required', array( 'status' => 400 ) );
        }

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $wpdb->query( 'START TRANSACTION' );

        $total_fulfilled_qty = 0;
        $total_fulfilled_value = 0;

        foreach ( $items as $item ) {
            $bo_queue_id = (int) ( $item['bo_queue_id'] ?? 0 );
            $qty         = max( 1, (int) ( $item['qty'] ?? 0 ) );
            $sku         = strtoupper( trim( $item['sku'] ?? '' ) );

            if ( ! $bo_queue_id ) continue;

            // Lock BO row
            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT * FROM {$bo_table} WHERE id = %d AND order_id = %d FOR UPDATE",
                $bo_queue_id, $order_id
            ) );
            if ( ! $row || $row->status !== 'pending' && $row->status !== 'ready' ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'invalid_bo_row', "BO row {$bo_queue_id} ไม่สามารถ fulfill ได้", array( 'status' => 400 ) );
            }
            if ( $qty > (int) $row->qty_bo ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'qty_exceeded', "qty({$qty}) > qty_bo({$row->qty_bo})", array( 'status' => 400 ) );
            }

            // Subtract stock
            if ( function_exists( 'dinoco_stock_subtract' ) && function_exists( 'dinoco_get_leaf_skus' ) ) {
                $leaves = dinoco_get_leaf_skus( $row->sku );
                foreach ( $leaves as $leaf ) {
                    $result = dinoco_stock_subtract( $leaf, $qty, 'b2b_bo_fulfilled', 'b2b_order', $order_id );
                    if ( is_wp_error( $result ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'stock_error', "Stock subtract failed: {$leaf}", array( 'status' => 500 ) );
                    }
                }
            }

            // Update bo_queue
            $remaining = (int) $row->qty_bo - $qty;
            if ( $remaining <= 0 ) {
                $wpdb->update( $bo_table, array(
                    'status'      => 'fulfilled',
                    'resolved_at' => current_time( 'mysql' ),
                ), array( 'id' => $bo_queue_id ) );
            } else {
                $wpdb->update( $bo_table, array(
                    'qty_bo' => $remaining,
                ), array( 'id' => $bo_queue_id ) );
            }

            // Add debt for BO qty
            // V.1.8 BUG-H3 FIX: dealer tier price (was retail base_price)
            // V.1.8 BUG-H4 FIX: fail-loud on missing product_data
            $dist_id = (int) get_field( 'distributor_id', $order_id );
            $pd      = function_exists( 'b2b_get_product_data' ) ? b2b_get_product_data( $row->sku ) : null;
            if ( ! $pd ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'b2b_log' ) ) {
                    b2b_log( "[BO] CRITICAL: product_data missing for SKU {$row->sku}, order {$order_id} (bo-fulfill)" );
                }
                if ( function_exists( 'b2b_send_telegram_alert' ) ) {
                    b2b_send_telegram_alert( 'bo_critical',
                        "BO FULFILL: missing product_data SKU={$row->sku} order=#{$order_id} — admin กรุณาตรวจสอบ (ROLLBACK แล้ว)" );
                }
                return new WP_Error( 'product_data_missing',
                    "ไม่พบข้อมูลสินค้า SKU: {$row->sku} — กรุณาติดต่อ admin",
                    array( 'status' => 500 )
                );
            }
            $base  = (float) ( $pd['base_price'] ?? 0 );
            $rank  = $dist_id ? ( get_field( 'rank_system', $dist_id ) ?: 'standard' ) : 'standard';
            $price = function_exists( 'b2b_compute_dealer_price' )
                ? (float) b2b_compute_dealer_price( $base, $rank, $pd )
                : $base;
            if ( $dist_id && $price > 0 && function_exists( 'b2b_debt_add' ) ) {
                b2b_debt_add( $dist_id, $price * $qty, 'b2b_bo_fulfilled', $order_id );
            }

            $total_fulfilled_qty   += $qty;
            $total_fulfilled_value += $price * $qty;
        }

        // Check if all BO items resolved → transition to awaiting_confirm
        $pending_count = (int) $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM {$bo_table} WHERE order_id = %d AND status IN ('pending', 'ready')",
            $order_id
        ) );

        // V.1.8 BUG-C2 FIX: set _stock_deducted=1 BEFORE FSM transition
        // Stock ถูก subtract manual ใน loop ข้างบน (lines 1202-1212). ถ้า all BO resolve →
        // FSM transition partial_fulfilled → awaiting_confirm ยิง hook
        // `dinoco_inv_on_status_change` (Snippet 2:3682) ซึ่งจะ parse order_items แล้ว
        // subtract stock ทั้งออเดอร์ซ้ำ. flag block hook ทัน.
        if ( $total_fulfilled_qty > 0 ) {
            update_post_meta( $order_id, '_stock_deducted', 1 );
        }

        if ( $pending_count === 0 ) {
            if ( function_exists( 'b2b_transition_order' ) ) {
                b2b_transition_order( $order_id, 'awaiting_confirm', 'admin', 'all BO resolved' );
            }
        }

        $wpdb->query( 'COMMIT' );

        // Log + notify
        $dist_id = (int) get_field( 'distributor_id', $order_id );
        b2b_log_attempt( $dist_id, 'bo_fulfill', $order_id, '', 'accepted', null, array(
            'total_qty' => $total_fulfilled_qty, 'total_value' => $total_fulfilled_value
        ) );

        if ( function_exists( 'b2b_bo_notify_customer_bo_ready' ) ) {
            b2b_bo_notify_customer_bo_ready( $order_id, $items );
        }

        // V.1.6 H5 + H6: Fire action hooks for Flash shipping + Print queue integration
        // Snippet 3/5 listen and create secondary Flash order + print label
        do_action( 'b2b_bo_items_fulfilled', $order_id, $items, array(
            'total_qty'   => $total_fulfilled_qty,
            'total_value' => $total_fulfilled_value,
            'all_resolved'=> $pending_count === 0,
        ) );

        return rest_ensure_response( array(
            'success'               => true,
            'order_id'              => $order_id,
            'total_fulfilled_qty'   => $total_fulfilled_qty,
            'total_fulfilled_value' => $total_fulfilled_value,
            'all_resolved'          => $pending_count === 0,
        ) );
    }
}

