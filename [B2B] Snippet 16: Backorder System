if ( ! function_exists( 'b2b_bo_permission_admin' ) ) {
    /**
     * Security H1 FIX: CSRF scheme
     *   - WP admin → X-WP-Nonce header + wp_verify_nonce('wp_rest') (standard WP REST)
     *   - Admin LINE LIFF → JWT session token via b2b_verify_session_token + is_admin flag
     * GET requests skip nonce (read-only) — POST/PUT/DELETE enforce
     */
    function b2b_bo_permission_admin( $request ) {
        $method = $request->get_method();

        // WP admin path
        if ( current_user_can( 'manage_options' ) ) {
            // Enforce nonce for write methods
            if ( in_array( $method, array( 'POST', 'PUT', 'DELETE' ), true ) ) {
                $nonce = $request->get_header( 'X-WP-Nonce' );
                if ( ! $nonce || ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
                    return new WP_Error( 'rest_csrf_failed', 'Nonce required for write ops', array( 'status' => 403 ) );
                }
            }
            return true;
        }

        // Admin LINE LIFF path (session JWT)
        if ( function_exists( 'b2b_verify_session_token' ) ) {
            $session = b2b_verify_session_token( $request );
            if ( $session && ! empty( $session['is_admin'] ) ) {
                // Session token itself = CSRF defense (attacker can't forge)
                return true;
            }
        }

        return new WP_Error( 'rest_forbidden', 'Admin only', array( 'status' => 403 ) );
    }
}

/**
 * 4.1 — POST /b2b/v1/bo-split
 * Admin splits order into fulfilled + BO items
 *
 * Request: { order_id, splits: [{sku, qty_fulfill, qty_bo, eta_days, notes}] }
 */
if ( ! function_exists( 'b2b_rest_bo_split' ) ) {
    function b2b_rest_bo_split( $request ) {
        $order_id = (int) $request->get_param( 'order_id' );
        $splits   = $request->get_param( 'splits' );

        if ( ! $order_id || ! is_array( $splits ) || empty( $splits ) ) {
            return new WP_Error( 'invalid_input', 'order_id + splits required', array( 'status' => 400 ) );
        }

        // Validate order status
        $status = get_field( 'order_status', $order_id );
        if ( $status !== 'pending_stock_review' ) {
            return new WP_Error( 'invalid_status', "Order ต้องอยู่ใน pending_stock_review (current={$status})", array( 'status' => 400 ) );
        }

        // Load existing order items (from meta or order_text)
        $order_items_text = get_field( 'order_items', $order_id ) ?: '';
        $parsed_items     = b2b_bo_parse_order_items( $order_items_text );

        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $wpdb->query( 'START TRANSACTION' );

        $fulfilled_total = 0;
        $bo_total        = 0;
        $bo_queue_ids    = array();
        $dist_id         = (int) get_field( 'distributor_id', $order_id );

        foreach ( $splits as $idx => $split ) {
            $sku          = strtoupper( trim( $split['sku'] ?? '' ) );
            $qty_fulfill  = max( 0, (int) ( $split['qty_fulfill'] ?? 0 ) );
            $qty_bo       = max( 0, (int) ( $split['qty_bo'] ?? 0 ) );
            $eta_days     = max( 0, (int) ( $split['eta_days'] ?? b2b_bo_get_config( 'b2b_bo_eta_default_days' ) ) );
            $notes        = sanitize_text_field( $split['notes'] ?? '' );

            // Validate invariant: qty_fulfill + qty_bo === original_qty
            $original_qty = 0;
            foreach ( $parsed_items as $pi ) {
                if ( $pi['sku'] === $sku ) {
                    $original_qty = $pi['qty'];
                    break;
                }
            }
            if ( $qty_fulfill + $qty_bo !== $original_qty ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'invariant_violation',
                    "SKU {$sku}: qty_fulfill({$qty_fulfill}) + qty_bo({$qty_bo}) ต้อง = original({$original_qty})",
                    array( 'status' => 400 )
                );
            }

            // Subtract stock for fulfilled qty (leaf-aware)
            if ( $qty_fulfill > 0 && function_exists( 'dinoco_stock_subtract' ) && function_exists( 'dinoco_get_leaf_skus' ) ) {
                $leaves = dinoco_get_leaf_skus( $sku );
                foreach ( $leaves as $leaf ) {
                    $result = dinoco_stock_subtract( $leaf, $qty_fulfill, 'b2b_reserved', 'b2b_order', $order_id );
                    if ( is_wp_error( $result ) ) {
                        $wpdb->query( 'ROLLBACK' );
                        return new WP_Error( 'stock_error',
                            "Stock subtract failed for {$leaf}: " . $result->get_error_message(),
                            array( 'status' => 500 )
                        );
                    }
                }
            }

            // Insert bo_queue row (if qty_bo > 0)
            if ( $qty_bo > 0 ) {
                $eta_date = $eta_days > 0 ? date( 'Y-m-d', strtotime( "+{$eta_days} days" ) ) : null;
                $inserted = $wpdb->insert( $bo_table, array(
                    'order_id'   => $order_id,
                    'item_index' => $idx,
                    'sku'        => $sku,
                    'qty_bo'     => $qty_bo,
                    'eta'        => $eta_date,
                    'status'     => 'pending',
                    'notes'      => $notes,
                    'created_at' => current_time( 'mysql' ),
                ) );
                if ( ! $inserted ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'db_error', 'bo_queue insert failed', array( 'status' => 500 ) );
                }
                $bo_queue_ids[] = $wpdb->insert_id;
            }

            $fulfilled_total += $qty_fulfill;
            $bo_total        += $qty_bo;
        }

        // Update debt (confirmed qty only)
        $total_value = (float) get_field( 'total_amount', $order_id );
        $confirmed_ratio = $fulfilled_total > 0 && ( $fulfilled_total + $bo_total ) > 0
            ? $fulfilled_total / ( $fulfilled_total + $bo_total )
            : 0;
        $confirmed_value = $total_value * $confirmed_ratio;

        if ( $dist_id && $confirmed_value > 0 && function_exists( 'b2b_debt_add' ) ) {
            b2b_debt_add( $dist_id, $confirmed_value, 'b2b_bo_split_confirm', $order_id );
        }

        // FSM transition: pending_stock_review → partial_fulfilled
        if ( function_exists( 'b2b_transition_order' ) ) {
            $transition = b2b_transition_order( $order_id, 'partial_fulfilled', 'admin', 'admin split BO' );
            if ( is_wp_error( $transition ) ) {
                $wpdb->query( 'ROLLBACK' );
                return $transition;
            }
        }

        // Meta: undo window + audit
        $now_ts       = time();
        $undo_minutes = (int) b2b_bo_get_config( 'b2b_bo_split_undo_window_minutes' );
        update_post_meta( $order_id, '_b2b_split_at', $now_ts );
        update_post_meta( $order_id, '_b2b_split_by', get_current_user_id() );
        update_post_meta( $order_id, '_b2b_split_undo_deadline', $now_ts + ( $undo_minutes * 60 ) );

        $wpdb->query( 'COMMIT' );

        // Log attempt
        b2b_log_attempt( $dist_id, 'split', $order_id, '', 'accepted', null, array( 'total_qty' => $fulfilled_total + $bo_total ) );

        // Send customer notification Flex
        if ( function_exists( 'b2b_bo_notify_customer_split' ) ) {
            b2b_bo_notify_customer_split( $order_id );
        }

        return rest_ensure_response( array(
            'success'         => true,
            'order_id'        => $order_id,
            'status'          => 'partial_fulfilled',
            'fulfilled_total' => $fulfilled_total,
            'bo_total'        => $bo_total,
            'bo_queue_ids'    => $bo_queue_ids,
            'undo_deadline'   => date( 'Y-m-d H:i:s', $now_ts + ( $undo_minutes * 60 ) ),
        ) );
    }
}

/**
 * 4.2 — POST /b2b/v1/bo-confirm-full
