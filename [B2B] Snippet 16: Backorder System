// SECTION 10: REST RESPONSE FILTER — hide admin-only meta
// ═══════════════════════════════════════════════════════════════

add_filter( 'rest_prepare_post', function( $response, $post, $request ) {
    if ( $post->post_type !== 'b2b_order' ) return $response;

    // Only filter for non-admin requests
    if ( current_user_can( 'manage_options' ) ) return $response;

    $data = $response->get_data();
    if ( isset( $data['meta'] ) ) {
        unset( $data['meta']['_b2b_stock_snapshot'] );
        unset( $data['meta']['_b2b_enumeration_flags'] );
        $response->set_data( $data );
    }

    return $response;
}, 10, 3 );

