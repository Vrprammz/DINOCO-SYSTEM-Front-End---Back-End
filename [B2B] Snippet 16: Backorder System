if ( ! function_exists( 'b2b_bo_restock_scan' ) ) {
    /**
     * Core restock scan — promote pending rows to ready if stock available
     *
     * @param string|null $specific_sku  null = scan all
     * @return array  list of bo_queue IDs ที่ mark ready
     */
    function b2b_bo_restock_scan( $specific_sku = null ) {
        global $wpdb;
        $bo_table = $wpdb->prefix . 'dinoco_bo_queue';

        $where = array( "status = 'pending'" );
        $params = array();
        if ( $specific_sku ) {
            $where[] = 'sku = %s';
            $params[] = strtoupper( trim( $specific_sku ) );
        }

        $sql = "SELECT * FROM {$bo_table}
                WHERE " . implode( ' AND ', $where ) . "
                ORDER BY created_at ASC
                LIMIT 500";
        $rows = $params
            ? $wpdb->get_results( $wpdb->prepare( $sql, ...$params ), ARRAY_A )
            : $wpdb->get_results( $sql, ARRAY_A );

        $marked = array();
        foreach ( $rows as $r ) {
            $available = 0;
            if ( function_exists( 'dinoco_compute_hierarchy_stock' ) && function_exists( 'dinoco_get_reserved_qty' ) ) {
                $computed  = (int) dinoco_compute_hierarchy_stock( $r['sku'] );
                $reserved  = (int) dinoco_get_reserved_qty( $r['sku'] );
                $available = max( 0, $computed - $reserved );
            }

            if ( $available >= (int) $r['qty_bo'] ) {
                $wpdb->update( $bo_table, array( 'status' => 'ready' ), array( 'id' => $r['id'] ) );
                $marked[] = (int) $r['id'];
            }
        }

        if ( ! empty( $marked ) && function_exists( 'b2b_log' ) ) {
            b2b_log( '[BO] Restock scan: ' . count( $marked ) . ' rows marked ready — ' . implode( ',', $marked ) );
        }

        // Telegram alert if any marked ready
        if ( ! empty( $marked ) && function_exists( 'b2b_send_telegram_alert' ) ) {
            b2b_send_telegram_alert( 'bo_restock_ready', 'มี BO พร้อม fulfill: ' . count( $marked ) . ' รายการ' );
        }

        return $marked;
    }
}

if ( ! function_exists( 'b2b_bo_parse_order_items' ) ) {
    /**
     * Parse order_items text "(SKU_X)xQTY (SKU_Y)xQTY" → [['sku'=>X, 'qty'=>N], ...]
     */
    function b2b_bo_parse_order_items( $order_items_text ) {
        $items = array();
        if ( preg_match_all( '/\(([A-Z0-9\-]+)\)\s*x(\d+)/i', $order_items_text, $matches, PREG_SET_ORDER ) ) {
            foreach ( $matches as $m ) {
                $items[] = array(
                    'sku' => strtoupper( trim( $m[1] ) ),
                    'qty' => (int) $m[2],
                );
            }
        }
        return $items;
    }
}

