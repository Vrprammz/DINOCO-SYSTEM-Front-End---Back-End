/**
 * Hook ให้ Snippet 2 route postback actions เข้า BO handlers
 * Pattern: action=bo_confirm_full | bo_reject
 */
add_filter( 'b2b_webhook_postback_action', function( $handled, $action, $params, $user_id, $reply_token ) {
    if ( $handled ) return $handled;

    if ( $action === 'bo_confirm_full' ) {
        $order_id = (int) ( $params['order_id'] ?? 0 );
        if ( $order_id ) {
            // Simulate REST call internally
            $req = new WP_REST_Request();
            $req->set_param( 'order_id', $order_id );
            $result = b2b_rest_bo_confirm_full( $req );
            if ( function_exists( 'b2b_line_reply' ) && ! is_wp_error( $result ) ) {
                b2b_line_reply( $reply_token, "✅ ยืนยันเต็มแล้ว — ลูกค้าได้รับบิลยืนยัน" );
            }
        }
        return true;
    }

    if ( $action === 'bo_reject' ) {
        $order_id = (int) ( $params['order_id'] ?? 0 );
        if ( $order_id ) {
            $req = new WP_REST_Request();
            $req->set_param( 'order_id', $order_id );
            $req->set_param( 'reason', 'admin manual reject' );
            $result = b2b_rest_bo_reject( $req );
            if ( function_exists( 'b2b_line_reply' ) && ! is_wp_error( $result ) ) {
                b2b_line_reply( $reply_token, "❌ ปฏิเสธแล้ว — ลูกค้าได้รับแจ้งเตือน" );
            }
        }
        return true;
    }

    return false;
}, 10, 5 );

// ═══════════════════════════════════════════════════════════════
// SECTION 9: PLACE-ORDER HARD CAPS (hook into Snippet 3 b2b_rest_place_order)
// ═══════════════════════════════════════════════════════════════

/**
 * Hook ก่อน place-order process — validate caps + rate limits
 * ใช้ filter hook 'b2b_place_order_pre_validate' (ถ้า Snippet 3 รองรับ)
 * หรือ direct wrap ผ่าน add_action('rest_pre_dispatch', ...)
 */
add_filter( 'rest_pre_dispatch', function( $result, $server, $request ) {
    $route = $request->get_route();
    if ( $route !== '/b2b/v1/place-order' ) return $result;

    $method = $request->get_method();
    if ( $method !== 'POST' ) return $result;

    // Only gate when feature flag ON
    // Need session to identify distributor — check if session valid first
    if ( ! function_exists( 'b2b_verify_session_token' ) ) return $result;
    $session = b2b_verify_session_token( $request );
    if ( ! $session ) return $result; // let existing handler reject

    $group_id = $session['gid'] ?? '';
    $dist_id  = 0;
    if ( function_exists( 'b2b_get_dist_by_group' ) ) {
        $dist = b2b_get_dist_by_group( $group_id );
        if ( $dist ) $dist_id = (int) $dist->ID;
    }

    // Feature flag gate
    if ( ! b2b_bo_flag_enabled( $dist_id ) ) return $result;

    // Walk-in skip all caps (existing flow)
    if ( $dist_id && get_field( 'is_walkin', $dist_id ) ) return $result;

    $items = $request->get_param( 'items' );
    if ( ! is_array( $items ) ) return $result;

    // Hard cap 1: items count
    $max_items = (int) b2b_bo_get_config( 'b2b_bo_max_items_per_order' );
    if ( count( $items ) > $max_items ) {
        b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rejected', 'ITEMS_OVER_LIMIT', array( 'group_id' => $group_id ) );
        return new WP_Error( 'ITEMS_OVER_LIMIT', 'จำนวนรายการเกินที่สั่งได้', array( 'status' => 400 ) );
    }

    // Hard cap 2: qty per item + Security H2 suspicious qty flagger
    // แจ้งเตือน Telegram ถ้าเจอ qty ที่เป็น typical binary search values (100, 500, 1000, 2000)
    $max_qty = (int) b2b_bo_get_config( 'b2b_bo_max_qty_per_item' );
    $suspicious_values = array( 100, 500, 1000, 2000 );
    $has_suspicious = false;

    foreach ( $items as $it ) {
        $qty = (int) ( $it['qty'] ?? 0 );
        if ( $qty > $max_qty ) {
            b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rejected', 'QTY_OVER_LIMIT', array( 'group_id' => $group_id ) );
            return new WP_Error( 'QTY_OVER_LIMIT', 'จำนวนเกินที่สั่งได้ต่อครั้ง', array( 'status' => 400 ) );
        }
        if ( $qty < 1 ) {
            return new WP_Error( 'QTY_INVALID', 'จำนวนต้อง >= 1', array( 'status' => 400 ) );
        }
        if ( in_array( $qty, $suspicious_values, true ) ) {
            $has_suspicious = true;
        }
    }

    if ( $has_suspicious && function_exists( 'b2b_send_telegram_alert' ) ) {
        b2b_send_telegram_alert( 'suspicious_qty',
            "Distributor #{$dist_id}: order มี qty ใกล้ binary search (100/500/1000/2000) — monitor enumeration?" );
    }

    // Rate limit 1: 10/hour  (V.1.7 BUG-C1 FIX: b2b_rate_limit() returns true on allow, WP_Error on block → check is_wp_error)
    if ( function_exists( 'b2b_rate_limit' ) ) {
        $rate_hr = (int) b2b_bo_get_config( 'b2b_bo_rate_place_per_hour' );
        $rl_hr   = b2b_rate_limit( 'bo_place_hr_' . $dist_id, $rate_hr, 3600 );
        if ( is_wp_error( $rl_hr ) ) {
            b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rate_limit', 'RATE_LIMIT', array( 'group_id' => $group_id ) );
            return new WP_Error( 'RATE_LIMIT', $rl_hr->get_error_message() ?: 'สั่งซื้อบ่อยเกินไป กรุณารอสักครู่', array( 'status' => 429, 'retry_after' => 3600 ) );
        }

        $rate_day = (int) b2b_bo_get_config( 'b2b_bo_rate_place_per_day' );
        $rl_day   = b2b_rate_limit( 'bo_place_day_' . $dist_id, $rate_day, 86400 );
        if ( is_wp_error( $rl_day ) ) {
            b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rate_limit', 'RATE_LIMIT_DAY', array( 'group_id' => $group_id ) );
            return new WP_Error( 'RATE_LIMIT', $rl_day->get_error_message() ?: 'เกินจำนวนครั้งต่อวัน กรุณาติดต่อทีมงาน', array( 'status' => 429 ) );
        }
    }

    // Rate limit 2: daily qty per SKU
    $daily_qty_limit = (int) b2b_bo_get_config( 'b2b_bo_daily_qty_per_sku' );
    foreach ( $items as $it ) {
        $sku = strtoupper( $it['sku'] );
        $qty = (int) $it['qty'];
        $key = 'b2b_daily_qty_' . $dist_id . '_' . $sku;
        $used = (int) ( get_transient( $key ) ?: 0 );
        if ( $used + $qty > $daily_qty_limit ) {
            b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rejected', 'DAILY_QTY_LIMIT', array( 'group_id' => $group_id ) );
            return new WP_Error( 'DAILY_QTY_LIMIT', 'เกินโควต้ารายวัน กรุณาติดต่อทีมงาน', array( 'status' => 429 ) );
        }
    }

    // Security H2 FIX: unique-SKU/day cap (prevent cross-SKU enumeration)
    $unique_sku_cap = (int) b2b_bo_get_config( 'b2b_bo_daily_unique_sku_cap' );
    $order_skus = array_unique( array_map( function( $it ) { return strtoupper( $it['sku'] ); }, $items ) );
    $unique_key = 'b2b_daily_unique_skus_' . $dist_id;
    $existing_skus = get_transient( $unique_key );
    if ( ! is_array( $existing_skus ) ) $existing_skus = array();
    $combined_skus = array_unique( array_merge( $existing_skus, $order_skus ) );
    if ( count( $combined_skus ) > $unique_sku_cap ) {
        b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rejected', 'UNIQUE_SKU_CAP', array( 'group_id' => $group_id ) );
        return new WP_Error( 'UNIQUE_SKU_CAP', 'สั่งหลาย SKU เกินโควต้ารายวัน กรุณาติดต่อทีมงาน', array( 'status' => 429 ) );
    }
    set_transient( $unique_key, $combined_skus, 86400 );

    // Tier value cap (checked after existing handler computes total)
    // — we store dist_id + items in request meta for post-handler check
    // Simpler: compute rough estimate here using b2b_get_product_data
    $total_value = 0;
    if ( function_exists( 'b2b_get_product_data' ) ) {
        foreach ( $items as $it ) {
            $pd = b2b_get_product_data( strtoupper( $it['sku'] ) );
            if ( $pd ) {
                $price = (float) ( $pd['base_price'] ?? 0 );
                $total_value += $price * (int) $it['qty'];
            }
        }
    }

    $tier_caps = b2b_bo_get_config( 'b2b_bo_tier_value_caps' );
    $rank      = get_field( 'rank_system', $dist_id ) ?: 'standard';
    $cap       = $tier_caps[ $rank ] ?? 50000;
    if ( $cap > 0 ) {
        $daily_value_key = 'b2b_daily_value_' . $dist_id;
        $daily_used      = (float) ( get_transient( $daily_value_key ) ?: 0 );
        if ( $daily_used + $total_value > $cap ) {
            b2b_log_attempt( $dist_id, 'place_order', 0, '', 'rejected', 'DAILY_VALUE_LIMIT', array( 'group_id' => $group_id ) );
            return new WP_Error( 'DAILY_VALUE_LIMIT', 'เกินวงเงินรายวัน', array( 'status' => 429 ) );
        }
    }

    // Security H3 FIX: artificial timing jitter ป้องกัน timing side-channel attack
    // Real σ ใน WP >> 10ms — add random delay 50-150ms เพื่อ mask natural variance
    usleep( random_int( 50000, 150000 ) );

    return $result; // pass through to original handler
}, 5, 3 ); // Priority 5 — before default handlers

/**
 * V.1.8 BUG-C6 FIX: Removed C1 place-order post-process listener
 * ─────────────────────────────────────────────────────────────────
 * เดิม: hook `b2b_place_order_post_process` transition draft → pending_stock_review
 *        ทันทีที่ place-order (ก่อน customer confirm Flex)
 * ปัญหา: ลูกค้าเห็น draft Flex แล้วกด "ยืนยัน" → Snippet 2 b2b_action_confirm_order
