// SECTION 14: C3 META FILTER HARDENING (V.1.5)
// ═══════════════════════════════════════════════════════════════

/**
 * Ensure admin-only meta NEVER leaks through default WP REST.
 * 2 layers:
 *   (a) register_meta auth_callback = reject non-admin
 *   (b) rest_prepare_b2b_order filter — strip meta from response
 */
add_action( 'init', function() {
    $admin_only_meta = array(
        '_b2b_stock_snapshot',
        '_b2b_enumeration_flags',
        '_b2b_opaque_accept_at',
        '_b2b_split_at',
        '_b2b_split_by',
        '_b2b_split_undo_deadline',
        '_b2b_undo_count',
        '_b2b_reject_reason',
    );

    foreach ( $admin_only_meta as $meta_key ) {
        register_post_meta( 'b2b_order', $meta_key, array(
            'show_in_rest'   => false,  // BLANKET: hide from default REST
            'single'         => true,
            'type'           => 'string',
            'auth_callback'  => function() { return current_user_can( 'manage_options' ); },
        ) );
    }
}, 20 ); // Priority 20 — after CPT registered

/**
 * Defense-in-depth: strip meta from REST response too
 * (in case show_in_rest override happens somewhere else)
 */
add_filter( 'rest_prepare_b2b_order', function( $response, $post, $request ) {
    if ( current_user_can( 'manage_options' ) ) return $response;

    $data = $response->get_data();
    if ( isset( $data['meta'] ) && is_array( $data['meta'] ) ) {
        $admin_only = array(
            '_b2b_stock_snapshot', '_b2b_enumeration_flags', '_b2b_opaque_accept_at',
            '_b2b_split_at', '_b2b_split_by', '_b2b_split_undo_deadline',
            '_b2b_undo_count', '_b2b_reject_reason',
        );
        foreach ( $admin_only as $key ) {
            unset( $data['meta'][ $key ] );
        }
        $response->set_data( $data );
    }
    return $response;
}, 10, 3 );

