// V.2.3: QC Reject Resolve modal
var actionLabels = { replacement: 'สร้างใบสั่งซื้อใหม่', reship: 'ให้โรงงานส่งใหม่', write_off: 'ตัดยอด (ไม่ต้องส่งใหม่)' };
