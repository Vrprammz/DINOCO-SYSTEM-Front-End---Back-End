<script>
(function(){
var PO_ID = <?php echo intval($po_id); ?>;
var REST = <?php echo wp_json_encode($rest_url); ?>;
var WP_NONCE = <?php echo wp_json_encode($wp_nonce); ?>;
var B2F_TOKEN = <?php echo wp_json_encode($b2f_api_token); ?>;

function toast(msg, cls) {
    var t = document.getElementById('rcvToast');
    t.textContent = msg; t.className = 'b2f-toast ' + (cls||'');
    requestAnimationFrame(function(){t.classList.add('show');});
    setTimeout(function(){t.classList.remove('show');}, 3000);
}

window.b2fRcvStep = function(btn, delta) {
    var row = btn.parentElement;
    var inp = row.querySelector('input[type=number]');
    if (!inp) return;
    var val = parseInt(inp.value) || 0;
    var mn = parseInt(inp.min) || 0;
    var mx = parseInt(inp.max) || 9999;
    inp.value = Math.max(mn, Math.min(mx, val + delta));
};

window.b2fRcvAutoFill = function() {
    document.querySelectorAll('.rcv-qty').forEach(function(inp) {
        inp.value = inp.max;
    });
    toast('เติมจำนวนครบทุกรายการแล้ว');
};

window.b2fRcvQcChange = function(sel) {
    var sku = sel.dataset.sku;
    var reject = document.querySelector('.b2f-rcv-reject[data-sku="'+sku+'"]');
    if (reject) reject.style.display = sel.value === 'failed' ? 'block' : 'none';
};

window.b2fRcvSubmit = function() {
    var btn = document.getElementById('rcvSubmitBtn');
    if (btn.disabled) return;

    var itemEls = document.querySelectorAll('.b2f-rcv-item[data-max]');
    var items = [];
    var hasQty = false;
    var invalid = false;

    itemEls.forEach(function(el) {
        var max = parseInt(el.dataset.max) || 0;
        if (max <= 0) return;
        var sku = el.dataset.sku;
        var qty = parseInt(el.querySelector('.rcv-qty').value) || 0;
        if (qty > max) { toast('จำนวนรับ ' + sku + ' เกินที่เหลือ', 'error'); invalid = true; return; }
        if (qty <= 0) return;
        hasQty = true;
        var qc = el.querySelector('.rcv-qc').value;
        var item = { sku: sku, qty_received: qty, qc_status: qc };
        if (qc === 'failed') {
            var rq = parseInt(el.querySelector('.rcv-reject-qty').value) || 0;
            if (rq > qty) { toast('Reject เกินจำนวนรับ ' + sku, 'error'); invalid = true; return; }
            item.reject_qty = rq;
            item.reject_reason = el.querySelector('.rcv-reject-reason').value.trim();
        }
        items.push(item);
    });

    if (invalid) return;
    if (!hasQty) { toast('กรุณาระบุจำนวนอย่างน้อย 1 รายการ', 'error'); return; }

    var inspector = document.getElementById('rcvInspector').value.trim();
    var note = document.getElementById('rcvNote').value.trim();

    // Show confirmation
    var totalRcv = 0, totalRej = 0, totalVal = 0;
    var summaryHtml = '';
    items.forEach(function(it) {
        var accepted = it.qty_received - (it.reject_qty || 0);
        totalRcv += it.qty_received;
        totalRej += (it.reject_qty || 0);
        summaryHtml += '<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:13px;">' +
            '<span>' + it.sku + '</span>' +
            '<span>x' + it.qty_received + (it.reject_qty ? ' (reject ' + it.reject_qty + ')' : '') + '</span></div>';
    });

    var allComplete = true;
    itemEls.forEach(function(el) {
        var max = parseInt(el.dataset.max) || 0;
        if (max <= 0) return;
        var qty = parseInt(el.querySelector('.rcv-qty').value) || 0;
        if (qty < max) allComplete = false;
    });
    var statusText = allComplete ? '✅ รับครบ' : '⏳ รับบางส่วน';

    var modal = document.getElementById('rcvModal');
    document.getElementById('rcvModalContent').innerHTML =
        '<h3 style="font-size:16px;margin-bottom:12px;">📦 ยืนยันตรวจรับ</h3>' +
        '<div style="font-size:13px;color:#64748b;margin-bottom:8px;">' + statusText + '</div>' +
        summaryHtml +
        '<div style="border-top:1px solid #e2e8f0;padding-top:8px;margin-top:8px;font-size:13px;">' +
            '<div>รับรวม: <strong>' + totalRcv + '</strong> ชิ้น</div>' +
            (totalRej > 0 ? '<div style="color:#dc2626;">Reject: <strong>' + totalRej + '</strong> ชิ้น</div>' : '') +
        '</div>' +
        (inspector ? '<div style="font-size:11px;color:#64748b;margin-top:6px;">ผู้ตรวจ: ' + inspector + '</div>' : '') +
        '<div style="display:flex;gap:8px;margin-top:16px;">' +
            '<button onclick="document.getElementById(\'rcvModal\').classList.remove(\'show\')" style="flex:1;padding:12px;border:1px solid #d1d5db;border-radius:8px;background:#fff;font-size:13px;cursor:pointer;font-family:inherit;">ยกเลิก</button>' +
            '<button onclick="b2fRcvDoSubmit()" style="flex:2;padding:12px;border:none;border-radius:8px;background:#059669;color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;">ยืนยัน</button>' +
        '</div>';
    modal.classList.add('show');

    window._rcvItems = items;
    window._rcvInspector = inspector;
    window._rcvNote = note;
};

window.b2fRcvDoSubmit = function() {
    var btn = document.getElementById('rcvSubmitBtn');
    btn.disabled = true;
    document.getElementById('rcvModal').classList.remove('show');
    toast('กำลังบันทึก...');

    var fd = new FormData();
    fd.append('po_id', PO_ID);
    fd.append('items', JSON.stringify(window._rcvItems));
    fd.append('inspected_by', window._rcvInspector || '');
    fd.append('note', window._rcvNote || '');

    // Attach photos
    document.querySelectorAll('.b2f-rcv-item[data-max]').forEach(function(el) {
        var max = parseInt(el.dataset.max) || 0;
        if (max <= 0) return;
        var sku = el.dataset.sku;
        var qc = el.querySelector('.rcv-qc');
        if (qc && qc.value === 'failed') {
            var files = el.querySelector('.rcv-photos');
            if (files && files.files) {
                for (var i = 0; i < Math.min(files.files.length, 5); i++) {
                    fd.append('photos_' + sku + '[]', files.files[i]);
                }
            }
        }
    });

    fetch(REST + 'receive-goods', {
        method: 'POST',
        headers: WP_NONCE ? { 'X-WP-Nonce': WP_NONCE } : { 'X-B2F-Token': B2F_TOKEN },
        body: fd
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
        if (res.success) {
            document.querySelector('.b2f-rcv-form').innerHTML =
                '<div class="b2f-rcv-success">' +
                    '<div class="icon">✅</div>' +
                    '<h2>ตรวจรับสำเร็จ</h2>' +
                    '<div class="rcv-num">' + (res.rcv_number || '') + '</div>' +
                    '<div style="font-size:13px;color:#64748b;">สถานะ: ' + (res.po_status === 'received' ? 'รับครบแล้ว' : 'รับบางส่วน') + '</div>' +
                    (res.debt_added ? '<div style="font-size:12px;color:#d97706;margin-top:8px;">ยอดค้างจ่าย ฿' + Number(res.debt_added).toLocaleString() + ' (THB)</div>' : '') +
                    (res.has_reject ? '<div style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px;margin-top:10px;color:#dc2626;font-size:12px;font-weight:600;text-align:center;">⚠️ มีรายการ QC ไม่ผ่าน กรุณาดำเนินการ</div>' : '') +
                    (res._debug_push ? '<div style="font-size:10px;color:#94a3b8;margin-top:12px;text-align:left;background:#f8fafc;padding:8px;border-radius:6px;">' +
                        'Push: Maker=' + res._debug_push.maker_push + ' (' + res._debug_push.maker_group + ')' +
                        '<br>Admin=' + res._debug_push.admin_push + ' (' + res._debug_push.admin_group + ')' +
                        '<br>maker_id=' + res._debug_push.maker_id +
                    '</div>' : '') +
                    '<div style="margin-top:16px;display:flex;gap:8px;justify-content:center;">' +
                        '<button onclick="location.reload()" style="padding:10px 20px;border:1px solid #d1d5db;border-radius:8px;background:#fff;font-size:13px;cursor:pointer;font-family:inherit;">ดูรายละเอียด</button>' +
                        '<button onclick="try{liff.closeWindow()}catch(e){window.close()}" style="padding:10px 20px;border:none;border-radius:8px;background:#1a3a5c;color:#fff;font-size:13px;cursor:pointer;font-family:inherit;">ปิดหน้านี้</button>' +
                    '</div>' +
                '</div>';
        } else {
            toast(res.error || 'เกิดข้อผิดพลาด', 'error');
            btn.disabled = false;
        }
    })
    .catch(function(err) {
        toast('เชื่อมต่อไม่ได้ ลองใหม่', 'error');
        btn.disabled = false;
    });
};

// Photo preview
document.querySelectorAll('.rcv-photos').forEach(function(inp) {
