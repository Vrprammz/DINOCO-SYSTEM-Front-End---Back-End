/**
 * ╔══════════════════════════════════════════════════════════════╗
 * ║  [B2F] Snippet 9: PO Ticket View                            ║
 * ║  Version: V.3.3 — Multi-currency display + Admin cost breakdown    ║
 * ║  DB_ID: 1169                                                 ║
 * ║  Route: /b2f-po-ticket/?po_id=XXX                           ║
 * ║  Kill Switch: define('B2F_DISABLED', true)                   ║
 * ╚══════════════════════════════════════════════════════════════╝
 *
 * หน้าดูรายละเอียด PO — คล้าย B2B Ticket View
 * แสดง: Status Banner, PO Info, Items, Timeline, Receiving, Payment
 */

if ( ! defined( 'ABSPATH' ) ) exit;
if ( defined( 'B2F_DISABLED' ) && B2F_DISABLED ) return;

add_action( 'template_redirect', function () {
    if ( ! is_page( 'b2f-po-ticket' ) ) return;

    // Security: WP Admin session OR HMAC signed URL (จาก Flex button)
    $is_authorized = current_user_can( 'manage_options' );
    if ( ! $is_authorized ) {
        // Fallback: ตรวจ HMAC sig จาก b2f_liff_url()
        // b2f_liff_url สร้าง sig: path + '|' + params ตามลำดับที่ใส่ (ไม่ sort)
        // path อาจมี '/' นำหน้า → ลอง match ทั้ง 2 แบบ
        $sig = sanitize_text_field( $_GET['_sig'] ?? '' );
        $ts  = intval( $_GET['_ts'] ?? 0 );
        if ( ! empty( $sig ) && $ts > 0 && abs( time() - $ts ) <= 14400 ) {
            $secret = defined( 'B2B_LINE_CHANNEL_SECRET' ) ? B2B_LINE_CHANNEL_SECRET : wp_salt( 'auth' );
            $params = $_GET;
            unset( $params['_sig'] );

            // ลอง match หลาย format ที่ b2f_liff_url อาจสร้าง
            $paths_to_try = array( '/b2f-po-ticket/', 'b2f-po-ticket/' );
            foreach ( $paths_to_try as $path ) {
                // แบบ 1: ตามลำดับ params (เหมือน b2f_liff_url)
                $sig_data = $path . '|' . implode( '|', array_map( function( $k, $v ) { return $k . '=' . $v; }, array_keys( $params ), $params ) );
                $expected = substr( hash_hmac( 'sha256', $sig_data, $secret ), 0, 16 );
                if ( hash_equals( $expected, $sig ) ) { $is_authorized = true; break; }

                // แบบ 2: sorted params
                $sorted = $params; ksort( $sorted );
                $sig_data2 = $path . '|' . implode( '|', array_map( function( $k, $v ) { return $k . '=' . $v; }, array_keys( $sorted ), $sorted ) );
                $expected2 = substr( hash_hmac( 'sha256', $sig_data2, $secret ), 0, 16 );
                if ( hash_equals( $expected2, $sig ) ) { $is_authorized = true; break; }
            }
        }
    }
    if ( ! $is_authorized ) {
        header( 'Content-Type: text/html; charset=UTF-8' );
        echo '<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body style="font-family:sans-serif;text-align:center;padding:60px;"><h2>🔒 Access Denied</h2><p>ต้องเป็น Admin เท่านั้น</p></body></html>';
        exit;
    }
    // V.2.2: Auth สำหรับ API calls — รองรับทั้ง WP session (backend) + JWT (LIFF)
    $has_wp_session = current_user_can( 'manage_options' );
    $wp_nonce = $has_wp_session ? wp_create_nonce( 'wp_rest' ) : '';
    $b2f_api_token = '';
    if ( ! $has_wp_session && class_exists( 'DINOCO_JWT' ) ) {
        $b2f_api_token = DINOCO_JWT::create( array(
            'is_admin' => true,
            'role'     => 'b2f_admin',
            'uid'      => 'hmac_admin',
            'source'   => 'po_ticket',
        ), 3600 );
    }

    // V.2.8: No-cache — ป้องกัน LIFF webview/browser cache ข้อมูลเก่า
    header( 'Cache-Control: no-store, no-cache, must-revalidate, max-age=0' );
    header( 'Pragma: no-cache' );
    header( 'Expires: 0' );

    $po_id = intval( $_GET['po_id'] ?? 0 );
    if ( ! $po_id || get_post_type( $po_id ) !== 'b2f_order' ) {
        header( 'Content-Type: text/html; charset=UTF-8' );
        echo '<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body style="font-family:sans-serif;text-align:center;padding:60px;"><h2>ไม่พบ PO</h2><p>PO ID ไม่ถูกต้องหรือถูกลบแล้ว</p></body></html>';
        exit;
    }

    // Load PO data — clear ALL caches ก่อนอ่าน
    wp_cache_delete( $po_id, 'post_meta' );
    clean_post_cache( $po_id );

    $po_number   = get_field( 'po_number', $po_id ) ?: 'PO-' . $po_id;
    $status      = get_field( 'po_status', $po_id ) ?: 'draft';
    $maker_id    = get_field( 'po_maker_id', $po_id );
    $maker_name  = is_numeric( $maker_id ) ? ( get_field( 'maker_name', $maker_id ) ?: get_the_title( $maker_id ) ) : '';
    $items       = get_field( 'po_items', $po_id ) ?: array();
    $total       = floatval( get_field( 'po_total_amount', $po_id ) ?: 0 );
    $requested   = get_field( 'po_requested_date', $po_id );
    $expected    = get_field( 'po_expected_date', $po_id );
    $actual      = get_field( 'po_actual_date', $po_id );
    $admin_note  = get_field( 'po_admin_note', $po_id );
    $maker_note  = get_field( 'po_maker_note', $po_id );
    $created_by  = get_field( 'po_created_by', $po_id );
    $cancel_reason = get_field( 'po_cancelled_reason', $po_id );
    $reject_reason = get_field( 'po_rejected_reason', $po_id );
    $paid_amount = floatval( get_field( 'po_paid_amount', $po_id ) ?: 0 );
    $pay_status  = get_field( 'po_payment_status', $po_id ) ?: 'unpaid';
    $created_date = get_the_date( 'd/m/Y H:i', $po_id );
    $po_currency = get_field( 'po_currency', $po_id ) ?: 'THB';
    $po_exchange_rate = (float) ( get_field( 'po_exchange_rate', $po_id ) ?: 1 );
    $po_shipping_method = get_field( 'po_shipping_method', $po_id ) ?: '';
    $po_total_amount_thb = (float) ( get_field( 'po_total_amount_thb', $po_id ) ?: 0 );
    $po_shipping_total = (float) ( get_field( 'po_shipping_total', $po_id ) ?: 0 );
    $po_grand_total_thb = (float) ( get_field( 'po_grand_total_thb', $po_id ) ?: 0 );
    $cur_sym = function_exists( 'b2f_currency_symbol' ) ? b2f_currency_symbol( $po_currency ) : '฿';
    $is_foreign = ( $po_currency !== 'THB' );

    // FIX-5: Query มูลค่าที่รับจริง (received_total) แยกจาก po_total_amount
    global $wpdb;
    $received_total = (float) $wpdb->get_var( $wpdb->prepare(
        "SELECT COALESCE(SUM(pm.meta_value), 0)
         FROM {$wpdb->posts} rcv
         JOIN {$wpdb->postmeta} pm_po ON pm_po.post_id = rcv.ID AND pm_po.meta_key = 'rcv_po_id'
         JOIN {$wpdb->postmeta} pm ON pm.post_id = rcv.ID AND pm.meta_key = 'rcv_total_value'
         WHERE rcv.post_type = 'b2f_receiving' AND rcv.post_status = 'publish'
         AND pm_po.meta_value = %s",
        $po_id
    ) );
    $outstanding = round( max( 0, ( $received_total > 0 ? $received_total : $total ) - $paid_amount ), 2 );

    // Status label + color
    $status_label = class_exists( 'B2F_Order_FSM' ) ? B2F_Order_FSM::label( $status ) : $status;
    $status_colors = array(
        'draft'=>'#6b7280','submitted'=>'#d97706','confirmed'=>'#059669','amended'=>'#a855f7',
        'rejected'=>'#dc2626','delivering'=>'#2563eb','received'=>'#10b981','partial_received'=>'#f59e0b',
        'paid'=>'#059669','partial_paid'=>'#f59e0b','completed'=>'#64748b','cancelled'=>'#dc2626',
    );
    $sc = $status_colors[ $status ] ?? '#6b7280';

    // Timeline
    $history = get_post_meta( $po_id, '_b2f_status_history', true ) ?: array();

    // Receiving records
    $receivings = get_posts( array( 'post_type' => 'b2f_receiving', 'posts_per_page' => -1, 'meta_query' => array( array( 'key' => 'rcv_po_id', 'value' => $po_id ) ), 'orderby' => 'date', 'order' => 'DESC' ) );

    // V.2.3: QC Reject data
    $reject_receivings = array();
    foreach ( $receivings as $rcv ) {
        if ( get_field( 'rcv_has_reject', $rcv->ID ) ) {
            $rcv_reject = array(
                'rcv_id'     => $rcv->ID,
                'rcv_number' => get_field( 'rcv_number', $rcv->ID ) ?: 'RCV-' . $rcv->ID,
                'resolved'   => (bool) get_field( 'rcv_reject_resolved', $rcv->ID ),
                'action'     => get_field( 'rcv_reject_action', $rcv->ID ) ?: '',
                'note'       => get_field( 'rcv_reject_note', $rcv->ID ) ?: '',
                'replacement_po' => intval( get_field( 'rcv_replacement_po_id', $rcv->ID ) ?: 0 ),
                'items'      => array(),
            );
            $rcv_items_data = get_field( 'rcv_items', $rcv->ID ) ?: array();
            foreach ( $rcv_items_data as $ri ) {
                $rej = intval( $ri['rcvi_qty_rejected'] ?? 0 );
                if ( $rej <= 0 ) continue;
                $photo_ids  = $ri['rcvi_reject_photos'] ?? array();
                $photo_urls = array();
                if ( is_array( $photo_ids ) ) {
                    foreach ( $photo_ids as $att_id ) {
                        $url = wp_get_attachment_url( $att_id );
                        if ( $url ) $photo_urls[] = $url;
                    }
                }
                $rcv_reject['items'][] = array(
                    'sku'        => $ri['rcvi_sku'] ?? '',
                    'qty'        => $rej,
                    'reason'     => $ri['rcvi_reject_reason'] ?? '',
                    'photos'     => $photo_urls,
                );
            }
            $reject_receivings[] = $rcv_reject;
        }
    }
    $has_unresolved_reject = false;
    foreach ( $reject_receivings as $rr ) {
        if ( ! $rr['resolved'] ) { $has_unresolved_reject = true; break; }
    }

    // Delivery records (po_deliveries ACF repeater)
    $deliveries = get_field( 'po_deliveries', $po_id ) ?: array();

    // Payment records
    $payments = get_posts( array( 'post_type' => 'b2f_payment', 'posts_per_page' => -1, 'meta_query' => array( array( 'key' => 'pmt_po_id', 'value' => $po_id ) ), 'orderby' => 'date', 'order' => 'DESC' ) );

    // Credit info
    $mk_debt = is_numeric( $maker_id ) ? floatval( get_field( 'maker_current_debt', $maker_id ) ?: 0 ) : 0;
    $mk_limit = is_numeric( $maker_id ) ? floatval( get_field( 'maker_credit_limit', $maker_id ) ?: 0 ) : 0;
    $credit_term = intval( get_field( 'maker_credit_term_days', $maker_id ) ?: 30 );

    $logo = 'https://www.dinoco.in.th/wp-content/uploads/2026/01/sss.png';
    // V.2.0: ตรวจว่า PO receivable ไหม (delivering / partial_received)
    $is_receivable = in_array( $status, array( 'delivering', 'partial_received' ), true );
    $rest_url = rest_url( 'b2f/v1/' );

    header( 'Content-Type: text/html; charset=UTF-8' );
?>
