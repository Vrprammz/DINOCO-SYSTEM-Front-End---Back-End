window.b2fRejectResolve = function(rcvId, action) {
    var modal = document.getElementById('rejectModal');
    var label = actionLabels[action] || action;
    var color = actionColors[action] || '#64748b';
    document.getElementById('rejectModalContent').innerHTML =
        '<h3 style="font-size:16px;margin:0 0 8px;">⚠️ ยืนยัน: ' + label + '</h3>' +
        '<div style="font-size:13px;color:#64748b;margin-bottom:12px;">ใบรับ #' + rcvId + '</div>' +
        '<textarea id="rejectNote" placeholder="หมายเหตุ (ไม่บังคับ)" style="width:100%;min-height:60px;border:1px solid #d1d5db;border-radius:8px;padding:8px;font-size:13px;font-family:inherit;resize:vertical;box-sizing:border-box;"></textarea>' +
        '<div style="display:flex;gap:8px;margin-top:16px;">' +
            '<button onclick="document.getElementById(\'rejectModal\').style.display=\'none\'" style="flex:1;padding:10px;border:1px solid #d1d5db;border-radius:8px;background:#fff;font-size:13px;cursor:pointer;font-family:inherit;">ยกเลิก</button>' +
            '<button onclick="b2fRejectDoResolve(' + rcvId + ',\'' + action + '\')" style="flex:2;padding:10px;border:none;border-radius:8px;background:' + color + ';color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;">ยืนยัน</button>' +
        '</div>';
    modal.style.display = 'flex';
};

window.b2fRejectDoResolve = function(rcvId, action) {
    document.getElementById('rejectModal').style.display = 'none';
    // C-2: disable ทุกปุ่ม reject resolve ป้องกันกดซ้ำ
    document.querySelectorAll('[onclick*="b2fRejectResolve"]').forEach(function(b){b.disabled=true;b.style.opacity='0.5';});
    toast('กำลังดำเนินการ...');

    var note = (document.getElementById('rejectNote') || {}).value || '';
    var headers = WP_NONCE ? { 'X-WP-Nonce': WP_NONCE, 'Content-Type': 'application/json' } : { 'X-B2F-Token': B2F_TOKEN, 'Content-Type': 'application/json' };

    fetch(REST + 'reject-resolve', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify({ rcv_id: rcvId, action: action, note: note })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
        if (res.success) {
            var msg = (actionLabels[action] || action) + ' สำเร็จ';
            if (res.new_po_number) msg += ' (' + res.new_po_number + ')';
            toast(msg, 'success');
            setTimeout(function() { location.reload(); }, 1500);
        } else {
            toast(res.error || 'เกิดข้อผิดพลาด', 'error');
        }
    })
    .catch(function() {
        toast('เชื่อมต่อไม่ได้ ลองใหม่', 'error');
    });
};

// Backdrop click to close reject modal
document.getElementById('rejectModal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
});

// Auto-scroll to #receive
if (location.hash === '#receive') {
    var el = document.getElementById('receive');
    if (el) setTimeout(function(){ el.scrollIntoView({behavior:'smooth'}); }, 300);
}
})();
