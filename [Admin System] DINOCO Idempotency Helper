    <script>
    (function() {
        var REST_LIST    = <?php echo wp_json_encode( $rest_url ); ?>;
        var REST_CLEANUP = <?php echo wp_json_encode( $cleanup ); ?>;
        var NONCE        = <?php echo wp_json_encode( $nonce ); ?>;

        function esc(s) {
            if (s === null || s === undefined) return '';
            return String(s).replace(/[&<>"']/g, function(c) {
                return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
            });
        }

        function fmtUser(uid) {
            if (!uid || uid === '0') return '<span style="color:#9ca3af;">system</span>';
            return '<a href="user-edit.php?user_id=' + esc(uid) + '" target="_blank" style="color:#3b82f6;">#' + esc(uid) + '</a>';
        }

        function fmtCode(c) {
            c = parseInt(c, 10) || 0;
            var color = c >= 200 && c < 300 ? '#10b981' : (c >= 400 ? '#dc2626' : '#6b7280');
            return '<span style="color:' + color + ';font-weight:600;font-family:monospace;">' + esc(c) + '</span>';
        }

        function fetchPage() {
            var params = new URLSearchParams({
                namespace: document.getElementById('idmFilterNs').value || '',
                user_id:   document.getElementById('idmFilterUser').value || '',
                limit:     50,
                offset:    0
            });
            var tbody = document.getElementById('idmTbody');
            tbody.innerHTML = '<tr><td colspan="7" style="padding:18px;text-align:center;color:#9ca3af;">⏳ กำลังโหลด...</td></tr>';

            fetch(REST_LIST + '?' + params.toString(), {
                headers: { 'X-WP-Nonce': NONCE },
                credentials: 'same-origin'
            })
            .then(function(r) { return r.json(); })
            .then(function(j) {
                if (!j || !j.success) {
                    tbody.innerHTML = '<tr><td colspan="7" style="padding:18px;text-align:center;color:#dc2626;">❌ โหลดล้มเหลว</td></tr>';
                    return;
                }
                renderRows(j.data || [], j.meta || {});
            })
            .catch(function(err) {
                tbody.innerHTML = '<tr><td colspan="7" style="padding:18px;text-align:center;color:#dc2626;">❌ ' + esc(err.message) + '</td></tr>';
            });
        }

        function renderRows(rows, meta) {
            var tbody = document.getElementById('idmTbody');
            if (!rows.length) {
                tbody.innerHTML = '<tr><td colspan="7" style="padding:24px;text-align:center;color:#9ca3af;">— ไม่มีรายการ —</td></tr>';
                document.getElementById('idmSummary').textContent = '';
                return;
            }
            var html = '';
            rows.forEach(function(r) {
                var hash_short = (r.request_hash || '').substring(0, 12) + '…';
                html += '<tr style="border-bottom:1px solid #f3f4f6;">';
                html += '<td style="padding:8px 10px;white-space:nowrap;color:#6b7280;font-size:12px;">' + esc(r.created_at) + '</td>';
                html += '<td style="padding:8px 10px;font-family:monospace;font-size:11px;color:#1f2937;">' + esc(r.idempotency_key) + '</td>';
                html += '<td style="padding:8px 10px;font-family:monospace;font-size:11px;color:#374151;">' + esc(r.namespace) + '</td>';
                html += '<td style="padding:8px 10px;font-family:monospace;font-size:11px;color:#9ca3af;" title="' + esc(r.request_hash) + '">' + esc(hash_short) + '</td>';
                html += '<td style="padding:8px 10px;">' + fmtCode(r.response_code) + '</td>';
                html += '<td style="padding:8px 10px;">' + fmtUser(r.user_id) + '</td>';
                html += '<td style="padding:8px 10px;color:#6b7280;font-size:12px;">' + esc(r.expires_at) + '</td>';
                html += '</tr>';
            });
            tbody.innerHTML = html;
            document.getElementById('idmSummary').textContent = '✓ ' + rows.length + ' / ' + (meta.total || 0) + ' รายการ';
        }

        function runCleanup() {
            var doIt = function(ok) {
                if (!ok) return;
                fetch(REST_CLEANUP, {
                    method: 'POST',
                    headers: { 'X-WP-Nonce': NONCE, 'Content-Type': 'application/json' },
                    credentials: 'same-origin'
                })
                .then(function(r) { return r.json(); })
                .then(function(j) {
                    var msg = (j && j.success) ? ('✓ ลบแล้ว ' + (j.data && j.data.deleted || 0) + ' แถว') : ('❌ ล้มเหลว');
                    if (window.dinocoModal && window.dinocoModal.alert) {
                        window.dinocoModal.alert({ title: 'Cleanup', message: msg });
                    } else {
                        alert(msg);
                    }
                    fetchPage();
                });
            };
            if (window.dinocoModal && window.dinocoModal.confirm) {
                window.dinocoModal.confirm({
                    title: 'Cleanup ทันที',
                    message: 'ลบ idempotency keys ที่หมดอายุแล้วทั้งหมด?',
                    onConfirm: function() { doIt(true); }
                });
            } else {
                doIt(confirm('ลบ idempotency keys ที่หมดอายุแล้วทั้งหมด?'));
            }
        }

        document.getElementById('idmRefresh').addEventListener('click', fetchPage);
        document.getElementById('idmApply').addEventListener('click', fetchPage);
        document.getElementById('idmCleanupBtn').addEventListener('click', runCleanup);
    })();
    </script>
