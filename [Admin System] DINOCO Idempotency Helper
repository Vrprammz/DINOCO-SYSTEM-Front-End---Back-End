/**
 * ╔══════════════════════════════════════════════════════════════════╗
 * ║  [Admin System] DINOCO Idempotency Helper                        ║
 * ║  Version: V.1.2 (2026-05-07) — R3 Idempotency hash deterministic ║
 * ║    (RFC 8785 JCS canonical form). Recursive ksort + sort numeric ║
 * ║    arrays by `sn` (when present) ascending. Stabilizes hash      ║
 * ║    across cross-client retries (mobile/RPi/OpenClaw produce      ║
 * ║    different JSON key order on retry → previously triggered 409).║
 * ║  Version: V.1.1 (2026-04-30) — Round 28: register dinoco_        ║
 * ║    idempotency_cleanup_cron via dinoco_register_cron heartbeat   ║
 * ║    tracking (Health Monitor visibility). Fallback to legacy      ║
 * ║    add_action preserved when Health Monitor snippet not synced.  ║
 * ║  Version: V.1.0 (2026-04-29) — Round 18 API-H4 Foundation        ║
 * ║  DB_ID: (pending — populate after first WP Code Snippets sync)   ║
 * ║  Description: Idempotency-Key middleware for safe POST retry     ║
 * ║    handling across DINOCO REST endpoints.                        ║
 * ╚══════════════════════════════════════════════════════════════════╝
 *
 * PROBLEM
 * -------
 * Audit finding API-H4 (Phase 5+ Deferred): 75+ POST endpoints across
 * /b2b/v1/, /b2f/v1/, /dinoco-stock/v1/, /dinoco-mcp/v1/, /liff-ai/v1/
 * accept any retry as a NEW request. Mobile/RPi/OpenClaw retries on
 * timeout (which often succeed server-side but client doesn't know) →
 * duplicate orders, double debt, double Flash dispatches.
 *
 * Existing patterns (per-endpoint custom keys):
 *   - bo-bulk-update-display: idempotency_key in body (B2F audit V.3.3)
 *   - DLQ retry: GET_LOCK prevents duplicate (V.34.5)
 *   - bo-fulfill: FOR UPDATE + idempotency check (V.1.6)
 *   - Snapshot create: GET_LOCK + idempotency (V.34.6)
 *
 * No central infrastructure → each endpoint reinvents the pattern,
 * inconsistent client integration story (some need body field, some
 * need header, some none at all).
 *
 * SOLUTION
 * --------
 * Single canonical table `wp_dinoco_idempotency_keys` (24h TTL) +
 * helper functions any REST handler can call:
 *
 *   - dinoco_idempotency_check( $key, $namespace, $request_body )
 *     → returns cached response if key+hash match, NULL if new request,
 *       WP_Error 409 if key matches but body hash differs
 *
 *   - dinoco_idempotency_store( $key, $namespace, $body, $resp, $code )
 *     → persists for future replay (24h)
 *
 *   - dinoco_idempotency_middleware( $namespace ) → wrapper that does
 *     check + handler + store in one call.
 *
 * Storage namespace: 'b2b/v1::place-order' so two endpoints with same
 * client-generated UUID don't collide.
 *
 * DESIGN PRINCIPLES
 *   - ADDITIVE       — zero behavior change at existing endpoints
 *                      (foundation only, integration in future rounds)
 *   - NON-THROWING   — best-effort; failures fall through to handler
 *   - DEFENSIVE      — silent fail-soft if table missing (lazy install)
 *   - BOUNDED        — 24h TTL via cron + hard 64-char key cap
 *
 * Public API:
 *   dinoco_idempotency_check( $key, $namespace, $body ) : array|null|WP_Error
 *   dinoco_idempotency_store( $key, $namespace, $body, $resp_data, $resp_code ) : int|false
 *   dinoco_idempotency_hash( $body ) : string  (SHA256)
 *   dinoco_idempotency_extract_key( WP_REST_Request $req ) : string  (header)
 *   dinoco_idempotency_cleanup_run() : int  (cron)
 *
 * Future endpoint integration pattern:
 *   register_rest_route( 'b2b/v1', '/place-order', array(
 *     'methods'  => 'POST',
 *     'callback' => function( WP_REST_Request $req ) {
 *       $key = dinoco_idempotency_extract_key( $req );
 *       if ( $key !== '' ) {
 *         $cached = dinoco_idempotency_check( $key, 'b2b/v1::place-order', $req->get_body() );
 *         if ( is_wp_error( $cached ) ) return $cached;          // 409 conflict
 *         if ( is_array( $cached ) )   return rest_ensure_response( $cached );  // replay
 *       }
 *       $result = b2b_place_order_handler( $req );  // existing logic untouched
 *       if ( $key !== '' && ! is_wp_error( $result ) ) {
 *         dinoco_idempotency_store( $key, 'b2b/v1::place-order', $req->get_body(), $result->get_data(), $result->get_status() );
 *       }
 *       return $result;
 *     },
 *   ) );
 *
 * NOT integrated into endpoints in this round — foundation only.
 */

if ( ! defined( 'ABSPATH' ) ) exit;

/* ═══════════════════════════════════════════════════════════════════════════
 * 1. SCHEMA INSTALL (lazy, idempotent)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_idempotency_schema_install' ) ) {
    /**
     * Install wp_dinoco_idempotency_keys table via dbDelta. Idempotent —
     * tracks version in wp_option 'dinoco_idempotency_schema_version'.
     *
     * Schema rationale:
     *   - idempotency_key VARCHAR(64) — covers UUIDv4 (36 chars), ULID
     *     (26 chars), client custom keys; 64 = headroom + cap enforced
     *     in extract helper to prevent abuse (very long keys waste index).
     *   - namespace VARCHAR(64) — '<namespace>::<route>' format, e.g.
     *     'b2b/v1::place-order' (19 chars typical, 64 = headroom).
     *   - request_hash CHAR(64) — SHA256 hex (always 64 chars).
     *   - response_data LONGTEXT — JSON-encoded, no realistic upper bound
     *     for cached endpoint responses (Flex cards can be ~10KB).
     *   - response_code SMALLINT UNSIGNED — HTTP status (200, 400, etc.)
     *   - 2 indexes:
     *       idx_key_namespace — primary lookup path (composite, ordered
     *         to match WHERE idempotency_key=? AND namespace=?)
     *       idx_expires_at — retention DELETE WHERE expires_at < NOW()
     *
     * @return void
     */
    function dinoco_idempotency_schema_install() {
        global $wpdb;

        $current = get_option( 'dinoco_idempotency_schema_version', '0' );
        $target  = '1.0';
        if ( $current === $target ) return;

        $table   = $wpdb->prefix . 'dinoco_idempotency_keys';
        $charset = $wpdb->get_charset_collate();

        // dbDelta-compatible CREATE: PRIMARY KEY inside, no FOREIGN KEY,
        // KEY (not INDEX), 2 spaces after PRIMARY KEY (dbDelta quirk).
        $sql = "CREATE TABLE {$table} (
            id BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
            idempotency_key VARCHAR(64) NOT NULL,
            namespace VARCHAR(64) NOT NULL,
            request_hash CHAR(64) NOT NULL,
            response_data LONGTEXT DEFAULT NULL,
            response_code SMALLINT(5) UNSIGNED DEFAULT NULL,
            user_id BIGINT(20) UNSIGNED DEFAULT NULL,
            request_ip VARCHAR(45) DEFAULT NULL,
            created_at DATETIME NOT NULL,
            expires_at DATETIME NOT NULL,
            PRIMARY KEY  (id),
            KEY idx_key_namespace (idempotency_key, namespace),
            KEY idx_expires_at (expires_at)
        ) {$charset};";

        require_once ABSPATH . 'wp-admin/includes/upgrade.php';
        dbDelta( $sql );

        update_option( 'dinoco_idempotency_schema_version', $target, false );
    }
}

// Lazy install on admin_init (fast — dbDelta is idempotent + version-gated)
add_action( 'admin_init', function() {
    if ( get_option( 'dinoco_idempotency_schema_version', '0' ) !== '1.0' ) {
        dinoco_idempotency_schema_install();
    }
} );

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. UTILITIES — hash, key extract, IP resolve
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_idempotency_canonical_normalize' ) ) {
    /**
     * V.1.2 — RFC 8785 JCS canonical form for cross-client retry compat.
     *
     * Recursively normalizes a body structure so that two clients producing
     * the same logical request (different JSON key order, different array
     * order) hash to the same value:
     *
     *   - Associative arrays  → ksort by key (stable, ASCII)
     *   - Numeric arrays      → if every element is an associative array
     *                           AND has 'sn' key → sort by sn ASC
     *                           (bulk-array endpoint pattern, see
     *                           docs/patterns/IDEMPOTENCY-KEY.md §Bulk).
     *                           Otherwise → preserved order (semantic).
     *   - Objects             → cast to array → ksort
     *   - Scalars             → returned unchanged
     *
     * Pure-logic. Bounded recursion (max depth 32). Defensive for cycles via
     * stack depth cap.
     *
     * @param mixed $value Input structure
     * @param int   $depth Current recursion depth (internal)
     * @return mixed Normalized structure
     */
    function dinoco_idempotency_canonical_normalize( $value, $depth = 0 ) {
        if ( $depth > 32 ) return $value; // safety cap
        if ( is_object( $value ) ) {
            $value = (array) $value;
        }
        if ( ! is_array( $value ) ) {
            return $value;
        }
        // Detect numeric (list) vs associative
        $is_list = ( array_keys( $value ) === range( 0, count( $value ) - 1 ) );
        if ( $is_list ) {
            $normalized = array();
            $all_have_sn = ( ! empty( $value ) );
            foreach ( $value as $item ) {
                $normalized[] = dinoco_idempotency_canonical_normalize( $item, $depth + 1 );
                if ( ! is_array( $item ) || ! array_key_exists( 'sn', $item ) ) {
                    $all_have_sn = false;
                }
            }
            if ( $all_have_sn ) {
                usort( $normalized, function( $a, $b ) {
                    $sa = is_array( $a ) && isset( $a['sn'] ) ? (string) $a['sn'] : '';
                    $sb = is_array( $b ) && isset( $b['sn'] ) ? (string) $b['sn'] : '';
                    return strcmp( $sa, $sb );
                } );
            }
            return $normalized;
        }
        // Associative — ksort + recurse
        ksort( $value, SORT_STRING );
        foreach ( $value as $k => $v ) {
            $value[ $k ] = dinoco_idempotency_canonical_normalize( $v, $depth + 1 );
        }
        return $value;
    }
}

if ( ! function_exists( 'dinoco_idempotency_hash' ) ) {
    /**
     * Compute SHA256 hex hash of a request body. Used to detect when
     * a client retries the SAME idempotency key with a DIFFERENT body
     * (which is a 409 conflict — client bug or intentional abuse).
     *
     * Body normalization rules (V.1.2):
     *   - null/array/object  → canonical normalize → wp_json_encode
     *   - string             → as-is (already serialized by client)
     *   - scalar (int/bool)  → cast to string
     *
     * V.1.2 RFC 8785 JCS canonical form: associative arrays ksort recursively,
     * numeric arrays sort by `sn` if every element has `sn` key. Stabilizes
     * hash across cross-client retries — different mobile/RPi/OpenClaw retry
     * paths emit JSON in different key order but same logical payload now
     * hashes identically.
     *
     * @param mixed $body Request body
     * @return string SHA256 hex (64 chars)
     */
    function dinoco_idempotency_hash( $body ) {
        if ( is_array( $body ) || is_object( $body ) ) {
            // V.1.2 — canonical normalize before encode
            if ( function_exists( 'dinoco_idempotency_canonical_normalize' ) ) {
                $body = dinoco_idempotency_canonical_normalize( $body );
            }
            $serialized = function_exists( 'wp_json_encode' )
                ? wp_json_encode( $body )
                : json_encode( $body );
            if ( $serialized === false ) $serialized = '[encode_failed]';
        } elseif ( is_scalar( $body ) ) {
            $serialized = (string) $body;
        } else {
            $serialized = ''; // null
        }
        return hash( 'sha256', $serialized );
    }
}

if ( ! function_exists( 'dinoco_idempotency_extract_key' ) ) {
    /**
     * Extract Idempotency-Key from a WP_REST_Request. Reads:
     *   1. X-Idempotency-Key header (preferred)
     *   2. Idempotency-Key header (canonical RFC draft naming)
     *
     * Returns '' (empty) if missing or invalid (not [A-Za-z0-9_-]+).
     * Caller treats '' as "no idempotency requested" → handler runs as
     * usual (no caching).
     *
     * Validation rules:
     *   - 1-64 chars (longer = abuse, reject silently as missing)
     *   - alphanum + dash + underscore + dot only (UUID/ULID compatible)
     *
     * @param WP_REST_Request $req
     * @return string Extracted key or '' if invalid/missing
     */
    function dinoco_idempotency_extract_key( $req ) {
        if ( ! is_object( $req ) || ! method_exists( $req, 'get_header' ) ) {
            return '';
        }
        $key = (string) $req->get_header( 'x_idempotency_key' );
        if ( $key === '' ) {
            $key = (string) $req->get_header( 'idempotency_key' );
        }
        $key = trim( $key );
        if ( $key === '' ) return '';

        // Strict validation: only safe chars + length cap
        if ( strlen( $key ) > 64 ) return '';
        if ( ! preg_match( '/^[A-Za-z0-9._-]+$/', $key ) ) return '';

        return $key;
    }
}

if ( ! function_exists( 'dinoco_idempotency_resolve_ip' ) ) {
    /**
     * Resolve client IP. Prefers GDPR snippet's Cloudflare/proxy-aware
     * helper (V.1.1), falls back to raw REMOTE_ADDR.
     *
     * @return string IPv4/IPv6 (max 45 chars) or '' if unavailable
     */
    function dinoco_idempotency_resolve_ip() {
        if ( function_exists( 'dinoco_gdpr_get_client_ip' ) ) {
            return (string) dinoco_gdpr_get_client_ip();
        }
        return isset( $_SERVER['REMOTE_ADDR'] ) ? (string) $_SERVER['REMOTE_ADDR'] : '';
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 3. CHECK API — dinoco_idempotency_check()
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_idempotency_check' ) ) {
    /**
     * Check if (key, namespace) has a cached response. Returns:
     *
     *   array      → cached response data (replay this to client; no handler call)
     *   WP_Error   → 409 conflict (key reused with DIFFERENT body — client bug)
     *   null       → no cache (proceed with handler, then store)
     *
     * Defensive behavior: if table missing, returns null (fall-through to
     * handler). Caller MUST treat null as "no cache" not "error".
     *
     * @param string $key       Client-supplied idempotency key
     * @param string $namespace Endpoint discriminator (e.g. 'b2b/v1::place-order')
     * @param mixed  $body      Request body (for hash comparison)
     * @return array|WP_Error|null
     */
    function dinoco_idempotency_check( $key, $namespace, $body ) {
        if ( ! is_string( $key ) || $key === '' || ! is_string( $namespace ) || $namespace === '' ) {
            return null;
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_idempotency_keys';

        // Defensive — table may not exist yet (snippet activated before sync)
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SHOW TABLES LIKE %s", $wpdb->esc_like( $table )
        ) );
        if ( $exists !== $table ) {
            // Try lazy install once per request
            static $tried_install = false;
            if ( ! $tried_install ) {
                $tried_install = true;
                if ( function_exists( 'dinoco_idempotency_schema_install' ) ) {
                    dinoco_idempotency_schema_install();
                    $exists = $wpdb->get_var( $wpdb->prepare(
                        "SHOW TABLES LIKE %s", $wpdb->esc_like( $table )
                    ) );
                }
            }
            if ( $exists !== $table ) {
                if ( ! get_transient( 'dinoco_idempotency_table_missing_logged' ) ) {
                    error_log( '[DINOCO_IDEMPOTENCY] table missing — replay disabled' );
                    set_transient( 'dinoco_idempotency_table_missing_logged', 1, HOUR_IN_SECONDS );
                }
                return null;
            }
        }

        $request_hash = dinoco_idempotency_hash( $body );

        try {
            // Cap key/namespace lengths defensively (extract helper already caps,
            // but caller may bypass)
            $key_safe       = substr( (string) $key, 0, 64 );
            $namespace_safe = substr( (string) $namespace, 0, 64 );

            $row = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, request_hash, response_data, response_code, expires_at
                 FROM {$table}
                 WHERE idempotency_key = %s AND namespace = %s
                 ORDER BY id DESC LIMIT 1",
                $key_safe,
                $namespace_safe
            ) );

            if ( ! $row ) return null;

            // TTL check — if expired, treat as new request (cron may not
            // have cleaned up yet; check defensively at read time too)
            $now_ts = (int) ( function_exists( 'current_time' ) ? current_time( 'timestamp' ) : time() );
            $exp_ts = strtotime( (string) $row->expires_at );
            if ( $exp_ts && $exp_ts < $now_ts ) {
                return null;
            }

            // Hash mismatch — same key, different body → 409 conflict
            if ( (string) $row->request_hash !== $request_hash ) {
                return new WP_Error(
                    'idempotency_conflict',
                    'Idempotency-Key reused with different request body',
                    array(
                        'status'           => 409,
                        'idempotency_key'  => $key_safe,
                        'namespace'        => $namespace_safe,
                        'original_request' => substr( (string) $row->request_hash, 0, 16 ) . '…',
                    )
                );
            }

            // Hash match — replay cached response
            $data = $row->response_data;
            if ( is_string( $data ) && $data !== '' ) {
                $decoded = json_decode( $data, true );
                if ( json_last_error() === JSON_ERROR_NONE ) {
                    $data = $decoded;
                }
            }

            return is_array( $data ) ? $data : array( 'replayed' => true, 'data' => $data );
        } catch ( \Throwable $e ) {
            error_log( '[DINOCO_IDEMPOTENCY] check exception: ' . $e->getMessage() );
            return null;
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 4. STORE API — dinoco_idempotency_store()
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_idempotency_store' ) ) {
    /**
     * Persist a (key, namespace, body, response) tuple for 24h replay.
     * No-op if table missing or key/namespace invalid.
     *
     * @param string $key
     * @param string $namespace
     * @param mixed  $body          Request body (hashed for future compare)
     * @param mixed  $response_data Response payload (array/scalar/null)
     * @param int    $response_code HTTP status (default 200)
     * @param int    $ttl_seconds   Default 86400 (24h); range 60..604800 (1min..7d)
     * @return int|false insert_id on success, false on failure
     */
    function dinoco_idempotency_store( $key, $namespace, $body, $response_data, $response_code = 200, $ttl_seconds = 86400 ) {
        if ( ! is_string( $key ) || $key === '' || ! is_string( $namespace ) || $namespace === '' ) {
            return false;
        }

        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_idempotency_keys';

        // Defensive — table may not exist yet
        $exists = $wpdb->get_var( $wpdb->prepare(
            "SHOW TABLES LIKE %s", $wpdb->esc_like( $table )
        ) );
        if ( $exists !== $table ) {
            // Don't bother lazy-installing here — check() already tried; if
            // we got here without check() (caller pattern violation), the
            // sole next request gets a fresh attempt.
            return false;
        }

        // Clamp TTL to safe range
        $ttl = (int) $ttl_seconds;
        if ( $ttl < 60 )       $ttl = 60;        // 1 min floor (anything less = pointless)
        if ( $ttl > 604800 )   $ttl = 604800;    // 7d ceiling

        $now      = (int) ( function_exists( 'current_time' ) ? current_time( 'timestamp' ) : time() );
        $created  = function_exists( 'current_time' ) ? current_time( 'mysql' ) : gmdate( 'Y-m-d H:i:s', $now );
        $expires  = function_exists( 'current_time' )
            ? gmdate( 'Y-m-d H:i:s', $now + $ttl )  // current_time('timestamp') is local; but we add seconds → still correct
            : gmdate( 'Y-m-d H:i:s', $now + $ttl );

        // Encode response — JSON for arrays/objects, string fallback for scalars
        $resp_str = '';
        if ( is_array( $response_data ) || is_object( $response_data ) ) {
            $encoded = function_exists( 'wp_json_encode' )
                ? wp_json_encode( $response_data )
                : json_encode( $response_data );
            $resp_str = ( $encoded === false ) ? '' : $encoded;
        } elseif ( is_scalar( $response_data ) ) {
            $resp_str = (string) $response_data;
        }

        $row = array(
            'idempotency_key' => substr( (string) $key, 0, 64 ),
            'namespace'       => substr( (string) $namespace, 0, 64 ),
            'request_hash'    => dinoco_idempotency_hash( $body ),
            'response_data'   => $resp_str,
            'response_code'   => max( 0, min( 65535, (int) $response_code ) ),
            'user_id'         => function_exists( 'get_current_user_id' ) ? ( get_current_user_id() ?: null ) : null,
            'request_ip'      => substr( dinoco_idempotency_resolve_ip(), 0, 45 ),
            'created_at'      => $created,
            'expires_at'      => $expires,
        );

        try {
            $ok = $wpdb->insert( $table, $row );
            if ( $ok === false ) {
                if ( ! get_transient( 'dinoco_idempotency_insert_failed_logged' ) ) {
                    error_log( '[DINOCO_IDEMPOTENCY] INSERT failed: ' . $wpdb->last_error );
                    set_transient( 'dinoco_idempotency_insert_failed_logged', 1, HOUR_IN_SECONDS );
                }
                return false;
            }
            return (int) $wpdb->insert_id;
        } catch ( \Throwable $e ) {
            error_log( '[DINOCO_IDEMPOTENCY] store exception: ' . $e->getMessage() );
            return false;
        }
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 5. CLEANUP CRON (24h TTL by default)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_idempotency_cleanup_run' ) ) {
    /**
     * DELETE expired rows. Chunked 1000/iter to avoid long lock + deadlock
     * with concurrent INSERTs. Max 20 iterations (= 20K rows/run cap).
     *
     * @return int Total rows deleted this run
     */
    function dinoco_idempotency_cleanup_run() {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_idempotency_keys';
        if ( $wpdb->get_var( $wpdb->prepare( "SHOW TABLES LIKE %s", $wpdb->esc_like( $table ) ) ) !== $table ) {
            return 0;
        }

        $total_deleted = 0;
        $max_iters     = 20;
        for ( $i = 0; $i < $max_iters; $i++ ) {
            $deleted = $wpdb->query(
                "DELETE FROM {$table} WHERE expires_at < NOW() LIMIT 1000"
            );
            if ( ! $deleted || $deleted === false ) break;
            $total_deleted += (int) $deleted;
            if ( $deleted < 1000 ) break;
            usleep( 50000 ); // 50ms gap
        }

        if ( $total_deleted > 0 ) {
            update_option( 'dinoco_idempotency_cleanup_last_run', array(
                'ran_at'  => current_time( 'mysql' ),
                'deleted' => $total_deleted,
            ), false );
        }

        return $total_deleted;
    }
}

if ( ! wp_next_scheduled( 'dinoco_idempotency_cleanup_cron' ) ) {
    // Daily at ~03:15 (offset from flag-audit retention at 03:00 to spread DB load)
    $first_run = strtotime( 'tomorrow 03:15' );
    if ( ! $first_run ) $first_run = time() + DAY_IN_SECONDS;
    wp_schedule_event( $first_run, 'daily', 'dinoco_idempotency_cleanup_cron' );
}
// V.1.1 Round 28: register heartbeat tracking via dinoco_register_cron when Health Monitor available;
// fallback to legacy add_action when snippet not synced (preserves backward compat).
if ( function_exists( 'dinoco_register_cron' ) && function_exists( 'dinoco_idempotency_cleanup_run' ) ) {
    dinoco_register_cron( 'dinoco_idempotency_cleanup_cron', 'daily', 'dinoco_idempotency_cleanup_run' );
} else {
    add_action( 'dinoco_idempotency_cleanup_cron', 'dinoco_idempotency_cleanup_run' );
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 6. QUERY API (admin viewer)
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_idempotency_query' ) ) {
    /**
     * Query idempotency rows with filters + pagination.
     *
     * @param array $args {
     *   @type string $namespace  Filter by namespace (exact)
     *   @type int    $user_id    Filter by user_id
     *   @type int    $limit      Page size (default 50, max 500)
     *   @type int    $offset     Pagination offset (default 0)
     *   @type string $orderby    'created_at'|'expires_at' (default created_at)
     *   @type string $order      'ASC'|'DESC' (default DESC)
     * }
     * @return array { rows: array<object>, total: int }
     */
    function dinoco_idempotency_query( $args = array() ) {
        global $wpdb;
        $table = $wpdb->prefix . 'dinoco_idempotency_keys';

        $defaults = array(
            'namespace' => '',
            'user_id'   => 0,
            'limit'     => 50,
            'offset'    => 0,
            'orderby'   => 'created_at',
            'order'     => 'DESC',
        );
        $args = wp_parse_args( $args, $defaults );

        $where  = array( '1=1' );
        $params = array();

        if ( ! empty( $args['namespace'] ) ) {
            $where[]  = 'namespace = %s';
            $params[] = (string) $args['namespace'];
        }
        if ( ! empty( $args['user_id'] ) ) {
            $where[]  = 'user_id = %d';
            $params[] = (int) $args['user_id'];
        }

        $orderby = in_array( $args['orderby'], array( 'created_at', 'expires_at', 'id' ), true )
            ? $args['orderby'] : 'created_at';
        $order   = strtoupper( $args['order'] ) === 'ASC' ? 'ASC' : 'DESC';

        $limit  = max( 1, min( 500, (int) $args['limit'] ) );
        $offset = max( 0, (int) $args['offset'] );

        $where_sql = implode( ' AND ', $where );

        // Count
        $count_sql = "SELECT COUNT(*) FROM {$table} WHERE {$where_sql}";
        $total = (int) ( $params
            ? $wpdb->get_var( $wpdb->prepare( $count_sql, $params ) )
            : $wpdb->get_var( $count_sql ) );

        // Rows — exclude response_data from list view (LONGTEXT — too heavy)
        $row_sql = "SELECT id, idempotency_key, namespace, request_hash, response_code,
                           user_id, request_ip, created_at, expires_at
                    FROM {$table}
                    WHERE {$where_sql}
                    ORDER BY {$orderby} {$order}
                    LIMIT %d OFFSET %d";
        $row_params = array_merge( $params, array( $limit, $offset ) );
        $rows = $wpdb->get_results( $wpdb->prepare( $row_sql, $row_params ) );
        if ( ! is_array( $rows ) ) $rows = array();

        return array( 'rows' => $rows, 'total' => $total );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 7. REST API — /wp-json/dinoco/v1/idempotency*
 * ═══════════════════════════════════════════════════════════════════════════ */

add_action( 'rest_api_init', function() {

    $perm_admin = function() {
        return current_user_can( 'manage_options' );
    };

    // GET /idempotency — list with filters
    register_rest_route( 'dinoco/v1', '/idempotency', array(
        'methods'             => 'GET',
        'permission_callback' => $perm_admin,
        'callback'            => function( WP_REST_Request $req ) {
            $args = array(
                'namespace' => sanitize_text_field( (string) $req->get_param( 'namespace' ) ),
                'user_id'   => absint( $req->get_param( 'user_id' ) ),
                'limit'     => max( 1, min( 500, (int) ( $req->get_param( 'limit' ) ?: 50 ) ) ),
                'offset'    => max( 0, (int) $req->get_param( 'offset' ) ),
                'orderby'   => sanitize_text_field( (string) ( $req->get_param( 'orderby' ) ?: 'created_at' ) ),
                'order'     => sanitize_text_field( (string) ( $req->get_param( 'order' ) ?: 'DESC' ) ),
            );
            $result = dinoco_idempotency_query( $args );
            return rest_ensure_response( array(
                'success' => true,
                'data'    => $result['rows'],
                'meta'    => array(
                    'total'  => $result['total'],
                    'limit'  => $args['limit'],
                    'offset' => $args['offset'],
                ),
            ) );
        },
    ) );

    // POST /idempotency/cleanup — manual trigger (admin only)
    register_rest_route( 'dinoco/v1', '/idempotency/cleanup', array(
        'methods'             => 'POST',
        'permission_callback' => $perm_admin,
        'callback'            => function( WP_REST_Request $req ) {
            $deleted = dinoco_idempotency_cleanup_run();
            return rest_ensure_response( array(
                'success' => true,
                'data'    => array(
                    'deleted'  => $deleted,
                    'last_run' => get_option( 'dinoco_idempotency_cleanup_last_run', null ),
                ),
            ) );
        },
    ) );
} );

