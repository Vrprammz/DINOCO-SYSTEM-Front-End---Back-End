if ( ! function_exists( 'dinoco_sn_recon_table_sessions' ) ) {
    function dinoco_sn_recon_table_sessions() {
        global $wpdb;
        return $wpdb->prefix . DINOCO_SN_RECON_TABLE_SESSIONS;
    }
}

if ( ! function_exists( 'dinoco_sn_recon_table_scans' ) ) {
    function dinoco_sn_recon_table_scans() {
        global $wpdb;
        return $wpdb->prefix . DINOCO_SN_RECON_TABLE_SCANS;
    }
}

if ( ! function_exists( 'dinoco_sn_recon_tables_exist' ) ) {
    function dinoco_sn_recon_tables_exist() {
        global $wpdb;
        $sessions = dinoco_sn_recon_table_sessions();
        $scans    = dinoco_sn_recon_table_scans();
        $count = $wpdb->get_var( $wpdb->prepare(
            "SELECT COUNT(*) FROM information_schema.tables
             WHERE table_schema = %s AND table_name IN ( %s, %s )",
            DB_NAME, $sessions, $scans
        ) );
        return ( (int) $count ) >= 2;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 2. SCHEMA — lazy install on admin_init via dbDelta
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_recon_install_schema' ) ) {
    /**
     * Lazy install both tables. Idempotent via dbDelta. Sets
     * `dinoco_sn_recon_schema_version` option after success.
     *
     * Pattern follows Approval Workflow V.0.1 — utf8mb4_bin on sn column
     * via post-create ALTER (dbDelta does not support per-column COLLATE).
     */
    function dinoco_sn_recon_install_schema() {
        global $wpdb;

        $current = (string) get_option( 'dinoco_sn_recon_schema_version', '0.0' );
        if ( version_compare( $current, DINOCO_SN_RECON_SCHEMA_VERSION, '>=' ) ) return;

        $sessions = dinoco_sn_recon_table_sessions();
        $scans    = dinoco_sn_recon_table_scans();
        $charset  = $wpdb->get_charset_collate();

        $sql_sessions = "CREATE TABLE {$sessions} (
            id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
            session_uuid CHAR(36) NOT NULL,
            initiated_by BIGINT UNSIGNED NOT NULL,
            status VARCHAR(16) NOT NULL DEFAULT 'counting',
            expected_count INT UNSIGNED NOT NULL,
            scanned_count INT UNSIGNED NOT NULL DEFAULT 0,
            variance_missing INT NOT NULL DEFAULT 0,
            variance_extra INT NOT NULL DEFAULT 0,
            resolution_action VARCHAR(20) DEFAULT NULL,
            notes TEXT,
            started_at DATETIME NOT NULL,
            submitted_at DATETIME DEFAULT NULL,
            closed_at DATETIME DEFAULT NULL,
            closed_by BIGINT UNSIGNED DEFAULT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY uniq_uuid (session_uuid),
            KEY idx_status (status, started_at),
            KEY idx_initiator (initiated_by, started_at)
        ) {$charset};";

        $sql_scans = "CREATE TABLE {$scans} (
            id BIGINT UNSIGNED NOT NULL AUTO_INCREMENT,
            session_id BIGINT UNSIGNED NOT NULL,
            sn VARCHAR(40) NOT NULL,
            scanned_at DATETIME NOT NULL,
            found_in_system TINYINT(1) NOT NULL DEFAULT 1,
            scanned_by BIGINT UNSIGNED NOT NULL,
            PRIMARY KEY  (id),
            UNIQUE KEY uq_session_sn (session_id, sn),
            KEY idx_session (session_id, scanned_at)
        ) {$charset};";

        if ( ! function_exists( 'dbDelta' ) ) {
            require_once ABSPATH . 'wp-admin/includes/upgrade.php';
        }
        dbDelta( $sql_sessions );
        dbDelta( $sql_scans );

        // ALTER post-create to enforce utf8mb4_bin collation on sn column
        // (case-sensitive S/N matching — DINOCO standard, mirrors sn_pool).
        $wpdb->query( "ALTER TABLE {$scans} MODIFY sn VARCHAR(40) COLLATE utf8mb4_bin NOT NULL" );

        update_option( 'dinoco_sn_recon_schema_version', DINOCO_SN_RECON_SCHEMA_VERSION, false );
    }
}

if ( ! has_action( 'admin_init', 'dinoco_sn_recon_install_schema' ) ) {
    add_action( 'admin_init', 'dinoco_sn_recon_install_schema', 36 );
}

