if ( ! function_exists( 'dinoco_sn_recon_register_routes' ) ) {
    function dinoco_sn_recon_register_routes() {
        if ( ! defined( 'DINOCO_SN_REST_NAMESPACE' ) ) return; // REST API snippet not synced

        $ns = DINOCO_SN_REST_NAMESPACE;
        $perm_we = function_exists( 'dinoco_sn_recon_perm_warehouse_or_admin' )
                     ? 'dinoco_sn_recon_perm_warehouse_or_admin' : '__return_true';
        $perm_admin = function_exists( 'dinoco_sn_recon_perm_admin' )
                        ? 'dinoco_sn_recon_perm_admin' : '__return_true';

        // POST /reconciliation/start
        register_rest_route( $ns, '/reconciliation/start', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_recon_start',
            'permission_callback' => $perm_we,
            'args'                => array(
                'actor_user_id' => array( 'type' => 'integer', 'sanitize_callback' => 'absint' ),
            ),
        ) );

        // GET /reconciliation/active
        register_rest_route( $ns, '/reconciliation/active', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_recon_active',
            'permission_callback' => $perm_we,
        ) );

        // GET /reconciliation/history
        register_rest_route( $ns, '/reconciliation/history', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_recon_history',
            'permission_callback' => $perm_admin,
            'args'                => array(
                'limit'  => array( 'type' => 'integer', 'default' => 20, 'sanitize_callback' => 'absint' ),
                'offset' => array( 'type' => 'integer', 'default' => 0, 'sanitize_callback' => 'absint' ),
            ),
        ) );

        // GET /reconciliation/{uuid}
        register_rest_route( $ns, '/reconciliation/(?P<uuid>[a-f0-9\-]{36})', array(
            'methods'             => 'GET',
            'callback'            => 'dinoco_sn_rest_recon_get',
            'permission_callback' => $perm_we,
            'args'                => array(
                'uuid' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
            ),
        ) );

        // POST /reconciliation/{uuid}/scan
        register_rest_route( $ns, '/reconciliation/(?P<uuid>[a-f0-9\-]{36})/scan', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_recon_scan',
            'permission_callback' => $perm_we,
            'args'                => array(
                'uuid' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'sn'   => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
            ),
        ) );

        // POST /reconciliation/{uuid}/submit
        register_rest_route( $ns, '/reconciliation/(?P<uuid>[a-f0-9\-]{36})/submit', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_recon_submit',
            'permission_callback' => $perm_we,
            'args'                => array(
                'uuid' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
            ),
        ) );

        // POST /reconciliation/{uuid}/close
        register_rest_route( $ns, '/reconciliation/(?P<uuid>[a-f0-9\-]{36})/close', array(
            'methods'             => 'POST',
            'callback'            => 'dinoco_sn_rest_recon_close',
            'permission_callback' => $perm_admin,
            'args'                => array(
                'uuid' => array( 'required' => true, 'type' => 'string', 'sanitize_callback' => 'sanitize_text_field' ),
                'resolution_action' => array(
                    'required'          => true,
                    'type'              => 'string',
                    'sanitize_callback' => 'sanitize_text_field',
                    'enum'              => array( 'void_missing', 'investigate', 'cancel' ),
                ),
                'notes' => array( 'type' => 'string', 'sanitize_callback' => 'sanitize_textarea_field' ),
            ),
        ) );
    }
}

