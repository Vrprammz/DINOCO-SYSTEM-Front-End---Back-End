if ( ! function_exists( 'dinoco_sn_rest_recon_start' ) ) {
    function dinoco_sn_rest_recon_start( $req ) {
        if ( function_exists( 'dinoco_sn_with_idempotency' ) ) {
            return dinoco_sn_with_idempotency( $req, 'reconciliation-start',
                array( 'actor_user_id' ),
                function( $req ) {
                    $actor = (int) $req->get_param( 'actor_user_id' );
                    $r = dinoco_sn_recon_start_session( $actor );
                    if ( is_wp_error( $r ) ) return $r;
                    return rest_ensure_response( array_merge( array( 'success' => true ), $r ) );
                }
            );
        }
        $actor = (int) $req->get_param( 'actor_user_id' );
        $r = dinoco_sn_recon_start_session( $actor );
        if ( is_wp_error( $r ) ) return $r;
        return rest_ensure_response( array_merge( array( 'success' => true ), $r ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_recon_active' ) ) {
    function dinoco_sn_rest_recon_active( $req ) {
        $session = dinoco_sn_recon_get_active_session();
        return rest_ensure_response( array(
            'success' => true,
            'session' => $session ?: null,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_recon_history' ) ) {
    function dinoco_sn_rest_recon_history( $req ) {
        if ( ! dinoco_sn_recon_tables_exist() ) {
            return rest_ensure_response( array( 'success' => true, 'sessions' => array() ) );
        }
        global $wpdb;
        $tbl = dinoco_sn_recon_table_sessions();
        $limit  = min( 100, max( 1, (int) $req->get_param( 'limit' ) ) );
        $offset = max( 0, (int) $req->get_param( 'offset' ) );
        $rows = $wpdb->get_results( $wpdb->prepare(
            "SELECT * FROM {$tbl}
             ORDER BY started_at DESC
             LIMIT %d OFFSET %d",
            $limit, $offset
        ) );
        return rest_ensure_response( array(
            'success'  => true,
            'sessions' => is_array( $rows ) ? $rows : array(),
            'limit'    => $limit,
            'offset'   => $offset,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_recon_get' ) ) {
    function dinoco_sn_rest_recon_get( $req ) {
        $uuid = (string) $req->get_param( 'uuid' );
        $session = dinoco_sn_recon_get_session_by_uuid( $uuid );
        if ( ! $session ) {
            return new WP_Error( 'session_not_found',
                __( 'Session not found.', 'dinoco-sn' ),
                array( 'status' => 404 ) );
        }
        // Include variance report if session is submitted/closed
        $report = null;
        if ( in_array( $session->status, array( 'submitted', 'closed' ), true ) ) {
            $rep = dinoco_sn_recon_get_variance_report( $uuid );
            if ( ! is_wp_error( $rep ) ) $report = $rep;
        }
        return rest_ensure_response( array(
            'success' => true,
            'session' => $session,
            'report'  => $report,
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_rest_recon_scan' ) ) {
    function dinoco_sn_rest_recon_scan( $req ) {
        $uuid = (string) $req->get_param( 'uuid' );
        $sn   = (string) $req->get_param( 'sn' );
        $cb = function( $req ) use ( $uuid, $sn ) {
            $r = dinoco_sn_recon_record_scan( $uuid, $sn, get_current_user_id() );
            if ( is_wp_error( $r ) ) return $r;
            return rest_ensure_response( array_merge( array( 'success' => true ), $r ) );
        };
        if ( function_exists( 'dinoco_sn_with_idempotency' ) ) {
            return dinoco_sn_with_idempotency( $req, 'reconciliation-scan',
                array( 'uuid', 'sn' ), $cb );
        }
        return $cb( $req );
    }
}

