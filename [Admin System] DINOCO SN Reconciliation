if ( ! function_exists( 'dinoco_sn_recon_generate_uuid' ) ) {
    function dinoco_sn_recon_generate_uuid() {
        if ( function_exists( 'wp_generate_uuid4' ) ) {
            return wp_generate_uuid4();
        }
        try {
            $data = random_bytes( 16 );
        } catch ( \Throwable $e ) {
            $data = openssl_random_pseudo_bytes( 16 );
        }
        $data[6] = chr( ord( $data[6] ) & 0x0f | 0x40 );
        $data[8] = chr( ord( $data[8] ) & 0x3f | 0x80 );
        return vsprintf( '%s%s-%s-%s-%s-%s%s%s', str_split( bin2hex( $data ), 4 ) );
    }
}

if ( ! function_exists( 'dinoco_sn_recon_is_valid_uuid' ) ) {
    function dinoco_sn_recon_is_valid_uuid( $uuid ) {
        return is_string( $uuid ) && (bool) preg_match(
            '/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i',
            $uuid
        );
    }
}

if ( ! function_exists( 'dinoco_sn_recon_valid_resolution' ) ) {
    function dinoco_sn_recon_valid_resolution( $action ) {
        $allowed = explode( ',', DINOCO_SN_RECON_VALID_RESOLUTIONS );
        return in_array( strtolower( trim( (string) $action ) ), $allowed, true );
    }
}

if ( ! function_exists( 'dinoco_sn_recon_compute_variance_pct' ) ) {
    /**
     * Compute absolute variance percentage of a session.
     * Pure-logic — no DB. Returns float [0.0, +∞).
     *
     * Edge case: expected_count=0 → variance_pct=0 ถ้าทุกอย่าง 0 ก็ตาม
     * (empty session is degenerate but not an error).
     */
    function dinoco_sn_recon_compute_variance_pct( $expected, $missing, $extra ) {
        $expected = max( 0, (int) $expected );
        $missing  = max( 0, (int) $missing );
        $extra    = max( 0, (int) $extra );
        if ( $expected === 0 ) {
            // No baseline — any extra is 100% variance, otherwise 0
            return $extra > 0 ? 100.0 : 0.0;
        }
        return ( ( $missing + $extra ) / $expected ) * 100.0;
    }
}

if ( ! function_exists( 'dinoco_sn_recon_requires_4eyes' ) ) {
    /**
     * 4-eyes gate: variance > threshold (default 5%) must be closed by an
     * admin with manage_options capability (regardless of warehouse role).
     *
     * Pure-logic — no DB. Threshold configurable via constant.
     */
    function dinoco_sn_recon_requires_4eyes( $expected, $missing, $extra ) {
        $pct = dinoco_sn_recon_compute_variance_pct( $expected, $missing, $extra );
        return $pct > (float) DINOCO_SN_RECON_4EYES_VARIANCE_PCT;
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 4. CORE HELPERS — START / GET / SCAN / SUBMIT / CLOSE
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_recon_get_active_session' ) ) {
    /**
     * Return current open session (status='counting' OR 'submitted') or null.
     * Defensive: null if tables not yet installed.
     */
    function dinoco_sn_recon_get_active_session() {
        if ( ! dinoco_sn_recon_tables_exist() ) return null;
        global $wpdb;
        $tbl = dinoco_sn_recon_table_sessions();
        return $wpdb->get_row(
            "SELECT * FROM {$tbl}
             WHERE status IN ( 'counting', 'submitted' )
             ORDER BY started_at DESC
             LIMIT 1"
        );
    }
}

if ( ! function_exists( 'dinoco_sn_recon_start_session' ) ) {
    /**
     * Atomic start. Snapshots `expected_count = COUNT(in_pool)` + INSERT.
     * Blocks if existing session is counting or submitted (409).
     *
     * @param int $actor_user_id Defaults to current user
     * @return array|WP_Error    { uuid, expected_count, started_at } | error
     */
    function dinoco_sn_recon_start_session( $actor_user_id = 0 ) {
        global $wpdb;

        $actor_user_id = (int) ( $actor_user_id ?: get_current_user_id() );
        if ( $actor_user_id <= 0 ) {
            return new WP_Error( 'invalid_actor',
                __( 'Actor user ID required.', 'dinoco-sn' ),
                array( 'status' => 400 ) );
        }

        // Defensive: ensure schema installed
        if ( ! dinoco_sn_recon_tables_exist() ) {
            if ( function_exists( 'dinoco_sn_recon_install_schema' ) ) {
                dinoco_sn_recon_install_schema();
            }
            if ( ! dinoco_sn_recon_tables_exist() ) {
                return new WP_Error( 'schema_not_ready',
                    __( 'Reconciliation tables not installed.', 'dinoco-sn' ),
                    array( 'status' => 503 ) );
            }
        }

        // Pool table required — we snapshot in_pool count from there
        if ( ! function_exists( 'dinoco_sn_table_exists' ) || ! dinoco_sn_table_exists( 'pool' ) ) {
            return new WP_Error( 'pool_not_ready',
                __( 'sn_pool table missing.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $sessions = dinoco_sn_recon_table_sessions();
        $pool     = dinoco_sn_table( 'pool' );
        $lock_name = 'dnc_sn_recon_start';

        // GET_LOCK to serialize concurrent start attempts (race protection)
        $got = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
        if ( $got !== 1 ) {
            return new WP_Error( 'lock_timeout',
                __( 'Another reconciliation start in progress.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        try {
            $wpdb->query( 'START TRANSACTION' );
            try {
                // Block if any active session exists
                $active = $wpdb->get_var(
                    "SELECT id FROM {$sessions}
                     WHERE status IN ( 'counting', 'submitted' )
                     LIMIT 1"
                );
                if ( $active ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'session_active',
                        __( 'An active reconciliation session already exists. Close it before starting a new one.', 'dinoco-sn' ),
                        array( 'status' => 409 ) );
                }

                $expected = (int) $wpdb->get_var(
                    "SELECT COUNT(*) FROM {$pool} WHERE status = 'in_pool'"
                );

                $uuid = dinoco_sn_recon_generate_uuid();
                $now  = current_time( 'mysql' );

                $ok = $wpdb->insert( $sessions, array(
                    'session_uuid'     => $uuid,
                    'initiated_by'     => $actor_user_id,
                    'status'           => 'counting',
                    'expected_count'   => $expected,
                    'scanned_count'    => 0,
                    'variance_missing' => 0,
                    'variance_extra'   => 0,
                    'started_at'       => $now,
                ) );

                if ( ! $ok ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'insert_failed',
                        __( 'Could not start reconciliation session.', 'dinoco-sn' ),
                        array( 'status' => 500 ) );
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log(
                        '', 'reconciliation_started', null, 'counting',
                        array( 'session_uuid' => $uuid, 'expected' => $expected ),
                        $actor_user_id, null, '', 'reconciliation', false
                    );
                }
                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( 'reconciliation_started', array(
                        'uuid' => $uuid, 'expected' => $expected, 'actor' => $actor_user_id,
                    ) );
                }

                $wpdb->query( 'COMMIT' );

                return array(
                    'uuid'           => $uuid,
                    'expected_count' => $expected,
                    'started_at'     => $now,
                );
            } catch ( \Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( $e, array( 'context' => 'sn_recon_start' ) );
                }
                return new WP_Error( 'start_failed', $e->getMessage(), array( 'status' => 500 ) );
            }
        } finally {
            // Always release lock
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_recon_get_session_by_uuid' ) ) {
    function dinoco_sn_recon_get_session_by_uuid( $uuid ) {
        if ( ! dinoco_sn_recon_is_valid_uuid( $uuid ) ) return null;
        if ( ! dinoco_sn_recon_tables_exist() ) return null;
        global $wpdb;
        $tbl = dinoco_sn_recon_table_sessions();
        return $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$tbl} WHERE session_uuid = %s LIMIT 1", $uuid
        ) );
    }
}

if ( ! function_exists( 'dinoco_sn_recon_record_scan' ) ) {
    /**
     * Idempotent scan record. Atomic check session active + check sn exists
     * in sn_pool. INSERT scan row (UNIQUE KEY uq_session_sn prevents dup).
     * Updates sessions.scanned_count.
     *
     * Defensive: dup-scan returns existing record (idempotent — admin scans
     * same plate twice). UNIQUE constraint catches race.
     *
     * @return array|WP_Error  { scanned_count, found_in_system, sn, message, dup }
     */
    function dinoco_sn_recon_record_scan( $uuid, $sn, $scanner_user_id = 0 ) {
        global $wpdb;

        if ( ! dinoco_sn_recon_is_valid_uuid( $uuid ) ) {
            return new WP_Error( 'invalid_uuid', __( 'Invalid session UUID.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        $sn = strtoupper( trim( (string) $sn ) );
        if ( $sn === '' ) {
            return new WP_Error( 'invalid_sn', __( 'sn is required.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        $scanner_user_id = (int) ( $scanner_user_id ?: get_current_user_id() );
        if ( $scanner_user_id <= 0 ) {
            return new WP_Error( 'invalid_actor', __( 'Scanner user required.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( ! dinoco_sn_recon_tables_exist() ) {
            return new WP_Error( 'schema_not_ready',
                __( 'Reconciliation tables not installed.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $sessions = dinoco_sn_recon_table_sessions();
        $scans    = dinoco_sn_recon_table_scans();

        $wpdb->query( 'START TRANSACTION' );
        try {
            // Lock session row + check status
            $session = $wpdb->get_row( $wpdb->prepare(
                "SELECT id, status, scanned_count FROM {$sessions}
                 WHERE session_uuid = %s FOR UPDATE",
                $uuid
            ), ARRAY_A );

            if ( ! $session ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'session_not_found',
                    __( 'Session not found.', 'dinoco-sn' ),
                    array( 'status' => 404 ) );
            }
            if ( $session['status'] !== 'counting' ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'session_not_counting',
                    sprintf( __( 'Session is %s; cannot accept new scans.', 'dinoco-sn' ), $session['status'] ),
                    array( 'status' => 409, 'current_status' => $session['status'] ) );
            }

            $session_id = (int) $session['id'];

            // Look up plate in sn_pool to set found_in_system
            $found = 0;
            if ( function_exists( 'dinoco_sn_table_exists' ) && dinoco_sn_table_exists( 'pool' ) ) {
                $pool = dinoco_sn_table( 'pool' );
                $exists = $wpdb->get_var( $wpdb->prepare(
                    "SELECT COUNT(*) FROM {$pool}
                     WHERE sn = %s AND status = 'in_pool'",
                    $sn
                ) );
                $found = ( (int) $exists > 0 ) ? 1 : 0;
            }

            $now = current_time( 'mysql' );
            $ins_ok = $wpdb->insert( $scans, array(
                'session_id'      => $session_id,
                'sn'              => $sn,
                'scanned_at'      => $now,
                'found_in_system' => $found,
                'scanned_by'      => $scanner_user_id,
            ) );

            if ( ! $ins_ok ) {
                // Most likely UNIQUE KEY violation on (session_id, sn) — duplicate scan.
                // Treat as idempotent — return existing record + dup=true.
                $existing = $wpdb->get_row( $wpdb->prepare(
                    "SELECT id, scanned_at, found_in_system FROM {$scans}
                     WHERE session_id = %d AND sn = %s LIMIT 1",
                    $session_id, $sn
                ), ARRAY_A );
                if ( $existing ) {
                    $wpdb->query( 'COMMIT' ); // no-op commit (no writes happened)
                    return array(
                        'scanned_count'    => (int) $session['scanned_count'],
                        'found_in_system'  => (int) $existing['found_in_system'] === 1,
                        'sn'               => $sn,
                        'message'          => 'duplicate_scan_idempotent',
                        'dup'              => true,
                    );
                }
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'scan_insert_failed',
                    __( 'Could not record scan.', 'dinoco-sn' ),
                    array( 'status' => 500 ) );
            }

            // Bump scanned_count atomically
            $wpdb->query( $wpdb->prepare(
                "UPDATE {$sessions} SET scanned_count = scanned_count + 1
                 WHERE id = %d AND status = 'counting'",
                $session_id
            ) );

            $wpdb->query( 'COMMIT' );

            $new_count = (int) $session['scanned_count'] + 1;
            return array(
                'scanned_count'   => $new_count,
                'found_in_system' => $found === 1,
                'sn'              => $sn,
                'message'         => $found ? 'recorded' : 'recorded_unknown_sn',
                'dup'             => false,
            );
        } catch ( \Throwable $e ) {
            $wpdb->query( 'ROLLBACK' );
            if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                dinoco_sn_obs_capture( $e, array( 'context' => 'sn_recon_scan', 'sn' => $sn, 'uuid' => $uuid ) );
            }
            return new WP_Error( 'scan_failed', $e->getMessage(), array( 'status' => 500 ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_recon_submit_session' ) ) {
    /**
     * Atomic compute variance + flip status counting → submitted.
     *   missing = sn_pool WHERE status='in_pool' AND sn NOT IN (scans this session)
     *   extra   = scans WHERE found_in_system=0 (sn not in_pool at scan time)
     *
     * Note: extra computed at SCAN time (not submit) to match boss spec —
     * pool can mutate between scans + submit; we use scan snapshot.
     *
     * @return array|WP_Error  { variance_missing, variance_extra, missing_sns[], extra_sns[], variance_pct, requires_4eyes }
     */
    function dinoco_sn_recon_submit_session( $uuid, $actor_user_id = 0 ) {
        global $wpdb;

        if ( ! dinoco_sn_recon_is_valid_uuid( $uuid ) ) {
            return new WP_Error( 'invalid_uuid', __( 'Invalid session UUID.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        $actor_user_id = (int) ( $actor_user_id ?: get_current_user_id() );
        if ( ! dinoco_sn_recon_tables_exist() ) {
            return new WP_Error( 'schema_not_ready',
                __( 'Reconciliation tables not installed.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $sessions = dinoco_sn_recon_table_sessions();
        $scans    = dinoco_sn_recon_table_scans();
        $lock_name = 'dnc_sn_recon_sub_' . substr( md5( $uuid ), 0, 16 );

        $got = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
        if ( $got !== 1 ) {
            return new WP_Error( 'lock_timeout',
                __( 'Concurrent submit in progress.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        try {
            $wpdb->query( 'START TRANSACTION' );
            try {
                $session = $wpdb->get_row( $wpdb->prepare(
                    "SELECT id, status, expected_count, scanned_count FROM {$sessions}
                     WHERE session_uuid = %s FOR UPDATE",
                    $uuid
                ), ARRAY_A );

                if ( ! $session ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'session_not_found',
                        __( 'Session not found.', 'dinoco-sn' ),
                        array( 'status' => 404 ) );
                }
                if ( $session['status'] !== 'counting' ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'invalid_state',
                        sprintf( __( 'Session is %s; cannot submit.', 'dinoco-sn' ), $session['status'] ),
                        array( 'status' => 409, 'current_status' => $session['status'] ) );
                }

                $session_id = (int) $session['id'];

                // Compute MISSING — in_pool plates not scanned this session
                $missing_sns = array();
                if ( function_exists( 'dinoco_sn_table_exists' ) && dinoco_sn_table_exists( 'pool' ) ) {
                    $pool = dinoco_sn_table( 'pool' );
                    $rows = $wpdb->get_col( $wpdb->prepare(
                        "SELECT p.sn FROM {$pool} p
                         WHERE p.status = 'in_pool'
                           AND NOT EXISTS (
                               SELECT 1 FROM {$scans} s
                               WHERE s.session_id = %d AND s.sn = p.sn
                           )
                         LIMIT 5000",
                        $session_id
                    ) );
                    $missing_sns = is_array( $rows ) ? $rows : array();
                }

                // Compute EXTRA — scanned but not found_in_system at scan time
                $extra_sns = $wpdb->get_col( $wpdb->prepare(
                    "SELECT sn FROM {$scans}
                     WHERE session_id = %d AND found_in_system = 0
                     LIMIT 5000",
                    $session_id
                ) );
                if ( ! is_array( $extra_sns ) ) $extra_sns = array();

                $missing_count = count( $missing_sns );
                $extra_count   = count( $extra_sns );

                $now = current_time( 'mysql' );
                $upd = $wpdb->update( $sessions,
                    array(
                        'status'           => 'submitted',
                        'variance_missing' => $missing_count,
                        'variance_extra'   => $extra_count,
                        'submitted_at'     => $now,
                    ),
                    array( 'id' => $session_id, 'status' => 'counting' ) // optimistic
                );
                if ( $upd === false || $upd === 0 ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'concurrent_modification',
                        __( 'Status changed during submit. Retry.', 'dinoco-sn' ),
                        array( 'status' => 409 ) );
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log(
                        '', 'reconciliation_submitted', 'counting', 'submitted',
                        array(
                            'session_uuid' => $uuid,
                            'missing'      => $missing_count,
                            'extra'        => $extra_count,
                            'expected'     => (int) $session['expected_count'],
                            'scanned'      => (int) $session['scanned_count'],
                        ),
                        $actor_user_id, null, '', 'reconciliation', false
                    );
                }
                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( 'reconciliation_submitted', array(
                        'uuid' => $uuid, 'missing' => $missing_count, 'extra' => $extra_count,
                    ) );
                }

                $wpdb->query( 'COMMIT' );

                $variance_pct = dinoco_sn_recon_compute_variance_pct(
                    (int) $session['expected_count'], $missing_count, $extra_count
                );
                $requires_4eyes = dinoco_sn_recon_requires_4eyes(
                    (int) $session['expected_count'], $missing_count, $extra_count
                );

                return array(
                    'variance_missing' => $missing_count,
                    'variance_extra'   => $extra_count,
                    'variance_pct'     => round( $variance_pct, 2 ),
                    'missing_sns'      => $missing_sns,
                    'extra_sns'        => $extra_sns,
                    'requires_4eyes'   => $requires_4eyes,
                );
            } catch ( \Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( $e, array( 'context' => 'sn_recon_submit', 'uuid' => $uuid ) );
                }
                return new WP_Error( 'submit_failed', $e->getMessage(), array( 'status' => 500 ) );
            }
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_recon_close_session' ) ) {
    /**
     * Close session with resolution. Atomic.
     *
     *   'void_missing' → loop missing → flip plate status → 'voided' (per-plate
     *                    audit + reason 'lost during count'); admin-only if
     *                    variance > 5% (4-eyes gate)
     *   'investigate'  → keep plates as-is, store notes, mark closed
     *   'cancel'       → close without changes (audit only)
     *
     * @return array|WP_Error  { resolution_action, voided_count, variance_pct, telegram_alert_sent }
     */
    function dinoco_sn_recon_close_session( $uuid, $actor_user_id = 0, $resolution_action = 'cancel', $notes = '' ) {
        global $wpdb;

        if ( ! dinoco_sn_recon_is_valid_uuid( $uuid ) ) {
            return new WP_Error( 'invalid_uuid', __( 'Invalid session UUID.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( ! dinoco_sn_recon_valid_resolution( $resolution_action ) ) {
            return new WP_Error( 'invalid_resolution',
                __( 'resolution_action must be void_missing|investigate|cancel.', 'dinoco-sn' ),
                array( 'status' => 400 ) );
        }
        $actor_user_id = (int) ( $actor_user_id ?: get_current_user_id() );
        if ( ! dinoco_sn_recon_tables_exist() ) {
            return new WP_Error( 'schema_not_ready',
                __( 'Reconciliation tables not installed.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $sessions = dinoco_sn_recon_table_sessions();
        $scans    = dinoco_sn_recon_table_scans();
        $resolution_action = strtolower( trim( (string) $resolution_action ) );
        $notes = mb_substr( (string) $notes, 0, 2000 );

        $lock_name = 'dnc_sn_recon_close_' . substr( md5( $uuid ), 0, 16 );
        $got = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 5)", $lock_name ) );
        if ( $got !== 1 ) {
            return new WP_Error( 'lock_timeout',
                __( 'Concurrent close in progress.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        try {
            $wpdb->query( 'START TRANSACTION' );
            try {
                $session = $wpdb->get_row( $wpdb->prepare(
                    "SELECT id, status, expected_count, variance_missing, variance_extra
                     FROM {$sessions} WHERE session_uuid = %s FOR UPDATE",
                    $uuid
                ), ARRAY_A );

                if ( ! $session ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'session_not_found',
                        __( 'Session not found.', 'dinoco-sn' ),
                        array( 'status' => 404 ) );
                }
                // Allow close from BOTH counting (admin force-close) AND submitted (normal flow)
                if ( ! in_array( $session['status'], array( 'counting', 'submitted' ), true ) ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'invalid_state',
                        sprintf( __( 'Session is %s; cannot close.', 'dinoco-sn' ), $session['status'] ),
                        array( 'status' => 409, 'current_status' => $session['status'] ) );
                }

                // 4-eyes gate — if variance > 5%, require admin manage_options
                $expected = (int) $session['expected_count'];
                $missing  = (int) $session['variance_missing'];
                $extra    = (int) $session['variance_extra'];
                $needs_4eyes = dinoco_sn_recon_requires_4eyes( $expected, $missing, $extra );

                if ( $needs_4eyes && ! current_user_can( 'manage_options' ) ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'requires_4eyes',
                        sprintf( __( 'Variance > %d%% requires admin (manage_options) to close.', 'dinoco-sn' ),
                                 (int) DINOCO_SN_RECON_4EYES_VARIANCE_PCT ),
                        array( 'status' => 422 ) );
                }

                $session_id = (int) $session['id'];
                $voided_count = 0;

                if ( $resolution_action === 'void_missing'
                     && function_exists( 'dinoco_sn_table_exists' )
                     && dinoco_sn_table_exists( 'pool' ) ) {

                    $pool = dinoco_sn_table( 'pool' );

                    // Re-derive missing list at close time (defensive — pool may
                    // have shifted since submit). Use NOT EXISTS subquery.
                    $missing_sns = $wpdb->get_col( $wpdb->prepare(
                        "SELECT p.sn FROM {$pool} p
                         WHERE p.status = 'in_pool'
                           AND NOT EXISTS (
                               SELECT 1 FROM {$scans} s
                               WHERE s.session_id = %d AND s.sn = p.sn
                           )
                         LIMIT 5000",
                        $session_id
                    ) );

                    if ( is_array( $missing_sns ) && ! empty( $missing_sns ) ) {
                        foreach ( $missing_sns as $sn ) {
                            $sn = strtoupper( trim( (string) $sn ) );
                            if ( $sn === '' ) continue;
                            // Per-plate UPDATE — optimistic on status='in_pool' to avoid stomping
                            // any race-arrived registration.
                            $r = $wpdb->update( $pool,
                                array(
                                    'status'      => 'voided',
                                    'prev_status' => 'in_pool',
                                    'voided_at'   => current_time( 'mysql' ),
                                ),
                                array( 'sn' => $sn, 'status' => 'in_pool' )
                            );
                            if ( $r ) {
                                $voided_count++;
                                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                                    dinoco_sn_audit_log(
                                        $sn, 'plate_voided', 'in_pool', 'voided',
                                        array( 'reconciliation_uuid' => $uuid ),
                                        $actor_user_id, null,
                                        'lost during count', 'reconciliation_void', false
                                    );
                                }
                                // V.x R8 B2 — fire canonical dispatcher so MCP cache,
                                // Member Dashboard banner cache, and observability
                                // pick up reconciliation voids. owner_uid=0 (in_pool
                                // plates have no customer owner; defensive zero).
                                if ( function_exists( 'dinoco_sn_fire_status_changed' ) ) {
                                    dinoco_sn_fire_status_changed(
                                        $sn, 'in_pool', 'voided', 0
                                    );
                                }
                            }
                        }
                    }
                }

                // Flip session → closed
                $now = current_time( 'mysql' );
                $upd = $wpdb->update( $sessions,
                    array(
                        'status'            => $resolution_action === 'cancel' && $session['status'] === 'counting'
                                                  ? 'cancelled' : 'closed',
                        'resolution_action' => $resolution_action,
                        'notes'             => $notes !== '' ? $notes : null,
                        'closed_at'         => $now,
                        'closed_by'         => $actor_user_id,
                    ),
                    array( 'id' => $session_id )
                );
                if ( $upd === false ) {
                    $wpdb->query( 'ROLLBACK' );
                    return new WP_Error( 'close_failed',
                        __( 'Could not close session.', 'dinoco-sn' ),
                        array( 'status' => 500 ) );
                }

                if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                    dinoco_sn_audit_log(
                        '', 'reconciliation_closed', $session['status'],
                        $resolution_action === 'cancel' && $session['status'] === 'counting' ? 'cancelled' : 'closed',
                        array(
                            'session_uuid'      => $uuid,
                            'resolution_action' => $resolution_action,
                            'voided_count'      => $voided_count,
                            'variance_missing'  => $missing,
                            'variance_extra'    => $extra,
                            'variance_pct'      => round( dinoco_sn_recon_compute_variance_pct( $expected, $missing, $extra ), 2 ),
                        ),
                        $actor_user_id, null, $notes, 'reconciliation_close',
                        $needs_4eyes  // sensitive=true if 4-eyes was required (5y retention)
                    );
                }

                $wpdb->query( 'COMMIT' );

                $variance_pct = dinoco_sn_recon_compute_variance_pct( $expected, $missing, $extra );
                $telegram_sent = false;

                // Telegram alert บอส if variance > 5% (defensive function_exists)
                if ( $needs_4eyes && function_exists( 'b2b_tg_send_dedup' ) ) {
                    $msg = sprintf(
                        "⚠️ S/N Reconciliation closed with HIGH variance\n"
                        . "Session: %s\n"
                        . "Variance: %.2f%% (missing=%d, extra=%d, expected=%d)\n"
                        . "Resolution: %s%s\n"
                        . "Voided: %d plates\n"
                        . "Closed by user #%d",
                        $uuid, $variance_pct, $missing, $extra, $expected,
                        $resolution_action,
                        $resolution_action === 'void_missing' ? ' (auto-voided missing plates)' : '',
                        $voided_count, $actor_user_id
                    );
                    try {
                        b2b_tg_send_dedup( 'sn_recon_close_' . $uuid, $msg, 86400 );
                        $telegram_sent = true;
                    } catch ( \Throwable $e ) {
                        // Best-effort — never throw from notification path
                    }
                }

                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( 'reconciliation_closed', array(
                        'uuid' => $uuid, 'resolution' => $resolution_action,
                        'voided_count' => $voided_count, 'variance_pct' => round( $variance_pct, 2 ),
                    ) );
                }

                return array(
                    'resolution_action'   => $resolution_action,
                    'voided_count'        => $voided_count,
                    'variance_pct'        => round( $variance_pct, 2 ),
                    'telegram_alert_sent' => $telegram_sent,
                );
            } catch ( \Throwable $e ) {
                $wpdb->query( 'ROLLBACK' );
                if ( function_exists( 'dinoco_sn_obs_capture' ) ) {
                    dinoco_sn_obs_capture( $e, array( 'context' => 'sn_recon_close', 'uuid' => $uuid ) );
                }
                return new WP_Error( 'close_failed', $e->getMessage(), array( 'status' => 500 ) );
            }
        } finally {
            $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
        }
    }
}

if ( ! function_exists( 'dinoco_sn_recon_get_variance_report' ) ) {
    /**
     * Read-only variance report. Returns missing[]+extra[] SNs with metadata.
     * Safe to call on submitted OR closed sessions.
     */
    function dinoco_sn_recon_get_variance_report( $uuid ) {
        global $wpdb;
        if ( ! dinoco_sn_recon_is_valid_uuid( $uuid ) ) {
            return new WP_Error( 'invalid_uuid', __( 'Invalid session UUID.', 'dinoco-sn' ), array( 'status' => 400 ) );
        }
        if ( ! dinoco_sn_recon_tables_exist() ) {
            return new WP_Error( 'schema_not_ready',
                __( 'Reconciliation tables not installed.', 'dinoco-sn' ),
                array( 'status' => 503 ) );
        }

        $sessions = dinoco_sn_recon_table_sessions();
        $scans    = dinoco_sn_recon_table_scans();

        $session = $wpdb->get_row( $wpdb->prepare(
            "SELECT * FROM {$sessions} WHERE session_uuid = %s LIMIT 1", $uuid
        ), ARRAY_A );
        if ( ! $session ) {
            return new WP_Error( 'session_not_found',
                __( 'Session not found.', 'dinoco-sn' ),
                array( 'status' => 404 ) );
        }

        $session_id = (int) $session['id'];
        $missing = array();
        $extra   = array();

        if ( function_exists( 'dinoco_sn_table_exists' ) && dinoco_sn_table_exists( 'pool' ) ) {
            $pool = dinoco_sn_table( 'pool' );
            $missing = $wpdb->get_col( $wpdb->prepare(
                "SELECT p.sn FROM {$pool} p
                 WHERE p.status = 'in_pool'
                   AND NOT EXISTS (
                       SELECT 1 FROM {$scans} s WHERE s.session_id = %d AND s.sn = p.sn
                   )
                 LIMIT 5000",
                $session_id
            ) );
            $missing = is_array( $missing ) ? $missing : array();
        }

        $extra = $wpdb->get_col( $wpdb->prepare(
            "SELECT sn FROM {$scans}
             WHERE session_id = %d AND found_in_system = 0
             LIMIT 5000",
            $session_id
        ) );
        $extra = is_array( $extra ) ? $extra : array();

        return array(
            'session'      => $session,
            'missing_sns'  => $missing,
            'extra_sns'    => $extra,
            'variance_pct' => round( dinoco_sn_recon_compute_variance_pct(
                (int) $session['expected_count'],
                (int) $session['variance_missing'],
                (int) $session['variance_extra']
            ), 2 ),
        );
    }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * 5. SLA CRON — auto-cancel sessions older than 7 days
 * ═══════════════════════════════════════════════════════════════════════════ */

if ( ! function_exists( 'dinoco_sn_run_reconciliation_timeout' ) ) {
    /**
     * Daily 04:00 — find sessions where status='counting' AND started_at older
     * than 7 days. Auto-flip to status='cancelled' + write Telegram alert.
     *
     * Heartbeat: dinoco_cron_sn_reconciliation_timeout_last_run option
     * (Round 28+ Health Monitor pattern).
     */
    function dinoco_sn_run_reconciliation_timeout() {
        if ( ! dinoco_sn_recon_tables_exist() ) {
            update_option( 'dinoco_cron_sn_reconciliation_timeout_last_run', current_time( 'mysql' ) );
            return;
        }

        try {
            global $wpdb;
            $tbl = dinoco_sn_recon_table_sessions();
            $cutoff = gmdate( 'Y-m-d H:i:s', time() - DINOCO_SN_RECON_SLA_DAYS * 86400 );

            $stale = $wpdb->get_results( $wpdb->prepare(
                "SELECT id, session_uuid, initiated_by, expected_count, scanned_count, started_at
                 FROM {$tbl}
                 WHERE status = 'counting' AND started_at < %s
                 LIMIT 50",
                $cutoff
            ), ARRAY_A );

            if ( ! is_array( $stale ) ) $stale = array();
            $cancelled = 0;

            foreach ( $stale as $row ) {
                $upd = $wpdb->update( $tbl,
                    array(
                        'status'            => 'cancelled',
                        'resolution_action' => 'cancel',
                        'notes'             => 'auto-cancelled by SLA cron (>' . DINOCO_SN_RECON_SLA_DAYS . ' days)',
                        'closed_at'         => current_time( 'mysql' ),
                    ),
                    array( 'id' => (int) $row['id'], 'status' => 'counting' )
                );
                if ( $upd ) {
                    $cancelled++;
                    if ( function_exists( 'dinoco_sn_audit_log' ) ) {
                        dinoco_sn_audit_log(
                            '', 'reconciliation_auto_cancelled', 'counting', 'cancelled',
                            array(
                                'session_uuid' => $row['session_uuid'],
                                'reason'       => 'sla_timeout',
                                'started_at'   => $row['started_at'],
                            ),
                            0, null, '', 'reconciliation_sla', false
                        );
                    }
                    if ( function_exists( 'b2b_tg_send_dedup' ) ) {
                        $msg = sprintf(
                            "⏰ S/N Reconciliation auto-cancelled (SLA %dd)\n"
                            . "Session: %s\n"
                            . "Started: %s\n"
                            . "Initiated by: user #%d\n"
                            . "Progress: %d/%d scanned",
                            DINOCO_SN_RECON_SLA_DAYS,
                            $row['session_uuid'],
                            $row['started_at'],
                            (int) $row['initiated_by'],
                            (int) $row['scanned_count'],
                            (int) $row['expected_count']
                        );
                        try {
                            b2b_tg_send_dedup( 'sn_recon_sla_' . $row['session_uuid'], $msg, 86400 );
                        } catch ( \Throwable $e ) {
                            // Best-effort
                        }
                    }
                }
            }

            update_option( 'dinoco_sn_recon_last_sla_run', array(
                'at'        => current_time( 'mysql' ),
                'cancelled' => $cancelled,
                'scanned'   => count( $stale ),
            ), false );
        } catch ( \Throwable $e ) {
            if ( function_exists( 'dinoco_obs_capture' ) ) {
                dinoco_obs_capture_exception( $e, array( 'context' => 'sn_reconciliation_timeout' ) );
            }
        }

        update_option( 'dinoco_cron_sn_reconciliation_timeout_last_run', current_time( 'mysql' ) );
    }
}

if ( ! function_exists( 'dinoco_sn_recon_register_cron' ) ) {
    function dinoco_sn_recon_register_cron() {
        // Use dinoco_register_cron heartbeat pattern (Round 28+) if available
        if ( function_exists( 'dinoco_register_cron' ) ) {
            dinoco_register_cron(
                'dinoco_sn_reconciliation_timeout_cron',
                'daily',
                'dinoco_sn_run_reconciliation_timeout'
            );
            return;
        }

        // Fallback — plain WP-Cron schedule + action
        if ( ! wp_next_scheduled( 'dinoco_sn_reconciliation_timeout_cron' ) ) {
            wp_schedule_event( time() + 60, 'daily', 'dinoco_sn_reconciliation_timeout_cron' );
        }
        if ( ! has_action( 'dinoco_sn_reconciliation_timeout_cron', 'dinoco_sn_run_reconciliation_timeout' ) ) {
            add_action( 'dinoco_sn_reconciliation_timeout_cron', 'dinoco_sn_run_reconciliation_timeout' );
        }
    }
}

if ( ! has_action( 'init', 'dinoco_sn_recon_register_cron' ) ) {
    add_action( 'init', 'dinoco_sn_recon_register_cron', 35 );
}

