if ( ! function_exists( 'dinoco_sn_recon_perm_warehouse_or_admin' ) ) {
    /**
     * Warehouse staff (dinoco_sn_warehouse cap) OR admin (manage_options).
     * Used for start/scan/submit/active/get/history.
     */
    function dinoco_sn_recon_perm_warehouse_or_admin( $req ) {
        if ( current_user_can( 'manage_options' ) ) return true;
        if ( current_user_can( 'dinoco_sn_warehouse' ) ) return true;
        if ( function_exists( 'dinoco_sn_user_can_warehouse' ) && dinoco_sn_user_can_warehouse() ) {
            return true;
        }
        return new WP_Error( 'rest_forbidden',
            __( 'Warehouse or admin role required.', 'dinoco-sn' ),
            array( 'status' => 403 ) );
    }
