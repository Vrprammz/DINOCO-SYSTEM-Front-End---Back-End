        <script>
        (function() {
            var ROOT = document.querySelector('.dnc-sn-recon-root');
            if (!ROOT || ROOT.dataset.bound === '1') return;
            ROOT.dataset.bound = '1';

            var REST = (window.wpApiSettings && window.wpApiSettings.root) || '/wp-json/';
            var NS = REST + 'dinoco-sn/v1/reconciliation';

            function api(path, opts) {
                opts = opts || {};
                var headers = opts.headers || {};
                headers['Content-Type'] = 'application/json';
                var nonce = (opts.nonce) || (ROOT.querySelector('[data-nonce]') || {}).getAttribute && ROOT.querySelector('[data-nonce]').getAttribute('data-nonce');
                if (nonce) headers['X-WP-Nonce'] = nonce;
                opts.headers = headers;
                opts.credentials = 'same-origin';
                return fetch(NS + path, opts).then(function(r) { return r.json().then(function(j) { return { ok: r.ok, status: r.status, body: j }; }); });
            }

            ROOT.addEventListener('click', async function(ev) {
                var btn = ev.target.closest('[data-action]');
                if (!btn) return;
                var action = btn.dataset.action;
                var uuid = btn.dataset.uuid || (btn.closest('[data-uuid]') || {}).getAttribute && btn.closest('[data-uuid]').getAttribute('data-uuid');
                var nonce = btn.dataset.nonce || (btn.closest('[data-nonce]') || {}).getAttribute && btn.closest('[data-nonce]').getAttribute('data-nonce');

                if (action === 'start') {
                    if (!(await dinoco_modal_confirm('เริ่ม Reconciliation Session ใหม่?'))) return;
                    api('/start', { method: 'POST', nonce: nonce, body: '{}' }).then(async function(r) {
                        if (r.ok) { location.reload(); }
                        else await dinoco_modal_alert((r.body && r.body.message) || 'Start failed');
                    });
                }
                else if (action === 'scan') {
                    var input = ROOT.querySelector('#dnc-sn-recon-scan-input');
                    if (!input || !input.value.trim()) return;
                    var sn = input.value.trim().toUpperCase();
                    api('/' + uuid + '/scan', { method: 'POST', nonce: nonce, body: JSON.stringify({ uuid: uuid, sn: sn }) }).then(async function(r) {
                        if (r.ok) {
                            var li = document.createElement('li');
                            var cls = r.body.dup ? 'dup' : (r.body.found_in_system ? 'found' : 'not-found');
                            li.className = cls;
                            li.innerHTML = '<span>' + sn + '</span><span>' + (r.body.dup ? 'ซ้ำ' : (r.body.found_in_system ? '✓' : '⚠ ไม่อยู่')) + '</span>';
                            var list = ROOT.querySelector('#dnc-sn-recon-recent-list');
                            if (list) list.insertBefore(li, list.firstChild);
                            input.value = ''; input.focus();
                        } else {
                            await dinoco_modal_alert((r.body && r.body.message) || 'Scan failed');
                        }
                    });
                }
                else if (action === 'submit') {
                    if (!(await dinoco_modal_confirm('Submit count? หลังจากนี้แก้ scan ไม่ได้'))) return;
                    api('/' + uuid + '/submit', { method: 'POST', nonce: nonce, body: JSON.stringify({ uuid: uuid }) }).then(async function(r) {
                        if (r.ok) location.reload();
                        else await dinoco_modal_alert((r.body && r.body.message) || 'Submit failed');
                    });
                }
                else if (action === 'close-void' || action === 'close-investigate' || action === 'close-cancel') {
                    var resmap = { 'close-void': 'void_missing', 'close-investigate': 'investigate', 'close-cancel': 'cancel' };
                    var res = resmap[action];
                    var msg = res === 'void_missing'
                        ? 'Void missing plates ทั้งหมด? — ไม่สามารถ undo ได้'
                        : (res === 'investigate' ? 'ปิด session แบบ investigate (เก็บ missing plates ไว้)?' : 'ยกเลิก session?');
                    if (!(await dinoco_modal_confirm(msg))) return;
                    var notes = (ROOT.querySelector('#dnc-sn-recon-close-notes') || {}).value || '';
                    api('/' + uuid + '/close', { method: 'POST', nonce: nonce, body: JSON.stringify({ uuid: uuid, resolution_action: res, notes: notes }) }).then(async function(r) {
                        if (r.ok) location.reload();
                        else await dinoco_modal_alert((r.body && r.body.message) || 'Close failed');
                    });
                }
            });

            // Enter-key scan support
            var scanInput = ROOT.querySelector('#dnc-sn-recon-scan-input');
            if (scanInput) {
                scanInput.addEventListener('keydown', function(ev) {
                    if (ev.key === 'Enter') {
                        ev.preventDefault();
                        var btn = ROOT.querySelector('button[data-action="scan"]');
                        if (btn) btn.click();
                    }
                });
            }
        })();
        </script>
        <?php
    }
