        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // V.1.3 NEW: POST /save-pack-slots — save slots for a SKU (replace all)
    register_rest_route( 'dinoco-flash-golive/v1', '/save-pack-slots', array(
        'methods'  => 'POST',
        'callback' => function( $req ) {
            global $wpdb;
            $sku   = strtoupper( trim( sanitize_text_field( $req->get_param( 'sku' ) ?: '' ) ) );
            $slots = $req->get_param( 'slots' );
            if ( empty( $sku ) ) return new WP_Error( 'bad_sku', 'sku required', array( 'status' => 400 ) );
            if ( ! is_array( $slots ) || empty( $slots ) ) {
                return new WP_Error( 'no_slots', 'slots[] required', array( 'status' => 400 ) );
            }
            if ( count( $slots ) > 20 ) {
                return new WP_Error( 'too_many_slots', 'max 20 slots per SKU', array( 'status' => 400 ) );
            }

            $products_tbl = $wpdb->prefix . 'dinoco_products';
            $slots_tbl    = $wpdb->prefix . 'dinoco_pack_slots';

            // Verify SKU exists + is multi_box
            $prod = $wpdb->get_row( $wpdb->prepare(
                "SELECT sku, pack_mode, boxes_per_unit FROM {$products_tbl} WHERE sku = %s AND is_active = 1 LIMIT 1",
                $sku
            ) );
            if ( ! $prod ) return new WP_Error( 'sku_not_found', 'SKU not found or inactive', array( 'status' => 404 ) );

            // Transaction wrap: replace all slots
            $wpdb->query( 'START TRANSACTION' );
            try {
                $wpdb->query( $wpdb->prepare(
                    "DELETE FROM {$slots_tbl} WHERE product_sku = %s", $sku
                ) );
                $inserted = 0;
                foreach ( $slots as $idx => $slot ) {
                    if ( ! is_array( $slot ) ) continue;
                    $tpl_id  = intval( $slot['box_template_id'] ?? 0 );
                    $content = intval( $slot['content_weight_g'] ?? 0 );
                    if ( $tpl_id <= 0 ) {
                        throw new Exception( "slot {$idx}: box_template_id required" );
                    }
                    // Validate template exists + active
                    $tpl_ok = (int) $wpdb->get_var( $wpdb->prepare(
                        "SELECT COUNT(*) FROM {$wpdb->prefix}dinoco_box_templates WHERE id = %d AND is_active = 1",
                        $tpl_id
                    ) );
                    if ( ! $tpl_ok ) throw new Exception( "slot {$idx}: template_id {$tpl_id} not found" );
                    $ok = $wpdb->insert( $slots_tbl, array(
                        'product_sku'      => $sku,
                        'slot_index'       => intval( $idx ),
                        'box_template_id'  => $tpl_id,
                        'content_weight_g' => $content > 0 ? $content : null,
                        'created_at'       => current_time( 'mysql' ),
                        'updated_at'       => current_time( 'mysql' ),
                    ) );
                    if ( $ok === false ) throw new Exception( "slot {$idx} insert failed: " . $wpdb->last_error );
                    $inserted++;
                }
                // Update shipping_updated_by + at on the product
                $wpdb->update(
                    $products_tbl,
                    array(
                        'shipping_updated_by' => get_current_user_id(),
                        'shipping_updated_at' => current_time( 'mysql' ),
                    ),
                    array( 'sku' => $sku )
                );
                $wpdb->query( 'COMMIT' );
            } catch ( Exception $e ) {
                $wpdb->query( 'ROLLBACK' );
                return new WP_Error( 'save_failed', $e->getMessage(), array( 'status' => 500 ) );
            }

            // Invalidate caches
            wp_cache_flush_group( 'dinoco_shipping' );
            if ( class_exists( 'DINOCO_Catalog' ) && method_exists( 'DINOCO_Catalog', 'flush_memo' ) ) DINOCO_Catalog::flush_memo();

            return rest_ensure_response( array(
                'ok'       => true,
                'sku'      => $sku,
                'inserted' => $inserted,
            ) );
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // POST /smoke-test — resolver dry-runs
    register_rest_route( 'dinoco-flash-golive/v1', '/smoke-test', array(
        'methods'  => 'POST',
        'callback' => function() {
            global $wpdb;
            if ( ! function_exists( 'dinoco_resolve_pno_shipping' ) ) {
                return new WP_Error( 'no_helper', 'resolver missing', array( 'status' => 500 ) );
            }
            // Pick 1 SKU per pack_mode for smoke test
            $products_tbl = $wpdb->prefix . 'dinoco_products';
            $modes = array( 'single_box', 'multi_box', 'bulk_pack', 'assembled_set', 'auto', 'unknown' );
            $results = array();
            foreach ( $modes as $mode ) {
                $sku = $wpdb->get_var( $wpdb->prepare( "
                    SELECT sku FROM {$products_tbl}
                    WHERE is_active=1 AND pack_mode = %s
                    LIMIT 1
                ", $mode ) );
                if ( ! $sku ) {
                    $results[] = array( 'mode' => $mode, 'status' => 'skip', 'reason' => 'no SKU with this pack_mode' );
                    continue;
                }
                try {
                    $out = dinoco_resolve_pno_shipping( array( 'sku' => $sku ), 1 );
                    $ok = isset( $out['weight_g'] ) && $out['weight_g'] > 0
                       && isset( $out['length_cm'] ) && $out['length_cm'] > 0
                       && isset( $out['express_category'] ) && in_array( (int) $out['express_category'], array( 1, 4 ), true );
                    $results[] = array(
                        'mode'   => $mode,
                        'sku'    => $sku,
                        'status' => $ok ? 'pass' : 'fail',
                        'output' => $out,
                    );
                } catch ( Exception $e ) {
                    $results[] = array( 'mode' => $mode, 'sku' => $sku, 'status' => 'error', 'error' => $e->getMessage() );
                }
            }
            $passed = count( array_filter( $results, function( $r ) { return $r['status'] === 'pass'; } ) );
            $failed = count( array_filter( $results, function( $r ) { return $r['status'] === 'fail' || $r['status'] === 'error'; } ) );
            return rest_ensure_response( array(
                'ok'      => $failed === 0,
                'passed'  => $passed,
                'failed'  => $failed,
                'skipped' => count( $results ) - $passed - $failed,
                'results' => $results,
            ) );
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // GET /monitor
    register_rest_route( 'dinoco-flash-golive/v1', '/monitor', array(
        'methods'  => 'GET',
        'callback' => function() {
            global $wpdb;
            $flag = (string) get_option( 'dinoco_shipping_meta_enabled', '0' );
            // DLQ stats
            $dlq_tbl = $wpdb->prefix . 'dinoco_flash_dead_letter';
            $dlq_exists = $wpdb->get_var( $wpdb->prepare( 'SHOW TABLES LIKE %s', $wpdb->esc_like( $dlq_tbl ) ) ) === $dlq_tbl;
            $dlq_pending = $dlq_exists ? (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$dlq_tbl} WHERE status='pending'" ) : 0;
            $dlq_resolved = $dlq_exists ? (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$dlq_tbl} WHERE status='resolved'" ) : 0;
            $dlq_recent = $dlq_exists ? $wpdb->get_results( "
                SELECT id, ticket_id, endpoint, last_error_code, retry_count, status, created_at
                FROM {$dlq_tbl}
                ORDER BY created_at DESC LIMIT 10
            ", ARRAY_A ) : array();

            // Audit stats last 24h
            $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
            $audit_exists = $wpdb->get_var( $wpdb->prepare( 'SHOW TABLES LIKE %s', $wpdb->esc_like( $audit_tbl ) ) ) === $audit_tbl;
            $audit_24h = $audit_exists ? (int) $wpdb->get_var( "
                SELECT COUNT(*) FROM {$audit_tbl}
                WHERE created_at >= DATE_SUB(NOW(), INTERVAL 24 HOUR)
            " ) : 0;
            $bumps_24h = $audit_exists ? (int) $wpdb->get_var( "
                SELECT COUNT(*) FROM {$audit_tbl}
                WHERE event_type='bump_detected'
                  AND created_at >= DATE_SUB(NOW(), INTERVAL 24 HOUR)
            " ) : 0;
            $audit_recent = $audit_exists ? $wpdb->get_results( "
                SELECT id, ticket_id, event_type, expected_ec, actual_ec, created_at
                FROM {$audit_tbl}
                ORDER BY created_at DESC LIMIT 10
            ", ARRAY_A ) : array();

            // V.1.2 H-R1: cron heartbeat — read last_run options (wired by Snippet 1 cron agent).
            // Returns seconds since last run; null if never ran (or helper not present).
            $last_verify   = (int) get_option( 'dinoco_cron_flash_category_verify_last_run', 0 );
            $last_rollback = (int) get_option( 'dinoco_cron_shipping_auto_rollback_last_run', 0 );
            $last_dlq      = (int) get_option( 'dinoco_cron_flash_dlq_cleanup_last_run', 0 );
            $now           = time();
            $cron_health   = array(
                'verify_age_sec'   => $last_verify   ? ( $now - $last_verify )   : null,
                'rollback_age_sec' => $last_rollback ? ( $now - $last_rollback ) : null,
                'dlq_age_sec'      => $last_dlq      ? ( $now - $last_dlq )      : null,
                // Expected intervals (sec): verify=15min, rollback=10min, dlq=daily
                'verify_expected_sec'   => 15 * 60,
                'rollback_expected_sec' => 10 * 60,
                'dlq_expected_sec'      => 24 * 60 * 60,
            );

            return rest_ensure_response( array(
                'flag_state'  => $flag === '1' ? 'on' : 'off',
                'dlq_pending' => $dlq_pending,
                'dlq_resolved' => $dlq_resolved,
                'dlq_recent'  => $dlq_recent,
                'audit_24h'   => $audit_24h,
                'bumps_24h'   => $bumps_24h,
                'audit_recent' => $audit_recent,
                'cron_health' => $cron_health,
            ) );
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // POST /flip-flag
    register_rest_route( 'dinoco-flash-golive/v1', '/flip-flag', array(
        'methods'  => 'POST',
        'callback' => function( $req ) {
            global $wpdb;
            $direction = sanitize_text_field( $req->get_param( 'direction' ) );
            if ( ! in_array( $direction, array( 'on', 'off' ), true ) ) {
                return new WP_Error( 'bad_direction', 'direction must be on|off', array( 'status' => 400 ) );
            }
            $reason = sanitize_text_field( $req->get_param( 'reason' ) ?: '' );
            $new_val = $direction === 'on' ? '1' : '0';
            $old_val = (string) get_option( 'dinoco_shipping_meta_enabled', '0' );

            // V.1.2 L12: idempotency — if new value matches current, skip update + audit
            if ( $new_val === $old_val ) {
                return rest_ensure_response( array(
                    'ok'         => true,
                    'direction'  => $direction,
                    'old'        => $old_val,
                    'new'        => $new_val,
                    'no_change'  => true,
                    'flipped_at' => (string) get_option( 'dinoco_shipping_flag_flipped_at', '' ),
                ) );
            }

            // Safety: flip ON requires preflight pass + coverage >= 95%
            if ( $direction === 'on' ) {
                $pre = dinoco_fsv42_preflight_check();
                if ( ! $pre['ready'] ) {
                    return new WP_Error( 'preflight_blocked', 'pre-flight has blockers — fix first', array(
                        'status' => 400,
                        'blockers' => $pre['blockers'],
                    ) );
                }
                $cov = dinoco_fsv42_coverage();
                if ( $cov['pct'] < 95.0 ) {
                    return new WP_Error( 'coverage_low', "coverage {$cov['pct']}% < 95% threshold", array(
                        'status' => 400,
                        'coverage' => $cov,
                    ) );
                }
            }

            update_option( 'dinoco_shipping_meta_enabled', $new_val );
            update_option( 'dinoco_shipping_flag_flipped_at', current_time( 'mysql' ) ); // L12 companion: track last-flipped timestamp

            // Audit
            $audit_tbl = $wpdb->prefix . 'dinoco_flash_audit';
            if ( $wpdb->get_var( $wpdb->prepare( 'SHOW TABLES LIKE %s', $wpdb->esc_like( $audit_tbl ) ) ) === $audit_tbl ) {
                $wpdb->insert( $audit_tbl, array(
                    'ticket_id'    => 0,
                    'event_type'   => 'golive_flip_' . $direction,
                    'payload_json' => wp_json_encode( array(
                        'old'     => $old_val,
                        'new'     => $new_val,
                        'user_id' => get_current_user_id(),
                        'reason'  => $reason,
                        'source'  => 'golive_wizard',
                    ) ),
                    'created_at'   => current_time( 'mysql' ),
                ) );
            }

            return rest_ensure_response( array(
                'ok'          => true,
                'direction'   => $direction,
                'old'         => $old_val,
                'new'         => $new_val,
                'flipped_at'  => current_time( 'mysql' ),
            ) );
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

} );

