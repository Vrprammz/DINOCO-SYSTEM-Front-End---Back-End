if ( ! function_exists( 'dinoco_fsv42_perm' ) ) {
    function dinoco_fsv42_perm( $request ) {
        if ( ! current_user_can( 'manage_options' ) ) {
            return new WP_Error( 'forbidden', 'admin only', array( 'status' => 403 ) );
        }
        // Nonce check for mutating requests
        $method = $request->get_method();
        if ( in_array( $method, array( 'POST', 'PUT', 'DELETE' ), true ) ) {
            $nonce = $request->get_header( 'x_wp_nonce' );
            if ( ! $nonce || ! wp_verify_nonce( $nonce, 'wp_rest' ) ) {
                return new WP_Error( 'bad_nonce', 'invalid nonce', array( 'status' => 403 ) );
            }
            // Rate limit 30/min/user
            $uid = get_current_user_id();
            $tk  = 'fsv42_rl_' . $uid;
            $ct  = (int) get_transient( $tk );
            if ( $ct >= 30 ) {
                return new WP_Error( 'rate_limited', 'too many requests', array( 'status' => 429 ) );
            }
            set_transient( $tk, $ct + 1, 60 );
        }
        return true;
    }
}

