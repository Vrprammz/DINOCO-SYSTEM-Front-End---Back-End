        'methods'  => 'GET',
        'callback' => function() {
            return rest_ensure_response( dinoco_fsv42_coverage() );
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // POST /auto-detect-all
    register_rest_route( 'dinoco-flash-golive/v1', '/auto-detect-all', array(
        'methods'  => 'POST',
        'callback' => function( $req ) {
            global $wpdb;
            if ( ! function_exists( 'dinoco_smart_detect_pack_mode' ) ) {
                return new WP_Error( 'no_helper', 'dinoco_smart_detect_pack_mode missing', array( 'status' => 500 ) );
            }
            $dry_run = (bool) $req->get_param( 'dry_run' );

            // V.1.2 C-Conc-H3: serialize bulk UPDATE across PHP workers via MySQL advisory lock
            $lock_name = 'fsv42_bulk_op';
            $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 2)", $lock_name ) );
            if ( $got_lock !== 1 ) {
                return new WP_Error( 'busy', 'another bulk op in progress — try again in a moment', array( 'status' => 423 ) );
            }
            try {
                $products_tbl = $wpdb->prefix . 'dinoco_products';
                $rows = $wpdb->get_results( "
                    SELECT sku, pack_mode FROM {$products_tbl}
                    WHERE is_active=1 AND (pack_mode IS NULL OR pack_mode = 'auto')
                " );
                $updated = 0;
                $samples = array();
                foreach ( $rows as $r ) {
                    $suggested = dinoco_smart_detect_pack_mode( $r->sku );
                    if ( ! $suggested || $suggested === 'auto' ) continue;
                    if ( count( $samples ) < 20 ) {
                        $samples[] = array( 'sku' => $r->sku, 'was' => $r->pack_mode, 'now' => $suggested );
                    }
                    if ( ! $dry_run ) {
                        $wpdb->update(
                            $products_tbl,
                            array(
                                'pack_mode'           => $suggested,
                                'shipping_updated_by' => get_current_user_id(),
                                'shipping_updated_at' => current_time( 'mysql' ),
                            ),
                            array( 'sku' => $r->sku )
                        );
                    }
                    $updated++;
                }
                // V.1.1 FIX C4: function_exists('Class::method') always returns false
                // (checks free functions, not methods). Use class_exists + method_exists.
                if ( ! $dry_run && class_exists( 'DINOCO_Catalog' ) && method_exists( 'DINOCO_Catalog', 'flush_memo' ) ) {
                    DINOCO_Catalog::flush_memo();
                }
                return rest_ensure_response( array(
                    'ok'          => true,
                    'dry_run'     => $dry_run,
                    'scanned'     => count( $rows ),
                    'updated'     => $updated,
                    'samples'     => $samples,
                ) );
            } finally {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // POST /bulk-assign-defaults
    register_rest_route( 'dinoco-flash-golive/v1', '/bulk-assign-defaults', array(
        'methods'  => 'POST',
        'callback' => function( $req ) {
            global $wpdb;
            $dry_run = (bool) $req->get_param( 'dry_run' );

            // V.1.2 C-Conc-H3: serialize bulk UPDATE across PHP workers via MySQL advisory lock
            $lock_name = 'fsv42_bulk_op';
            $got_lock = (int) $wpdb->get_var( $wpdb->prepare( "SELECT GET_LOCK(%s, 2)", $lock_name ) );
            if ( $got_lock !== 1 ) {
                return new WP_Error( 'busy', 'another bulk op in progress — try again in a moment', array( 'status' => 423 ) );
            }
            try {
                $products_tbl = $wpdb->prefix . 'dinoco_products';
                // Target: SKUs without box_template_id, pack_mode ∈ (single_box/bulk_pack/assembled_set)
                $rows = $wpdb->get_results( "
                    SELECT sku, pack_mode, weight_per_unit_g FROM {$products_tbl}
                    WHERE is_active=1
                      AND box_template_id IS NULL
                      AND pack_mode IN ('single_box', 'bulk_pack', 'assembled_set')
                " );
                $updated = 0;
                $samples = array();
                foreach ( $rows as $r ) {
                    $weight = (int) ( $r->weight_per_unit_g ?: 1000 );
                    $tpl_id = dinoco_fsv42_suggest_template_by_weight( $weight );
                    if ( ! $tpl_id ) continue;
                    if ( count( $samples ) < 20 ) {
                        $samples[] = array( 'sku' => $r->sku, 'pack_mode' => $r->pack_mode, 'weight_g' => $weight, 'tpl_id' => $tpl_id );
                    }
                    if ( ! $dry_run ) {
                        $wpdb->update(
                            $products_tbl,
                            array(
                                'box_template_id'     => $tpl_id,
                                'shipping_updated_by' => get_current_user_id(),
                                'shipping_updated_at' => current_time( 'mysql' ),
                            ),
                            array( 'sku' => $r->sku )
                        );
                    }
                    $updated++;
                }
                if ( ! $dry_run ) {
                    // invalidate caches
                    wp_cache_flush_group( 'dinoco_shipping' );
                    if ( class_exists( 'DINOCO_Catalog' ) && method_exists( 'DINOCO_Catalog', 'flush_memo' ) ) DINOCO_Catalog::flush_memo();
                }
                return rest_ensure_response( array(
                    'ok'      => true,
                    'dry_run' => $dry_run,
                    'scanned' => count( $rows ),
                    'updated' => $updated,
                    'samples' => $samples,
                ) );
            } finally {
                $wpdb->query( $wpdb->prepare( "SELECT RELEASE_LOCK(%s)", $lock_name ) );
            }
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // V.1.3 NEW: GET /multi-box-pending — list multi_box SKUs needing pack_slots
    register_rest_route( 'dinoco-flash-golive/v1', '/multi-box-pending', array(
        'methods'  => 'GET',
        'callback' => function() {
            global $wpdb;
            $products_tbl = $wpdb->prefix . 'dinoco_products';
            $slots_tbl    = $wpdb->prefix . 'dinoco_pack_slots';
            // SKUs with pack_mode=multi_box but no pack_slots rows
            $rows = $wpdb->get_results( "
                SELECT p.sku, p.name, p.boxes_per_unit, p.box_template_id, p.weight_per_unit_g,
                       (SELECT COUNT(*) FROM {$slots_tbl} s WHERE s.product_sku = p.sku) AS slot_count
                FROM {$products_tbl} p
                WHERE p.is_active = 1 AND p.pack_mode = 'multi_box'
                ORDER BY p.sku ASC
            ", ARRAY_A );
            // Only return those with mismatched slot count
            $pending = array();
            foreach ( $rows as $r ) {
                $bpu       = max( 2, intval( $r['boxes_per_unit'] ) );
                $slot_cnt  = intval( $r['slot_count'] );
                if ( $slot_cnt !== $bpu ) {
                    $pending[] = array(
                        'sku'                  => $r['sku'],
                        'name'                 => $r['name'],
                        'bpu'                  => $bpu,
                        'slot_count'           => $slot_cnt,
                        'box_template_id'      => intval( $r['box_template_id'] ) ?: null,
                        'weight_per_unit_g'    => intval( $r['weight_per_unit_g'] ) ?: null,
                    );
                }
            }
            return rest_ensure_response( array( 'ok' => true, 'pending' => $pending, 'total' => count( $pending ) ) );
        },
        'permission_callback' => 'dinoco_fsv42_perm',
    ) );

    // V.1.3 NEW: GET /box-templates-list — for slot template dropdown
    register_rest_route( 'dinoco-flash-golive/v1', '/box-templates-list', array(
        'methods'  => 'GET',
        'callback' => function() {
