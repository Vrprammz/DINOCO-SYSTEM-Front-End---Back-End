    <div class="fsv42-card" id="fsv42-card-smoke">
        <h2>Step 3: Smoke Test <span class="fsv42-badge fsv42-badge-info" id="fsv42-st-badge">ยังไม่รัน</span></h2>
        <p style="color:#64748b;margin:0 0 12px;">รัน resolver test 1 SKU ต่อ pack_mode ดูว่า output ถูกไหม</p>
        <div class="fsv42-actions">
            <button class="fsv42-btn fsv42-btn-primary" onclick="FSV42.runSmoke()">🧪 รัน Smoke Test</button>
        </div>
        <div id="fsv42-st-result" style="margin-top:12px;"></div>
    </div>

    <!-- Step 4: Flip Flag -->
    <div class="fsv42-card" id="fsv42-card-flip">
        <h2>Step 4: Flip Flag <span class="fsv42-flag-state" id="fsv42-flag-current">loading...</span></h2>
        <p style="color:#64748b;margin:0 0 12px;">เปิด/ปิด V.42 — ต้องผ่าน pre-flight + coverage ≥ 95% ก่อนเปิด ON</p>
        <div id="fsv42-flip-ui"></div>
    </div>

    <!-- Step 5: Monitor -->
    <div class="fsv42-card" id="fsv42-card-monitor">
        <h2>Step 5: Monitor <span class="fsv42-badge fsv42-badge-info">live</span></h2>
        <p style="color:#64748b;margin:0 0 12px;">สถานะ V.42 หลังเปิด ON — เช็ค DLQ + Flash bumps + audit trail</p>
        <div class="fsv42-stats-grid" id="fsv42-mon-stats">
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-mon-dlq">–</div><div class="fsv42-stat-lbl">DLQ Pending</div></div>
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-mon-bumps">–</div><div class="fsv42-stat-lbl">Bumps 24h</div></div>
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-mon-audit">–</div><div class="fsv42-stat-lbl">Audit 24h</div></div>
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-mon-resolved">–</div><div class="fsv42-stat-lbl">DLQ Resolved</div></div>
        </div>
        <!-- V.1.2 H-R1: cron heartbeat cards -->
        <div class="fsv42-stats-grid" id="fsv42-mon-cron" style="margin-top:4px;">
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-cron-verify" style="font-size:16px;">–</div><div class="fsv42-stat-lbl">Cron: Category Verify (15m)</div></div>
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-cron-rollback" style="font-size:16px;">–</div><div class="fsv42-stat-lbl">Cron: Auto-Rollback (10m)</div></div>
            <div class="fsv42-stat-box"><div class="fsv42-stat-val" id="fsv42-cron-dlq" style="font-size:16px;">–</div><div class="fsv42-stat-lbl">Cron: DLQ Cleanup (24h)</div></div>
        </div>
        <div class="fsv42-actions">
            <button class="fsv42-btn fsv42-btn-ghost" onclick="FSV42.refreshMonitor()">🔄 Refresh</button>
            <button class="fsv42-btn fsv42-btn-danger" onclick="FSV42.emergencyOff()">🚨 EMERGENCY ROLLBACK</button>
        </div>
        <details style="margin-top:12px;">
            <summary style="cursor:pointer;color:#4f46e5;font-weight:600;">📋 Recent audit events</summary>
            <div id="fsv42-mon-audit-list" style="margin-top:10px;"></div>
        </details>
        <details style="margin-top:8px;">
            <summary style="cursor:pointer;color:#4f46e5;font-weight:600;">⚠️ Recent DLQ entries</summary>
            <div id="fsv42-mon-dlq-list" style="margin-top:10px;"></div>
        </details>
    </div>
</div>

<script>
(function(){
    const esc = s => String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    const nonce = document.querySelector('.fsv42-wrap').dataset.nonce;
    const base = '/wp-json/dinoco-flash-golive/v1';

    // V.1.3 H-2 FIX: in-flight guard prevents duplicate POSTs from double-click.
    // Keyed by path+method so different ops can run in parallel but same op serializes.
    const _inflight = new Set();
    const fmtNum = v => (v === null || v === undefined) ? '—' : String(v);  // M-6
    const fmtVal = v => (v === null || v === undefined || v === '') ? '—' : String(v);  // M-6

    async function api(path, method='GET', body=null) {
        const key = method + ' ' + path;
        if (method !== 'GET' && _inflight.has(key)) {
            throw new Error('already_running');
        }
        _inflight.add(key);
        const opts = { method, headers: { 'X-WP-Nonce': nonce, 'Content-Type': 'application/json' }, credentials: 'same-origin' };
        if (body) opts.body = JSON.stringify(body);
        try {
            const r = await fetch(base + path, opts);
            const txt = await r.text();
            let data; try { data = JSON.parse(txt); } catch(e) { throw new Error('bad json: ' + txt.slice(0, 200)); }
            // V.1.3 R8 FIX: detect expired nonce with infinite-loop guard
            // (if logged-out session, reload → 403 → alert → reload loop).
            // Uses sessionStorage flag to bail out after 1 attempt.
            if (r.status === 403 && data && (data.code === 'rest_cookie_invalid_nonce' || data.code === 'bad_nonce')) {
                const alreadyTried = sessionStorage.getItem('fsv42_reloaded_once') === '1';
                if (alreadyTried) {
                    alert('Session ยังหมดอายุหลัง reload — โปรดล็อกอิน WP Admin ใหม่');
                    throw new Error('session_expired_persistent');
                }
                sessionStorage.setItem('fsv42_reloaded_once', '1');
                alert('Session หมดอายุ — กด OK เพื่อ reload หน้า');
                window.location.reload();
                throw new Error('session_expired');
            }
            if (!r.ok) throw new Error(data.message || data.code || ('HTTP ' + r.status));
            // Clear reload guard on successful call — allows future genuine expiry to re-trigger once
            sessionStorage.removeItem('fsv42_reloaded_once');
            return data;
        } finally {
            _inflight.delete(key);
        }
    }

    // V.1.2 C-JS-1: markStep state machine rewrite — per-step memory prevents
    //   done states from being overwritten when later steps become active.
    const stepState = {}; // { '1': 'done', '2': 'done', '3': 'active', ... }
    function markStep(n, state) {
        stepState[String(n)] = state;
        // implicit: earlier un-set steps become done when a later step goes active
        if (state === 'active') {
            for (let i = 1; i < n; i++) {
                if (stepState[String(i)] !== 'done') stepState[String(i)] = 'done';
            }
        }
        document.querySelectorAll('.fsv42-progress .fsv42-step').forEach(el => {
            const s = String(el.dataset.step);
            el.classList.remove('active', 'done');
            if (stepState[s]) el.classList.add(stepState[s]);
        });
    }

    window.FSV42 = {
        async runPreflight() {
            markStep(1, 'active');
            const ul = document.getElementById('fsv42-pf-list');
            const badge = document.getElementById('fsv42-pf-badge');
            ul.innerHTML = '<li class="info"><div class="fsv42-icon">…</div><div class="fsv42-info"><div class="fsv42-info-label">กำลังตรวจ...</div></div></li>';
            try {
                const r = await api('/preflight');
                ul.innerHTML = '';
                r.checks.forEach(c => {
                    const li = document.createElement('li');
                    li.className = c.pass ? 'ok' : (c.blocker ? 'fail' : 'info');
                    const icon = document.createElement('div'); icon.className = 'fsv42-icon';
                    icon.textContent = c.pass ? '✓' : (c.blocker ? '✗' : 'i');
                    const info = document.createElement('div'); info.className = 'fsv42-info';
                    const lbl = document.createElement('div'); lbl.className = 'fsv42-info-label'; lbl.textContent = c.label;
                    const val = document.createElement('div'); val.className = 'fsv42-info-value'; val.textContent = c.value;
                    info.appendChild(lbl); info.appendChild(val);
                    if (c.note) { const note = document.createElement('div'); note.className = 'fsv42-info-note'; note.textContent = c.note; info.appendChild(note); }
                    li.appendChild(icon); li.appendChild(info);
                    ul.appendChild(li);
                });
                badge.className = 'fsv42-badge ' + (r.ready ? 'fsv42-badge-pass' : 'fsv42-badge-fail');
                badge.textContent = r.ready ? `${r.passing}/${r.total} pass` : `${r.blockers} blocker${r.blockers > 1 ? 's' : ''}`;
                if (r.ready) markStep(1, 'done');
            } catch (e) {
                ul.innerHTML = '';
                const li = document.createElement('li'); li.className = 'fail';
                const icon = document.createElement('div'); icon.className = 'fsv42-icon'; icon.textContent = '!';
                const info = document.createElement('div'); info.className = 'fsv42-info';
                const lbl = document.createElement('div'); lbl.className = 'fsv42-info-label'; lbl.textContent = 'Error';
                const note = document.createElement('div'); note.className = 'fsv42-info-note'; note.textContent = e.message;
                info.appendChild(lbl); info.appendChild(note);
                li.appendChild(icon); li.appendChild(info);
                ul.appendChild(li);
            }
        },

        async refreshCoverage() {
            try {
                const r = await api('/coverage');
                document.getElementById('fsv42-cov-pct').textContent = r.pct + '%';
                document.getElementById('fsv42-cov-ring').style.setProperty('--pct', r.pct + '%');
                document.getElementById('fsv42-cov-complete').textContent = r.complete;
                document.getElementById('fsv42-cov-total').textContent = r.total;
                document.getElementById('fsv42-cov-incomplete').textContent = r.incomplete > 0 ? `ยังต้องกรอกอีก ${r.incomplete} ชิ้น` : '🎉 ครบแล้ว';
                const modes = (r.by_mode || []).map(m => `${m.pack_mode || 'null'}: ${m.n}`).join(' · ');
                document.getElementById('fsv42-cov-bymode').textContent = modes;
                const badge = document.getElementById('fsv42-mg-badge');
                badge.className = 'fsv42-badge ' + (r.pct >= 95 ? 'fsv42-badge-pass' : (r.pct >= 50 ? 'fsv42-badge-warn' : 'fsv42-badge-fail'));
                badge.textContent = r.pct + '% coverage';
                if (r.pct >= 95) markStep(2, 'done');

                const list = document.getElementById('fsv42-mg-incomplete-list');
                list.innerHTML = '';
                if (!r.incomplete_sample || !r.incomplete_sample.length) {
                    list.innerHTML = '<p style="color:#16a34a;">🎉 ครบทุก SKU</p>';
                } else {
                    const tbl = document.createElement('table'); tbl.className = 'fsv42-table';
                    tbl.innerHTML = '<thead><tr><th>SKU</th><th>Name</th><th>pack_mode</th></tr></thead>';
                    const tb = document.createElement('tbody');
                    r.incomplete_sample.forEach(row => {
                        const tr = document.createElement('tr');
                        ['sku', 'name', 'pack_mode'].forEach(k => {
                            const td = document.createElement('td'); td.textContent = row[k] || '-'; tr.appendChild(td);
                        });
                        tb.appendChild(tr);
                    });
                    tbl.appendChild(tb); list.appendChild(tbl);
                }
            } catch (e) { alert('Coverage load failed: ' + e.message); }
        },

        async autoDetect(dry) {
            markStep(2, 'active');
            const result = document.getElementById('fsv42-mg-result');
            result.innerHTML = '<div class="fsv42-alert fsv42-alert-info">⏳ กำลัง ' + (dry ? 'dry-run' : 'apply') + '...</div>';
            try {
                const r = await api('/auto-detect-all', 'POST', { dry_run: dry });
                const msg = dry ?
                    `Dry-run: ${r.updated} / ${r.scanned} SKUs จะถูก update (ยังไม่บันทึก)` :
                    `✅ อัปเดตแล้ว ${r.updated} / ${r.scanned} SKUs`;
                const samples = (r.samples || []).map(s => `${esc(s.sku)}: ${esc(s.was || 'null')} → <strong>${esc(s.now)}</strong>`).join('<br>');
                result.innerHTML = '<div class="fsv42-alert fsv42-alert-success">' + esc(msg) +
                    (samples ? '<div style="margin-top:8px;font-family:ui-monospace,monospace;font-size:12px;">' + samples + '</div>' : '') + '</div>';
                if (!dry) { await FSV42.refreshCoverage(); await FSV42.refreshMultiBox(); }
            } catch (e) {
                result.innerHTML = '<div class="fsv42-alert fsv42-alert-danger">Error: ' + esc(e.message) + '</div>';
            }
        },

        async bulkAssign(dry) {
            markStep(2, 'active');
            const result = document.getElementById('fsv42-mg-result');
            result.innerHTML = '<div class="fsv42-alert fsv42-alert-info">⏳ กำลัง ' + (dry ? 'dry-run' : 'apply') + ' bulk-assign...</div>';
            try {
                const r = await api('/bulk-assign-defaults', 'POST', { dry_run: dry });
                const msg = dry ?
                    `Dry-run: ${r.updated} / ${r.scanned} SKUs จะได้ box template` :
                    `✅ Assign box template แล้ว ${r.updated} / ${r.scanned} SKUs`;
                const samples = (r.samples || []).map(s => `${esc(s.sku)} (${esc(s.pack_mode)}, ${s.weight_g}g) → tpl#${s.tpl_id}`).join('<br>');
                result.innerHTML = '<div class="fsv42-alert fsv42-alert-success">' + esc(msg) +
                    (samples ? '<div style="margin-top:8px;font-family:ui-monospace,monospace;font-size:12px;">' + samples + '</div>' : '') + '</div>';
                if (!dry) { await FSV42.refreshCoverage(); await FSV42.refreshMultiBox(); }
            } catch (e) {
                result.innerHTML = '<div class="fsv42-alert fsv42-alert-danger">Error: ' + esc(e.message) + '</div>';
            }
        },

        // V.1.3 NEW: Multi-box configurator
        _boxTemplates: null,

        async _loadBoxTemplates() {
            if (FSV42._boxTemplates) return FSV42._boxTemplates;
            const r = await api('/box-templates-list');
            FSV42._boxTemplates = r.templates || [];
            return FSV42._boxTemplates;
        },

        async refreshMultiBox() {
            const section = document.getElementById('fsv42-mbox-section');
            const list = document.getElementById('fsv42-mbox-list');
            const counter = document.getElementById('fsv42-mbox-count');
            list.innerHTML = '<p style="color:#78350f;font-size:13px;">⏳ กำลังโหลด...</p>';
            try {
                const [pending, tpls] = await Promise.all([
                    api('/multi-box-pending'),
                    FSV42._loadBoxTemplates(),
                ]);
                if (!pending.pending || !pending.pending.length) {
                    section.style.display = 'none';
                    return;
                }
                section.style.display = 'block';
                counter.textContent = `(${pending.total} SKUs)`;
                list.innerHTML = '';
                pending.pending.forEach(sku => {
                    list.appendChild(FSV42._buildMboxRow(sku, tpls));
                });
            } catch (e) {
                list.innerHTML = `<div class="fsv42-alert fsv42-alert-danger">Error: ${esc(e.message)}</div>`;
            }
        },

        _buildMboxRow(skuData, tpls) {
            const bpu = Math.max(2, skuData.bpu || 2);
            const defaultTplId = skuData.box_template_id || '';
            const defaultWeight = skuData.weight_per_unit_g || '';
            const row = document.createElement('div');
            row.style.cssText = 'background:white;border-radius:8px;padding:12px;margin-bottom:10px;border:1px solid #fcd34d;';
            row.dataset.sku = skuData.sku;

            // Header
            const header = document.createElement('div');
            header.style.cssText = 'display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;';
            const left = document.createElement('div');
            const skuEl = document.createElement('strong'); skuEl.style.fontSize='13px'; skuEl.textContent = skuData.sku;
            const nameEl = document.createElement('div'); nameEl.style.cssText='font-size:11px;color:#64748b;'; nameEl.textContent = skuData.name || '';
            const metaEl = document.createElement('div'); metaEl.style.cssText='font-size:11px;color:#f59e0b;margin-top:2px;';
            metaEl.textContent = `bpu=${bpu} · slots ${skuData.slot_count}/${bpu}`;
            left.appendChild(skuEl); left.appendChild(nameEl); left.appendChild(metaEl);
            header.appendChild(left);

            // Quick-fill button
            const quickBtn = document.createElement('button');
            quickBtn.className = 'fsv42-btn fsv42-btn-ghost';
            quickBtn.style.cssText = 'font-size:11px;padding:6px 10px;';
            quickBtn.textContent = `⚡ Fill ${bpu} slots (same template)`;
            quickBtn.onclick = () => FSV42._quickFillMbox(row, bpu, defaultTplId, defaultWeight);
            header.appendChild(quickBtn);
            row.appendChild(header);

            // Slot rows
            const slotsContainer = document.createElement('div');
            slotsContainer.className = 'fsv42-mbox-slots';
            for (let i = 0; i < bpu; i++) {
                slotsContainer.appendChild(FSV42._buildSlotRow(i, tpls, defaultTplId, defaultWeight));
            }
            row.appendChild(slotsContainer);

            // Save button
            const saveBtn = document.createElement('button');
            saveBtn.className = 'fsv42-btn fsv42-btn-success';
            saveBtn.style.cssText = 'margin-top:10px;width:100%;';
            saveBtn.textContent = '💾 Save slots';
            saveBtn.onclick = () => FSV42._saveMbox(row, saveBtn);
            row.appendChild(saveBtn);

            // Status
            const status = document.createElement('div');
            status.className = 'fsv42-mbox-status';
            status.style.cssText = 'font-size:12px;margin-top:8px;';
            row.appendChild(status);

            return row;
        },

        _buildSlotRow(idx, tpls, defaultTplId, defaultWeight) {
            const slotRow = document.createElement('div');
            slotRow.className = 'fsv42-slot-row';
            slotRow.style.cssText = 'display:grid;grid-template-columns:40px 1fr 100px;gap:8px;align-items:center;margin-bottom:6px;';
            const label = document.createElement('span');
            label.style.cssText = 'font-size:12px;color:#64748b;font-weight:600;';
            label.textContent = `#${idx}`;
            slotRow.appendChild(label);

            const sel = document.createElement('select');
            sel.className = 'fsv42-slot-tpl';
            sel.style.cssText = 'padding:6px 8px;border:1px solid #e2e8f0;border-radius:6px;font-size:12px;';
            const opt0 = document.createElement('option'); opt0.value=''; opt0.textContent='— เลือก template —'; sel.appendChild(opt0);
            tpls.forEach(t => {
                const o = document.createElement('option');
                o.value = t.id;
                o.textContent = `${t.code} — ${t.name} (${t.length_cm}×${t.width_cm}×${t.height_cm}, tare ${t.tare_weight_g}g)`;
                if (String(t.id) === String(defaultTplId)) o.selected = true;
                sel.appendChild(o);
            });
            slotRow.appendChild(sel);

            const wInput = document.createElement('input');
            wInput.type = 'number';
            wInput.className = 'fsv42-slot-weight';
            wInput.placeholder = 'weight (g)';
            wInput.min = '0'; wInput.max = '60000';
            wInput.style.cssText = 'padding:6px 8px;border:1px solid #e2e8f0;border-radius:6px;font-size:12px;';
            if (defaultWeight) wInput.value = defaultWeight;
            slotRow.appendChild(wInput);

            return slotRow;
        },

        _quickFillMbox(row, bpu, tplId, weight) {
            const sels = row.querySelectorAll('.fsv42-slot-tpl');
            const ins = row.querySelectorAll('.fsv42-slot-weight');
            sels.forEach(s => { if (tplId) s.value = String(tplId); });
            ins.forEach(i => { if (weight) i.value = weight; });
        },

        async _saveMbox(row, btn) {
            const sku = row.dataset.sku;
            const status = row.querySelector('.fsv42-mbox-status');
            const slotRows = row.querySelectorAll('.fsv42-slot-row');
            const slots = [];
            for (const sr of slotRows) {
                const tplId = parseInt(sr.querySelector('.fsv42-slot-tpl').value) || 0;
                const weight = parseInt(sr.querySelector('.fsv42-slot-weight').value) || 0;
                if (!tplId) {
                    status.textContent = '⚠️ ทุก slot ต้องเลือก template';
                    status.style.color = '#dc2626';
                    return;
                }
                slots.push({ box_template_id: tplId, content_weight_g: weight });
            }
            btn.disabled = true;
            btn.textContent = '⏳ Saving...';
            status.textContent = '';
            try {
                const r = await api('/save-pack-slots', 'POST', { sku, slots });
                status.textContent = `✅ บันทึกแล้ว ${r.inserted} slots`;
                status.style.color = '#16a34a';
                btn.textContent = '✅ Saved';
                // Remove row after 1s + refresh coverage
                setTimeout(() => {
                    row.style.opacity = '0.5';
                    row.style.transition = 'opacity 0.3s';
                    setTimeout(() => {
                        row.remove();
                        FSV42.refreshCoverage();
                        FSV42.refreshMultiBox();
                    }, 300);
                }, 1000);
            } catch (e) {
                status.textContent = `❌ Error: ${e.message}`;
                status.style.color = '#dc2626';
                btn.disabled = false;
                btn.textContent = '💾 Save slots';
            }
        },

        async runSmoke() {
            markStep(3, 'active');
            const result = document.getElementById('fsv42-st-result');
            const badge = document.getElementById('fsv42-st-badge');
            result.innerHTML = '<div class="fsv42-alert fsv42-alert-info">⏳ กำลังรัน resolver...</div>';
            try {
                const r = await api('/smoke-test', 'POST');
                badge.className = 'fsv42-badge ' + (r.ok ? 'fsv42-badge-pass' : 'fsv42-badge-fail');
                badge.textContent = `${r.passed} pass / ${r.failed} fail / ${r.skipped} skip`;
                const tbl = document.createElement('table'); tbl.className = 'fsv42-table';
                tbl.innerHTML = '<thead><tr><th>pack_mode</th><th>SKU</th><th>Status</th><th>Output</th></tr></thead>';
                const tb = document.createElement('tbody');
                r.results.forEach(x => {
                    const tr = document.createElement('tr');
                    const td1 = document.createElement('td'); td1.textContent = x.mode; tr.appendChild(td1);
                    const td2 = document.createElement('td'); td2.textContent = x.sku || '—'; tr.appendChild(td2);
                    const td3 = document.createElement('td');
                    const span = document.createElement('span');
                    span.className = 'fsv42-badge ' + (x.status === 'pass' ? 'fsv42-badge-pass' : (x.status === 'skip' ? 'fsv42-badge-info' : 'fsv42-badge-fail'));
                    span.textContent = x.status;
                    td3.appendChild(span); tr.appendChild(td3);
                    const td4 = document.createElement('td');
                    td4.style.fontFamily = 'ui-monospace, monospace'; td4.style.fontSize = '11px';
                    // V.1.2 H-J3: disambiguate 0 vs null/undefined — "—" for missing, "0g" for explicit zero
                    const fmtNum = v => (v === null || v === undefined) ? '—' : String(v);
                    td4.textContent = x.output ?
                        `${fmtNum(x.output.weight_g)}g / ${fmtNum(x.output.length_cm)}×${fmtNum(x.output.width_cm)}×${fmtNum(x.output.height_cm)} / ec=${fmtNum(x.output.express_category)}` :
                        (x.error || x.reason || '');
                    tr.appendChild(td4);
                    tb.appendChild(tr);
                });
                tbl.appendChild(tb);
                result.innerHTML = '';
                result.appendChild(tbl);
                if (r.ok) markStep(3, 'done');
            } catch (e) {
                result.innerHTML = '<div class="fsv42-alert fsv42-alert-danger">Error: ' + esc(e.message) + '</div>';
                badge.className = 'fsv42-badge fsv42-badge-fail'; badge.textContent = 'error';
            }
        },

        async refreshFlip() {
            try {
                const r = await api('/monitor');
                const el = document.getElementById('fsv42-flag-current');
                el.className = 'fsv42-flag-state ' + (r.flag_state === 'on' ? 'fsv42-flag-on' : 'fsv42-flag-off');
                el.textContent = r.flag_state === 'on' ? '🟢 ON (V.42 active)' : '⚪ OFF (V.41 legacy)';
                const ui = document.getElementById('fsv42-flip-ui');
                if (r.flag_state === 'on') {
                    ui.innerHTML = '<div class="fsv42-alert fsv42-alert-success">V.42 ทำงานอยู่ — ไปดู Monitor ด้านล่าง</div>' +
                        '<div class="fsv42-actions"><button class="fsv42-btn fsv42-btn-danger" onclick="FSV42.flipOff()">⏪ Flip OFF (rollback)</button></div>';
                    markStep(5, 'active');
                } else {
                    ui.innerHTML = `<div class="fsv42-confirm-box">
                        <h3>⚠️ เปิด V.42 (irreversible without rollback)</h3>
                        <p>ก่อนกดเปิด ตรวจว่า:</p>
                        <ul style="margin:8px 0 12px 20px;color:#7c2d12;">
                            <li>Step 1 Pre-flight ผ่านทั้งหมด (✓ ไม่มี blocker)</li>
                            <li>Step 2 Coverage ≥ 95%</li>
                            <li>Step 3 Smoke test pass</li>
                            <li>บอส approve แล้ว</li>
                        </ul>
                        <p><strong>พิมพ์ "FLIP ON" เพื่อยืนยัน:</strong></p>
                        <input type="text" id="fsv42-flip-confirm" placeholder="FLIP ON" />
                        <p style="font-size:12px;">เหตุผล (optional):</p>
                        <input type="text" id="fsv42-flip-reason" placeholder="เช่น ลงมือ migrate ครบแล้ว" />
                        <div class="fsv42-actions" style="margin-top:10px;">
                            <button class="fsv42-btn fsv42-btn-success" onclick="FSV42.flipOn()">🚀 FLIP ON</button>
                        </div>
                    </div>`;
                }
            } catch (e) { console.error(e); }
        },

        async flipOn() {
            // V.1.2 H-J2: normalize input — remove NBSP (U+00A0) + trim + case-insensitive compare
            const raw = document.getElementById('fsv42-flip-confirm').value;
            const normalized = raw.replace(/\u00A0/g, ' ').trim().toUpperCase();
            const reason = document.getElementById('fsv42-flip-reason').value.trim();
            if (normalized !== 'FLIP ON') {
                alert('พิมพ์ "FLIP ON" ให้ถูก (ตัวพิมพ์ใหญ่หรือเล็กก็ได้)');
                return;
            }
            try {
                const r = await api('/flip-flag', 'POST', { direction: 'on', reason });
                alert('✅ Flag flipped ON: ' + r.flipped_at);
                await FSV42.refreshFlip();
                await FSV42.refreshMonitor();
                markStep(4, 'done');
            } catch (e) {
                alert('❌ Flip failed: ' + e.message);
            }
        },

        async flipOff() {
            if (!confirm('Rollback V.42 → V.41 legacy?')) return;
            const reason = prompt('เหตุผล (optional):') || 'admin manual rollback';
            try {
                const r = await api('/flip-flag', 'POST', { direction: 'off', reason });
                alert('⏪ Flag flipped OFF: ' + r.flipped_at);
                await FSV42.refreshFlip();
                // V.1.2 C-JS-1 companion: after flipOff, step 4 is the current step again (not "done")
                markStep(4, 'active');
            } catch (e) {
                alert('❌ Rollback failed: ' + e.message);
            }
        },

        async emergencyOff() {
            if (!confirm('🚨 EMERGENCY ROLLBACK — หยุด V.42 ทันที?\nกด OK = ปิด flag + log audit')) return;
            try {
                const r = await api('/flip-flag', 'POST', { direction: 'off', reason: 'EMERGENCY_ROLLBACK_FROM_MONITOR' });
                alert('🚨 Rolled back: ' + r.flipped_at);
                await FSV42.refreshFlip();
                await FSV42.refreshMonitor();
            } catch (e) { alert('Failed: ' + e.message); }
        },

        async refreshMonitor() {
            try {
                const r = await api('/monitor');
                document.getElementById('fsv42-mon-dlq').textContent = r.dlq_pending;
                document.getElementById('fsv42-mon-bumps').textContent = r.bumps_24h;
                document.getElementById('fsv42-mon-audit').textContent = r.audit_24h;
                document.getElementById('fsv42-mon-resolved').textContent = r.dlq_resolved;

                // V.1.2 H-R1: cron heartbeat — red if age > expected × 2, amber if > expected, else green
                const renderCron = (elId, ageSec, expectedSec) => {
                    const el = document.getElementById(elId);
                    if (!el) return;
                    if (ageSec === null || ageSec === undefined) {
                        el.textContent = 'never';
                        el.style.color = '#64748b';
                        return;
                    }
                    const mins = Math.round(ageSec / 60);
                    const human = mins < 60 ? `${mins}m ago` : `${Math.round(mins / 60)}h ago`;
                    el.textContent = human;
                    if (expectedSec && ageSec > expectedSec * 2)       el.style.color = '#dc2626'; // red
                    else if (expectedSec && ageSec > expectedSec)      el.style.color = '#f59e0b'; // amber
                    else                                               el.style.color = '#16a34a'; // green
                };
                const ch = r.cron_health || {};
                renderCron('fsv42-cron-verify',   ch.verify_age_sec,   ch.verify_expected_sec);
                renderCron('fsv42-cron-rollback', ch.rollback_age_sec, ch.rollback_expected_sec);
                renderCron('fsv42-cron-dlq',      ch.dlq_age_sec,      ch.dlq_expected_sec);

                const auditList = document.getElementById('fsv42-mon-audit-list');
                auditList.innerHTML = '';
                if (!r.audit_recent || !r.audit_recent.length) { auditList.innerHTML = '<p style="color:#64748b;">ไม่มี audit events</p>'; }
                else {
                    const tbl = document.createElement('table'); tbl.className = 'fsv42-table';
                    tbl.innerHTML = '<thead><tr><th>Time</th><th>Event</th><th>Ticket</th><th>EC exp→act</th></tr></thead>';
                    const tb = document.createElement('tbody');
                    r.audit_recent.forEach(x => {
                        const tr = document.createElement('tr');
                        // M-6 FIX: fmtVal returns '—' for null/undefined/'' instead of "undefined" string
                        [fmtVal(x.created_at), fmtVal(x.event_type), fmtVal(x.ticket_id), (x.expected_ec && x.actual_ec ? `${x.expected_ec}→${x.actual_ec}` : '—')].forEach(v => {
                            const td = document.createElement('td'); td.textContent = v; tr.appendChild(td);
                        });
                        tb.appendChild(tr);
                    });
                    tbl.appendChild(tb); auditList.appendChild(tbl);
                }

                const dlqList = document.getElementById('fsv42-mon-dlq-list');
                dlqList.innerHTML = '';
                if (!r.dlq_recent || !r.dlq_recent.length) { dlqList.innerHTML = '<p style="color:#16a34a;">✅ DLQ ว่าง</p>'; }
                else {
                    const tbl = document.createElement('table'); tbl.className = 'fsv42-table';
                    tbl.innerHTML = '<thead><tr><th>Time</th><th>Ticket</th><th>Endpoint</th><th>Error</th><th>Retry</th><th>Status</th></tr></thead>';
                    const tb = document.createElement('tbody');
                    r.dlq_recent.forEach(x => {
                        const tr = document.createElement('tr');
                        // M-6 FIX: fmtVal for null/undefined safety
                        [fmtVal(x.created_at), fmtVal(x.ticket_id), fmtVal(x.endpoint), fmtVal(x.last_error_code), fmtVal(x.retry_count), fmtVal(x.status)].forEach(v => {
                            const td = document.createElement('td'); td.textContent = v; tr.appendChild(td);
                        });
                        tb.appendChild(tr);
                    });
                    tbl.appendChild(tb); dlqList.appendChild(tbl);
                }
            } catch (e) { console.error(e); }
        },
    };

    // Auto-load on mount
    document.addEventListener('DOMContentLoaded', async () => {
        await FSV42.runPreflight();
        await FSV42.refreshCoverage();
        await FSV42.refreshFlip();
        await FSV42.refreshMonitor();
        await FSV42.refreshMultiBox(); // V.1.3
    });
})();
</script>
