if ( ! function_exists( 'dinoco_fsv42_preflight_check' ) ) {
    function dinoco_fsv42_preflight_check() {
        global $wpdb;
        $checks = array();

        // 1. MySQL version >= 8.0.16 OR MariaDB >= 10.3
        $version = (string) $wpdb->get_var( 'SELECT VERSION()' );
        $is_mariadb = ( stripos( $version, 'mariadb' ) !== false );
        $numeric = preg_replace( '/[^0-9.]/', '', strtok( $version, '-' ) );
        if ( $is_mariadb ) {
            $pass_version = version_compare( $numeric, '10.3.0', '>=' );
        } else {
            $pass_version = version_compare( $numeric, '8.0.16', '>=' );
        }
        $checks[] = array(
            'id'      => 'mysql_version',
            'label'   => 'MySQL/MariaDB version',
            'pass'    => $pass_version,
            'value'   => $version,
            'note'    => $pass_version ? 'CHECK constraints รองรับ' : 'PHP validator เป็น primary defense (ok)',
            'blocker' => false, // not a blocker, just warning
        );

        // 2. Schema tables exist
        $required_tables = array(
            'dinoco_box_templates'        => 'Box Templates',
            'dinoco_pack_slots'           => 'Pack Slots',
            'dinoco_warehouse_mapping'    => 'Warehouse Mapping',
            'dinoco_flash_audit'          => 'Flash Audit',
            'dinoco_flash_dead_letter'    => 'Flash DLQ',
        );
        foreach ( $required_tables as $tbl_suffix => $label ) {
            $tbl   = $wpdb->prefix . $tbl_suffix;
            $exist = $wpdb->get_var( $wpdb->prepare( 'SHOW TABLES LIKE %s', $wpdb->esc_like( $tbl ) ) ) === $tbl;
            $checks[] = array(
                'id'      => 'table_' . $tbl_suffix,
                'label'   => "Table: {$label}",
                'pass'    => $exist,
                'value'   => $exist ? 'exists' : 'missing',
                'note'    => $exist ? '' : 'Schema activation needed — hit any /dinoco-stock/v1 endpoint',
                'blocker' => true,
            );
        }

        // 3. Box templates seeded
        $tpl_count = $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}dinoco_box_templates WHERE is_active=1" );
        $checks[] = array(
            'id'      => 'box_templates_seed',
            'label'   => 'Box Templates seeded',
            'pass'    => (int) $tpl_count >= 5,
            'value'   => "{$tpl_count} active templates",
            'note'    => $tpl_count >= 5 ? 'S/M/L/XL/AL37 พร้อม' : 'รอ seed (ต้อง >= 5)',
            'blocker' => true,
        );

        // 4. Warehouse mapping seeded
        $wh_count = $wpdb->get_var( "SELECT COUNT(*) FROM {$wpdb->prefix}dinoco_warehouse_mapping" );
        $checks[] = array(
            'id'      => 'warehouse_mapping',
            'label'   => 'Warehouse mapping (F4)',
            'pass'    => (int) $wh_count >= 2,
            'value'   => "{$wh_count} mappings",
            'note'    => $wh_count >= 2 ? 'bike + truck mappings พร้อม' : 'ขาด mapping BKN_SP/5BKN_PDC',
            'blocker' => true,
        );

        // 5. Shipping defaults option
        $defaults = get_option( 'dinoco_shipping_defaults', array() );
        $has_defaults = is_array( $defaults ) && ! empty( $defaults['weight_grams'] );
        $checks[] = array(
            'id'      => 'shipping_defaults',
            'label'   => 'Global shipping defaults',
            'pass'    => $has_defaults,
            'value'   => $has_defaults ? 'configured' : 'not set',
            'note'    => $has_defaults ? "default weight = {$defaults['weight_grams']}g" : 'ตั้ง defaults ก่อน (weight/L/W/H/threshold)',
            'blocker' => true,
        );

        // 6. Helper functions loaded (Snippet 15 active)
        $helper_ok = function_exists( 'dinoco_resolve_pno_shipping' )
            && function_exists( 'dinoco_smart_detect_pack_mode' )
            && function_exists( 'dinoco_snapshot_ticket_shipping' );
        $checks[] = array(
            'id'      => 'helpers_loaded',
            'label'   => 'Core helpers (Snippet 15 V.8.0+)',
            'pass'    => $helper_ok,
            'value'   => $helper_ok ? 'loaded' : 'missing',
            'note'    => $helper_ok ? '' : 'Snippet 15 ยังไม่ sync — ตรวจ GitHub sync dashboard',
            'blocker' => true,
        );

        // 7. Dispatcher (Snippet 1 V.34.2+)
        $dispatcher_ok = function_exists( 'b2b_flash_dispatch_create_all' )
            && function_exists( 'b2b_flash_create_all_boxes_v42' );
        $checks[] = array(
            'id'      => 'dispatcher_loaded',
            'label'   => 'Flash V.42 dispatcher (Snippet 1 V.34.2+)',
            'pass'    => $dispatcher_ok,
            'value'   => $dispatcher_ok ? 'loaded' : 'missing',
            'note'    => $dispatcher_ok ? '' : 'Snippet 1 V.34.2 ยังไม่ sync',
            'blocker' => true,
        );

        // 8. Current flag state (info only)
        $flag = (string) get_option( 'dinoco_shipping_meta_enabled', '0' );
        $checks[] = array(
            'id'      => 'flag_state',
            'label'   => 'Current flag state',
            'pass'    => true, // info only
            'value'   => $flag === '1' ? '🟢 ON (V.42 active)' : '⚪ OFF (V.41 legacy)',
            'note'    => '',
            'blocker' => false,
        );

        $total    = count( $checks );
        $passing  = count( array_filter( $checks, function( $c ) { return $c['pass']; } ) );
        $blockers = count( array_filter( $checks, function( $c ) { return ! $c['pass'] && $c['blocker']; } ) );
        $ready    = ( $blockers === 0 );

        return array(
            'checks'   => $checks,
            'total'    => $total,
            'passing'  => $passing,
            'blockers' => $blockers,
            'ready'    => $ready,
        );
    }
}

// ==================================================================
// Helper: coverage calculator
// ==================================================================
if ( ! function_exists( 'dinoco_fsv42_coverage' ) ) {
    function dinoco_fsv42_coverage() {
        global $wpdb;
        $products_tbl = $wpdb->prefix . 'dinoco_products';

        // Total active SKUs
        $total = (int) $wpdb->get_var( "SELECT COUNT(*) FROM {$products_tbl} WHERE is_active=1" );

        // V.1.2 H-D1: Complete must have concrete data per pack_mode
        //   - single_box / bulk_pack / assembled_set → must have box_template_id
        //   - multi_box → must have at least 1 pack_slots row (NOT default fallback)
        //   - unknown → must have weight_grams > 0
        //   - any mode → plain dims (L/W/H + weight) also counts as complete
        $complete = (int) $wpdb->get_var( "
            SELECT COUNT(*) FROM {$products_tbl} p
            WHERE p.is_active=1 AND (
                (p.pack_mode IN ('single_box','bulk_pack','assembled_set') AND p.box_template_id IS NOT NULL)
                OR (p.pack_mode = 'multi_box' AND EXISTS (SELECT 1 FROM {$wpdb->prefix}dinoco_pack_slots s WHERE s.product_sku = p.sku))
                OR (p.pack_mode = 'unknown' AND p.weight_grams > 0)
                OR (p.weight_grams > 0 AND p.length_cm > 0 AND p.width_cm > 0 AND p.height_cm > 0)
            )
        " );

        $pct = $total > 0 ? round( ( $complete / $total ) * 100, 1 ) : 0;

        // Breakdown by pack_mode
        $by_mode = $wpdb->get_results( "
            SELECT pack_mode, COUNT(*) as n
            FROM {$products_tbl}
            WHERE is_active=1
            GROUP BY pack_mode
        ", ARRAY_A );

        // Sample of incomplete (for fix list)
        $incomplete = $wpdb->get_results( "
            SELECT sku, name, pack_mode, box_template_id, weight_grams
            FROM {$products_tbl}
            WHERE is_active=1
              AND (pack_mode IS NULL OR pack_mode = 'auto')
              AND box_template_id IS NULL
              AND (weight_grams IS NULL OR weight_grams = 0)
            ORDER BY sku ASC
            LIMIT 50
        ", ARRAY_A );

        return array(
            'total'      => $total,
            'complete'   => $complete,
            'incomplete' => max( 0, $total - $complete ),
            'pct'        => $pct,
            'by_mode'    => $by_mode,
            'incomplete_sample' => $incomplete,
        );
    }
}

// ==================================================================
// Helper: default box template by weight heuristic
// ==================================================================
if ( ! function_exists( 'dinoco_fsv42_suggest_template_by_weight' ) ) {
    function dinoco_fsv42_suggest_template_by_weight( $weight_g ) {
        global $wpdb;
        $weight_g = (int) $weight_g;
        if ( $weight_g <= 0 ) $weight_g = 1000;
        // Find smallest active template where max_weight_g >= weight_g
        $tpl = $wpdb->get_row( $wpdb->prepare( "
            SELECT id, code, max_weight_g FROM {$wpdb->prefix}dinoco_box_templates
            WHERE is_active=1 AND max_weight_g >= %d
            ORDER BY max_weight_g ASC LIMIT 1
        ", $weight_g ) );
        return $tpl ? (int) $tpl->id : null;
    }
}

