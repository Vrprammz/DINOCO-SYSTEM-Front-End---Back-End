add_action('init', function() {
    if ($_SERVER['REQUEST_METHOD'] !== 'POST' || empty($_POST['dinoco_bv_action'])) return;

    $action = sanitize_text_field($_POST['dinoco_bv_action']);

    // (a) save_entry
    if ($action === 'save_entry') {
        if (ob_get_length()) ob_clean();
        header('Content-Type: application/json; charset=utf-8');
        if (!current_user_can('manage_options')) { echo json_encode(['success'=>false,'error'=>'ACCESS DENIED']); exit; }

        $brands     = isset($_POST['brands']) ? array_map('sanitize_text_field', (array)$_POST['brands']) : [];
        $categories = isset($_POST['categories']) ? array_map('sanitize_text_field', (array)$_POST['categories']) : [];
        $models     = isset($_POST['models']) ? array_map('sanitize_text_field', (array)$_POST['models']) : [];

        $data = [
            'brands'           => $brands,
            'brand_other'      => sanitize_text_field($_POST['brand_other'] ?? ''),
            'content'          => sanitize_textarea_field($_POST['content'] ?? ''),
            'summary'          => sanitize_text_field($_POST['summary'] ?? ''),
            'sentiment'        => sanitize_text_field($_POST['sentiment'] ?? 'neutral'),
            'intensity'        => intval($_POST['intensity'] ?? 3),
            'categories'       => $categories,
            'platform'         => sanitize_text_field($_POST['platform'] ?? ''),
            'source_url'       => esc_url_raw($_POST['source_url'] ?? ''),
            'source_name'      => sanitize_text_field($_POST['source_name'] ?? ''),
            'post_date'        => sanitize_text_field($_POST['post_date'] ?? date('Y-m-d')),
            'product'          => sanitize_text_field($_POST['product'] ?? ''),
            'models'           => $models,
            'author_name'      => sanitize_text_field($_POST['author_name'] ?? ''),
            'is_customer'      => !empty($_POST['is_customer']) ? '1' : '0',
            'has_photo'        => !empty($_POST['has_photo']) ? '1' : '0',
            'engagement'       => sanitize_text_field($_POST['engagement'] ?? 'low'),
            'is_lead'          => !empty($_POST['is_lead']) ? '1' : '0',
            'is_complaint'     => !empty($_POST['is_complaint']) ? '1' : '0',
            'complaint_status' => sanitize_text_field($_POST['complaint_status'] ?? ''),
            'is_influencer'    => !empty($_POST['is_influencer']) ? '1' : '0',
            'dinoco_responded' => !empty($_POST['dinoco_responded']) ? '1' : '0',
            'response_text'    => sanitize_textarea_field($_POST['response_text'] ?? ''),
            'tags'             => sanitize_text_field($_POST['tags'] ?? ''),
            'admin_notes'      => sanitize_textarea_field($_POST['admin_notes'] ?? ''),
        ];

        $post_id = bv_create_entry($data);
        echo json_encode(['success' => (bool)$post_id, 'id' => $post_id]);
        exit;
    }

    // (b) get_entries
    if ($action === 'get_entries') {
        if (ob_get_length()) ob_clean();
        header('Content-Type: application/json; charset=utf-8');
        if (!current_user_can('manage_options')) { echo json_encode(['success'=>false]); exit; }

        $result = bv_get_entries([
            'brand'     => sanitize_text_field($_POST['brand'] ?? ''),
            'sentiment' => sanitize_text_field($_POST['sentiment'] ?? ''),
            'platform'  => sanitize_text_field($_POST['platform'] ?? ''),
            'search'    => sanitize_text_field($_POST['search'] ?? ''),
            'limit'     => intval($_POST['limit'] ?? 50),
        ]);
        echo json_encode(['success' => true, 'data' => $result]);
        exit;
    }

    // (c) get_stats
    if ($action === 'get_stats') {
        if (ob_get_length()) ob_clean();
        header('Content-Type: application/json; charset=utf-8');
        if (!current_user_can('manage_options')) { echo json_encode(['success'=>false]); exit; }

        echo json_encode(['success' => true, 'data' => bv_get_stats()]);
        exit;
    }

    // (d) delete_entry
    if ($action === 'delete_entry') {
        if (ob_get_length()) ob_clean();
        header('Content-Type: application/json; charset=utf-8');
        if (!current_user_can('manage_options')) { echo json_encode(['success'=>false]); exit; }

        $post_id = intval($_POST['id'] ?? 0);
        if ($post_id) wp_delete_post($post_id, true);
        echo json_encode(['success' => true]);
        exit;
    }

}, 20);

