                'name'       => $name,
                'created'    => date('Y-m-d H:i:s'),
                'last_used'  => null,
            ];
            update_option('bv_api_keys', $stored);
            return new WP_REST_Response([
                'success' => true,
                'api_key' => $raw_key,
                'message' => 'เก็บ key นี้ไว้ — จะแสดงครั้งเดียว',
            ], 201);
        },
    ]);

    // DELETE /wp-json/brand-voice/v1/api-keys/revoke — Admin ลบ API key
    register_rest_route('brand-voice/v1', '/api-keys/revoke', [
        'methods'  => 'POST',
        'permission_callback' => function() { return current_user_can('manage_options'); },
        'callback' => function(WP_REST_Request $req) {
            $index = intval($req->get_param('index'));
            $stored = get_option('bv_api_keys', []);
            if (!is_array($stored) || !isset($stored[$index])) {
                return new WP_Error('not_found', 'Key not found', ['status' => 404]);
            }
            $name = $stored[$index]['name'] ?? 'Unknown';
            array_splice($stored, $index, 1);
            update_option('bv_api_keys', $stored);
            return new WP_REST_Response(['success' => true, 'message' => 'Revoked: ' . $name], 200);
        },
    ]);

