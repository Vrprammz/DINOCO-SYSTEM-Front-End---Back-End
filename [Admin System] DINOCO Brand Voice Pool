<script>
(function($){
    var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
    var ajaxUrl = '<?php echo esc_url(admin_url('admin-post.php')); ?>';
    var PLATFORMS = <?php echo json_encode($platforms); ?>;
    var CATEGORIES = <?php echo json_encode($categories); ?>;

    window.BV = {};

    // ── Sources (กลุ่มที่ติดตาม) ──
    BV.loadSources = function() {
        $.post(ajaxUrl, { action:'admin_post_nopriv', dinoco_bv_action:'get_sources' }, function(r) {
            if (typeof r === 'string') try { r = JSON.parse(r); } catch(e) { return; }
            var src = (r.sources || '').trim();
            if (src) {
                var lines = src.split('\n').filter(function(l){return l.trim();});
                var html = lines.map(function(l) {
                    var icon = 'fa-globe';
                    if (l.toLowerCase().indexOf('facebook') !== -1) icon = 'fa-brands fa-facebook';
                    else if (l.toLowerCase().indexOf('youtube') !== -1) icon = 'fa-brands fa-youtube';
                    else if (l.toLowerCase().indexOf('tiktok') !== -1) icon = 'fa-brands fa-tiktok';
                    return '<span style="display:inline-block;padding:3px 8px;background:#fff;border:1px solid var(--bv-border);border-radius:5px;margin:2px;font-size:11px;"><i class="' + icon + '" style="margin-right:3px;opacity:0.6;"></i>' + $('<span>').text(l.trim()).html() + '</span>';
                }).join('');
                $('#bv-sources-display').html(html);
                $('#bv-sources-input').val(src);
            } else {
                $('#bv-sources-display').html('<span style="color:#94a3b8;font-size:11px;">ยังไม่ได้ระบุ — กด "แก้ไข" เพื่อเพิ่มกลุ่ม Facebook/YouTube/TikTok ที่ต้องการติดตาม</span>');
            }
            // แสดงข้อมูล last collect
            if (r.last_collect) {
                var ago = Math.round((Date.now()/1000 - r.last_collect) / 3600);
                $('#bv-ai-status').html('<span style="color:#94a3b8;font-size:10px;">รวบรวมล่าสุด: ' + (ago < 1 ? 'เมื่อกี้' : ago + ' ชม. ก่อน') + '</span>');
            }
        });
    };

    BV.toggleSources = function() {
        var $edit = $('#bv-sources-edit');
        var $display = $('#bv-sources-display');
        if ($edit.is(':visible')) {
            $edit.hide(); $display.show();
        } else {
            $edit.show(); $display.hide(); $('#bv-sources-input').focus();
        }
    };

    BV.saveSources = function() {
        var val = $('#bv-sources-input').val();
        $.post(ajaxUrl, { action:'admin_post_nopriv', dinoco_bv_action:'save_sources', sources: val }, function(r) {
            if (typeof r === 'string') try { r = JSON.parse(r); } catch(e) {}
            BV.toggleSources();
            BV.loadSources();
        });
    };

    // ── Tab switch ──
    BV.switchTab = function(tab) {
        $('.dnc-bv .bv-tab-btn').removeClass('active');
        $('.dnc-bv .bv-tab-btn[data-tab="'+tab+'"]').addClass('active');
        $('.dnc-bv .bv-tab-pane').removeClass('active');
        $('#bv-pane-'+tab).addClass('active');

        if (tab === 'list') BV.loadList();
        if (tab === 'stats') BV.loadStats();
    };

    // ── Chip toggle ──
    BV.toggleChip = function(el) {
        var $el = $(el);
        var $cb = $el.find('input[type="checkbox"]');
        $cb.prop('checked', !$cb.prop('checked'));
        $el.toggleClass('selected', $cb.prop('checked'));
    };

    // ── Sentiment ──
    BV.currentSentiment = 'neutral';
    BV.setSentiment = function(el) {
        var $el = $(el);
        $('#bv-sentiment-group .bv-sent-btn').removeClass('active');
        $el.addClass('active');
        BV.currentSentiment = $el.data('val');
    };

    // ── Platform auto-detect ──
    $(document).on('input', '#bv-source-url', function() {
        var url = this.value;
        if (url.includes('facebook.com')) $('#bv-platform').val('facebook_group');
        else if (url.includes('youtube.com') || url.includes('youtu.be')) $('#bv-platform').val('youtube');
        else if (url.includes('tiktok.com')) $('#bv-platform').val('tiktok');
        else if (url.includes('pantip.com')) $('#bv-platform').val('pantip');
        else if (url.includes('instagram.com')) $('#bv-platform').val('instagram');
    });

    // ── Collect form data ──
    function collectFormData() {
        var brands = [];
        $('#bv-brands-group input:checked').each(function(){ brands.push($(this).val()); });
        var categories = [];
        $('#bv-cats-group input:checked').each(function(){ categories.push($(this).val()); });
        var models = [];
        $('#bv-models-group input:checked').each(function(){ models.push($(this).val()); });

        return {
            dinoco_bv_action: 'save_entry',
            content:          $('#bv-content').val(),
            summary:          $('#bv-summary').val(),
            source_url:       $('#bv-source-url').val(),
            source_name:      $('#bv-source-name').val(),
            author_name:      $('#bv-author-name').val(),
            post_date:        $('#bv-post-date').val(),
            product:          $('#bv-product').val(),
            brands:           brands,
            brand_other:      $('#bv-brand-other').val(),
            sentiment:        BV.currentSentiment,
            intensity:        $('#bv-intensity').val(),
            categories:       categories,
            platform:         $('#bv-platform').val(),
            models:           models,
            engagement:       $('#bv-engagement').val(),
            is_customer:      $('#bv-is-customer').is(':checked') ? '1' : '',
            has_photo:        $('#bv-has-photo').is(':checked') ? '1' : '',
            is_lead:          $('#bv-is-lead').is(':checked') ? '1' : '',
            is_complaint:     $('#bv-is-complaint').is(':checked') ? '1' : '',
            is_influencer:    $('#bv-is-influencer').is(':checked') ? '1' : '',
            dinoco_responded: $('#bv-dinoco-responded').is(':checked') ? '1' : '',
            tags:             $('#bv-tags').val(),
            admin_notes:      $('#bv-admin-notes').val()
        };
    }

    // ── Reset form ──
    function resetForm() {
        var batch = $('#bv-batch-mode').is(':checked');
        var keepBrands   = batch ? $('#bv-brands-group input:checked').map(function(){ return $(this).val(); }).get() : [];
        var keepModels   = batch ? $('#bv-models-group input:checked').map(function(){ return $(this).val(); }).get() : [];
        var keepPlatform = batch ? $('#bv-platform').val() : '';

        // Clear all
        $('#bv-content, #bv-summary, #bv-source-url, #bv-source-name, #bv-author-name, #bv-product, #bv-brand-other, #bv-tags').val('');
        $('#bv-admin-notes').val('');
        $('#bv-post-date').val(new Date().toISOString().slice(0,10));
        $('#bv-intensity').val(3); $('#bv-intensity-val').text('3');
        $('#bv-engagement').val('low');
        BV.currentSentiment = 'neutral';
        $('#bv-sentiment-group .bv-sent-btn').removeClass('active');
        $('#bv-sentiment-group .bv-sent-btn.s-neutral').addClass('active');

        // Uncheck all chips
        $('.dnc-bv .bv-chip').removeClass('selected').find('input').prop('checked', false);
        // Uncheck flags
        $('#bv-is-customer, #bv-has-photo, #bv-is-lead, #bv-is-complaint, #bv-is-influencer, #bv-dinoco-responded').prop('checked', false);

        // Restore batch values
        if (batch) {
            keepBrands.forEach(function(v) {
                var $cb = $('#bv-brands-group input[value="'+v+'"]');
                $cb.prop('checked', true).closest('.bv-chip').addClass('selected');
            });
            keepModels.forEach(function(v) {
                var $cb = $('#bv-models-group input[value="'+v+'"]');
                $cb.prop('checked', true).closest('.bv-chip').addClass('selected');
            });
            $('#bv-platform').val(keepPlatform);
        } else {
            $('#bv-platform').val('');
        }

        $('#bv-content').focus();
    }

    // ── Save ──
    BV.save = function(mode) {
        var data = collectFormData();
        if (!data.content && !data.summary) {
            if (window.Swal) Swal.fire('กรุณากรอกข้อมูล', 'ต้องมีข้อความหรือสรุปอย่างน้อย 1 อย่าง', 'warning');
            return;
        }

        $.post(ajaxUrl, data, function(res) {
            if (res && res.success) {
                if (window.showToast) window.showToast('success', 'บันทึกแล้ว', 'Brand Voice #' + res.id);
                if (mode === 'continue') {
                    resetForm();
                } else {
                    resetForm();
                    BV.switchTab('list');
                }
            } else {
                if (window.Swal) Swal.fire('Error', res.error || 'บันทึกไม่สำเร็จ', 'error');
            }
        }, 'json').fail(function() {
            if (window.Swal) Swal.fire('Error', 'เกิดข้อผิดพลาด', 'error');
        });
    };

    // ── Keyboard shortcuts ──
    $(document).on('keydown', function(e) {
        // Ctrl+Enter = save & continue
        if (e.ctrlKey && e.key === 'Enter' && $('.dnc-bv .bv-tab-pane#bv-pane-entry').hasClass('active')) {
            e.preventDefault(); BV.save('continue');
        }
        // Ctrl+S = save & close
        if (e.ctrlKey && e.key === 's' && $('.dnc-bv .bv-tab-pane#bv-pane-entry').hasClass('active')) {
            e.preventDefault(); BV.save('close');
        }
    });

    // ── Load List ──
    BV.loadList = function() {
        $('#bv-list-container').html('<div class="bv-loading"><i class="fa-solid fa-spinner fa-spin"></i> กำลังโหลด...</div>');

        $.post(ajaxUrl, {
            dinoco_bv_action: 'get_entries',
            brand:     $('#bv-f-brand').val(),
            sentiment: $('#bv-f-sentiment').val(),
            platform:  $('#bv-f-platform').val(),
            search:    $('#bv-f-search').val(),
            limit: 50
        }, function(res) {
            if (!res || !res.success) { $('#bv-list-container').html('<div class="bv-no-data">โหลดข้อมูลไม่สำเร็จ</div>'); return; }

            var entries = res.data.entries;
            if (!entries.length) { $('#bv-list-container').html('<div class="bv-no-data"><i class="fa-solid fa-inbox" style="font-size:32px;display:block;margin-bottom:12px;"></i>ยังไม่มีข้อมูล</div>'); return; }

            var sentMap = { positive: 'เชิงบวก', negative: 'เชิงลบ', neutral: 'กลาง', mixed: 'ปนกัน' };
            var sentIcon = { positive: 'fa-face-smile', negative: 'fa-face-frown', neutral: 'fa-face-meh', mixed: 'fa-face-meh-blank' };

            var html = '<table class="bv-table"><thead><tr>';
            html += '<th>วันที่</th><th>แบรนด์</th><th>สรุป</th><th>ความรู้สึก</th><th>แหล่งที่มา</th>';
            html += '</tr></thead><tbody>';

            entries.forEach(function(e, idx) {
                var brandsStr = Array.isArray(e.brands) ? e.brands.join(', ') : (e.brands || '-');
                var sent = e.sentiment || 'neutral';
                var sentClass = 'bv-sentiment-' + sent;
                var sentLabel = sentMap[sent] || sent;
                var sentIc = sentIcon[sent] || 'fa-face-meh';
                var platLabel = PLATFORMS[e.platform] || e.platform || '-';
                var srcName = e.source_name || platLabel;
                var isNeg = sent === 'negative';

                html += '<tr onclick="BV.toggleExpand('+idx+')" style="' + (isNeg ? 'background:#fef2f2;' : '') + '">';
                html += '<td style="white-space:nowrap;">' + (e.date || '-') + '</td>';
                html += '<td><strong>' + escHtml(brandsStr) + '</strong></td>';
                html += '<td>' + escHtml(e.summary || '-') + '</td>';
                html += '<td class="'+sentClass+'"><i class="fa-solid '+sentIc+'"></i> ' + sentLabel + '</td>';
                html += '<td style="font-size:11px;">' + escHtml(srcName) + '</td>';
                html += '</tr>';

                // Expand row
                html += '<tr><td colspan="5" style="padding:0;"><div class="bv-expand" id="bv-expand-'+idx+'">';
                html += '<div class="bv-content-text">' + escHtml(e.content || '') + '</div>';
                html += '<div class="bv-meta">';
                if (e.source_name) html += '<i class="fa-solid fa-location-dot" style="color:#94a3b8;"></i> ' + escHtml(e.source_name) + ' (' + escHtml(platLabel) + ') | ';
                if (e.source_url) html += '<a href="'+escHtml(e.source_url)+'" target="_blank" style="color:#3b82f6;">ดูต้นฉบับ</a> | ';
                if (e.tags) html += 'Tags: ' + escHtml(e.tags);
                html += '</div>';
                if (isNeg) {
                    html += '<div style="margin-top:8px;padding:6px 10px;background:#fef2f2;border:1px solid #fca5a5;border-radius:6px;font-size:11px;color:#dc2626;"><i class="fa-solid fa-triangle-exclamation"></i> เสียงเชิงลบ — ควรติดตามและแก้ไข</div>';
                }
                html += '<button class="bv-delete-btn" onclick="event.stopPropagation();BV.deleteEntry('+e.id+')"><i class="fa-solid fa-trash"></i> ลบ</button>';
                html += '</div></td></tr>';
            });

            html += '</tbody></table>';
            html += '<div style="text-align:center;padding:8px;font-size:12px;color:#475569;">แสดง ' + entries.length + ' / ' + res.data.total + ' รายการ</div>';
            $('#bv-list-container').html(html);
        }, 'json');
    };

    BV.toggleExpand = function(idx) {
        $('#bv-expand-'+idx).toggleClass('open');
    };

    BV.deleteEntry = function(id) {
        if (!window.Swal) { if (!confirm('ลบรายการนี้?')) return; }
        else {
            Swal.fire({
                title: 'ยืนยันการลบ?',
                text: 'ลบ Brand Voice #' + id,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'ลบ',
                cancelButtonText: 'ยกเลิก'
            }).then(function(result) {
                if (!result.isConfirmed) return;
                doDelete(id);
            });
            return;
        }
        doDelete(id);
    };

    function doDelete(id) {
        $.post(ajaxUrl, { dinoco_bv_action: 'delete_entry', id: id }, function(res) {
            if (res && res.success) {
                if (window.showToast) window.showToast('success', 'ลบแล้ว', '#' + id);
                BV.loadList();
            }
        }, 'json');
    }

    // ── Load Stats ──
    BV.loadStats = function() {
        $('#bv-stats-container').html('<div class="bv-loading"><i class="fa-solid fa-spinner fa-spin"></i> กำลังโหลดสถิติ...</div>');

        $.post(ajaxUrl, { dinoco_bv_action: 'get_stats' }, function(res) {
            if (!res || !res.success) { $('#bv-stats-container').html('<div class="bv-no-data">โหลดสถิติไม่สำเร็จ</div>'); return; }

            var d = res.data;
            var posP = d.total > 0 ? Math.round((d.sentiment.positive / d.total) * 100) : 0;

            var html = '';

            // KPI Cards
            var negP = d.total > 0 ? Math.round((d.sentiment.negative / d.total) * 100) : 0;
            var neuP = 100 - posP - negP;
            html += '<div class="bv-kpi-grid">';
            html += '<div class="bv-kpi-card" style="border-left:3px solid #3b82f6;"><div class="bv-kpi-value" style="color:#3b82f6;">' + d.total + '</div><div class="bv-kpi-label">เสียงลูกค้าทั้งหมด</div></div>';
            html += '<div class="bv-kpi-card" style="border-left:3px solid #22c55e;"><div class="bv-kpi-value" style="color:#22c55e;">' + posP + '%</div><div class="bv-kpi-label">เชิงบวก</div></div>';
            html += '<div class="bv-kpi-card" style="border-left:3px solid #ef4444;"><div class="bv-kpi-value" style="color:#ef4444;">' + negP + '%</div><div class="bv-kpi-label">เชิงลบ</div></div>';
            html += '<div class="bv-kpi-card" style="border-left:3px solid #8b5cf6;"><div class="bv-kpi-value" style="color:#8b5cf6;">' + Object.keys(d.brands).length + '</div><div class="bv-kpi-label">แบรนด์ที่ติดตาม</div></div>';
            html += '</div>';

            // Brand Comparison Table
            html += '<h3 style="font-size:14px;font-weight:600;color:#0f172a;margin-bottom:12px;"><i class="fa-solid fa-ranking-star" style="color:#f59e0b;margin-right:4px;"></i> เปรียบเทียบแบรนด์</h3>';
            html += '<table class="bv-brand-table"><thead><tr><th>แบรนด์</th><th>จำนวน</th><th>เชิงบวก</th><th>เชิงลบ</th><th>ภาพรวม</th></tr></thead><tbody>';

            var brandKeys = Object.keys(d.brands).sort(function(a,b){ return d.brands[b].total - d.brands[a].total; });
            brandKeys.forEach(function(b) {
                var bs = d.brands[b];
                var pp = bs.total > 0 ? Math.round((bs.positive/bs.total)*100) : 0;
                var np = bs.total > 0 ? Math.round((bs.negative/bs.total)*100) : 0;
                var neup = 100 - pp - np;
                var isDinoco = b.toUpperCase() === 'DINOCO';
                html += '<tr' + (isDinoco ? ' style="background:#eff6ff;"' : '') + '>';
                html += '<td><strong' + (isDinoco ? ' style="color:#2563eb;"' : '') + '>' + escHtml(b) + (isDinoco ? ' ★' : '') + '</strong></td>';
                html += '<td>' + bs.total + '</td>';
                html += '<td style="color:#22c55e;font-weight:600;">' + pp + '%</td>';
                html += '<td style="color:#ef4444;font-weight:600;">' + np + '%</td>';
                html += '<td><div class="bv-bar-wrap" style="min-width:120px;">';
                html += '<div class="bv-bar-pos" style="width:'+pp+'%;"></div>';
                html += '<div class="bv-bar-neu" style="width:'+neup+'%;"></div>';
                html += '<div class="bv-bar-neg" style="width:'+np+'%;"></div>';
                html += '</div></td>';
                html += '</tr>';
            });
            html += '</tbody></table>';

            // Negative Alert + Top Supporters
            html += '<div class="bv-charts-row">';

            // Negative Alert
            html += '<div class="bv-chart-box" style="border-left:3px solid #ef4444;">';
            html += '<div class="bv-chart-title"><i class="fa-solid fa-triangle-exclamation" style="color:#ef4444;margin-right:4px;"></i> เสียงเชิงลบ DINOCO (7 วัน)</div>';
            var negs = d.recent_negatives || [];
            if (negs.length === 0) {
                html += '<div style="text-align:center;padding:16px;color:#16a34a;font-size:13px;"><i class="fa-solid fa-circle-check"></i> ไม่มีเสียงเชิงลบในรอบ 7 วัน</div>';
            } else {
                negs.forEach(function(n) {
                    html += '<div style="padding:6px 0;border-bottom:1px solid #fef2f2;font-size:12px;">';
                    html += '<div style="color:#dc2626;font-weight:600;">' + escHtml(n.summary || '') + '</div>';
                    html += '<div style="color:#94a3b8;font-size:11px;margin-top:2px;">' + escHtml(n.author || '') + ' · ' + escHtml(n.source || '') + ' · ' + (n.date || '') + '</div>';
                    html += '</div>';
                });
            }
            html += '</div>';

            // Top Supporters
            html += '<div class="bv-chart-box" style="border-left:3px solid #f59e0b;">';
            html += '<div class="bv-chart-title"><i class="fa-solid fa-heart" style="color:#f59e0b;margin-right:4px;"></i> ผู้สนับสนุน DINOCO</div>';
            var sups = d.top_supporters || [];
            if (sups.length === 0) {
                html += '<div style="text-align:center;padding:16px;color:#94a3b8;font-size:13px;">ยังไม่มีข้อมูลเพียงพอ (ต้องชม >= 2 ครั้ง)</div>';
            } else {
                sups.forEach(function(s, idx) {
                    var medal = idx === 0 ? '🥇' : idx === 1 ? '🥈' : idx === 2 ? '🥉' : '⭐';
                    var platIcons = (s.platforms || []).map(function(p) { return PLATFORMS[p] || p; }).join(', ');
                    html += '<div style="padding:6px 0;border-bottom:1px solid #f1f5f9;font-size:12px;display:flex;align-items:center;gap:8px;">';
                    html += '<span style="font-size:16px;">' + medal + '</span>';
                    html += '<div style="flex:1;">';
                    html += '<div style="font-weight:600;color:#334155;">' + escHtml(s.name) + '</div>';
                    html += '<div style="color:#94a3b8;font-size:11px;">ชม ' + s.positive + ' ครั้ง จาก ' + s.total + ' ครั้ง · ' + escHtml(platIcons) + '</div>';
                    html += '</div>';
                    html += '</div>';
                });
            }
            html += '</div>';

            html += '</div>';

            // Charts
            html += '<div class="bv-charts-row">';
            html += '<div class="bv-chart-box"><div class="bv-chart-title"><i class="fa-solid fa-share-nodes" style="color:#3b82f6;margin-right:4px;"></i> แหล่งที่มา</div><div id="bv-chart-platform"></div></div>';
            html += '<div class="bv-chart-box"><div class="bv-chart-title"><i class="fa-solid fa-tags" style="color:#8b5cf6;margin-right:4px;"></i> หมวดที่พูดถึง</div><div id="bv-chart-category"></div></div>';
            html += '</div>';

            $('#bv-stats-container').html(html);

            // Render charts (ApexCharts)
            if (typeof ApexCharts !== 'undefined') {
                // Platform pie
                var platLabels = [], platValues = [];
                Object.keys(d.platforms).forEach(function(k) {
                    platLabels.push(PLATFORMS[k] || k);
                    platValues.push(d.platforms[k]);
                });
                if (platLabels.length) {
                    new ApexCharts(document.querySelector('#bv-chart-platform'), {
                        chart: { type: 'donut', height: 260, background: 'transparent' },
                        series: platValues,
                        labels: platLabels,
                        colors: ['#3b82f6','#8b5cf6','#ef4444','#f59e0b','#06b6d4','#ec4899','#22c55e','#64748b'],
                        legend: { position: 'bottom', labels: { colors: '#64748b' } },
                        stroke: { width: 0 },
                        dataLabels: { style: { fontSize: '11px' } },
                        theme: { mode: 'light' }
                    }).render();
                }

                // Category bar — top 8 + ภาษาไทย
                var catLabels = [], catValues = [];
                var catKeys = Object.keys(d.categories).sort(function(a,b){ return d.categories[b] - d.categories[a]; }).slice(0, 8);
                catKeys.forEach(function(k) {
                    catLabels.push(CATEGORIES[k] || k);
                    catValues.push(d.categories[k]);
                });
                if (catLabels.length) {
                    new ApexCharts(document.querySelector('#bv-chart-category'), {
                        chart: { type: 'bar', height: 260, background: 'transparent', toolbar: { show: false } },
                        series: [{ name: 'Entries', data: catValues }],
                        xaxis: { categories: catLabels, labels: { style: { colors: '#64748b', fontSize: '11px' } } },
                        yaxis: { labels: { style: { colors: '#94a3b8' } } },
                        colors: ['#3b82f6'],
                        plotOptions: { bar: { borderRadius: 4, horizontal: true } },
                        grid: { borderColor: '#e2e8f0' },
                        theme: { mode: 'light' }
                    }).render();
                }
            }
        }, 'json');
    };

    // ── AI Collect ──
    BV.aiCollect = function(force) {
        var $btn = $('#bv-ai-collect-btn');
        var $status = $('#bv-ai-status');

        $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> กำลังรวบรวม...');
        $status.text('AI กำลังค้นหาเสียงลูกค้าจาก Facebook/YouTube/TikTok... (รอ 15-30 วินาที)');

        $.post(ajaxUrl, {
            dinoco_bv_action: 'ai_collect',
            force: force ? '1' : '0'
        }, function(resp) {
            if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) { resp = {}; }

            $btn.prop('disabled', false).html('<i class="fa-solid fa-wand-magic-sparkles"></i> AI รวบรวมเสียงลูกค้า');

            if (resp.success) {
                var msg = resp.cached ? resp.message : resp.message;
                $status.html('<span style="color:#10b981;"><i class="fa-solid fa-check"></i> ' + (msg || 'สำเร็จ') + '</span>');
                // Refresh stats + entries
                BV.loadStats();
                BV.loadList();
            } else {
                $status.html('<span style="color:#ef4444;"><i class="fa-solid fa-triangle-exclamation"></i> ' + (resp.error || 'ไม่สำเร็จ') + '</span>');
            }
        }, 'json').fail(function() {
            $btn.prop('disabled', false).html('<i class="fa-solid fa-wand-magic-sparkles"></i> AI รวบรวมเสียงลูกค้า');
            $status.html('<span style="color:#ef4444;">เชื่อมต่อไม่สำเร็จ</span>');
        });
    };

    // ── Generate API Key (for Extension) ──
    BV.generateApiKey = function() {
        var $btn = $('#bv-gen-key-btn');
        $btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> กำลังสร้าง...');

        $.ajax({
            url: '<?php echo esc_url(rest_url('brand-voice/v1/api-keys/generate')); ?>',
            method: 'POST',
            beforeSend: function(xhr) {
                xhr.setRequestHeader('X-WP-Nonce', '<?php echo wp_create_nonce('wp_rest'); ?>');
            },
            data: JSON.stringify({ name: 'Extension Key ' + new Date().toISOString().slice(0,10) }),
            contentType: 'application/json',
            success: function(res) {
                if (res.success) {
                    $('#bv-api-key-value').text(res.api_key);
                    $('#bv-api-key-result').show();
                    $btn.html('<i class="fa-solid fa-check"></i> สร้างแล้ว').css('background', '#16a34a');
                } else {
                    alert('สร้าง API Key ไม่สำเร็จ');
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-plus"></i> สร้าง API Key ใหม่');
                }
            },
            error: function() {
                alert('เชื่อมต่อ REST API ไม่สำเร็จ');
                $btn.prop('disabled', false).html('<i class="fa-solid fa-plus"></i> สร้าง API Key ใหม่');
            }
        });
    };

    // ── Bookmarklet generator ──
    BV.generateBookmarklet = function() {
        // Base URL = Dashboard page (Brand Voice is a tab inside it)
        var pageUrl = window.location.href.split('?')[0].split('#')[0];
        // Bookmarklet: grabs selected text + current URL + page title, detects platform, opens Brand Voice
        var code = "(function(){" +
            "var t=window.getSelection().toString().trim();" +
            "var u=location.href;" +
            "var n=document.title;" +
            "var p='';" +
            "if(u.indexOf('facebook.com')!==-1)p='facebook_group';" +
            "else if(u.indexOf('youtube.com')!==-1||u.indexOf('youtu.be')!==-1)p='youtube';" +
            "else if(u.indexOf('tiktok.com')!==-1)p='tiktok';" +
            "else if(u.indexOf('pantip.com')!==-1)p='pantip';" +
            "else if(u.indexOf('instagram.com')!==-1)p='instagram';" +
            "else if(u.indexOf('line.me')!==-1)p='line';" +
            "var q='bv_content='+encodeURIComponent(t)" +
            "+'&bv_url='+encodeURIComponent(u)" +
            "+'&bv_source='+encodeURIComponent(n)" +
            "+'&bv_platform='+encodeURIComponent(p);" +
            "window.open('" + pageUrl + "?'+q+'#brand_voice','_blank','width=1100,height=800');" +
            "})();";
        return 'javascript:' + encodeURI(code);
    };

    // ── Prefill from URL params (bookmarklet flow) ──
    BV.checkPrefill = function() {
        var params = new URLSearchParams(window.location.search);
        var content  = params.get('bv_content');
        var url      = params.get('bv_url');
        var source   = params.get('bv_source');
        var platform = params.get('bv_platform');

        if (!content && !url) return;

        // Switch to entry tab
        BV.switchTab('entry');

        // Fill fields
        if (content) $('#bv-content').val(content);
        if (url)     $('#bv-source-url').val(url);
        if (source)  $('#bv-source-name').val(source);
        if (platform) $('#bv-platform').val(platform);

        // Auto-generate summary from first 80 chars of content
        if (content && !$('#bv-summary').val()) {
            var sum = content.length > 80 ? content.substring(0, 77) + '...' : content;
            $('#bv-summary').val(sum);
        }

        // Focus on summary for quick edit
        _st(function() { $('#bv-summary').focus().select(); }, 300);

        // Show toast
        if (window.showToast) {
            window.showToast('info', 'Bookmarklet', 'ข้อมูลจากโซเชียลถูกกรอกให้แล้ว — เลือกแบรนด์แล้วบันทึก');
        }
    };

    // ── Auto-load stats on page load (default tab) ──
    $(function() {
        BV.loadSources(); BV.loadStats();

        // Generate bookmarklet link
        var bmLink = BV.generateBookmarklet();
        $('#bv-bookmarklet-link').attr('href', bmLink);

        // Check prefill from bookmarklet
        BV.checkPrefill();
    });

    // ── Utility ──
    function escHtml(s) {
        if (!s) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

})(jQuery);
</script>

