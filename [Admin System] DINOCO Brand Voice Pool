function bv_create_entry($data) {
    $post_id = wp_insert_post([
        'post_type'   => 'brand_voice',
        'post_status' => 'publish',
        'post_title'  => mb_substr(sanitize_text_field($data['summary'] ?? ''), 0, 100) ?: 'Brand Voice ' . date('Y-m-d H:i'),
    ]);

    if (is_wp_error($post_id)) return false;

    $fields = [
        'bv_brands', 'bv_brand_other', 'bv_content', 'bv_summary',
        'bv_sentiment', 'bv_intensity', 'bv_categories', 'bv_platform',
        'bv_source_url', 'bv_source_name', 'bv_post_date',
        'bv_product', 'bv_models', 'bv_author_name',
        'bv_is_customer', 'bv_has_photo', 'bv_engagement',
        'bv_is_lead', 'bv_is_complaint', 'bv_complaint_status',
        'bv_is_influencer', 'bv_dinoco_responded', 'bv_response_text',
        'bv_tags', 'bv_admin_notes',
    ];

    foreach ($fields as $key) {
        $short = str_replace('bv_', '', $key);
        if (isset($data[$short])) {
            $val = is_array($data[$short]) ? array_map('sanitize_text_field', $data[$short]) : sanitize_text_field($data[$short]);
            update_post_meta($post_id, $key, $val);
        }
    }

    update_post_meta($post_id, 'bv_entered_by', get_current_user_id());
    update_post_meta($post_id, 'bv_entry_method', 'manual');

    return $post_id;
}

function bv_get_entries($args = []) {
    $defaults = [
        'brand'     => '',
        'sentiment' => '',
        'platform'  => '',
        'category'  => '',
        'model'     => '',
        'date_from' => '',
        'date_to'   => '',
        'search'    => '',
        'limit'     => 50,
        'offset'    => 0,
    ];
    $args = wp_parse_args($args, $defaults);

    $meta_query = ['relation' => 'AND'];

    if ($args['brand']) {
        $meta_query[] = ['key' => 'bv_brands', 'value' => $args['brand'], 'compare' => 'LIKE'];
    }
    if ($args['sentiment']) {
        $meta_query[] = ['key' => 'bv_sentiment', 'value' => $args['sentiment'], 'compare' => '='];
    }
    if ($args['platform']) {
        $meta_query[] = ['key' => 'bv_platform', 'value' => $args['platform'], 'compare' => '='];
    }

    $q = new WP_Query([
        'post_type'      => 'brand_voice',
        'post_status'    => 'publish',
        'posts_per_page' => intval($args['limit']),
        'offset'         => intval($args['offset']),
        'orderby'        => 'date',
        'order'          => 'DESC',
        'meta_query'     => count($meta_query) > 1 ? $meta_query : [],
        's'              => $args['search'] ?: null,
    ]);

    $entries = [];
    foreach ($q->posts as $p) {
        $entries[] = [
            'id'               => $p->ID,
            'date'             => get_the_date('Y-m-d', $p->ID),
            'brands'           => get_post_meta($p->ID, 'bv_brands', true) ?: [],
            'summary'          => get_post_meta($p->ID, 'bv_summary', true),
            'content'          => get_post_meta($p->ID, 'bv_content', true),
            'sentiment'        => get_post_meta($p->ID, 'bv_sentiment', true),
            'intensity'        => intval(get_post_meta($p->ID, 'bv_intensity', true)),
            'categories'       => get_post_meta($p->ID, 'bv_categories', true) ?: [],
            'platform'         => get_post_meta($p->ID, 'bv_platform', true),
            'source_url'       => get_post_meta($p->ID, 'bv_source_url', true),
            'source_name'      => get_post_meta($p->ID, 'bv_source_name', true),
            'post_date'        => get_post_meta($p->ID, 'bv_post_date', true),
            'product'          => get_post_meta($p->ID, 'bv_product', true),
            'models'           => get_post_meta($p->ID, 'bv_models', true) ?: [],
            'author_name'      => get_post_meta($p->ID, 'bv_author_name', true),
            'engagement'       => get_post_meta($p->ID, 'bv_engagement', true),
            'is_lead'          => get_post_meta($p->ID, 'bv_is_lead', true),
            'is_complaint'     => get_post_meta($p->ID, 'bv_is_complaint', true),
            'complaint_status' => get_post_meta($p->ID, 'bv_complaint_status', true),
            'is_influencer'    => get_post_meta($p->ID, 'bv_is_influencer', true),
            'dinoco_responded' => get_post_meta($p->ID, 'bv_dinoco_responded', true),
            'tags'             => get_post_meta($p->ID, 'bv_tags', true),
        ];
    }

    return ['entries' => $entries, 'total' => $q->found_posts];
}

function bv_get_stats($days = 30) {
    $all     = bv_get_entries(['limit' => 9999]);
    $entries = $all['entries'];
    $total   = count($entries);

    $sentiment_counts = ['positive' => 0, 'neutral' => 0, 'negative' => 0, 'mixed' => 0];
    $brand_stats      = [];
    $platform_stats   = [];
    $category_stats   = [];

    foreach ($entries as $e) {
        $s = $e['sentiment'] ?: 'neutral';
        if (isset($sentiment_counts[$s])) $sentiment_counts[$s]++;

        $brands = is_array($e['brands']) ? $e['brands'] : [$e['brands']];
        foreach ($brands as $b) {
            if (!$b) continue;
            if (!isset($brand_stats[$b])) $brand_stats[$b] = ['total' => 0, 'positive' => 0, 'neutral' => 0, 'negative' => 0, 'mixed' => 0];
            $brand_stats[$b]['total']++;
            if (isset($brand_stats[$b][$s])) $brand_stats[$b][$s]++;
        }

        $p = $e['platform'] ?: 'other';
        if (!isset($platform_stats[$p])) $platform_stats[$p] = 0;
        $platform_stats[$p]++;

        $cats = is_array($e['categories']) ? $e['categories'] : [];
        foreach ($cats as $c) {
            if (!isset($category_stats[$c])) $category_stats[$c] = 0;
            $category_stats[$c]++;
        }
    }

    $complaints = array_filter($entries, function($e) {
        return $e['is_complaint'] && $e['complaint_status'] !== 'resolved';
    });

    // ผู้สนับสนุน DINOCO — track คนที่พูดถึง DINOCO เชิงบวกบ่อย
    $supporters = [];
    foreach ($entries as $e) {
        $author = $e['author_name'] ?? '';
        if (!$author || mb_strlen($author) < 2) continue;
        $brands = is_array($e['brands']) ? $e['brands'] : [$e['brands']];
        if (!in_array('DINOCO', $brands)) continue;

        if (!isset($supporters[$author])) {
            $supporters[$author] = ['positive' => 0, 'total' => 0, 'last_date' => '', 'platforms' => []];
        }
        $supporters[$author]['total']++;
        if ($e['sentiment'] === 'positive') $supporters[$author]['positive']++;
        if ($e['date'] > $supporters[$author]['last_date']) $supporters[$author]['last_date'] = $e['date'];
        $plat = $e['platform'] ?: 'other';
        if (!in_array($plat, $supporters[$author]['platforms'])) $supporters[$author]['platforms'][] = $plat;
    }
    // เรียงตาม positive count แล้วเอา top 10
    uasort($supporters, function($a, $b) { return $b['positive'] - $a['positive']; });
    $top_supporters = [];
    $rank = 0;
    foreach ($supporters as $name => $data) {
        if ($data['positive'] < 2) break; // ต้องชม >= 2 ครั้งถึงจะนับ
        $rank++;
        $top_supporters[] = [
            'name'      => $name,
            'positive'  => $data['positive'],
            'total'     => $data['total'],
            'last_date' => $data['last_date'],
            'platforms' => $data['platforms'],
        ];
        if ($rank >= 10) break;
    }

    // Negative alert — entries เชิงลบล่าสุด 7 วัน
    $week_ago = date('Y-m-d', strtotime('-7 days'));
    $recent_negatives = [];
    foreach ($entries as $e) {
        if ($e['sentiment'] !== 'negative') continue;
        if ($e['date'] < $week_ago) continue;
        $brands = is_array($e['brands']) ? $e['brands'] : [$e['brands']];
        if (!in_array('DINOCO', $brands)) continue;
        $recent_negatives[] = [
            'date'    => $e['date'],
            'summary' => $e['summary'],
            'author'  => $e['author_name'] ?? '',
            'source'  => $e['source_name'] ?? '',
        ];
    }

    return [
        'total'              => $total,
        'sentiment'          => $sentiment_counts,
        'brands'             => $brand_stats,
        'platforms'          => $platform_stats,
        'categories'         => $category_stats,
        'pending_complaints' => count($complaints),
        'top_supporters'     => $top_supporters,
        'recent_negatives'   => $recent_negatives,
    ];
}

function bv_get_ai_summary() {
    $stats = bv_get_stats(90);
    if ($stats['total'] === 0) return null;

    $recent    = bv_get_entries(['limit' => 20]);
    $summaries = [];
    foreach ($recent['entries'] as $e) {
        $brands     = is_array($e['brands']) ? implode(',', $e['brands']) : $e['brands'];
        $summaries[] = $brands . '|' . $e['sentiment'] . '|' . $e['summary'];
    }

    return [
        'total_entries'       => $stats['total'],
        'sentiment_breakdown' => $stats['sentiment'],
        'brand_comparison'    => $stats['brands'],
        'top_categories'      => $stats['categories'],
        'recent_voices'       => implode("\n", $summaries),
    ];
}

