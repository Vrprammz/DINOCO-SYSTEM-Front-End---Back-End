<script>
(function($){
    var _st = (window._dncAutoRefresh && window._dncAutoRefresh.origSetTimeout) || setTimeout;
    var ajaxUrl = '<?php echo esc_url(admin_url('admin-post.php')); ?>';
    var PLATFORMS = <?php echo json_encode($platforms); ?>;
    var CATEGORIES = <?php echo json_encode($categories); ?>;

    window.BV = {};

    // ── Tab switch ──
    BV.switchTab = function(tab) {
        $('.dnc-bv .bv-tab-btn').removeClass('active');
        $('.dnc-bv .bv-tab-btn[data-tab="'+tab+'"]').addClass('active');
        $('.dnc-bv .bv-tab-pane').removeClass('active');
        $('#bv-pane-'+tab).addClass('active');

        if (tab === 'list') BV.loadList();
        if (tab === 'stats') BV.loadStats();
    };

    // ── Chip toggle ──
    BV.toggleChip = function(el) {
        var $el = $(el);
        var $cb = $el.find('input[type="checkbox"]');
        $cb.prop('checked', !$cb.prop('checked'));
        $el.toggleClass('selected', $cb.prop('checked'));
    };

    // ── Sentiment ──
    BV.currentSentiment = 'neutral';
    BV.setSentiment = function(el) {
        var $el = $(el);
        $('#bv-sentiment-group .bv-sent-btn').removeClass('active');
        $el.addClass('active');
        BV.currentSentiment = $el.data('val');
    };

    // ── Platform auto-detect ──
    $(document).on('input', '#bv-source-url', function() {
        var url = this.value;
        if (url.includes('facebook.com')) $('#bv-platform').val('facebook_group');
        else if (url.includes('youtube.com') || url.includes('youtu.be')) $('#bv-platform').val('youtube');
        else if (url.includes('tiktok.com')) $('#bv-platform').val('tiktok');
        else if (url.includes('pantip.com')) $('#bv-platform').val('pantip');
        else if (url.includes('instagram.com')) $('#bv-platform').val('instagram');
    });

    // ── Collect form data ──
    function collectFormData() {
        var brands = [];
        $('#bv-brands-group input:checked').each(function(){ brands.push($(this).val()); });
        var categories = [];
        $('#bv-cats-group input:checked').each(function(){ categories.push($(this).val()); });
        var models = [];
        $('#bv-models-group input:checked').each(function(){ models.push($(this).val()); });

        return {
            dinoco_bv_action: 'save_entry',
            content:          $('#bv-content').val(),
            summary:          $('#bv-summary').val(),
            source_url:       $('#bv-source-url').val(),
            source_name:      $('#bv-source-name').val(),
            author_name:      $('#bv-author-name').val(),
            post_date:        $('#bv-post-date').val(),
            product:          $('#bv-product').val(),
            brands:           brands,
            brand_other:      $('#bv-brand-other').val(),
            sentiment:        BV.currentSentiment,
            intensity:        $('#bv-intensity').val(),
            categories:       categories,
            platform:         $('#bv-platform').val(),
            models:           models,
            engagement:       $('#bv-engagement').val(),
            is_customer:      $('#bv-is-customer').is(':checked') ? '1' : '',
            has_photo:        $('#bv-has-photo').is(':checked') ? '1' : '',
            is_lead:          $('#bv-is-lead').is(':checked') ? '1' : '',
            is_complaint:     $('#bv-is-complaint').is(':checked') ? '1' : '',
            is_influencer:    $('#bv-is-influencer').is(':checked') ? '1' : '',
            dinoco_responded: $('#bv-dinoco-responded').is(':checked') ? '1' : '',
            tags:             $('#bv-tags').val(),
            admin_notes:      $('#bv-admin-notes').val()
        };
    }

    // ── Reset form ──
    function resetForm() {
        var batch = $('#bv-batch-mode').is(':checked');
        var keepBrands   = batch ? $('#bv-brands-group input:checked').map(function(){ return $(this).val(); }).get() : [];
        var keepModels   = batch ? $('#bv-models-group input:checked').map(function(){ return $(this).val(); }).get() : [];
        var keepPlatform = batch ? $('#bv-platform').val() : '';

        // Clear all
        $('#bv-content, #bv-summary, #bv-source-url, #bv-source-name, #bv-author-name, #bv-product, #bv-brand-other, #bv-tags').val('');
        $('#bv-admin-notes').val('');
        $('#bv-post-date').val(new Date().toISOString().slice(0,10));
        $('#bv-intensity').val(3); $('#bv-intensity-val').text('3');
        $('#bv-engagement').val('low');
        BV.currentSentiment = 'neutral';
        $('#bv-sentiment-group .bv-sent-btn').removeClass('active');
        $('#bv-sentiment-group .bv-sent-btn.s-neutral').addClass('active');

        // Uncheck all chips
        $('.dnc-bv .bv-chip').removeClass('selected').find('input').prop('checked', false);
        // Uncheck flags
        $('#bv-is-customer, #bv-has-photo, #bv-is-lead, #bv-is-complaint, #bv-is-influencer, #bv-dinoco-responded').prop('checked', false);

        // Restore batch values
        if (batch) {
            keepBrands.forEach(function(v) {
                var $cb = $('#bv-brands-group input[value="'+v+'"]');
                $cb.prop('checked', true).closest('.bv-chip').addClass('selected');
            });
            keepModels.forEach(function(v) {
                var $cb = $('#bv-models-group input[value="'+v+'"]');
                $cb.prop('checked', true).closest('.bv-chip').addClass('selected');
            });
            $('#bv-platform').val(keepPlatform);
        } else {
            $('#bv-platform').val('');
        }

        $('#bv-content').focus();
    }

    // ── Save ──
    BV.save = function(mode) {
        var data = collectFormData();
        if (!data.content && !data.summary) {
            if (window.Swal) Swal.fire('กรุณากรอกข้อมูล', 'ต้องมีข้อความหรือสรุปอย่างน้อย 1 อย่าง', 'warning');
            return;
        }

        $.post(ajaxUrl, data, function(res) {
            if (res && res.success) {
                if (window.showToast) window.showToast('success', 'บันทึกแล้ว', 'Brand Voice #' + res.id);
                if (mode === 'continue') {
                    resetForm();
                } else {
                    resetForm();
                    BV.switchTab('list');
                }
            } else {
                if (window.Swal) Swal.fire('Error', res.error || 'บันทึกไม่สำเร็จ', 'error');
            }
        }, 'json').fail(function() {
            if (window.Swal) Swal.fire('Error', 'เกิดข้อผิดพลาด', 'error');
        });
    };

    // ── Keyboard shortcuts ──
    $(document).on('keydown', function(e) {
        // Ctrl+Enter = save & continue
        if (e.ctrlKey && e.key === 'Enter' && $('.dnc-bv .bv-tab-pane#bv-pane-entry').hasClass('active')) {
            e.preventDefault(); BV.save('continue');
        }
        // Ctrl+S = save & close
        if (e.ctrlKey && e.key === 's' && $('.dnc-bv .bv-tab-pane#bv-pane-entry').hasClass('active')) {
            e.preventDefault(); BV.save('close');
        }
    });

    // ── Load List ──
    BV.loadList = function() {
        $('#bv-list-container').html('<div class="bv-loading"><i class="fa-solid fa-spinner fa-spin"></i> กำลังโหลด...</div>');

        $.post(ajaxUrl, {
            dinoco_bv_action: 'get_entries',
            brand:     $('#bv-f-brand').val(),
            sentiment: $('#bv-f-sentiment').val(),
            platform:  $('#bv-f-platform').val(),
            search:    $('#bv-f-search').val(),
            limit: 50
        }, function(res) {
            if (!res || !res.success) { $('#bv-list-container').html('<div class="bv-no-data">โหลดข้อมูลไม่สำเร็จ</div>'); return; }

            var entries = res.data.entries;
            if (!entries.length) { $('#bv-list-container').html('<div class="bv-no-data"><i class="fa-solid fa-inbox" style="font-size:32px;display:block;margin-bottom:12px;"></i>ยังไม่มีข้อมูล</div>'); return; }

            var html = '<table class="bv-table"><thead><tr>';
            html += '<th>วันที่</th><th>แบรนด์</th><th>สรุป</th><th>Sentiment</th><th>Platform</th><th>Engagement</th>';
            html += '</tr></thead><tbody>';

            entries.forEach(function(e, idx) {
                var brandsStr = Array.isArray(e.brands) ? e.brands.join(', ') : (e.brands || '-');
                var sentClass = 'bv-sentiment-' + (e.sentiment || 'neutral');
                var sentLabel = (e.sentiment || 'neutral').charAt(0).toUpperCase() + (e.sentiment || 'neutral').slice(1);
                var platLabel = PLATFORMS[e.platform] || e.platform || '-';
                var engLabel  = (e.engagement || 'low').charAt(0).toUpperCase() + (e.engagement || 'low').slice(1);

                html += '<tr onclick="BV.toggleExpand('+idx+')">';
                html += '<td>' + (e.date || '-') + '</td>';
                html += '<td><strong>' + escHtml(brandsStr) + '</strong></td>';
                html += '<td>' + escHtml(e.summary || '-') + '</td>';
                html += '<td class="'+sentClass+'">' + sentLabel + '</td>';
                html += '<td>' + escHtml(platLabel) + '</td>';
                html += '<td>' + engLabel + '</td>';
                html += '</tr>';

                // Expand row
                html += '<tr><td colspan="6" style="padding:0;"><div class="bv-expand" id="bv-expand-'+idx+'">';
                html += '<div class="bv-content-text">' + escHtml(e.content || '') + '</div>';
                html += '<div class="bv-meta">';
                if (e.source_url) html += '<a href="'+escHtml(e.source_url)+'" target="_blank" style="color:#3b82f6;">ดูต้นฉบับ</a> | ';
                if (e.author_name) html += 'โดย: ' + escHtml(e.author_name) + ' | ';
                if (e.tags) html += 'Tags: ' + escHtml(e.tags);
                html += '</div>';
                html += '<button class="bv-delete-btn" onclick="event.stopPropagation();BV.deleteEntry('+e.id+')"><i class="fa-solid fa-trash"></i> ลบ</button>';
                html += '</div></td></tr>';
            });

            html += '</tbody></table>';
            html += '<div style="text-align:center;padding:8px;font-size:12px;color:#475569;">แสดง ' + entries.length + ' / ' + res.data.total + ' รายการ</div>';
            $('#bv-list-container').html(html);
        }, 'json');
    };

    BV.toggleExpand = function(idx) {
        $('#bv-expand-'+idx).toggleClass('open');
    };

    BV.deleteEntry = function(id) {
        if (!window.Swal) { if (!confirm('ลบรายการนี้?')) return; }
        else {
            Swal.fire({
                title: 'ยืนยันการลบ?',
                text: 'ลบ Brand Voice #' + id,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'ลบ',
                cancelButtonText: 'ยกเลิก'
            }).then(function(result) {
                if (!result.isConfirmed) return;
                doDelete(id);
            });
            return;
        }
        doDelete(id);
    };

    function doDelete(id) {
        $.post(ajaxUrl, { dinoco_bv_action: 'delete_entry', id: id }, function(res) {
            if (res && res.success) {
                if (window.showToast) window.showToast('success', 'ลบแล้ว', '#' + id);
                BV.loadList();
            }
        }, 'json');
    }

    // ── Load Stats ──
    BV.loadStats = function() {
        $('#bv-stats-container').html('<div class="bv-loading"><i class="fa-solid fa-spinner fa-spin"></i> กำลังโหลดสถิติ...</div>');

        $.post(ajaxUrl, { dinoco_bv_action: 'get_stats' }, function(res) {
            if (!res || !res.success) { $('#bv-stats-container').html('<div class="bv-no-data">โหลดสถิติไม่สำเร็จ</div>'); return; }

            var d = res.data;
            var posP = d.total > 0 ? Math.round((d.sentiment.positive / d.total) * 100) : 0;

            var html = '';

            // KPI Cards
            html += '<div class="bv-kpi-grid">';
            html += '<div class="bv-kpi-card"><div class="bv-kpi-value">' + d.total + '</div><div class="bv-kpi-label">Total Entries</div></div>';
            html += '<div class="bv-kpi-card"><div class="bv-kpi-value" style="color:#22c55e;">' + posP + '%</div><div class="bv-kpi-label">Positive</div></div>';
            html += '<div class="bv-kpi-card"><div class="bv-kpi-value" style="color:#ef4444;">' + d.pending_complaints + '</div><div class="bv-kpi-label">Pending Complaints</div></div>';
            html += '<div class="bv-kpi-card"><div class="bv-kpi-value" style="color:#94a3b8;">' + Object.keys(d.brands).length + '</div><div class="bv-kpi-label">Brands Tracked</div></div>';
            html += '</div>';

            // Brand Comparison Table
            html += '<h3 style="font-size:14px;color:#94a3b8;margin-bottom:12px;">Brand Comparison</h3>';
            html += '<table class="bv-brand-table"><thead><tr><th>แบรนด์</th><th>Entries</th><th>Positive%</th><th>Negative%</th><th>Sentiment</th></tr></thead><tbody>';

            var brandKeys = Object.keys(d.brands).sort(function(a,b){ return d.brands[b].total - d.brands[a].total; });
            brandKeys.forEach(function(b) {
                var bs = d.brands[b];
                var pp = bs.total > 0 ? Math.round((bs.positive/bs.total)*100) : 0;
                var np = bs.total > 0 ? Math.round((bs.negative/bs.total)*100) : 0;
                var neup = 100 - pp - np;
                html += '<tr>';
                html += '<td><strong>' + escHtml(b) + '</strong></td>';
                html += '<td>' + bs.total + '</td>';
                html += '<td style="color:#22c55e;">' + pp + '%</td>';
                html += '<td style="color:#ef4444;">' + np + '%</td>';
                html += '<td><div class="bv-bar-wrap" style="min-width:120px;">';
                html += '<div class="bv-bar-pos" style="width:'+pp+'%;"></div>';
                html += '<div class="bv-bar-neu" style="width:'+neup+'%;"></div>';
                html += '<div class="bv-bar-neg" style="width:'+np+'%;"></div>';
                html += '</div></td>';
                html += '</tr>';
            });
            html += '</tbody></table>';

            // Charts
            html += '<div class="bv-charts-row">';
            html += '<div class="bv-chart-box"><div class="bv-chart-title">Platform Distribution</div><div id="bv-chart-platform"></div></div>';
            html += '<div class="bv-chart-box"><div class="bv-chart-title">Category Distribution</div><div id="bv-chart-category"></div></div>';
            html += '</div>';

            $('#bv-stats-container').html(html);

            // Render charts (ApexCharts)
            if (typeof ApexCharts !== 'undefined') {
                // Platform pie
                var platLabels = [], platValues = [];
                Object.keys(d.platforms).forEach(function(k) {
                    platLabels.push(PLATFORMS[k] || k);
                    platValues.push(d.platforms[k]);
                });
                if (platLabels.length) {
                    new ApexCharts(document.querySelector('#bv-chart-platform'), {
                        chart: { type: 'donut', height: 260, background: 'transparent' },
                        series: platValues,
                        labels: platLabels,
                        colors: ['#3b82f6','#8b5cf6','#ef4444','#f59e0b','#06b6d4','#ec4899','#22c55e','#64748b'],
                        legend: { position: 'bottom', labels: { colors: '#94a3b8' } },
                        stroke: { width: 0 },
                        dataLabels: { style: { fontSize: '11px' } },
                        theme: { mode: 'dark' }
                    }).render();
                }

                // Category bar
                var catLabels = [], catValues = [];
                var catKeys = Object.keys(d.categories).sort(function(a,b){ return d.categories[b] - d.categories[a]; });
                catKeys.forEach(function(k) {
                    catLabels.push(CATEGORIES[k] || k);
                    catValues.push(d.categories[k]);
                });
                if (catLabels.length) {
                    new ApexCharts(document.querySelector('#bv-chart-category'), {
                        chart: { type: 'bar', height: 260, background: 'transparent', toolbar: { show: false } },
                        series: [{ name: 'Entries', data: catValues }],
                        xaxis: { categories: catLabels, labels: { style: { colors: '#94a3b8', fontSize: '11px' } } },
                        yaxis: { labels: { style: { colors: '#64748b' } } },
                        colors: ['#fbbf24'],
                        plotOptions: { bar: { borderRadius: 4, horizontal: true } },
                        grid: { borderColor: '#1e293b' },
                        theme: { mode: 'dark' }
                    }).render();
                }
            }
        }, 'json');
    };

    // ── Utility ──
    function escHtml(s) {
        if (!s) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

})(jQuery);
</script>

    <?php
    return ob_get_clean();
});
