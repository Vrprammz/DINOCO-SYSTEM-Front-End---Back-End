// CORS for Brand Voice REST API (Chrome Extension)
add_action('rest_api_init', function() {
    remove_filter('rest_pre_serve_request', 'rest_send_cors_headers');
    add_filter('rest_pre_serve_request', function($value) {
        $origin = isset($_SERVER['HTTP_ORIGIN']) ? $_SERVER['HTTP_ORIGIN'] : '';
        if (preg_match('/^chrome-extension:\/\//', $origin) || strpos($origin, 'dinoco.in.th') !== false || strpos($origin, 'localhost') !== false) {
            header('Access-Control-Allow-Origin: ' . $origin);
            header('Access-Control-Allow-Methods: GET, POST, OPTIONS');
            header('Access-Control-Allow-Headers: Content-Type, X-BV-API-Key, X-WP-Nonce');
            header('Access-Control-Allow-Credentials: true');
        }
        return $value;
    });
}, 15);

// Handle OPTIONS preflight for brand-voice endpoints
add_action('init', function() {
    if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS' && isset($_SERVER['HTTP_ORIGIN'])) {
        $uri = $_SERVER['REQUEST_URI'] ?? '';
        if (strpos($uri, '/wp-json/brand-voice/') !== false) {
            $origin = $_SERVER['HTTP_ORIGIN'];
            if (preg_match('/^chrome-extension:\/\//', $origin) || strpos($origin, 'dinoco.in.th') !== false) {
                header('Access-Control-Allow-Origin: ' . $origin);
                header('Access-Control-Allow-Methods: GET, POST, OPTIONS');
                header('Access-Control-Allow-Headers: Content-Type, X-BV-API-Key, X-WP-Nonce');
                header('Access-Control-Allow-Credentials: true');
                header('Access-Control-Max-Age: 86400');
                header('Content-Length: 0');
                header('HTTP/1.1 204 No Content');
                exit;
            }
        }
    }
}, 1);

add_action('rest_api_init', function() {

    // Verify API key from X-BV-API-Key header
    $verify_key = function() {
        $key = isset($_SERVER['HTTP_X_BV_API_KEY']) ? sanitize_text_field($_SERVER['HTTP_X_BV_API_KEY']) : '';
        if (!$key) return false;
        $stored = get_option('bv_api_keys', []);
        if (!is_array($stored)) return false;
        $hash = hash('sha256', $key);
        foreach ($stored as $k) {
            if (isset($k['key_hash']) && hash_equals($k['key_hash'], $hash)) {
                // Track last_used via transient (ไม่ write DB ทุก request)
                $short = substr($hash, 0, 12);
                if (!get_transient('bv_key_used_' . $short)) {
                    set_transient('bv_key_used_' . $short, wp_date('Y-m-d H:i:s'), HOUR_IN_SECONDS);
                }
                return true;
            }
        }
        return false;
    };

    // Permission callback with proper WP_Error
    $api_permission = function() use ($verify_key) {
        if (!$verify_key()) return new WP_Error('unauthorized', 'Invalid API key', ['status' => 401]);
        // Rate limit
        $key = sanitize_text_field($_SERVER['HTTP_X_BV_API_KEY'] ?? '');
        $short = substr(hash('sha256', $key), 0, 12);
        $tk = 'bv_rate_' . $short . '_' . wp_date('YmdHi');
        $count = (int) get_transient($tk);
        if ($count >= 60) return new WP_Error('rate_limit', 'Rate limit exceeded', ['status' => 429]);
        set_transient($tk, $count + 1, 120);
        return true;
    };

    // Shared: validate + save single entry from body array
    $save_single_entry = function($body) {
        $valid_brands     = bv_get_brands();
        $valid_categories = array_keys(bv_get_categories());
        $valid_platforms  = array_keys(bv_get_platforms());
        $valid_sentiments = ['positive', 'neutral', 'negative', 'mixed'];
        $valid_models     = bv_get_models();

        $source_url = esc_url_raw($body['source_url'] ?? '');

        // Duplicate check by source_url + author + content + brands (แยก brand = entry ต่าง)
        if ($source_url) {
            $brands_key = is_array($body['brands'] ?? null) ? implode(',', (array)$body['brands']) : '';
            $content_hash = md5(($body['author_name'] ?? '') . '|' . mb_substr($body['content'] ?? '', 0, 100) . '|' . $brands_key);
            $dup_key = 'bv_dup_' . md5($source_url . $content_hash);
            if (get_transient($dup_key)) {
                return ['status' => 'duplicate', 'message' => 'Duplicate entry'];
            }
        }

        $brands = array_values(array_filter(array_map('sanitize_text_field', (array)($body['brands'] ?? [])), function($b) use ($valid_brands) { return in_array($b, $valid_brands); }));
        $cats   = array_values(array_filter(array_map('sanitize_text_field', (array)($body['categories'] ?? [])), function($c) use ($valid_categories) { return in_array($c, $valid_categories); }));
        $models = array_values(array_filter(array_map('sanitize_text_field', (array)($body['models'] ?? [])), function($m) use ($valid_models) { return in_array($m, $valid_models); }));

        $sentiment = in_array($body['sentiment'] ?? '', $valid_sentiments) ? $body['sentiment'] : 'neutral';
        $platform  = in_array($body['platform'] ?? '', $valid_platforms) ? $body['platform'] : 'other';

        if (empty($body['content']) && empty($body['summary'])) {
            return ['status' => 'error', 'message' => 'content or summary required'];
        }

        $data = [
            'brands'      => $brands,
            'content'     => sanitize_textarea_field($body['content'] ?? ''),
            'summary'     => sanitize_text_field(mb_substr($body['summary'] ?? '', 0, 200)),
            'sentiment'   => $sentiment,
            'intensity'   => max(1, min(5, intval($body['intensity'] ?? 3))),
            'categories'  => $cats,
            'platform'    => $platform,
            'source_url'  => $source_url,
            'source_name' => sanitize_text_field($body['source_name'] ?? ''),
            'post_date'   => sanitize_text_field($body['post_date'] ?? wp_date('Y-m-d')),
            'product'     => sanitize_text_field($body['product'] ?? ''),
            'models'      => $models,
            'author_name' => sanitize_text_field($body['author_name'] ?? ''),
            'engagement'  => sanitize_text_field($body['engagement'] ?? 'low'),
            'is_lead'     => !empty($body['is_lead']) ? '1' : '0',
            'is_complaint'  => !empty($body['is_complaint']) ? '1' : '0',
            'is_influencer' => !empty($body['is_influencer']) ? '1' : '0',
            'has_photo'     => !empty($body['has_photo']) ? '1' : '0',
            'tags'        => sanitize_text_field($body['tags'] ?? ''),
            'admin_notes' => sanitize_textarea_field($body['admin_notes'] ?? ''),
        ];

        $post_id = bv_create_entry($data);
        if (!$post_id) {
            return ['status' => 'error', 'message' => 'Failed to save'];
        }

        // Agent metadata
        update_post_meta($post_id, 'bv_entry_method', sanitize_text_field($body['_entry_method'] ?? 'extension'));
        $agent = $body['_agent'] ?? [];
        if (!empty($agent['agent_id'])) update_post_meta($post_id, 'bv_agent_id', sanitize_text_field($agent['agent_id']));
        if (isset($agent['confidence_score'])) update_post_meta($post_id, 'bv_agent_confidence', floatval($agent['confidence_score']));

        // Set dedup transient (24h)
        if ($source_url) {
            $brands_str = is_array($body['brands'] ?? null) ? implode(',', (array)$body['brands']) : '';
            $content_hash = md5(($body['author_name'] ?? '') . '|' . mb_substr($body['content'] ?? '', 0, 100) . '|' . $brands_str);
            set_transient('bv_dup_' . md5($source_url . $content_hash), 1, DAY_IN_SECONDS);
        }

        return ['status' => 'created', 'entry_id' => $post_id];
    };

    // POST /wp-json/brand-voice/v1/entries — สร้าง entry
    register_rest_route('brand-voice/v1', '/entries', [
        'methods'  => 'POST',
        'permission_callback' => $api_permission,
        'callback' => function(WP_REST_Request $req) use ($save_single_entry) {
            $body = $req->get_json_params();
            if (empty($body)) return new WP_Error('bad_request', 'JSON body required', ['status' => 400]);

            $result = $save_single_entry($body);
            if ($result['status'] === 'created') {
                return new WP_REST_Response(['success' => true, 'entry_id' => $result['entry_id']], 201);
            } elseif ($result['status'] === 'duplicate') {
                return new WP_REST_Response(['success' => false, 'code' => 'duplicate', 'message' => $result['message']], 409);
            }
            return new WP_Error('save_failed', $result['message'] ?? 'Unknown error', ['status' => 400]);
        },
    ]);

    // POST /wp-json/brand-voice/v1/entries/batch — สร้างหลาย entries
    register_rest_route('brand-voice/v1', '/entries/batch', [
        'methods'  => 'POST',
        'permission_callback' => $api_permission,
        'callback' => function(WP_REST_Request $req) use ($save_single_entry) {
            $body = $req->get_json_params();
            $entries = $body['entries'] ?? [];
            if (!is_array($entries) || empty($entries)) {
                return new WP_Error('bad_request', 'entries array required', ['status' => 400]);
            }
            if (count($entries) > 50) {
                return new WP_Error('bad_request', 'Max 50 entries per batch', ['status' => 400]);
            }

            $results = [];
            $created = 0;
            foreach ($entries as $i => $entry) {
                $r = $save_single_entry($entry);
                $r['index'] = $i;
                $results[] = $r;
                if ($r['status'] === 'created') $created++;
            }

            return new WP_REST_Response([
                'success' => true, 'total' => count($entries),
                'created' => $created, 'results' => $results,
            ], 200);
        },
    ]);

    // GET /wp-json/brand-voice/v1/meta — ดึง brands/categories/models/platforms (สำหรับ Extension)
    register_rest_route('brand-voice/v1', '/meta', [
        'methods'  => 'GET',
        'permission_callback' => $api_permission,
        'callback' => function() {
            return new WP_REST_Response([
                'brands'     => bv_get_brands(),
                'categories' => bv_get_categories(),
                'models'     => bv_get_models(),
                'platforms'  => bv_get_platforms(),
            ], 200);
        },
    ]);

    // POST /wp-json/brand-voice/v1/entries/ai-bulk — รับ post+comments แล้ว AI วิเคราะห์ทีละอัน
    register_rest_route('brand-voice/v1', '/entries/ai-bulk', [
        'methods'  => 'POST',
        'permission_callback' => $api_permission,
        'callback' => function(WP_REST_Request $req) use ($save_single_entry) {
            $body = $req->get_json_params();
            $post_data = $body['post'] ?? null;
            $comments  = $body['comments'] ?? [];
            $raw_text  = sanitize_textarea_field($body['raw_text'] ?? '');
            $source_url  = esc_url_raw($body['url'] ?? '');
            $platform    = sanitize_text_field($body['platform'] ?? 'other');
            $source_name = sanitize_text_field($body['source_name'] ?? '');

            if (!$post_data && empty($comments) && !$raw_text) {
                return new WP_Error('bad_request', 'post, comments, or raw_text required', ['status' => 400]);
            }

            // Build items (max 40 comments + 1 post = 41 items)
            $items = [];
            if ($post_data && !empty($post_data['text'])) {
                $items[] = ['type' => 'post', 'author' => $post_data['author'] ?? '', 'text' => $post_data['text']];
            }
            $comment_limit = min(count($comments), 40);
            for ($ci = 0; $ci < $comment_limit; $ci++) {
                $c = $comments[$ci];
                if (!empty($c['text']) && mb_strlen($c['text']) >= 3) {
                    $items[] = ['type' => 'comment', 'author' => $c['author'] ?? '', 'text' => $c['text']];
                }
            }

            // Fallback: raw_text → ส่ง AI แยก post/comments ให้
